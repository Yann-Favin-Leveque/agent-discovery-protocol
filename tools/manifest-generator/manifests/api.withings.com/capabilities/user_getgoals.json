{
  "name": "user_getgoals",
  "description": "Retrieve the user's health goals for weight, steps, and sleep.",
  "resource_group": "user",
  "endpoint": "/v2/user",
  "method": "POST",
  "parameters": [
    {
      "name": "action",
      "type": "string",
      "required": true,
      "description": "Must be 'getgoals'."
    }
  ],
  "auth_scopes": [
    "user.info"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://wbsapi.withings.net/v2/user",
    "headers": {
      "Authorization": "Bearer TOKEN",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "action": "getgoals"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": 0,
      "body": {
        "goals": {
          "weight": 70000,
          "steps": 10000,
          "sleep": 28800
        }
      }
    }
  }
}