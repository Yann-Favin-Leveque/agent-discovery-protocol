{
  "name": "request_time_off",
  "description": "Submit a time-off request for an employee specifying the start and end dates, time-off type, and amount per day. The request will go through the normal approval workflow.",
  "endpoint": "/api/gateway.php/{company_domain}/v1/employees/{employee_id}/time_off/request",
  "method": "PUT",
  "parameters": [
    { "name": "company_domain", "type": "string", "description": "Your BambooHR company subdomain.", "required": true, "example": "mycompany" },
    { "name": "employee_id", "type": "integer", "description": "The employee's unique ID.", "required": true, "example": 123 },
    { "name": "timeOffTypeId", "type": "integer", "description": "The ID of the time-off type (e.g., vacation, sick leave).", "required": true, "example": 1 },
    { "name": "start", "type": "string", "description": "Start date in YYYY-MM-DD format.", "required": true, "example": "2026-04-01" },
    { "name": "end", "type": "string", "description": "End date in YYYY-MM-DD format.", "required": true, "example": "2026-04-05" },
    { "name": "notes", "type": "string", "description": "Notes or reason for the time-off request.", "required": false, "example": "Family vacation" }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/employees/123/time_off/request",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "body": {
      "status": "requested",
      "start": "2026-04-01",
      "end": "2026-04-05",
      "timeOffTypeId": 1,
      "amount": 5,
      "notes": [
        { "from": "employee", "note": "Family vacation" }
      ],
      "dates": {
        "2026-04-01": 8,
        "2026-04-02": 8,
        "2026-04-03": 8,
        "2026-04-04": 8,
        "2026-04-05": 8
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 789,
      "employeeId": 123,
      "status": { "status": "requested", "lastChanged": "2026-03-01" },
      "start": "2026-04-01",
      "end": "2026-04-05",
      "type": { "id": 1, "name": "Vacation" },
      "amount": { "unit": "hours", "amount": 40 }
    }
  }
}
