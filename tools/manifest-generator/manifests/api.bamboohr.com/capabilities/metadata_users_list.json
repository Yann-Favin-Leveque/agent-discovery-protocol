{
  "name": "metadata_users_list",
  "description": "List all BambooHR system users (admins and staff who can log in) and their access levels.",
  "endpoint": "/api/gateway.php/{companyDomain}/v1/meta/users/",
  "method": "GET",
  "resource_group": "metadata",
  "parameters": [
    {
      "name": "companyDomain",
      "type": "string",
      "description": "Your BambooHR subdomain.",
      "required": true,
      "example": "mycompany",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/meta/users/",
    "headers": {
      "Authorization": "Basic {base64(apikey:x)}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "1": {
        "employeeId": 123,
        "firstName": "John",
        "lastName": "Doe",
        "email": "john@company.com",
        "status": "enabled"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
