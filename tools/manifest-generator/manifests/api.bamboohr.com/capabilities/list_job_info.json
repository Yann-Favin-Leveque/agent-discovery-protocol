{
  "name": "list_job_info",
  "description": "Get the job information history for an employee including title changes, department transfers, compensation adjustments, and reporting structure changes. Returns a chronological list of all job info records.",
  "endpoint": "/api/gateway.php/{company_domain}/v1/employees/{employee_id}/tables/jobInfo",
  "method": "GET",
  "parameters": [
    { "name": "company_domain", "type": "string", "description": "Your BambooHR company subdomain.", "required": true, "example": "mycompany" },
    { "name": "employee_id", "type": "integer", "description": "The employee's unique ID.", "required": true, "example": 123 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/employees/123/tables/jobInfo",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "employeeId": 123,
        "date": "2023-06-15",
        "department": "Engineering",
        "division": "Product",
        "jobTitle": "Junior Developer",
        "reportsTo": "Mike Manager",
        "location": "San Francisco"
      },
      {
        "id": 2,
        "employeeId": 123,
        "date": "2025-01-01",
        "department": "Engineering",
        "division": "Product",
        "jobTitle": "Senior Developer",
        "reportsTo": "Mike Manager",
        "location": "San Francisco"
      }
    ]
  }
}
