{
  "name": "tables_get_rows",
  "description": "Get tabular data rows for an employee (job info, compensation, emergency contacts, etc.).",
  "endpoint": "/api/gateway.php/{companyDomain}/v1/employees/{employeeId}/tables/{tableName}",
  "method": "GET",
  "resource_group": "tables",
  "parameters": [
    {"name": "companyDomain", "type": "string", "description": "Your BambooHR subdomain.", "required": true, "example": "mycompany"},
    {"name": "employeeId", "type": "integer", "description": "Employee ID.", "required": true, "example": 123},
    {"name": "tableName", "type": "string", "description": "Table name (jobInfo, compensation, emergencyContacts, etc.).", "required": true, "example": "jobInfo"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/employees/123/tables/jobInfo",
    "headers": {"Authorization": "Basic {base64(apikey:x)}", "Accept": "application/json"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": 1, "employeeId": 123, "date": "2024-01-15", "jobTitle": "Senior Engineer", "department": "Engineering", "reportsTo": "Jane Manager"}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 60}
}
