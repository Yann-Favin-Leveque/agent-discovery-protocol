{
  "name": "time_off_policies_list",
  "description": "List all time-off policies available for assignment to employees.",
  "endpoint": "/api/gateway.php/{companyDomain}/v1/meta/time_off/policies/",
  "method": "GET",
  "resource_group": "time_off",
  "parameters": [
    {
      "name": "companyDomain",
      "type": "string",
      "description": "Your BambooHR subdomain.",
      "required": true,
      "example": "mycompany",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/meta/time_off/policies/",
    "headers": {
      "Authorization": "Basic {base64(apikey:x)}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "name": "Standard PTO",
        "timeOffTypeId": 1,
        "accrualRate": "10 days/year"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
