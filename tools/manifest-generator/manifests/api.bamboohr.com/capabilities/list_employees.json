{
  "name": "list_employees",
  "description": "Get a directory of all employees in the company with their basic information like name, department, job title, work email, and employment status. Uses the employee directory endpoint which returns a simplified employee list.",
  "endpoint": "/api/gateway.php/{company_domain}/v1/employees/directory",
  "method": "GET",
  "parameters": [
    { "name": "company_domain", "type": "string", "description": "Your BambooHR company subdomain.", "required": true, "example": "mycompany" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/employees/directory",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "fields": [
        { "id": "displayName", "type": "text", "name": "Display name" },
        { "id": "department", "type": "list", "name": "Department" },
        { "id": "jobTitle", "type": "list", "name": "Job Title" }
      ],
      "employees": [
        {
          "id": "123",
          "displayName": "Jane Doe",
          "department": "Engineering",
          "jobTitle": "Senior Developer",
          "workEmail": "jane@mycompany.com",
          "workPhone": "+1-555-0100",
          "photoUrl": "https://resources.bamboohr.com/images/photo.jpg"
        }
      ]
    }
  }
}
