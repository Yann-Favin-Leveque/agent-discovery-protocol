{
  "name": "metadata_fields_list",
  "description": "Retrieve metadata about all employee fields available in your BambooHR account.",
  "endpoint": "/api/gateway.php/{companyDomain}/v1/meta/fields/",
  "method": "GET",
  "resource_group": "metadata",
  "parameters": [
    {
      "name": "companyDomain",
      "type": "string",
      "description": "Your BambooHR subdomain.",
      "required": true,
      "example": "mycompany",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/meta/fields/",
    "headers": {
      "Authorization": "Basic {base64(apikey:x)}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 4,
        "name": "First Name",
        "type": "text",
        "alias": "firstName"
      },
      {
        "id": 5,
        "name": "Last Name",
        "type": "text",
        "alias": "lastName"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
