{
  "name": "list_time_off_requests",
  "description": "List time-off requests across the company with optional filtering by employee, status, or date range. Returns request details including type, dates, status, and approval information.",
  "endpoint": "/api/gateway.php/{company_domain}/v1/time_off/requests",
  "method": "GET",
  "parameters": [
    { "name": "company_domain", "type": "string", "description": "Your BambooHR company subdomain.", "required": true, "example": "mycompany" },
    { "name": "start", "type": "string", "description": "Filter requests starting on or after this date (YYYY-MM-DD).", "required": false, "example": "2026-01-01" },
    { "name": "end", "type": "string", "description": "Filter requests ending on or before this date (YYYY-MM-DD).", "required": false, "example": "2026-12-31" },
    { "name": "status", "type": "string", "description": "Filter by status: 'approved', 'denied', 'requested', 'canceled'.", "required": false, "example": "approved" },
    { "name": "employeeId", "type": "integer", "description": "Filter by a specific employee ID.", "required": false, "example": 123 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/time_off/requests?start=2026-01-01&end=2026-12-31&status=approved",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 789,
        "employeeId": 123,
        "status": { "status": "approved", "lastChanged": "2026-03-02", "lastChangedByUserId": 1 },
        "name": "Jane Doe",
        "start": "2026-04-01",
        "end": "2026-04-05",
        "type": { "id": 1, "name": "Vacation" },
        "amount": { "unit": "hours", "amount": 40 },
        "notes": {
          "employee": "Family vacation",
          "manager": "Approved. Enjoy!"
        },
        "created": "2026-03-01"
      }
    ]
  }
}
