{
  "name": "webhooks_create",
  "description": "Create a new webhook to receive notifications when employee data changes.",
  "endpoint": "/api/gateway.php/{companyDomain}/v1/webhooks/",
  "method": "POST",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "companyDomain",
      "type": "string",
      "description": "Your BambooHR subdomain.",
      "required": true,
      "example": "mycompany",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Webhook name.",
      "required": true,
      "example": "Employee Update Webhook",
      "in": "body"
    },
    {
      "name": "monitorFields",
      "type": "array",
      "description": "Fields to monitor for changes.",
      "required": true,
      "example": [
        "firstName",
        "lastName",
        "jobTitle"
      ],
      "in": "body"
    },
    {
      "name": "postFields",
      "type": "object",
      "description": "Fields to include in webhook payload.",
      "required": false,
      "example": {
        "firstName": "First Name"
      },
      "in": "body"
    },
    {
      "name": "url",
      "type": "string",
      "description": "URL to receive webhook POST requests.",
      "required": true,
      "example": "https://myapp.com/webhooks/bamboo",
      "in": "body"
    },
    {
      "name": "format",
      "type": "string",
      "description": "Payload format: json or form.",
      "required": false,
      "example": "json",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/webhooks/",
    "headers": {
      "Authorization": "Basic {base64(apikey:x)}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Employee Updates",
      "monitorFields": [
        "jobTitle",
        "department"
      ],
      "url": "https://myapp.com/webhooks/bamboo",
      "format": "json"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2,
      "name": "Employee Updates"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
