{
  "name": "metadata_tables_list",
  "description": "List all tabular data tables and their fields available in BambooHR (job info, compensation, etc.).",
  "endpoint": "/api/gateway.php/{companyDomain}/v1/meta/tables/",
  "method": "GET",
  "resource_group": "metadata",
  "parameters": [
    {"name": "companyDomain", "type": "string", "description": "Your BambooHR subdomain.", "required": true, "example": "mycompany"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/meta/tables/",
    "headers": {"Authorization": "Basic {base64(apikey:x)}", "Accept": "application/json"}
  },
  "response_example": {
    "status": 200,
    "body": [{"alias": "jobInfo", "fields": [{"id": 17, "name": "Date", "alias": "date", "type": "date"}]}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 60}
}
