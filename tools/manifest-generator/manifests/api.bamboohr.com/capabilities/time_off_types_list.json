{
  "name": "time_off_types_list",
  "description": "List all time-off types configured for the company (vacation, sick, personal, etc.).",
  "endpoint": "/api/gateway.php/{companyDomain}/v1/meta/time_off/types/",
  "method": "GET",
  "resource_group": "time_off",
  "parameters": [
    {"name": "companyDomain", "type": "string", "description": "Your BambooHR subdomain.", "required": true, "example": "mycompany"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/meta/time_off/types/",
    "headers": {"Authorization": "Basic {base64(apikey:x)}", "Accept": "application/json"}
  },
  "response_example": {
    "status": 200,
    "body": {"timeOffTypes": [{"id": 1, "name": "Vacation", "units": "days"}, {"id": 2, "name": "Sick Leave", "units": "days"}]}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 60}
}
