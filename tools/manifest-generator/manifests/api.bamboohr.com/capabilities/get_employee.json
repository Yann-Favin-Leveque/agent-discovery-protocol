{
  "name": "get_employee",
  "description": "Get detailed information about a specific employee by their ID. You can request specific fields or use 'all' to get everything including personal data, job information, compensation, and custom fields.",
  "endpoint": "/api/gateway.php/{company_domain}/v1/employees/{employee_id}",
  "method": "GET",
  "parameters": [
    { "name": "company_domain", "type": "string", "description": "Your BambooHR company subdomain.", "required": true, "example": "mycompany" },
    { "name": "employee_id", "type": "integer", "description": "The employee's unique ID.", "required": true, "example": 123 },
    { "name": "fields", "type": "string", "description": "Comma-separated list of fields to return, or 'all' for everything.", "required": false, "example": "firstName,lastName,department,jobTitle,hireDate" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bamboohr.com/api/gateway.php/mycompany/v1/employees/123?fields=firstName,lastName,department,jobTitle,hireDate,workEmail",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "123",
      "firstName": "Jane",
      "lastName": "Doe",
      "department": "Engineering",
      "jobTitle": "Senior Developer",
      "hireDate": "2023-06-15",
      "workEmail": "jane@mycompany.com"
    }
  }
}
