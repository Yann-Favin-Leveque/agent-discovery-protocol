{
  "name": "items_get_by_path",
  "description": "Get a DriveItem by its path relative to the root.",
  "resource_group": "items",
  "endpoint": "/v1.0/me/drive/root:/{item-path}",
  "method": "GET",
  "parameters": [
    {
      "name": "item-path",
      "type": "string",
      "description": "Path relative to root.",
      "required": true,
      "example": "Documents/report.pdf"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/me/drive/root:/Documents/report.pdf",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "item123",
      "name": "report.pdf"
    }
  }
}