{
  "name": "thumbnails_list",
  "description": "Get thumbnails for a DriveItem.",
  "resource_group": "thumbnails",
  "endpoint": "/v1.0/me/drive/items/{item-id}/thumbnails",
  "method": "GET",
  "parameters": [
    {
      "name": "item-id",
      "type": "string",
      "description": "The item ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/me/drive/items/item123/thumbnails",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "value": [
        {
          "id": "0",
          "small": {
            "url": "https://...",
            "width": 96,
            "height": 96
          },
          "medium": {
            "url": "https://..."
          },
          "large": {
            "url": "https://..."
          }
        }
      ]
    }
  }
}