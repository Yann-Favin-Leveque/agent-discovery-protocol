{
  "name": "permissions_list",
  "description": "List permissions on a DriveItem.",
  "resource_group": "permissions",
  "endpoint": "/v1.0/me/drive/items/{item-id}/permissions",
  "method": "GET",
  "parameters": [
    {
      "name": "item-id",
      "type": "string",
      "description": "The item ID.",
      "required": true,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/me/drive/items/item123/permissions",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "value": [
        {
          "id": "perm123",
          "roles": [
            "read"
          ],
          "grantedTo": {
            "user": {
              "displayName": "Jane Doe"
            }
          }
        }
      ]
    }
  }
}
