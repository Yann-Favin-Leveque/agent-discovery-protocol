{
  "name": "drives_get_by_id",
  "description": "Get a specific drive by its ID.",
  "resource_group": "drives",
  "endpoint": "/v1.0/drives/{drive-id}",
  "method": "GET",
  "parameters": [
    {
      "name": "drive-id",
      "type": "string",
      "description": "The drive ID.",
      "required": true,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/drives/drive123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "drive123",
      "driveType": "personal"
    }
  }
}
