{
  "name": "permissions_delete",
  "description": "Remove a permission from a DriveItem.",
  "resource_group": "permissions",
  "endpoint": "/v1.0/me/drive/items/{item-id}/permissions/{perm-id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "item-id",
      "type": "string",
      "description": "The item ID.",
      "required": true
    },
    {
      "name": "perm-id",
      "type": "string",
      "description": "The permission ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://graph.microsoft.com/v1.0/me/drive/items/item123/permissions/perm123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  }
}