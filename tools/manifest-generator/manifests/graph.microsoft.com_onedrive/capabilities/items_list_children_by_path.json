{
  "name": "items_list_children_by_path",
  "description": "List children of a folder by its path.",
  "resource_group": "items",
  "endpoint": "/v1.0/me/drive/root:/{folder-path}:/children",
  "method": "GET",
  "parameters": [
    {
      "name": "folder-path",
      "type": "string",
      "description": "Folder path relative to root.",
      "required": true,
      "example": "Documents"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/me/drive/root:/Documents:/children",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "value": [
        {
          "id": "item123",
          "name": "report.pdf"
        }
      ]
    }
  }
}