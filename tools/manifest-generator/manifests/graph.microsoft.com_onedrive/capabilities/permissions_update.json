{
  "name": "permissions_update",
  "description": "Update a permission on a DriveItem.",
  "resource_group": "permissions",
  "endpoint": "/v1.0/me/drive/items/{item-id}/permissions/{perm-id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "item-id",
      "type": "string",
      "description": "The item ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "perm-id",
      "type": "string",
      "description": "The permission ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "roles",
      "type": "array",
      "description": "Updated roles: read, write.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://graph.microsoft.com/v1.0/me/drive/items/item123/permissions/perm123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "roles": [
        "write"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "perm123",
      "roles": [
        "write"
      ]
    }
  }
}
