{
  "name": "special_folders_get",
  "description": "Get a special folder by name (e.g. documents, photos, music).",
  "resource_group": "special_folders",
  "endpoint": "/v1.0/me/drive/special/{special-folder-name}",
  "method": "GET",
  "parameters": [
    {
      "name": "special-folder-name",
      "type": "string",
      "description": "Special folder name: documents, photos, music, etc.",
      "required": true,
      "example": "documents"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/me/drive/special/documents",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "folder789",
      "name": "Documents",
      "folder": {
        "childCount": 15
      }
    }
  }
}