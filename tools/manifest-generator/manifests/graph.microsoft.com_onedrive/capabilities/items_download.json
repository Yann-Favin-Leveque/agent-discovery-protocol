{
  "name": "items_download",
  "description": "Download the content of a file.",
  "resource_group": "items",
  "endpoint": "/v1.0/me/drive/items/{item-id}/content",
  "method": "GET",
  "parameters": [
    {
      "name": "item-id",
      "type": "string",
      "description": "The file item ID.",
      "required": true,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.microsoft.com/v1.0/me/drive/items/item123/content",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 302,
    "body": "<redirect to download URL>"
  }
}
