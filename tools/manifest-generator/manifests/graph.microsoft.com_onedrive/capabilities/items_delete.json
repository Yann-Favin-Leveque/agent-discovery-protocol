{
  "name": "items_delete",
  "description": "Delete a DriveItem (move to recycle bin).",
  "resource_group": "items",
  "endpoint": "/v1.0/me/drive/items/{item-id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "item-id",
      "type": "string",
      "description": "The item ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://graph.microsoft.com/v1.0/me/drive/items/item123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  }
}