{
  "name": "search_query",
  "description": "Search for coins, categories, and exchanges by keyword.",
  "resource_group": "search",
  "endpoint": "/search",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "Search query string.",
      "required": true,
      "example": "bitcoin",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coingecko.com/api/v3/search?query=bitcoin",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "coins": [
        {
          "id": "bitcoin",
          "name": "Bitcoin",
          "symbol": "BTC",
          "market_cap_rank": 1,
          "thumb": "https://assets.coingecko.com/coins/images/1/thumb/bitcoin.png"
        }
      ],
      "exchanges": [],
      "categories": [
        {
          "id": 150,
          "name": "Bitcoin Fork"
        }
      ]
    }
  },
  "rate_limits": {
    "requests_per_minute": 30
  }
}
