{
  "name": "coins_history",
  "description": "Get historical data (price, market cap, volume) for a coin on a specific date.",
  "resource_group": "coins",
  "endpoint": "/coins/{id}/history",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Coin ID.",
      "required": true,
      "example": "bitcoin",
      "in": "path"
    },
    {
      "name": "date",
      "type": "string",
      "description": "Date in dd-mm-yyyy format.",
      "required": true,
      "example": "15-01-2024",
      "in": "query"
    },
    {
      "name": "localization",
      "type": "boolean",
      "description": "Include localized languages.",
      "required": false,
      "example": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coingecko.com/api/v3/coins/bitcoin/history?date=15-01-2024&localization=false",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "bitcoin",
      "symbol": "btc",
      "name": "Bitcoin",
      "market_data": {
        "current_price": {
          "usd": 42800
        },
        "market_cap": {
          "usd": 840000000000
        },
        "total_volume": {
          "usd": 22000000000
        }
      }
    }
  },
  "rate_limits": {
    "requests_per_minute": 30
  }
}
