{
  "name": "exchanges_get",
  "description": "Get detailed data for a specific exchange including name, trust score, volume, and social links.",
  "resource_group": "exchanges",
  "endpoint": "/exchanges/{id}",
  "method": "GET",
  "parameters": [
    {"name": "id", "type": "string", "description": "Exchange ID.", "required": true, "example": "binance"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coingecko.com/api/v3/exchanges/binance",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "Binance",
      "year_established": 2017,
      "country": "Cayman Islands",
      "url": "https://www.binance.com/",
      "trust_score": 10,
      "trust_score_rank": 1,
      "trade_volume_24h_btc": 350000.5,
      "tickers": []
    }
  },
  "rate_limits": {"requests_per_minute": 30}
}