{
  "name": "coins_markets",
  "description": "Get market data for coins including price, market cap, volume, price change, and optional sparkline chart data. Supports sorting and pagination.",
  "resource_group": "coins",
  "endpoint": "/coins/markets",
  "method": "GET",
  "parameters": [
    {"name": "vs_currency", "type": "string", "description": "Target currency for market data.", "required": true, "example": "usd"},
    {"name": "ids", "type": "string", "description": "Comma-separated coin IDs to filter.", "required": false, "example": "bitcoin,ethereum"},
    {"name": "category", "type": "string", "description": "Filter by category (e.g., defi, stablecoins).", "required": false},
    {"name": "order", "type": "string", "description": "Sort order: market_cap_desc, gecko_desc, volume_desc, etc.", "required": false, "example": "market_cap_desc"},
    {"name": "per_page", "type": "integer", "description": "Results per page (1-250, default 100).", "required": false, "example": 100},
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 1},
    {"name": "sparkline", "type": "boolean", "description": "Include 7-day sparkline data.", "required": false, "example": false},
    {"name": "price_change_percentage", "type": "string", "description": "Include price change for periods: 1h,24h,7d,14d,30d,200d,1y.", "required": false, "example": "24h,7d"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=10&page=1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "bitcoin",
        "symbol": "btc",
        "name": "Bitcoin",
        "image": "https://assets.coingecko.com/coins/images/1/large/bitcoin.png",
        "current_price": 43250.50,
        "market_cap": 847000000000,
        "market_cap_rank": 1,
        "total_volume": 25000000000,
        "price_change_percentage_24h": 2.15,
        "last_updated": "2024-01-15T10:30:00.000Z"
      }
    ]
  },
  "rate_limits": {"requests_per_minute": 30}
}