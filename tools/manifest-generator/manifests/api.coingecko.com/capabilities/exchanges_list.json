{
  "name": "exchanges_list",
  "description": "List all supported exchanges with name, country, trust score, trading volume, and metadata.",
  "resource_group": "exchanges",
  "endpoint": "/exchanges",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page (1-250, default 100).",
      "required": false,
      "example": 100,
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coingecko.com/api/v3/exchanges?per_page=10&page=1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "binance",
        "name": "Binance",
        "year_established": 2017,
        "country": "Cayman Islands",
        "trust_score": 10,
        "trade_volume_24h_btc": 350000.5
      }
    ]
  },
  "rate_limits": {
    "requests_per_minute": 30
  }
}
