{
  "name": "calls_get",
  "resource_group": "calls",
  "description": "Retrieve a specific call by SID.",
  "endpoint": "/2010-04-01/Accounts/{AccountSid}/Calls/{CallSid}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "AccountSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Account SID",
      "example": "ACXXX"
    },
    {
      "name": "CallSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Call SID",
      "example": "CAXXX"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.twilio.com/2010-04-01/Accounts/ACXXX/Calls/CAXXX.json",
    "headers": {
      "Authorization": "Basic BASE64(AccountSid:AuthToken)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sid": "CAXXX",
      "status": "completed",
      "duration": "45"
    }
  }
}