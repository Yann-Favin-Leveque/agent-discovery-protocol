{
  "name": "messages_get",
  "resource_group": "messages",
  "description": "Retrieve a specific message by SID.",
  "endpoint": "/2010-04-01/Accounts/{AccountSid}/Messages/{MessageSid}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "AccountSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Account SID",
      "example": "ACXXX"
    },
    {
      "name": "MessageSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Message SID",
      "example": "SMXXX"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.twilio.com/2010-04-01/Accounts/ACXXX/Messages/SMXXX.json",
    "headers": {
      "Authorization": "Basic BASE64(AccountSid:AuthToken)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sid": "SMXXX",
      "to": "+15558675310",
      "body": "Hello!",
      "status": "delivered"
    }
  }
}