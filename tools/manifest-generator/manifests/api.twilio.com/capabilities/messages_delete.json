{
  "name": "messages_delete",
  "resource_group": "messages",
  "description": "Delete a message by SID.",
  "endpoint": "/2010-04-01/Accounts/{AccountSid}/Messages/{MessageSid}.json",
  "method": "DELETE",
  "parameters": [
    {
      "name": "AccountSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Account SID",
      "example": "ACXXX"
    },
    {
      "name": "MessageSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Message SID",
      "example": "SMXXX"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.twilio.com/2010-04-01/Accounts/ACXXX/Messages/SMXXX.json",
    "headers": {
      "Authorization": "Basic BASE64(AccountSid:AuthToken)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}