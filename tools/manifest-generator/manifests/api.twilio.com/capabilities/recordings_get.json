{
  "name": "recordings_get",
  "resource_group": "recordings",
  "description": "Retrieve a specific recording.",
  "endpoint": "/2010-04-01/Accounts/{AccountSid}/Recordings/{RecordingSid}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "AccountSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Account SID",
      "example": "ACXXX"
    },
    {
      "name": "RecordingSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Recording SID",
      "example": "REXXX"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.twilio.com/2010-04-01/Accounts/ACXXX/Recordings/REXXX.json",
    "headers": {
      "Authorization": "Basic BASE64(AccountSid:AuthToken)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sid": "REXXX",
      "duration": "45",
      "channels": 1
    }
  }
}