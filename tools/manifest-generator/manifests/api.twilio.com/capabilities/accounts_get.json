{
  "name": "accounts_get",
  "resource_group": "accounts",
  "description": "Retrieve account information.",
  "endpoint": "/2010-04-01/Accounts/{AccountSid}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "AccountSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Account SID",
      "example": "ACXXX"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.twilio.com/2010-04-01/Accounts/ACXXX.json",
    "headers": {
      "Authorization": "Basic BASE64(AccountSid:AuthToken)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sid": "ACXXX",
      "friendly_name": "My Account",
      "status": "active",
      "type": "Full"
    }
  }
}