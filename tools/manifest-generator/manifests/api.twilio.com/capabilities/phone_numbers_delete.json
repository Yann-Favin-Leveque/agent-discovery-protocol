{
  "name": "phone_numbers_delete",
  "resource_group": "phone_numbers",
  "description": "Release a phone number from the account.",
  "endpoint": "/2010-04-01/Accounts/{AccountSid}/IncomingPhoneNumbers/{PhoneNumberSid}.json",
  "method": "DELETE",
  "parameters": [
    {
      "name": "AccountSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Account SID",
      "example": "ACXXX"
    },
    {
      "name": "PhoneNumberSid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Phone number SID",
      "example": "PNXXX"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.twilio.com/2010-04-01/Accounts/ACXXX/IncomingPhoneNumbers/PNXXX.json",
    "headers": {
      "Authorization": "Basic BASE64(AccountSid:AuthToken)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}