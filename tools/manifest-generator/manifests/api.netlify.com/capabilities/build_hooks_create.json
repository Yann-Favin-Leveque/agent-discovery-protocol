{
  "name": "build_hooks_create",
  "description": "Create a build hook (URL to trigger deploys).",
  "endpoint": "/api/v1/sites/{site_id}/build_hooks",
  "method": "POST",
  "resource_group": "build_hooks",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "description": "Site ID",
      "required": true,
      "example": "site_abc",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "description": "Build hook title",
      "required": true,
      "example": "CMS publish",
      "in": "body"
    },
    {
      "name": "branch",
      "type": "string",
      "description": "Git branch to build",
      "required": false,
      "example": "main",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.netlify.com/api/v1/sites/{site_id}/build_hooks",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
