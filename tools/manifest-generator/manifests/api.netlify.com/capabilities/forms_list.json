{
  "name": "forms_list",
  "description": "List all forms detected on a deployed site.",
  "endpoint": "/api/v1/sites/{site_id}/forms",
  "method": "GET",
  "resource_group": "forms",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "description": "Site ID",
      "required": true,
      "example": "site_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/sites/{site_id}/forms",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "form_1",
        "name": "contact",
        "submission_count": 42
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}