{
  "name": "list_deploys",
  "description": "List all deploys for a specific Netlify site. Returns deploy IDs, states (ready, building, error, enqueued), timestamps, commit messages, branch names, and individual deploy URLs. Supports pagination.",
  "endpoint": "/api/v1/sites/{site_id}/deploys",
  "method": "GET",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "required": true,
      "description": "The site ID (UUID) to list deploys for."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default is 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of deploys per page. Default is 100."
    },
    {
      "name": "branch",
      "type": "string",
      "required": false,
      "description": "Filter deploys by Git branch name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/sites/a1b2c3d4-5678-90ab-cdef-1234567890ab/deploys?per_page=5"
  },
