{
  "name": "rollback_deploy",
  "description": "Rollback a Netlify site to a previous deploy. This restores the site to the state of an earlier successful deployment without triggering a new build. The previous deploy becomes the new published deploy instantly. Useful for quick recovery from broken deployments.",
  "endpoint": "/api/v1/sites/{site_id}/rollback",
  "method": "POST",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "required": true,
      "description": "The site ID (UUID) to rollback."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.netlify.com/api/v1/sites/a1b2c3d4-5678-90ab-cdef-1234567890ab/rollback",
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "response_example": {
