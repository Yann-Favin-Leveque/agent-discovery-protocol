{
  "name": "deploys_get",
  "description": "Get details for a specific deploy.",
  "endpoint": "/api/v1/sites/{site_id}/deploys/{deploy_id}",
  "method": "GET",
  "resource_group": "deploys",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "description": "Site ID",
      "required": true,
      "example": "site_abc",
      "in": "path"
    },
    {
      "name": "deploy_id",
      "type": "string",
      "description": "Deploy ID",
      "required": true,
      "example": "deploy_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/sites/{site_id}/deploys/{deploy_id}",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "deploy_123",
      "state": "ready",
      "deploy_url": "https://deploy-123--my-site.netlify.app"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
