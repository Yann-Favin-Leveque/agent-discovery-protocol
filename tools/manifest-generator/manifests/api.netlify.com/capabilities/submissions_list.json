{
  "name": "submissions_list",
  "description": "List all submissions for a specific form.",
  "endpoint": "/api/v1/forms/{form_id}/submissions",
  "method": "GET",
  "resource_group": "forms",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "description": "Form ID",
      "required": true,
      "example": "form_1"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/forms/{form_id}/submissions",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "sub_1",
        "data": {
          "name": "John",
          "email": "john@example.com"
        },
        "created_at": "2025-01-15T10:00:00Z"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}