{
  "name": "sites_list",
  "description": "List all sites in your Netlify account with deployment status and URLs.",
  "endpoint": "/api/v1/sites",
  "method": "GET",
  "resource_group": "sites",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for pagination",
      "required": false,
      "example": 1
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Items per page",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/sites",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "site_abc",
        "name": "my-site",
        "url": "https://my-site.netlify.app",
        "ssl_url": "https://my-site.netlify.app"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}