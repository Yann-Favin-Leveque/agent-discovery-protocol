{
  "name": "env_vars_update",
  "description": "Update an environment variable.",
  "endpoint": "/api/v1/env/{env_id}",
  "method": "PUT",
  "resource_group": "env_vars",
  "parameters": [
    {
      "name": "env_id",
      "type": "string",
      "description": "Environment variable ID",
      "required": true,
      "example": "env_abc",
      "in": "path"
    },
    {
      "name": "key",
      "type": "string",
      "description": "Variable name",
      "required": true,
      "example": "API_KEY",
      "in": "body"
    },
    {
      "name": "values",
      "type": "array",
      "description": "Updated values",
      "required": true,
      "example": [
        {
          "value": "newsecret",
          "context": "production"
        }
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.netlify.com/api/v1/env/{env_id}",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
