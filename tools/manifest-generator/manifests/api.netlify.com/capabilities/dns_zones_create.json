{
  "name": "dns_zones_create",
  "description": "Create a new DNS zone.",
  "endpoint": "/api/v1/dns_zones",
  "method": "POST",
  "resource_group": "dns",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Domain name for the DNS zone",
      "required": true,
      "example": "example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.netlify.com/api/v1/dns_zones",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}