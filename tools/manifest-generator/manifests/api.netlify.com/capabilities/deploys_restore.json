{
  "name": "deploys_restore",
  "description": "Restore a previous deploy, making it the live version of the site.",
  "endpoint": "/api/v1/sites/{site_id}/deploys/{deploy_id}/restore",
  "method": "POST",
  "resource_group": "deploys",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "description": "Site ID",
      "required": true,
      "example": "site_abc"
    },
    {
      "name": "deploy_id",
      "type": "string",
      "description": "Deploy ID to restore",
      "required": true,
      "example": "deploy_old"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.netlify.com/api/v1/sites/{site_id}/deploys/{deploy_id}/restore",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}