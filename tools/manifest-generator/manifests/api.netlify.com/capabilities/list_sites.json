{
  "name": "list_sites",
  "description": "List all sites in your Netlify account. Returns site names, IDs, URLs, custom domains, SSL status, and the current published deploy. Supports filtering by name and pagination.",
  "endpoint": "/api/v1/sites",
  "method": "GET",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter sites by name (exact match)."
    },
    {
      "name": "filter",
      "type": "string",
      "required": false,
      "description": "Filter type: 'all', 'owner', 'guest'. Default is 'all'."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default is 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of sites per page. Default is 100."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/sites?per_page=10"
  },
  "response_example": [
