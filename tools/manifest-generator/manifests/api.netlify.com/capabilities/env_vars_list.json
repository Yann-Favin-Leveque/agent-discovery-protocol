{
  "name": "env_vars_list",
  "description": "List all environment variables for a site.",
  "endpoint": "/api/v1/sites/{site_id}/env",
  "method": "GET",
  "resource_group": "env_vars",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "description": "Site ID",
      "required": true,
      "example": "site_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/sites/{site_id}/env",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "key": "API_KEY",
        "values": [
          {
            "value": "secret123",
            "context": "production"
          }
        ]
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
