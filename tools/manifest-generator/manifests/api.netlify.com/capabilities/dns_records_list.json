{
  "name": "dns_records_list",
  "description": "List all DNS records in a zone.",
  "endpoint": "/api/v1/dns_zones/{zone_id}/records",
  "method": "GET",
  "resource_group": "dns",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "description": "DNS zone ID",
      "required": true,
      "example": "zone_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.netlify.com/api/v1/dns_zones/{zone_id}/records",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "rec_1",
        "hostname": "www",
        "type": "CNAME",
        "value": "my-site.netlify.app"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
