{
  "name": "snippets_create",
  "description": "Create a code snippet to inject into a site.",
  "endpoint": "/api/v1/sites/{site_id}/snippets",
  "method": "POST",
  "resource_group": "snippets",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "description": "Site ID",
      "required": true,
      "example": "site_abc"
    },
    {
      "name": "title",
      "type": "string",
      "description": "Snippet title",
      "required": true,
      "example": "Analytics"
    },
    {
      "name": "general",
      "type": "string",
      "description": "Code to inject",
      "required": true,
      "example": "<script>...</script>"
    },
    {
      "name": "general_position",
      "type": "string",
      "description": "Position: before_closing_head or before_closing_body",
      "required": true,
      "example": "before_closing_body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.netlify.com/api/v1/sites/{site_id}/snippets",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}