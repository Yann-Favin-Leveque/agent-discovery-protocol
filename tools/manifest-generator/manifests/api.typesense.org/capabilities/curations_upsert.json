{
  "name": "curations_upsert",
  "description": "Create or update a curation set to promote or hide specific search results.",
  "endpoint": "/curation_sets/{curationSetName}",
  "method": "PUT",
  "resource_group": "curations",
  "parameters": [
    {
      "name": "curationSetName",
      "type": "string",
      "description": "Curation set name",
      "required": true,
      "example": "featured_products"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.typesense.org/curation_sets/featured_products",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "featured_products"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "featured_products"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}