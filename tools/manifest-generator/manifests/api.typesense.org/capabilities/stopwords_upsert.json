{
  "name": "stopwords_upsert",
  "description": "Create or update a stopwords set.",
  "endpoint": "/stopwords/{setId}",
  "method": "PUT",
  "resource_group": "stopwords",
  "parameters": [
    {
      "name": "setId",
      "type": "string",
      "description": "Stopwords set ID",
      "required": true,
      "example": "common_words",
      "in": "path"
    },
    {
      "name": "stopwords",
      "type": "array",
      "description": "List of stopwords",
      "required": true,
      "example": [
        "the",
        "a",
        "an"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.typesense.org/stopwords/common_words",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "stopwords": [
        "the",
        "a",
        "an"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "common_words",
      "stopwords": [
        "the",
        "a",
        "an"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
