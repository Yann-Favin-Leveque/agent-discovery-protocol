{
  "name": "presets",
  "description": "Manage presets — upserts a preset, retrieves all presets, retrieves a preset. Supports standard CRUD operations through the REST API.",
  "endpoint": "/presets/{presetId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "presetId",
      "type": "string",
      "description": "The name of the preset set to upsert.",
      "required": true,
      "example": "listing_view"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "{protocol}://{hostname}:{port}/presets/{presetId}",
    "headers": {
      "Content-Type": "application/json",
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {
      "presetId": "listing_view"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "presetId": "listing_view"
      }
    }
  }
}
