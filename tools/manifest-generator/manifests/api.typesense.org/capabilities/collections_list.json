{
  "name": "collections_list",
  "description": "List all collections in the Typesense cluster.",
  "endpoint": "/collections",
  "method": "GET",
  "resource_group": "collections",
  "parameters": [
    {
      "name": "exclude_fields",
      "type": "string",
      "description": "Comma-separated list of fields to exclude from response",
      "required": false,
      "example": "fields",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of collections to return",
      "required": false,
      "example": "10",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of collections to skip",
      "required": false,
      "example": "0",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typesense.org/collections",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "name": "products",
        "num_documents": 1000,
        "fields": []
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
