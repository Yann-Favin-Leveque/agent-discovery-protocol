{
  "name": "collections_delete",
  "description": "Permanently drop a collection and all its documents.",
  "endpoint": "/collections/{collectionName}",
  "method": "DELETE",
  "resource_group": "collections",
  "parameters": [
    {
      "name": "collectionName",
      "type": "string",
      "description": "Name of the collection to delete",
      "required": true,
      "example": "products",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/collections/products",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "products",
      "num_documents": 1000
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
