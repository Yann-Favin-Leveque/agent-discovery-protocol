{
  "name": "synonyms_items_delete",
  "description": "Delete a synonym item from a set.",
  "endpoint": "/synonym_sets/{synonymSetName}/items/{itemId}",
  "method": "DELETE",
  "resource_group": "synonyms",
  "parameters": [
    {
      "name": "synonymSetName",
      "type": "string",
      "description": "Synonym set name",
      "required": true,
      "example": "electronics_synonyms"
    },
    {
      "name": "itemId",
      "type": "string",
      "description": "Synonym item ID",
      "required": true,
      "example": "laptop_syn"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/synonym_sets/electronics_synonyms/items/laptop_syn",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "laptop_syn"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}