{
  "name": "documents_export",
  "description": "Export all documents from a collection as newline-delimited JSON.",
  "endpoint": "/collections/{collectionName}/documents/export",
  "method": "GET",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "collectionName",
      "type": "string",
      "description": "Collection name",
      "required": true,
      "example": "products",
      "in": "path"
    },
    {
      "name": "filter_by",
      "type": "string",
      "description": "Filter expression to limit exported documents",
      "required": false,
      "example": "category:=electronics",
      "in": "query"
    },
    {
      "name": "include_fields",
      "type": "string",
      "description": "Comma-separated list of fields to include",
      "required": false,
      "example": "id,title",
      "in": "query"
    },
    {
      "name": "exclude_fields",
      "type": "string",
      "description": "Comma-separated list of fields to exclude",
      "required": false,
      "example": "description",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typesense.org/collections/products/documents/export",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": "{\"id\":\"1\",\"title\":\"Laptop\"}\n{\"id\":\"2\",\"title\":\"Phone\"}"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
