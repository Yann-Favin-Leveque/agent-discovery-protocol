{
  "name": "synonyms_delete",
  "description": "Delete a synonym set.",
  "endpoint": "/synonym_sets/{synonymSetName}",
  "method": "DELETE",
  "resource_group": "synonyms",
  "parameters": [
    {
      "name": "synonymSetName",
      "type": "string",
      "description": "Synonym set name to delete",
      "required": true,
      "example": "electronics_synonyms",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/synonym_sets/electronics_synonyms",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "electronics_synonyms"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
