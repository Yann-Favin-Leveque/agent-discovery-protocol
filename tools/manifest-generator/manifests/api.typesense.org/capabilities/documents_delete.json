{
  "name": "documents_delete",
  "description": "Delete a single document from a collection by its ID.",
  "endpoint": "/collections/{collectionName}/documents/{documentId}",
  "method": "DELETE",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "collectionName",
      "type": "string",
      "description": "Collection name",
      "required": true,
      "example": "products",
      "in": "path"
    },
    {
      "name": "documentId",
      "type": "string",
      "description": "Document ID",
      "required": true,
      "example": "1",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/collections/products/documents/1",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "1"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
