{
  "name": "keys_delete",
  "description": "Delete an API key.",
  "endpoint": "/keys/{keyId}",
  "method": "DELETE",
  "resource_group": "keys",
  "parameters": [
    {
      "name": "keyId",
      "type": "integer",
      "description": "API key ID to delete",
      "required": true,
      "example": "1"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/keys/1",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}