{
  "name": "stopwords_get",
  "description": "Retrieve a specific stopwords set.",
  "endpoint": "/stopwords/{setId}",
  "method": "GET",
  "resource_group": "stopwords",
  "parameters": [
    {
      "name": "setId",
      "type": "string",
      "description": "Stopwords set ID",
      "required": true,
      "example": "common_words"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typesense.org/stopwords/common_words",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "common_words",
      "stopwords": [
        "the",
        "a",
        "an"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}