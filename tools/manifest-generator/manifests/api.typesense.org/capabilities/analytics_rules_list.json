{
  "name": "analytics_rules_list",
  "description": "Retrieve all analytics rules.",
  "endpoint": "/analytics/rules",
  "method": "GET",
  "resource_group": "analytics",
  "parameters": [
    {
      "name": "rule_tag",
      "type": "string",
      "description": "Filter rules by tag",
      "required": false,
      "example": "clicks"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typesense.org/analytics/rules",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "rules": [
        {
          "name": "product_clicks",
          "type": "counter"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}