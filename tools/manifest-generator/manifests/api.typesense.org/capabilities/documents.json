{
  "name": "documents",
  "description": "Manage documents — send multiple search requests in a single http request, index a document, import documents into a collection. Supports standard CRUD operations through the REST API.",
  "endpoint": "/multi_search",
  "method": "POST",
  "parameters": [
    {
      "name": "multiSearchParameters",
      "type": "string",
      "description": "The multiSearchParameters parameter.",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{protocol}://{hostname}:{port}/multi_search",
    "headers": {
      "Content-Type": "application/json",
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {
      "multiSearchParameters": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "multiSearchParameters": "example_value"
      }
    }
  }
}
