{
  "name": "synonyms_upsert",
  "description": "Create or update a synonym set.",
  "endpoint": "/synonym_sets/{synonymSetName}",
  "method": "PUT",
  "resource_group": "synonyms",
  "parameters": [
    {
      "name": "synonymSetName",
      "type": "string",
      "description": "Synonym set name",
      "required": true,
      "example": "electronics_synonyms"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.typesense.org/synonym_sets/electronics_synonyms",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "electronics_synonyms"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "electronics_synonyms"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}