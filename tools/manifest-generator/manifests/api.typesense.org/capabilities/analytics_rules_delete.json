{
  "name": "analytics_rules_delete",
  "description": "Delete an analytics rule.",
  "endpoint": "/analytics/rules/{ruleName}",
  "method": "DELETE",
  "resource_group": "analytics",
  "parameters": [
    {
      "name": "ruleName",
      "type": "string",
      "description": "Rule name to delete",
      "required": true,
      "example": "product_clicks"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/analytics/rules/product_clicks",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "product_clicks"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}