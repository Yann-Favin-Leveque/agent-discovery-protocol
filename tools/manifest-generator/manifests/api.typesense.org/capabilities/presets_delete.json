{
  "name": "presets_delete",
  "description": "Delete a search preset.",
  "endpoint": "/presets/{presetId}",
  "method": "DELETE",
  "resource_group": "presets",
  "parameters": [
    {
      "name": "presetId",
      "type": "string",
      "description": "Preset ID to delete",
      "required": true,
      "example": "default_search",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/presets/default_search",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "default_search"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
