{
  "name": "conversation_models_create",
  "description": "Create a new RAG conversation model for question-answering over collections.",
  "endpoint": "/conversations/models",
  "method": "POST",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "model_name",
      "type": "string",
      "description": "Name of the conversation model",
      "required": true,
      "example": "Support Bot",
      "in": "body"
    },
    {
      "name": "history_collection",
      "type": "string",
      "description": "Collection for storing conversation history",
      "required": true,
      "example": "conversations",
      "in": "body"
    },
    {
      "name": "system_prompt",
      "type": "string",
      "description": "System prompt for the model",
      "required": false,
      "example": "You are a helpful assistant.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.typesense.org/conversations/models",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "model_name": "Support Bot",
      "history_collection": "conversations"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "model_1",
      "model_name": "Support Bot"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
