{
  "name": "collections_get",
  "description": "Retrieve details of a specific collection including its schema and document count.",
  "endpoint": "/collections/{collectionName}",
  "method": "GET",
  "resource_group": "collections",
  "parameters": [
    {
      "name": "collectionName",
      "type": "string",
      "description": "Name of the collection",
      "required": true,
      "example": "products"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typesense.org/collections/products",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "products",
      "num_documents": 1000,
      "fields": [
        {
          "name": "title",
          "type": "string"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}