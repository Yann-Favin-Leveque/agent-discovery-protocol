{
  "name": "synonyms_items_list",
  "description": "List all items in a synonym set.",
  "endpoint": "/synonym_sets/{synonymSetName}/items",
  "method": "GET",
  "resource_group": "synonyms",
  "parameters": [
    {
      "name": "synonymSetName",
      "type": "string",
      "description": "Synonym set name",
      "required": true,
      "example": "electronics_synonyms"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typesense.org/synonym_sets/electronics_synonyms/items",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "1",
          "synonyms": [
            "laptop",
            "notebook"
          ]
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}