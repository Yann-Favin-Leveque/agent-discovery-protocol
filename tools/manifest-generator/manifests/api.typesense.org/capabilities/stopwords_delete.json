{
  "name": "stopwords_delete",
  "description": "Delete a stopwords set.",
  "endpoint": "/stopwords/{setId}",
  "method": "DELETE",
  "resource_group": "stopwords",
  "parameters": [
    {
      "name": "setId",
      "type": "string",
      "description": "Stopwords set ID to delete",
      "required": true,
      "example": "common_words"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/stopwords/common_words",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "common_words"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}