{
  "name": "documents_import",
  "description": "Bulk import documents into a collection using newline-delimited JSON.",
  "endpoint": "/collections/{collectionName}/documents/import",
  "method": "POST",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "collectionName",
      "type": "string",
      "description": "Collection name",
      "required": true,
      "example": "products",
      "in": "path"
    },
    {
      "name": "action",
      "type": "string",
      "description": "Import action: create, upsert, update, emplace",
      "required": false,
      "example": "upsert",
      "in": "body"
    },
    {
      "name": "batch_size",
      "type": "integer",
      "description": "Batch size for import",
      "required": false,
      "example": "40",
      "in": "body"
    },
    {
      "name": "return_id",
      "type": "boolean",
      "description": "Return document IDs in response",
      "required": false,
      "example": "true",
      "in": "body"
    },
    {
      "name": "dirty_values",
      "type": "string",
      "description": "How to handle dirty values",
      "required": false,
      "example": "coerce_or_reject",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.typesense.org/collections/products/documents/import?action=upsert",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}",
      "Content-Type": "text/plain"
    },
    "body": "{\"id\":\"1\",\"title\":\"Laptop\"}\n{\"id\":\"2\",\"title\":\"Phone\"}"
  },
  "response_example": {
    "status": 200,
    "body": "{\"success\":true}\n{\"success\":true}"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
