{
  "name": "aliases_delete",
  "description": "Delete a collection alias.",
  "endpoint": "/aliases/{aliasName}",
  "method": "DELETE",
  "resource_group": "aliases",
  "parameters": [
    {
      "name": "aliasName",
      "type": "string",
      "description": "Alias name to delete",
      "required": true,
      "example": "products_alias",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typesense.org/aliases/products_alias",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "products_alias"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
