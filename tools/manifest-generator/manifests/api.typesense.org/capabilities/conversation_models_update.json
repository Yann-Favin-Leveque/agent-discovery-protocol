{
  "name": "conversation_models_update",
  "description": "Update an existing conversation model.",
  "endpoint": "/conversations/models/{modelId}",
  "method": "PUT",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "modelId",
      "type": "string",
      "description": "Model ID",
      "required": true,
      "example": "model_1",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.typesense.org/conversations/models/model_1",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "system_prompt": "Updated prompt"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "model_1",
      "system_prompt": "Updated prompt"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
