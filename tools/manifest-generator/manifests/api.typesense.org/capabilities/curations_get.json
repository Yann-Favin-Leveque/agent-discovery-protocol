{
  "name": "curations_get",
  "description": "Retrieve a specific curation set.",
  "endpoint": "/curation_sets/{curationSetName}",
  "method": "GET",
  "resource_group": "curations",
  "parameters": [
    {
      "name": "curationSetName",
      "type": "string",
      "description": "Curation set name",
      "required": true,
      "example": "featured_products",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typesense.org/curation_sets/featured_products",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "featured_products",
      "items": []
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
