{
  "name": "operations_snapshot",
  "description": "Create a point-in-time snapshot of the Typesense node's state and data.",
  "endpoint": "/operations/snapshot",
  "method": "POST",
  "resource_group": "operations",
  "parameters": [
    {
      "name": "snapshot_path",
      "type": "string",
      "description": "Directory path to save the snapshot",
      "required": true,
      "example": "/tmp/typesense-snapshot"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.typesense.org/operations/snapshot?snapshot_path=/tmp/typesense-snapshot",
    "headers": {
      "X-TYPESENSE-API-KEY": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}