{
  "name": "exports_status_get",
  "description": "Check export job status.",
  "resource_group": "exports",
  "endpoint": "/public/api/v1/exports/{jobId}",
  "method": "GET",
  "parameters": [
    {
      "name": "jobId",
      "type": "string",
      "description": "Job ID.",
      "required": true,
      "example": "exp_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/exports/exp_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "jobId": "exp_001",
      "status": "completed"
    }
  }
}
