{
  "name": "workflows_get",
  "description": "Retrieve a specific workflow.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "wf_001",
      "template": "tmpl_001",
      "status": "In Progress",
      "step": "Internal Review"
    }
  }
}
