{
  "name": "workflows_recipient_url_create",
  "description": "Create a recipient URL.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/recipient-url",
  "method": "POST",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/recipient-url",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "url": "https://app.ironcladapp.com/recipient/abc123"
    }
  }
}
