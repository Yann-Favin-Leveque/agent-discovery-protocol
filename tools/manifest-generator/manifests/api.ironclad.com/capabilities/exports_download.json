{
  "name": "exports_download",
  "description": "Download export file.",
  "resource_group": "exports",
  "endpoint": "/public/api/v1/exports/{jobId}/download",
  "method": "GET",
  "parameters": [
    {
      "name": "jobId",
      "type": "string",
      "description": "Job ID.",
      "required": true,
      "example": "exp_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/exports/exp_001/download",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "Binary file content"
  }
}