{
  "name": "workflows_approvals_list",
  "description": "List approvals for a workflow.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/approvals",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/approvals",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "approvals": [
        {
          "id": "appr_001",
          "status": "pending"
        }
      ]
    }
  }
}