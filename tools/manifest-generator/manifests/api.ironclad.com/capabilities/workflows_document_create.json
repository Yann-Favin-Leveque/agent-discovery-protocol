{
  "name": "workflows_document_create",
  "description": "Attach a document.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/documents",
  "method": "POST",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    },
    {
      "name": "file",
      "type": "file",
      "description": "Document file.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/documents",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "multipart/form-data"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "documentId": "doc_002"
    }
  }
}
