{
  "name": "records_attachment_create",
  "description": "Attach a file to a record.",
  "resource_group": "records",
  "endpoint": "/public/api/v1/records/{recordId}/attachments",
  "method": "POST",
  "parameters": [
    {
      "name": "recordId",
      "type": "string",
      "description": "Record ID.",
      "required": true,
      "example": "rec_001"
    },
    {
      "name": "file",
      "type": "file",
      "description": "File.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/records/rec_001/attachments",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "multipart/form-data"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "attachmentId": "att_001"
    }
  }
}