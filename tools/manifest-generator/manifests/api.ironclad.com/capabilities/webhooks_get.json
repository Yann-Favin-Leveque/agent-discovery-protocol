{
  "name": "webhooks_get",
  "description": "Retrieve a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/public/api/v1/webhooks/{webhookId}",
  "method": "GET",
  "parameters": [
    {
      "name": "webhookId",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "example": "wh_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/webhooks/wh_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "wh_001",
      "targetURL": "https://example.com/hook"
    }
  }
}
