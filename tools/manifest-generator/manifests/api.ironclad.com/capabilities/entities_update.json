{
  "name": "entities_update",
  "description": "Update an entity.",
  "resource_group": "entities",
  "endpoint": "/public/api/v1/entities/{entityId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "entityId",
      "type": "string",
      "description": "Entity ID.",
      "required": true,
      "example": "ent_001",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "Acme Inc",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.ironclad.com/public/api/v1/entities/ent_001",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Inc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ent_001",
      "name": "Acme Inc"
    }
  }
}
