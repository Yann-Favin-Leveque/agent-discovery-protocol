{
  "name": "list_records",
  "description": "Retrieve all contract records from the Ironclad repository. Records represent completed or imported contracts. You can filter by metadata fields, search by keyword, and paginate through results.",
  "endpoint": "/public/api/v1/records",
  "method": "GET",
  "parameters": [
    { "name": "filter", "type": "string", "description": "Filter expression for querying records by metadata fields (e.g., counterpartyName, contractValue).", "required": false, "example": "counterpartyName=Acme Corp" },
    { "name": "page", "type": "integer", "description": "Page number for pagination (0-based).", "required": false, "example": 0 },
    { "name": "pageSize", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/records?pageSize=25&page=0",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list": [
        {
          "id": "rec_abc123def456",
          "ironcladId": "IC-12345",
          "name": "Acme Corp NDA",
          "lastUpdated": "2026-01-20T14:00:00.000Z",
          "properties": {
            "counterpartyName": "Acme Corp",
            "contractValue": 50000,
            "effectiveDate": "2026-03-01",
            "expirationDate": "2027-03-01"
          }
        }
      ],
      "page": 0,
      "pageSize": 25,
      "count": 1
    }
  }
}
