{
  "name": "workflow_schemas_get",
  "description": "Retrieve a workflow schema.",
  "resource_group": "workflow_schemas",
  "endpoint": "/public/api/v1/workflow-schemas/{templateId}",
  "method": "GET",
  "parameters": [
    {
      "name": "templateId",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "tmpl_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflow-schemas/tmpl_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tmpl_001",
      "name": "Standard NDA",
      "attributes": [
        {
          "name": "counterpartyName",
          "type": "string"
        }
      ]
    }
  }
}