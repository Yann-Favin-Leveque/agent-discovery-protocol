  "parameters": [
    {
      "name": "webhookId",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "example": "wh_001"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.ironclad.com/public/api/v1/webhooks/wh_001",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "targetURL": "https://example.com/v2"
    }
  },
  "response_example": {
