{
  "name": "workflows_comments_get",
  "description": "Get a specific comment.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/comments/{commentId}",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    },
    {
      "name": "commentId",
      "type": "string",
      "description": "Comment ID.",
      "required": true,
      "example": "cmt_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/comments/cmt_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cmt_001",
      "body": "Please review clause 5."
    }
  }
}