{
  "name": "workflows_metadata_update",
  "description": "Update workflow metadata.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/metadata",
  "method": "PATCH",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    },
    {
      "name": "attributes",
      "type": "object",
      "description": "Metadata to update.",
      "required": true,
      "example": {
        "contractValue": 75000
      }
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/metadata",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "attributes": {
        "contractValue": 75000
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}