{
  "name": "records_replace",
  "description": "Replace a contract record.",
  "resource_group": "records",
  "endpoint": "/public/api/v1/records/{recordId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "recordId",
      "type": "string",
      "description": "Record ID.",
      "required": true,
      "example": "rec_001"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.ironclad.com/public/api/v1/records/rec_001",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme NDA v2"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rec_001",
      "name": "Acme NDA v2"
    }
  }
}