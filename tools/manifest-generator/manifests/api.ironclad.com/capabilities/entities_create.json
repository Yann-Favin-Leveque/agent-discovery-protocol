{
  "name": "entities_create",
  "description": "Create an entity.",
  "resource_group": "entities",
  "endpoint": "/public/api/v1/entities",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Entity name.",
      "required": true,
      "example": "Acme Corp"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/entities",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Corp",
      "type": "company"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ent_002",
      "name": "Acme Corp"
    }
  }
}