{
  "name": "workflows_approval_requests_get",
  "description": "Retrieve approval requests.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/approval-requests",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/approval-requests",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "approvalRequests": [
        {
          "id": "ar_001",
          "status": "pending"
        }
      ]
    }
  }
}
