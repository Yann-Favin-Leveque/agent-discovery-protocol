{
  "name": "workflows_resume",
  "description": "Resume a paused workflow.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/resume",
  "method": "POST",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/resume",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "In Progress"
    }
  }
}
