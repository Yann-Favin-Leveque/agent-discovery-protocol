{
  "name": "webhooks_create",
  "description": "Create a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/public/api/v1/webhooks",
  "method": "POST",
  "parameters": [
    {
      "name": "targetURL",
      "type": "string",
      "description": "URL.",
      "required": true,
      "example": "https://example.com/hook"
    },
    {
      "name": "events",
      "type": "array",
      "description": "Events.",
      "required": true,
      "example": [
        "workflow_completed"
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/webhooks",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "targetURL": "https://example.com/hook",
      "events": [
        "workflow_completed"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "wh_001"
    }
  }
}