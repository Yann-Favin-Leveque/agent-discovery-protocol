{
  "name": "workflows_async_status_get",
  "description": "Check async workflow creation status.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/async/{jobId}",
  "method": "GET",
  "parameters": [
    {
      "name": "jobId",
      "type": "string",
      "description": "Async job ID.",
      "required": true,
      "example": "job_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/async/job_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "completed",
      "workflowId": "wf_001"
    }
  }
}
