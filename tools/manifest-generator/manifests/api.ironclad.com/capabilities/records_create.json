{
  "name": "records_create",
  "description": "Create a contract record.",
  "resource_group": "records",
  "endpoint": "/public/api/v1/records",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Record name.",
      "required": true,
      "example": "Acme NDA 2026"
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Record metadata.",
      "required": false,
      "example": {
        "counterparty": "Acme Corp"
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/records",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme NDA 2026"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rec_002",
      "name": "Acme NDA 2026"
    }
  }
}