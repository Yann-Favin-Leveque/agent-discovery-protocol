{
  "name": "workflows_comments_list",
  "description": "List comments.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/comments",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/comments",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "comments": [
        {
          "id": "cmt_001",
          "body": "Please review clause 5."
        }
      ]
    }
  }
}