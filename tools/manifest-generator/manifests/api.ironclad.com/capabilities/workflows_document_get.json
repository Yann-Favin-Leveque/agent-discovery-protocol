{
  "name": "workflows_document_get",
  "description": "Retrieve a workflow document.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/documents/{documentId}",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    },
    {
      "name": "documentId",
      "type": "string",
      "description": "Document ID.",
      "required": true,
      "example": "doc_002",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/documents/doc_002",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "documentId": "doc_002",
      "name": "NDA.pdf"
    }
  }
}
