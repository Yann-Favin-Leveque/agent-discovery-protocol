{
  "name": "workflows_participants_list",
  "description": "List workflow participants.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/participants",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/participants",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "participants": [
        {
          "email": "legal@co.com",
          "role": "creator"
        }
      ]
    }
  }
}
