{
  "name": "workflows_signer_delete",
  "description": "Remove a signer.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/signers/{signerId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    },
    {
      "name": "signerId",
      "type": "string",
      "description": "Signer ID.",
      "required": true,
      "example": "sig_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/signers/sig_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}
