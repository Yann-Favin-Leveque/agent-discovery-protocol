{
  "name": "records_metadata_update",
  "description": "Update record metadata.",
  "resource_group": "records",
  "endpoint": "/public/api/v1/records/{recordId}/metadata",
  "method": "PATCH",
  "parameters": [
    {
      "name": "recordId",
      "type": "string",
      "description": "Record ID.",
      "required": true,
      "example": "rec_001"
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Metadata.",
      "required": true,
      "example": {
        "counterparty": "Acme Inc"
      }
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.ironclad.com/public/api/v1/records/rec_001/metadata",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "metadata": {
        "counterparty": "Acme Inc"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}