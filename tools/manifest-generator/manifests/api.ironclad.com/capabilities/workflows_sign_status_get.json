{
  "name": "workflows_sign_status_get",
  "description": "Retrieve signature step status.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/sign-status",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/sign-status",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "awaiting_signatures",
      "signers": [
        {
          "email": "ceo@acme.com",
          "signed": false
        }
      ]
    }
  }
}