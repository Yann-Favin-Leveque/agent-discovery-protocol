{
  "name": "workflows_signers_list",
  "description": "List signers on a workflow.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/signers",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/signers",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "signers": [
        {
          "id": "sig_001",
          "email": "ceo@acme.com",
          "signed": false
        }
      ]
    }
  }
}
