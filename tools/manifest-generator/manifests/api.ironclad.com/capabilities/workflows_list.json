{
  "name": "workflows_list",
  "description": "List all workflows with optional filtering.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "pageSize",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 20,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows?page=1&pageSize=20",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list": [
        {
          "id": "wf_001",
          "status": "In Progress"
        }
      ],
      "page": 1,
      "count": 1
    }
  }
}
