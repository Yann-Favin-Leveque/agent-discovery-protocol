{
  "name": "records_attachment_get",
  "description": "Retrieve a record attachment.",
  "resource_group": "records",
  "endpoint": "/public/api/v1/records/{recordId}/attachments/{attachmentId}",
  "method": "GET",
  "parameters": [
    {
      "name": "recordId",
      "type": "string",
      "description": "Record ID.",
      "required": true,
      "example": "rec_001",
      "in": "path"
    },
    {
      "name": "attachmentId",
      "type": "string",
      "description": "Attachment ID.",
      "required": true,
      "example": "att_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/records/rec_001/attachments/att_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "attachmentId": "att_001",
      "name": "contract.pdf"
    }
  }
}
