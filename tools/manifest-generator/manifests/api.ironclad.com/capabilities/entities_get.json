{
  "name": "entities_get",
  "description": "Retrieve an entity.",
  "resource_group": "entities",
  "endpoint": "/public/api/v1/entities/{entityId}",
  "method": "GET",
  "parameters": [
    {
      "name": "entityId",
      "type": "string",
      "description": "Entity ID.",
      "required": true,
      "example": "ent_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/entities/ent_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ent_001",
      "name": "Acme Corp"
    }
  }
}