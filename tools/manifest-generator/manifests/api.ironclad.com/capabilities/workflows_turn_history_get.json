{
  "name": "workflows_turn_history_get",
  "description": "Retrieve turn history.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/turn-history",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/turn-history",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "turns": [
        {
          "step": "Internal Review",
          "action": "approved"
        }
      ]
    }
  }
}