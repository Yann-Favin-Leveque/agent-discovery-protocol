{
  "name": "workflows_comments_create",
  "description": "Add a comment.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001",
      "in": "path"
    },
    {
      "name": "body",
      "type": "string",
      "description": "Comment text.",
      "required": true,
      "example": "Please review clause 5.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/comments",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "body": "Please review clause 5."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cmt_001",
      "body": "Please review clause 5."
    }
  }
}
