{
  "name": "exports_create",
  "description": "Submit an export request.",
  "resource_group": "exports",
  "endpoint": "/public/api/v1/exports",
  "method": "POST",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "Export type.",
      "required": true,
      "example": "records"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/exports",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "type": "records"
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "jobId": "exp_001",
      "status": "pending"
    }
  }
}