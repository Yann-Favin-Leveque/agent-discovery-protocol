{
  "name": "list_workflows",
  "description": "List all contract workflows in your Ironclad instance. Results can be filtered by status, template, creator, and date range. Supports pagination for large result sets.",
  "endpoint": "/public/api/v1/workflows",
  "method": "GET",
  "parameters": [
    { "name": "status", "type": "string", "description": "Filter by workflow status. Options: active, completed, cancelled.", "required": false, "example": "active" },
    { "name": "template", "type": "string", "description": "Filter by template ID to see only workflows created from a specific template.", "required": false, "example": "60d5f484e1c1a30012345678" },
    { "name": "page", "type": "integer", "description": "Page number for pagination (0-based).", "required": false, "example": 0 },
    { "name": "pageSize", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/workflows?status=active&pageSize=25&page=0",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list": [
        {
          "id": "61a2b3c4d5e6f70089abcdef",
          "template": "60d5f484e1c1a30012345678",
          "templateName": "Standard NDA",
          "status": "In Progress",
          "step": "Counterparty Signature",
          "dateCreated": "2026-01-15T10:30:00.000Z"
        }
      ],
      "page": 0,
      "pageSize": 25,
      "count": 1
    }
  }
}
