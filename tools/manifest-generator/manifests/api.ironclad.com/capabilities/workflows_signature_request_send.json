{
  "name": "workflows_signature_request_send",
  "description": "Send signature requests.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/signature-requests",
  "method": "POST",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/signature-requests",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "sent"
    }
  }
}