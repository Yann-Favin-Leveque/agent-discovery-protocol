{
  "name": "records_list",
  "description": "List all contract records.",
  "resource_group": "records",
  "endpoint": "/public/api/v1/records",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ironclad.com/public/api/v1/records?page=1",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list": [
        {
          "id": "rec_001",
          "name": "Acme NDA"
        }
      ],
      "page": 1,
      "count": 1
    }
  }
}
