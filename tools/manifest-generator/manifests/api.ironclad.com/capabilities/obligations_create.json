{
  "name": "obligations_create",
  "description": "Create an obligation.",
  "resource_group": "obligations",
  "endpoint": "/public/api/v1/obligations",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "description": "Title.",
      "required": true,
      "example": "Annual Audit",
      "in": "body"
    },
    {
      "name": "dueDate",
      "type": "string",
      "description": "Due date.",
      "required": true,
      "example": "2026-12-31",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/obligations",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Annual Audit",
      "dueDate": "2026-12-31"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "obl_002",
      "title": "Annual Audit"
    }
  }
}
