{
  "name": "workflows_signed_document_upload",
  "description": "Upload externally signed document.",
  "resource_group": "workflows",
  "endpoint": "/public/api/v1/workflows/{workflowId}/signed-documents",
  "method": "POST",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "description": "Workflow ID.",
      "required": true,
      "example": "wf_001"
    },
    {
      "name": "file",
      "type": "file",
      "description": "Signed document.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.ironclad.com/public/api/v1/workflows/wf_001/signed-documents",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "multipart/form-data"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "documentId": "doc_001"
    }
  }
}