{
  "name": "packages_update",
  "description": "Update a custom package type.",
  "endpoint": "/v1/packages/{package_id}",
  "method": "PUT",
  "resource_group": "packages",
  "parameters": [
    {
      "name": "package_id",
      "type": "string",
      "description": "The package type ID.",
      "required": true,
      "example": "se-pkg-123"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    },
    {
      "name": "dimensions",
      "type": "object",
      "description": "Updated dimensions.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.shipengine.com/v1/packages/se-pkg-123",
    "headers": {
      "API-Key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Box"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "package_id": "se-pkg-123",
      "name": "Updated Box"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}