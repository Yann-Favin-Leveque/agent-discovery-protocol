{
  "name": "batches_add_shipments",
  "description": "Add shipments or rates to an existing batch.",
  "endpoint": "/v1/batches/{batch_id}/add",
  "method": "POST",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "batch_id",
      "type": "string",
      "description": "The batch ID.",
      "required": true,
      "example": "se-batch-123",
      "in": "path"
    },
    {
      "name": "shipment_ids",
      "type": "array",
      "description": "Shipment IDs to add.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.shipengine.com/v1/batches/se-batch-123/add",
    "headers": {
      "API-Key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "shipment_ids": [
        "se-9999999"
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
