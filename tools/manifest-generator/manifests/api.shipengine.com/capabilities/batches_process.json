{
  "name": "batches_process",
  "description": "Process a batch to generate labels for all shipments.",
  "endpoint": "/v1/batches/{batch_id}/process/labels",
  "method": "POST",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "batch_id",
      "type": "string",
      "description": "The batch ID.",
      "required": true,
      "example": "se-batch-123"
    },
    {
      "name": "label_format",
      "type": "string",
      "description": "Label format.",
      "required": false,
      "example": "pdf"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.shipengine.com/v1/batches/se-batch-123/process/labels",
    "headers": {
      "API-Key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "label_format": "pdf"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}