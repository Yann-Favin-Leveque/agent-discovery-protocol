{
  "name": "carriers_options",
  "description": "List available shipping options for a carrier.",
  "endpoint": "/v1/carriers/{carrier_id}/options",
  "method": "GET",
  "resource_group": "carriers",
  "parameters": [
    {
      "name": "carrier_id",
      "type": "string",
      "description": "The carrier ID.",
      "required": true,
      "example": "se-121861",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/carriers/se-121861/options",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "options": [
        {
          "name": "signature_confirmation",
          "description": "Requires signature at delivery"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
