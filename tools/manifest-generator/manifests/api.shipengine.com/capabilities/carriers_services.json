{
  "name": "carriers_services",
  "description": "List available services for a carrier.",
  "endpoint": "/v1/carriers/{carrier_id}/services",
  "method": "GET",
  "resource_group": "carriers",
  "parameters": [
    {
      "name": "carrier_id",
      "type": "string",
      "description": "The carrier ID.",
      "required": true,
      "example": "se-121861",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/carriers/se-121861/services",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "services": [
        {
          "service_code": "usps_priority_mail",
          "name": "USPS Priority Mail"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
