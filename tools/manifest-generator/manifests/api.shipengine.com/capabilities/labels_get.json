{
  "name": "labels_get",
  "description": "Retrieve label details by ID.",
  "endpoint": "/v1/labels/{label_id}",
  "method": "GET",
  "resource_group": "labels",
  "parameters": [
    {
      "name": "label_id",
      "type": "string",
      "description": "The label ID.",
      "required": true,
      "example": "se-label-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/labels/se-label-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "label_id": "se-label-123",
      "status": "completed",
      "tracking_number": "1Z999AA10123456784",
      "carrier_id": "se-121861"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}