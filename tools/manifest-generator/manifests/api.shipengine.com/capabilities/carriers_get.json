{
  "name": "carriers_get",
  "description": "Retrieve details for a specific carrier.",
  "endpoint": "/v1/carriers/{carrier_id}",
  "method": "GET",
  "resource_group": "carriers",
  "parameters": [
    {
      "name": "carrier_id",
      "type": "string",
      "description": "The carrier ID.",
      "required": true,
      "example": "se-121861"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/carriers/se-121861",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "carrier_id": "se-121861",
      "carrier_code": "stamps_com",
      "friendly_name": "Stamps.com",
      "balance": 100.0
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}