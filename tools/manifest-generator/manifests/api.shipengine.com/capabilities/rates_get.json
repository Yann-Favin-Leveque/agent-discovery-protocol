{
  "name": "rates_get",
  "description": "Retrieve a specific rate quote by ID.",
  "endpoint": "/v1/rates/{rate_id}",
  "method": "GET",
  "resource_group": "rates",
  "parameters": [
    {
      "name": "rate_id",
      "type": "string",
      "description": "The rate ID.",
      "required": true,
      "example": "se-rate-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/rates/se-rate-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "rate_id": "se-rate-123",
      "carrier_id": "se-121861",
      "shipping_amount": {
        "currency": "usd",
        "amount": 7.99
      },
      "delivery_days": 3
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}