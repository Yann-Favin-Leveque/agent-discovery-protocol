{
  "name": "manifests_list",
  "description": "List manifests with filters for warehouse, date, and carrier.",
  "endpoint": "/v1/manifests",
  "method": "GET",
  "resource_group": "manifests",
  "parameters": [
    {
      "name": "warehouse_id",
      "type": "string",
      "description": "Filter by warehouse.",
      "required": false,
      "in": "query"
    },
    {
      "name": "carrier_id",
      "type": "string",
      "description": "Filter by carrier.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/manifests",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "manifests": [
        {
          "manifest_id": "se-manifest-123",
          "carrier_id": "se-121861",
          "ship_date": "2024-01-15"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
