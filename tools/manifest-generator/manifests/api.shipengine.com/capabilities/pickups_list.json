{
  "name": "pickups_list",
  "description": "List scheduled carrier pickups.",
  "endpoint": "/v1/pickups",
  "method": "GET",
  "resource_group": "pickups",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Results per page.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/pickups",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "pickups": [
        {
          "pickup_id": "se-pickup-123",
          "carrier_id": "se-121861",
          "pickup_date": "2024-01-16"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}