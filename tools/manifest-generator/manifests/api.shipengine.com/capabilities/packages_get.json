{
  "name": "packages_get",
  "description": "Retrieve a custom package type by ID.",
  "endpoint": "/v1/packages/{package_id}",
  "method": "GET",
  "resource_group": "packages",
  "parameters": [
    {
      "name": "package_id",
      "type": "string",
      "description": "The package type ID.",
      "required": true,
      "example": "se-pkg-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/packages/se-pkg-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "package_id": "se-pkg-123",
      "name": "My Box",
      "dimensions": {
        "length": 12,
        "width": 10,
        "height": 6,
        "unit": "inch"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
