{
  "name": "service_points_get",
  "description": "Get details for a specific carrier service point.",
  "endpoint": "/v1/service_points/{carrier_code}/{country_code}/{service_point_id}",
  "method": "GET",
  "resource_group": "service_points",
  "parameters": [
    {
      "name": "carrier_code",
      "type": "string",
      "description": "Carrier code.",
      "required": true,
      "example": "ups",
      "in": "path"
    },
    {
      "name": "country_code",
      "type": "string",
      "description": "Country code.",
      "required": true,
      "example": "US",
      "in": "path"
    },
    {
      "name": "service_point_id",
      "type": "string",
      "description": "Service point ID.",
      "required": true,
      "example": "sp-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/service_points/ups/US/sp-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "service_point_id": "sp-123",
      "carrier_code": "ups",
      "name": "UPS Store",
      "address": {
        "address_line1": "123 Main St"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
