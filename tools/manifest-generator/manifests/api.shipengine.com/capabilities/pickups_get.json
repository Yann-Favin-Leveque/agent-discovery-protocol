{
  "name": "pickups_get",
  "description": "Retrieve pickup details by ID.",
  "endpoint": "/v1/pickups/{pickup_id}",
  "method": "GET",
  "resource_group": "pickups",
  "parameters": [
    {
      "name": "pickup_id",
      "type": "string",
      "description": "The pickup ID.",
      "required": true,
      "example": "se-pickup-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/pickups/se-pickup-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "pickup_id": "se-pickup-123",
      "carrier_id": "se-121861",
      "pickup_date": "2024-01-16",
      "confirmation_number": "WTC123456"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}