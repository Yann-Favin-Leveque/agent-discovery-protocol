{
  "name": "batches_get",
  "description": "Retrieve batch details by ID.",
  "endpoint": "/v1/batches/{batch_id}",
  "method": "GET",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "batch_id",
      "type": "string",
      "description": "The batch ID.",
      "required": true,
      "example": "se-batch-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/batches/se-batch-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "batch_id": "se-batch-123",
      "status": "completed",
      "count": 50,
      "completed": 48,
      "errors": 2
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
