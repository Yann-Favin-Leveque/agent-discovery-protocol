{
  "name": "batches_errors",
  "description": "List processing errors for a batch.",
  "endpoint": "/v1/batches/{batch_id}/errors",
  "method": "GET",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "batch_id",
      "type": "string",
      "description": "The batch ID.",
      "required": true,
      "example": "se-batch-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/batches/se-batch-123/errors",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "errors": [
        {
          "error": "Invalid address",
          "shipment_id": "se-9999999"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
