{
  "name": "manifests_get",
  "description": "Retrieve manifest details by ID.",
  "endpoint": "/v1/manifests/{manifest_id}",
  "method": "GET",
  "resource_group": "manifests",
  "parameters": [
    {
      "name": "manifest_id",
      "type": "string",
      "description": "The manifest ID.",
      "required": true,
      "example": "se-manifest-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/manifests/se-manifest-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "manifest_id": "se-manifest-123",
      "carrier_id": "se-121861",
      "ship_date": "2024-01-15",
      "status": "completed"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
