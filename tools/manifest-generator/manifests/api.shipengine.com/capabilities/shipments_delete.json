{
  "name": "shipments_delete",
  "description": "Delete an existing shipment by ID.",
  "endpoint": "/v1/shipments/{shipment_id}",
  "method": "DELETE",
  "resource_group": "shipments",
  "parameters": [
    {
      "name": "shipment_id",
      "type": "string",
      "description": "The shipment ID to delete.",
      "required": true,
      "example": "se-1234567",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.shipengine.com/v1/shipments/se-1234567",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
