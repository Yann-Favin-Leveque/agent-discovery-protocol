{
  "name": "labels_void",
  "description": "Void a label and request a refund.",
  "endpoint": "/v1/labels/{label_id}/void",
  "method": "PUT",
  "resource_group": "labels",
  "parameters": [
    {
      "name": "label_id",
      "type": "string",
      "description": "The label ID to void.",
      "required": true,
      "example": "se-label-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.shipengine.com/v1/labels/se-label-123/void",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "approved": true,
      "message": "Label voided successfully."
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
