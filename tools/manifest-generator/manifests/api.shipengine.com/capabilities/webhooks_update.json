{
  "name": "webhooks_update",
  "description": "Update a webhook URL or configuration.",
  "endpoint": "/v1/environment/webhooks/{webhook_id}",
  "method": "PUT",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "The webhook ID.",
      "required": true,
      "example": "se-wh-123"
    },
    {
      "name": "url",
      "type": "string",
      "description": "New webhook URL.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.shipengine.com/v1/environment/webhooks/se-wh-123",
    "headers": {
      "API-Key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://example.com/new-webhook"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}