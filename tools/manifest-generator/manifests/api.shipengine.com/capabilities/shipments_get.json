{
  "name": "shipments_get",
  "description": "Retrieve a specific shipment by ID.",
  "endpoint": "/v1/shipments/{shipment_id}",
  "method": "GET",
  "resource_group": "shipments",
  "parameters": [
    {
      "name": "shipment_id",
      "type": "string",
      "description": "The shipment ID.",
      "required": true,
      "example": "se-1234567",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/shipments/se-1234567",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "shipment_id": "se-1234567",
      "shipment_status": "pending",
      "ship_to": {
        "name": "John Smith"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
