{
  "name": "webhooks_get",
  "description": "Retrieve webhook details by ID.",
  "endpoint": "/v1/environment/webhooks/{webhook_id}",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "The webhook ID.",
      "required": true,
      "example": "se-wh-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.shipengine.com/v1/environment/webhooks/se-wh-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "webhook_id": "se-wh-123",
      "url": "https://example.com/webhook",
      "event": "track"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}