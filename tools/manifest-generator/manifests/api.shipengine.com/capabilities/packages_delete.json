{
  "name": "packages_delete",
  "description": "Delete a custom package type.",
  "endpoint": "/v1/packages/{package_id}",
  "method": "DELETE",
  "resource_group": "packages",
  "parameters": [
    {
      "name": "package_id",
      "type": "string",
      "description": "The package type ID.",
      "required": true,
      "example": "se-pkg-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.shipengine.com/v1/packages/se-pkg-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
