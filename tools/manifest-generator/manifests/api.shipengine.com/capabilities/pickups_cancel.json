    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.shipengine.com/v1/pickups/se-pickup-123",
    "headers": {
      "API-Key": "{api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
