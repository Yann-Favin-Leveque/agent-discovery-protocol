{
  "name": "sessions_get_events",
  "description": "Return the full set of captured events for a specified session.",
  "endpoint": "/v2/sessions/{session_id}/events",
  "method": "GET",
  "resource_group": "sessions",
  "parameters": [
    {
      "name": "session_id",
      "type": "string",
      "description": "The session ID to retrieve events for.",
      "required": true,
      "example": "sess_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fullstory.com/v2/sessions/sess_abc123/events",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "events": [
        {
          "type": "navigate",
          "timestamp": "2024-01-20T10:00:00Z",
          "properties": {
            "page_url": "https://example.com/pricing"
          }
        },
        {
          "type": "click",
          "timestamp": "2024-01-20T10:01:00Z",
          "properties": {
            "element": "button.cta"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "server"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
