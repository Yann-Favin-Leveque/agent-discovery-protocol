{
  "name": "events_batch_import_get",
  "description": "Get the status and details of a batch events import job.",
  "endpoint": "/v2/events/batch/{job_id}",
  "method": "GET",
  "resource_group": "events",
  "parameters": [
    {
      "name": "job_id",
      "type": "string",
      "description": "The batch import job ID.",
      "required": true,
      "example": "job_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fullstory.com/v2/events/batch/job_abc123",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "job": {
        "id": "job_abc123",
        "state": "COMPLETED",
        "created": "2024-01-20T10:00:00Z",
        "total": 5000,
        "imported": 4998,
        "errored": 2
      }
    }
  },
  "auth_scopes": ["server"],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
