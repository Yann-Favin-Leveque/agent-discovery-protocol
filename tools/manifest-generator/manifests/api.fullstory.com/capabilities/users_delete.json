{
  "name": "users_delete",
  "description": "Permanently delete a user and all their associated data including sessions, events, and properties.",
  "endpoint": "/v2/users/{id}",
  "method": "DELETE",
  "resource_group": "users",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The FullStory user ID to delete.",
      "required": true,
      "example": "fs_user_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.fullstory.com/v2/users/fs_user_abc123",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "server"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
