{
  "name": "annotations_list",
  "description": "List all annotations in the FullStory timeline with optional filtering.",
  "endpoint": "/v2/annotations",
  "method": "GET",
  "resource_group": "annotations",
  "parameters": [
    {
      "name": "page_token",
      "type": "string",
      "description": "Pagination token from a previous response.",
      "required": false,
      "example": "",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fullstory.com/v2/annotations",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "annotations": [
        {
          "id": "ann_abc123",
          "title": "v2.5.0 Deployed",
          "timestamp": "2024-01-20T10:00:00Z"
        },
        {
          "id": "ann_def456",
          "title": "Marketing Campaign Launch",
          "timestamp": "2024-01-18T09:00:00Z"
        }
      ],
      "next_page_token": ""
    }
  },
  "auth_scopes": [
    "server"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
