{
  "name": "get_session_details",
  "description": "Get detailed information about a specific user session including pages visited, events, and frustration signals.",
  "endpoint": "/sessions/v2/{session_id}",
  "method": "GET",
  "parameters": [
    {"name": "session_id", "type": "string", "description": "The session ID to retrieve.", "required": true, "example": "sess_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fullstory.com/sessions/v2/sess_abc123",
    "headers": {"Authorization": "Basic {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"session_id": "sess_abc123", "user_id": "user_123", "created_time": "2024-01-20T10:00:00Z", "duration_ms": 120000, "pages_visited": 5, "frustration_signals": {"rage_clicks": 2, "dead_clicks": 5, "error_clicks": 1}, "device": {"browser": "Chrome", "os": "macOS"}}
  }
}
