{
  "name": "set_user_properties",
  "description": "Set custom properties on a FullStory user for segmentation and analysis.",
  "endpoint": "/users/v1/individual/{uid}/customvars",
  "method": "POST",
  "parameters": [
    {"name": "uid", "type": "string", "description": "FullStory user ID or custom user ID.", "required": true, "example": "user_123"},
    {"name": "properties", "type": "object", "description": "Custom properties to set.", "required": true, "example": {"displayName": "John Doe", "email": "john@example.com", "plan_str": "enterprise", "mrr_real": 99.99}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.fullstory.com/users/v1/individual/user_123/customvars",
    "headers": {"Authorization": "Basic {api_key}", "Content-Type": "application/json"},
    "body": {"displayName": "John Doe", "email": "john@example.com", "plan_str": "enterprise", "mrr_real": 99.99}
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
