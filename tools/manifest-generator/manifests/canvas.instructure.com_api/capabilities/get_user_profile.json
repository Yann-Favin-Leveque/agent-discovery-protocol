{
  "name": "get_user_profile",
  "description": "Retrieve the profile and account details of a specific user or the currently authenticated user. Returns name, email, avatar, bio, and login information.",
  "endpoint": "/v1/users/{user_id}/profile",
  "method": "GET",
  "parameters": [
    { "name": "user_id", "type": "string", "description": "The ID of the user to retrieve, or 'self' for the currently authenticated user.", "required": true, "example": "self" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/users/self/profile",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 99999,
      "name": "Jane Smith",
      "short_name": "Jane",
      "login_id": "jane.smith@university.edu",
      "email": "jane.smith@university.edu",
      "avatar_url": "https://canvas.instructure.com/images/messages/avatar-50.png",
      "bio": "Computer Science major, Class of 2027",
      "locale": "en",
      "time_zone": "America/New_York"
    }
  }
}
