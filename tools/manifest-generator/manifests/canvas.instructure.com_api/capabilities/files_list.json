{
  "name": "files_list",
  "description": "List files in a course.",
  "resource_group": "files",
  "endpoint": "/api/v1/courses/{course_id}/files",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "sort",
      "type": "string",
      "description": "Sort field.",
      "required": false,
      "example": "name"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/files",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 14001,
        "display_name": "syllabus.pdf",
        "size": 245760,
        "content-type": "application/pdf"
      }
    ]
  }
}