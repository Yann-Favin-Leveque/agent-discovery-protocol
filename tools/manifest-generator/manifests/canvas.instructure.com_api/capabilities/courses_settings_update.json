{
  "name": "courses_settings_update",
  "description": "Update course settings.",
  "resource_group": "courses",
  "endpoint": "/api/v1/courses/{course_id}/settings",
  "method": "PUT",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "hide_final_grades",
      "type": "boolean",
      "description": "Hide grades.",
      "required": false,
      "example": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/settings",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "hide_final_grades": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hide_final_grades": true
    }
  }
}
