{
  "name": "discussions_update",
  "description": "Update a discussion topic.",
  "resource_group": "discussions",
  "endpoint": "/api/v1/courses/{course_id}/discussion_topics/{topic_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "topic_id",
      "type": "integer",
      "description": "Topic ID.",
      "required": true,
      "example": 8001,
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "description": "Updated title.",
      "required": false,
      "example": "Week 1 Discussion (Updated)",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/discussion_topics/8001",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Week 1 Discussion (Updated)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 8001,
      "title": "Week 1 Discussion (Updated)"
    }
  }
}
