{
  "name": "courses_delete",
  "description": "Delete or conclude a course.",
  "resource_group": "courses",
  "endpoint": "/api/v1/courses/{course_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "event",
      "type": "string",
      "description": "delete or conclude.",
      "required": true,
      "example": "conclude"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://canvas.instructure.com/api/v1/courses/1234?event=conclude",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "conclude": true
    }
  }
}