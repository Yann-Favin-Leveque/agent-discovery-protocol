{
  "name": "quizzes_delete",
  "description": "Delete a quiz.",
  "resource_group": "quizzes",
  "endpoint": "/api/v1/courses/{course_id}/quizzes/{quiz_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "quiz_id",
      "type": "integer",
      "description": "Quiz ID.",
      "required": true,
      "example": 10001
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/quizzes/10001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 10001,
      "deleted": true
    }
  }
}