{
  "name": "assignments_get",
  "description": "Retrieve a single assignment.",
  "resource_group": "assignments",
  "endpoint": "/api/v1/courses/{course_id}/assignments/{assignment_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "assignment_id",
      "type": "integer",
      "description": "Assignment ID.",
      "required": true,
      "example": 2001
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/assignments/2001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 2001,
      "name": "Homework 1",
      "due_at": "2026-02-01T23:59:00Z",
      "points_possible": 100,
      "submission_types": [
        "online_text_entry"
      ]
    }
  }
}