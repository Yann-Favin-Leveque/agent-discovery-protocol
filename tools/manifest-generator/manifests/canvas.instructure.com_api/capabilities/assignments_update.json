{
  "name": "assignments_update",
  "description": "Update an assignment.",
  "resource_group": "assignments",
  "endpoint": "/api/v1/courses/{course_id}/assignments/{assignment_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "assignment_id",
      "type": "integer",
      "description": "Assignment ID.",
      "required": true,
      "example": 2001
    },
    {
      "name": "assignment[name]",
      "type": "string",
      "description": "Name.",
      "required": false,
      "example": "Homework 1 (Updated)"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/assignments/2001",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "assignment": {
        "name": "Homework 1 (Updated)"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 2001,
      "name": "Homework 1 (Updated)"
    }
  }
}