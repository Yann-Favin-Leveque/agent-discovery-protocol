{
  "name": "calendar_events_list",
  "description": "List calendar events.",
  "resource_group": "calendar_events",
  "endpoint": "/api/v1/calendar_events",
  "method": "GET",
  "parameters": [
    {
      "name": "context_codes[]",
      "type": "string",
      "description": "Context codes like course_1234.",
      "required": false,
      "example": "course_1234",
      "in": "query"
    },
    {
      "name": "start_date",
      "type": "string",
      "description": "Start date.",
      "required": false,
      "example": "2026-01-01",
      "in": "query"
    },
    {
      "name": "end_date",
      "type": "string",
      "description": "End date.",
      "required": false,
      "example": "2026-06-30",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/calendar_events?context_codes[]=course_1234",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 12001,
        "title": "Midterm",
        "start_at": "2026-03-15T09:00:00Z",
        "end_at": "2026-03-15T11:00:00Z"
      }
    ]
  }
}
