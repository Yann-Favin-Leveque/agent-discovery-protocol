{
  "name": "pages_get",
  "description": "Retrieve a wiki page.",
  "resource_group": "pages",
  "endpoint": "/api/v1/courses/{course_id}/pages/{url_or_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "url_or_id",
      "type": "string",
      "description": "Page URL slug or ID.",
      "required": true,
      "example": "syllabus",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/pages/syllabus",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "page_id": 11001,
      "url": "syllabus",
      "title": "Syllabus",
      "body": "<h1>Course Syllabus</h1>"
    }
  }
}
