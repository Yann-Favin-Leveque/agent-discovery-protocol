{
  "name": "pages_delete",
  "description": "Delete a wiki page.",
  "resource_group": "pages",
  "endpoint": "/api/v1/courses/{course_id}/pages/{url_or_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "url_or_id",
      "type": "string",
      "description": "Page URL slug.",
      "required": true,
      "example": "resources",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/pages/resources",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "page_id": 11002,
      "deleted": true
    }
  }
}
