{
  "name": "pages_list",
  "description": "List wiki pages in a course.",
  "resource_group": "pages",
  "endpoint": "/api/v1/courses/{course_id}/pages",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "sort",
      "type": "string",
      "description": "Sort by title or updated_at.",
      "required": false,
      "example": "title"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/pages",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "page_id": 11001,
        "url": "syllabus",
        "title": "Syllabus",
        "published": true
      }
    ]
  }
}