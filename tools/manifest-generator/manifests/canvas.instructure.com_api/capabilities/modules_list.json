{
  "name": "modules_list",
  "description": "List modules in a course.",
  "resource_group": "modules",
  "endpoint": "/api/v1/courses/{course_id}/modules",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/modules",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 6001,
        "name": "Week 1",
        "position": 1,
        "items_count": 5
      }
    ]
  }
}