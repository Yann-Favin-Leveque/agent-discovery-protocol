{
  "name": "discussions_list",
  "description": "List discussion topics for a course.",
  "resource_group": "discussions",
  "endpoint": "/api/v1/courses/{course_id}/discussion_topics",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "order_by",
      "type": "string",
      "description": "Sort order.",
      "required": false,
      "example": "recent_activity"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/discussion_topics",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 8001,
        "title": "Week 1 Discussion",
        "message": "Introduce yourself.",
        "posted_at": "2026-01-15T12:00:00Z"
      }
    ]
  }
}