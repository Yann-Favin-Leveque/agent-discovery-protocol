{
  "name": "users_get",
  "description": "Retrieve user details.",
  "resource_group": "users",
  "endpoint": "/api/v1/users/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "User ID or self.",
      "required": true,
      "example": "self",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/users/self",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 5001,
      "name": "Alice Smith",
      "email": "alice@school.edu",
      "login_id": "alice"
    }
  }
}
