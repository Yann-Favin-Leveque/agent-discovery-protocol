{
  "name": "calendar_events_delete",
  "description": "Delete a calendar event.",
  "resource_group": "calendar_events",
  "endpoint": "/api/v1/calendar_events/{event_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "event_id",
      "type": "integer",
      "description": "Event ID.",
      "required": true,
      "example": 12001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://canvas.instructure.com/api/v1/calendar_events/12001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12001,
      "deleted": true
    }
  }
}
