{
  "name": "courses_get",
  "description": "Retrieve a single course by ID.",
  "resource_group": "courses",
  "endpoint": "/api/v1/courses/{course_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "include[]",
      "type": "string",
      "description": "Extra info to include.",
      "required": false,
      "example": "total_students",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1234,
      "name": "Intro to CS",
      "course_code": "CS101",
      "start_at": "2026-01-15T00:00:00Z"
    }
  }
}
