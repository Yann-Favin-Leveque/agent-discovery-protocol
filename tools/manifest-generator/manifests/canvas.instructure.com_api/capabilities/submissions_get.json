{
  "name": "submissions_get",
  "description": "Retrieve a single submission.",
  "resource_group": "submissions",
  "endpoint": "/api/v1/courses/{course_id}/assignments/{assignment_id}/submissions/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "assignment_id",
      "type": "integer",
      "description": "Assignment ID.",
      "required": true,
      "example": 2001,
      "in": "path"
    },
    {
      "name": "user_id",
      "type": "integer",
      "description": "User ID.",
      "required": true,
      "example": 5001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/assignments/2001/submissions/5001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 3001,
      "user_id": 5001,
      "score": 95,
      "grade": "A"
    }
  }
}
