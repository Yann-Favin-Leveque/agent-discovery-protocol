{
  "name": "modules_get",
  "description": "Retrieve a module.",
  "resource_group": "modules",
  "endpoint": "/api/v1/courses/{course_id}/modules/{module_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "module_id",
      "type": "integer",
      "description": "Module ID.",
      "required": true,
      "example": 6001
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/modules/6001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 6001,
      "name": "Week 1",
      "position": 1,
      "items_count": 5
    }
  }
}