{
  "name": "enrollments_list",
  "description": "List enrollments for a course.",
  "resource_group": "enrollments",
  "endpoint": "/api/v1/courses/{course_id}/enrollments",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "type[]",
      "type": "string",
      "description": "Filter by type.",
      "required": false,
      "example": "StudentEnrollment",
      "in": "query"
    },
    {
      "name": "state[]",
      "type": "string",
      "description": "Filter by state.",
      "required": false,
      "example": "active",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/enrollments?type[]=StudentEnrollment",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 4001,
        "user_id": 5001,
        "type": "StudentEnrollment",
        "enrollment_state": "active",
        "course_id": 1234
      }
    ]
  }
}
