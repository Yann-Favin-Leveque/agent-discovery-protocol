{
  "name": "users_update",
  "description": "Update a user.",
  "resource_group": "users",
  "endpoint": "/api/v1/users/{user_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "user_id",
      "type": "integer",
      "description": "User ID.",
      "required": true,
      "example": 5001,
      "in": "path"
    },
    {
      "name": "user[name]",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "Alice B. Smith",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://canvas.instructure.com/api/v1/users/5001",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "user": {
        "name": "Alice B. Smith"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 5001,
      "name": "Alice B. Smith"
    }
  }
}
