{
  "name": "discussions_entries_list",
  "description": "List entries in a discussion.",
  "resource_group": "discussions",
  "endpoint": "/api/v1/courses/{course_id}/discussion_topics/{topic_id}/entries",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "topic_id",
      "type": "integer",
      "description": "Topic ID.",
      "required": true,
      "example": 8001
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/discussion_topics/8001/entries",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 9001,
        "user_id": 5001,
        "message": "Hello everyone!",
        "created_at": "2026-01-16T10:00:00Z"
      }
    ]
  }
}