{
  "name": "assignments_create",
  "description": "Create a new assignment.",
  "resource_group": "assignments",
  "endpoint": "/api/v1/courses/{course_id}/assignments",
  "method": "POST",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "assignment[name]",
      "type": "string",
      "description": "Name.",
      "required": true,
      "example": "Midterm Exam",
      "in": "body"
    },
    {
      "name": "assignment[points_possible]",
      "type": "number",
      "description": "Points.",
      "required": false,
      "example": 200,
      "in": "body"
    },
    {
      "name": "assignment[due_at]",
      "type": "string",
      "description": "Due date ISO8601.",
      "required": false,
      "example": "2026-03-15T23:59:00Z",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/assignments",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "assignment": {
        "name": "Midterm Exam",
        "points_possible": 200,
        "due_at": "2026-03-15T23:59:00Z"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2002,
      "name": "Midterm Exam",
      "points_possible": 200
    }
  }
}
