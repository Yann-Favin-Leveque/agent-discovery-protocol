{
  "name": "quizzes_get",
  "description": "Retrieve a quiz.",
  "resource_group": "quizzes",
  "endpoint": "/api/v1/courses/{course_id}/quizzes/{quiz_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "quiz_id",
      "type": "integer",
      "description": "Quiz ID.",
      "required": true,
      "example": 10001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/quizzes/10001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 10001,
      "title": "Quiz 1",
      "quiz_type": "assignment",
      "points_possible": 50,
      "question_count": 10
    }
  }
}
