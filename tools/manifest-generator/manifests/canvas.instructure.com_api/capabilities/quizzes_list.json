{
  "name": "quizzes_list",
  "description": "List quizzes in a course.",
  "resource_group": "quizzes",
  "endpoint": "/api/v1/courses/{course_id}/quizzes",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/quizzes",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 10001,
        "title": "Quiz 1",
        "quiz_type": "assignment",
        "points_possible": 50
      }
    ]
  }
}
