{
  "name": "discussions_create",
  "description": "Create a discussion topic.",
  "resource_group": "discussions",
  "endpoint": "/api/v1/courses/{course_id}/discussion_topics",
  "method": "POST",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "description": "Topic title.",
      "required": true,
      "example": "Week 2 Discussion",
      "in": "body"
    },
    {
      "name": "message",
      "type": "string",
      "description": "Topic body.",
      "required": false,
      "example": "Discuss this week readings.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/discussion_topics",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Week 2 Discussion",
      "message": "Discuss this week readings."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 8002,
      "title": "Week 2 Discussion"
    }
  }
}
