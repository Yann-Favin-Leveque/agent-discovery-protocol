{
  "name": "module_items_list",
  "description": "List items in a module.",
  "resource_group": "modules",
  "endpoint": "/api/v1/courses/{course_id}/modules/{module_id}/items",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "module_id",
      "type": "integer",
      "description": "Module ID.",
      "required": true,
      "example": 6001
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/modules/6001/items",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 7001,
        "title": "Intro Video",
        "type": "ExternalUrl",
        "position": 1
      }
    ]
  }
}