{
  "name": "courses_settings_get",
  "description": "Get course settings.",
  "resource_group": "courses",
  "endpoint": "/api/v1/courses/{course_id}/settings",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/settings",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hide_final_grades": false,
      "allow_student_discussion_topics": true
    }
  }
}