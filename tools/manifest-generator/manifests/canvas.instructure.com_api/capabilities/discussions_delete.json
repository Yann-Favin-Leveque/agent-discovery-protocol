{
  "name": "discussions_delete",
  "description": "Delete a discussion topic.",
  "resource_group": "discussions",
  "endpoint": "/api/v1/courses/{course_id}/discussion_topics/{topic_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "topic_id",
      "type": "integer",
      "description": "Topic ID.",
      "required": true,
      "example": 8001
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/discussion_topics/8001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 8001,
      "deleted": true
    }
  }
}