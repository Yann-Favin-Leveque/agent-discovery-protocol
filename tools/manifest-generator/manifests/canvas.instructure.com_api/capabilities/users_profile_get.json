{
  "name": "users_profile_get",
  "description": "Retrieve user profile.",
  "resource_group": "users",
  "endpoint": "/api/v1/users/{user_id}/profile",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "User ID or self.",
      "required": true,
      "example": "self"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/users/self/profile",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 5001,
      "name": "Alice Smith",
      "bio": "CS student",
      "avatar_url": "https://canvas.instructure.com/avatar.png"
    }
  }
}