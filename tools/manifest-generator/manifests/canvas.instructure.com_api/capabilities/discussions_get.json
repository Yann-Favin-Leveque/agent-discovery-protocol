{
  "name": "discussions_get",
  "description": "Retrieve a discussion topic.",
  "resource_group": "discussions",
  "endpoint": "/api/v1/courses/{course_id}/discussion_topics/{topic_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "topic_id",
      "type": "integer",
      "description": "Topic ID.",
      "required": true,
      "example": 8001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/discussion_topics/8001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 8001,
      "title": "Week 1 Discussion",
      "message": "Introduce yourself.",
      "discussion_type": "threaded"
    }
  }
}
