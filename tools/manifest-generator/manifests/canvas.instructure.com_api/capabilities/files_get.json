{
  "name": "files_get",
  "description": "Retrieve file metadata.",
  "resource_group": "files",
  "endpoint": "/api/v1/files/{file_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "file_id",
      "type": "integer",
      "description": "File ID.",
      "required": true,
      "example": 14001
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://canvas.instructure.com/api/v1/files/14001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 14001,
      "display_name": "syllabus.pdf",
      "url": "https://canvas.instructure.com/files/14001/download"
    }
  }
}