{
  "name": "enrollments_create",
  "description": "Enroll a user in a course.",
  "resource_group": "enrollments",
  "endpoint": "/api/v1/courses/{course_id}/enrollments",
  "method": "POST",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "enrollment[user_id]",
      "type": "integer",
      "description": "User ID.",
      "required": true,
      "example": 5002,
      "in": "body"
    },
    {
      "name": "enrollment[type]",
      "type": "string",
      "description": "Enrollment type.",
      "required": true,
      "example": "StudentEnrollment",
      "in": "body"
    },
    {
      "name": "enrollment[enrollment_state]",
      "type": "string",
      "description": "State.",
      "required": false,
      "example": "active",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/enrollments",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "enrollment": {
        "user_id": 5002,
        "type": "StudentEnrollment",
        "enrollment_state": "active"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 4002,
      "user_id": 5002,
      "type": "StudentEnrollment",
      "enrollment_state": "active"
    }
  }
}
