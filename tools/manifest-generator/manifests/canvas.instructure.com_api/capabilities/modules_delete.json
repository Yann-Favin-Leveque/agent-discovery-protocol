{
  "name": "modules_delete",
  "description": "Delete a module.",
  "resource_group": "modules",
  "endpoint": "/api/v1/courses/{course_id}/modules/{module_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234,
      "in": "path"
    },
    {
      "name": "module_id",
      "type": "integer",
      "description": "Module ID.",
      "required": true,
      "example": 6001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/modules/6001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 6001,
      "deleted": true
    }
  }
}
