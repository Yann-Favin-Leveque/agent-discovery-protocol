{
  "name": "assignments_delete",
  "description": "Delete an assignment.",
  "resource_group": "assignments",
  "endpoint": "/api/v1/courses/{course_id}/assignments/{assignment_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "assignment_id",
      "type": "integer",
      "description": "Assignment ID.",
      "required": true,
      "example": 2001
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://canvas.instructure.com/api/v1/courses/1234/assignments/2001",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 2001,
      "deleted": true
    }
  }
}