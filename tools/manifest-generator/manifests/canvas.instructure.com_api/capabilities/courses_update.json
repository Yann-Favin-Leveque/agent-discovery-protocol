{
  "name": "courses_update",
  "description": "Update an existing course.",
  "resource_group": "courses",
  "endpoint": "/api/v1/courses/{course_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "Course ID.",
      "required": true,
      "example": 1234
    },
    {
      "name": "course[name]",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "Intro to Computer Science"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://canvas.instructure.com/api/v1/courses/1234",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "course": {
        "name": "Intro to Computer Science"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1234,
      "name": "Intro to Computer Science"
    }
  }
}