{
  "name": "files_delete",
  "resource_group": "files",
  "description": "Delete a file from the workspace.",
  "endpoint": "/files.delete",
  "method": "POST",
  "parameters": [
    {
      "name": "file",
      "type": "string",
      "required": true,
      "description": "File ID to delete",
      "example": "F1234567890"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/files.delete",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "file": "F1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}