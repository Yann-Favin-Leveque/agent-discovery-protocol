{
  "name": "conversations_unarchive",
  "resource_group": "conversations",
  "description": "Unarchive a channel.",
  "endpoint": "/conversations.unarchive",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID to unarchive",
      "example": "C1234567890"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/conversations.unarchive",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}