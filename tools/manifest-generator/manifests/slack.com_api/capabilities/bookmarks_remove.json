{
  "name": "bookmarks_remove",
  "resource_group": "bookmarks",
  "description": "Remove a bookmark from a channel.",
  "endpoint": "/bookmarks.remove",
  "method": "POST",
  "parameters": [
    {
      "name": "bookmark_id",
      "type": "string",
      "required": true,
      "description": "Bookmark ID",
      "example": "Bk12345",
      "in": "body"
    },
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/bookmarks.remove",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "bookmark_id": "Bk12345",
      "channel_id": "C1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}
