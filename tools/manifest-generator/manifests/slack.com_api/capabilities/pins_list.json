{
  "name": "pins_list",
  "resource_group": "pins",
  "description": "List pinned items in a channel.",
  "endpoint": "/pins.list",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/pins.list?channel=C1234567890",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "items": [
        {
          "type": "message",
          "message": {
            "text": "Important announcement",
            "ts": "1503435956.000247"
          },
          "created": 1503435956
        }
      ]
    }
  }
}