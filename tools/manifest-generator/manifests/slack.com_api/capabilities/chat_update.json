{
  "name": "chat_update",
  "resource_group": "chat",
  "description": "Update an existing message's text, blocks, or attachments.",
  "endpoint": "/chat.update",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel containing the message",
      "example": "C1234567890",
      "in": "body"
    },
    {
      "name": "ts",
      "type": "string",
      "required": true,
      "description": "Timestamp of the message to update",
      "example": "1503435956.000247",
      "in": "body"
    },
    {
      "name": "text",
      "type": "string",
      "required": false,
      "description": "Updated message text",
      "example": "Updated message!",
      "in": "body"
    },
    {
      "name": "blocks",
      "type": "array",
      "required": false,
      "description": "Updated Block Kit blocks",
      "example": [],
      "in": "body"
    },
    {
      "name": "attachments",
      "type": "array",
      "required": false,
      "description": "Updated attachments",
      "example": [],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/chat.update",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "ts": "1503435956.000247",
      "text": "Updated message!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "channel": "C1234567890",
      "ts": "1503435956.000247",
      "text": "Updated message!"
    }
  }
}
