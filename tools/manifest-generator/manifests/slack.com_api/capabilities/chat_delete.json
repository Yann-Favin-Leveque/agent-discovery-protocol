{
  "name": "chat_delete",
  "resource_group": "chat",
  "description": "Delete a message from a channel.",
  "endpoint": "/chat.delete",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel containing the message",
      "example": "C1234567890"
    },
    {
      "name": "ts",
      "type": "string",
      "required": true,
      "description": "Timestamp of the message to delete",
      "example": "1503435956.000247"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/chat.delete",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "ts": "1503435956.000247"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "channel": "C1234567890",
      "ts": "1503435956.000247"
    }
  }
}