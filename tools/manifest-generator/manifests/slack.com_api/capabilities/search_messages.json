{
  "name": "search_messages",
  "resource_group": "search",
  "description": "Search for messages across the workspace using keywords and filters.",
  "endpoint": "/search.messages",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "Search query",
      "example": "project deadline"
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort by (score or timestamp)",
      "example": "timestamp"
    },
    {
      "name": "sort_dir",
      "type": "string",
      "required": false,
      "description": "Sort direction (asc or desc)",
      "example": "desc"
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Results per page",
      "example": 20
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number",
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/search.messages?query=project%20deadline&sort=timestamp&count=20",
    "headers": {
      "Authorization": "Bearer xoxp-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "query": "project deadline",
      "messages": {
        "total": 15,
        "paging": {
          "count": 20,
          "total": 15,
          "page": 1,
          "pages": 1
        },
        "matches": [
          {
            "type": "message",
            "user": "U1234567890",
            "text": "The project deadline is Friday",
            "ts": "1503435956.000247",
            "channel": {
              "id": "C1234567890",
              "name": "general"
            }
          }
        ]
      }
    }
  }
}