{
  "name": "users_info",
  "resource_group": "users",
  "description": "Retrieve information about a specific user.",
  "endpoint": "/users.info",
  "method": "GET",
  "parameters": [
    {
      "name": "user",
      "type": "string",
      "required": true,
      "description": "User ID",
      "example": "U1234567890"
    },
    {
      "name": "include_locale",
      "type": "boolean",
      "required": false,
      "description": "Include locale info",
      "example": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/users.info?user=U1234567890",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "user": {
        "id": "U1234567890",
        "name": "john",
        "real_name": "John Doe",
        "profile": {
          "email": "john@example.com"
        },
        "tz": "America/New_York"
      }
    }
  }
}