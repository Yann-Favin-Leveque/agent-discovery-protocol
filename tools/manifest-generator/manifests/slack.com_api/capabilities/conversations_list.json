{
  "name": "conversations_list",
  "resource_group": "conversations",
  "description": "List all channels (public, private, IMs, MPIMs) in a workspace.",
  "endpoint": "/conversations.list",
  "method": "GET",
  "parameters": [
    {
      "name": "types",
      "type": "string",
      "required": false,
      "description": "Comma-separated channel types (public_channel, private_channel, mpim, im)",
      "example": "public_channel,private_channel",
      "in": "query"
    },
    {
      "name": "exclude_archived",
      "type": "boolean",
      "required": false,
      "description": "Exclude archived channels",
      "example": true,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page (max 1000)",
      "example": 100,
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Pagination cursor",
      "example": "dXNlcjpVMDYx",
      "in": "query"
    },
    {
      "name": "team_id",
      "type": "string",
      "required": false,
      "description": "Team ID for Enterprise Grid",
      "example": "T1234567890",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/conversations.list?types=public_channel&exclude_archived=true&limit=100",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "channels": [
        {
          "id": "C1234567890",
          "name": "general",
          "is_channel": true,
          "is_archived": false,
          "topic": {
            "value": "Company-wide announcements"
          },
          "purpose": {
            "value": "General discussion"
          },
          "num_members": 150
        }
      ],
      "response_metadata": {
        "next_cursor": ""
      }
    }
  }
}
