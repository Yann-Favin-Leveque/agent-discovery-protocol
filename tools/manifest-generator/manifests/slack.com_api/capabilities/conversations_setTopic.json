{
  "name": "conversations_setTopic",
  "resource_group": "conversations",
  "description": "Set the topic of a channel.",
  "endpoint": "/conversations.setTopic",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    },
    {
      "name": "topic",
      "type": "string",
      "required": true,
      "description": "New channel topic",
      "example": "Sprint 5 Discussion"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/conversations.setTopic",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "topic": "Sprint 5 Discussion"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "topic": "Sprint 5 Discussion"
    }
  }
}