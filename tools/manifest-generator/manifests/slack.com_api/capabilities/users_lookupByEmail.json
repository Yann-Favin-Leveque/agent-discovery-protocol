{
  "name": "users_lookupByEmail",
  "resource_group": "users",
  "description": "Find a user by their email address.",
  "endpoint": "/users.lookupByEmail",
  "method": "GET",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email address to look up",
      "example": "john@example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/users.lookupByEmail?email=john@example.com",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "user": {
        "id": "U1234567890",
        "name": "john",
        "real_name": "John Doe",
        "profile": {
          "email": "john@example.com"
        }
      }
    }
  }
}