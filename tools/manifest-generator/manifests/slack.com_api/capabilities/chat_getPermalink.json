{
  "name": "chat_getPermalink",
  "resource_group": "chat",
  "description": "Get a permalink URL for a specific message.",
  "endpoint": "/chat.getPermalink",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    },
    {
      "name": "message_ts",
      "type": "string",
      "required": true,
      "description": "Message timestamp",
      "example": "1503435956.000247"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/chat.getPermalink?channel=C1234567890&message_ts=1503435956.000247",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "channel": "C1234567890",
      "permalink": "https://myteam.slack.com/archives/C1234567890/p1503435956000247"
    }
  }
}