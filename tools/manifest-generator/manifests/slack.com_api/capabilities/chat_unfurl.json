{
  "name": "chat_unfurl",
  "resource_group": "chat",
  "description": "Provide custom unfurl behavior for URLs in messages.",
  "endpoint": "/chat.unfurl",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "body"
    },
    {
      "name": "ts",
      "type": "string",
      "required": true,
      "description": "Message timestamp",
      "example": "1503435956.000247",
      "in": "body"
    },
    {
      "name": "unfurls",
      "type": "object",
      "required": true,
      "description": "Map of URLs to unfurl content",
      "example": {
        "https://example.com": {
          "text": "Custom unfurl"
        }
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/chat.unfurl",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "ts": "1503435956.000247",
      "unfurls": {
        "https://example.com": {
          "text": "Custom unfurl"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}
