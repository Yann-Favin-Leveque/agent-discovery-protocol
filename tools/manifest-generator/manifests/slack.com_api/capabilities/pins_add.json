{
  "name": "pins_add",
  "resource_group": "pins",
  "description": "Pin a message to a channel.",
  "endpoint": "/pins.add",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    },
    {
      "name": "timestamp",
      "type": "string",
      "required": true,
      "description": "Message timestamp to pin",
      "example": "1503435956.000247"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/pins.add",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "timestamp": "1503435956.000247"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}