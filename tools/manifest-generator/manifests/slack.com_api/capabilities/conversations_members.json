{
  "name": "conversations_members",
  "resource_group": "conversations",
  "description": "List members of a channel.",
  "endpoint": "/conversations.members",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page",
      "example": 100,
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Pagination cursor",
      "example": "",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/conversations.members?channel=C1234567890",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "members": [
        "U1234567890",
        "U0987654321"
      ],
      "response_metadata": {
        "next_cursor": ""
      }
    }
  }
}
