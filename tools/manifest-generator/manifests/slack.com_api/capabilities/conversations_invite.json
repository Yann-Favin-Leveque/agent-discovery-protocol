{
  "name": "conversations_invite",
  "resource_group": "conversations",
  "description": "Invite users to a channel.",
  "endpoint": "/conversations.invite",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    },
    {
      "name": "users",
      "type": "string",
      "required": true,
      "description": "Comma-separated user IDs",
      "example": "U1234567890,U0987654321"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/conversations.invite",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "users": "U1234567890,U0987654321"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "channel": {
        "id": "C1234567890",
        "name": "general"
      }
    }
  }
}