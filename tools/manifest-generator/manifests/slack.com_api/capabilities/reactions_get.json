{
  "name": "reactions_get",
  "resource_group": "reactions",
  "description": "Get reactions for a specific message.",
  "endpoint": "/reactions.get",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "query"
    },
    {
      "name": "timestamp",
      "type": "string",
      "required": true,
      "description": "Message timestamp",
      "example": "1503435956.000247",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/reactions.get?channel=C1234567890&timestamp=1503435956.000247",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "type": "message",
      "message": {
        "reactions": [
          {
            "name": "thumbsup",
            "count": 3,
            "users": [
              "U1234567890"
            ]
          }
        ]
      }
    }
  }
}
