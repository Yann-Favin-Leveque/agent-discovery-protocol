{
  "name": "conversations_kick",
  "resource_group": "conversations",
  "description": "Remove a user from a channel.",
  "endpoint": "/conversations.kick",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    },
    {
      "name": "user",
      "type": "string",
      "required": true,
      "description": "User ID to remove",
      "example": "U1234567890"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/conversations.kick",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "user": "U1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}