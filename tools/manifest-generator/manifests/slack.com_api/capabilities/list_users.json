{
  "name": "list_users",
  "description": "Retrieve a paginated list of all users in the workspace. Get user IDs, names, emails, real names, and status information.",
  "endpoint": "/users.list",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "The maximum number of users to return per page. Default is 0 (all users), maximum is 999.",
      "required": false,
      "example": 100
    },
    {
      "name": "cursor",
      "type": "string",
      "description": "Pagination cursor for fetching the next page of results.",
      "required": false,
      "example": "dXNlcjpVMDZEOUZWUkE="
    },
    {
      "name": "include_locale",
      "type": "boolean",
      "description": "Set to true to include user locale information in the response.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/users.list?limit=100",
    "headers": {
