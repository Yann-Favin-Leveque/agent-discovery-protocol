{
  "name": "chat_schedule_message",
  "resource_group": "chat",
  "description": "Schedule a message to be sent at a future time.",
  "endpoint": "/chat.scheduleMessage",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "body"
    },
    {
      "name": "text",
      "type": "string",
      "required": true,
      "description": "Message text",
      "example": "Reminder: meeting in 30 minutes!",
      "in": "body"
    },
    {
      "name": "post_at",
      "type": "integer",
      "required": true,
      "description": "Unix timestamp for when to send",
      "example": 1735689600,
      "in": "body"
    },
    {
      "name": "blocks",
      "type": "array",
      "required": false,
      "description": "Block Kit blocks",
      "example": [],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/chat.scheduleMessage",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "text": "Reminder: meeting in 30 minutes!",
      "post_at": 1735689600
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "channel": "C1234567890",
      "scheduled_message_id": "Q1298393284",
      "post_at": 1735689600
    }
  }
}
