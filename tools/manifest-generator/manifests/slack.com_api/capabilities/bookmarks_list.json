{
  "name": "bookmarks_list",
  "resource_group": "bookmarks",
  "description": "List all bookmarks in a channel.",
  "endpoint": "/bookmarks.list",
  "method": "GET",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/bookmarks.list?channel_id=C1234567890",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "bookmarks": [
        {
          "id": "Bk12345",
          "title": "Project Wiki",
          "link": "https://wiki.example.com"
        }
      ]
    }
  }
}
