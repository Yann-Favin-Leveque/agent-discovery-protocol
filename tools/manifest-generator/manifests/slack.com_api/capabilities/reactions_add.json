{
  "name": "reactions_add",
  "resource_group": "reactions",
  "description": "Add an emoji reaction to a message.",
  "endpoint": "/reactions.add",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "body"
    },
    {
      "name": "timestamp",
      "type": "string",
      "required": true,
      "description": "Message timestamp",
      "example": "1503435956.000247",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Emoji name (without colons)",
      "example": "thumbsup",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://slack.com/api/reactions.add",
    "headers": {
      "Authorization": "Bearer xoxb-xxx",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "C1234567890",
      "timestamp": "1503435956.000247",
      "name": "thumbsup"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}
