{
  "name": "conversations_info",
  "resource_group": "conversations",
  "description": "Retrieve information about a specific channel.",
  "endpoint": "/conversations.info",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    },
    {
      "name": "include_locale",
      "type": "boolean",
      "required": false,
      "description": "Include locale info",
      "example": false
    },
    {
      "name": "include_num_members",
      "type": "boolean",
      "required": false,
      "description": "Include member count",
      "example": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/conversations.info?channel=C1234567890&include_num_members=true",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "channel": {
        "id": "C1234567890",
        "name": "general",
        "is_channel": true,
        "topic": {
          "value": "Company-wide announcements"
        },
        "num_members": 150
      }
    }
  }
}