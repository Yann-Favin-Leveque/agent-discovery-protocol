{
  "name": "conversations_replies",
  "resource_group": "conversations",
  "description": "Retrieve all replies in a message thread.",
  "endpoint": "/conversations.replies",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890"
    },
    {
      "name": "ts",
      "type": "string",
      "required": true,
      "description": "Parent message timestamp",
      "example": "1503435956.000247"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page",
      "example": 100
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Pagination cursor",
      "example": "dXNlcjpVMDYx"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/conversations.replies?channel=C1234567890&ts=1503435956.000247",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "messages": [
        {
          "type": "message",
          "user": "U1234567890",
          "text": "Hello everyone!",
          "ts": "1503435956.000247",
          "reply_count": 2,
          "replies": [
            {
              "user": "U0987654321",
              "ts": "1503435957.000000"
            }
          ]
        }
      ]
    }
  }
}