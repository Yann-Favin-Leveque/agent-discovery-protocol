{
  "name": "conversations_history",
  "resource_group": "conversations",
  "description": "Fetch message history from a channel.",
  "endpoint": "/conversations.history",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel ID",
      "example": "C1234567890",
      "in": "query"
    },
    {
      "name": "latest",
      "type": "string",
      "required": false,
      "description": "End of time range (message ts)",
      "example": "1234567890.123456",
      "in": "query"
    },
    {
      "name": "oldest",
      "type": "string",
      "required": false,
      "description": "Start of time range",
      "example": "1234567800.000000",
      "in": "query"
    },
    {
      "name": "inclusive",
      "type": "boolean",
      "required": false,
      "description": "Include messages with oldest/latest timestamps",
      "example": true,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page (max 1000)",
      "example": 100,
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Pagination cursor",
      "example": "dXNlcjpVMDYx",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://slack.com/api/conversations.history?channel=C1234567890&limit=100",
    "headers": {
      "Authorization": "Bearer xoxb-xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "messages": [
        {
          "type": "message",
          "user": "U1234567890",
          "text": "Hello everyone!",
          "ts": "1503435956.000247"
        }
      ],
      "has_more": false,
      "response_metadata": {
        "next_cursor": ""
      }
    }
  }
}
