{
  "name": "webhook_subscriptions_get",
  "resource_group": "webhook_subscriptions",
  "description": "Retrieve a specific webhook subscription.",
  "endpoint": "/webhook_subscriptions/{uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Webhook subscription UUID",
      "example": "PPPP-QQQQ-RRRR"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/webhook_subscriptions/PPPP-QQQQ-RRRR",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/webhook_subscriptions/PPPP-QQQQ-RRRR",
        "callback_url": "https://example.com/webhook",
        "events": [
          "invitee.created"
        ],
        "state": "active"
      }
    }
  }
}