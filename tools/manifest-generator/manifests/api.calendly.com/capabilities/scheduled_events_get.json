{
  "name": "scheduled_events_get",
  "resource_group": "scheduled_events",
  "description": "Retrieve details of a specific scheduled event by UUID.",
  "endpoint": "/scheduled_events/{uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Scheduled event UUID",
      "example": "DDDD-EEEE-FFFF"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/scheduled_events/DDDD-EEEE-FFFF",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/scheduled_events/DDDD-EEEE-FFFF",
        "name": "30 Minute Meeting",
        "status": "active",
        "start_time": "2025-03-15T10:00:00Z",
        "end_time": "2025-03-15T10:30:00Z"
      }
    }
  }
}