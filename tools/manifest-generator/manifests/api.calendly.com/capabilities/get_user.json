{
  "name": "get_user",
  "description": "Retrieve the authenticated Calendly user's profile information. Returns the user's name, email, scheduling URL, timezone, avatar, organization, and current subscription plan. Use the 'me' shortcut to get the current user or provide a specific user UUID. The user URI returned here is needed for most other Calendly API calls.",
  "endpoint": "/users/me",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/users/me",
    "headers": {
      "Authorization": "Bearer pat_abcdefghijklmnop1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/users/abc123def456",
        "name": "Jane Smith",
        "slug": "janesmith",
        "email": "jane@example.com",
        "scheduling_url": "https://calendly.com/janesmith",
        "timezone": "America/New_York",
        "avatar_url": "https://calendly.com/avatars/abc123.jpg",
        "created_at": "2023-01-10T08:00:00.000000Z",
        "updated_at": "2024-01-20T12:00:00.000000Z",
        "current_organization": "https://api.calendly.com/organizations/org_xyz789",
        "resource_type": "User"
      }
    }
  }
}
