{
  "name": "list_event_types",
  "description": "Retrieve all event types for a Calendly user or organization. Event types define the types of meetings people can schedule (e.g., '30 Minute Meeting', '1-on-1 Consultation'). You must provide the user URI. Returns event type details including name, duration, scheduling URL, color, and whether the type is active.",
  "endpoint": "/event_types",
  "method": "GET",
  "parameters": [
    {
      "name": "user",
      "type": "string",
      "description": "The URI of the user whose event types to list (format: https://api.calendly.com/users/XXXXXXXX).",
      "required": true,
      "example": "https://api.calendly.com/users/abc123def456"
    },
    {
      "name": "active",
      "type": "boolean",
      "description": "Filter by active status. True returns only active event types.",
      "required": false,
      "example": true
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Number of results per page (max 100).",
      "required": false,
      "example": 20
    },
    {
      "name": "page_token",
      "type": "string",
      "description": "Token for fetching the next page of results.",
      "required": false,
      "example": "next-page-token-xyz"
    },
    {
      "name": "sort",
      "type": "string",
      "description": "Sort order: 'name:asc', 'name:desc', or by other fields.",
      "required": false,
      "example": "name:asc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/event_types?user=https://api.calendly.com/users/abc123def456&active=true&count=20",
    "headers": {
      "Authorization": "Bearer pat_abcdefghijklmnop1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collection": [
        {
