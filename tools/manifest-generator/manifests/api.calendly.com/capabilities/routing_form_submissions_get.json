{
  "name": "routing_form_submissions_get",
  "resource_group": "routing_forms",
  "description": "Retrieve a specific routing form submission.",
  "endpoint": "/routing_form_submissions/{uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Submission UUID",
      "example": "VVVV-WWWW-XXXX"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/routing_form_submissions/VVVV-WWWW-XXXX",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/routing_form_submissions/VVVV-WWWW-XXXX",
        "questions_and_answers": [
          {
            "question_uuid": "q1",
            "answer": "Engineering"
          }
        ]
      }
    }
  }
}