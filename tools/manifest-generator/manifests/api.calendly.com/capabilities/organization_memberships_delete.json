{
  "name": "organization_memberships_delete",
  "resource_group": "organization_memberships",
  "description": "Remove a user from the organization.",
  "endpoint": "/organization_memberships/{uuid}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Membership UUID to remove",
      "example": "JJJJ-KKKK-LLLL"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.calendly.com/organization_memberships/JJJJ-KKKK-LLLL",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}