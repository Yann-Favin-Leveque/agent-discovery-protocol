{
  "name": "users_get_current",
  "resource_group": "users",
  "description": "Retrieve the authenticated user's profile including name, email, timezone, and scheduling URL.",
  "endpoint": "/users/me",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/users/me",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/users/AAAA",
        "name": "John Doe",
        "email": "john@example.com",
        "scheduling_url": "https://calendly.com/johndoe",
        "timezone": "America/New_York",
        "slug": "johndoe",
        "current_organization": "https://api.calendly.com/organizations/BBBB"
      }
    }
  }
}