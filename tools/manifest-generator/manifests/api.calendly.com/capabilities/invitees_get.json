{
  "name": "invitees_get",
  "resource_group": "invitees",
  "description": "Get details about a specific invitee of a scheduled event.",
  "endpoint": "/scheduled_events/{event_uuid}/invitees/{invitee_uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "event_uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Scheduled event UUID",
      "example": "DDDD-EEEE-FFFF"
    },
    {
      "name": "invitee_uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Invitee UUID",
      "example": "GGGG-HHHH-IIII"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/scheduled_events/DDDD-EEEE-FFFF/invitees/GGGG-HHHH-IIII",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/scheduled_events/DDDD-EEEE-FFFF/invitees/GGGG-HHHH-IIII",
        "name": "Jane Smith",
        "email": "jane@example.com",
        "status": "active",
        "timezone": "America/Chicago"
      }
    }
  }
}