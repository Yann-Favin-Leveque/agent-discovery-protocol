{
  "name": "webhook_subscriptions_list",
  "resource_group": "webhook_subscriptions",
  "description": "List all webhook subscriptions for a user or organization.",
  "endpoint": "/webhook_subscriptions",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "description": "Organization URI",
      "example": "https://api.calendly.com/organizations/BBBB",
      "in": "query"
    },
    {
      "name": "user",
      "type": "string",
      "required": false,
      "description": "User URI to filter by",
      "example": "https://api.calendly.com/users/AAAA",
      "in": "query"
    },
    {
      "name": "scope",
      "type": "string",
      "required": false,
      "description": "Filter by scope (user or organization)",
      "example": "user",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Results per page",
      "example": 20,
      "in": "query"
    },
    {
      "name": "page_token",
      "type": "string",
      "required": false,
      "description": "Next page token",
      "example": "abc123",
      "in": "query"
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort order",
      "example": "created_at:desc",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/webhook_subscriptions?organization=https://api.calendly.com/organizations/BBBB",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collection": [
        {
          "uri": "https://api.calendly.com/webhook_subscriptions/PPPP",
          "callback_url": "https://example.com/webhook",
          "events": [
            "invitee.created",
            "invitee.canceled"
          ],
          "scope": "organization",
          "state": "active",
          "organization": "https://api.calendly.com/organizations/BBBB"
        }
      ],
      "pagination": {
        "count": 20,
        "next_page_token": null
      }
    }
  }
}
