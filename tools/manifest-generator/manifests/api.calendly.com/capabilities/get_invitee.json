{
  "name": "get_invitee",
  "description": "Get detailed information about a specific invitee of a scheduled Calendly event. Returns the invitee's name, email, timezone, answers to custom questions, tracking parameters (UTM), cancellation details if applicable, and payment info if the event type requires payment.",
  "endpoint": "/scheduled_events/{event_uuid}/invitees/{invitee_uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "event_uuid",
      "type": "string",
      "description": "The UUID of the scheduled event.",
      "required": true,
      "example": "evt_scheduled_123"
    },
    {
      "name": "invitee_uuid",
      "type": "string",
      "description": "The UUID of the invitee to retrieve.",
      "required": true,
      "example": "inv_abc456def"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/scheduled_events/evt_scheduled_123/invitees/inv_abc456def",
    "headers": {
      "Authorization": "Bearer pat_abcdefghijklmnop1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/scheduled_events/evt_scheduled_123/invitees/inv_abc456def",
        "email": "john@example.com",
        "name": "John Doe",
        "first_name": "John",
        "last_name": "Doe",
        "status": "active",
        "timezone": "America/New_York",
        "event": "https://api.calendly.com/scheduled_events/evt_scheduled_123",
        "created_at": "2024-02-10T09:00:00.000000Z",
        "updated_at": "2024-02-10T09:00:00.000000Z",
        "questions_and_answers": [
          {
            "question": "What would you like to discuss?",
            "answer": "Q1 product roadmap and partnership opportunities",
            "position": 0
          }
        ],
        "tracking": {
          "utm_campaign": null,
          "utm_source": "agent",
          "utm_medium": null,
          "utm_content": null,
          "utm_term": null,
          "salesforce_uuid": null
        },
        "text_reminder_number": null,
        "rescheduled": false,
        "old_invitee": null,
        "new_invitee": null,
        "cancel_url": "https://calendly.com/cancellations/inv_abc456def",
        "reschedule_url": "https://calendly.com/reschedulings/inv_abc456def",
        "payment": null,
        "no_show": null,
        "routing_form_submission": null
      }
    }
  }
}
