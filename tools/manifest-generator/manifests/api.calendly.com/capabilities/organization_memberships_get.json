{
  "name": "organization_memberships_get",
  "resource_group": "organization_memberships",
  "description": "Retrieve a specific organization membership.",
  "endpoint": "/organization_memberships/{uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Membership UUID",
      "example": "JJJJ-KKKK-LLLL"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/organization_memberships/JJJJ-KKKK-LLLL",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/organization_memberships/JJJJ-KKKK-LLLL",
        "role": "admin",
        "user": {
          "name": "John Doe",
          "email": "john@example.com"
        }
      }
    }
  }
}