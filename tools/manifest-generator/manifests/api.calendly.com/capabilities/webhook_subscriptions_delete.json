      "required": true,
      "in": "path",
      "description": "Webhook subscription UUID",
      "example": "PPPP-QQQQ-RRRR"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.calendly.com/webhook_subscriptions/PPPP-QQQQ-RRRR",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}