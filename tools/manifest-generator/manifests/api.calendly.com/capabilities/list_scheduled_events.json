{
  "name": "list_scheduled_events",
  "description": "List all scheduled events for a Calendly user, including past and upcoming meetings. You can filter by status (active or canceled), date range, and sort order. Returns event details including name, start/end times, location, invitees count, and status. Supports pagination.",
  "endpoint": "/scheduled_events",
  "method": "GET",
  "parameters": [
    {
      "name": "user",
      "type": "string",
      "description": "The URI of the user whose events to list.",
      "required": true,
      "example": "https://api.calendly.com/users/abc123def456"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by event status: 'active' or 'canceled'.",
      "required": false,
      "example": "active"
    },
    {
      "name": "min_start_time",
      "type": "string",
      "description": "Filter events starting on or after this ISO 8601 datetime.",
      "required": false,
      "example": "2024-02-01T00:00:00Z"
    },
    {
      "name": "max_start_time",
      "type": "string",
      "description": "Filter events starting before this ISO 8601 datetime.",
      "required": false,
      "example": "2024-02-28T23:59:59Z"
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Number of results per page (max 100).",
      "required": false,
      "example": 20
    },
    {
      "name": "page_token",
      "type": "string",
      "description": "Token for fetching the next page of results.",
      "required": false,
      "example": "next-page-token-xyz"
    },
    {
      "name": "sort",
      "type": "string",
      "description": "Sort by start time: 'start_time:asc' or 'start_time:desc'.",
      "required": false,
      "example": "start_time:asc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/scheduled_events?user=https://api.calendly.com/users/abc123def456&status=active&min_start_time=2024-02-01T00:00:00Z&count=20&sort=start_time:asc",
    "headers": {
      "Authorization": "Bearer pat_abcdefghijklmnop1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collection": [
        {
          "uri": "https://api.calendly.com/scheduled_events/evt_scheduled_123",
          "name": "30 Minute Meeting",
          "status": "active",
          "start_time": "2024-02-15T15:00:00.000000Z",
          "end_time": "2024-02-15T15:30:00.000000Z",
          "event_type": "https://api.calendly.com/event_types/evt123abc456",
          "location": {
            "type": "google_conference",
            "join_url": "https://meet.google.com/abc-defg-hij",
            "status": "pushed"
          },
          "invitees_counter": {
            "total": 1,
            "active": 1,
            "limit": 1
          },
          "created_at": "2024-02-10T09:00:00.000000Z",
          "updated_at": "2024-02-10T09:00:00.000000Z",
          "event_memberships": [
            {
              "user": "https://api.calendly.com/users/abc123def456",
              "user_name": "Jane Smith",
              "user_email": "jane@example.com"
            }
          ],
          "calendar_event": {
            "kind": "google",
            "external_id": "google-event-id-xyz"
          }
        }
      ],
      "pagination": {
        "count": 1,
        "next_page": null,
        "previous_page": null,
        "next_page_token": null,
        "previous_page_token": null
      }
    }
  }
}
