{
  "name": "data_compliance_delete_invitee",
  "resource_group": "data_compliance",
  "description": "Delete invitee data for GDPR/data compliance purposes.",
  "endpoint": "/data_compliance/deletion/invitees",
  "method": "POST",
  "parameters": [
    {
      "name": "emails",
      "type": "array",
      "required": true,
      "description": "List of invitee emails to delete",
      "example": [
        "invitee@example.com"
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.calendly.com/data_compliance/deletion/invitees",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "emails": [
        "invitee@example.com"
      ]
    }
  },
  "response_example": {
    "status": 202,
    "body": null
  }
}