{
  "name": "event_types_get",
  "resource_group": "event_types",
  "description": "Retrieve a specific event type by its UUID.",
  "endpoint": "/event_types/{uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Event type UUID",
      "example": "CCCC-DDDD-EEEE"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/event_types/CCCC-DDDD-EEEE",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/event_types/CCCC-DDDD-EEEE",
        "name": "30 Minute Meeting",
        "active": true,
        "duration": 30,
        "slug": "30min"
      }
    }
  }
}