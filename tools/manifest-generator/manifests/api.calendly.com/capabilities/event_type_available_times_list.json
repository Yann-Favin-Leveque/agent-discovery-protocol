{
  "name": "event_type_available_times_list",
  "resource_group": "availability",
  "description": "Retrieve available time slots for an event type within a date range.",
  "endpoint": "/event_type_available_times",
  "method": "GET",
  "parameters": [
    {
      "name": "event_type",
      "type": "string",
      "required": true,
      "description": "Event type URI",
      "example": "https://api.calendly.com/event_types/CCCC",
      "in": "query"
    },
    {
      "name": "start_time",
      "type": "string",
      "required": true,
      "description": "Start of range in ISO 8601",
      "example": "2025-03-15T00:00:00Z",
      "in": "query"
    },
    {
      "name": "end_time",
      "type": "string",
      "required": true,
      "description": "End of range in ISO 8601",
      "example": "2025-03-22T00:00:00Z",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/event_type_available_times?event_type=https://api.calendly.com/event_types/CCCC&start_time=2025-03-15T00:00:00Z&end_time=2025-03-22T00:00:00Z",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collection": [
        {
          "status": "available",
          "invitees_remaining": 1,
          "start_time": "2025-03-15T09:00:00Z",
          "scheduling_url": "https://calendly.com/johndoe/30min/2025-03-15T09:00:00Z"
        }
      ]
    }
  }
}
