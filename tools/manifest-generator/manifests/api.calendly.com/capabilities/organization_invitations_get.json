{
  "name": "organization_invitations_get",
  "resource_group": "organization_invitations",
  "description": "Retrieve a specific organization invitation.",
  "endpoint": "/organizations/{org_uuid}/invitations/{inv_uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "org_uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization UUID",
      "example": "BBBB-CCCC-DDDD"
    },
    {
      "name": "inv_uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Invitation UUID",
      "example": "MMMM-NNNN-OOOO"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/organizations/BBBB-CCCC-DDDD/invitations/MMMM-NNNN-OOOO",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/organizations/BBBB-CCCC-DDDD/invitations/MMMM-NNNN-OOOO",
        "email": "newuser@example.com",
        "status": "pending"
      }
    }
  }
}