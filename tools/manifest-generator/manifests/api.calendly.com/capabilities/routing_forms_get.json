{
  "name": "routing_forms_get",
  "resource_group": "routing_forms",
  "description": "Retrieve a specific routing form by UUID.",
  "endpoint": "/routing_forms/{uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Routing form UUID",
      "example": "SSSS-TTTT-UUUU"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/routing_forms/SSSS-TTTT-UUUU",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/routing_forms/SSSS-TTTT-UUUU",
        "name": "Meeting Router",
        "status": "published"
      }
    }
  }
}