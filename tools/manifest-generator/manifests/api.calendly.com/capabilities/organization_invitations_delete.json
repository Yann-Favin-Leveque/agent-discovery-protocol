{
  "name": "organization_invitations_delete",
  "resource_group": "organization_invitations",
  "description": "Revoke a pending organization invitation.",
  "endpoint": "/organizations/{org_uuid}/invitations/{inv_uuid}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "org_uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization UUID",
      "example": "BBBB-CCCC-DDDD"
    },
    {
      "name": "inv_uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Invitation UUID",
      "example": "MMMM-NNNN-OOOO"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.calendly.com/organizations/BBBB-CCCC-DDDD/invitations/MMMM-NNNN-OOOO",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}