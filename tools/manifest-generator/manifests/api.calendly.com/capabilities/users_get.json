{
  "name": "users_get",
  "resource_group": "users",
  "description": "Retrieve a specific user's profile by their URI.",
  "endpoint": "/users/{uuid}",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "User UUID from their URI",
      "example": "AAAA-BBBB-CCCC"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/users/AAAA-BBBB-CCCC",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": {
        "uri": "https://api.calendly.com/users/AAAA-BBBB-CCCC",
        "name": "John Doe",
        "email": "john@example.com",
        "timezone": "America/New_York"
      }
    }
  }
}