{
  "name": "organization_memberships_list",
  "resource_group": "organization_memberships",
  "description": "List all memberships in an organization.",
  "endpoint": "/organization_memberships",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": false,
      "description": "Organization URI",
      "example": "https://api.calendly.com/organizations/BBBB",
      "in": "query"
    },
    {
      "name": "user",
      "type": "string",
      "required": false,
      "description": "User URI",
      "example": "https://api.calendly.com/users/AAAA",
      "in": "query"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by member email",
      "example": "john@example.com",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Results per page",
      "example": 20,
      "in": "query"
    },
    {
      "name": "page_token",
      "type": "string",
      "required": false,
      "description": "Next page token",
      "example": "abc123",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/organization_memberships?organization=https://api.calendly.com/organizations/BBBB",
    "headers": {
      "Authorization": "Bearer CALENDLY_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collection": [
        {
          "uri": "https://api.calendly.com/organization_memberships/JJJJ",
          "role": "admin",
          "user": {
            "uri": "https://api.calendly.com/users/AAAA",
            "name": "John Doe",
            "email": "john@example.com"
          }
        }
      ],
      "pagination": {
        "count": 20,
        "next_page_token": null
      }
    }
  }
}
