{
  "name": "list_available_times",
  "description": "Retrieve available time slots for a specific Calendly event type within a date range. Returns a list of available scheduling windows that invitees can book. Useful for programmatically finding open times before sharing a scheduling link or creating a booking.",
  "endpoint": "/event_type_available_times",
  "method": "GET",
  "parameters": [
    {
      "name": "event_type",
      "type": "string",
      "description": "The URI of the event type to check availability for.",
      "required": true,
      "example": "https://api.calendly.com/event_types/evt123abc456"
    },
    {
      "name": "start_time",
      "type": "string",
      "description": "Start of the availability window in ISO 8601 format.",
      "required": true,
      "example": "2024-02-15T00:00:00Z"
    },
    {
      "name": "end_time",
      "type": "string",
      "description": "End of the availability window in ISO 8601 format. Maximum range is 7 days.",
      "required": true,
      "example": "2024-02-22T00:00:00Z"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.calendly.com/event_type_available_times?event_type=https://api.calendly.com/event_types/evt123abc456&start_time=2024-02-15T00:00:00Z&end_time=2024-02-22T00:00:00Z",
    "headers": {
      "Authorization": "Bearer pat_abcdefghijklmnop1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collection": [
        {
          "status": "available",
          "invitees_remaining": 1,
          "start_time": "2024-02-15T14:00:00.000000Z",
          "scheduling_url": "https://calendly.com/janesmith/30min?month=2024-02&date=2024-02-15&start_time=14:00"
        },
        {
          "status": "available",
          "invitees_remaining": 1,
          "start_time": "2024-02-15T14:30:00.000000Z",
          "scheduling_url": "https://calendly.com/janesmith/30min?month=2024-02&date=2024-02-15&start_time=14:30"
        },
        {
          "status": "available",
          "invitees_remaining": 1,
          "start_time": "2024-02-15T15:00:00.000000Z",
          "scheduling_url": "https://calendly.com/janesmith/30min?month=2024-02&date=2024-02-15&start_time=15:00"
        },
        {
          "status": "available",
          "invitees_remaining": 1,
          "start_time": "2024-02-16T09:00:00.000000Z",
          "scheduling_url": "https://calendly.com/janesmith/30min?month=2024-02&date=2024-02-16&start_time=09:00"
        },
        {
          "status": "available",
          "invitees_remaining": 1,
          "start_time": "2024-02-16T09:30:00.000000Z",
          "scheduling_url": "https://calendly.com/janesmith/30min?month=2024-02&date=2024-02-16&start_time=09:30"
        }
      ]
    }
  }
}
