{
  "name": "page_comments_list",
  "description": "List comments on a page.",
  "resource_group": "comments",
  "endpoint": "/v1/pages/{page_id}/comments",
  "method": "GET",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the page"
    },
    {
      "name": "start_cursor",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination cursor"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Results per page"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}