{
  "name": "blocks_update",
  "description": "Update a block's content.",
  "resource_group": "blocks",
  "endpoint": "/v1/blocks/{block_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "block_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the block"
    },
    {
      "name": "type",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "Block type content to update (e.g., paragraph, heading_1)"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}