{
  "name": "page_property_get",
  "description": "Retrieve a page property item.",
  "resource_group": "pages",
  "endpoint": "/v1/pages/{page_id}/properties/{property_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the page"
    },
    {
      "name": "property_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the property"
    },
    {
      "name": "start_cursor",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination cursor"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Number of items per page"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}