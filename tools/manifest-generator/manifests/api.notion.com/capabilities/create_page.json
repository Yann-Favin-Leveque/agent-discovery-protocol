{
  "name": "create_page",
  "description": "Create a new page in Notion as a child of a specified parent page or database. You can set the page's title, icon, cover, and properties (if the parent is a database). Optionally include content blocks as the page body.",
  "endpoint": "/v1/pages",
  "method": "POST",
  "parameters": [
    {
      "name": "parent",
      "type": "object",
      "description": "The parent of the new page. Either { \"database_id\": \"...\" } to create a row in a database, or { \"page_id\": \"...\" } to create a subpage.",
      "required": true,
      "example": {
        "database_id": "d9824bdc-8445-4327-be8b-5b47500af6ce"
      }
    },
    {
      "name": "properties",
      "type": "object",
      "description": "Page property values. For database parents, these must match the database schema. For page parents, only 'title' is required.",
      "required": true,
      "example": {
        "Name": {
          "title": [
            {
              "text": {
                "content": "New Task"
              }
            }
          ]
        },
        "Status": {
          "select": {
            "name": "In Progress"
          }
        }
      }
    },
    {
      "name": "children",
      "type": "array",
      "description": "Optional array of block objects to add as the page's initial content (paragraphs, headings, lists, etc.).",
      "required": false,
      "example": [
        {
          "object": "block",
          "type": "paragraph",
          "paragraph": {
            "rich_text": [
              {
                "type": "text",
                "text": {
                  "content": "This is the page content."
                }
              }
            ]
          }
        }
      ]
    },
    {
      "name": "icon",
      "type": "object",
      "description": "Optional page icon. Either an emoji or an external URL.",
      "required": false,
      "example": {
        "type": "emoji",
        "emoji": "rocket"
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.notion.com/v1/pages",
    "headers": {
      "Authorization": "Bearer your-integration-token",
      "Content-Type": "application/json",
      "Notion-Version": "2022-06-28"
    },
    "body": {
      "parent": {
        "database_id": "d9824bdc-8445-4327-be8b-5b47500af6ce"
      },
      "properties": {
        "Name": {
          "title": [
            {
              "text": {
                "content": "New Task"
              }
            }
          ]
        },
        "Status": {
          "select": {
            "name": "In Progress"
          }
        }
      },
      "children": [
        {
          "object": "block",
          "type": "paragraph",
          "paragraph": {
            "rich_text": [
              {
                "type": "text",
                "text": {
                  "content": "This is the initial content of the page."
                }
              }
            ]
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "page",
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "created_time": "2026-01-12T10:30:00.000Z",
      "last_edited_time": "2026-01-12T10:30:00.000Z",
      "archived": false,
      "url": "https://www.notion.so/New-Task-a1b2c3d4e5f67890abcdef1234567890",
      "parent": {
        "type": "database_id",
        "database_id": "d9824bdc-8445-4327-be8b-5b47500af6ce"
      },
      "properties": {
        "Name": {
          "id": "title",
          "type": "title",
          "title": [
            {
              "type": "text",
              "text": { "content": "New Task" },
              "plain_text": "New Task"
            }
          ]
        },
        "Status": {
          "id": "xyz",
          "type": "select",
          "select": {
            "id": "1",
            "name": "In Progress",
            "color": "blue"
          }
        }
      }
    }
  }
}
