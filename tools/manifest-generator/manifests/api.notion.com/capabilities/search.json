{
  "name": "search",
  "description": "Search across pages and databases in the workspace.",
  "resource_group": "search",
  "endpoint": "/v1/search",
  "method": "POST",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Search query text",
      "in": "body"
    },
    {
      "name": "filter",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Filter by object type (page or database)",
      "in": "body"
    },
    {
      "name": "sort",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Sort direction and timestamp",
      "in": "body"
    },
    {
      "name": "start_cursor",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Pagination cursor",
      "in": "body"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Number of results",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ],
  "request_example": {
    "query": "meeting notes",
    "filter": {
      "value": "page",
      "property": "object"
    },
    "sort": {
      "direction": "descending",
      "timestamp": "last_edited_time"
    }
  }
}
