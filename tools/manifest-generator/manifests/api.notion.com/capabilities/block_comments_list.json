{
  "name": "block_comments_list",
  "description": "List comments on a block.",
  "resource_group": "comments",
  "endpoint": "/v1/blocks/{block_id}/comments",
  "method": "GET",
  "parameters": [
    {
      "name": "block_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the block",
      "in": "path"
    },
    {
      "name": "start_cursor",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination cursor",
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Results per page",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
