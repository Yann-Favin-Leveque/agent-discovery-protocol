{
  "name": "files_send",
  "description": "Send file content to Notion.",
  "resource_group": "files",
  "endpoint": "/v1/files/{file_id}/send",
  "method": "POST",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the file upload"
    },
    {
      "name": "part_number",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Part number for multipart uploads"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}