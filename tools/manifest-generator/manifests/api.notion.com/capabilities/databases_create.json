{
  "name": "databases_create",
  "description": "Create a new database as a child of a page.",
  "resource_group": "databases",
  "endpoint": "/v1/databases",
  "method": "POST",
  "parameters": [
    {
      "name": "parent",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "Parent page reference",
      "in": "body"
    },
    {
      "name": "title",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Database title as rich text",
      "in": "body"
    },
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "Property schema for the database",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ],
  "request_example": {
    "parent": {
      "page_id": "page-id"
    },
    "title": [
      {
        "text": {
          "content": "My Database"
        }
      }
    ],
    "properties": {
      "Name": {
        "title": {}
      }
    }
  }
}
