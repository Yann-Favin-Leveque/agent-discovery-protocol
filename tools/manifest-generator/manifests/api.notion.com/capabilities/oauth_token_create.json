{
  "name": "oauth_token_create",
  "description": "Create an access token via OAuth.",
  "resource_group": "oauth",
  "endpoint": "/v1/oauth/token",
  "method": "POST",
  "parameters": [
    {
      "name": "grant_type",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "OAuth grant type (authorization_code)"
    },
    {
      "name": "code",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Authorization code"
    },
    {
      "name": "redirect_uri",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Redirect URI"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}