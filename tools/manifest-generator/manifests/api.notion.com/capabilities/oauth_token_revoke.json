{
  "name": "oauth_token_revoke",
  "description": "Revoke an access token.",
  "resource_group": "oauth",
  "endpoint": "/v1/oauth/token/revoke",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Token to revoke"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}