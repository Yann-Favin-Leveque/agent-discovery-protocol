{
  "name": "comments_create",
  "description": "Create a comment on a page or discussion thread.",
  "resource_group": "comments",
  "endpoint": "/v1/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "parent",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Parent page_id for top-level comments"
    },
    {
      "name": "discussion_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Discussion thread ID for replies"
    },
    {
      "name": "rich_text",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Comment content as rich text"
    }
  ],
  "auth_scopes": [
    "default"
  ],
  "request_example": {
    "parent": {
      "page_id": "page-id"
    },
    "rich_text": [
      {
        "text": {
          "content": "Great work!"
        }
      }
    ]
  }
}