{
  "name": "pages_update_markdown",
  "description": "Update page content using markdown.",
  "resource_group": "pages",
  "endpoint": "/v1/pages/{page_id}/markdown",
  "method": "PATCH",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the page"
    },
    {
      "name": "markdown",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Markdown content to set"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}