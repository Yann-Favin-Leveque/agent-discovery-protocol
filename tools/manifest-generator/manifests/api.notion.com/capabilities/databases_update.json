{
  "name": "databases_update",
  "description": "Update database title, description, or properties.",
  "resource_group": "databases",
  "endpoint": "/v1/databases/{database_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "database_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the database",
      "in": "path"
    },
    {
      "name": "title",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "New title",
      "in": "body"
    },
    {
      "name": "description",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "New description",
      "in": "body"
    },
    {
      "name": "properties",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Updated property schema",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
