{
  "name": "pages_move",
  "description": "Move a page to a new parent.",
  "resource_group": "pages",
  "endpoint": "/v1/pages/{page_id}/move",
  "method": "PUT",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the page to move"
    },
    {
      "name": "parent",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "New parent page or database"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}