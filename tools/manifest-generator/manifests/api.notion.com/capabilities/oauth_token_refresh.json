{
  "name": "oauth_token_refresh",
  "description": "Refresh an access token.",
  "resource_group": "oauth",
  "endpoint": "/v1/oauth/token/refresh",
  "method": "POST",
  "parameters": [
    {
      "name": "grant_type",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Must be 'refresh_token'"
    },
    {
      "name": "refresh_token",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "The refresh token"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}