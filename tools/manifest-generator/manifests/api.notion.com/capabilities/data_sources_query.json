{
  "name": "data_sources_query",
  "description": "Query a data source.",
  "resource_group": "data_sources",
  "endpoint": "/v1/data_sources/{data_source_id}/query",
  "method": "POST",
  "parameters": [
    {
      "name": "data_source_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the data source",
      "in": "path"
    },
    {
      "name": "filter",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Filter conditions",
      "in": "body"
    },
    {
      "name": "sorts",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "Sort criteria",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
