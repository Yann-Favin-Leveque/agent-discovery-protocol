{
  "name": "blocks_children_append",
  "description": "Append new children blocks to a parent.",
  "resource_group": "blocks",
  "endpoint": "/v1/blocks/{block_id}/children",
  "method": "PATCH",
  "parameters": [
    {
      "name": "block_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the parent block or page",
      "in": "path"
    },
    {
      "name": "children",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Array of block objects to append",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ],
  "request_example": {
    "children": [
      {
        "object": "block",
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Hello world"
              }
            }
          ]
        }
      }
    ]
  }
}
