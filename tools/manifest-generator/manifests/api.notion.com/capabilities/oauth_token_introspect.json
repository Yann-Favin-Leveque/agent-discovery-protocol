{
  "name": "oauth_token_introspect",
  "description": "Introspect a token's status and scope.",
  "resource_group": "oauth",
  "endpoint": "/v1/oauth/token/introspect",
  "method": "GET",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Token to introspect"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}