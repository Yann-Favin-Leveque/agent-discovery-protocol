{
  "name": "blocks_children_list",
  "description": "List child blocks of a block or page.",
  "resource_group": "blocks",
  "endpoint": "/v1/blocks/{block_id}/children",
  "method": "GET",
  "parameters": [
    {
      "name": "block_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the parent block or page",
      "in": "path"
    },
    {
      "name": "start_cursor",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination cursor",
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Number of results (max 100)",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
