{
  "name": "pages_update",
  "description": "Update properties of an existing page.",
  "resource_group": "pages",
  "endpoint": "/v1/pages/{page_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the page to update"
    },
    {
      "name": "properties",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Properties to update"
    },
    {
      "name": "archived",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Set to true to archive the page"
    },
    {
      "name": "icon",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Page icon"
    },
    {
      "name": "cover",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Page cover image"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}