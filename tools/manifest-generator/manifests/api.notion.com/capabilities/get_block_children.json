{
  "name": "get_block_children",
  "description": "Retrieve the content blocks that are children of a specific block or page. This is how you read the actual content of a Notion page: paragraphs, headings, lists, code blocks, images, and other block types. Supports pagination for pages with many blocks.",
  "endpoint": "/v1/blocks/{block_id}/children",
  "method": "GET",
  "parameters": [
    {
      "name": "block_id",
      "type": "string",
      "description": "The UUID of the block or page whose children to retrieve. Use a page ID to get the top-level content of a page.",
      "required": true,
      "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    },
    {
      "name": "start_cursor",
      "type": "string",
      "description": "Pagination cursor from a previous response to fetch the next page of blocks.",
      "required": false,
      "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Number of blocks to return per page (max 100, default 100).",
      "required": false,
      "example": 100
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.notion.com/v1/blocks/a1b2c3d4-e5f6-7890-abcd-ef1234567890/children?page_size=100",
    "headers": {
      "Authorization": "Bearer your-integration-token",
      "Notion-Version": "2022-06-28"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "list",
      "results": [
        {
          "object": "block",
          "id": "d4e5f6a7-b8c9-0123-defg-456789012345",
          "type": "heading_2",
          "heading_2": {
            "rich_text": [
              {
                "type": "text",
                "text": { "content": "Project Overview" },
                "plain_text": "Project Overview"
              }
            ],
            "color": "default"
          },
          "has_children": false
        },
        {
          "object": "block",
          "id": "e5f6a7b8-c9d0-1234-efgh-567890123456",
          "type": "paragraph",
          "paragraph": {
            "rich_text": [
              {
                "type": "text",
                "text": { "content": "This project aims to build a new dashboard for the analytics team." },
                "plain_text": "This project aims to build a new dashboard for the analytics team."
              }
            ],
            "color": "default"
          },
          "has_children": false
        },
        {
          "object": "block",
          "id": "f6a7b8c9-d0e1-2345-fghi-678901234567",
          "type": "bulleted_list_item",
          "bulleted_list_item": {
            "rich_text": [
              {
                "type": "text",
                "text": { "content": "Phase 1: Data collection" },
                "plain_text": "Phase 1: Data collection"
              }
            ],
            "color": "default"
          },
          "has_children": false
        }
      ],
      "has_more": false,
      "next_cursor": null
    }
  }
}
