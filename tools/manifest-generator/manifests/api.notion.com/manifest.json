{
  "spec_version": "1.0",
  "name": "Notion",
  "description": "Notion is an all-in-one workspace for notes, databases, wikis, and project management. The API provides full CRUD for pages, databases, blocks, comments, users, file uploads, data sources, and workspace search.",
  "base_url": "https://api.notion.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://www.notion.so/my-integrations"
  },
