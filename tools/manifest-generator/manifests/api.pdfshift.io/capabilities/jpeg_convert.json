{
  "name": "jpeg_convert",
  "description": "Convert an HTML string or URL to a JPEG screenshot image. Supports viewport sizing, full-page capture, quality control, and element selection.",
  "resource_group": "convert",
  "endpoint": "/convert/jpeg",
  "method": "POST",
  "parameters": [
    {
      "name": "source",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "URL or HTML string to convert."
    },
    {
      "name": "viewport",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Rendering window size. Default: '1280x1024'."
    },
    {
      "name": "fullpage",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Capture entire scrollable page. Default: false."
    },
    {
      "name": "quality",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "JPEG quality 10-100. Default: 80."
    },
    {
      "name": "css_selector",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "CSS selector to capture a specific element."
    },
    {
      "name": "dpi",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "DPI scaling: 1, 2, or 4. Default: 1."
    },
    {
      "name": "delay",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Delay in ms before capture. Default: 0."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pdfshift.io/v3/convert/jpeg",
    "headers": {
      "X-API-Key": "your-pdfshift-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "source": "https://example.com",
      "quality": 90,
      "fullpage": false
    }
  },
  "response_example": {
    "status": 200,
    "headers": {
      "Content-Type": "image/jpeg"
    },
    "body": "<binary JPEG content>"
  }
}
