{
  "name": "templates_get_html",
  "description": "Retrieve the raw HTML content of a saved template by its slug.",
  "resource_group": "templates",
  "endpoint": "/templates/{slug}.html",
  "method": "GET",
  "parameters": [
    {
      "name": "slug",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The unique template slug identifier.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pdfshift.io/v3/templates/invoice-template.html",
    "headers": {
      "X-API-Key": "your-pdfshift-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "headers": {
      "Content-Type": "text/html"
    },
    "body": "<html><body><h1>Invoice #{{invoice_number}}</h1><p>Amount: {{amount}}</p></body></html>"
  }
}
