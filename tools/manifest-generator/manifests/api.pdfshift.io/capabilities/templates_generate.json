{
  "name": "templates_generate",
  "description": "Generate a document from a saved template with variable substitution. Supports output formats: html, pdf, jpeg, png, webp. Template variables are replaced with provided data.",
  "resource_group": "templates",
  "endpoint": "/templates/{slug}.{ext}",
  "method": "POST",
  "parameters": [
    {
      "name": "slug",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The template slug identifier."
    },
    {
      "name": "ext",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Output format: 'html', 'pdf', 'jpeg', 'png', or 'webp'."
    },
    {
      "name": "variables",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Key-value pairs to replace template variables (e.g., { invoice_number: '001', amount: '99.99' })."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pdfshift.io/v3/templates/invoice-template.pdf",
    "headers": {
      "X-API-Key": "your-pdfshift-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "invoice_number": "INV-2026-001",
      "amount": "99.99",
      "due_date": "2026-04-01"
    }
  },
  "response_example": {
    "status": 200,
    "headers": {
      "Content-Type": "application/pdf"
    },
    "body": "<binary PDF content>"
  }
}
