{
  "name": "deals_list",
  "description": "List deals from a view.",
  "resource_group": "deals",
  "endpoint": "/deals/view/{view_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "view_id",
      "type": "integer",
      "required": true,
      "description": "View ID.",
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/deals/view/1"
  },
  "response_example": {
    "deals": [
      {
        "id": 1,
        "name": "Enterprise Deal",
        "amount": 50000
      }
    ],
    "meta": {
      "total": 25
    }
  }
}
