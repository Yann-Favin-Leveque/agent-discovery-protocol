{
  "name": "contacts_search",
  "description": "Search across entities.",
  "resource_group": "contacts",
  "endpoint": "/search",
  "method": "GET",
  "parameters": [
    {
      "name": "q",
      "type": "string",
      "required": true,
      "description": "Search query."
    },
    {
      "name": "include",
      "type": "string",
      "required": false,
      "description": "Entity types: contact, sales_account, deal."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/search?q=jane&include=contact"
  },
  "response_example": [
    {
      "id": 1,
      "type": "contact",
      "display_name": "Jane Doe",
      "email": "jane@example.com"
    }
  ]
}