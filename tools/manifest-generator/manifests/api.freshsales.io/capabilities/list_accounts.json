{
  "name": "list_accounts",
  "description": "List all accounts (companies) in Freshsales with optional search and filtering.",
  "endpoint": "/sales_accounts/view/{view_id}",
  "method": "GET",
  "parameters": [
    {"name": "view_id", "type": "number", "description": "View ID for filtering accounts.", "required": true, "example": 1},
    {"name": "page", "type": "number", "description": "Page number.", "required": false, "example": 1}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/sales_accounts/view/1?page=1",
    "headers": {"Authorization": "Token token={api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"sales_accounts": [{"id": 301, "name": "Acme Corp", "website": "https://acme.com", "number_of_employees": 500, "city": "San Francisco"}], "meta": {"total": 100, "total_pages": 10}}
  }
}
