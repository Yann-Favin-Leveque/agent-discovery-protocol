{
  "name": "tasks_update",
  "description": "Update a task.",
  "resource_group": "tasks",
  "endpoint": "/tasks/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Task ID.",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Title.",
      "in": "body"
    },
    {
      "name": "status",
      "type": "integer",
      "required": false,
      "description": "0=open, 1=completed.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://domain.freshsales.io/api/tasks/1",
    "body": {
      "task": {
        "status": 1
      }
    }
  },
  "response_example": {
    "task": {
      "id": 1,
      "status": 1
    }
  }
}
