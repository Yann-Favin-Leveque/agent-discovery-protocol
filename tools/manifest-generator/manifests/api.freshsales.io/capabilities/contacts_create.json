{
  "name": "contacts_create",
  "description": "Create a new contact.",
  "resource_group": "contacts",
  "endpoint": "/contacts",
  "method": "POST",
  "parameters": [
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "First name."
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Last name."
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Email."
    },
    {
      "name": "mobile_number",
      "type": "string",
      "required": false,
      "description": "Mobile."
    },
    {
      "name": "job_title",
      "type": "string",
      "required": false,
      "description": "Job title."
    },
    {
      "name": "sales_account_id",
      "type": "integer",
      "required": false,
      "description": "Account ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/contacts",
    "body": {
      "contact": {
        "first_name": "Jane",
        "last_name": "Doe",
        "email": "jane@example.com",
        "mobile_number": "+15551234567"
      }
    }
  },
  "response_example": {
    "contact": {
      "id": 1,
      "first_name": "Jane",
      "last_name": "Doe",
      "email": "jane@example.com"
    }
  }
}