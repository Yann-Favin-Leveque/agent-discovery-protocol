{
  "name": "notes_create",
  "description": "Create a note on a record.",
  "resource_group": "notes",
  "endpoint": "/notes",
  "method": "POST",
  "parameters": [
    {
      "name": "description",
      "type": "string",
      "required": true,
      "description": "Note content."
    },
    {
      "name": "targetable_type",
      "type": "string",
      "required": true,
      "description": "Type: Contact, SalesAccount, Deal."
    },
    {
      "name": "targetable_id",
      "type": "integer",
      "required": true,
      "description": "Record ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/notes",
    "body": {
      "note": {
        "description": "Meeting notes",
        "targetable_type": "Contact",
        "targetable_id": 1
      }
    }
  },
  "response_example": {
    "note": {
      "id": 1,
      "description": "Meeting notes"
    }
  }
}