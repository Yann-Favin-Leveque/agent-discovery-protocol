{
  "name": "accounts_update",
  "description": "Update a sales account.",
  "resource_group": "accounts",
  "endpoint": "/sales_accounts/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Name."
    },
    {
      "name": "website",
      "type": "string",
      "required": false,
      "description": "Website."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://domain.freshsales.io/api/sales_accounts/1",
    "body": {
      "sales_account": {
        "website": "https://acme.io"
      }
    }
  },
  "response_example": {
    "sales_account": {
      "id": 1,
      "website": "https://acme.io"
    }
  }
}