{
  "name": "appointments_update",
  "description": "Update an appointment.",
  "resource_group": "appointments",
  "endpoint": "/appointments/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Appointment ID."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Title."
    },
    {
      "name": "from_date",
      "type": "string",
      "required": false,
      "description": "Start."
    },
    {
      "name": "end_date",
      "type": "string",
      "required": false,
      "description": "End."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://domain.freshsales.io/api/appointments/1",
    "body": {
      "appointment": {
        "title": "Updated demo"
      }
    }
  },
  "response_example": {
    "appointment": {
      "id": 1,
      "title": "Updated demo"
    }
  }
}