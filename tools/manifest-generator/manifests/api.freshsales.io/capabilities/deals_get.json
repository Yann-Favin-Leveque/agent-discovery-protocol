{
  "name": "deals_get",
  "description": "Get a deal by ID.",
  "resource_group": "deals",
  "endpoint": "/deals/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Deal ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/deals/1"
  },
  "response_example": {
    "deal": {
      "id": 1,
      "name": "Enterprise Deal",
      "amount": 50000,
      "deal_stage": {
        "name": "Qualified"
      }
    }
  }
}
