{
  "name": "accounts_list",
  "description": "List accounts from a view.",
  "resource_group": "accounts",
  "endpoint": "/sales_accounts/view/{view_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "view_id",
      "type": "integer",
      "required": true,
      "description": "View ID.",
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/sales_accounts/view/1"
  },
  "response_example": {
    "sales_accounts": [
      {
        "id": 1,
        "name": "Acme Corp"
      }
    ],
    "meta": {
      "total": 50
    }
  }
}
