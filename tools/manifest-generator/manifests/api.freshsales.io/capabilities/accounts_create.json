{
  "name": "accounts_create",
  "description": "Create a sales account.",
  "resource_group": "accounts",
  "endpoint": "/sales_accounts",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Account name."
    },
    {
      "name": "website",
      "type": "string",
      "required": false,
      "description": "Website."
    },
    {
      "name": "phone",
      "type": "string",
      "required": false,
      "description": "Phone."
    },
    {
      "name": "industry_type_id",
      "type": "integer",
      "required": false,
      "description": "Industry type."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/sales_accounts",
    "body": {
      "sales_account": {
        "name": "Acme Corp",
        "website": "https://acme.com"
      }
    }
  },
  "response_example": {
    "sales_account": {
      "id": 1,
      "name": "Acme Corp",
      "website": "https://acme.com"
    }
  }
}