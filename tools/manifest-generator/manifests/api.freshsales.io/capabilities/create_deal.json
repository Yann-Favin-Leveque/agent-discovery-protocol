{
  "name": "create_deal",
  "description": "Create a new deal in Freshsales with amount, pipeline stage, and expected close date.",
  "endpoint": "/deals",
  "method": "POST",
  "parameters": [
    {"name": "deal", "type": "object", "description": "Deal object with properties.", "required": true, "example": {"name": "Enterprise License", "amount": 50000, "expected_close": "2024-06-01", "deal_stage_id": 1, "contact_id": 123}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/deals",
    "headers": {"Authorization": "Token token={api_key}", "Content-Type": "application/json"},
    "body": {"deal": {"name": "Enterprise License", "amount": 50000, "expected_close": "2024-06-01", "deal_stage_id": 1, "contact_id": 123}}
  },
  "response_example": {
    "status": 201,
    "body": {"deal": {"id": 101, "name": "Enterprise License", "amount": 50000, "expected_close": "2024-06-01", "created_at": "2024-01-20T10:00:00Z"}}
  }
}
