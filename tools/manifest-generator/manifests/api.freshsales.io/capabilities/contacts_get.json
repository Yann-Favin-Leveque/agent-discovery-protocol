{
  "name": "contacts_get",
  "description": "Get a contact by ID.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Contact ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/contacts/1"
  },
  "response_example": {
    "contact": {
      "id": 1,
      "first_name": "Jane",
      "last_name": "Doe",
      "email": "jane@example.com",
      "sales_account": {
        "id": 1,
        "name": "Acme Corp"
      }
    }
  }
}