{
  "name": "contacts_update",
  "description": "Update a contact.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Contact ID.",
      "in": "path"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Email.",
      "in": "body"
    },
    {
      "name": "job_title",
      "type": "string",
      "required": false,
      "description": "Job title.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://domain.freshsales.io/api/contacts/1",
    "body": {
      "contact": {
        "job_title": "VP Sales"
      }
    }
  },
  "response_example": {
    "contact": {
      "id": 1,
      "job_title": "VP Sales"
    }
  }
}
