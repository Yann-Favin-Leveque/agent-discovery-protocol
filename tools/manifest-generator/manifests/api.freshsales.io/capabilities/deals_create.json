{
  "name": "deals_create",
  "description": "Create a deal.",
  "resource_group": "deals",
  "endpoint": "/deals",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Deal name.",
      "in": "body"
    },
    {
      "name": "amount",
      "type": "number",
      "required": false,
      "description": "Deal amount.",
      "in": "body"
    },
    {
      "name": "expected_close",
      "type": "string",
      "required": false,
      "description": "Expected close date.",
      "in": "body"
    },
    {
      "name": "sales_account_id",
      "type": "integer",
      "required": false,
      "description": "Account.",
      "in": "body"
    },
    {
      "name": "deal_stage_id",
      "type": "integer",
      "required": false,
      "description": "Stage.",
      "in": "body"
    },
    {
      "name": "deal_pipeline_id",
      "type": "integer",
      "required": false,
      "description": "Pipeline.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/deals",
    "body": {
      "deal": {
        "name": "Enterprise Deal",
        "amount": 50000,
        "sales_account_id": 1,
        "deal_stage_id": 1
      }
    }
  },
  "response_example": {
    "deal": {
      "id": 1,
      "name": "Enterprise Deal",
      "amount": 50000
    }
  }
}
