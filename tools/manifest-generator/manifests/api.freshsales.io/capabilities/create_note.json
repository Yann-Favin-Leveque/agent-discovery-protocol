{
  "name": "create_note",
  "description": "Add a note to a contact, account, or deal in Freshsales.",
  "endpoint": "/notes",
  "method": "POST",
  "parameters": [
    {"name": "note", "type": "object", "description": "Note object with description and targetable reference.", "required": true, "example": {"description": "Follow up on pricing discussion.", "targetable_type": "Contact", "targetable_id": 123}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/notes",
    "headers": {"Authorization": "Token token={api_key}", "Content-Type": "application/json"},
    "body": {"note": {"description": "Follow up on pricing discussion.", "targetable_type": "Contact", "targetable_id": 123}}
  },
  "response_example": {
    "status": 201,
    "body": {"note": {"id": 202, "description": "Follow up on pricing discussion.", "targetable_type": "Contact", "targetable_id": 123, "created_at": "2024-01-20T10:00:00Z"}}
  }
}
