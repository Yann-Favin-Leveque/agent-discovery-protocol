{
  "name": "notes_update",
  "description": "Update a note.",
  "resource_group": "notes",
  "endpoint": "/notes/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Note ID.",
      "in": "path"
    },
    {
      "name": "description",
      "type": "string",
      "required": true,
      "description": "Updated content.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://domain.freshsales.io/api/notes/1",
    "body": {
      "note": {
        "description": "Updated notes"
      }
    }
  },
  "response_example": {
    "note": {
      "id": 1,
      "description": "Updated notes"
    }
  }
}
