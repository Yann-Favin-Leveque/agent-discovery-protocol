{
  "name": "sales_activities_create",
  "description": "Create a sales activity.",
  "resource_group": "sales_activities",
  "endpoint": "/sales_activities",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Activity title."
    },
    {
      "name": "sales_activity_type_id",
      "type": "integer",
      "required": true,
      "description": "Activity type ID."
    },
    {
      "name": "targetable_type",
      "type": "string",
      "required": false,
      "description": "Target type."
    },
    {
      "name": "targetable_id",
      "type": "integer",
      "required": false,
      "description": "Target ID."
    },
    {
      "name": "start_date",
      "type": "string",
      "required": false,
      "description": "Start date."
    },
    {
      "name": "end_date",
      "type": "string",
      "required": false,
      "description": "End date."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/sales_activities",
    "body": {
      "sales_activity": {
        "title": "Cold call",
        "sales_activity_type_id": 1,
        "targetable_type": "Contact",
        "targetable_id": 1
      }
    }
  },
  "response_example": {
    "sales_activity": {
      "id": 1,
      "title": "Cold call"
    }
  }
}