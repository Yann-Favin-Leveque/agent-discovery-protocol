{
  "name": "accounts_get",
  "description": "Get a sales account by ID.",
  "resource_group": "accounts",
  "endpoint": "/sales_accounts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Account ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/sales_accounts/1"
  },
  "response_example": {
    "sales_account": {
      "id": 1,
      "name": "Acme Corp",
      "website": "https://acme.com",
      "open_deals_amount": 50000
    }
  }
}