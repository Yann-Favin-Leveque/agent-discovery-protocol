{
  "name": "contacts_list",
  "description": "List contacts from a view.",
  "resource_group": "contacts",
  "endpoint": "/contacts/view/{view_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "view_id",
      "type": "integer",
      "required": true,
      "description": "View ID.",
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page (default 25).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://domain.freshsales.io/api/contacts/view/1?per_page=10"
  },
  "response_example": {
    "contacts": [
      {
        "id": 1,
        "first_name": "Jane",
        "last_name": "Doe",
        "email": "jane@example.com"
      }
    ],
    "meta": {
      "total_pages": 5,
      "total": 100
    }
  }
}
