{
  "name": "deals_update",
  "description": "Update a deal.",
  "resource_group": "deals",
  "endpoint": "/deals/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Deal ID."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Name."
    },
    {
      "name": "amount",
      "type": "number",
      "required": false,
      "description": "Amount."
    },
    {
      "name": "deal_stage_id",
      "type": "integer",
      "required": false,
      "description": "Stage."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://domain.freshsales.io/api/deals/1",
    "body": {
      "deal": {
        "deal_stage_id": 3,
        "amount": 55000
      }
    }
  },
  "response_example": {
    "deal": {
      "id": 1,
      "amount": 55000
    }
  }
}