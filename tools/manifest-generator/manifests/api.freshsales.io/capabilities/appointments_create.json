{
  "name": "appointments_create",
  "description": "Create an appointment.",
  "resource_group": "appointments",
  "endpoint": "/appointments",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Title."
    },
    {
      "name": "from_date",
      "type": "string",
      "required": true,
      "description": "Start datetime ISO 8601."
    },
    {
      "name": "end_date",
      "type": "string",
      "required": true,
      "description": "End datetime ISO 8601."
    },
    {
      "name": "targetable_type",
      "type": "string",
      "required": false,
      "description": "Type."
    },
    {
      "name": "targetable_id",
      "type": "integer",
      "required": false,
      "description": "Record ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/appointments",
    "body": {
      "appointment": {
        "title": "Demo call",
        "from_date": "2026-01-22T10:00:00Z",
        "end_date": "2026-01-22T11:00:00Z",
        "targetable_type": "Contact",
        "targetable_id": 1
      }
    }
  },
  "response_example": {
    "appointment": {
      "id": 1,
      "title": "Demo call"
    }
  }
}