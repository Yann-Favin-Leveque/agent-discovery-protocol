{
  "name": "create_contact",
  "description": "Create a new contact in Freshsales with personal and business information.",
  "endpoint": "/contacts",
  "method": "POST",
  "parameters": [
    {"name": "contact", "type": "object", "description": "Contact object with properties.", "required": true, "example": {"first_name": "Jane", "last_name": "Smith", "email": "jane@example.com", "mobile_number": "+1234567890", "job_title": "VP Sales"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://domain.freshsales.io/api/contacts",
    "headers": {"Authorization": "Token token={api_key}", "Content-Type": "application/json"},
    "body": {"contact": {"first_name": "Jane", "last_name": "Smith", "email": "jane@example.com", "mobile_number": "+1234567890", "job_title": "VP Sales"}}
  },
  "response_example": {
    "status": 201,
    "body": {"contact": {"id": 456, "first_name": "Jane", "last_name": "Smith", "email": "jane@example.com", "created_at": "2024-01-20T10:00:00Z"}}
  }
}
