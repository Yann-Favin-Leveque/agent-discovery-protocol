{
  "name": "line_items_delete",
  "description": "Delete a line item.",
  "resource_group": "line_items",
  "endpoint": "/12/accounts/{account_id}/line_items/{line_item_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "line_item_id",
      "type": "string",
      "description": "Line item ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/line_items/li_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "li_1",
        "deleted": true
      }
    }
  }
}
