{
  "name": "targeting_criteria_delete",
  "description": "Remove targeting criteria.",
  "resource_group": "targeting",
  "endpoint": "/12/accounts/{account_id}/targeting_criteria/{targeting_criterion_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true
    },
    {
      "name": "targeting_criterion_id",
      "type": "string",
      "description": "Targeting criterion ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/targeting_criteria/tc_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "tc_1",
        "deleted": true
      }
    }
  }
}