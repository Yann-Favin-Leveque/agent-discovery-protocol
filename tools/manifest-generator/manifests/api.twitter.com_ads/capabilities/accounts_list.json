{
  "name": "accounts_list",
  "description": "List all ad accounts accessible by the authenticated user.",
  "resource_group": "accounts",
  "endpoint": "/12/accounts",
  "method": "GET",
  "parameters": [
    {
      "name": "with_deleted",
      "type": "boolean",
      "description": "Include deleted accounts.",
      "required": false
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Number of results. Max 1000.",
      "required": false,
      "example": 50
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "abc123",
          "name": "My Ad Account",
          "approval_status": "ACCEPTED"
        }
      ]
    }
  }
}