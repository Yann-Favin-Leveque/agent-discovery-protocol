{
  "name": "promoted_tweets_delete",
  "description": "Remove a promoted tweet.",
  "resource_group": "promoted_tweets",
  "endpoint": "/12/accounts/{account_id}/promoted_tweets/{promoted_tweet_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "promoted_tweet_id",
      "type": "string",
      "description": "Promoted tweet ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/promoted_tweets/pt_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "pt_1",
        "deleted": true
      }
    }
  }
}
