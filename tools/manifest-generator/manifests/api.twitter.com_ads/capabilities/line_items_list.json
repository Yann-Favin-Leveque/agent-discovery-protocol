{
  "name": "line_items_list",
  "description": "List all line items for a campaign.",
  "resource_group": "line_items",
  "endpoint": "/12/accounts/{account_id}/line_items",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true
    },
    {
      "name": "campaign_ids",
      "type": "string",
      "description": "Comma-separated campaign IDs.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/line_items?campaign_ids=camp_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "li_1",
          "campaign_id": "camp_1",
          "bid_amount_local_micro": 1500000
        }
      ]
    }
  }
}