{
  "name": "manage_creatives",
  "description": "Create and manage promoted tweets and creative assets for your X ad campaigns. Associate an existing tweet with a line item to promote it, or create website cards and app cards as rich creative formats.",
  "endpoint": "/12/accounts/{account_id}/promoted_tweets",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The X Ads account ID.",
      "required": true,
      "example": "abc123xyz"
    },
    {
      "name": "line_item_id",
      "type": "string",
      "description": "The line item to associate the promoted tweet with.",
      "required": true,
      "example": "li_def456"
    },
    {
      "name": "tweet_ids",
      "type": "array",
      "description": "Array of tweet IDs to promote under this line item.",
      "required": true,
      "example": ["1234567890123456789"]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://ads-api.twitter.com/12/accounts/abc123xyz/promoted_tweets",
    "headers": {
      "Authorization": "OAuth oauth_consumer_key=\"{consumer_key}\", oauth_token=\"{access_token}\", ...",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "line_item_id": "li_def456",
      "tweet_ids": ["1234567890123456789"]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "pt_ghi789",
          "line_item_id": "li_def456",
          "tweet_id": "1234567890123456789",
          "entity_status": "ACTIVE",
          "created_at": "2026-03-01T12:10:00Z"
        }
      ]
    }
  }
}
