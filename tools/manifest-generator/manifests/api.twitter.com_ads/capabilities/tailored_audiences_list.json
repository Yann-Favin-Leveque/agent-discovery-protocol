{
  "name": "tailored_audiences_list",
  "description": "List all tailored audiences.",
  "resource_group": "audiences",
  "endpoint": "/12/accounts/{account_id}/tailored_audiences",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/tailored_audiences",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "ta_1",
          "name": "Email List",
          "audience_size": 5000,
          "audience_type": "CRM"
        }
      ]
    }
  }
}
