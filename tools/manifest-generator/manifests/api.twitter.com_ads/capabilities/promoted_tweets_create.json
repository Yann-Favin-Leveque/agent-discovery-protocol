{
  "name": "promoted_tweets_create",
  "description": "Promote a tweet.",
  "resource_group": "promoted_tweets",
  "endpoint": "/12/accounts/{account_id}/promoted_tweets",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "line_item_id",
      "type": "string",
      "description": "Line item ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "tweet_ids",
      "type": "array",
      "description": "Tweet IDs to promote.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/promoted_tweets",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "line_item_id": "li_1",
      "tweet_ids": [
        "123456789"
      ]
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": [
        {
          "id": "pt_2",
          "tweet_id": "123456789"
        }
      ]
    }
  }
}
