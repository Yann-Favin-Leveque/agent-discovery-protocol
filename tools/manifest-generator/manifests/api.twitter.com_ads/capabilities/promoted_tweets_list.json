{
  "name": "promoted_tweets_list",
  "description": "List promoted tweets.",
  "resource_group": "promoted_tweets",
  "endpoint": "/12/accounts/{account_id}/promoted_tweets",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true
    },
    {
      "name": "line_item_ids",
      "type": "string",
      "description": "Filter by line item IDs.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/promoted_tweets",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "pt_1",
          "line_item_id": "li_1",
          "tweet_id": "123456789"
        }
      ]
    }
  }
}