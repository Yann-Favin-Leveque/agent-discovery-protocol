{
  "name": "campaigns_list",
  "description": "List all campaigns for an ad account.",
  "resource_group": "campaigns",
  "endpoint": "/12/accounts/{account_id}/campaigns",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true
    },
    {
      "name": "with_deleted",
      "type": "boolean",
      "description": "Include deleted.",
      "required": false
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Results per page.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/campaigns",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "camp_1",
          "name": "Spring Sale",
          "entity_status": "ACTIVE"
        }
      ]
    }
  }
}