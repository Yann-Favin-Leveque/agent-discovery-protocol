{
  "name": "campaigns_get",
  "description": "Retrieve a specific campaign.",
  "resource_group": "campaigns",
  "endpoint": "/12/accounts/{account_id}/campaigns/{campaign_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true
    },
    {
      "name": "campaign_id",
      "type": "string",
      "description": "Campaign ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/campaigns/camp_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "camp_1",
        "name": "Spring Sale",
        "entity_status": "ACTIVE",
        "daily_budget_amount_local_micro": 50000000
      }
    }
  }
}