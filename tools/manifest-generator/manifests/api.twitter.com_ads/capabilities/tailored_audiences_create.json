{
  "name": "tailored_audiences_create",
  "description": "Create a new tailored audience.",
  "resource_group": "audiences",
  "endpoint": "/12/accounts/{account_id}/tailored_audiences",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Audience name.",
      "required": true,
      "in": "body"
    },
    {
      "name": "list_type",
      "type": "string",
      "description": "EMAIL, DEVICE_ID, TWITTER_ID, etc.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/tailored_audiences",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Email List",
      "list_type": "EMAIL"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "ta_2",
        "name": "Email List"
      }
    }
  }
}
