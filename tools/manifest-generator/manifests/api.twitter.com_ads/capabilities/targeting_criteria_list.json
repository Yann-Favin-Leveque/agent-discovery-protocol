{
  "name": "targeting_criteria_list",
  "description": "List targeting criteria for a line item.",
  "resource_group": "targeting",
  "endpoint": "/12/accounts/{account_id}/targeting_criteria",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true
    },
    {
      "name": "line_item_ids",
      "type": "string",
      "description": "Filter by line item IDs.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/targeting_criteria?line_item_ids=li_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "tc_1",
          "line_item_id": "li_1",
          "targeting_type": "LOCATION",
          "targeting_value": "US"
        }
      ]
    }
  }
}