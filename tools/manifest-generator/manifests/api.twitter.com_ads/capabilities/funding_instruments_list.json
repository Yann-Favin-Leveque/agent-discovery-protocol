{
  "name": "funding_instruments_list",
  "description": "List funding instruments for an ad account.",
  "resource_group": "funding",
  "endpoint": "/12/accounts/{account_id}/funding_instruments",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/funding_instruments",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "fi_1",
          "type": "CREDIT_CARD",
          "currency": "USD"
        }
      ]
    }
  }
}