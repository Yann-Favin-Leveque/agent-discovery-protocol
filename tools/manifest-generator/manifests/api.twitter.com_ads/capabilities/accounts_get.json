{
  "name": "accounts_get",
  "description": "Retrieve a specific ad account.",
  "resource_group": "accounts",
  "endpoint": "/12/accounts/{account_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/accounts/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "abc123",
        "name": "My Ad Account",
        "currency": "USD"
      }
    }
  }
}
