{
  "name": "analytics_query",
  "description": "Retrieve performance analytics.",
  "resource_group": "analytics",
  "endpoint": "/12/stats/accounts/{account_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "entity",
      "type": "string",
      "description": "Entity type: CAMPAIGN, LINE_ITEM, PROMOTED_TWEET.",
      "required": true,
      "in": "query"
    },
    {
      "name": "entity_ids",
      "type": "string",
      "description": "Comma-separated entity IDs.",
      "required": true,
      "in": "query"
    },
    {
      "name": "start_time",
      "type": "string",
      "description": "ISO 8601 start time.",
      "required": true,
      "in": "query"
    },
    {
      "name": "end_time",
      "type": "string",
      "description": "ISO 8601 end time.",
      "required": true,
      "in": "query"
    },
    {
      "name": "granularity",
      "type": "string",
      "description": "DAY, HOUR, TOTAL.",
      "required": false,
      "example": "DAY",
      "in": "query"
    },
    {
      "name": "metric_groups",
      "type": "string",
      "description": "Comma-separated: ENGAGEMENT, BILLING, etc.",
      "required": true,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://ads-api.twitter.com/12/stats/accounts/abc123?entity=CAMPAIGN&entity_ids=camp_1&start_time=2024-06-01T00:00:00Z&end_time=2024-06-30T23:59:59Z&granularity=DAY&metric_groups=ENGAGEMENT,BILLING",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "camp_1",
          "id_data": [
            {
              "metrics": {
                "impressions": 15000,
                "engagements": 450,
                "spend_micro": 25000000
              }
            }
          ]
        }
      ]
    }
  }
}
