{
  "name": "campaigns_delete",
  "description": "Delete a campaign.",
  "resource_group": "campaigns",
  "endpoint": "/12/accounts/{account_id}/campaigns/{campaign_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Ad account ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "campaign_id",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://ads-api.twitter.com/12/accounts/abc123/campaigns/camp_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "camp_1",
        "deleted": true
      }
    }
  }
}
