{
  "name": "solutions_articles_list",
  "description": "List all knowledge base articles in a specific folder.",
  "endpoint": "/api/v2/solutions/folders/{folder_id}/articles",
  "method": "GET",
  "resource_group": "solutions",
  "parameters": [
    {
      "name": "folder_id",
      "type": "integer",
      "description": "The solutions folder ID.",
      "required": true,
      "example": 10,
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/solutions/folders/10/articles",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 50,
        "title": "How to reset your password",
        "description_text": "Follow these steps to reset...",
        "status": 2,
        "folder_id": 10
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
