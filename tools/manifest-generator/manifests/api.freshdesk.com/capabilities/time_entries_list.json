{
  "name": "time_entries_list",
  "description": "List all time entries logged against a ticket.",
  "endpoint": "/api/v2/tickets/{ticket_id}/time_entries",
  "method": "GET",
  "resource_group": "time_entries",
  "parameters": [
    {
      "name": "ticket_id",
      "type": "integer",
      "description": "The ticket ID.",
      "required": true,
      "example": 1,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/tickets/1/time_entries",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 300,
        "agent_id": 67890,
        "billable": true,
        "time_spent": "01:30",
        "note": "Debugging login issue",
        "created_at": "2024-09-01T15:00:00Z"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
