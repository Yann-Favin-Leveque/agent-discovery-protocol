{
  "name": "companies_list",
  "description": "List all companies in your Freshdesk account.",
  "endpoint": "/api/v2/companies",
  "method": "GET",
  "resource_group": "companies",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/companies",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 100,
        "name": "Acme Corp",
        "domains": [
          "acme.com"
        ],
        "description": "Enterprise customer"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
