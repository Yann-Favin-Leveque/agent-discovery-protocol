{
  "name": "tickets_note_create",
  "description": "Add a private note to a ticket for internal agent collaboration.",
  "endpoint": "/api/v2/tickets/{id}/notes",
  "method": "POST",
  "resource_group": "tickets",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "The ticket ID.",
      "required": true,
      "example": 1,
      "in": "path"
    },
    {
      "name": "body",
      "type": "string",
      "description": "Note content in HTML.",
      "required": true,
      "example": "<p>Escalating to engineering team.</p>",
      "in": "body"
    },
    {
      "name": "private",
      "type": "boolean",
      "description": "Whether the note is private (true) or public (false).",
      "required": false,
      "example": true,
      "in": "body"
    },
    {
      "name": "notify_emails",
      "type": "array",
      "description": "Email addresses to notify.",
      "required": false,
      "example": [
        "engineer@example.com"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://yourdomain.freshdesk.com/api/v2/tickets/1/notes",
    "headers": {
      "Authorization": "Basic base64(api_key:X)",
      "Content-Type": "application/json"
    },
    "body": {
      "body": "<p>Escalating to engineering team.</p>",
      "private": true
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 102,
      "body_text": "Escalating to engineering team.",
      "private": true,
      "created_at": "2024-09-01T14:30:00Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
