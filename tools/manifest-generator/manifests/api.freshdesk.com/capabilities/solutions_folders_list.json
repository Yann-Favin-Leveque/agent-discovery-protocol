{
  "name": "solutions_folders_list",
  "description": "List all folders within a solution category.",
  "endpoint": "/api/v2/solutions/categories/{category_id}/folders",
  "method": "GET",
  "resource_group": "solutions",
  "parameters": [
    {"name": "category_id", "type": "integer", "description": "The category ID.", "required": true, "example": 5},
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 1}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/solutions/categories/5/folders",
    "headers": {"Authorization": "Basic base64(api_key:X)"},
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": 10, "name": "Account Management", "description": "Articles about managing your account", "articles_count": 15}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 80}
}
