{
  "name": "companies_get",
  "description": "Retrieve a specific company by ID with its details and associated contacts.",
  "endpoint": "/api/v2/companies/{id}",
  "method": "GET",
  "resource_group": "companies",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "The company ID.",
      "required": true,
      "example": 100,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/companies/100",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 100,
      "name": "Acme Corp",
      "domains": [
        "acme.com"
      ],
      "description": "Enterprise customer",
      "note": "VIP account"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
