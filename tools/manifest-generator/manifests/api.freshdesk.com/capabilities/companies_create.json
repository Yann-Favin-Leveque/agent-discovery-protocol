{
  "name": "companies_create",
  "description": "Create a new company with name, domain, and description.",
  "endpoint": "/api/v2/companies",
  "method": "POST",
  "resource_group": "companies",
  "parameters": [
    {"name": "name", "type": "string", "description": "Company name.", "required": true, "example": "TechStart Inc"},
    {"name": "domains", "type": "array", "description": "Email domains associated with the company.", "required": false, "example": ["techstart.com"]},
    {"name": "description", "type": "string", "description": "Company description.", "required": false, "example": "Startup client"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://yourdomain.freshdesk.com/api/v2/companies",
    "headers": {"Authorization": "Basic base64(api_key:X)", "Content-Type": "application/json"},
    "body": {"name": "TechStart Inc", "domains": ["techstart.com"]}
  },
  "response_example": {
    "status": 201,
    "body": {"id": 101, "name": "TechStart Inc", "domains": ["techstart.com"]}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 80}
}
