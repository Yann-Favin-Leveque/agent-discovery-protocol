{
  "name": "list_contacts",
  "description": "Retrieve all contacts (customer records) in your Freshdesk account. Returns names, emails, phone numbers, company associations, and other profile details. Supports filtering by email, phone, and company.",
  "endpoint": "/api/v2/contacts",
  "method": "GET",
  "parameters": [
    { "name": "email", "type": "string", "description": "Filter contacts by email address.", "required": false, "example": "customer@example.com" },
    { "name": "phone", "type": "string", "description": "Filter contacts by phone number.", "required": false, "example": "+1-555-123-4567" },
    { "name": "company_id", "type": "integer", "description": "Filter contacts by company ID.", "required": false, "example": 1000 },
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "integer", "description": "Number of results per page (max 30).", "required": false, "example": 30 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.freshdesk.com/api/v2/contacts?per_page=30",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 20001,
        "name": "Jane Customer",
        "email": "jane@example.com",
        "phone": "+1-555-123-4567",
        "company_id": 1000,
        "active": true,
        "created_at": "2024-06-01T08:00:00Z"
      }
    ]
  }
}
