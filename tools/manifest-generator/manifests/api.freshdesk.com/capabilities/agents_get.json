{
  "name": "agents_get",
  "description": "Retrieve a specific agent by ID with their details, roles, and group memberships.",
  "endpoint": "/api/v2/agents/{id}",
  "method": "GET",
  "resource_group": "agents",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "The agent ID.",
      "required": true,
      "example": 67890,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/agents/67890",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 67890,
      "contact": {
        "name": "Alice Agent",
        "email": "alice@company.com"
      },
      "available": true,
      "type": "fulltime",
      "group_ids": [
        1,
        2
      ],
      "role_ids": [
        1
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
