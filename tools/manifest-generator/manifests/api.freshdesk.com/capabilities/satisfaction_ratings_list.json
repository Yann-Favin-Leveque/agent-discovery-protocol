{
  "name": "satisfaction_ratings_list",
  "description": "List customer satisfaction survey ratings for a ticket.",
  "endpoint": "/api/v2/tickets/{ticket_id}/satisfaction_ratings",
  "method": "GET",
  "resource_group": "satisfaction_ratings",
  "parameters": [
    {
      "name": "ticket_id",
      "type": "integer",
      "description": "The ticket ID.",
      "required": true,
      "example": 1,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/tickets/1/satisfaction_ratings",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 400,
        "survey_id": 1,
        "agent_id": 67890,
        "ratings": {
          "default_question": 103
        },
        "created_at": "2024-09-02T10:00:00Z"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
