{
  "name": "create_contact",
  "description": "Create a new contact (customer record) in Freshdesk. Contacts are the people who submit support tickets. You can associate them with a company and add custom fields for segmentation.",
  "endpoint": "/api/v2/contacts",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "The contact's full name.", "required": true, "example": "John Doe" },
    { "name": "email", "type": "string", "description": "The contact's primary email address. Must be unique.", "required": true, "example": "john.doe@example.com" },
    { "name": "phone", "type": "string", "description": "The contact's phone number.", "required": false, "example": "+1-555-987-6543" },
    { "name": "company_id", "type": "integer", "description": "ID of the company this contact belongs to.", "required": false, "example": 1000 },
    { "name": "description", "type": "string", "description": "A brief description or notes about the contact.", "required": false, "example": "Premium plan customer since 2024" },
    { "name": "tags", "type": "array", "description": "Tags to categorize the contact.", "required": false, "example": ["premium", "enterprise"] }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.freshdesk.com/api/v2/contacts",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "John Doe",
      "email": "john.doe@example.com",
      "phone": "+1-555-987-6543",
      "company_id": 1000,
      "tags": ["premium"]
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 20002,
      "name": "John Doe",
      "email": "john.doe@example.com",
      "phone": "+1-555-987-6543",
      "company_id": 1000,
      "active": true,
      "tags": ["premium"],
      "created_at": "2025-01-15T16:30:00Z"
    }
  }
}
