{
  "name": "companies_update",
  "description": "Update a company's details such as name, domains, or description.",
  "endpoint": "/api/v2/companies/{id}",
  "method": "PUT",
  "resource_group": "companies",
  "parameters": [
    {"name": "id", "type": "integer", "description": "The company ID.", "required": true, "example": 100},
    {"name": "name", "type": "string", "description": "Updated name.", "required": false, "example": "Acme Corporation"},
    {"name": "note", "type": "string", "description": "Updated note.", "required": false, "example": "Premium account"}
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://yourdomain.freshdesk.com/api/v2/companies/100",
    "headers": {"Authorization": "Basic base64(api_key:X)", "Content-Type": "application/json"},
    "body": {"name": "Acme Corporation", "note": "Premium account"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": 100, "name": "Acme Corporation", "note": "Premium account"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 80}
}
