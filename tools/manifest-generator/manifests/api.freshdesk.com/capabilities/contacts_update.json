{
  "name": "contacts_update",
  "description": "Update a contact's details such as name, email, phone, or company.",
  "endpoint": "/api/v2/contacts/{id}",
  "method": "PUT",
  "resource_group": "contacts",
  "parameters": [
    {"name": "id", "type": "integer", "description": "The contact ID.", "required": true, "example": 12345},
    {"name": "name", "type": "string", "description": "Updated name.", "required": false, "example": "John D."},
    {"name": "email", "type": "string", "description": "Updated email.", "required": false, "example": "johnd@example.com"}
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://yourdomain.freshdesk.com/api/v2/contacts/12345",
    "headers": {"Authorization": "Basic base64(api_key:X)", "Content-Type": "application/json"},
    "body": {"name": "John D."}
  },
  "response_example": {
    "status": 200,
    "body": {"id": 12345, "name": "John D.", "email": "john@example.com"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 80}
}
