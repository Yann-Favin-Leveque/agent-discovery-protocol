{
  "name": "contacts_delete",
  "description": "Permanently delete a contact by ID.",
  "endpoint": "/api/v2/contacts/{id}",
  "method": "DELETE",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "The contact ID to delete.",
      "required": true,
      "example": 12345,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://yourdomain.freshdesk.com/api/v2/contacts/12345",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
