{
  "name": "contacts_create",
  "description": "Create a new contact with name, email, phone, and company association.",
  "endpoint": "/api/v2/contacts",
  "method": "POST",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Contact full name.",
      "required": true,
      "example": "Jane Smith",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Contact email.",
      "required": false,
      "example": "jane@example.com",
      "in": "body"
    },
    {
      "name": "phone",
      "type": "string",
      "description": "Contact phone.",
      "required": false,
      "example": "+1987654321",
      "in": "body"
    },
    {
      "name": "company_id",
      "type": "integer",
      "description": "Company to associate with.",
      "required": false,
      "example": 100,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://yourdomain.freshdesk.com/api/v2/contacts",
    "headers": {
      "Authorization": "Basic base64(api_key:X)",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Jane Smith",
      "email": "jane@example.com",
      "phone": "+1987654321"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 12346,
      "name": "Jane Smith",
      "email": "jane@example.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
