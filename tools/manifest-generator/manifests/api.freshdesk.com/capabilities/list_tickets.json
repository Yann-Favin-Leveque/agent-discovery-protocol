{
  "name": "list_tickets",
  "description": "Retrieve all support tickets in your Freshdesk account. Supports filtering by requester email, status, priority, agent, company, and creation date. Results are paginated with a maximum of 30 tickets per page.",
  "endpoint": "/api/v2/tickets",
  "method": "GET",
  "parameters": [
    { "name": "email", "type": "string", "description": "Filter tickets by requester email address.", "required": false, "example": "customer@example.com" },
    { "name": "requester_id", "type": "integer", "description": "Filter tickets by requester contact ID.", "required": false, "example": 20001 },
    { "name": "updated_since", "type": "string", "description": "Return tickets updated after this date (ISO 8601).", "required": false, "example": "2025-01-01T00:00:00Z" },
    { "name": "order_by", "type": "string", "description": "Sort field: 'created_at', 'due_by', 'updated_at', or 'status'.", "required": false, "example": "updated_at" },
    { "name": "order_type", "type": "string", "description": "Sort direction: 'asc' or 'desc'.", "required": false, "example": "desc" },
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "integer", "description": "Number of results per page (max 30).", "required": false, "example": 30 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.freshdesk.com/api/v2/tickets?order_by=updated_at&order_type=desc&per_page=30",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 10001,
        "subject": "Unable to process payment",
        "status": 2,
        "priority": 3,
        "requester_id": 20001,
        "responder_id": 5001,
        "source": 1,
        "created_at": "2025-01-15T10:30:00Z",
        "updated_at": "2025-01-15T14:22:00Z"
      }
    ]
  }
}
