{
  "name": "tickets_reply",
  "description": "Send a public reply to a customer on an existing ticket via the ticket's original channel.",
  "endpoint": "/api/v2/tickets/{id}/reply",
  "method": "POST",
  "resource_group": "tickets",
  "parameters": [
    {"name": "id", "type": "integer", "description": "The ticket ID.", "required": true, "example": 1},
    {"name": "body", "type": "string", "description": "Reply content in HTML.", "required": true, "example": "<p>We've resolved your issue. Please try again.</p>"},
    {"name": "cc_emails", "type": "array", "description": "CC email addresses.", "required": false, "example": ["manager@example.com"]}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://yourdomain.freshdesk.com/api/v2/tickets/1/reply",
    "headers": {"Authorization": "Basic base64(api_key:X)", "Content-Type": "application/json"},
    "body": {"body": "<p>We've resolved your issue. Please try again.</p>"}
  },
  "response_example": {
    "status": 201,
    "body": {"id": 101, "body_text": "We've resolved your issue. Please try again.", "incoming": false, "created_at": "2024-09-01T14:00:00Z"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 80}
}
