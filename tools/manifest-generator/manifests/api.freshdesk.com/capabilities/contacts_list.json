{
  "name": "contacts_list",
  "description": "List all contacts (customers) with their email, phone, company, and ticket history.",
  "endpoint": "/api/v2/contacts",
  "method": "GET",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Filter by email.",
      "required": false,
      "example": "john@example.com",
      "in": "query"
    },
    {
      "name": "phone",
      "type": "string",
      "description": "Filter by phone number.",
      "required": false,
      "example": "+1234567890",
      "in": "query"
    },
    {
      "name": "company_id",
      "type": "integer",
      "description": "Filter by company ID.",
      "required": false,
      "example": 100,
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/contacts?page=1",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 12345,
        "name": "John Doe",
        "email": "john@example.com",
        "phone": "+1234567890",
        "company_id": 100,
        "active": true
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
