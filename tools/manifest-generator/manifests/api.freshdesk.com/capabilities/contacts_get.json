{
  "name": "contacts_get",
  "description": "Retrieve a specific contact by ID with all their details.",
  "endpoint": "/api/v2/contacts/{id}",
  "method": "GET",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "The contact ID.",
      "required": true,
      "example": 12345,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://yourdomain.freshdesk.com/api/v2/contacts/12345",
    "headers": {
      "Authorization": "Basic base64(api_key:X)"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345,
      "name": "John Doe",
      "email": "john@example.com",
      "phone": "+1234567890",
      "company_id": 100,
      "active": true,
      "address": "123 Main St"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 80
  }
}
