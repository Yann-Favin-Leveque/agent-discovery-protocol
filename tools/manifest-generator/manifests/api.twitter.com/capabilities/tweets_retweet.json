{
  "name": "tweets_retweet",
  "description": "Retweet a tweet.",
  "resource_group": "retweets",
  "endpoint": "/2/users/{id}/retweets",
  "method": "POST",
  "auth_scopes": [
    "tweet.write"
  ],
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Authenticated user ID.",
      "in": "path"
    },
    {
      "name": "tweet_id",
      "type": "string",
      "required": true,
      "description": "Tweet ID to retweet.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.twitter.com/2/users/123456/retweets",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "tweet_id": "1234567890123456789"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "retweeted": true
      }
    }
  }
}
