{
  "name": "users_me",
  "description": "Retrieve the authenticated user profile.",
  "resource_group": "users",
  "endpoint": "/2/users/me",
  "method": "GET",
  "auth_scopes": [
    "users.read"
  ],
  "parameters": [
    {
      "name": "user.fields",
      "type": "string",
      "required": false,
      "description": "User fields to return."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.twitter.com/2/users/me?user.fields=description,public_metrics",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "123456",
        "name": "My Name",
        "username": "myhandle"
      }
    }
  }
}