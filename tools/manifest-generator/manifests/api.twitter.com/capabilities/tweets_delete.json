{
  "name": "tweets_delete",
  "description": "Delete a tweet by the authenticated user.",
  "resource_group": "tweets",
  "endpoint": "/2/tweets/{id}",
  "method": "DELETE",
  "auth_scopes": [
    "tweet.write"
  ],
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Tweet ID to delete."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.twitter.com/2/tweets/1234567890123456789",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "deleted": true
      }
    }
  }
}