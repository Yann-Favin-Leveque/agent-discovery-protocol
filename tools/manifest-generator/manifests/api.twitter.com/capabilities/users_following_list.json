{
  "name": "users_following_list",
  "description": "List users that a user is following.",
  "resource_group": "users",
  "endpoint": "/2/users/{id}/following",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "User ID."
    },
    {
      "name": "max_results",
      "type": "integer",
      "required": false,
      "description": "Results per page (1-1000)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.twitter.com/2/users/123456/following?max_results=100",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "789",
          "name": "Following",
          "username": "following1"
        }
      ]
    }
  }
}