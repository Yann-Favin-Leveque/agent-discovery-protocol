{
  "name": "tweets_unlike",
  "description": "Unlike a tweet.",
  "resource_group": "likes",
  "endpoint": "/2/users/{id}/likes/{tweet_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Authenticated user ID.",
      "in": "path"
    },
    {
      "name": "tweet_id",
      "type": "string",
      "required": true,
      "description": "Tweet ID to unlike.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.twitter.com/2/users/123456/likes/1234567890123456789",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "liked": false
      }
    }
  }
}
