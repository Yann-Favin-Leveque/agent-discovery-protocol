{
  "name": "users_get_by_id",
  "description": "Look up a user by user ID.",
  "resource_group": "users",
  "endpoint": "/2/users/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "User ID."
    },
    {
      "name": "user.fields",
      "type": "string",
      "required": false,
      "description": "User fields to return."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.twitter.com/2/users/44196397?user.fields=description,public_metrics",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "44196397",
        "name": "Elon Musk",
        "username": "elonmusk"
      }
    }
  }
}