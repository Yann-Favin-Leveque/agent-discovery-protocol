{
  "name": "auth_signin_password",
  "resource_group": "auth",
  "description": "Sign in with email and password. Returns ID token, refresh token, and user info.",
  "endpoint": "/v1/accounts:signInWithPassword",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "User email."
    },
    {
      "name": "password",
      "type": "string",
      "required": true,
      "description": "User password."
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "required": false,
      "description": "Return tokens. Default true."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "alice@example.com",
      "password": "securePass123!",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "idToken": "eyJhbGciOi...",
      "email": "alice@example.com",
      "refreshToken": "AMf-vBx...",
      "expiresIn": "3600",
      "localId": "uid123",
      "registered": true
    }
  }
}