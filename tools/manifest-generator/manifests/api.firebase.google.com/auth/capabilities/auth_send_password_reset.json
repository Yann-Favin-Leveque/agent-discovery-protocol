{
  "name": "auth_send_password_reset",
  "resource_group": "password_reset",
  "description": "Send a password reset email to the user.",
  "endpoint": "/v1/accounts:sendOobCode",
  "method": "POST",
  "parameters": [
    {
      "name": "requestType",
      "type": "string",
      "required": true,
      "description": "Must be 'PASSWORD_RESET'."
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email to send reset link to."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:sendOobCode?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "requestType": "PASSWORD_RESET",
      "email": "alice@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "email": "alice@example.com"
    }
  }
}