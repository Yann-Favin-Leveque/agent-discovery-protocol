{
  "name": "auth_signin_custom_token",
  "resource_group": "auth",
  "description": "Exchange a custom Auth token (created server-side) for ID and refresh tokens.",
  "endpoint": "/v1/accounts:signInWithCustomToken",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "description": "A Firebase custom token."
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "required": false,
      "description": "Return tokens. Default true."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithCustomToken?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "token": "CUSTOM_TOKEN",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "idToken": "eyJhbGciOi...",
      "refreshToken": "AMf-vBx...",
      "expiresIn": "3600"
    }
  }
}