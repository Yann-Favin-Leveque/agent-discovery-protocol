{
  "name": "auth_signin_anonymous",
  "resource_group": "auth",
  "description": "Sign in anonymously. Creates a temporary anonymous account.",
  "endpoint": "/v1/accounts:signUp",
  "method": "POST",
  "parameters": [
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "required": true,
      "description": "Must be true."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "idToken": "eyJhbGciOi...",
      "refreshToken": "AMf-vBx...",
      "expiresIn": "3600",
      "localId": "anonUid123"
    }
  }
}