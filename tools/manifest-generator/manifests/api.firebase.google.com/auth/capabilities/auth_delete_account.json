{
  "name": "auth_delete_account",
  "resource_group": "users",
  "description": "Delete the current user account.",
  "endpoint": "/v1/accounts:delete",
  "method": "POST",
  "parameters": [
    {
      "name": "idToken",
      "type": "string",
      "required": true,
      "description": "Firebase ID token of the user to delete."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:delete?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "idToken": "eyJhbGciOi..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}