{
  "name": "auth_confirm_password_reset",
  "resource_group": "password_reset",
  "description": "Apply a new password using the reset code.",
  "endpoint": "/v1/accounts:resetPassword",
  "method": "POST",
  "parameters": [
    {
      "name": "oobCode",
      "type": "string",
      "required": true,
      "description": "The password reset code."
    },
    {
      "name": "newPassword",
      "type": "string",
      "required": true,
      "description": "The new password to set."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:resetPassword?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "oobCode": "CODE_FROM_EMAIL",
      "newPassword": "newSecurePass!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "email": "alice@example.com",
      "requestType": "PASSWORD_RESET"
    }
  }
}