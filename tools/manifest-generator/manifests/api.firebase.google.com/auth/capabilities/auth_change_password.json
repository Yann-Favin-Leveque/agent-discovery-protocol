{
  "name": "auth_change_password",
  "resource_group": "users",
  "description": "Change the user's password.",
  "endpoint": "/v1/accounts:update",
  "method": "POST",
  "parameters": [
    {
      "name": "idToken",
      "type": "string",
      "required": true,
      "description": "Firebase ID token."
    },
    {
      "name": "password",
      "type": "string",
      "required": true,
      "description": "New password."
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "required": false,
      "description": "Return new tokens."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:update?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "idToken": "eyJhbGciOi...",
      "password": "newSecurePass!",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "localId": "uid123",
      "email": "alice@example.com",
      "idToken": "eyJhbGciOi..."
    }
  }
}