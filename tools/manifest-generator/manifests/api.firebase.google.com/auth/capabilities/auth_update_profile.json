{
  "name": "auth_update_profile",
  "resource_group": "users",
  "description": "Update user display name and/or photo URL.",
  "endpoint": "/v1/accounts:update",
  "method": "POST",
  "parameters": [
    {
      "name": "idToken",
      "type": "string",
      "required": true,
      "description": "Firebase ID token."
    },
    {
      "name": "displayName",
      "type": "string",
      "required": false,
      "description": "New display name."
    },
    {
      "name": "photoUrl",
      "type": "string",
      "required": false,
      "description": "New photo URL."
    },
    {
      "name": "deleteAttribute",
      "type": "array",
      "required": false,
      "description": "Attributes to delete: DISPLAY_NAME, PHOTO_URL."
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "required": false,
      "description": "Return new tokens."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:update?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "idToken": "eyJhbGciOi...",
      "displayName": "Alice Johnson",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "localId": "uid123",
      "displayName": "Alice Johnson",
      "email": "alice@example.com",
      "idToken": "eyJhbGciOi..."
    }
  }
}