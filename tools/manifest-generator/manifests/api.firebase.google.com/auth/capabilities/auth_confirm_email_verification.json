{
  "name": "auth_confirm_email_verification",
  "resource_group": "email_verification",
  "description": "Confirm an email verification code and mark the email as verified.",
  "endpoint": "/v1/accounts:update",
  "method": "POST",
  "parameters": [
    {
      "name": "oobCode",
      "type": "string",
      "required": true,
      "description": "The verification code from the email."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:update?key=AIzaSyXXXXXX",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "oobCode": "VERIFICATION_CODE"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "localId": "uid123",
      "email": "alice@example.com",
      "emailVerified": true
    }
  }
}