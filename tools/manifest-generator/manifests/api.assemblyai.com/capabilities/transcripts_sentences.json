{
  "name": "transcripts_sentences",
  "description": "Get the transcript split into sentences with timestamps.",
  "endpoint": "/v2/transcript/{transcript_id}/sentences",
  "method": "GET",
  "resource_group": "transcripts",
  "parameters": [
    {
      "name": "transcript_id",
      "type": "string",
      "description": "Transcript ID.",
      "required": true,
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.assemblyai.com/v2/transcript/abc123/sentences",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "confidence": 0.95,
      "sentences": [
        {
          "text": "Hello, welcome to AssemblyAI.",
          "start": 0,
          "end": 3000,
          "confidence": 0.95,
          "words": []
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}