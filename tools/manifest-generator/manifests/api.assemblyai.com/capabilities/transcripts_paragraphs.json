{
  "name": "transcripts_paragraphs",
  "description": "Get the transcript split into paragraphs with timestamps.",
  "endpoint": "/v2/transcript/{transcript_id}/paragraphs",
  "method": "GET",
  "resource_group": "transcripts",
  "parameters": [
    {
      "name": "transcript_id",
      "type": "string",
      "description": "Transcript ID.",
      "required": true,
      "example": "abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.assemblyai.com/v2/transcript/abc123/paragraphs",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "confidence": 0.95,
      "paragraphs": [
        {
          "text": "Hello, welcome to AssemblyAI. We are going to demonstrate the transcription features.",
          "start": 0,
          "end": 8000,
          "confidence": 0.95
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
