{
  "name": "transcripts_subtitles_vtt",
  "description": "Get the transcript as VTT subtitles.",
  "endpoint": "/v2/transcript/{transcript_id}/vtt",
  "method": "GET",
  "resource_group": "transcripts",
  "parameters": [
    {
      "name": "transcript_id",
      "type": "string",
      "description": "Transcript ID.",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "chars_per_caption",
      "type": "integer",
      "description": "Max characters per caption.",
      "required": false,
      "example": 32
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.assemblyai.com/v2/transcript/abc123/vtt?chars_per_caption=32",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "WEBVTT\n\n00:00:00.000 --> 00:00:03.000\nHello, welcome to AssemblyAI.\n"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}