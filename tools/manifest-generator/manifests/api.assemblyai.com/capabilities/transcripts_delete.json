{
  "name": "transcripts_delete",
  "description": "Delete a transcript and any uploaded audio files associated with it.",
  "endpoint": "/v2/transcript/{transcript_id}",
  "method": "DELETE",
  "resource_group": "transcripts",
  "parameters": [
    {
      "name": "transcript_id",
      "type": "string",
      "description": "Transcript ID to delete.",
      "required": true,
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.assemblyai.com/v2/transcript/abc123",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "status": "completed",
      "text": "Hello, welcome to AssemblyAI.",
      "audio_url": "https://cdn.assemblyai.com/upload/abc123-def456"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}