{
  "name": "lemur_purge",
  "description": "Purge LeMUR request data for a specific request ID.",
  "endpoint": "/v2/lemur/v3/{request_id}",
  "method": "DELETE",
  "resource_group": "lemur",
  "parameters": [
    {
      "name": "request_id",
      "type": "string",
      "description": "LeMUR request ID to purge.",
      "required": true,
      "example": "req_abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.assemblyai.com/v2/lemur/v3/req_abc123",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req_abc123",
      "request_id_to_purge": "req_abc123",
      "deleted": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}