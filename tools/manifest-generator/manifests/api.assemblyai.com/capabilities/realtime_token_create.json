{
  "name": "realtime_token_create",
  "description": "Generate a temporary authentication token for real-time streaming transcription.",
  "endpoint": "/v2/realtime/token",
  "method": "POST",
  "resource_group": "realtime",
  "parameters": [
    {
      "name": "expires_in",
      "type": "integer",
      "description": "Token expiration time in seconds.",
      "required": true,
      "example": 3600
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.assemblyai.com/v2/realtime/token",
    "headers": {
      "Authorization": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "expires_in": 3600
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "token": "abc123def456"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}