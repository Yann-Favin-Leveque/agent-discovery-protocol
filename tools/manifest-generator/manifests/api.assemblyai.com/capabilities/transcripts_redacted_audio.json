{
  "name": "transcripts_redacted_audio",
  "description": "Get a redacted version of the audio with PII bleeped out.",
  "endpoint": "/v2/transcript/{transcript_id}/redacted-audio",
  "method": "GET",
  "resource_group": "transcripts",
  "parameters": [
    {
      "name": "transcript_id",
      "type": "string",
      "description": "Transcript ID (must have redact_pii enabled).",
      "required": true,
      "example": "abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.assemblyai.com/v2/transcript/abc123/redacted-audio",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "redacted_audio_ready",
      "redacted_audio_url": "https://cdn.assemblyai.com/redacted/abc123.mp3"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
