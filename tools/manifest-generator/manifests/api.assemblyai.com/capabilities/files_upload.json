{
  "name": "files_upload",
  "description": "Upload a local audio/video file for transcription. Returns a temporary URL accessible only by AssemblyAI.",
  "endpoint": "/v2/upload",
  "method": "POST",
  "resource_group": "files",
  "parameters": [
    {
      "name": "body",
      "type": "binary",
      "description": "Raw binary audio/video file data.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.assemblyai.com/v2/upload",
    "headers": {
      "Authorization": "{api_key}",
      "Content-Type": "application/octet-stream"
    },
    "body": "<binary audio data>"
  },
  "response_example": {
    "status": 200,
    "body": {
      "upload_url": "https://cdn.assemblyai.com/upload/abc123-def456"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
