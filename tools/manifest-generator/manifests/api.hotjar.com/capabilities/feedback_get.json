{
  "name": "feedback_get",
  "description": "Retrieve details of a specific feedback response including rating, comment, and screenshot.",
  "endpoint": "/v2/sites/{site_id}/feedback/{feedback_id}",
  "method": "GET",
  "resource_group": "feedback",
  "parameters": [
    {
      "name": "site_id",
      "type": "number",
      "description": "The site ID.",
      "required": true,
      "example": 123456
    },
    {
      "name": "feedback_id",
      "type": "string",
      "description": "The feedback response ID.",
      "required": true,
      "example": "fb_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/feedback/fb_123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "fb_123",
      "rating": 4,
      "message": "Great product, but the checkout flow is confusing.",
      "page_url": "https://example.com/checkout",
      "screenshot_url": "https://hotjar-assets.com/feedback/fb_123.png",
      "country": "US",
      "device": "desktop",
      "browser": "Chrome",
      "created_at": "2024-01-20T10:00:00Z"
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
