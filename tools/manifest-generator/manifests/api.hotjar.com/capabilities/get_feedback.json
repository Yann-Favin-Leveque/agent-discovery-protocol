{
  "name": "get_feedback",
  "description": "Retrieve incoming feedback widget responses with emoji ratings, comments, and page URLs.",
  "endpoint": "/sites/{site_id}/feedback",
  "method": "GET",
  "parameters": [
    {"name": "site_id", "type": "number", "description": "Site ID.", "required": true, "example": 123456},
    {"name": "offset", "type": "number", "description": "Pagination offset.", "required": false, "example": 0},
    {"name": "limit", "type": "number", "description": "Max results.", "required": false, "example": 25}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/feedback?limit=25",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": [{"id": "fb_123", "rating": 4, "message": "Great product, but the checkout flow is confusing.", "page_url": "https://example.com/checkout", "country": "US", "device": "desktop", "created_at": "2024-01-20T10:00:00Z"}], "total": 150}
  }
}
