{
  "name": "list_recordings",
  "description": "List session recordings with filtering by date range, pages visited, and user attributes.",
  "endpoint": "/sites/{site_id}/recordings",
  "method": "GET",
  "parameters": [
    {"name": "site_id", "type": "number", "description": "Site ID.", "required": true, "example": 123456},
    {"name": "offset", "type": "number", "description": "Pagination offset.", "required": false, "example": 0},
    {"name": "limit", "type": "number", "description": "Max results.", "required": false, "example": 25},
    {"name": "sort", "type": "string", "description": "Sort field: created, duration, pages.", "required": false, "example": "created"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/recordings?limit=25&sort=created",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": [{"id": "rec_abc", "visitor_id": "vis_123", "duration_ms": 95000, "pages_count": 4, "country": "US", "device": "desktop", "browser": "Chrome", "created_at": "2024-01-20T10:00:00Z", "playback_url": "https://app.hotjar.com/recordings/rec_abc"}], "total": 500}
  }
}
