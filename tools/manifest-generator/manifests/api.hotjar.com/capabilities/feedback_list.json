{
  "name": "feedback_list",
  "description": "Retrieve incoming feedback widget responses with emoji ratings, comments, and page URLs.",
  "endpoint": "/v2/sites/{site_id}/feedback",
  "method": "GET",
  "resource_group": "feedback",
  "parameters": [
    {
      "name": "site_id",
      "type": "number",
      "description": "The site ID.",
      "required": true,
      "example": 123456,
      "in": "path"
    },
    {
      "name": "offset",
      "type": "number",
      "description": "Pagination offset.",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "number",
      "description": "Maximum results to return.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/feedback?limit=25",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "fb_123",
          "rating": 4,
          "message": "Great product, but the checkout flow is confusing.",
          "page_url": "https://example.com/checkout",
          "country": "US",
          "device": "desktop",
          "created_at": "2024-01-20T10:00:00Z"
        }
      ],
      "total": 150
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
