{
  "name": "recordings_get",
  "description": "Retrieve details of a specific session recording including pages, events, and playback URL.",
  "endpoint": "/v2/sites/{site_id}/recordings/{recording_id}",
  "method": "GET",
  "resource_group": "recordings",
  "parameters": [
    {
      "name": "site_id",
      "type": "number",
      "description": "The site ID.",
      "required": true,
      "example": 123456,
      "in": "path"
    },
    {
      "name": "recording_id",
      "type": "string",
      "description": "The recording ID.",
      "required": true,
      "example": "rec_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/recordings/rec_abc",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rec_abc",
      "visitor_id": "vis_123",
      "duration_ms": 95000,
      "pages": [
        {
          "url": "https://example.com",
          "time_on_page_ms": 30000
        },
        {
          "url": "https://example.com/pricing",
          "time_on_page_ms": 45000
        }
      ],
      "country": "US",
      "device": "desktop",
      "browser": "Chrome",
      "created_at": "2024-01-20T10:00:00Z",
      "playback_url": "https://app.hotjar.com/recordings/rec_abc"
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
