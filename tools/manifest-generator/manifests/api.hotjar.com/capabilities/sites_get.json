{
  "name": "sites_get",
  "description": "Retrieve details for a specific site (property) including tracking status and configuration.",
  "endpoint": "/v2/sites/{site_id}",
  "method": "GET",
  "resource_group": "sites",
  "parameters": [
    {
      "name": "site_id",
      "type": "number",
      "description": "The site ID.",
      "required": true,
      "example": 123456,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 123456,
      "name": "My Website",
      "url": "https://example.com",
      "tracking_code_installed": true,
      "created_at": "2024-01-01T00:00:00Z",
      "plan": "business"
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
