{
  "name": "heatmaps_list",
  "description": "List heatmaps for a site showing click, move, and scroll behavior patterns.",
  "endpoint": "/v2/sites/{site_id}/heatmaps",
  "method": "GET",
  "resource_group": "heatmaps",
  "parameters": [
    {
      "name": "site_id",
      "type": "number",
      "description": "The site ID.",
      "required": true,
      "example": 123456
    },
    {
      "name": "url",
      "type": "string",
      "description": "Filter by page URL.",
      "required": false,
      "example": "https://example.com/pricing"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Heatmap type: click, move, or scroll.",
      "required": false,
      "example": "click"
    },
    {
      "name": "offset",
      "type": "number",
      "description": "Pagination offset.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "number",
      "description": "Maximum results to return.",
      "required": false,
      "example": 25
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/heatmaps?type=click&limit=25",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 789,
          "name": "Pricing Page Clicks",
          "url_pattern": "https://example.com/pricing",
          "type": "click",
          "sample_size": 5000,
          "status": "active",
          "created_at": "2024-01-15T00:00:00Z"
        }
      ],
      "total": 12
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
