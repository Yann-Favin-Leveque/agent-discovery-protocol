{
  "name": "surveys_get_responses",
  "description": "Retrieve responses for a specific survey with answers, timestamps, and respondent info.",
  "endpoint": "/v2/sites/{site_id}/surveys/{survey_id}/responses",
  "method": "GET",
  "resource_group": "surveys",
  "parameters": [
    {
      "name": "site_id",
      "type": "number",
      "description": "The site ID.",
      "required": true,
      "example": 123456,
      "in": "path"
    },
    {
      "name": "survey_id",
      "type": "number",
      "description": "The survey ID.",
      "required": true,
      "example": 456,
      "in": "path"
    },
    {
      "name": "offset",
      "type": "number",
      "description": "Pagination offset.",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "number",
      "description": "Maximum results to return.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/surveys/456/responses?limit=25",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "resp_001",
          "answers": [
            {
              "question_id": 1,
              "answer": 9
            }
          ],
          "country": "US",
          "device": "desktop",
          "page_url": "https://example.com/dashboard",
          "created_at": "2024-01-20T10:00:00Z"
        }
      ],
      "total": 250
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
