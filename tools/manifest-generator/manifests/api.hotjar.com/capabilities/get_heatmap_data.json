{
  "name": "get_heatmap_data",
  "description": "Retrieve heatmap data for a specific page showing user click, move, and scroll behavior patterns.",
  "endpoint": "/sites/{site_id}/heatmaps",
  "method": "GET",
  "parameters": [
    {"name": "site_id", "type": "number", "description": "Site ID.", "required": true, "example": 123456},
    {"name": "url", "type": "string", "description": "Page URL to get heatmap for.", "required": false, "example": "https://example.com/pricing"},
    {"name": "type", "type": "string", "description": "Heatmap type: click, move, or scroll.", "required": false, "example": "click"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hotjar.com/v2/sites/123456/heatmaps?url=https://example.com/pricing&type=click",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": [{"id": 789, "name": "Pricing Page Clicks", "url_pattern": "https://example.com/pricing", "type": "click", "sample_size": 5000, "created_at": "2024-01-15T00:00:00Z", "status": "active"}]}
  }
}
