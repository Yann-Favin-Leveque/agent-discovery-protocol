{
  "spec_version": "1.0",
  "name": "HubSpot",
  "description": "HubSpot is an all-in-one CRM platform for marketing, sales, and customer service. Manage contacts, companies, deals, tickets, engagements, and pipelines through a comprehensive REST API.",
  "base_url": "https://api.hubapi.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://app.hubspot.com/private-apps/"
  },
  "capabilities": [
    {
      "name": "contacts_list",
      "resource_group": "contacts",
      "description": "List all contacts with pagination.",
      "detail_url": "/capabilities/contacts_list"
    },
    {
      "name": "contacts_get",
      "resource_group": "contacts",
      "description": "Get a contact by ID or email.",
      "detail_url": "/capabilities/contacts_get"
    },
    {
      "name": "contacts_create",
      "resource_group": "contacts",
      "description": "Create a new contact.",
      "detail_url": "/capabilities/contacts_create"
    },
    {
      "name": "contacts_update",
      "resource_group": "contacts",
      "description": "Update a contact.",
      "detail_url": "/capabilities/contacts_update"
    },
    {
      "name": "contacts_delete",
      "resource_group": "contacts",
      "description": "Delete a contact (moves to recycling bin).",
      "detail_url": "/capabilities/contacts_delete"
    },
    {
      "name": "contacts_search",
      "resource_group": "contacts",
      "description": "Search contacts using filters and query.",
      "detail_url": "/capabilities/contacts_search"
    },
    {
      "name": "contacts_batch_create",
      "resource_group": "contacts",
      "description": "Create multiple contacts.",
      "detail_url": "/capabilities/contacts_batch_create"
    },
    {
      "name": "companies_list",
      "resource_group": "companies",
      "description": "List all companies.",
      "detail_url": "/capabilities/companies_list"
    },
    {
      "name": "companies_create",
      "resource_group": "companies",
      "description": "Create a company.",
      "detail_url": "/capabilities/companies_create"
    },
    {
      "name": "companies_get",
      "resource_group": "companies",
      "description": "Get a company by ID.",
      "detail_url": "/capabilities/companies_get"
    },
    {
      "name": "companies_update",
      "resource_group": "companies",
      "description": "Update a company.",
      "detail_url": "/capabilities/companies_update"
    },
    {
      "name": "companies_delete",
      "resource_group": "companies",
      "description": "Delete a company.",
      "detail_url": "/capabilities/companies_delete"
    },
    {
      "name": "deals_list",
      "resource_group": "deals",
      "description": "List all deals.",
      "detail_url": "/capabilities/deals_list"
    },
    {
      "name": "deals_create",
      "resource_group": "deals",
      "description": "Create a deal.",
      "detail_url": "/capabilities/deals_create"
    },
    {
      "name": "deals_update",
      "resource_group": "deals",
      "description": "Update a deal.",
      "detail_url": "/capabilities/deals_update"
    },
    {
      "name": "deals_delete",
      "resource_group": "deals",
      "description": "Delete a deal.",
      "detail_url": "/capabilities/deals_delete"
    },
    {
      "name": "deals_search",
      "resource_group": "deals",
      "description": "Search deals with filters.",
      "detail_url": "/capabilities/deals_search"
    },
    {
      "name": "tickets_list",
      "resource_group": "tickets",
