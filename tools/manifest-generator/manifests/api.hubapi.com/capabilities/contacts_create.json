{
  "name": "contacts_create",
  "description": "Create a new contact.",
  "resource_group": "contacts",
  "endpoint": "/crm/v3/objects/contacts",
  "method": "POST",
  "parameters": [
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Contact properties: email, firstname, lastname, phone, company, etc.",
      "in": "body"
    },
    {
      "name": "associations",
      "type": "array",
      "required": false,
      "description": "Associations to create.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/contacts",
    "body": {
      "properties": {
        "email": "new@example.com",
        "firstname": "John",
        "lastname": "Smith",
        "phone": "+15559876543"
      }
    }
  },
  "response_example": {
    "id": "201",
    "properties": {
      "email": "new@example.com",
      "firstname": "John",
      "lastname": "Smith"
    },
    "createdAt": "2026-01-20T14:00:00Z"
  }
}
