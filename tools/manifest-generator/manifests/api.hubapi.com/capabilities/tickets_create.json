{
  "name": "tickets_create",
  "description": "Create a ticket.",
  "resource_group": "tickets",
  "endpoint": "/crm/v3/objects/tickets",
  "method": "POST",
  "parameters": [
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Ticket properties: subject, content, hs_pipeline, hs_pipeline_stage, hs_ticket_priority.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/tickets",
    "body": {
      "properties": {
        "subject": "Bug report",
        "content": "App crashes on login",
        "hs_pipeline": "0",
        "hs_pipeline_stage": "1",
        "hs_ticket_priority": "HIGH"
      }
    }
  },
  "response_example": {
    "id": "1001",
    "properties": {
      "subject": "Bug report",
      "hs_pipeline_stage": "1"
    }
  }
}
