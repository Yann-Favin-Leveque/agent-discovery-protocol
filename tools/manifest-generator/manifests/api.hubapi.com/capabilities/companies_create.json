{
  "name": "companies_create",
  "description": "Create a company.",
  "resource_group": "companies",
  "endpoint": "/crm/v3/objects/companies",
  "method": "POST",
  "parameters": [
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Company properties: name, domain, industry, phone, etc.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/companies",
    "body": {
      "properties": {
        "name": "New Corp",
        "domain": "newcorp.com",
        "industry": "Software"
      }
    }
  },
  "response_example": {
    "id": "601",
    "properties": {
      "name": "New Corp",
      "domain": "newcorp.com"
    }
  }
}
