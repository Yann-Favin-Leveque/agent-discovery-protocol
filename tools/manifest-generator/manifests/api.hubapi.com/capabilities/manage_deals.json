{
  "name": "manage_deals",
  "description": "Create, update, or list deals in the HubSpot sales pipeline with stage and amount tracking.",
  "endpoint": "/crm/v3/objects/deals",
  "method": "POST",
  "parameters": [
    {"name": "properties", "type": "object", "description": "Deal properties including name, amount, stage, and pipeline.", "required": true, "example": {"dealname": "Enterprise License", "amount": "50000", "dealstage": "qualifiedtobuy", "pipeline": "default"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/deals",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"properties": {"dealname": "Enterprise License", "amount": "50000", "dealstage": "qualifiedtobuy", "pipeline": "default"}}
  },
  "response_example": {
    "status": 201,
    "body": {"id": "789", "properties": {"dealname": "Enterprise License", "amount": "50000", "dealstage": "qualifiedtobuy"}, "createdAt": "2024-01-20T10:00:00Z"}
  }
}
