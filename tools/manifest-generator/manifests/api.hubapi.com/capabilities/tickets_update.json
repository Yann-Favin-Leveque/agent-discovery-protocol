{
  "name": "tickets_update",
  "description": "Update a ticket.",
  "resource_group": "tickets",
  "endpoint": "/crm/v3/objects/tickets/{ticketId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "ticketId",
      "type": "string",
      "required": true,
      "description": "Ticket ID."
    },
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Properties to update."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.hubapi.com/crm/v3/objects/tickets/901",
    "body": {
      "properties": {
        "hs_pipeline_stage": "4"
      }
    }
  },
  "response_example": {
    "id": "901",
    "properties": {
      "hs_pipeline_stage": "4"
    }
  }
}