{
  "name": "owners_list",
  "description": "List all owners (users) in the account.",
  "resource_group": "owners",
  "endpoint": "/crm/v3/owners/",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Pagination cursor.",
      "in": "query"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by email.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubapi.com/crm/v3/owners/"
  },
  "response_example": {
    "results": [
      {
        "id": "owner-abc",
        "email": "john@company.com",
        "firstName": "John",
        "lastName": "Doe"
      }
    ]
  }
}
