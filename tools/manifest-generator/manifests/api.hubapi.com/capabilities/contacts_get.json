{
  "name": "contacts_get",
  "description": "Get a contact by ID or email.",
  "resource_group": "contacts",
  "endpoint": "/crm/v3/objects/contacts/{contactId}",
  "method": "GET",
  "parameters": [
    {
      "name": "contactId",
      "type": "string",
      "required": true,
      "description": "Contact ID or email (with idProperty=email).",
      "in": "path"
    },
    {
      "name": "idProperty",
      "type": "string",
      "required": false,
      "description": "ID property: id or email.",
      "in": "query"
    },
    {
      "name": "properties",
      "type": "string",
      "required": false,
      "description": "Properties to return.",
      "in": "query"
    },
    {
      "name": "associations",
      "type": "string",
      "required": false,
      "description": "Associations to include.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubapi.com/crm/v3/objects/contacts/101?properties=email,firstname,lastname,phone"
  },
  "response_example": {
    "id": "101",
    "properties": {
      "email": "jane@example.com",
      "firstname": "Jane",
      "lastname": "Doe",
      "phone": "+15551234567"
    }
  }
}
