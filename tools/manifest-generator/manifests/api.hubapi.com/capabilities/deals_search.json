{
  "name": "deals_search",
  "description": "Search deals with filters.",
  "resource_group": "deals",
  "endpoint": "/crm/v3/objects/deals/search",
  "method": "POST",
  "parameters": [
    {
      "name": "filterGroups",
      "type": "array",
      "required": false,
      "description": "Filters.",
      "in": "body"
    },
    {
      "name": "query",
      "type": "string",
      "required": false,
      "description": "Text search.",
      "in": "body"
    },
    {
      "name": "properties",
      "type": "array",
      "required": false,
      "description": "Properties to return.",
      "in": "body"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/deals/search",
    "body": {
      "filterGroups": [
        {
          "filters": [
            {
              "propertyName": "dealstage",
              "operator": "EQ",
              "value": "closedwon"
            }
          ]
        }
      ],
      "properties": [
        "dealname",
        "amount"
      ],
      "limit": 10
    }
  },
  "response_example": {
    "total": 3,
    "results": [
      {
        "id": "701",
        "properties": {
          "dealname": "Enterprise Deal",
          "amount": "50000"
        }
      }
    ]
  }
}
