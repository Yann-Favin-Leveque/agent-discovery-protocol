{
  "name": "tickets_list",
  "description": "List support tickets.",
  "resource_group": "tickets",
  "endpoint": "/crm/v3/objects/tickets",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Pagination cursor.",
      "in": "query"
    },
    {
      "name": "properties",
      "type": "string",
      "required": false,
      "description": "Properties to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubapi.com/crm/v3/objects/tickets?limit=10&properties=subject,content,hs_pipeline_stage"
  },
  "response_example": {
    "results": [
      {
        "id": "901",
        "properties": {
          "subject": "Login issue",
          "hs_pipeline_stage": "1"
        }
      }
    ]
  }
}
