{
  "name": "companies_list",
  "description": "List all companies.",
  "resource_group": "companies",
  "endpoint": "/crm/v3/objects/companies",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Pagination cursor.",
      "in": "query"
    },
    {
      "name": "properties",
      "type": "string",
      "required": false,
      "description": "Properties to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubapi.com/crm/v3/objects/companies?limit=10&properties=name,domain,industry"
  },
  "response_example": {
    "results": [
      {
        "id": "501",
        "properties": {
          "name": "Acme Corp",
          "domain": "acme.com",
          "industry": "Technology"
        }
      }
    ]
  }
}
