{
  "name": "companies_update",
  "description": "Update a company.",
  "resource_group": "companies",
  "endpoint": "/crm/v3/objects/companies/{companyId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "companyId",
      "type": "string",
      "required": true,
      "description": "Company ID.",
      "in": "path"
    },
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Properties to update.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.hubapi.com/crm/v3/objects/companies/501",
    "body": {
      "properties": {
        "industry": "SaaS"
      }
    }
  },
  "response_example": {
    "id": "501",
    "properties": {
      "industry": "SaaS"
    }
  }
}
