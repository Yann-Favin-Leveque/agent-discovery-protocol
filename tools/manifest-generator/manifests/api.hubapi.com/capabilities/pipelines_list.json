{
  "name": "pipelines_list",
  "description": "List deal or ticket pipelines.",
  "resource_group": "pipelines",
  "endpoint": "/crm/v3/pipelines/{objectType}",
  "method": "GET",
  "parameters": [
    {
      "name": "objectType",
      "type": "string",
      "required": true,
      "description": "Object type: deals or tickets.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubapi.com/crm/v3/pipelines/deals"
  },
  "response_example": {
    "results": [
      {
        "id": "default",
        "label": "Sales Pipeline",
        "stages": [
          {
            "id": "appointmentscheduled",
            "label": "Appointment Scheduled"
          },
          {
            "id": "closedwon",
            "label": "Closed Won"
          }
        ]
      }
    ]
  }
}
