{
  "name": "create_contact",
  "description": "Create a new contact in HubSpot with specified properties such as email, name, phone, and company.",
  "endpoint": "/crm/v3/objects/contacts",
  "method": "POST",
  "parameters": [
    {"name": "properties", "type": "object", "description": "Contact properties to set.", "required": true, "example": {"email": "jane@example.com", "firstname": "Jane", "lastname": "Smith", "phone": "+1234567890", "company": "Acme Corp"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/contacts",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"properties": {"email": "jane@example.com", "firstname": "Jane", "lastname": "Smith", "phone": "+1234567890", "company": "Acme Corp"}}
  },
  "response_example": {
    "status": 201,
    "body": {"id": "456", "properties": {"email": "jane@example.com", "firstname": "Jane", "lastname": "Smith"}, "createdAt": "2024-01-20T10:00:00Z"}
  }
}
