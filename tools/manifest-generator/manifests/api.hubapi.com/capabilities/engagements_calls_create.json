{
  "name": "engagements_calls_create",
  "description": "Log a call activity.",
  "resource_group": "engagements",
  "endpoint": "/crm/v3/objects/calls",
  "method": "POST",
  "parameters": [
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Call properties: hs_call_title, hs_call_body, hs_call_duration, hs_call_direction, hs_timestamp.",
      "in": "body"
    },
    {
      "name": "associations",
      "type": "array",
      "required": false,
      "description": "Associations.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/calls",
    "body": {
      "properties": {
        "hs_call_title": "Discovery call",
        "hs_call_body": "Discussed requirements",
        "hs_call_duration": "1800000",
        "hs_call_direction": "OUTBOUND",
        "hs_timestamp": "2026-01-20T14:00:00Z"
      }
    }
  },
  "response_example": {
    "id": "call-abc",
    "properties": {
      "hs_call_title": "Discovery call"
    }
  }
}
