{
  "name": "deals_list",
  "description": "List all deals.",
  "resource_group": "deals",
  "endpoint": "/crm/v3/objects/deals",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Pagination cursor.",
      "in": "query"
    },
    {
      "name": "properties",
      "type": "string",
      "required": false,
      "description": "Properties to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubapi.com/crm/v3/objects/deals?limit=10&properties=dealname,amount,dealstage,closedate"
  },
  "response_example": {
    "results": [
      {
        "id": "701",
        "properties": {
          "dealname": "Enterprise Deal",
          "amount": "50000",
          "dealstage": "closedwon"
        }
      }
    ]
  }
}
