{
  "name": "deals_update",
  "description": "Update a deal.",
  "resource_group": "deals",
  "endpoint": "/crm/v3/objects/deals/{dealId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "dealId",
      "type": "string",
      "required": true,
      "description": "Deal ID.",
      "in": "path"
    },
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Properties to update.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.hubapi.com/crm/v3/objects/deals/701",
    "body": {
      "properties": {
        "dealstage": "closedwon",
        "amount": "55000"
      }
    }
  },
  "response_example": {
    "id": "701",
    "properties": {
      "dealstage": "closedwon",
      "amount": "55000"
    }
  }
}
