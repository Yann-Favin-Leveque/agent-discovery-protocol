{
  "name": "engagements_emails_create",
  "description": "Log an email activity.",
  "resource_group": "engagements",
  "endpoint": "/crm/v3/objects/emails",
  "method": "POST",
  "parameters": [
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Email properties: hs_email_subject, hs_email_text, hs_email_direction, hs_timestamp."
    },
    {
      "name": "associations",
      "type": "array",
      "required": false,
      "description": "Associations."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/emails",
    "body": {
      "properties": {
        "hs_email_subject": "Follow up",
        "hs_email_text": "Thanks for the meeting",
        "hs_email_direction": "EMAIL",
        "hs_timestamp": "2026-01-20T14:00:00Z"
      }
    }
  },
  "response_example": {
    "id": "email-abc",
    "properties": {
      "hs_email_subject": "Follow up"
    }
  }
}