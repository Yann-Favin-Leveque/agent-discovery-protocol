{
  "name": "deals_create",
  "description": "Create a deal.",
  "resource_group": "deals",
  "endpoint": "/crm/v3/objects/deals",
  "method": "POST",
  "parameters": [
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Deal properties: dealname, amount, dealstage, closedate, pipeline, hubspot_owner_id.",
      "in": "body"
    },
    {
      "name": "associations",
      "type": "array",
      "required": false,
      "description": "Associations to contacts/companies.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubapi.com/crm/v3/objects/deals",
    "body": {
      "properties": {
        "dealname": "New Deal",
        "amount": "25000",
        "dealstage": "appointmentscheduled",
        "pipeline": "default"
      }
    }
  },
  "response_example": {
    "id": "801",
    "properties": {
      "dealname": "New Deal",
      "amount": "25000",
      "dealstage": "appointmentscheduled"
    }
  }
}
