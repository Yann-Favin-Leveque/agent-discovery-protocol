{
  "name": "contacts_update",
  "description": "Update a contact.",
  "resource_group": "contacts",
  "endpoint": "/crm/v3/objects/contacts/{contactId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "contactId",
      "type": "string",
      "required": true,
      "description": "Contact ID.",
      "in": "path"
    },
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "description": "Properties to update.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.hubapi.com/crm/v3/objects/contacts/101",
    "body": {
      "properties": {
        "jobtitle": "Manager",
        "lifecyclestage": "customer"
      }
    }
  },
  "response_example": {
    "id": "101",
    "properties": {
      "jobtitle": "Manager",
      "lifecyclestage": "customer"
    },
    "updatedAt": "2026-01-20T15:00:00Z"
  }
}
