{
  "name": "companies_get",
  "description": "Get a company by ID.",
  "resource_group": "companies",
  "endpoint": "/crm/v3/objects/companies/{companyId}",
  "method": "GET",
  "parameters": [
    {
      "name": "companyId",
      "type": "string",
      "required": true,
      "description": "Company ID."
    },
    {
      "name": "properties",
      "type": "string",
      "required": false,
      "description": "Properties to return."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubapi.com/crm/v3/objects/companies/501?properties=name,domain,industry"
  },
  "response_example": {
    "id": "501",
    "properties": {
      "name": "Acme Corp",
      "domain": "acme.com",
      "industry": "Technology"
    }
  }
}