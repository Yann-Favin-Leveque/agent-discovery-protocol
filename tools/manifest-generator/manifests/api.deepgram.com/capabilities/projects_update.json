{
  "name": "projects_update",
  "description": "Update the name or settings of a project.",
  "resource_group": "projects",
  "endpoint": "/v1/projects/{project_id}",
  "method": "PATCH",
  "parameters": [
    {"name": "project_id", "type": "string", "description": "Unique project identifier.", "required": true, "example": "proj_abc123"},
    {"name": "name", "type": "string", "description": "New project name.", "required": false, "example": "Renamed Project"},
    {"name": "company", "type": "string", "description": "Company name for the project.", "required": false}
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.deepgram.com/v1/projects/proj_abc123",
    "headers": {"Authorization": "Token {api_key}", "Content-Type": "application/json"},
    "body": {"name": "Renamed Project"}
  },
  "response_example": {
    "status": 200,
    "body": {"message": "Project updated."}
  },
  "rate_limits": {"requests_per_minute": 100}
}