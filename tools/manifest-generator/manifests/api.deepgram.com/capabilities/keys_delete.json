{
  "name": "keys_delete",
  "description": "Delete an API key from a project.",
  "resource_group": "keys",
  "endpoint": "/v1/projects/{project_id}/keys/{key_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "description": "Project identifier.",
      "required": true,
      "example": "proj_abc123",
      "in": "path"
    },
    {
      "name": "key_id",
      "type": "string",
      "description": "API key identifier to delete.",
      "required": true,
      "example": "key_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.deepgram.com/v1/projects/proj_abc123/keys/key_123",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "rate_limits": {
    "requests_per_minute": 100
  }
}
