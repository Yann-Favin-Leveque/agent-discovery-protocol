{
  "name": "members_list",
  "description": "List all members of a project.",
  "resource_group": "members",
  "endpoint": "/v1/projects/{project_id}/members",
  "method": "GET",
  "parameters": [
    {"name": "project_id", "type": "string", "description": "Project identifier.", "required": true, "example": "proj_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepgram.com/v1/projects/proj_abc123/members",
    "headers": {"Authorization": "Token {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {
      "members": [
        {"member_id": "mem_123", "email": "user@example.com", "scopes": ["admin"]}
      ]
    }
  },
  "rate_limits": {"requests_per_minute": 100}
}