{
  "name": "projects_get",
  "description": "Retrieve details for a specific project by ID.",
  "resource_group": "projects",
  "endpoint": "/v1/projects/{project_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "description": "Unique project identifier.",
      "required": true,
      "example": "proj_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepgram.com/v1/projects/proj_abc123",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "project_id": "proj_abc123",
      "name": "My Transcription App",
      "company": "Acme Corp"
    }
  },
  "rate_limits": {
    "requests_per_minute": 100
  }
}
