{
  "name": "keys_list",
  "description": "List all API keys for a project.",
  "resource_group": "keys",
  "endpoint": "/v1/projects/{project_id}/keys",
  "method": "GET",
  "parameters": [
    {"name": "project_id", "type": "string", "description": "Project identifier.", "required": true, "example": "proj_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepgram.com/v1/projects/proj_abc123/keys",
    "headers": {"Authorization": "Token {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {
      "api_keys": [
        {
          "member": {"member_id": "mem_123", "email": "user@example.com"},
          "api_key": {"api_key_id": "key_123", "comment": "Production", "scopes": ["member"], "created": "2024-01-01T00:00:00Z"}
        }
      ]
    }
  },
  "rate_limits": {"requests_per_minute": 100}
}