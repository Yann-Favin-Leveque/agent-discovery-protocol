{
  "name": "balances_list",
  "description": "Retrieve billing balance information for a project.",
  "resource_group": "balances",
  "endpoint": "/v1/projects/{project_id}/balances",
  "method": "GET",
  "parameters": [
    {"name": "project_id", "type": "string", "description": "Project identifier.", "required": true, "example": "proj_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepgram.com/v1/projects/proj_abc123/balances",
    "headers": {"Authorization": "Token {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {
      "balances": [
        {"balance_id": "bal_123", "amount": 50.0, "units": "usd"}
      ]
    }
  },
  "rate_limits": {"requests_per_minute": 100}
}