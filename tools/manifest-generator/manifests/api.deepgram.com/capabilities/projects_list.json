{
  "name": "projects_list",
  "description": "Retrieve a list of all projects associated with the authenticated API key.",
  "resource_group": "projects",
  "endpoint": "/v1/projects",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepgram.com/v1/projects",
    "headers": {"Authorization": "Token {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {
      "projects": [
        {"project_id": "proj_abc123", "name": "My Transcription App"}
      ]
    }
  },
  "rate_limits": {"requests_per_minute": 100}
}