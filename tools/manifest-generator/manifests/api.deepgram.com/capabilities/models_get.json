{
  "name": "models_get",
  "description": "Retrieve metadata and details for a specific Deepgram model.",
  "resource_group": "models",
  "endpoint": "/v1/models/{model_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "model_id",
      "type": "string",
      "description": "Model identifier.",
      "required": true,
      "example": "nova-3",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepgram.com/v1/models/nova-3",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "nova-3",
      "languages": [
        "en",
        "es",
        "fr",
        "de"
      ],
      "version": "2024-01-01",
      "description": "Most powerful speech-to-text model"
    }
  },
  "rate_limits": {
    "requests_per_minute": 100
  }
}
