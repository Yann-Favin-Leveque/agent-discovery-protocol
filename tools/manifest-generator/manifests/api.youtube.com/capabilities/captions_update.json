{
  "name": "captions_update",
  "description": "Update a caption track.",
  "endpoint": "/youtube/v3/captions",
  "method": "PUT",
  "resource_group": "captions",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://youtube.googleapis.com/youtube/v3/captions",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "caption_123",
      "snippet": {
        "isDraft": false
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "caption_123"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
