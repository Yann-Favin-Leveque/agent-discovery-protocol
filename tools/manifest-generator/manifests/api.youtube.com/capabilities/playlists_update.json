{
  "name": "playlists_update",
  "description": "Update a playlist's metadata.",
  "endpoint": "/youtube/v3/playlists",
  "method": "PUT",
  "resource_group": "playlists",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts to update",
      "required": true,
      "example": "snippet",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://youtube.googleapis.com/youtube/v3/playlists",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "PL_playlist_id",
      "snippet": {
        "title": "Updated Playlist"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "PL_playlist_id",
      "snippet": {
        "title": "Updated Playlist"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
