{
  "name": "abuse_reports_insert",
  "description": "File an abuse report.",
  "endpoint": "/youtube/v3/abuseReports",
  "method": "POST",
  "resource_group": "abuse_reports",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/abuseReports",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "snippet": {
        "reasonId": "S",
        "comments": "Spam content"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "report_123"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}