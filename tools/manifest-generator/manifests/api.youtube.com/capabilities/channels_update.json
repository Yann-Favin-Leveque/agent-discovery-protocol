{
  "name": "channels_update",
  "description": "Update a channel's metadata and settings.",
  "endpoint": "/youtube/v3/channels",
  "method": "PUT",
  "resource_group": "channels",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts to update",
      "required": true,
      "example": "brandingSettings",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://youtube.googleapis.com/youtube/v3/channels",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "UC_channel_id",
      "brandingSettings": {
        "channel": {
          "description": "Updated description"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "UC_channel_id",
      "brandingSettings": {
        "channel": {
          "description": "Updated description"
        }
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
