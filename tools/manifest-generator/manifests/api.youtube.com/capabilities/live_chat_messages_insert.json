{
  "name": "live_chat_messages_insert",
  "description": "Send a message to a live chat.",
  "endpoint": "/youtube/v3/liveChat/messages",
  "method": "POST",
  "resource_group": "live_chat",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/liveChat/messages",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "snippet": {
        "liveChatId": "LC_chat_id",
        "type": "textMessageEvent",
        "textMessageDetails": {
          "messageText": "Hello everyone!"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "snippet": {
        "displayMessage": "Hello everyone!"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
