{
  "name": "live_chat_messages_list",
  "description": "Retrieve live chat messages for a broadcast.",
  "endpoint": "/youtube/v3/liveChat/messages",
  "method": "GET",
  "resource_group": "live_chat",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet,authorDetails",
      "in": "query"
    },
    {
      "name": "liveChatId",
      "type": "string",
      "description": "Live chat ID",
      "required": true,
      "example": "LC_chat_id",
      "in": "query"
    },
    {
      "name": "maxResults",
      "type": "integer",
      "description": "Max results (200-2000)",
      "required": false,
      "example": "500",
      "in": "query"
    },
    {
      "name": "pageToken",
      "type": "string",
      "description": "Pagination token",
      "required": false,
      "example": "",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/liveChat/messages",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "snippet": {
            "displayMessage": "Hello!",
            "publishedAt": "2024-01-15T10:30:00Z"
          },
          "authorDetails": {
            "displayName": "Viewer"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
