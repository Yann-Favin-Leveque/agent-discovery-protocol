{
  "name": "live_broadcasts_bind",
  "description": "Bind a broadcast to a live stream.",
  "endpoint": "/youtube/v3/liveBroadcasts/bind",
  "method": "POST",
  "resource_group": "live_broadcasts",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Broadcast ID",
      "required": true,
      "example": "broadcast_123",
      "in": "body"
    },
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet",
      "in": "body"
    },
    {
      "name": "streamId",
      "type": "string",
      "description": "Stream ID to bind",
      "required": false,
      "example": "stream_123",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/liveBroadcasts/bind",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "broadcast_123"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
