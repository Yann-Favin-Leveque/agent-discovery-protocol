{
  "name": "videos_report_abuse",
  "description": "Report a video for abusive content.",
  "endpoint": "/youtube/v3/videos/reportAbuse",
  "method": "POST",
  "resource_group": "videos",
  "parameters": [
    {
      "name": "videoId",
      "type": "string",
      "description": "Video ID",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "reasonId",
      "type": "string",
      "description": "Abuse reason ID",
      "required": true,
      "example": "S"
    },
    {
      "name": "comments",
      "type": "string",
      "description": "Additional comments",
      "required": false,
      "example": "Spam content"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/videos/reportAbuse",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "videoId": "abc123",
      "reasonId": "S",
      "comments": "Spam content"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}