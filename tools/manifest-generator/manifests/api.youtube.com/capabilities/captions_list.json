{
  "name": "captions_list",
  "description": "List caption tracks for a video.",
  "endpoint": "/youtube/v3/captions",
  "method": "GET",
  "resource_group": "captions",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    },
    {
      "name": "videoId",
      "type": "string",
      "description": "Video ID",
      "required": true,
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/captions",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "caption_123",
          "snippet": {
            "language": "en",
            "name": "English",
            "status": "serving"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}