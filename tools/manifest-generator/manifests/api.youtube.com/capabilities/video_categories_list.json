{
  "name": "video_categories_list",
  "description": "List video categories available in a region.",
  "endpoint": "/youtube/v3/videoCategories",
  "method": "GET",
  "resource_group": "video_categories",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    },
    {
      "name": "regionCode",
      "type": "string",
      "description": "Country code",
      "required": false,
      "example": "US"
    },
    {
      "name": "id",
      "type": "string",
      "description": "Category IDs",
      "required": false,
      "example": ""
    },
    {
      "name": "hl",
      "type": "string",
      "description": "Language",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/videoCategories",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "22",
          "snippet": {
            "title": "People & Blogs"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.readonly"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}