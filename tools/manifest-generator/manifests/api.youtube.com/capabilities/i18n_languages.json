{
  "name": "i18n_languages",
  "description": "Manage i18nlanguages — retrieves a list of resources, possibly filtered. Supports standard CRUD operations through the REST API.",
  "endpoint": "/youtube/v3/i18nLanguages",
  "method": "GET",
  "parameters": [
    {
      "name": "hl",
      "type": "string",
      "description": "The hl parameter.",
      "required": false,
      "example": "en_US"
    },
    {
      "name": "part",
      "type": "string",
      "description": "The *part* parameter specifies the i18nLanguage resource properties that the API response will include. Set the parameter value to snippet.",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/i18nLanguages",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "part": "example_value"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube",
    "https://www.googleapis.com/auth/youtube.channel-memberships.creator",
    "https://www.googleapis.com/auth/youtube.force-ssl",
    "https://www.googleapis.com/auth/youtube.readonly",
    "https://www.googleapis.com/auth/youtube.upload"
  ]
}
