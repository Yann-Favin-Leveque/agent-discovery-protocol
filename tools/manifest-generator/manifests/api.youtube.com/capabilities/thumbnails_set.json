{
  "name": "thumbnails_set",
  "description": "Upload and set a custom thumbnail for a video.",
  "endpoint": "/youtube/v3/thumbnails/set",
  "method": "POST",
  "resource_group": "thumbnails",
  "parameters": [
    {
      "name": "videoId",
      "type": "string",
      "description": "Video ID",
      "required": true,
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/thumbnails/set",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "default": {
            "url": "https://i.ytimg.com/vi/abc123/default.jpg"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.upload"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}