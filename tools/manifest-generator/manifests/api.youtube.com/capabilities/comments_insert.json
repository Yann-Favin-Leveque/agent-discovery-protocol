{
  "name": "comments_insert",
  "description": "Post a reply to an existing comment.",
  "endpoint": "/youtube/v3/comments",
  "method": "POST",
  "resource_group": "comments",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/comments",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "snippet": {
        "parentId": "thread_123",
        "textOriginal": "Thanks for the feedback!"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "comment_new",
      "snippet": {
        "textDisplay": "Thanks for the feedback!"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}