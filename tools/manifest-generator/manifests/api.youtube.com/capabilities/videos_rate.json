{
  "name": "videos_rate",
  "description": "Add a like or dislike rating to a video.",
  "endpoint": "/youtube/v3/videos/rate",
  "method": "POST",
  "resource_group": "videos",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Video ID",
      "required": true,
      "example": "abc123",
      "in": "body"
    },
    {
      "name": "rating",
      "type": "string",
      "description": "Rating (like, dislike, none)",
      "required": true,
      "example": "like",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/videos/rate",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
