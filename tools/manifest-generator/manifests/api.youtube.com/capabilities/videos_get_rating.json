{
  "name": "videos_get_rating",
  "description": "Retrieve the rating the authenticated user gave to specified videos.",
  "endpoint": "/youtube/v3/videos/getRating",
  "method": "GET",
  "resource_group": "videos",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Comma-separated video IDs",
      "required": true,
      "example": "abc123,def456",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/videos/getRating",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "videoId": "abc123",
          "rating": "like"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
