{
  "name": "captions_insert",
  "description": "Upload a caption track for a video.",
  "endpoint": "/youtube/v3/captions",
  "method": "POST",
  "resource_group": "captions",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    },
    {
      "name": "sync",
      "type": "boolean",
      "description": "Auto-sync caption timing",
      "required": false,
      "example": "true"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/captions",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "snippet": {
        "videoId": "abc123",
        "language": "en",
        "name": "English"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "caption_new",
      "snippet": {
        "language": "en",
        "status": "serving"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}