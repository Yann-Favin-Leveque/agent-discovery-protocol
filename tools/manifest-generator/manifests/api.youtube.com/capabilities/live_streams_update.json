{
  "name": "live_streams_update",
  "description": "Update a live stream's settings.",
  "endpoint": "/youtube/v3/liveStreams",
  "method": "PUT",
  "resource_group": "live_streams",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://youtube.googleapis.com/youtube/v3/liveStreams",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "stream_123",
      "snippet": {
        "title": "Updated Stream"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "stream_123",
      "snippet": {
        "title": "Updated Stream"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}