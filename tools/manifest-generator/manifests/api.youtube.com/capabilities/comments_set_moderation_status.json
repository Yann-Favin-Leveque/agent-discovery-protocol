{
  "name": "comments_set_moderation_status",
  "description": "Set the moderation status of one or more comments.",
  "endpoint": "/youtube/v3/comments/setModerationStatus",
  "method": "POST",
  "resource_group": "comments",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Comma-separated comment IDs",
      "required": true,
      "example": "comment_456",
      "in": "body"
    },
    {
      "name": "moderationStatus",
      "type": "string",
      "description": "Status (heldForReview, published, rejected)",
      "required": true,
      "example": "published",
      "in": "body"
    },
    {
      "name": "banAuthor",
      "type": "boolean",
      "description": "Ban the comment author",
      "required": false,
      "example": "false",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/comments/setModerationStatus",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
