{
  "name": "i18n_regions_list",
  "description": "List geographic regions supported by YouTube.",
  "endpoint": "/youtube/v3/i18nRegions",
  "method": "GET",
  "resource_group": "i18n",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    },
    {
      "name": "hl",
      "type": "string",
      "description": "Language for localized text",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/i18nRegions",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "US",
          "snippet": {
            "gl": "US",
            "name": "United States"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.readonly"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}