{
  "name": "subscriptions_insert",
  "description": "Subscribe to a channel.",
  "endpoint": "/youtube/v3/subscriptions",
  "method": "POST",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/subscriptions",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "snippet": {
        "resourceId": {
          "channelId": "UC_channel_id"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sub_new",
      "snippet": {
        "resourceId": {
          "channelId": "UC_channel_id"
        }
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}