{
  "name": "live_chat_moderators_list",
  "description": "List moderators for a live chat.",
  "endpoint": "/youtube/v3/liveChat/moderators",
  "method": "GET",
  "resource_group": "live_chat",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet",
      "in": "query"
    },
    {
      "name": "liveChatId",
      "type": "string",
      "description": "Live chat ID",
      "required": true,
      "example": "LC_chat_id",
      "in": "query"
    },
    {
      "name": "maxResults",
      "type": "integer",
      "description": "Max results",
      "required": false,
      "example": "10",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/liveChat/moderators",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "snippet": {
            "moderatorDetails": {
              "displayName": "Moderator"
            }
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
