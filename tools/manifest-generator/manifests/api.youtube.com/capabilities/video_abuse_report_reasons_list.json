{
  "name": "video_abuse_report_reasons_list",
  "description": "List reasons for reporting video abuse.",
  "endpoint": "/youtube/v3/videoAbuseReportReasons",
  "method": "GET",
  "resource_group": "video_abuse",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet"
    },
    {
      "name": "hl",
      "type": "string",
      "description": "Language",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/videoAbuseReportReasons",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "S",
          "snippet": {
            "label": "Spam or misleading"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.readonly"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}