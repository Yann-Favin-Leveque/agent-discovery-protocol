{
  "name": "channel_sections_list",
  "description": "List channel sections (featured content shelves).",
  "endpoint": "/youtube/v3/channelSections",
  "method": "GET",
  "resource_group": "channel_sections",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet,contentDetails"
    },
    {
      "name": "channelId",
      "type": "string",
      "description": "Channel ID",
      "required": false,
      "example": "UC_channel_id"
    },
    {
      "name": "mine",
      "type": "boolean",
      "description": "Return user's channel sections",
      "required": false,
      "example": "true"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/channelSections",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "section_123",
          "snippet": {
            "type": "singlePlaylist",
            "title": "Featured"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.readonly"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}