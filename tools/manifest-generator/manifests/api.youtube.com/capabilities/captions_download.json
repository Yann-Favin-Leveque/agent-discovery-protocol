{
  "name": "captions_download",
  "description": "Download a caption track file.",
  "endpoint": "/youtube/v3/captions/{id}",
  "method": "GET",
  "resource_group": "captions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Caption track ID",
      "required": true,
      "example": "caption_123",
      "in": "path"
    },
    {
      "name": "tfmt",
      "type": "string",
      "description": "Caption format (sbv, scc, srt, ttml, vtt)",
      "required": false,
      "example": "srt",
      "in": "query"
    },
    {
      "name": "tlang",
      "type": "string",
      "description": "Translation language",
      "required": false,
      "example": "",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://youtube.googleapis.com/youtube/v3/captions/{id}",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": "1\n00:00:00,000 --> 00:00:05,000\nHello world"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
