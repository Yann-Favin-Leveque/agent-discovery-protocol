{
  "name": "channel_banners_insert",
  "description": "Upload a channel banner image.",
  "endpoint": "/youtube/v3/channelBanners/insert",
  "method": "POST",
  "resource_group": "channel_banners",
  "parameters": [
    {
      "name": "channelId",
      "type": "string",
      "description": "Channel ID",
      "required": false,
      "example": "UC_channel_id",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://youtube.googleapis.com/youtube/v3/channelBanners/insert",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "url": "https://yt3.ggpht.com/banner_url"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.upload"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
