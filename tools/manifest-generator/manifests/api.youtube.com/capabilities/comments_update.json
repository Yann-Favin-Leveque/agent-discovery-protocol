{
  "name": "comments_update",
  "description": "Update a comment's text.",
  "endpoint": "/youtube/v3/comments",
  "method": "PUT",
  "resource_group": "comments",
  "parameters": [
    {
      "name": "part",
      "type": "string",
      "description": "Resource parts",
      "required": true,
      "example": "snippet",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://youtube.googleapis.com/youtube/v3/comments",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "comment_456",
      "snippet": {
        "textOriginal": "Updated comment text"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "comment_456",
      "snippet": {
        "textDisplay": "Updated comment text"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/youtube.force-ssl"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
