{
  "name": "get_item",
  "description": "Retrieve full details of a specific item including its fields, secret values, and metadata. This is how you read passwords, API keys, and other secrets from 1Password.",
  "endpoint": "/v1/vaults/{vaultId}/items/{itemId}",
  "method": "GET",
  "parameters": [
    { "name": "vaultId", "type": "string", "description": "The vault UUID.", "required": true, "example": "vault_abc123" },
    { "name": "itemId", "type": "string", "description": "The item UUID.", "required": true, "example": "item_xyz789" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://your-connect-server:8080/v1/vaults/vault_abc123/items/item_xyz789",
    "headers": { "Authorization": "Bearer {connect_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "item_xyz789",
      "title": "Database Password",
      "category": "LOGIN",
      "fields": [
        { "id": "username", "type": "STRING", "label": "username", "value": "admin" },
        { "id": "password", "type": "CONCEALED", "label": "password", "value": "s3cr3t_p@ssw0rd" }
      ],
      "urls": [{ "primary": true, "href": "https://db.example.com" }]
    }
  }
}
