{
  "name": "list_vaults",
  "description": "Retrieve a list of all vaults accessible to your Connect server. Vaults are containers that organize your items by team, project, or purpose.",
  "endpoint": "/v1/vaults",
  "method": "GET",
  "parameters": [
    { "name": "filter", "type": "string", "description": "SCIM filter expression.", "required": false, "example": "name eq \"Engineering\"" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://your-connect-server:8080/v1/vaults",
    "headers": { "Authorization": "Bearer {connect_token}" }
  },
  "response_example": {
    "status": 200,
    "body": [
      { "id": "vault_abc123", "name": "Engineering", "description": "Engineering team secrets", "attributeVersion": 1, "contentVersion": 42, "items": 15, "type": "USER_CREATED", "createdAt": "2024-01-15T10:00:00Z", "updatedAt": "2024-02-01T14:30:00Z" }
    ]
  }
}
