{
  "name": "items_delete",
  "description": "Permanently delete an item from a vault by its UUID.",
  "endpoint": "/v1/vaults/{vaultUUID}/items/{itemUUID}",
  "method": "DELETE",
  "resource_group": "items",
  "parameters": [
    {
      "name": "vaultUUID",
      "type": "string",
      "description": "UUID of the vault containing the item.",
      "required": true,
      "example": "hfnjvi6aymbsnfc2xeeoheizda"
    },
    {
      "name": "itemUUID",
      "type": "string",
      "description": "UUID of the item to delete.",
      "required": true,
      "example": "wepiqdxdzncjtnvmv5fegud4qy"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.1password.com/v1/vaults/hfnjvi6aymbsnfc2xeeoheizda/items/wepiqdxdzncjtnvmv5fegud4qy",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": ["vaults"],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
