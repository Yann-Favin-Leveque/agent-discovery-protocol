{
  "name": "vaults_get",
  "description": "Retrieve details about a specific vault by its UUID, including item count and metadata.",
  "endpoint": "/v1/vaults/{vaultUUID}",
  "method": "GET",
  "resource_group": "vaults",
  "parameters": [
    {
      "name": "vaultUUID",
      "type": "string",
      "description": "UUID of the vault to retrieve.",
      "required": true,
      "example": "hfnjvi6aymbsnfc2xeeoheizda"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.1password.com/v1/vaults/hfnjvi6aymbsnfc2xeeoheizda",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "hfnjvi6aymbsnfc2xeeoheizda",
      "name": "Production",
      "description": "Production secrets",
      "attributeVersion": 1,
      "contentVersion": 42,
      "items": 15,
      "type": "USER_CREATED",
      "createdAt": "2023-01-15T10:30:00Z",
      "updatedAt": "2024-06-01T14:22:00Z"
    }
  },
  "auth_scopes": ["vaults"],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
