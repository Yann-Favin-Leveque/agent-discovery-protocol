{
  "name": "files_get_content",
  "description": "Download the raw binary content of a file attachment from an item.",
  "endpoint": "/v1/vaults/{vaultUUID}/items/{itemUUID}/files/{fileUUID}/content",
  "method": "GET",
  "resource_group": "files",
  "parameters": [
    {
      "name": "vaultUUID",
      "type": "string",
      "description": "UUID of the vault.",
      "required": true,
      "example": "hfnjvi6aymbsnfc2xeeoheizda",
      "in": "path"
    },
    {
      "name": "itemUUID",
      "type": "string",
      "description": "UUID of the item.",
      "required": true,
      "example": "wepiqdxdzncjtnvmv5fegud4qy",
      "in": "path"
    },
    {
      "name": "fileUUID",
      "type": "string",
      "description": "UUID of the file to download.",
      "required": true,
      "example": "6lu2cjizrrehtobqp7sfez7fja",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.1password.com/v1/vaults/hfnjvi6aymbsnfc2xeeoheizda/items/wepiqdxdzncjtnvmv5fegud4qy/files/6lu2cjizrrehtobqp7sfez7fja/content",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "(binary file content)"
  },
  "auth_scopes": [
    "vaults"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
