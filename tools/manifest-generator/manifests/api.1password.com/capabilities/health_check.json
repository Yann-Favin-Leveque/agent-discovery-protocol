{
  "name": "health_check",
  "description": "Query the state of the Connect server and its service dependencies to verify operational status.",
  "endpoint": "/v1/health",
  "method": "GET",
  "resource_group": "monitoring",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.1password.com/v1/health",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "1Password Connect API",
      "version": "1.5.7",
      "dependencies": [
        { "service": "sync", "status": "ACTIVE" },
        { "service": "storage", "status": "ACTIVE" }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
