{
  "name": "chat_create_stream",
  "description": "Generate conversational responses as a real-time stream of server-sent events for token-by-token display. Uses the same endpoint as chat_create with stream=true.",
  "resource_group": "chat",
  "endpoint": "/v2/chat",
  "method": "POST",
  "parameters": [
    {
      "name": "model",
      "type": "string",
      "required": true,
      "description": "Model identifier.",
      "in": "body"
    },
    {
      "name": "messages",
      "type": "array",
      "required": true,
      "description": "Chat message history.",
      "in": "body"
    },
    {
      "name": "stream",
      "type": "boolean",
      "required": true,
      "description": "Must be set to true for streaming.",
      "in": "body"
    },
    {
      "name": "max_tokens",
      "type": "integer",
      "required": false,
      "description": "Maximum output tokens.",
      "in": "body"
    },
    {
      "name": "temperature",
      "type": "number",
      "required": false,
      "description": "Randomness degree (default 0.3).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cohere.com/v2/chat",
    "headers": {
      "Authorization": "Bearer co-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "command-a-03-2025",
      "stream": true,
      "messages": [
        {
          "role": "user",
          "content": "Tell me a short story."
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": "event: content-delta\ndata: {\"type\": \"content-delta\", \"delta\": {\"message\": {\"content\": {\"text\": \"Once upon\"}}}}\n\nevent: message-end\ndata: {\"type\": \"message-end\"}"
  }
}
