{
  "name": "classify_text",
  "description": "Classify text inputs into predefined categories using few-shot examples. Useful for sentiment analysis, topic labeling, intent detection, and content moderation without fine-tuning a model.",
  "endpoint": "/v1/classify",
  "method": "POST",
  "parameters": [
    {
      "name": "model",
      "type": "string",
      "description": "The model ID to use for classification.",
      "required": false,
      "example": "embed-v4.0"
    },
    {
      "name": "inputs",
      "type": "array",
      "description": "Array of text strings to classify (max 96 items).",
      "required": true,
      "example": ["This product is amazing!", "Terrible experience, never again."]
    },
    {
      "name": "examples",
      "type": "array",
      "description": "Array of labeled examples with 'text' and 'label' fields for few-shot classification.",
      "required": true,
      "example": [
        {"text": "I love this!", "label": "positive"},
        {"text": "This is awful.", "label": "negative"}
      ]
    },
    {
      "name": "preset",
      "type": "string",
      "description": "Name of a saved preset to use instead of inline examples.",
      "required": false,
      "example": "sentiment-analysis"
    },
    {
      "name": "truncate",
      "type": "string",
      "description": "How to handle inputs exceeding max length: 'NONE', 'START', or 'END'.",
      "required": false,
      "example": "END"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cohere.com/v1/classify",
    "headers": {
      "Authorization": "Bearer your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "inputs": ["This product is fantastic!", "Worst purchase ever."],
      "examples": [
        {"text": "I love this product", "label": "positive"},
        {"text": "Great quality", "label": "positive"},
        {"text": "This is terrible", "label": "negative"},
        {"text": "Very disappointing", "label": "negative"}
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cls-1234567890",
      "classifications": [
        {
          "id": "0",
          "input": "This product is fantastic!",
          "prediction": "positive",
          "confidence": 0.95,
          "labels": {
            "positive": {"confidence": 0.95},
            "negative": {"confidence": 0.05}
          }
        },
        {
          "id": "1",
          "input": "Worst purchase ever.",
          "prediction": "negative",
          "confidence": 0.92,
          "labels": {
            "positive": {"confidence": 0.08},
            "negative": {"confidence": 0.92}
          }
        }
      ]
    }
  }
}
