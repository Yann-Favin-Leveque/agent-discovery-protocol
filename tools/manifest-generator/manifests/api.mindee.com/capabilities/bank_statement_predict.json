{
  "name": "bank_statement_predict",
  "description": "Parse a bank statement to extract account details, transactions, and balances.",
  "endpoint": "/v1/products/mindee/bank_statement/v1/predict",
  "method": "POST",
  "resource_group": "financial",
  "parameters": [
    {
      "name": "document",
      "type": "file",
      "description": "Bank statement file (PDF, JPG, PNG).",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mindee.com/v1/products/mindee/bank_statement/v1/predict",
    "headers": {
      "Authorization": "Token {api_key}",
      "Content-Type": "multipart/form-data"
    },
    "body": {
      "document": "(binary file data)"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "api_request": {
        "status": "success"
      },
      "document": {
        "inference": {
          "prediction": {
            "account_number": {
              "value": "1234567890"
            },
            "bank_name": {
              "value": "Chase Bank"
            },
            "opening_balance": {
              "value": 5000
            },
            "closing_balance": {
              "value": 4250
            },
            "transactions": [
              {
                "date": "2024-01-10",
                "description": "Payment to vendor",
                "amount": -750
              }
            ]
          }
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
