{
  "name": "boards_delete",
  "description": "Delete a board.",
  "resource_group": "boards",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "board_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Board ID to delete",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "mutation { delete_board (board_id: 123) { id } }"
  }
}
