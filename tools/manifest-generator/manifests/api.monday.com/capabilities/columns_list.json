{
  "name": "columns_list",
  "description": "List columns on a board.",
  "resource_group": "columns",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "board_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Board ID"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "{ boards (ids: [123]) { columns { id title type settings_str } } }"
  }
}