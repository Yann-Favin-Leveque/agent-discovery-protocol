{
  "name": "groups_create",
  "description": "Create a new group on a board.",
  "resource_group": "groups",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "board_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Board ID"
    },
    {
      "name": "group_name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Group name"
    },
    {
      "name": "group_color",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Group color"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "mutation { create_group (board_id: 123, group_name: \"New Group\") { id title } }"
  }
}