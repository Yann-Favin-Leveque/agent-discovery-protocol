{
  "name": "items_create",
  "description": "Create a new item on a board.",
  "resource_group": "items",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "board_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Board ID",
      "in": "body"
    },
    {
      "name": "item_name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Item name",
      "in": "body"
    },
    {
      "name": "group_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Group to create the item in",
      "in": "body"
    },
    {
      "name": "column_values",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "JSON string of column values",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "mutation { create_item (board_id: 123, item_name: \"New Item\", column_values: \"{\\\"status\\\":{\\\"label\\\":\\\"Working on it\\\"}}\") { id name } }"
  }
}
