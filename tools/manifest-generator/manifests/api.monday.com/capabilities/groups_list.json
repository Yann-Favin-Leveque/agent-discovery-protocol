{
  "name": "groups_list",
  "description": "List groups on a board.",
  "resource_group": "groups",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "board_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Board ID"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "{ boards (ids: [123]) { groups { id title color position } } }"
  }
}