{
  "name": "updates_create",
  "description": "Post an update (comment) on an item.",
  "resource_group": "updates",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "item_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Item ID"
    },
    {
      "name": "body",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Update text content"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "mutation { create_update (item_id: 456, body: \"Progress update: completed phase 1\") { id } }"
  }
}