{
  "name": "items_move_to_group",
  "description": "Move an item to a different group.",
  "resource_group": "items",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "item_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Item ID"
    },
    {
      "name": "group_id",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Target group ID"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "mutation { move_item_to_group (item_id: 456, group_id: \"new_group\") { id } }"
  }
}