{
  "name": "tags_create",
  "description": "Create a tag.",
  "resource_group": "tags",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "tag_name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Tag name",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "mutation { create_or_get_tag (tag_name: \"urgent\") { id name } }"
  }
}
