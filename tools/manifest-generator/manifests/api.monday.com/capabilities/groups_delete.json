{
  "name": "groups_delete",
  "description": "Delete a group from a board.",
  "resource_group": "groups",
  "endpoint": "/",
  "method": "POST",
  "parameters": [
    {
      "name": "board_id",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Board ID",
      "in": "body"
    },
    {
      "name": "group_id",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Group ID to delete",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "boards:read",
    "boards:write",
    "workspaces:read",
    "workspaces:write"
  ],
  "request_example": {
    "query": "mutation { delete_group (board_id: 123, group_id: \"topics\") { id } }"
  }
}
