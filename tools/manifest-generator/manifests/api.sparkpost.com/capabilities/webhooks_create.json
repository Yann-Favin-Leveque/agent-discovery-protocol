{
  "name": "webhooks_create",
  "description": "Create a webhook to receive real-time event notifications at a target URL.",
  "endpoint": "/api/v1/webhooks",
  "method": "POST",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Webhook name",
      "required": true,
      "example": "My Webhook",
      "in": "body"
    },
    {
      "name": "target",
      "type": "string",
      "description": "Target URL for event delivery",
      "required": true,
      "example": "https://example.com/webhook",
      "in": "body"
    },
    {
      "name": "events",
      "type": "array",
      "description": "Event types to subscribe to",
      "required": true,
      "example": [
        "delivery",
        "bounce",
        "open"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.sparkpost.com/api/v1/webhooks",
    "headers": {
      "Authorization": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "My Webhook",
      "target": "https://example.com/webhook",
      "events": [
        "delivery",
        "bounce",
        "open"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": {
        "id": "webhook-123"
      }
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
