{
  "name": "metrics_by_template",
  "description": "Get deliverability metrics grouped by template.",
  "endpoint": "/api/v1/metrics/deliverability/template",
  "method": "GET",
  "resource_group": "metrics",
  "parameters": [
    {
      "name": "from",
      "type": "string",
      "description": "Start datetime",
      "required": true,
      "example": "2026-03-01T00:00"
    },
    {
      "name": "metrics",
      "type": "string",
      "description": "Metrics to return",
      "required": true,
      "example": "count_delivered,count_unique_clicked"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/metrics/deliverability/template?from=2026-03-01T00:00&metrics=count_delivered,count_unique_clicked",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "template_id": "welcome",
          "count_delivered": 300,
          "count_unique_clicked": 45
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}