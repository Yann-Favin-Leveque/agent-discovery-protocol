{
  "name": "templates_delete",
  "description": "Delete both draft and published versions of a template.",
  "endpoint": "/api/v1/templates/{id}",
  "method": "DELETE",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Template ID to delete",
      "required": true,
      "example": "my-template",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sparkpost.com/api/v1/templates/my-template",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
