  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Webhook ID to delete",
      "required": true,
      "example": "webhook-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sparkpost.com/api/v1/webhooks/webhook-123",
