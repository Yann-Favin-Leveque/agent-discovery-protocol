{
  "name": "sending_domains_delete",
  "description": "Remove a sending domain from the account.",
  "endpoint": "/api/v1/sending-domains/{domain}",
  "method": "DELETE",
  "resource_group": "sending_domains",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain to delete",
      "required": true,
      "example": "mail.example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sparkpost.com/api/v1/sending-domains/mail.example.com",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
