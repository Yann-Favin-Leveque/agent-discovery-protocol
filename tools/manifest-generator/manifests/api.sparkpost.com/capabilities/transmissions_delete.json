{
  "name": "transmissions_delete",
  "description": "Cancel a scheduled transmission by ID.",
  "endpoint": "/api/v1/transmissions/{id}",
  "method": "DELETE",
  "resource_group": "transmissions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Transmission ID to cancel",
      "required": true,
      "example": "11668787484950529",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sparkpost.com/api/v1/transmissions/11668787484950529",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
