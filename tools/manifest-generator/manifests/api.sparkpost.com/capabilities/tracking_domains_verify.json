{
  "name": "tracking_domains_verify",
  "description": "Verify a tracking domain CNAME configuration.",
  "endpoint": "/api/v1/tracking-domains/{domain}/verify",
  "method": "POST",
  "resource_group": "tracking_domains",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain to verify",
      "required": true,
      "example": "track.example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.sparkpost.com/api/v1/tracking-domains/track.example.com/verify",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": {
        "verified": true
      }
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}