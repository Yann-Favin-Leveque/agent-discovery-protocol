{
  "name": "suppression_list_delete",
  "description": "Remove a suppression entry for a specific recipient.",
  "endpoint": "/api/v1/suppression-list/{recipient}",
  "method": "DELETE",
  "resource_group": "suppression_list",
  "parameters": [
    {
      "name": "recipient",
      "type": "string",
      "description": "Email address to unsuppress",
      "required": true,
      "example": "user@example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sparkpost.com/api/v1/suppression-list/user@example.com",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}