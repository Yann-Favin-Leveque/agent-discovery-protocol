{
  "name": "subaccounts_get",
  "description": "Retrieve details of a specific subaccount.",
  "endpoint": "/api/v1/subaccounts/{id}",
  "method": "GET",
  "resource_group": "subaccounts",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Subaccount ID",
      "required": true,
      "example": 123
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/subaccounts/123",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": {
        "id": 123,
        "name": "Client A",
        "status": "active"
      }
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}