{
  "name": "events_documentation",
  "description": "Get descriptions of all available event fields across event types.",
  "endpoint": "/api/v1/events/message/documentation",
  "method": "GET",
  "resource_group": "events",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/events/message/documentation",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "type": {
            "sampleValue": "bounce",
            "description": "Type of event"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}