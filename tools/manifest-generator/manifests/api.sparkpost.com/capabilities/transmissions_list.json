{
  "name": "transmissions_list",
  "description": "List recent transmissions with optional campaign_id filter.",
  "endpoint": "/api/v1/transmissions",
  "method": "GET",
  "resource_group": "transmissions",
  "parameters": [
    {
      "name": "campaign_id",
      "type": "string",
      "description": "Filter by campaign ID",
      "required": false,
      "example": "summer-sale"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/transmissions",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "11668787484950529",
          "state": "submitted",
          "campaign_id": "summer-sale"
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}