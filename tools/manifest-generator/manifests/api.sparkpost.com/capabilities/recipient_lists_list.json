{
  "name": "recipient_lists_list",
  "description": "List all recipient lists in the account.",
  "endpoint": "/api/v1/recipient-lists",
  "method": "GET",
  "resource_group": "recipient_lists",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/recipient-lists",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "my-list",
          "name": "Newsletter Subscribers",
          "total_accepted_recipients": 1
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}