{
  "name": "transmissions_get",
  "description": "Retrieve details of a scheduled or recently sent transmission.",
  "endpoint": "/api/v1/transmissions/{id}",
  "method": "GET",
  "resource_group": "transmissions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Transmission ID",
      "required": true,
      "example": "11668787484950529",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/transmissions/11668787484950529",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": {
        "transmission": {
          "id": "11668787484950529",
          "state": "submitted",
          "campaign_id": "",
          "content": {
            "template_id": "my-template"
          }
        }
      }
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
