{
  "name": "recipient_lists_delete",
  "description": "Delete a recipient list by ID.",
  "endpoint": "/api/v1/recipient-lists/{id}",
  "method": "DELETE",
  "resource_group": "recipient_lists",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "List ID to delete",
      "required": true,
      "example": "my-list",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sparkpost.com/api/v1/recipient-lists/my-list",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
