{
  "name": "sending_domains_list",
  "description": "List all sending domains with optional filtering by verification status.",
  "endpoint": "/api/v1/sending-domains",
  "method": "GET",
  "resource_group": "sending_domains",
  "parameters": [
    {
      "name": "ownership_verified",
      "type": "boolean",
      "description": "Filter by ownership verified",
      "required": false,
      "example": true,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/sending-domains",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "domain": "mail.example.com",
          "status": {
            "ownership_verified": true
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
