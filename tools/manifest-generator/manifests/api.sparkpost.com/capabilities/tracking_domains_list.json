{
  "name": "tracking_domains_list",
  "description": "List all tracking domains.",
  "endpoint": "/api/v1/tracking-domains",
  "method": "GET",
  "resource_group": "tracking_domains",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/tracking-domains",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "domain": "track.example.com",
          "status": {
            "verified": true
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}