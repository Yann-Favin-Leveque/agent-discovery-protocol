{
  "name": "templates_list",
  "description": "List all templates in the account. Returns up to 50,000 templates.",
  "endpoint": "/api/v1/templates",
  "method": "GET",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "draft",
      "type": "boolean",
      "description": "Filter by draft status",
      "required": false,
      "example": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/templates",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "my-template",
          "name": "Welcome Email",
          "published": true
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}