{
  "name": "suppression_list_summary",
  "description": "Get a summary of suppression counts grouped by source.",
  "endpoint": "/api/v1/suppression-list/summary",
  "method": "GET",
  "resource_group": "suppression_list",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/suppression-list/summary",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": {
        "compliance": 0,
        "manually_added": 5,
        "spam_complaint": 2,
        "bounce_rule": 10
      }
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}