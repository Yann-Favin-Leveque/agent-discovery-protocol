{
  "name": "metrics_timeseries",
  "description": "Get time-series deliverability metrics over a date range.",
  "endpoint": "/api/v1/metrics/deliverability/timeseries",
  "method": "GET",
  "resource_group": "metrics",
  "parameters": [
    {
      "name": "from",
      "type": "string",
      "description": "Start datetime",
      "required": true,
      "example": "2026-03-01T00:00",
      "in": "query"
    },
    {
      "name": "to",
      "type": "string",
      "description": "End datetime",
      "required": false,
      "example": "2026-03-07T23:59",
      "in": "query"
    },
    {
      "name": "metrics",
      "type": "string",
      "description": "Metrics to return",
      "required": true,
      "example": "count_delivered,count_bounced",
      "in": "query"
    },
    {
      "name": "precision",
      "type": "string",
      "description": "Time precision",
      "required": false,
      "example": "day",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/metrics/deliverability/timeseries?from=2026-03-01T00:00&to=2026-03-07T23:59&metrics=count_delivered&precision=day",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "ts": "2026-03-01T00:00:00Z",
          "count_delivered": 200
        },
        {
          "ts": "2026-03-02T00:00:00Z",
          "count_delivered": 250
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
