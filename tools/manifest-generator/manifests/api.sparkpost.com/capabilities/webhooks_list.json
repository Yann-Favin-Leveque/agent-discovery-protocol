{
  "name": "webhooks_list",
  "description": "List all webhooks configured in the account.",
  "endpoint": "/api/v1/webhooks",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.sparkpost.com/api/v1/webhooks",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "webhook-123",
          "name": "My Webhook",
          "target": "https://example.com/webhook"
        }
      ]
    }
  },
  "auth_scopes": [
    "transmissions/read-write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}