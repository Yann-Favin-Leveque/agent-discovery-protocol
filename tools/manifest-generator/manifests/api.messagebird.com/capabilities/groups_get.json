{
  "name": "groups_get",
  "description": "Retrieve a contact group by its ID.",
  "resource_group": "groups",
  "endpoint": "/groups/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The group ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/groups/group-id-123",
    "headers": {
      "Authorization": "AccessKey live_abc123xyz"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "group-id-123",
      "name": "VIP Customers",
      "contacts": {
        "totalCount": 15,
        "href": "https://rest.messagebird.com/groups/group-id-123/contacts"
      }
    }
  }
}
