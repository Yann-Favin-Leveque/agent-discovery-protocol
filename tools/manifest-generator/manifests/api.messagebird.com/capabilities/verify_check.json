{
  "name": "verify_check",
  "description": "Verify a code submitted by a user against an active verification request.",
  "resource_group": "verify",
  "endpoint": "/verify/{id}",
  "method": "GET",
  "parameters": [
    {"name": "id", "type": "string", "required": true, "location": "path", "description": "The verification request ID."},
    {"name": "token", "type": "string", "required": true, "description": "The code submitted by the user."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/verify/verify-id-123?token=123456",
    "headers": {"Authorization": "AccessKey live_abc123xyz"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "verify-id-123", "status": "verified", "recipient": 31612345678}
  }
}
