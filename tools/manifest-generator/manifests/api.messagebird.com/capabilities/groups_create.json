{
  "name": "groups_create",
  "description": "Create a new contact group for organizing contacts.",
  "resource_group": "groups",
  "endpoint": "/groups",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Name for the group.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.messagebird.com/groups",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "AccessKey live_abc123xyz"
    },
    "body": {
      "name": "VIP Customers"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "group-id-123",
      "href": "https://rest.messagebird.com/groups/group-id-123",
      "name": "VIP Customers",
      "contacts": {
        "totalCount": 0,
        "href": "https://rest.messagebird.com/groups/group-id-123/contacts"
      },
      "createdDatetime": "2026-03-01T12:00:00+00:00",
      "updatedDatetime": "2026-03-01T12:00:00+00:00"
    }
  }
