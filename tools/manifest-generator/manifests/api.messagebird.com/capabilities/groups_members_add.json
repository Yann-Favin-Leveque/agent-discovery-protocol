{
  "name": "groups_members_add",
  "description": "Add contacts to a group by their contact IDs.",
  "resource_group": "groups",
  "endpoint": "/groups/{groupId}/contacts",
  "method": "PUT",
  "parameters": [
    {
      "name": "groupId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The group ID.",
      "in": "path"
    },
    {
      "name": "ids",
      "type": "array",
      "required": true,
      "description": "Array of contact IDs to add to the group.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://rest.messagebird.com/groups/group-id-123/contacts",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "AccessKey live_abc123xyz"
    },
    "body": {
      "ids": [
        "contact-id-123",
        "contact-id-456"
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
