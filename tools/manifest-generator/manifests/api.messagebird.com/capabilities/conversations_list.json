{
  "name": "conversations_list",
  "description": "List conversations with optional filtering by status and contact.",
  "resource_group": "conversations",
  "endpoint": "/conversations",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Page size. Default 10, max 20.",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Page offset.",
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by status: 'active' or 'archived'.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://conversations.messagebird.com/v1/conversations?status=active&limit=10",
    "headers": {
      "Authorization": "AccessKey live_abc123xyz"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "offset": 0,
      "limit": 10,
      "count": 3,
      "totalCount": 25,
      "items": [
        {
          "id": "conv-id-789",
          "contactId": "contact-id-123",
          "status": "active",
          "lastUsedChannelId": "channel-id-abc",
          "createdDatetime": "2026-03-01T12:00:00Z"
        }
      ]
    }
  }
}
