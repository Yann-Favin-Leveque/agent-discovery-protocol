{
  "name": "voice_messages_list",
  "description": "List all voice messages sent from your account with pagination support.",
  "resource_group": "voice_messages",
  "endpoint": "/voicemessages",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Page size. Default 20, max 200.",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Skip results for pagination.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/voicemessages?limit=10",
    "headers": {
      "Authorization": "AccessKey live_abc123xyz"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "offset": 0,
      "limit": 10,
      "count": 3,
      "totalCount": 15,
      "items": [
        {
          "id": "a1b2c3d4e5f6",
          "body": "Your code is...",
          "createdDatetime": "2026-03-01T12:00:00+00:00"
        }
      ]
    }
  }
}
