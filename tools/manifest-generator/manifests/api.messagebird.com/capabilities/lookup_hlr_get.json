{
  "name": "lookup_hlr_get",
  "description": "Retrieve the result of a previously created HLR lookup including network and roaming information.",
  "resource_group": "lookup",
  "endpoint": "/lookup/{phoneNumber}/hlr",
  "method": "GET",
  "parameters": [
    {"name": "phoneNumber", "type": "string", "required": true, "location": "path", "description": "Phone number in international format."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/lookup/31612345678/hlr",
    "headers": {"Authorization": "AccessKey live_abc123xyz"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "hlr-id-456", "network": 20408, "reference": "hlr-check-001", "status": "active", "createdDatetime": "2026-03-01T12:00:00+00:00", "statusDatetime": "2026-03-01T12:00:01+00:00"}
  }
}
