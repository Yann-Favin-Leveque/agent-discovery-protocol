{
  "name": "verify_get",
  "description": "Retrieve the status of a verification request by its ID.",
  "resource_group": "verify",
  "endpoint": "/verify/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The verification request ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/verify/verify-id-123",
    "headers": {
      "Authorization": "AccessKey live_abc123xyz"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "verify-id-123",
      "status": "sent",
      "recipient": 31612345678,
      "createdDatetime": "2026-03-01T12:00:00+00:00",
      "validUntilDatetime": "2026-03-01T12:02:00+00:00"
    }
  }
}
