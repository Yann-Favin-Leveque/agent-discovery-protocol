{
  "name": "conversations_messages_list",
  "description": "List all messages within a specific conversation in chronological order.",
  "resource_group": "conversations",
  "endpoint": "/conversations/{id}/messages",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The conversation ID.",
      "in": "path"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Page size. Default 10, max 20.",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Page offset.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://conversations.messagebird.com/v1/conversations/conv-id-789/messages?limit=10",
    "headers": {
      "Authorization": "AccessKey live_abc123xyz"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "offset": 0,
      "limit": 10,
      "count": 3,
      "totalCount": 5,
      "items": [
        {
          "id": "msg-id-001",
          "type": "text",
          "content": {
            "text": "Hello!"
          },
          "direction": "received",
          "status": "received",
          "createdDatetime": "2026-03-01T12:00:00Z"
        },
        {
          "id": "msg-id-002",
          "type": "text",
          "content": {
            "text": "Hi there!"
          },
          "direction": "sent",
          "status": "delivered",
          "createdDatetime": "2026-03-01T12:01:00Z"
        }
      ]
    }
  }
}
