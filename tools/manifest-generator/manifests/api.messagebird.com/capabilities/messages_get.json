{
  "name": "messages_get",
  "description": "Retrieve details and delivery status of a previously sent SMS message by its ID.",
  "resource_group": "messages",
  "endpoint": "/messages/{id}",
  "method": "GET",
  "parameters": [
    {"name": "id", "type": "string", "required": true, "location": "path", "description": "The unique message ID."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/messages/e8077d803532c0b5937c639b60216938",
    "headers": {"Authorization": "AccessKey live_abc123xyz"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "e8077d803532c0b5937c639b60216938", "direction": "mt", "type": "sms", "originator": "MyApp", "body": "Your verification code is 123456.", "recipients": {"totalCount": 1, "totalDeliveredCount": 1, "items": [{"recipient": 31612345678, "status": "delivered"}]}}
  }
}
