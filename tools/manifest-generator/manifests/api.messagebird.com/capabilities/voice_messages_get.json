{
  "name": "voice_messages_get",
  "description": "Retrieve details of a previously sent voice message by its ID.",
  "resource_group": "voice_messages",
  "endpoint": "/voicemessages/{id}",
  "method": "GET",
  "parameters": [
    {"name": "id", "type": "string", "required": true, "location": "path", "description": "The unique voice message ID."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/voicemessages/a1b2c3d4e5f6",
    "headers": {"Authorization": "AccessKey live_abc123xyz"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "a1b2c3d4e5f6", "body": "Your one-time code is 5 4 3 2 1 0.", "recipients": {"totalCount": 1, "totalDeliveredCount": 1, "items": [{"recipient": 31612345678, "status": "answered"}]}}
  }
}
