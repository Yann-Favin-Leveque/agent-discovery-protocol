{
  "name": "contacts_create",
  "description": "Create a new contact with phone number, name, and custom fields.",
  "resource_group": "contacts",
  "endpoint": "/contacts",
  "method": "POST",
  "parameters": [
    {
      "name": "msisdn",
      "type": "integer",
      "required": true,
      "description": "Phone number in international format.",
      "in": "body"
    },
    {
      "name": "firstName",
      "type": "string",
      "required": false,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "lastName",
      "type": "string",
      "required": false,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "custom1",
      "type": "string",
      "required": false,
      "description": "Custom field 1.",
      "in": "body"
    },
    {
      "name": "custom2",
      "type": "string",
      "required": false,
      "description": "Custom field 2.",
      "in": "body"
    },
    {
      "name": "custom3",
      "type": "string",
      "required": false,
      "description": "Custom field 3.",
      "in": "body"
    },
    {
      "name": "custom4",
      "type": "string",
      "required": false,
      "description": "Custom field 4.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.messagebird.com/contacts",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "AccessKey live_abc123xyz"
    },
    "body": {
      "msisdn": 31612345678,
      "firstName": "Jane",
      "lastName": "Doe",
      "custom1": "VIP"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "contact-id-123",
      "href": "https://rest.messagebird.com/contacts/contact-id-123",
      "msisdn": 31612345678,
      "firstName": "Jane",
      "lastName": "Doe",
      "custom1": "VIP",
      "createdDatetime": "2026-03-01T12:00:00+00:00",
      "updatedDatetime": "2026-03-01T12:00:00+00:00"
    }
  }
}
