{
  "name": "conversations_get",
  "description": "Retrieve a conversation by ID with its metadata and message summary.",
  "resource_group": "conversations",
  "endpoint": "/conversations/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The conversation ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://conversations.messagebird.com/v1/conversations/conv-id-789",
    "headers": {
      "Authorization": "AccessKey live_abc123xyz"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "conv-id-789",
      "contactId": "contact-id-123",
      "status": "active",
      "channels": [
        {
          "id": "channel-id-abc",
          "name": "SMS Channel"
        }
      ],
      "messages": {
        "totalCount": 5,
        "href": "https://conversations.messagebird.com/v1/conversations/conv-id-789/messages"
      }
    }
  }
}
