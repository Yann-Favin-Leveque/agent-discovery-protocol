{
  "name": "conversations_update",
  "description": "Update a conversation's status (active or archived).",
  "resource_group": "conversations",
  "endpoint": "/conversations/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The conversation ID.",
      "in": "path"
    },
    {
      "name": "status",
      "type": "string",
      "required": true,
      "description": "New status: 'active' or 'archived'.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://conversations.messagebird.com/v1/conversations/conv-id-789",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "AccessKey live_abc123xyz"
    },
    "body": {
      "status": "archived"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "conv-id-789",
      "status": "archived"
    }
  }
}
