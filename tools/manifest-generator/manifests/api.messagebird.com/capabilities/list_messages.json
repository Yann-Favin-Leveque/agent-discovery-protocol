{
  "name": "list_messages",
  "description": "List messages sent and received on your MessageBird account. Returns a paginated list of message objects ordered by creation date (newest first). Each message includes delivery status summaries and recipient details. Use this to audit message history, monitor delivery rates, or find messages by reference.",
  "endpoint": "/messages",
  "method": "GET",
  "parameters": [
    {
      "name": "originator",
      "type": "string",
      "required": false,
      "description": "Filter messages by sender ID or originator name."
    },
    {
      "name": "direction",
      "type": "string",
      "required": false,
      "description": "Filter by message direction: 'mt' (mobile-terminated, sent) or 'mo' (mobile-originated, received)."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Maximum number of messages to return per page. Default is 20, maximum is 250."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Number of messages to skip for pagination. Default is 0."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.messagebird.com/messages?limit=10&offset=0",
    "headers": {
      "Authorization": "AccessKey live_gshuPaZoeEG6ovIvTsgrmmGXc"
    }
  },
