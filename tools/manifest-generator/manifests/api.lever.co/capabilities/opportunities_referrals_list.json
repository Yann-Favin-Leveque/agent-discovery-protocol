{
  "name": "opportunities_referrals_list",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/referrals",
  "method": "GET",
  "description": "List all referrals for an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/referrals",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "ref-1",
          "referrer": {
            "id": "user-2",
            "name": "Emily Park"
          }
        }
      ]
    }
  }
}