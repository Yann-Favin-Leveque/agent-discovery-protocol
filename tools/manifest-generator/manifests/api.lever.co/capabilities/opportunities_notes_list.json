{
  "name": "opportunities_notes_list",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/notes",
  "method": "GET",
  "description": "List all notes on an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/notes",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "note-1",
          "text": "Great interview performance",
          "createdAt": 1700000000000,
          "user": "user-1"
        }
      ]
    }
  }
}
