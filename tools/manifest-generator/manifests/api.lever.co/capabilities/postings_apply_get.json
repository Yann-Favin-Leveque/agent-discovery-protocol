{
  "name": "postings_apply_get",
  "resource_group": "Postings",
  "endpoint": "/v1/postings/{posting}/apply",
  "method": "GET",
  "description": "Retrieve application form fields for a posting.",
  "parameters": [
    {
      "name": "posting",
      "type": "string",
      "required": true,
      "description": "Posting UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/postings/posting-1/apply",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "fields": [
          {
            "text": "Resume",
            "type": "file",
            "required": true
          },
          {
            "text": "Cover Letter",
            "type": "textarea",
            "required": false
          }
        ]
      }
    }
  }
}