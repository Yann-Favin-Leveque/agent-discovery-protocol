{
  "name": "users_create",
  "resource_group": "Users",
  "endpoint": "/v1/users",
  "method": "POST",
  "description": "Create a new user.",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Full name."
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email."
    },
    {
      "name": "perform_as",
      "type": "string",
      "required": false,
      "description": "User UUID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lever.co/v1/users",
    "headers": {
      "Authorization": "Basic base64(apikey:)",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Alex Kim",
      "email": "alex@company.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "user-new",
        "name": "Alex Kim"
      }
    }
  }
}