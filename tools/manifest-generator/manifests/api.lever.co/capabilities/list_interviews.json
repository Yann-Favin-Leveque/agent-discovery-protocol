{
  "name": "list_interviews",
  "description": "Retrieve all scheduled interviews for a given opportunity. Returns interview details including panelist names, scheduled time, duration, and feedback submission status.",
  "endpoint": "/v1/opportunities/{opportunity_id}/interviews",
  "method": "GET",
  "parameters": [
    { "name": "opportunity_id", "type": "string", "description": "The ID of the opportunity whose interviews to list.", "required": true, "example": "opp-12345" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/opp-12345/interviews",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "interview-001",
          "subject": "Technical Interview - Jane Smith",
          "date": 1706832000000,
          "duration": 60,
          "timezone": "America/Los_Angeles",
          "interviewers": [
            { "id": "user-002", "name": "John Doe", "email": "john@company.com" }
          ],
          "feedbackSubmitted": false
        }
      ],
      "hasNext": false
    }
  }
}
