{
  "name": "opportunities_get",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}",
  "method": "GET",
  "description": "Retrieve detailed information about a specific opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "abc-123",
        "name": "John Doe",
        "headline": "Software Engineer at Acme",
        "stage": {
          "id": "stage-1",
          "text": "Phone Screen"
        },
        "contact": "contact-1",
        "emails": [
          "john@example.com"
        ]
      }
    }
  }
}