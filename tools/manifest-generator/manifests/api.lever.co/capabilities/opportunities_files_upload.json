{
  "name": "opportunities_files_upload",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/files",
  "method": "POST",
  "description": "Upload a file to an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID."
    },
    {
      "name": "file",
      "type": "file",
      "required": true,
      "description": "File to upload (multipart/form-data)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lever.co/v1/opportunities/abc-123/files",
    "headers": {
      "Authorization": "Basic base64(apikey:)",
      "Content-Type": "multipart/form-data"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "file-2",
        "name": "cover_letter.pdf"
      }
    }
  }
}