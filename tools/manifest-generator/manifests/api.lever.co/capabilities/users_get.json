{
  "name": "users_get",
  "resource_group": "Users",
  "endpoint": "/v1/users/{user}",
  "method": "GET",
  "description": "Retrieve a specific user.",
  "parameters": [
    {
      "name": "user",
      "type": "string",
      "required": true,
      "description": "User UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/users/user-1",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "user-1",
        "name": "Sarah Connor",
        "email": "sarah@company.com"
      }
    }
  }
}
