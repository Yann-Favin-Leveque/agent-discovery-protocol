{
  "name": "opportunities_notes_get",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/notes/{note}",
  "method": "GET",
  "description": "Retrieve a specific note.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID.",
      "in": "path"
    },
    {
      "name": "note",
      "type": "string",
      "required": true,
      "description": "Note UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/notes/note-1",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "note-1",
        "text": "Great interview performance"
      }
    }
  }
}
