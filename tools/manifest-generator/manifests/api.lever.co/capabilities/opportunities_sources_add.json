{
  "name": "opportunities_sources_add",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/addSources",
  "method": "POST",
  "description": "Add sources to an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID.",
      "in": "path"
    },
    {
      "name": "sources",
      "type": "array",
      "required": true,
      "description": "Source strings.",
      "in": "body"
    },
    {
      "name": "perform_as",
      "type": "string",
      "required": false,
      "description": "User UUID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lever.co/v1/opportunities/abc-123/addSources",
    "headers": {
      "Authorization": "Basic base64(apikey:)",
      "Content-Type": "application/json"
    },
    "body": {
      "sources": [
        "LinkedIn"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "sources": [
          "LinkedIn"
        ]
      }
    }
  }
}
