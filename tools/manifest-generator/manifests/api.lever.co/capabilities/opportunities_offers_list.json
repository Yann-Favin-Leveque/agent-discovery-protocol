{
  "name": "opportunities_offers_list",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/offers",
  "method": "GET",
  "description": "List all offers for an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/offers",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "offer-1",
          "status": "signed",
          "createdAt": 1700000000000
        }
      ]
    }
  }
}