{
  "name": "contacts_get",
  "resource_group": "Contacts",
  "endpoint": "/v1/contacts/{contact}",
  "method": "GET",
  "description": "Retrieve a specific contact's details.",
  "parameters": [
    {
      "name": "contact",
      "type": "string",
      "required": true,
      "description": "Contact UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/contacts/contact-1",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "contact-1",
        "name": "John Doe",
        "emails": [
          "john@example.com"
        ],
        "phones": [
          "555-1234"
        ]
      }
    }
  }
}