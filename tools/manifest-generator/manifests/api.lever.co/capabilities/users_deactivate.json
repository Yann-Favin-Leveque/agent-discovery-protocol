{
  "name": "users_deactivate",
  "resource_group": "Users",
  "endpoint": "/v1/users/{user}/deactivate",
  "method": "POST",
  "description": "Deactivate a user.",
  "parameters": [
    {
      "name": "user",
      "type": "string",
      "required": true,
      "description": "User UUID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lever.co/v1/users/user-1/deactivate",
    "headers": {
      "Authorization": "Basic base64(apikey:)",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "user-1",
        "deactivatedAt": 1700000000000
      }
    }
  }
}