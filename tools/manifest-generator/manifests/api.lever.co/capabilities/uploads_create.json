{
  "name": "uploads_create",
  "resource_group": "Uploads",
  "endpoint": "/v1/uploads",
  "method": "POST",
  "description": "Upload a file temporarily for use with the apply endpoint.",
  "parameters": [
    {
      "name": "file",
      "type": "file",
      "required": true,
      "description": "File to upload (multipart)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lever.co/v1/uploads",
    "headers": {
      "Authorization": "Basic base64(apikey:)",
      "Content-Type": "multipart/form-data"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "uri": "lever-file://abc123",
        "name": "resume.pdf"
      }
    }
  }
}