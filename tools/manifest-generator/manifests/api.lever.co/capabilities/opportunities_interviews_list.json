{
  "name": "opportunities_interviews_list",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/interviews",
  "method": "GET",
  "description": "List all interviews for an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/interviews",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "int-1",
          "subject": "Technical Interview",
          "date": 1700000000000,
          "interviewers": [
            {
              "id": "user-1",
              "name": "Sarah Connor"
            }
          ]
        }
      ]
    }
  }
}
