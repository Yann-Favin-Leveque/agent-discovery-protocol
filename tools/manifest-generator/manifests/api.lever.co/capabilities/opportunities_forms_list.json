{
  "name": "opportunities_forms_list",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/forms",
  "method": "GET",
  "description": "List all profile forms for an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/forms",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "form-1",
          "type": "personal",
          "fields": []
        }
      ]
    }
  }
}