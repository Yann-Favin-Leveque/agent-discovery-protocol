{
  "name": "opportunities_files_list",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/files",
  "method": "GET",
  "description": "List all files attached to an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/files",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "file-1",
          "name": "portfolio.pdf"
        }
      ]
    }
  }
}