{
  "name": "create_posting",
  "description": "Create a new job posting in Lever. Define the role title, description, team, location, and commitment type. Once published, candidates can apply through your careers page.",
  "endpoint": "/v1/postings",
  "method": "POST",
  "parameters": [
    { "name": "text", "type": "string", "description": "The job title.", "required": true, "example": "Senior Software Engineer" },
    { "name": "state", "type": "string", "description": "Posting state: 'published', 'internal', 'closed', or 'draft'.", "required": false, "example": "published" },
    { "name": "categories", "type": "object", "description": "Object with team, location, commitment, and department.", "required": false, "example": { "team": "Engineering", "location": "San Francisco", "commitment": "Full-time" } },
    { "name": "content", "type": "object", "description": "Object containing description (HTML), lists of requirements and responsibilities.", "required": false, "example": { "description": "We are looking for a senior engineer to lead our platform team." } },
    { "name": "tags", "type": "array", "description": "Tags to categorize this posting.", "required": false, "example": ["engineering", "senior"] }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lever.co/v1/postings",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "text": "Senior Software Engineer",
      "state": "published",
      "categories": {
        "team": "Engineering",
        "location": "San Francisco",
        "commitment": "Full-time"
      },
      "content": {
        "description": "We are looking for a senior engineer to lead our platform team."
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "posting-xyz789",
        "text": "Senior Software Engineer",
        "state": "published",
        "categories": {
          "team": "Engineering",
          "location": "San Francisco",
          "commitment": "Full-time"
        },
        "createdAt": 1706745600000
      }
    }
  }
}
