{
  "name": "users_list",
  "resource_group": "Users",
  "endpoint": "/v1/users",
  "method": "GET",
  "description": "List all users in the Lever account. Note: this endpoint is not officially documented but available via API.",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    },
    {
      "name": "offset",
      "type": "string",
      "required": false,
      "description": "Cursor."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/users",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "user-1",
          "name": "Sarah Connor",
          "email": "sarah@company.com"
        }
      ]
    }
  }
}