{
  "name": "postings_get",
  "resource_group": "Postings",
  "endpoint": "/v1/postings/{posting}",
  "method": "GET",
  "description": "Retrieve a specific posting.",
  "parameters": [
    {
      "name": "posting",
      "type": "string",
      "required": true,
      "description": "Posting UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/postings/posting-1",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "posting-1",
        "text": "Software Engineer",
        "state": "published",
        "content": {
          "description": "We are looking for..."
        }
      }
    }
  }
}