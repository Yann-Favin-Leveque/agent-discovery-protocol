{
  "name": "stages_get",
  "resource_group": "Stages",
  "endpoint": "/v1/stages/{stage}",
  "method": "GET",
  "description": "Retrieve a specific pipeline stage.",
  "parameters": [
    {
      "name": "stage",
      "type": "string",
      "required": true,
      "description": "Stage UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/stages/stage-1",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "stage-1",
        "text": "New Lead"
      }
    }
  }
}