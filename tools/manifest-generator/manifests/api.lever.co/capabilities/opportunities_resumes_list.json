{
  "name": "opportunities_resumes_list",
  "resource_group": "Opportunities",
  "endpoint": "/v1/opportunities/{opportunity}/resumes",
  "method": "GET",
  "description": "List all resumes for an opportunity.",
  "parameters": [
    {
      "name": "opportunity",
      "type": "string",
      "required": true,
      "description": "Opportunity UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lever.co/v1/opportunities/abc-123/resumes",
    "headers": {
      "Authorization": "Basic base64(apikey:)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "resume-1",
          "file": {
            "name": "resume.pdf",
            "ext": "pdf"
          }
        }
      ]
    }
  }
}