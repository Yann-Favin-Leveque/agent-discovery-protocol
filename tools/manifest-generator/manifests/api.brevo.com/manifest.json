{
  "spec_version": "1.0",
  "name": "Brevo (Sendinblue)",
  "description": "Brevo is an all-in-one marketing platform providing REST APIs to manage contacts, send transactional and marketing emails, SMS campaigns, manage webhooks, senders, domains, lists, conversations, and ecommerce data.",
  "base_url": "https://api.brevo.com/v3",
  "auth": {
    "type": "api_key",
    "header": "api-key",
    "setup_url": "https://app.brevo.com/settings/keys/api"
  },
  "capabilities": [
    {
      "name": "contacts_create",
      "resource_group": "contacts",
      "description": "Create a new contact with email, attributes, and list memberships.",
      "detail_url": "/capabilities/contacts_create"
    },
    {
      "name": "contacts_get",
      "resource_group": "contacts",
      "description": "Get contact details by email or ID.",
      "detail_url": "/capabilities/contacts_get"
    },
    {
      "name": "contacts_update",
      "resource_group": "contacts",
      "description": "Update a contact's attributes, lists, or blacklist status.",
      "detail_url": "/capabilities/contacts_update"
    },
    {
      "name": "contacts_delete",
      "resource_group": "contacts",
      "description": "Delete a contact by email or ID.",
      "detail_url": "/capabilities/contacts_delete"
    },
    {
      "name": "contacts_list",
      "resource_group": "contacts",
      "description": "Retrieve a paginated list of all contacts.",
      "detail_url": "/capabilities/contacts_list"
    },
    {
      "name": "contacts_import",
      "resource_group": "contacts",
      "description": "Import contacts in bulk via CSV or JSON.",
      "detail_url": "/capabilities/contacts_import"
    },
    {
      "name": "lists_list",
      "resource_group": "lists",
      "description": "Retrieve all contact lists.",
      "detail_url": "/capabilities/lists_list"
    },
    {
      "name": "lists_create",
      "resource_group": "lists",
      "description": "Create a new contact list.",
      "detail_url": "/capabilities/lists_create"
    },
    {
      "name": "lists_get",
      "resource_group": "lists",
      "description": "Get a specific list by ID.",
      "detail_url": "/capabilities/lists_get"
    },
    {
      "name": "lists_update",
      "resource_group": "lists",
      "description": "Update a list name or folder.",
      "detail_url": "/capabilities/lists_update"
    },
    {
      "name": "lists_delete",
      "resource_group": "lists",
      "description": "Delete a list by ID.",
      "detail_url": "/capabilities/lists_delete"
    },
    {
      "name": "lists_add_contacts",
      "resource_group": "lists",
      "description": "Add contacts to a list.",
      "detail_url": "/capabilities/lists_add_contacts"
    },
    {
      "name": "lists_remove_contacts",
      "resource_group": "lists",
      "description": "Remove contacts from a list.",
      "detail_url": "/capabilities/lists_remove_contacts"
    },
    {
      "name": "email_campaigns_list",
      "resource_group": "email_campaigns",
      "description": "Retrieve all email campaigns.",
      "detail_url": "/capabilities/email_campaigns_list"
    },
    {
      "name": "email_campaigns_create",
      "resource_group": "email_campaigns",
      "description": "Create a new email marketing campaign.",
      "detail_url": "/capabilities/email_campaigns_create"
    },
    {
      "name": "email_campaigns_get",
      "resource_group": "email_campaigns",
      "description": "Get a specific email campaign by ID.",
      "detail_url": "/capabilities/email_campaigns_get"
    },
    {
      "name": "email_campaigns_update",
      "resource_group": "email_campaigns",
      "description": "Update an email campaign.",
      "detail_url": "/capabilities/email_campaigns_update"
    },
    {
      "name": "email_campaigns_delete",
      "resource_group": "email_campaigns",
      "description": "Delete an email campaign.",
      "detail_url": "/capabilities/email_campaigns_delete"
    },
    {
      "name": "email_campaigns_send",
      "resource_group": "email_campaigns",
      "description": "Send an email campaign immediately.",
      "detail_url": "/capabilities/email_campaigns_send"
    },
    {
      "name": "email_campaigns_send_test",
      "resource_group": "email_campaigns",
      "description": "Send a test email for a campaign.",
      "detail_url": "/capabilities/email_campaigns_send_test"
    },
    {
      "name": "transactional_emails_send",
      "resource_group": "transactional_emails",
      "description": "Send a transactional email.",
      "detail_url": "/capabilities/transactional_emails_send"
    },
    {
      "name": "transactional_emails_list",
      "resource_group": "transactional_emails",
      "description": "Retrieve transactional email events and logs.",
      "detail_url": "/capabilities/transactional_emails_list"
    },
    {
      "name": "sms_send",
      "resource_group": "sms",
      "description": "Send a transactional SMS.",
      "detail_url": "/capabilities/sms_send"
    },
    {
      "name": "sms_campaigns_list",
      "resource_group": "sms",
      "description": "Retrieve all SMS campaigns.",
      "detail_url": "/capabilities/sms_campaigns_list"
    },
    {
      "name": "sms_campaigns_create",
      "resource_group": "sms",
      "description": "Create a new SMS campaign.",
      "detail_url": "/capabilities/sms_campaigns_create"
    },
    {
      "name": "senders_list",
      "resource_group": "senders",
      "description": "List all email senders.",
      "detail_url": "/capabilities/senders_list"
    },
    {
      "name": "senders_create",
      "resource_group": "senders",
      "description": "Create a new email sender.",
      "detail_url": "/capabilities/senders_create"
    },
    {
      "name": "webhooks_list",
      "resource_group": "webhooks",
      "description": "List all configured webhooks.",
      "detail_url": "/capabilities/webhooks_list"
    },
    {
      "name": "webhooks_create",
      "resource_group": "webhooks",
      "description": "Create a new webhook.",
      "detail_url": "/capabilities/webhooks_create"
    },
    {
      "name": "webhooks_update",
      "resource_group": "webhooks",
      "description": "Update a webhook.",
      "detail_url": "/capabilities/webhooks_update"
    },
    {
      "name": "webhooks_delete",
      "resource_group": "webhooks",
      "description": "Delete a webhook.",
      "detail_url": "/capabilities/webhooks_delete"
    },
    {
      "name": "account_get",
      "resource_group": "account",
      "description": "Retrieve account details including plan and credits.",
      "detail_url": "/capabilities/account_get"
    }
  ]
}