{
  "name": "webhooks_create",
  "description": "Create a new webhook.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks",
  "method": "POST",
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "description": "Webhook URL.",
      "required": true,
      "in": "body"
    },
    {
      "name": "events",
      "type": "array",
      "description": "Events: delivered, opened, clicked, etc.",
      "required": true,
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "description": "transactional or marketing.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.brevo.com/v3/webhooks",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://example.com/webhook",
      "events": [
        "delivered",
        "opened"
      ]
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2
    }
  }
}
