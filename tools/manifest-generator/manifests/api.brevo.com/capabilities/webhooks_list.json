{
  "name": "webhooks_list",
  "description": "List all webhooks.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks",
  "method": "GET",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "transactional or marketing.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/webhooks",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "webhooks": [
        {
          "id": 1,
          "url": "https://example.com/webhook",
          "events": [
            "delivered"
          ]
        }
      ]
    }
  }
}