{
  "name": "contacts_delete",
  "description": "Delete a contact.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{identifier}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "identifier",
      "type": "string",
      "description": "Contact email or ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.brevo.com/v3/contacts/john@example.com",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
