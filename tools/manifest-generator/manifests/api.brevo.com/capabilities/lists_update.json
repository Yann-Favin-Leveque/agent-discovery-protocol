{
  "name": "lists_update",
  "description": "Update a list.",
  "resource_group": "lists",
  "endpoint": "/contacts/lists/{listId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "listId",
      "type": "integer",
      "description": "List ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    },
    {
      "name": "folderId",
      "type": "integer",
      "description": "Updated folder.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.brevo.com/v3/contacts/lists/1",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Newsletter"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}