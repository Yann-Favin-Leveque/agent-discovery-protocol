{
  "name": "transactional_emails_list",
  "description": "Retrieve transactional email events.",
  "resource_group": "transactional_emails",
  "endpoint": "/smtp/statistics/events",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "example": 50
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Offset.",
      "required": false
    },
    {
      "name": "startDate",
      "type": "string",
      "description": "Start date YYYY-MM-DD.",
      "required": false
    },
    {
      "name": "endDate",
      "type": "string",
      "description": "End date YYYY-MM-DD.",
      "required": false
    },
    {
      "name": "email",
      "type": "string",
      "description": "Filter by recipient email.",
      "required": false
    },
    {
      "name": "event",
      "type": "string",
      "description": "Filter by event type.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/smtp/statistics/events?limit=50",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "events": [
        {
          "email": "john@example.com",
          "event": "delivered",
          "date": "2024-06-01T10:00:00Z"
        }
      ]
    }
  }
}