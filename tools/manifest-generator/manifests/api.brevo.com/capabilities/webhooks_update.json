{
  "name": "webhooks_update",
  "description": "Update a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks/{webhookId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "webhookId",
      "type": "integer",
      "description": "Webhook ID.",
      "required": true
    },
    {
      "name": "url",
      "type": "string",
      "description": "Updated URL.",
      "required": false
    },
    {
      "name": "events",
      "type": "array",
      "description": "Updated events.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.brevo.com/v3/webhooks/1",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "events": [
        "delivered",
        "opened",
        "clicked"
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}