{
  "name": "contacts_list",
  "description": "Retrieve paginated contacts.",
  "resource_group": "contacts",
  "endpoint": "/contacts",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results (max 1000).",
      "required": false,
      "example": 50
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "example": 0
    },
    {
      "name": "modifiedSince",
      "type": "string",
      "description": "Filter by last modified date.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/contacts?limit=50&offset=0",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "contacts": [
        {
          "id": 12345,
          "email": "john@example.com"
        }
      ],
      "count": 500
    }
  }
}