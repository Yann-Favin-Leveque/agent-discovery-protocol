{
  "name": "lists_create",
  "description": "Create a new contact list.",
  "resource_group": "lists",
  "endpoint": "/contacts/lists",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "List name.",
      "required": true,
      "example": "Newsletter",
      "in": "body"
    },
    {
      "name": "folderId",
      "type": "integer",
      "description": "Folder ID.",
      "required": true,
      "example": 1,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.brevo.com/v3/contacts/lists",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Newsletter",
      "folderId": 1
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2
    }
  }
}
