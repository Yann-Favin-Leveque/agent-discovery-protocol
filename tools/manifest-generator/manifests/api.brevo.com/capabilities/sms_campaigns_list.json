{
  "name": "sms_campaigns_list",
  "description": "Retrieve all SMS campaigns.",
  "resource_group": "sms",
  "endpoint": "/smsCampaigns",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Offset.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/smsCampaigns",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "campaigns": [
        {
          "id": 1,
          "name": "SMS Promo",
          "status": "sent"
        }
      ],
      "count": 5
    }
  }
}