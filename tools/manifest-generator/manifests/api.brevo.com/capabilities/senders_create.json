{
  "name": "senders_create",
  "description": "Create a new email sender.",
  "resource_group": "senders",
  "endpoint": "/senders",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Sender display name.",
      "required": true
    },
    {
      "name": "email",
      "type": "string",
      "description": "Sender email.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.brevo.com/v3/senders",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "My Store",
      "email": "store@example.com"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2
    }
  }
}