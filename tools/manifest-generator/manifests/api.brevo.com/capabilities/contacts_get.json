{
  "name": "contacts_get",
  "description": "Get contact details by email or ID.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{identifier}",
  "method": "GET",
  "parameters": [
    {
      "name": "identifier",
      "type": "string",
      "description": "Contact email or ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/contacts/john@example.com",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345,
      "email": "john@example.com",
      "attributes": {
        "FNAME": "John"
      },
      "listIds": [
        1
      ]
    }
  }
}