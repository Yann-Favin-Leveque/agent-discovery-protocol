{
  "name": "lists_get",
  "description": "Get a list by ID.",
  "resource_group": "lists",
  "endpoint": "/contacts/lists/{listId}",
  "method": "GET",
  "parameters": [
    {
      "name": "listId",
      "type": "integer",
      "description": "List ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/contacts/lists/1",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "name": "Newsletter",
      "totalSubscribers": 500
    }
  }
}
