      "type": "integer",
      "description": "Campaign ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Updated subject.",
      "required": false
    },
    {
      "name": "htmlContent",
      "type": "string",
      "description": "Updated content.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.brevo.com/v3/emailCampaigns/1",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "subject": "Updated Sale!"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
