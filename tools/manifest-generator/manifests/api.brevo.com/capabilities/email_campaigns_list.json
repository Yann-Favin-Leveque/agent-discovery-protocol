{
  "name": "email_campaigns_list",
  "description": "Retrieve all email campaigns.",
  "resource_group": "email_campaigns",
  "endpoint": "/emailCampaigns",
  "method": "GET",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "classic or trigger.",
      "required": false
    },
    {
      "name": "status",
      "type": "string",
      "description": "draft, sent, archive, etc.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Offset.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/emailCampaigns?type=classic&limit=50",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "campaigns": [
        {
          "id": 1,
          "name": "Summer Sale",
          "status": "sent"
        }
      ],
      "count": 10
    }
  }
}