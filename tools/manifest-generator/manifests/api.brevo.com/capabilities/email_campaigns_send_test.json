{
  "name": "email_campaigns_send_test",
  "description": "Send a test email for a campaign.",
  "resource_group": "email_campaigns",
  "endpoint": "/emailCampaigns/{campaignId}/sendTest",
  "method": "POST",
  "parameters": [
    {
      "name": "campaignId",
      "type": "integer",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "emailTo",
      "type": "array",
      "description": "Test recipient emails.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.brevo.com/v3/emailCampaigns/1/sendTest",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "emailTo": [
        "test@example.com"
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
