{
  "name": "lists_list",
  "description": "Retrieve all contact lists.",
  "resource_group": "lists",
  "endpoint": "/contacts/lists",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "example": 50
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Offset.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/contacts/lists",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "lists": [
        {
          "id": 1,
          "name": "Newsletter",
          "totalSubscribers": 500
        }
      ],
      "count": 3
    }
  }
}