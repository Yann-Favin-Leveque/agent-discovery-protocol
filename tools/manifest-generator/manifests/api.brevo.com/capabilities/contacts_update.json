{
  "name": "contacts_update",
  "description": "Update a contact.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{identifier}",
  "method": "PUT",
  "parameters": [
    {
      "name": "identifier",
      "type": "string",
      "description": "Contact email or ID.",
      "required": true
    },
    {
      "name": "attributes",
      "type": "object",
      "description": "Updated attributes.",
      "required": false
    },
    {
      "name": "listIds",
      "type": "array",
      "description": "Lists to add.",
      "required": false
    },
    {
      "name": "unlinkListIds",
      "type": "array",
      "description": "Lists to remove.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.brevo.com/v3/contacts/john@example.com",
    "headers": {
      "api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "attributes": {
        "FNAME": "Johnny"
      }
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}