{
  "name": "email_campaigns_get",
  "description": "Get a specific email campaign.",
  "resource_group": "email_campaigns",
  "endpoint": "/emailCampaigns/{campaignId}",
  "method": "GET",
  "parameters": [
    {
      "name": "campaignId",
      "type": "integer",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.brevo.com/v3/emailCampaigns/1",
    "headers": {
      "api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "name": "Summer Sale",
      "status": "sent",
      "statistics": {
        "globalStats": {
          "sent": 1000,
          "delivered": 985,
          "opens": 450
        }
      }
    }
  }
}
