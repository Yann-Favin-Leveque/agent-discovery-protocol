{
  "name": "geocode_forward_geojson",
  "description": "Forward geocode returning results in GeoJSON format.",
  "endpoint": "/geocode/v1/geojson",
  "method": "GET",
  "resource_group": "geocoding",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Your 30-character API key",
      "required": true,
      "example": "YOUR_API_KEY",
      "in": "query"
    },
    {
      "name": "language",
      "type": "string",
      "description": "IETF language tag for preferred response language",
      "required": false,
      "example": "en",
      "in": "query"
    },
    {
      "name": "pretty",
      "type": "integer",
      "description": "Set to 1 to pretty-print JSON output",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "no_annotations",
      "type": "integer",
      "description": "Set to 1 to exclude annotations from results",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "no_record",
      "type": "integer",
      "description": "Set to 1 to prevent query logging",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "add_request",
      "type": "integer",
      "description": "Set to 1 to include original request params in response",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "q",
      "type": "string",
      "description": "Address or place name to geocode",
      "required": true,
      "example": "Berlin, Germany",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.opencagedata.com/geocode/v1/geojson?q=Berlin+Germany&key=YOUR_API_KEY",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "FeatureCollection",
      "features": [
        {
          "type": "Feature",
          "geometry": {
            "type": "Point",
            "coordinates": [
              13.405,
              52.52
            ]
          },
          "properties": {
            "formatted": "Berlin, Germany"
          }
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 150
  }
}
