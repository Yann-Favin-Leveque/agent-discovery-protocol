{
  "name": "geocode_forward_bounded",
  "description": "Forward geocode within a specific bounding box to restrict results to a geographic area.",
  "endpoint": "/geocode/v1/json",
  "method": "GET",
  "resource_group": "geocoding",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Your 30-character API key",
      "required": true,
      "example": "YOUR_API_KEY",
      "in": "query"
    },
    {
      "name": "language",
      "type": "string",
      "description": "IETF language tag for preferred response language",
      "required": false,
      "example": "en",
      "in": "query"
    },
    {
      "name": "pretty",
      "type": "integer",
      "description": "Set to 1 to pretty-print JSON output",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "no_annotations",
      "type": "integer",
      "description": "Set to 1 to exclude annotations from results",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "no_record",
      "type": "integer",
      "description": "Set to 1 to prevent query logging",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "add_request",
      "type": "integer",
      "description": "Set to 1 to include original request params in response",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "q",
      "type": "string",
      "description": "Address or place name to geocode",
      "required": true,
      "example": "Springfield",
      "in": "query"
    },
    {
      "name": "bounds",
      "type": "string",
      "description": "Bounding box as 'sw_lng,sw_lat,ne_lng,ne_lat'",
      "required": true,
      "example": "-90.0,37.0,-89.0,40.0",
      "in": "query"
    },
    {
      "name": "countrycode",
      "type": "string",
      "description": "Country code filter",
      "required": false,
      "example": "us",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.opencagedata.com/geocode/v1/json?q=Springfield&bounds=-90.0,37.0,-89.0,40.0&key=YOUR_API_KEY",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "formatted": "Friedrich-Ebert-Strasse 7, 48153 Muenster, Germany",
          "geometry": {
            "lat": 51.9526,
            "lng": 7.6324
          },
          "components": {
            "country": "Germany",
            "city": "Muenster",
            "road": "Friedrich-Ebert-Strasse"
          },
          "confidence": 9,
          "annotations": {
            "timezone": {
              "name": "Europe/Berlin"
            },
            "currency": {
              "name": "Euro",
              "symbol": "EUR"
            }
          }
        }
      ],
      "status": {
        "code": 200,
        "message": "OK"
      },
      "total_results": 1
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 150
  }
}
