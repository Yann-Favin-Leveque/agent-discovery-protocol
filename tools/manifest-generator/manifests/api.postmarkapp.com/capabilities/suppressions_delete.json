{
  "name": "suppressions_delete",
  "description": "Remove suppressions from email addresses.",
  "resource_group": "suppressions",
  "endpoint": "/message-streams/{stream_id}/suppressions/delete",
  "method": "POST",
  "parameters": [
    {
      "name": "stream_id",
      "type": "string",
      "description": "Message stream ID.",
      "required": true,
      "example": "outbound",
      "in": "path"
    },
    {
      "name": "Suppressions",
      "type": "array",
      "description": "Array of email addresses to unsuppress (max 50).",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.postmarkapp.com/message-streams/outbound/suppressions/delete",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "body": {
      "Suppressions": [
        {
          "EmailAddress": "suppress@example.com"
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Suppressions": [
        {
          "EmailAddress": "suppress@example.com",
          "Status": "Deleted"
        }
      ]
    }
  }
}
