{
  "name": "messages_inbound_retry",
  "description": "Retry processing a failed inbound message.",
  "resource_group": "messages",
  "endpoint": "/messages/inbound/{messageid}/retry",
  "method": "PUT",
  "parameters": [
    {
      "name": "messageid",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "abc-456"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.postmarkapp.com/messages/inbound/abc-456/retry",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ErrorCode": 0,
      "Message": "OK"
    }
  }
}