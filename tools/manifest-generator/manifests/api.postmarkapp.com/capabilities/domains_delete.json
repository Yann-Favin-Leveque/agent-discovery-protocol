{
  "name": "domains_delete",
  "description": "Delete a domain.",
  "resource_group": "domains",
  "endpoint": "/domains/{domainid}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "domainid",
      "type": "number",
      "description": "Domain ID.",
      "required": true,
      "example": 123,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.postmarkapp.com/domains/123",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ErrorCode": 0,
      "Message": "Domain example.com removed."
    }
  }
}
