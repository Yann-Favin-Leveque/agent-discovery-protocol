{
  "name": "messages_outbound_get",
  "description": "Retrieve details of a specific outbound message.",
  "resource_group": "messages",
  "endpoint": "/messages/outbound/{messageid}/details",
  "method": "GET",
  "parameters": [
    {
      "name": "messageid",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "abc-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/messages/outbound/abc-123/details",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "MessageID": "abc-123",
      "Status": "Sent",
      "To": "user@example.com",
      "Subject": "Hello"
    }
  }
}
