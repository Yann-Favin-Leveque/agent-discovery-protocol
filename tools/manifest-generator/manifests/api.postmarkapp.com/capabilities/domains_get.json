{
  "name": "domains_get",
  "description": "Retrieve a single domain.",
  "resource_group": "domains",
  "endpoint": "/domains/{domainid}",
  "method": "GET",
  "parameters": [
    {
      "name": "domainid",
      "type": "number",
      "description": "Domain ID.",
      "required": true,
      "example": 123,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/domains/123",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Name": "example.com",
      "DKIMVerified": true
    }
  }
}
