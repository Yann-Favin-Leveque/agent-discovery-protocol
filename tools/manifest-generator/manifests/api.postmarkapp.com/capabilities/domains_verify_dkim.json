{
  "name": "domains_verify_dkim",
  "description": "Verify DKIM records for a domain.",
  "resource_group": "domains",
  "endpoint": "/domains/{domainid}/verifyDkim",
  "method": "PUT",
  "parameters": [
    {
      "name": "domainid",
      "type": "number",
      "description": "Domain ID.",
      "required": true,
      "example": 123,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.postmarkapp.com/domains/123/verifyDkim",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Name": "example.com",
      "DKIMVerified": true
    }
  }
}
