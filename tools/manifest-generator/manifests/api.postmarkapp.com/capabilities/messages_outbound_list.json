{
  "name": "messages_outbound_list",
  "description": "Search outbound messages.",
  "resource_group": "messages",
  "endpoint": "/messages/outbound",
  "method": "GET",
  "parameters": [
    {
      "name": "count",
      "type": "number",
      "description": "Messages per request (max 500).",
      "required": true,
      "example": 100,
      "in": "query"
    },
    {
      "name": "offset",
      "type": "number",
      "description": "Records to skip.",
      "required": true,
      "example": 0,
      "in": "query"
    },
    {
      "name": "recipient",
      "type": "string",
      "description": "Filter by recipient.",
      "required": false,
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status: queued, sent, processed.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/messages/outbound?count=100&offset=0",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TotalCount": 100,
      "Messages": [
        {
          "MessageID": "abc-123",
          "To": [
            {
              "Email": "user@example.com"
            }
          ],
          "Status": "Sent"
        }
      ]
    }
  }
}
