{
  "name": "templates_get",
  "description": "Retrieve a single template by ID or alias.",
  "resource_group": "templates",
  "endpoint": "/templates/{templateIdOrAlias}",
  "method": "GET",
  "parameters": [
    {
      "name": "templateIdOrAlias",
      "type": "string",
      "description": "Template ID or alias.",
      "required": true,
      "example": "12345"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/templates/12345",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TemplateId": 12345,
      "Name": "Welcome",
      "Subject": "Welcome!",
      "HtmlBody": "<p>Welcome</p>",
      "Active": true
    }
  }
}