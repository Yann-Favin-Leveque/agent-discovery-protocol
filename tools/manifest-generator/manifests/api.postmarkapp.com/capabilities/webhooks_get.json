{
  "name": "webhooks_get",
  "description": "Retrieve a single webhook by ID.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "number",
      "description": "Webhook ID.",
      "required": true,
      "example": 123,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/webhooks/123",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Url": "https://example.com/webhook",
      "Triggers": {
        "Open": {
          "Enabled": true
        }
      }
    }
  }
}
