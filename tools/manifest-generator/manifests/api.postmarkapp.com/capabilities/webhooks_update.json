{
  "name": "webhooks_update",
  "description": "Update an existing webhook.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "number",
      "description": "Webhook ID.",
      "required": true,
      "example": 123,
      "in": "path"
    },
    {
      "name": "Url",
      "type": "string",
      "description": "Updated URL.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.postmarkapp.com/webhooks/123",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "body": {
      "Url": "https://example.com/new-webhook"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Url": "https://example.com/new-webhook"
    }
  }
}
