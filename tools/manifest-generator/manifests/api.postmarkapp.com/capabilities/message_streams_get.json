{
  "name": "message_streams_get",
  "description": "Retrieve a single message stream.",
  "resource_group": "message_streams",
  "endpoint": "/message-streams/{stream_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "stream_id",
      "type": "string",
      "description": "Stream ID.",
      "required": true,
      "example": "outbound"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/message-streams/outbound",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": "outbound",
      "Name": "Transactional",
      "MessageStreamType": "Transactional"
    }
  }
}