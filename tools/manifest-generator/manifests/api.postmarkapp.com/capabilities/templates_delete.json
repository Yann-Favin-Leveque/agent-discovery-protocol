{
  "name": "templates_delete",
  "description": "Delete a template.",
  "resource_group": "templates",
  "endpoint": "/templates/{templateIdOrAlias}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "templateIdOrAlias",
      "type": "string",
      "description": "Template ID or alias.",
      "required": true,
      "example": "12345",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.postmarkapp.com/templates/12345",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ErrorCode": 0,
      "Message": "Template 12345 removed."
    }
  }
}
