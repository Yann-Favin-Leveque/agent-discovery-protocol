{
  "name": "message_streams_create",
  "description": "Create a new message stream.",
  "resource_group": "message_streams",
  "endpoint": "/message-streams",
  "method": "POST",
  "parameters": [
    {
      "name": "ID",
      "type": "string",
      "description": "Stream identifier.",
      "required": true,
      "example": "marketing",
      "in": "body"
    },
    {
      "name": "Name",
      "type": "string",
      "description": "Stream name.",
      "required": true,
      "example": "Marketing",
      "in": "body"
    },
    {
      "name": "MessageStreamType",
      "type": "string",
      "description": "Type: Broadcasts or Transactional.",
      "required": true,
      "example": "Broadcasts",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.postmarkapp.com/message-streams",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "body": {
      "ID": "marketing",
      "Name": "Marketing",
      "MessageStreamType": "Broadcasts"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": "marketing",
      "Name": "Marketing",
      "MessageStreamType": "Broadcasts"
    }
  }
}
