{
  "name": "webhooks_list",
  "description": "List all webhooks for a server.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks",
  "method": "GET",
  "parameters": [
    {
      "name": "MessageStream",
      "type": "string",
      "description": "Filter by message stream.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/webhooks",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Webhooks": [
        {
          "ID": 123,
          "Url": "https://example.com/webhook"
        }
      ]
    }
  }
}