{
  "name": "messages_inbound_get",
  "description": "Retrieve details of a specific inbound message.",
  "resource_group": "messages",
  "endpoint": "/messages/inbound/{messageid}/details",
  "method": "GET",
  "parameters": [
    {
      "name": "messageid",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "abc-456",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/messages/inbound/abc-456/details",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "MessageID": "abc-456",
      "From": "sender@example.com",
      "Subject": "Incoming"
    }
  }
}
