{
  "name": "message_streams_unarchive",
  "description": "Unarchive a message stream.",
  "resource_group": "message_streams",
  "endpoint": "/message-streams/{stream_id}/unarchive",
  "method": "POST",
  "parameters": [
    {
      "name": "stream_id",
      "type": "string",
      "description": "Stream ID.",
      "required": true,
      "example": "marketing"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.postmarkapp.com/message-streams/marketing/unarchive",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": "marketing",
      "MessageStreamType": "Broadcasts"
    }
  }
}