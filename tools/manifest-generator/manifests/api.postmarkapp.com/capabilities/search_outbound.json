{
  "name": "search_outbound",
  "description": "Search and retrieve outbound messages sent from your Postmark server. Filter by recipient, sender, subject, status, tag, date range, and custom metadata. Returns message details including delivery status, timestamps, and tracking info. Limited to 10,000 results per search (count + offset cannot exceed 10,000).",
  "endpoint": "/messages/outbound",
  "method": "GET",
  "parameters": [
    {
      "name": "count",
      "type": "integer",
      "description": "Number of messages to return per request. Maximum 500.",
      "required": true,
      "example": 50
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of messages to skip for pagination. Count + offset cannot exceed 10,000.",
      "required": true,
      "example": 0
    },
    {
      "name": "recipient",
      "type": "string",
      "description": "Filter by recipient email address.",
      "required": false,
      "example": "user@example.com"
    },
    {
      "name": "fromemail",
      "type": "string",
      "description": "Filter by sender email address.",
      "required": false,
      "example": "notifications@example.com"
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Filter by email subject (partial match).",
      "required": false,
      "example": "Password Reset"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by delivery status. Options: 'queued', 'sent' (or 'processed').",
      "required": false,
      "example": "sent"
    },
    {
      "name": "tag",
      "type": "string",
      "description": "Filter by message tag.",
      "required": false,
      "example": "password-reset"
    },
    {
      "name": "fromdate",
      "type": "string",
      "description": "Start of date range filter in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-01-01"
    },
    {
      "name": "todate",
      "type": "string",
      "description": "End of date range filter in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-02-01"
    },
    {
      "name": "messagestream",
      "type": "string",
      "description": "Filter by message stream ID.",
      "required": false,
      "example": "outbound"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/messages/outbound?count=50&offset=0&recipient=user@example.com&status=sent",
    "headers": {
      "Accept": "application/json",
      "X-Postmark-Server-Token": "your-server-token-here"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TotalCount": 194,
      "Messages": [
        {
          "MessageID": "b7bc2f4a-e38e-4336-af7d-e6c392c2f817",
          "MessageStream": "outbound",
          "From": "notifications@example.com",
          "To": [
            {
              "Email": "user@example.com",
              "Name": null
            }
          ],
          "Subject": "Your password has been reset",
          "Status": "Sent",
          "ReceivedAt": "2024-02-01T12:00:00Z",
          "TrackOpens": true,
          "TrackLinks": "HtmlAndText",
          "Tag": "password-reset",
          "Metadata": {
            "user_id": "u_abc"
          }
        }
      ]
    }
  }
}
