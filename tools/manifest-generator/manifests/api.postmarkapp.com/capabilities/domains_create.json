{
  "name": "domains_create",
  "description": "Create a new sending domain.",
  "resource_group": "domains",
  "endpoint": "/domains",
  "method": "POST",
  "parameters": [
    {
      "name": "Name",
      "type": "string",
      "description": "Domain name.",
      "required": true,
      "example": "example.com"
    },
    {
      "name": "ReturnPathDomain",
      "type": "string",
      "description": "Custom Return-Path subdomain.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.postmarkapp.com/domains",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "body": {
      "Name": "example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Name": "example.com"
    }
  }
}