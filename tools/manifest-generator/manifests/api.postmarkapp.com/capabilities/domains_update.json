{
  "name": "domains_update",
  "description": "Update a domain's settings.",
  "resource_group": "domains",
  "endpoint": "/domains/{domainid}",
  "method": "PUT",
  "parameters": [
    {
      "name": "domainid",
      "type": "number",
      "description": "Domain ID.",
      "required": true,
      "example": 123
    },
    {
      "name": "ReturnPathDomain",
      "type": "string",
      "description": "Updated Return-Path domain.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.postmarkapp.com/domains/123",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "body": {
      "ReturnPathDomain": "return.example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Name": "example.com"
    }
  }
}