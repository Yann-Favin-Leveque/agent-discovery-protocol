{
  "name": "message_streams_update",
  "description": "Update a message stream.",
  "resource_group": "message_streams",
  "endpoint": "/message-streams/{stream_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "stream_id",
      "type": "string",
      "description": "Stream ID.",
      "required": true,
      "example": "marketing"
    },
    {
      "name": "Name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    },
    {
      "name": "Description",
      "type": "string",
      "description": "Updated description.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.postmarkapp.com/message-streams/marketing",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "body": {
      "Name": "Updated Marketing"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": "marketing",
      "Name": "Updated Marketing"
    }
  }
}