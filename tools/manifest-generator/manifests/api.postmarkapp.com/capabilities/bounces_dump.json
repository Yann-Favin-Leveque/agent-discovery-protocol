{
  "name": "bounces_dump",
  "description": "Retrieve raw source of a bounce.",
  "resource_group": "bounces",
  "endpoint": "/bounces/{bounceid}/dump",
  "method": "GET",
  "parameters": [
    {
      "name": "bounceid",
      "type": "number",
      "description": "Bounce ID.",
      "required": true,
      "example": 123
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/bounces/123/dump",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Body": "raw bounce data..."
    }
  }
}