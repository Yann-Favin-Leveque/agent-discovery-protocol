{
  "name": "webhooks_delete",
  "description": "Delete a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "number",
      "description": "Webhook ID.",
      "required": true,
      "example": 123
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.postmarkapp.com/webhooks/123",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ErrorCode": 0,
      "Message": "Webhook 123 removed."
    }
  }
}