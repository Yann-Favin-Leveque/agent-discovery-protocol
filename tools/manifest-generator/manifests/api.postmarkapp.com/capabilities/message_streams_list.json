{
  "name": "message_streams_list",
  "description": "List all message streams for a server.",
  "resource_group": "message_streams",
  "endpoint": "/message-streams",
  "method": "GET",
  "parameters": [
    {
      "name": "MessageStreamType",
      "type": "string",
      "description": "Filter: All, Inbound, Transactional, Broadcasts.",
      "required": false,
      "example": "All",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/message-streams",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TotalCount": 3,
      "MessageStreams": [
        {
          "ID": "outbound",
          "Name": "Transactional",
          "MessageStreamType": "Transactional"
        }
      ]
    }
  }
}
