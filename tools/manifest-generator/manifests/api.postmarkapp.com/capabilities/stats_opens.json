{
  "name": "stats_opens",
  "description": "Get email open counts.",
  "resource_group": "stats",
  "endpoint": "/stats/outbound/opens",
  "method": "GET",
  "parameters": [
    {
      "name": "fromdate",
      "type": "string",
      "description": "Start date.",
      "required": false
    },
    {
      "name": "todate",
      "type": "string",
      "description": "End date.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/stats/outbound/opens",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Days": [
        {
          "Date": "2024-01-01",
          "Opens": 50,
          "Unique": 40
        }
      ]
    }
  }
}