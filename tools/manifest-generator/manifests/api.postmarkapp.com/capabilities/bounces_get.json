{
  "name": "bounces_get",
  "description": "Retrieve a single bounce record.",
  "resource_group": "bounces",
  "endpoint": "/bounces/{bounceid}",
  "method": "GET",
  "parameters": [
    {
      "name": "bounceid",
      "type": "number",
      "description": "Bounce ID.",
      "required": true,
      "example": 123,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/bounces/123",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Type": "HardBounce",
      "Email": "bounce@example.com"
    }
  }
}
