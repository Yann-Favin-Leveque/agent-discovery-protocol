{
  "name": "stats_outbound",
  "description": "Get a brief overview of outbound email statistics.",
  "resource_group": "stats",
  "endpoint": "/stats/outbound",
  "method": "GET",
  "parameters": [
    {
      "name": "fromdate",
      "type": "string",
      "description": "Start date.",
      "required": false,
      "example": "2024-01-01"
    },
    {
      "name": "todate",
      "type": "string",
      "description": "End date.",
      "required": false,
      "example": "2024-01-31"
    },
    {
      "name": "tag",
      "type": "string",
      "description": "Filter by tag.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/stats/outbound?fromdate=2024-01-01&todate=2024-01-31",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Sent": 1000,
      "BounceRate": 2.5,
      "Opens": 500,
      "Clicks": 200
    }
  }
}