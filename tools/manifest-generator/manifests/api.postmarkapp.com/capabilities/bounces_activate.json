{
  "name": "bounces_activate",
  "description": "Reactivate a bounced email address.",
  "resource_group": "bounces",
  "endpoint": "/bounces/{bounceid}/activate",
  "method": "PUT",
  "parameters": [
    {
      "name": "bounceid",
      "type": "number",
      "description": "Bounce ID.",
      "required": true,
      "example": 123,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.postmarkapp.com/bounces/123/activate",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": 123,
      "Message": "OK",
      "Bounce": {
        "Email": "bounce@example.com"
      }
    }
  }
}
