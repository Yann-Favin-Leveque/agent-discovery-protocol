{
  "name": "message_streams_archive",
  "description": "Archive a message stream.",
  "resource_group": "message_streams",
  "endpoint": "/message-streams/{stream_id}/archive",
  "method": "POST",
  "parameters": [
    {
      "name": "stream_id",
      "type": "string",
      "description": "Stream ID.",
      "required": true,
      "example": "marketing",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.postmarkapp.com/message-streams/marketing/archive",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ID": "marketing",
      "ExpectedPurgeDate": "2024-03-01T00:00:00Z"
    }
  }
}
