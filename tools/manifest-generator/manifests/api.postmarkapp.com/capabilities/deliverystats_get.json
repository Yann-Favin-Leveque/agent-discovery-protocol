{
  "name": "deliverystats_get",
  "description": "Retrieve aggregate delivery statistics including bounces and spam complaints.",
  "resource_group": "stats",
  "endpoint": "/deliverystats",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.postmarkapp.com/deliverystats",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "InactiveMails": 10,
      "Bounces": [
        {
          "Type": "HardBounce",
          "Name": "Hard bounce",
          "Count": 5
        }
      ]
    }
  }
}