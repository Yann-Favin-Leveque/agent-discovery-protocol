{
  "name": "templates_update",
  "description": "Update an existing template.",
  "resource_group": "templates",
  "endpoint": "/templates/{templateIdOrAlias}",
  "method": "PUT",
  "parameters": [
    {
      "name": "templateIdOrAlias",
      "type": "string",
      "description": "Template ID or alias.",
      "required": true,
      "example": "12345",
      "in": "path"
    },
    {
      "name": "Name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "Subject",
      "type": "string",
      "description": "Updated subject.",
      "required": false,
      "in": "body"
    },
    {
      "name": "HtmlBody",
      "type": "string",
      "description": "Updated HTML.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.postmarkapp.com/templates/12345",
    "headers": {
      "X-Postmark-Server-Token": "{server_token}",
      "Accept": "application/json",
      "Content-Type": "application/json"
    },
    "body": {
      "Name": "Updated Welcome",
      "Subject": "Welcome!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TemplateId": 12345,
      "Name": "Updated Welcome"
    }
  }
}
