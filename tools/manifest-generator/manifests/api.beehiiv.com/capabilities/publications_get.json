{
  "name": "publications_get",
  "description": "Retrieve a specific publication by ID.",
  "resource_group": "publications",
  "endpoint": "/v2/publications/{publicationId}",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "pub_xxx",
        "name": "My Newsletter",
        "subscriber_count": 5000
      }
    }
  }
}