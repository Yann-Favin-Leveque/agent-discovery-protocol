{
  "name": "referral_program_get",
  "description": "Retrieve the referral program configuration.",
  "resource_group": "referral_program",
  "endpoint": "/v2/publications/{publicationId}/referral_program",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/referral_program",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "enabled": true,
        "milestones": [
          {
            "referrals_required": 3,
            "reward": "Free stickers"
          }
        ]
      }
    }
  }
}
