{
  "name": "subscription_tags_list",
  "description": "Retrieve all tags for subscriptions.",
  "resource_group": "subscription_tags",
  "endpoint": "/v2/publications/{publicationId}/tags",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/tags",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "tag_xxx",
          "name": "premium-reader"
        }
      ]
    }
  }
}
