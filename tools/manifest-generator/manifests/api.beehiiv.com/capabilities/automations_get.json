{
  "name": "automations_get",
  "description": "Retrieve a specific automation by ID.",
  "resource_group": "automations",
  "endpoint": "/v2/publications/{publicationId}/automations/{automationId}",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "automationId",
      "type": "string",
      "description": "Automation ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/automations/auto_xxx",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "auto_xxx",
        "name": "Welcome Series",
        "status": "active"
      }
    }
  }
}
