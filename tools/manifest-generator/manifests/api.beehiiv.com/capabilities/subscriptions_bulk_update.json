{
  "name": "subscriptions_bulk_update",
  "description": "Update multiple subscriptions in a single bulk request.",
  "resource_group": "subscriptions",
  "endpoint": "/v2/publications/{publicationId}/subscriptions/bulk/update",
  "method": "PATCH",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    },
    {
      "name": "subscriptions",
      "type": "array",
      "description": "Array of subscription update objects.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/subscriptions/bulk/update",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "subscriptions": [
        {
          "id": "sub_xxx",
          "tier": "premium"
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "updated": 1,
        "errors": []
      }
    }
  }
}