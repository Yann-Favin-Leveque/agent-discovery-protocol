{
  "name": "webhooks_list",
  "description": "Retrieve all webhooks for a publication.",
  "resource_group": "webhooks",
  "endpoint": "/v2/publications/{publicationId}/webhooks",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/webhooks",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "wh_xxx",
          "url": "https://example.com/webhook",
          "events": [
            "subscription.created"
          ]
        }
      ]
    }
  }
}