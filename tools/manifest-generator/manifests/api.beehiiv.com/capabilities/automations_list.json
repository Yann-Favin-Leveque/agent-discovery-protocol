{
  "name": "automations_list",
  "description": "Retrieve all automations for a publication.",
  "resource_group": "automations",
  "endpoint": "/v2/publications/{publicationId}/automations",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/automations",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "auto_xxx",
          "name": "Welcome Series",
          "status": "active"
        }
      ]
    }
  }
}
