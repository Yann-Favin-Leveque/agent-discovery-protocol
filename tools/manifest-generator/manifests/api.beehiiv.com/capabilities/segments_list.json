{
  "name": "segments_list",
  "description": "Retrieve all audience segments for a publication.",
  "resource_group": "segments",
  "endpoint": "/v2/publications/{publicationId}/segments",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/segments",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "seg_xxx",
          "name": "Engaged Readers",
          "subscriber_count": 250
        }
      ]
    }
  }
}