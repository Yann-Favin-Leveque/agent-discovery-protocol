{
  "name": "webhooks_delete",
  "description": "Delete a webhook by ID.",
  "resource_group": "webhooks",
  "endpoint": "/v2/publications/{publicationId}/webhooks/{webhookId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "webhookId",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/webhooks/wh_xxx",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
