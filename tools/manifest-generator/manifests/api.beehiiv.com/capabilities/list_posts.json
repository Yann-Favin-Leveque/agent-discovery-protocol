{
  "name": "list_posts",
  "description": "Retrieve a paginated list of posts from your Beehiiv publication. Each post includes content, metadata, and performance statistics like send count, opens, and clicks.",
  "endpoint": "/v2/publications/{publication_id}/posts",
  "method": "GET",
  "parameters": [
    {
      "name": "publication_id",
      "type": "string",
      "description": "The ID of your Beehiiv publication.",
      "required": true,
      "example": "pub_abc123def456"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by post status. Options: draft, confirmed, archived.",
      "required": false,
      "example": "confirmed"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results per page. Max 100.",
      "required": false,
      "example": 10
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for paginated results.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_abc123def456/posts?status=confirmed&limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "post_abc789",
          "title": "February Product Update",
          "subtitle": "Recap of the month",
          "status": "confirmed",
          "publish_date": "2026-02-15T09:00:00Z",
          "web_url": "https://example.beehiiv.com/p/february-product-update",
          "stats": {
            "email_sent_count": 3200,
            "email_open_count": 1500,
            "email_click_count": 420
          }
        }
      ],
      "page": 1,
      "limit": 10,
      "total_results": 24
    }
  }
}
