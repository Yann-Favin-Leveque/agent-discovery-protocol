  "endpoint": "/v2/publications/{publicationId}/custom_fields/{customFieldId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "customFieldId",
      "type": "string",
      "description": "Custom field ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/custom_fields/cf_xxx",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
