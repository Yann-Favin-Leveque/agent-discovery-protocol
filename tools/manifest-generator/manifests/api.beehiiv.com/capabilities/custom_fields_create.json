{
  "name": "custom_fields_create",
  "description": "Create a new custom field.",
  "resource_group": "custom_fields",
  "endpoint": "/v2/publications/{publicationId}/custom_fields",
  "method": "POST",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Field name.",
      "required": true,
      "example": "company"
    },
    {
      "name": "display",
      "type": "string",
      "description": "Display label.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/custom_fields",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "company",
      "display": "Company"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "cf_yyy",
        "name": "company"
      }
    }
  }
}