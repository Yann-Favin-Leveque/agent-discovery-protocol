{
  "name": "segments_get",
  "description": "Retrieve a specific segment by ID.",
  "resource_group": "segments",
  "endpoint": "/v2/publications/{publicationId}/segments/{segmentId}",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    },
    {
      "name": "segmentId",
      "type": "string",
      "description": "Segment ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/segments/seg_xxx",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "seg_xxx",
        "name": "Engaged Readers",
        "subscriber_count": 250
      }
    }
  }
}