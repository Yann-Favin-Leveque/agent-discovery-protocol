{
  "name": "subscriptions_get",
  "description": "Retrieve a single subscription by ID.",
  "resource_group": "subscriptions",
  "endpoint": "/v2/publications/{publicationId}/subscriptions/{subscriptionId}",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "subscriptionId",
      "type": "string",
      "description": "Subscription ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "expand[]",
      "type": "string",
      "description": "Expandable: stats, custom_fields, referrals.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/subscriptions/sub_xxx",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "sub_xxx",
        "email": "john@example.com",
        "status": "active"
      }
    }
  }
}
