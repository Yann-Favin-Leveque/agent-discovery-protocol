{
  "name": "subscriptions_get_by_email",
  "description": "Retrieve a subscription by email address.",
  "resource_group": "subscriptions",
  "endpoint": "/v2/publications/{publicationId}/subscriptions/by_email/{email}",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    },
    {
      "name": "email",
      "type": "string",
      "description": "Subscriber email address.",
      "required": true,
      "example": "john@example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/subscriptions/by_email/john@example.com",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "sub_xxx",
        "email": "john@example.com",
        "status": "active"
      }
    }
  }
}