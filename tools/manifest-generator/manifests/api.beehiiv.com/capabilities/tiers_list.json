{
  "name": "tiers_list",
  "description": "Retrieve all subscription tiers.",
  "resource_group": "tiers",
  "endpoint": "/v2/publications/{publicationId}/tiers",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/tiers",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "tier_xxx",
          "name": "Free",
          "price": 0
        }
      ]
    }
  }
}