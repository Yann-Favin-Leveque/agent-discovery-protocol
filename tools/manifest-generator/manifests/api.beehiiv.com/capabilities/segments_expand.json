{
  "name": "segments_expand",
  "description": "Retrieve subscribers belonging to a segment.",
  "resource_group": "segments",
  "endpoint": "/v2/publications/{publicationId}/segments/{segmentId}/results",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    },
    {
      "name": "segmentId",
      "type": "string",
      "description": "Segment ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/segments/seg_xxx/results",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "sub_xxx",
          "email": "john@example.com"
        }
      ]
    }
  }
}