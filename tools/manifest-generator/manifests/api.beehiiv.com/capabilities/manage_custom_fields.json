{
  "name": "manage_custom_fields",
  "description": "Create, update, list, and delete custom data fields on subscriber profiles. Custom fields allow richer segmentation and personalization of your newsletters by storing arbitrary data about each subscriber.",
  "endpoint": "/v2/publications/{publication_id}/custom_fields",
  "method": "GET",
  "parameters": [
    {
      "name": "publication_id",
      "type": "string",
      "description": "The ID of your Beehiiv publication.",
      "required": true,
      "example": "pub_abc123def456"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_abc123def456/custom_fields",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "cf_001",
          "name": "company",
          "display_name": "Company Name",
          "type": "string",
          "created_at": 1704067200
        },
        {
          "id": "cf_002",
          "name": "plan_tier",
          "display_name": "Plan Tier",
          "type": "string",
          "created_at": 1704067200
        }
      ]
    }
  }
}
