{
  "name": "custom_fields_list",
  "description": "Retrieve all custom fields for a publication.",
  "resource_group": "custom_fields",
  "endpoint": "/v2/publications/{publicationId}/custom_fields",
  "method": "GET",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/custom_fields",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "cf_xxx",
          "name": "company",
          "display": "Company"
        }
      ]
    }
  }
}