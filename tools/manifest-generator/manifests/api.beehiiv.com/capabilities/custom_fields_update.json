{
  "name": "custom_fields_update",
  "description": "Update a custom field definition.",
  "resource_group": "custom_fields",
  "endpoint": "/v2/publications/{publicationId}/custom_fields/{customFieldId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    },
    {
      "name": "customFieldId",
      "type": "string",
      "description": "Custom field ID.",
      "required": true
    },
    {
      "name": "display",
      "type": "string",
      "description": "Updated display label.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/custom_fields/cf_xxx",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "display": "Organization"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "cf_xxx",
        "display": "Organization"
      }
    }
  }
}