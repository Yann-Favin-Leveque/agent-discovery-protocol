{
  "name": "subscription_tags_create",
  "description": "Create a new subscription tag.",
  "resource_group": "subscription_tags",
  "endpoint": "/v2/publications/{publicationId}/tags",
  "method": "POST",
  "parameters": [
    {
      "name": "publicationId",
      "type": "string",
      "description": "Publication ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Tag name.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.beehiiv.com/v2/publications/pub_xxx/tags",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "vip"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "tag_yyy",
        "name": "vip"
      }
    }
  }
}