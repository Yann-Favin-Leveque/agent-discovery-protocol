{
  "name": "push_device_delete",
  "description": "Unregister a device from push notifications.",
  "resource_group": "push",
  "endpoint": "/push/deviceRegistrations/{deviceId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device identifier to unregister.",
      "required": true,
      "example": "device_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://rest.ably.io/push/deviceRegistrations/device_001",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "rate_limits": {
    "requests_per_minute": 1500
  }
}
