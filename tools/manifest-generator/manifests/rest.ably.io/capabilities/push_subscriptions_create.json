{
  "name": "push_subscriptions_create",
  "description": "Subscribe a device or client to push notifications on a channel.",
  "resource_group": "push",
  "endpoint": "/push/channelSubscriptions",
  "method": "POST",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "description": "Channel to subscribe to.",
      "required": true,
      "example": "alerts",
      "in": "body"
    },
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID to subscribe (mutually exclusive with clientId).",
      "required": false,
      "example": "device_001",
      "in": "body"
    },
    {
      "name": "clientId",
      "type": "string",
      "description": "Client ID to subscribe (mutually exclusive with deviceId).",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.ably.io/push/channelSubscriptions",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "channel": "alerts",
      "deviceId": "device_001"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "channel": "alerts",
      "deviceId": "device_001"
    }
  },
  "rate_limits": {
    "requests_per_minute": 1500
  }
}
