{
  "name": "channels_get",
  "description": "Retrieve metadata for a specific channel including its active status and occupancy metrics.",
  "resource_group": "channels",
  "endpoint": "/channels/{channelId}",
  "method": "GET",
  "parameters": [
    {"name": "channelId", "type": "string", "description": "The channel name.", "required": true, "example": "my-channel"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.ably.io/channels/my-channel",
    "headers": {"Authorization": "Basic {base64_api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {
      "channelId": "my-channel",
      "status": {"isActive": true, "occupancy": {"metrics": {"connections": 10, "publishers": 3, "subscribers": 7}}}
    }
  },
  "rate_limits": {"requests_per_minute": 1500}
}