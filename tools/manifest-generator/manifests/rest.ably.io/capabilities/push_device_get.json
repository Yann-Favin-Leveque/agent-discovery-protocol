{
  "name": "push_device_get",
  "description": "Retrieve details of a registered push device.",
  "resource_group": "push",
  "endpoint": "/push/deviceRegistrations/{deviceId}",
  "method": "GET",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device identifier.",
      "required": true,
      "example": "device_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.ably.io/push/deviceRegistrations/device_001",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "device_001",
      "platform": "android",
      "formFactor": "phone",
      "clientId": "user1"
    }
  },
  "rate_limits": {
    "requests_per_minute": 1500
  }
}
