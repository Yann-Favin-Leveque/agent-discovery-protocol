{
  "name": "push_subscriptions_delete",
  "description": "Remove a push notification channel subscription.",
  "resource_group": "push",
  "endpoint": "/push/channelSubscriptions",
  "method": "DELETE",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "description": "Channel name.",
      "required": true,
      "example": "alerts",
      "in": "query"
    },
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID to unsubscribe.",
      "required": false,
      "example": "device_001",
      "in": "query"
    },
    {
      "name": "clientId",
      "type": "string",
      "description": "Client ID to unsubscribe.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://rest.ably.io/push/channelSubscriptions?channel=alerts&deviceId=device_001",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "rate_limits": {
    "requests_per_minute": 1500
  }
}
