{
  "name": "presence_history",
  "description": "Retrieve presence event history for a channel, including enter, leave, and update events.",
  "resource_group": "presence",
  "endpoint": "/channels/{channelId}/presence/history",
  "method": "GET",
  "parameters": [
    {"name": "channelId", "type": "string", "description": "The channel name.", "required": true, "example": "my-channel"},
    {"name": "start", "type": "string", "description": "Start of time range (millisecond epoch or ISO 8601).", "required": false},
    {"name": "end", "type": "string", "description": "End of time range.", "required": false},
    {"name": "limit", "type": "integer", "description": "Max results to return (default 100, max 1000).", "required": false, "example": 50},
    {"name": "direction", "type": "string", "description": "Order: forwards or backwards (default).", "required": false, "example": "backwards"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.ably.io/channels/my-channel/presence/history?limit=50",
    "headers": {"Authorization": "Basic {base64_api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": [
      {"clientId": "user1", "action": "enter", "data": "online", "timestamp": 1705312200000}
    ]
  },
  "rate_limits": {"requests_per_minute": 1500}
}