{
  "name": "get_order",
  "description": "Retrieve the full details of a specific order by its ID. Returns complete order information including line items, shipping address, billing address, payment details, fulfillment status, discount codes, and customer information.",
  "endpoint": "/admin/api/2024-01/orders/{order_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "order_id",
      "type": "integer",
      "description": "The unique numeric ID of the order to retrieve.",
      "required": true,
      "example": 450789469
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields to include in the response.",
      "required": false,
      "example": "id,name,total_price,line_items"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store_name}.myshopify.com/admin/api/2024-01/orders/450789469.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "id": 450789469,
        "name": "#1001",
        "email": "bob@example.com",
        "created_at": "2024-01-10T11:50:00-05:00",
        "total_price": "409.94",
        "subtotal_price": "398.00",
        "total_tax": "11.94",
        "total_discounts": "0.00",
        "currency": "USD",
        "financial_status": "paid",
        "fulfillment_status": null,
        "line_items": [
          {
            "id": 466157049,
            "title": "IPod Nano - 8GB",
            "quantity": 2,
            "price": "199.00",
            "sku": "IPOD2008PINK",
            "variant_title": "Pink"
          }
        ],
        "shipping_address": {
          "first_name": "Bob",
          "last_name": "Norman",
          "address1": "123 Amoebas St",
          "city": "Ottawa",
          "province": "Ontario",
          "country": "Canada",
          "zip": "K2P0V6"
        },
        "customer": {
          "id": 207119551,
          "first_name": "Bob",
          "last_name": "Norman",
          "email": "bob@example.com"
        }
      }
    }
  }
}
