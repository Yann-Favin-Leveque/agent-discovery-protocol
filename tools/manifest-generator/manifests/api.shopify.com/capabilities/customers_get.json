{
  "name": "customers_get",
  "description": "Retrieve full details of a specific customer including addresses and order statistics.",
  "resource_group": "customers",
  "endpoint": "/admin/api/2024-10/customers/{customer_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "customer_id",
      "type": "integer",
      "required": true,
      "description": "The ID of the customer.",
      "example": 207119551,
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of fields.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/customers/207119551.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer": {
        "id": 207119551,
        "email": "bob@example.com",
        "first_name": "Bob",
        "last_name": "Norman",
        "orders_count": 1,
        "total_spent": "199.65",
        "addresses": [
          {
            "id": 207119551,
            "address1": "123 Elm St",
            "city": "Ottawa",
            "province": "Ontario",
            "country": "Canada"
          }
        ]
      }
    }
  }
}
