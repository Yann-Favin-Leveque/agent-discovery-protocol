{
  "name": "list_orders",
  "description": "Retrieve a paginated list of orders from the Shopify store. Supports filtering by status, financial status, fulfillment status, and date ranges. Returns order details including line items, totals, and customer information.",
  "endpoint": "/admin/api/2024-01/orders.json",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of orders to return (max 250, default 50).",
      "required": false,
      "example": 50
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by order status: 'open', 'closed', 'cancelled', or 'any'.",
      "required": false,
      "example": "open"
    },
    {
      "name": "financial_status",
      "type": "string",
      "description": "Filter by financial status: 'authorized', 'pending', 'paid', 'partially_paid', 'refunded', 'voided', 'partially_refunded', or 'any'.",
      "required": false,
      "example": "paid"
    },
    {
      "name": "fulfillment_status",
      "type": "string",
      "description": "Filter by fulfillment status: 'shipped', 'partial', 'unshipped', or 'any'.",
      "required": false,
      "example": "unshipped"
    },
    {
      "name": "created_at_min",
      "type": "string",
      "description": "Show orders created after this date (ISO 8601 format).",
      "required": false,
      "example": "2024-01-01T00:00:00-05:00"
    },
    {
      "name": "created_at_max",
      "type": "string",
      "description": "Show orders created before this date (ISO 8601 format).",
      "required": false,
      "example": "2024-12-31T23:59:59-05:00"
    },
    {
      "name": "since_id",
      "type": "integer",
      "description": "Return only orders after the specified ID for pagination.",
      "required": false,
      "example": 123456789
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store_name}.myshopify.com/admin/api/2024-01/orders.json?status=open&financial_status=paid&limit=50",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "orders": [
        {
          "id": 450789469,
          "name": "#1001",
          "email": "bob@example.com",
          "created_at": "2024-01-10T11:50:00-05:00",
          "total_price": "409.94",
          "subtotal_price": "398.00",
          "total_tax": "11.94",
          "currency": "USD",
          "financial_status": "paid",
          "fulfillment_status": null,
          "line_items": [
            {
              "id": 466157049,
              "title": "IPod Nano - 8GB",
              "quantity": 2,
              "price": "199.00"
            }
          ],
          "customer": {
            "id": 207119551,
            "first_name": "Bob",
            "last_name": "Norman",
            "email": "bob@example.com"
          }
        }
      ]
    }
  }
}
