{
  "name": "shop_get",
  "description": "Retrieve shop general settings including name, domain, currency, and timezone.",
  "resource_group": "shop",
  "endpoint": "/admin/api/2024-10/shop.json",
  "method": "GET",
  "parameters": [
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of fields.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/shop.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "shop": {
        "id": 548380009,
        "name": "My Store",
        "email": "john@example.com",
        "domain": "my-store.myshopify.com",
        "currency": "USD"
      }
    }
  }
}
