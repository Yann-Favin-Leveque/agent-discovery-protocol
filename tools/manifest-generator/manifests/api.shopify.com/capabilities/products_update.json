{
  "name": "products_update",
  "description": "Update an existing product title, description, variants, images, or status.",
  "resource_group": "products",
  "endpoint": "/admin/api/2024-10/products/{product_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "product_id",
      "type": "integer",
      "required": true,
      "description": "Product ID to update.",
      "example": 632910392,
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Updated title.",
      "in": "body"
    },
    {
      "name": "body_html",
      "type": "string",
      "required": false,
      "description": "Updated description.",
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Updated status.",
      "in": "body"
    },
    {
      "name": "variants",
      "type": "array",
      "required": false,
      "description": "Updated variants.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/products/632910392.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "product": {
        "id": 632910392,
        "title": "Updated Product Title"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "product": {
        "id": 632910392,
        "title": "Updated Product Title"
      }
    }
  }
}
