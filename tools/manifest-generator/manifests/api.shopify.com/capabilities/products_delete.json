{
  "name": "products_delete",
  "description": "Delete a product from the Shopify store by its ID.",
  "resource_group": "products",
  "endpoint": "/admin/api/2024-10/products/{product_id}.json",
  "method": "DELETE",
  "parameters": [
    {
      "name": "product_id",
      "type": "integer",
      "required": true,
      "description": "Product ID to delete.",
      "example": 632910392
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/products/632910392.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}