{
  "name": "orders_close",
  "description": "Close a completed order to prevent further edits.",
  "resource_group": "orders",
  "endpoint": "/admin/api/2024-10/orders/{order_id}/close.json",
  "method": "POST",
  "parameters": [
    {
      "name": "order_id",
      "type": "integer",
      "required": true,
      "description": "Order ID to close.",
      "example": 450789469,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/orders/450789469/close.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "id": 450789469,
        "closed_at": "2024-01-15T12:00:00-05:00"
      }
    }
  }
}
