{
  "name": "collections_list",
  "description": "Retrieve custom collections from the store with titles, descriptions, and product counts.",
  "resource_group": "collections",
  "endpoint": "/admin/api/2024-10/custom_collections.json",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of results per page (max 250)."
    },
    {
      "name": "since_id",
      "type": "integer",
      "required": false,
      "description": "Return collections after specified ID."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Filter by collection title."
    },
    {
      "name": "product_id",
      "type": "integer",
      "required": false,
      "description": "Show collections including this product."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/custom_collections.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "custom_collections": [
        {
          "id": 841564295,
          "title": "Summer Collection",
          "body_html": "<p>Summer picks</p>"
        }
      ]
    }
  }
}