{
  "name": "create_fulfillment",
  "description": "Create a fulfillment for an order to mark items as shipped. Includes tracking number, tracking URL, and shipping carrier information. Notifies the customer by email when notify_customer is true.",
  "endpoint": "/admin/api/2024-01/fulfillments.json",
  "method": "POST",
  "parameters": [
    {
      "name": "line_items_by_fulfillment_order",
      "type": "array",
      "description": "Array of fulfillment order objects specifying which items to fulfill.",
      "required": true,
      "example": [
        {
          "fulfillment_order_id": 1046000778,
          "fulfillment_order_line_items": [
            {
              "id": 1058737482,
              "quantity": 1
            }
          ]
        }
      ]
    },
    {
      "name": "tracking_info",
      "type": "object",
      "description": "Tracking details including number, URL, and carrier company.",
      "required": false,
      "example": {
        "number": "1Z999AA10123456784",
        "url": "https://www.ups.com/track?tracknum=1Z999AA10123456784",
        "company": "UPS"
      }
    },
    {
      "name": "notify_customer",
      "type": "boolean",
      "description": "Whether to send a shipping confirmation email to the customer.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{store_name}.myshopify.com/admin/api/2024-01/fulfillments.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "fulfillment": {
        "line_items_by_fulfillment_order": [
          {
            "fulfillment_order_id": 1046000778
          }
        ],
        "tracking_info": {
          "number": "1Z999AA10123456784",
          "url": "https://www.ups.com/track?tracknum=1Z999AA10123456784",
          "company": "UPS"
        },
        "notify_customer": true
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "fulfillment": {
        "id": 255858046,
        "order_id": 450789469,
        "status": "success",
        "tracking_company": "UPS",
        "tracking_number": "1Z999AA10123456784",
        "tracking_url": "https://www.ups.com/track?tracknum=1Z999AA10123456784",
        "created_at": "2024-01-10T15:30:00-05:00",
        "line_items": [
          {
            "id": 466157049,
            "title": "IPod Nano - 8GB",
            "quantity": 1
          }
        ]
      }
    }
  }
}
