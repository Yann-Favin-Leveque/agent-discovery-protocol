{
  "name": "customers_create",
  "description": "Create a new customer with email, name, addresses, and marketing consent.",
  "resource_group": "customers",
  "endpoint": "/admin/api/2024-10/customers.json",
  "method": "POST",
  "parameters": [
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email address.",
      "example": "bob@example.com",
      "in": "body"
    },
    {
      "name": "phone",
      "type": "string",
      "required": false,
      "description": "Phone number.",
      "in": "body"
    },
    {
      "name": "addresses",
      "type": "array",
      "required": false,
      "description": "Array of address objects.",
      "in": "body"
    },
    {
      "name": "tags",
      "type": "string",
      "required": false,
      "description": "Comma-separated tags.",
      "in": "body"
    },
    {
      "name": "accepts_marketing",
      "type": "boolean",
      "required": false,
      "description": "Whether customer consented to marketing.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/customers.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "customer": {
        "first_name": "Steve",
        "last_name": "Jobs",
        "email": "steve@apple.com"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "customer": {
        "id": 1073339470,
        "email": "steve@apple.com",
        "first_name": "Steve",
        "last_name": "Jobs"
      }
    }
  }
}
