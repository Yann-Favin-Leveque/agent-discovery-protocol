{
  "name": "products_list",
  "description": "Retrieve a paginated list of products from the Shopify store with filtering by collection, type, vendor, status, and dates.",
  "resource_group": "products",
  "endpoint": "/admin/api/2024-10/products.json",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of results per page (max 250, default 50).",
      "example": 50,
      "in": "query"
    },
    {
      "name": "since_id",
      "type": "integer",
      "required": false,
      "description": "Return products after this ID for pagination.",
      "in": "query"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Filter by product title.",
      "in": "query"
    },
    {
      "name": "vendor",
      "type": "string",
      "required": false,
      "description": "Filter by product vendor.",
      "in": "query"
    },
    {
      "name": "product_type",
      "type": "string",
      "required": false,
      "description": "Filter by product type.",
      "in": "query"
    },
    {
      "name": "collection_id",
      "type": "integer",
      "required": false,
      "description": "Filter by collection ID.",
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter: active, archived, or draft.",
      "in": "query"
    },
    {
      "name": "created_at_min",
      "type": "string",
      "required": false,
      "description": "Show products created after date (ISO 8601).",
      "in": "query"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of fields to include.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/products.json?limit=10&status=active",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "products": [
        {
          "id": 632910392,
          "title": "IPod Nano - 8GB",
          "vendor": "Apple",
          "product_type": "Cult Products",
          "status": "active",
          "variants": [
            {
              "id": 808950810,
              "title": "Pink",
              "price": "199.00",
              "sku": "IPOD2008PINK"
            }
          ]
        }
      ]
    }
  }
}
