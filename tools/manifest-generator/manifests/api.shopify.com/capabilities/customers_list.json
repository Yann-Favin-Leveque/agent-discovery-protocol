{
  "name": "customers_list",
  "description": "Retrieve a paginated list of customers from the Shopify store. Supports searching by name or email and filtering by creation date.",
  "resource_group": "customers",
  "endpoint": "/admin/api/2024-10/customers.json",
  "method": "GET",
  "parameters": [
    {"name": "limit", "type": "integer", "required": false, "description": "Number of results per page (max 250, default 50)."},
    {"name": "since_id", "type": "integer", "required": false, "description": "Return customers after specified ID."},
    {"name": "created_at_min", "type": "string", "required": false, "description": "Customers created after date (ISO 8601)."},
    {"name": "created_at_max", "type": "string", "required": false, "description": "Customers created before date (ISO 8601)."},
    {"name": "fields", "type": "string", "required": false, "description": "Comma-separated list of fields to include."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/customers.json?limit=25",
    "headers": {"X-Shopify-Access-Token": "{access_token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"customers": [{"id": 207119551, "email": "bob@example.com", "first_name": "Bob", "last_name": "Norman", "orders_count": 1, "total_spent": "199.65"}]}
  }
}
