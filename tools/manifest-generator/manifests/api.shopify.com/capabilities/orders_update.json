{
  "name": "orders_update",
  "description": "Update an order note, tags, shipping address, or email.",
  "resource_group": "orders",
  "endpoint": "/admin/api/2024-10/orders/{order_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "order_id",
      "type": "integer",
      "required": true,
      "description": "Order ID.",
      "in": "path"
    },
    {
      "name": "note",
      "type": "string",
      "required": false,
      "description": "Updated note.",
      "in": "body"
    },
    {
      "name": "tags",
      "type": "string",
      "required": false,
      "description": "Updated tags.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Updated email.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/orders/450789469.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "order": {
        "id": 450789469,
        "note": "Customer requested gift wrap"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "id": 450789469,
        "note": "Customer requested gift wrap"
      }
    }
  }
}
