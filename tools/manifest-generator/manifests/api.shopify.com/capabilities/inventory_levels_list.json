{
  "name": "inventory_levels_list",
  "description": "Retrieve inventory levels for items at specific locations.",
  "resource_group": "inventory",
  "endpoint": "/admin/api/2024-10/inventory_levels.json",
  "method": "GET",
  "parameters": [
    {
      "name": "inventory_item_ids",
      "type": "string",
      "required": false,
      "description": "Comma-separated inventory item IDs.",
      "in": "query"
    },
    {
      "name": "location_ids",
      "type": "string",
      "required": false,
      "description": "Comma-separated location IDs.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/inventory_levels.json?inventory_item_ids=808950810",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "inventory_levels": [
        {
          "inventory_item_id": 808950810,
          "location_id": 905684977,
          "available": 6
        }
      ]
    }
  }
}
