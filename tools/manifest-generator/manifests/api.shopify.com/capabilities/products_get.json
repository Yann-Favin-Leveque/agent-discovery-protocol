{
  "name": "products_get",
  "description": "Retrieve a single product by ID with all variants, images, and options.",
  "resource_group": "products",
  "endpoint": "/admin/api/2024-10/products/{product_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "product_id",
      "type": "integer",
      "required": true,
      "description": "The product ID.",
      "example": 632910392,
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of fields.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}.myshopify.com/admin/api/2024-10/products/632910392.json",
    "headers": {
      "X-Shopify-Access-Token": "{access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "product": {
        "id": 632910392,
        "title": "IPod Nano - 8GB",
        "vendor": "Apple",
        "variants": [
          {
            "id": 808950810,
            "title": "Pink",
            "price": "199.00"
          }
        ],
        "images": [
          {
            "id": 850703190,
            "src": "https://cdn.shopify.com/..."
          }
        ]
      }
    }
  }
}
