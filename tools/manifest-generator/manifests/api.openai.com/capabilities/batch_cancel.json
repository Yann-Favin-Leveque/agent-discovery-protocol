{
  "name": "batch_cancel",
  "description": "Cancel an in-progress batch job. Already completed requests within the batch will not be cancelled.",
  "resource_group": "batches",
  "endpoint": "/v1/batches/{batch_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "batch_id",
      "type": "string",
      "required": true,
      "description": "The ID of the batch to cancel."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.openai.com/v1/batches/batch-abc123/cancel",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch-abc123",
      "object": "batch",
      "status": "cancelling"
    }
  }
}
