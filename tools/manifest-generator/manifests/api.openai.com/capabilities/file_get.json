{
  "name": "file_get",
  "description": "Retrieve metadata about a specific uploaded file by its ID.",
  "resource_group": "files",
  "endpoint": "/v1/files/{file_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "required": true,
      "description": "The ID of the file to retrieve."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.openai.com/v1/files/file-abc123",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "file-abc123",
      "object": "file",
      "bytes": 175234,
      "created_at": 1709164800,
      "filename": "training_data.jsonl",
      "purpose": "fine-tune"
    }
  }
}
