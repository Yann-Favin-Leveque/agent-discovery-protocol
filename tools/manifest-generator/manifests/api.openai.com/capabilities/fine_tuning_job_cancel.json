{
  "name": "fine_tuning_job_cancel",
  "description": "Cancel an in-progress fine-tuning job.",
  "resource_group": "fine_tuning",
  "endpoint": "/v1/fine_tuning/jobs/{fine_tuning_job_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "fine_tuning_job_id",
      "type": "string",
      "required": true,
      "description": "The ID of the fine-tuning job to cancel.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.openai.com/v1/fine_tuning/jobs/ftjob-abc123/cancel",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "fine_tuning.job",
      "id": "ftjob-abc123",
      "status": "cancelled"
    }
  }
}
