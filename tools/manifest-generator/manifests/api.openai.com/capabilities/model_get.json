{
  "name": "model_get",
  "description": "Retrieve details about a specific model by its ID, including ownership and creation date.",
  "resource_group": "models",
  "endpoint": "/v1/models/{model}",
  "method": "GET",
  "parameters": [
    {
      "name": "model",
      "type": "string",
      "required": true,
      "description": "The ID of the model to retrieve (e.g. 'gpt-4o')."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.openai.com/v1/models/gpt-4o",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "gpt-4o",
      "object": "model",
      "created": 1715367049,
      "owned_by": "system"
    }
  }
}
