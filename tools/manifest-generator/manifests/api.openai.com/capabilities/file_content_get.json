{
  "name": "file_content_get",
  "description": "Retrieve the contents of an uploaded file.",
  "resource_group": "files",
  "endpoint": "/v1/files/{file_id}/content",
  "method": "GET",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "required": true,
      "description": "The ID of the file whose content to retrieve."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.openai.com/v1/files/file-abc123/content",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": "Raw file content"
  }
}
