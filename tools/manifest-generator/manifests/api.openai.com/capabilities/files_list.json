{
  "name": "files_list",
  "description": "List all files uploaded to the OpenAI platform, including their purpose, size, and creation date.",
  "resource_group": "files",
  "endpoint": "/v1/files",
  "method": "GET",
  "parameters": [
    {
      "name": "purpose",
      "type": "string",
      "required": false,
      "description": "Filter by purpose: 'fine-tune', 'assistants', 'batch', 'vision'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.openai.com/v1/files",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "list",
      "data": [
        {
          "id": "file-abc123",
          "object": "file",
          "bytes": 175234,
          "created_at": 1709164800,
          "filename": "training_data.jsonl",
          "purpose": "fine-tune"
        }
      ]
    }
  }
}
