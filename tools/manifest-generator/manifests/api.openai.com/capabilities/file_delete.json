{
  "name": "file_delete",
  "description": "Delete an uploaded file by its ID.",
  "resource_group": "files",
  "endpoint": "/v1/files/{file_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "required": true,
      "description": "The ID of the file to delete."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.openai.com/v1/files/file-abc123",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "file-abc123",
      "object": "file",
      "deleted": true
    }
  }
}
