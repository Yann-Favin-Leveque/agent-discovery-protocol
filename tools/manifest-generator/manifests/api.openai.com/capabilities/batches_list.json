      "description": "Cursor for pagination.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of batches to retrieve (default 20).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.openai.com/v1/batches",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "list",
      "data": [
        {
          "id": "batch-abc123",
