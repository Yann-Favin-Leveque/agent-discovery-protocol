{
  "name": "create_moderation",
  "description": "Check whether text content violates OpenAI's content policy. Classifies content across categories including hate, harassment, self-harm, sexual content, and violence. Returns boolean flags and confidence scores for each category. Useful for content filtering before display or processing.",
  "endpoint": "/v1/moderations",
  "method": "POST",
  "parameters": [
    {
      "name": "input",
      "type": "string or array",
      "required": true,
      "description": "The text content to classify. Can be a single string or an array of strings."
    },
    {
      "name": "model",
      "type": "string",
      "required": false,
      "description": "Moderation model to use: 'text-moderation-latest' (default) or 'text-moderation-stable'."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.openai.com/v1/moderations",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "input": "I want to learn about the history of martial arts and their philosophical foundations."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "modr-abc123def456",
      "model": "text-moderation-007",
      "results": [
        {
          "flagged": false,
          "categories": {
            "sexual": false,
            "hate": false,
            "harassment": false,
            "self-harm": false,
            "sexual/minors": false,
            "hate/threatening": false,
            "violence/graphic": false,
            "self-harm/intent": false,
            "self-harm/instructions": false,
            "harassment/threatening": false,
            "violence": false
          },
          "category_scores": {
            "sexual": 0.000012,
            "hate": 0.000034,
            "harassment": 0.000056,
            "self-harm": 0.000002,
            "sexual/minors": 0.000001,
            "hate/threatening": 0.000003,
            "violence/graphic": 0.000089,
            "self-harm/intent": 0.000001,
            "self-harm/instructions": 0.000001,
            "harassment/threatening": 0.000023,
            "violence": 0.001234
          }
        }
      ]
    }
  }
}
