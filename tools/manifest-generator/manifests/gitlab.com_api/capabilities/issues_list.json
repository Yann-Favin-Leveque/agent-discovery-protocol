{
  "name": "issues_list",
  "description": "List issues for a project with filtering by state, labels, assignee, and more.",
  "resource_group": "issues",
  "endpoint": "/projects/{id}/issues",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or path.",
      "in": "path"
    },
    {
      "name": "state",
      "type": "string",
      "required": false,
      "description": "Filter: opened, closed, all.",
      "in": "query"
    },
    {
      "name": "labels",
      "type": "string",
      "required": false,
      "description": "Comma-separated label names.",
      "in": "query"
    },
    {
      "name": "assignee_id",
      "type": "integer",
      "required": false,
      "description": "Filter by assignee user ID.",
      "in": "query"
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "description": "Search in title and description.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gitlab.com/api/v4/projects/123/issues?state=opened&labels=bug",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "iid": 10,
        "title": "Login page crashes",
        "state": "opened",
        "labels": [
          "bug"
        ],
        "assignee": {
          "username": "octocat"
        },
        "web_url": "https://gitlab.com/octocat/my-project/-/issues/10"
      }
    ]
  }
}
