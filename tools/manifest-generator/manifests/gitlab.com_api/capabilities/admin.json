{
  "name": "admin",
  "description": "Manage admin — retrieve dictionary details. Supports standard CRUD operations through the REST API.",
  "endpoint": "/admin/databases/{database_name}/dictionary/tables/{table_name}",
  "method": "GET",
  "parameters": [
    {
      "name": "database_name",
      "type": "string",
      "description": "The database name",
      "required": true,
      "example": "main"
    },
    {
      "name": "table_name",
      "type": "string",
      "description": "The table name",
      "required": true,
      "example": "Example"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.gitlab.com/api/v4/admin/databases/{database_name}/dictionary/tables/{table_name}",
    "headers": {
      "Content-Type": "application/json",
      "Private-Token": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "database_name": "main",
        "table_name": "Example"
      }
    }
  }
}
