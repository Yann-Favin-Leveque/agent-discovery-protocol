{
  "name": "branches",
  "description": "Manage branches — create branch, unprotect a single branch, protect a single branch. Supports standard CRUD operations through the REST API.",
  "endpoint": "/projects/{id}/repository/branches",
  "method": "POST",
  "parameters": [
    {
      "name": "branch",
      "type": "string",
      "description": "The name of the branch",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "ref",
      "type": "string",
      "description": "Create branch from commit sha or existing branch",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.gitlab.com/api/v4/projects/{id}/repository/branches",
    "headers": {
      "Content-Type": "application/json",
      "Private-Token": "{api_key}"
    },
    "body": {
      "branch": "example_value",
      "ref": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "branch": "example_value",
        "ref": "example_value"
      }
    }
  }
}
