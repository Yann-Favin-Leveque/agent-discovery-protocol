{
  "name": "batched_background_migrations",
  "description": "Manage batched background migrations — resume a batched background migration, pause a batched background migration, get the list of batched background migrations. Supports standard CRUD operations through the REST API.",
  "endpoint": "/admin/batched_background_migrations/{id}/resume",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "number",
      "description": "The batched background migration id",
      "required": true,
      "example": 42
    },
    {
      "name": "database",
      "type": "string",
      "description": "The name of the database",
      "required": false,
      "example": "main"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://www.gitlab.com/api/v4/admin/batched_background_migrations/{id}/resume",
    "headers": {
      "Content-Type": "application/json",
      "Private-Token": "{api_key}"
    },
    "body": {
      "id": 42
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "id": 42
      }
    }
  }
}
