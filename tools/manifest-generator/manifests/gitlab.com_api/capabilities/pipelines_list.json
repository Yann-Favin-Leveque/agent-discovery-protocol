{
  "name": "pipelines_list",
  "description": "List CI/CD pipelines for a project with optional filtering.",
  "resource_group": "pipelines",
  "endpoint": "/projects/{id}/pipelines",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or path."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter: created, waiting_for_resource, preparing, pending, running, success, failed, canceled, skipped, manual, scheduled."
    },
    {
      "name": "ref",
      "type": "string",
      "required": false,
      "description": "Filter by branch or tag."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gitlab.com/api/v4/projects/123/pipelines?status=failed&per_page=5",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1001,
        "iid": 50,
        "status": "failed",
        "ref": "main",
        "sha": "abc123",
        "web_url": "https://gitlab.com/octocat/my-project/-/pipelines/1001",
        "created_at": "2026-02-28T10:00:00Z"
      }
    ]
  }
}