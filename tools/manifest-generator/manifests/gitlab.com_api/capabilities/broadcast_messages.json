{
  "name": "broadcast_messages",
  "description": "Manage broadcast messages — create a broadcast message, update a broadcast message, get all broadcast messages. Supports standard CRUD operations through the REST API.",
  "endpoint": "/broadcast_messages",
  "method": "POST",
  "parameters": [
    {
      "name": "message",
      "type": "string",
      "description": "Message to display",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "starts_at",
      "type": "string",
      "description": "Starting time",
      "required": false,
      "example": "example_value"
    },
    {
      "name": "ends_at",
      "type": "string",
      "description": "Ending time",
      "required": false,
      "example": "example_value"
    },
    {
      "name": "color",
      "type": "string",
      "description": "Background color",
      "required": false,
      "example": "example_value"
    },
    {
      "name": "font",
      "type": "string",
      "description": "Foreground color",
      "required": false,
      "example": "example_value"
    },
    {
      "name": "target_access_levels",
      "type": "integer[]",
      "description": "Target user roles",
      "required": false,
      "example": []
    },
    {
      "name": "target_path",
      "type": "string",
      "description": "Target path",
      "required": false,
      "example": "example_value"
    },
    {
      "name": "broadcast_type",
      "type": "string",
      "description": "Broadcast type. Defaults to banner",
      "required": false,
      "example": "banner"
    },
    {
      "name": "dismissable",
      "type": "boolean",
      "description": "Is dismissable",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.gitlab.com/api/v4/broadcast_messages",
    "headers": {
      "Content-Type": "application/json",
      "Private-Token": "{api_key}"
    },
    "body": {
      "message": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "message": "example_value"
      }
    }
  }
}
