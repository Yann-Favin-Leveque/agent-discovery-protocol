{
  "name": "releases_list",
  "description": "List releases for a project.",
  "resource_group": "releases",
  "endpoint": "/projects/{id}/releases",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or path.",
      "in": "path"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gitlab.com/api/v4/projects/123/releases",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "tag_name": "v2.0.0",
        "name": "v2.0.0",
        "description": "## What's New\n- Dark mode",
        "created_at": "2026-02-28T10:00:00Z",
        "released_at": "2026-02-28T10:00:00Z"
      }
    ]
  }
}
