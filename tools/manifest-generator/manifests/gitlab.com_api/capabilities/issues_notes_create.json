{
  "name": "issues_notes_create",
  "description": "Create a comment (note) on an issue.",
  "resource_group": "issues",
  "endpoint": "/projects/{id}/issues/{issue_iid}/notes",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or path.",
      "in": "path"
    },
    {
      "name": "issue_iid",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "Issue IID.",
      "in": "path"
    },
    {
      "name": "body",
      "type": "string",
      "required": true,
      "description": "Note body (Markdown).",
      "in": "body"
    },
    {
      "name": "confidential",
      "type": "boolean",
      "required": false,
      "description": "Make note confidential.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gitlab.com/api/v4/projects/123/issues/10/notes",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    },
    "body": {
      "body": "Fixed in !42. Closing."
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 100,
      "body": "Fixed in !42. Closing.",
      "author": {
        "username": "octocat"
      },
      "created_at": "2026-03-01T09:00:00Z"
    }
  }
}
