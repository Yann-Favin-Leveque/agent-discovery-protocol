{
  "name": "issues_get",
  "description": "Get a specific issue by its IID.",
  "resource_group": "issues",
  "endpoint": "/projects/{id}/issues/{issue_iid}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or path.",
      "in": "path"
    },
    {
      "name": "issue_iid",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "Issue internal ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gitlab.com/api/v4/projects/123/issues/10",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "iid": 10,
      "title": "Login page crashes",
      "description": "Steps to reproduce...",
      "state": "opened",
      "labels": [
        "bug"
      ],
      "milestone": {
        "title": "v2.0"
      },
      "weight": 3
    }
  }
}
