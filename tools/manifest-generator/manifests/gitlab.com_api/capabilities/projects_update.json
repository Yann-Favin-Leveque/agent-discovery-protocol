{
  "name": "projects_update",
  "description": "Update a project's settings.",
  "resource_group": "projects",
  "endpoint": "/projects/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or URL-encoded path."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name."
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Updated description."
    },
    {
      "name": "visibility",
      "type": "string",
      "required": false,
      "description": "Updated visibility."
    },
    {
      "name": "default_branch",
      "type": "string",
      "required": false,
      "description": "Change default branch."
    },
    {
      "name": "archived",
      "type": "boolean",
      "required": false,
      "description": "Archive or unarchive."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://gitlab.com/api/v4/projects/123",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    },
    "body": {
      "description": "Updated description"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 123,
      "name": "my-project",
      "description": "Updated description"
    }
  }
}