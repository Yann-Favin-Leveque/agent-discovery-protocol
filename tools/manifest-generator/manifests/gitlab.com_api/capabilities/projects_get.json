{
  "name": "projects_get",
  "description": "Get detailed information about a specific project by ID or URL-encoded path.",
  "resource_group": "projects",
  "endpoint": "/projects/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or URL-encoded path (e.g., 'octocat%2Fmy-project').",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gitlab.com/api/v4/projects/123",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 123,
      "name": "my-project",
      "path_with_namespace": "octocat/my-project",
      "description": "Sample project",
      "default_branch": "main",
      "web_url": "https://gitlab.com/octocat/my-project",
      "star_count": 5,
      "open_issues_count": 3
    }
  }
}
