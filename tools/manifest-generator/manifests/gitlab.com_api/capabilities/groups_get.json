{
  "name": "groups_get",
  "description": "Get details of a specific group.",
  "resource_group": "groups",
  "endpoint": "/groups/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Group ID or URL-encoded path."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gitlab.com/api/v4/groups/10",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 10,
      "name": "my-org",
      "path": "my-org",
      "full_path": "my-org",
      "description": "My organization",
      "visibility": "private",
      "projects": [
        {
          "id": 123,
          "name": "my-project"
        }
      ]
    }
  }
}