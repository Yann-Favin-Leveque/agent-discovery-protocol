{
  "name": "merge_requests_list",
  "description": "List merge requests for a project with optional filtering.",
  "resource_group": "merge_requests",
  "endpoint": "/projects/{id}/merge_requests",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or URL-encoded path.",
      "in": "path"
    },
    {
      "name": "state",
      "type": "string",
      "required": false,
      "description": "Filter: opened, closed, merged, all.",
      "in": "query"
    },
    {
      "name": "labels",
      "type": "string",
      "required": false,
      "description": "Comma-separated label names.",
      "in": "query"
    },
    {
      "name": "author_id",
      "type": "integer",
      "required": false,
      "description": "Filter by author user ID.",
      "in": "query"
    },
    {
      "name": "assignee_id",
      "type": "integer",
      "required": false,
      "description": "Filter by assignee user ID.",
      "in": "query"
    },
    {
      "name": "target_branch",
      "type": "string",
      "required": false,
      "description": "Filter by target branch.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gitlab.com/api/v4/projects/123/merge_requests?state=opened&per_page=10",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "iid": 42,
        "title": "Add dark mode",
        "state": "opened",
        "source_branch": "feature/dark-mode",
        "target_branch": "main",
        "author": {
          "username": "octocat"
        },
        "web_url": "https://gitlab.com/octocat/my-project/-/merge_requests/42",
        "created_at": "2026-02-28T10:00:00Z"
      }
    ]
  }
}
