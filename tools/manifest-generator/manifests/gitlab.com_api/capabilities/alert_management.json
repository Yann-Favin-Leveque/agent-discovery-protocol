{
  "name": "alert_management",
  "description": "Manage alert management — upload a metric image for an alert, workhorse authorize metric image file upload, update a metric image for an alert. Supports standard CRUD operations through the REST API.",
  "endpoint": "/projects/{id}/alert_management_alerts/{alert_iid}/metric_images",
  "method": "POST",
  "parameters": [
    {
      "name": "alert_iid",
      "type": "number",
      "description": "The IID of the Alert",
      "required": true,
      "example": 42
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.gitlab.com/api/v4/projects/{id}/alert_management_alerts/{alert_iid}/metric_images",
    "headers": {
      "Content-Type": "application/json",
      "Private-Token": "{api_key}"
    },
    "body": {
      "alert_iid": 42
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "alert_iid": 42
      }
    }
  }
}
