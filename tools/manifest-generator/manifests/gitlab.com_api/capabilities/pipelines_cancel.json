{
  "name": "pipelines_cancel",
  "description": "Cancel a running or pending pipeline.",
  "resource_group": "pipelines",
  "endpoint": "/projects/{id}/pipelines/{pipeline_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or path.",
      "in": "path"
    },
    {
      "name": "pipeline_id",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "Pipeline ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gitlab.com/api/v4/projects/123/pipelines/1001/cancel",
    "headers": {
      "Authorization": "Bearer glpat-xxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1001,
      "status": "canceled"
    }
  }
}
