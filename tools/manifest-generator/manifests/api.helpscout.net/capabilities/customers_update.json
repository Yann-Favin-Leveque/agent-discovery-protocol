{
  "name": "customers_update",
  "description": "Update a customer's profile information.",
  "endpoint": "/v2/customers/{id}",
  "method": "PATCH",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Customer ID.",
      "required": true,
      "example": 1
    },
    {
      "name": "firstName",
      "type": "string",
      "description": "Updated first name.",
      "required": false,
      "example": "Janet"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.helpscout.net/v2/customers/1",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "firstName": "Janet"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}