{
  "name": "teams_members_list",
  "description": "List all members of a specific team.",
  "endpoint": "/v2/teams/{id}/members",
  "method": "GET",
  "resource_group": "teams",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Team ID.",
      "required": true,
      "example": 1,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/teams/1/members",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "users": [
          {
            "id": 100,
            "firstName": "Agent",
            "lastName": "Smith"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
