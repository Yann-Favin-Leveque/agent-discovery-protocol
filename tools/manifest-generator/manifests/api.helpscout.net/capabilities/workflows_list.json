{
  "name": "workflows_list",
  "description": "List all workflows in your account.",
  "endpoint": "/v2/workflows",
  "method": "GET",
  "resource_group": "workflows",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/workflows?page=1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "workflows": [
          {
            "id": 1,
            "name": "Auto-assign billing",
            "type": "automatic",
            "status": "active"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
