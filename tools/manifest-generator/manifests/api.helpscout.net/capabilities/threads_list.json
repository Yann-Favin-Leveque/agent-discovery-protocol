{
  "name": "threads_list",
  "description": "List all threads in a conversation.",
  "endpoint": "/v2/conversations/{id}/threads",
  "method": "GET",
  "resource_group": "threads",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Conversation ID.",
      "required": true,
      "example": 123,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/conversations/123/threads",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "threads": [
          {
            "id": 1,
            "type": "customer",
            "body": "I need help.",
            "createdAt": "2024-01-15T10:00:00Z"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
