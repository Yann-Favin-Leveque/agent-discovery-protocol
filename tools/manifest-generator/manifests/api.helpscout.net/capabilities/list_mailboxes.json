{
  "name": "list_mailboxes",
  "description": "Retrieve all mailboxes (shared inboxes) in your Help Scout account. Mailboxes represent different support channels or teams. Returns mailbox name, email address, and folder configuration.",
  "endpoint": "/v2/mailboxes",
  "method": "GET",
  "parameters": [
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/mailboxes?page=1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "mailboxes": [
          {
            "id": 1234,
            "name": "General Support",
            "slug": "general-support",
            "email": "support@company.com",
            "createdAt": "2024-01-01T08:00:00Z",
            "updatedAt": "2025-01-10T12:00:00Z"
          }
        ]
      },
      "page": { "size": 25, "totalElements": 1, "totalPages": 1, "number": 1 }
    }
  }
}
