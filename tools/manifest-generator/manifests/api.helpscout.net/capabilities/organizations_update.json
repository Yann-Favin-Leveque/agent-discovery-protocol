{
  "name": "organizations_update",
  "description": "Update an organization.",
  "endpoint": "/v2/organizations/{id}",
  "method": "PATCH",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Organization ID.",
      "required": true,
      "example": 1,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "Acme Inc",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.helpscout.net/v2/organizations/1",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Inc"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
