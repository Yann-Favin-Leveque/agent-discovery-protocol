{
  "name": "list_conversations",
  "description": "Retrieve all conversations across your Help Scout mailboxes. Conversations are threaded customer interactions (like email threads). Supports filtering by mailbox, status, assignee, tags, and date range.",
  "endpoint": "/v2/conversations",
  "method": "GET",
  "parameters": [
    { "name": "mailbox", "type": "integer", "description": "Filter conversations by mailbox ID.", "required": false, "example": 1234 },
    { "name": "status", "type": "string", "description": "Filter by status: 'active', 'pending', 'closed', 'spam', or 'all'.", "required": false, "example": "active" },
    { "name": "assigned_to", "type": "integer", "description": "Filter by assigned user (agent) ID.", "required": false, "example": 100 },
    { "name": "tag", "type": "string", "description": "Filter by tag name.", "required": false, "example": "billing" },
    { "name": "modifiedSince", "type": "string", "description": "Return conversations modified after this date (ISO 8601).", "required": false, "example": "2025-01-01T00:00:00Z" },
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/conversations?status=active&mailbox=1234&page=1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "conversations": [
          {
            "id": 5001,
            "number": 1234,
            "subject": "Issue with account billing",
            "status": "active",
            "mailboxId": 1234,
            "assignee": { "id": 100, "first": "Agent", "last": "Smith" },
            "primaryCustomer": { "id": 2001, "email": "customer@example.com" },
            "createdAt": "2025-01-15T10:30:00Z",
            "tags": [{ "id": 1, "tag": "billing" }]
          }
        ]
      },
      "page": { "size": 25, "totalElements": 1, "totalPages": 1, "number": 1 }
    }
  }
}
