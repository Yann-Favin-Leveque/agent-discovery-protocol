{
  "name": "reports_productivity",
  "description": "Retrieve productivity metrics including first response and resolution times.",
  "endpoint": "/v2/reports/productivity",
  "method": "GET",
  "resource_group": "reports",
  "parameters": [
    {
      "name": "start",
      "type": "string",
      "description": "Start date.",
      "required": true,
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "end",
      "type": "string",
      "description": "End date.",
      "required": true,
      "example": "2024-12-31T23:59:59Z"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/reports/productivity?start=2024-01-01T00:00:00Z&end=2024-12-31T23:59:59Z",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "current": {
        "firstResponseTime": {
          "median": 1800
        },
        "resolutionTime": {
          "median": 7200
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}