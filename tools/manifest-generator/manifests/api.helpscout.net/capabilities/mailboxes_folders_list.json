{
  "name": "mailboxes_folders_list",
  "description": "List all folders in a mailbox.",
  "endpoint": "/v2/mailboxes/{id}/folders",
  "method": "GET",
  "resource_group": "mailboxes",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Mailbox ID.",
      "required": true,
      "example": 12345
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/mailboxes/12345/folders",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "folders": [
          {
            "id": 1,
            "name": "Unassigned",
            "type": "open",
            "activeCount": 10
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}