{
  "name": "organizations_create",
  "description": "Create a new organization.",
  "endpoint": "/v2/organizations",
  "method": "POST",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Organization name.",
      "required": true,
      "example": "Acme Corp",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.helpscout.net/v2/organizations",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Corp"
    }
  },
  "response_example": {
    "status": 201,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
