{
  "name": "mailboxes_list",
  "description": "List all mailboxes (shared inboxes) in your account.",
  "endpoint": "/v2/mailboxes",
  "method": "GET",
  "resource_group": "mailboxes",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/mailboxes",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "mailboxes": [
          {
            "id": 12345,
            "name": "Support",
            "email": "support@example.com"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}