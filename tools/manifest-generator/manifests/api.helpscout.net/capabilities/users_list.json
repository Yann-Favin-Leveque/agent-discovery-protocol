{
  "name": "users_list",
  "description": "List all users in your Help Scout account.",
  "endpoint": "/v2/users",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/users?page=1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "users": [
          {
            "id": 100,
            "firstName": "Agent",
            "lastName": "Smith",
            "email": "agent@example.com"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}