{
  "name": "customers_list",
  "description": "List all customers with their contact information.",
  "endpoint": "/v2/customers",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "query",
      "type": "string",
      "description": "Search query.",
      "required": false,
      "example": "john@example.com",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/customers?page=1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "customers": [
          {
            "id": 1,
            "firstName": "John",
            "lastName": "Doe",
            "emails": [
              {
                "value": "john@example.com"
              }
            ]
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
