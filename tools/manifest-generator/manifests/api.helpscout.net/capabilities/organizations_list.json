{
  "name": "organizations_list",
  "description": "List all organizations.",
  "endpoint": "/v2/organizations",
  "method": "GET",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/organizations?page=1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "organizations": [
          {
            "id": 1,
            "name": "Acme Corp"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}