{
  "name": "users_me",
  "description": "Retrieve the currently authenticated user's profile.",
  "endpoint": "/v2/users/me",
  "method": "GET",
  "resource_group": "users",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/users/me",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 100,
      "firstName": "Agent",
      "lastName": "Smith",
      "email": "agent@example.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}