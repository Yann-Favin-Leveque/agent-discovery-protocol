    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/organizations/1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "name": "Acme Corp"
    }
  },
