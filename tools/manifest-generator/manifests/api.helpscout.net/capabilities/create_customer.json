{
  "name": "create_customer",
  "description": "Create a new customer profile in Help Scout. Customers are automatically linked to conversations by their email address. You can add multiple emails, phones, and social profiles to a single customer record.",
  "endpoint": "/v2/customers",
  "method": "POST",
  "parameters": [
    { "name": "firstName", "type": "string", "description": "Customer's first name.", "required": true, "example": "John" },
    { "name": "lastName", "type": "string", "description": "Customer's last name.", "required": true, "example": "Doe" },
    { "name": "emails", "type": "array", "description": "Array of email objects with 'type' ('work' or 'home') and 'value'.", "required": false, "example": [{ "type": "work", "value": "john.doe@example.com" }] },
    { "name": "phones", "type": "array", "description": "Array of phone objects with 'type' and 'value'.", "required": false, "example": [{ "type": "work", "value": "+1-555-987-6543" }] },
    { "name": "organization", "type": "string", "description": "The company or organization name.", "required": false, "example": "Acme Corp" },
    { "name": "jobTitle", "type": "string", "description": "The customer's job title.", "required": false, "example": "VP of Engineering" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.helpscout.net/v2/customers",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "firstName": "John",
      "lastName": "Doe",
      "emails": [{ "type": "work", "value": "john.doe@example.com" }],
      "phones": [{ "type": "work", "value": "+1-555-987-6543" }],
      "organization": "Acme Corp",
      "jobTitle": "VP of Engineering"
    }
  },
  "response_example": {
    "status": 201,
    "headers": {
      "Resource-ID": "2002",
      "Location": "https://api.helpscout.net/v2/customers/2002"
    },
    "body": {}
  }
}
