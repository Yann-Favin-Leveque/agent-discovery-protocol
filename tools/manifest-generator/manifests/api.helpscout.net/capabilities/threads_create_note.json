{
  "name": "threads_create_note",
  "description": "Add an internal note to a conversation visible only to agents.",
  "endpoint": "/v2/conversations/{id}/notes",
  "method": "POST",
  "resource_group": "threads",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Conversation ID.",
      "required": true,
      "example": 123
    },
    {
      "name": "text",
      "type": "string",
      "description": "Note body (HTML).",
      "required": true,
      "example": "<p>Customer is a VIP.</p>"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.helpscout.net/v2/conversations/123/notes",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "text": "<p>Customer is a VIP.</p>"
    }
  },
  "response_example": {
    "status": 201,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}