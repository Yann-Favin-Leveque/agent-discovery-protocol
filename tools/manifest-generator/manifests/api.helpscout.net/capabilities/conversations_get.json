{
  "name": "conversations_get",
  "description": "Retrieve a specific conversation by ID with all its details.",
  "endpoint": "/v2/conversations/{id}",
  "method": "GET",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Conversation ID.",
      "required": true,
      "example": 123
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/conversations/123",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 123,
      "number": 456,
      "subject": "Help with billing",
      "status": "active",
      "assignee": {
        "id": 100,
        "email": "agent@example.com"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}