{
  "name": "mailboxes_get",
  "description": "Retrieve a specific mailbox by ID.",
  "endpoint": "/v2/mailboxes/{id}",
  "method": "GET",
  "resource_group": "mailboxes",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Mailbox ID.",
      "required": true,
      "example": 12345,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/mailboxes/12345",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345,
      "name": "Support",
      "email": "support@example.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
