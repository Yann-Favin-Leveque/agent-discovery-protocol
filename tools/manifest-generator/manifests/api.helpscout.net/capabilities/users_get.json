{
  "name": "users_get",
  "description": "Retrieve a specific user by ID.",
  "endpoint": "/v2/users/{id}",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "User ID.",
      "required": true,
      "example": 100,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/users/100",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 100,
      "firstName": "Agent",
      "lastName": "Smith",
      "email": "agent@example.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
