{
  "name": "webhooks_create",
  "description": "Create a new webhook subscription for event notifications.",
  "endpoint": "/v2/webhooks",
  "method": "POST",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "description": "URL to receive payloads.",
      "required": true,
      "example": "https://example.com/webhook"
    },
    {
      "name": "events",
      "type": "array",
      "description": "Event types to subscribe to.",
      "required": true,
      "example": [
        "convo.created",
        "convo.assigned"
      ]
    },
    {
      "name": "secret",
      "type": "string",
      "description": "Secret for HMAC verification.",
      "required": true,
      "example": "mysecret123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.helpscout.net/v2/webhooks",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://example.com/webhook",
      "events": [
        "convo.created"
      ],
      "secret": "mysecret123"
    }
  },
  "response_example": {
    "status": 201,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}