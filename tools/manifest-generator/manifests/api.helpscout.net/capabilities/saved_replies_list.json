{
  "name": "saved_replies_list",
  "description": "List all saved replies for a mailbox.",
  "endpoint": "/v2/mailboxes/{id}/saved-replies",
  "method": "GET",
  "resource_group": "saved_replies",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Mailbox ID.",
      "required": true,
      "example": 12345
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/mailboxes/12345/saved-replies",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "saved-replies": [
          {
            "id": 1,
            "name": "Welcome reply",
            "text": "<p>Welcome!</p>"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}