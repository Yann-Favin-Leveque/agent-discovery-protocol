{
  "name": "mailboxes_custom_fields_list",
  "description": "List custom fields configured for a mailbox.",
  "endpoint": "/v2/mailboxes/{id}/fields",
  "method": "GET",
  "resource_group": "mailboxes",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Mailbox ID.",
      "required": true,
      "example": 12345
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/mailboxes/12345/fields",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "fields": [
          {
            "id": 1,
            "name": "Priority",
            "type": "dropdown",
            "options": [
              "low",
              "medium",
              "high"
            ]
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}