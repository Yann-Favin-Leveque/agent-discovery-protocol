{
  "name": "webhooks_list",
  "description": "List all webhook subscriptions.",
  "endpoint": "/v2/webhooks",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/webhooks",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_embedded": {
        "webhooks": [
          {
            "id": 1,
            "url": "https://example.com/webhook",
            "events": [
              "convo.created"
            ]
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}