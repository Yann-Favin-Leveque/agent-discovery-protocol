{
  "name": "conversations_update_custom_fields",
  "description": "Update custom field values on a conversation.",
  "endpoint": "/v2/conversations/{id}/fields",
  "method": "PUT",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Conversation ID.",
      "required": true,
      "example": 123,
      "in": "path"
    },
    {
      "name": "fields",
      "type": "array",
      "description": "Custom field values.",
      "required": true,
      "example": [
        {
          "id": 1,
          "value": "premium"
        }
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.helpscout.net/v2/conversations/123/fields",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "fields": [
        {
          "id": 1,
          "value": "premium"
        }
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
