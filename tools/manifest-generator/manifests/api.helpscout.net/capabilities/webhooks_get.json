{
  "name": "webhooks_get",
  "description": "Retrieve a specific webhook by ID.",
  "endpoint": "/v2/webhooks/{id}",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Webhook ID.",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/webhooks/1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "url": "https://example.com/webhook",
      "events": [
        "convo.created"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}