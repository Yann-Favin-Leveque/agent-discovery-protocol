{
  "name": "customers_get",
  "description": "Retrieve a specific customer by ID.",
  "endpoint": "/v2/customers/{id}",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Customer ID.",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.helpscout.net/v2/customers/1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "firstName": "John",
      "lastName": "Doe",
      "emails": [
        {
          "value": "john@example.com"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}