{
  "name": "conversations_update_tags",
  "description": "Update the tags on a conversation.",
  "endpoint": "/v2/conversations/{id}/tags",
  "method": "PUT",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Conversation ID.",
      "required": true,
      "example": 123,
      "in": "path"
    },
    {
      "name": "tags",
      "type": "array",
      "description": "Tag names to set.",
      "required": true,
      "example": [
        "billing",
        "urgent"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.helpscout.net/v2/conversations/123/tags",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "tags": [
        "billing",
        "urgent"
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
