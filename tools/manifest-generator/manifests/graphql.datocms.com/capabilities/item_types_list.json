{
  "name": "item_types_list",
  "description": "List all content models (item types) defined in the DatoCMS project, including their field definitions, relationships, and configuration flags.",
  "resource_group": "item_types",
  "endpoint": "/item-types",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://site-api.datocms.com/item-types",
    "headers": {
      "Authorization": "Bearer your-datocms-api-token",
      "Accept": "application/json",
      "X-Api-Version": "3"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "item_type",
          "id": "article",
          "attributes": {
            "name": "Article",
            "api_key": "article",
            "singleton": false,
            "sortable": false,
            "modular_block": false,
            "tree": false,
            "draft_mode_active": true,
            "collection_appearance": "table"
          },
          "relationships": {
            "fields": {
              "data": [
                { "type": "field", "id": "title_field_id" },
                { "type": "field", "id": "content_field_id" }
              ]
            }
          }
        }
      ]
    }
  }
}
