{
  "name": "items_update",
  "description": "Update an existing content record by its ID. Omitted fields remain unchanged. Explicitly setting a field to null clears it. For localized fields, provide the complete locale object.",
  "resource_group": "items",
  "endpoint": "/items/{item_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "item_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The unique record ID."
    },
    {
      "name": "data.attributes",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "Field values to update. Omitted fields are preserved; null clears a field."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://site-api.datocms.com/items/hWl-mnkWRYmMCSTq4z_piQ",
    "headers": {
      "Authorization": "Bearer your-datocms-api-token",
      "Content-Type": "application/vnd.api+json",
      "Accept": "application/json",
      "X-Api-Version": "3"
    },
    "body": {
      "data": {
        "type": "item",
        "id": "hWl-mnkWRYmMCSTq4z_piQ",
        "attributes": {
          "title": "Updated Title"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "item",
        "id": "hWl-mnkWRYmMCSTq4z_piQ",
        "attributes": {
          "title": "Updated Title",
          "content": "Existing content unchanged...",
          "_updated_at": "2026-03-01T14:00:00.000Z"
        }
      }
    }
  }
}
