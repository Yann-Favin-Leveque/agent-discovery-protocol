{
  "name": "uploads_delete",
  "description": "Permanently delete an uploaded media asset by its ID.",
  "resource_group": "uploads",
  "endpoint": "/uploads/{upload_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "upload_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The unique upload ID to delete.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://site-api.datocms.com/uploads/upload123",
    "headers": {
      "Authorization": "Bearer your-datocms-api-token",
      "Accept": "application/json",
      "X-Api-Version": "3"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "upload",
        "id": "upload123",
        "attributes": {
          "filename": "photo.jpg"
        }
      }
    }
  }
}
