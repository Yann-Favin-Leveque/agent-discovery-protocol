{
  "name": "items_create",
  "description": "Create a new content record for a given model type. Provide field values as attributes matching the model schema. Localized fields require an object with locale keys.",
  "resource_group": "items",
  "endpoint": "/items",
  "method": "POST",
  "parameters": [
    {
      "name": "data.type",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Must be 'item'.",
      "in": "body"
    },
    {
      "name": "data.relationships.item_type",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "Reference to the model: { data: { type: 'item_type', id: '<model_id>' } }.",
      "in": "body"
    },
    {
      "name": "data.attributes",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "Field values matching the model schema. Localized fields use { 'en': value, 'it': value } format.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://site-api.datocms.com/items",
    "headers": {
      "Authorization": "Bearer your-datocms-api-token",
      "Content-Type": "application/vnd.api+json",
      "Accept": "application/json",
      "X-Api-Version": "3"
    },
    "body": {
      "data": {
        "type": "item",
        "attributes": {
          "title": "New Article",
          "content": "Article body..."
        },
        "relationships": {
          "item_type": {
            "data": {
              "type": "item_type",
              "id": "article"
            }
          }
        }
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "type": "item",
        "id": "newGeneratedId123",
        "attributes": {
          "title": "New Article",
          "content": "Article body...",
          "_status": "draft",
          "_created_at": "2026-03-01T12:00:00.000Z"
        }
      }
    }
  }
}
