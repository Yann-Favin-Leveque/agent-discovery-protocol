{
  "name": "items_delete",
  "description": "Permanently delete a content record by its ID. Returns the deleted record's data before removal.",
  "resource_group": "items",
  "endpoint": "/items/{item_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "item_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The unique record ID to delete."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://site-api.datocms.com/items/hWl-mnkWRYmMCSTq4z_piQ",
    "headers": {
      "Authorization": "Bearer your-datocms-api-token",
      "Accept": "application/json",
      "X-Api-Version": "3"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "item",
        "id": "hWl-mnkWRYmMCSTq4z_piQ",
        "attributes": {
          "title": "Deleted Article"
        }
      }
    }
  }
}
