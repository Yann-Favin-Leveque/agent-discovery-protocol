{
  "name": "uploads_list",
  "description": "List all uploaded media assets with optional filtering by text search, field conditions, and offset-based pagination.",
  "resource_group": "uploads",
  "endpoint": "/uploads",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[ids]",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated upload IDs to fetch.",
      "in": "query"
    },
    {
      "name": "filter[query]",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Full-text search query on upload metadata.",
      "in": "query"
    },
    {
      "name": "filter[fields]",
      "type": "object",
      "required": false,
      "location": "query",
      "description": "GraphQL-style filter conditions on upload fields.",
      "in": "query"
    },
    {
      "name": "locale",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Locale for filtering when query/fields are used.",
      "in": "query"
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Sort field in format field_name_ASC or field_name_DESC.",
      "in": "query"
    },
    {
      "name": "page[offset]",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Zero-based offset for pagination. Default: 0.",
      "in": "query"
    },
    {
      "name": "page[limit]",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Maximum records per page. Default: 30, max: 500.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://site-api.datocms.com/uploads?page[limit]=20&page[offset]=0",
    "headers": {
      "Authorization": "Bearer your-datocms-api-token",
      "Accept": "application/json",
      "X-Api-Version": "3"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "upload",
          "id": "upload123",
          "attributes": {
            "filename": "photo.jpg",
            "url": "https://www.datocms-assets.com/12345/photo.jpg",
            "size": 245500,
            "width": 1920,
            "height": 1080,
            "is_image": true,
            "mime_type": "image/jpeg",
            "format": "jpg",
            "tags": [
              "hero",
              "landscape"
            ],
            "created_at": "2026-02-28T10:00:00.000Z"
          }
        }
      ],
      "meta": {
        "total_count": 150
      }
    }
  }
}
