{
  "name": "quotes_get",
  "description": "Retrieve details of an existing quote.",
  "resource_group": "quotes",
  "endpoint": "/v3/profiles/{profileId}/quotes/{quoteId}",
  "method": "GET",
  "parameters": [
    {
      "name": "profileId",
      "type": "integer",
      "description": "Profile ID.",
      "required": true
    },
    {
      "name": "quoteId",
      "type": "string",
      "description": "Quote ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v3/profiles/12345/quotes/q-abc123",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "q-abc123",
      "sourceCurrency": "USD",
      "targetCurrency": "EUR"
    }
  }
}