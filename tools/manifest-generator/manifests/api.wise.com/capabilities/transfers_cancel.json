{
  "name": "transfers_cancel",
  "description": "Cancel a transfer that has not yet been funded.",
  "resource_group": "transfers",
  "endpoint": "/v1/transfers/{transferId}/cancel",
  "method": "PUT",
  "parameters": [
    {
      "name": "transferId",
      "type": "integer",
      "description": "Transfer ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.wise.com/v1/transfers/468956/cancel",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 468956,
      "status": "cancelled"
    }
  }
}