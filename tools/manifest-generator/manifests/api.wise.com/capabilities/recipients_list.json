{
  "name": "recipients_list",
  "description": "List all recipient accounts for a profile, optionally filtered by currency.",
  "resource_group": "recipients",
  "endpoint": "/v1/accounts",
  "method": "GET",
  "parameters": [
    {
      "name": "profile",
      "type": "integer",
      "description": "Profile ID.",
      "required": true
    },
    {
      "name": "currency",
      "type": "string",
      "description": "Filter by currency.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v1/accounts?profile=12345",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 13967839,
        "accountHolderName": "Jane Smith",
        "currency": "EUR"
      }
    ]
  }
}