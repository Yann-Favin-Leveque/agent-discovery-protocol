{
  "name": "currencies_list",
  "description": "List all currencies supported by Wise.",
  "resource_group": "currencies",
  "endpoint": "/v1/currencies",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v1/currencies",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "code": "EUR",
        "name": "Euro",
        "symbol": "\u20ac"
      },
      {
        "code": "USD",
        "name": "US Dollar",
        "symbol": "$"
      }
    ]
  }
}