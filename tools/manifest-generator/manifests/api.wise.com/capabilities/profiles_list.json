{
  "name": "profiles_list",
  "description": "List all profiles (personal and business) for the authenticated user.",
  "resource_group": "profiles",
  "endpoint": "/v1/profiles",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v1/profiles",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 12345,
        "type": "personal",
        "details": {
          "firstName": "John",
          "lastName": "Doe"
        }
      },
      {
        "id": 67890,
        "type": "business",
        "details": {
          "name": "Acme Corp"
        }
      }
    ]
  }
}