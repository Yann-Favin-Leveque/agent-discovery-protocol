{
  "name": "transfers_get",
  "description": "Retrieve the details and status of a specific transfer.",
  "resource_group": "transfers",
  "endpoint": "/v1/transfers/{transferId}",
  "method": "GET",
  "parameters": [
    {
      "name": "transferId",
      "type": "integer",
      "description": "Transfer ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v1/transfers/468956",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 468956,
      "status": "outgoing_payment_sent"
    }
  }
}