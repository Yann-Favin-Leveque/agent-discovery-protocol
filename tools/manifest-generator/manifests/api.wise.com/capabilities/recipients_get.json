{
  "name": "recipients_get",
  "description": "Retrieve a specific recipient account.",
  "resource_group": "recipients",
  "endpoint": "/v1/accounts/{accountId}",
  "method": "GET",
  "parameters": [
    {
      "name": "accountId",
      "type": "integer",
      "description": "Recipient account ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v1/accounts/13967839",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 13967839,
      "accountHolderName": "Jane Smith"
    }
  }
}
