{
  "name": "balances_delete",
  "description": "Delete/close a balance account.",
  "resource_group": "balances",
  "endpoint": "/v4/profiles/{profileId}/balances/{balanceId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "profileId",
      "type": "integer",
      "description": "Profile ID.",
      "required": true
    },
    {
      "name": "balanceId",
      "type": "integer",
      "description": "Balance ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.wise.com/v4/profiles/12345/balances/5678",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200
  }
}