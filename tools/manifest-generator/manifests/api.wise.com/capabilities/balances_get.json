{
  "name": "balances_get",
  "description": "Retrieve a specific balance by ID.",
  "resource_group": "balances",
  "endpoint": "/v4/profiles/{profileId}/balances/{balanceId}",
  "method": "GET",
  "parameters": [
    {
      "name": "profileId",
      "type": "integer",
      "description": "Profile ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "balanceId",
      "type": "integer",
      "description": "Balance ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v4/profiles/12345/balances/1234",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1234,
      "currency": "EUR",
      "amount": {
        "value": 1050.5,
        "currency": "EUR"
      }
    }
  }
}
