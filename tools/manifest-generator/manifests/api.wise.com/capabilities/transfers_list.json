{
  "name": "transfers_list",
  "description": "List all transfers for a profile.",
  "resource_group": "transfers",
  "endpoint": "/v1/transfers",
  "method": "GET",
  "parameters": [
    {
      "name": "profile",
      "type": "integer",
      "description": "Profile ID.",
      "required": false
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "example": 10
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v1/transfers?profile=12345&limit=10",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 468956,
        "status": "outgoing_payment_sent"
      }
    ]
  }
}