{
  "name": "profiles_get",
  "description": "Retrieve a specific profile by ID.",
  "resource_group": "profiles",
  "endpoint": "/v1/profiles/{profileId}",
  "method": "GET",
  "parameters": [
    {
      "name": "profileId",
      "type": "integer",
      "description": "The profile ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.wise.com/v1/profiles/12345",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345,
      "type": "personal"
    }
  }
}