{
  "spec_version": "1.0",
  "name": "Typeform",
  "description": "Typeform is a conversational form and survey platform. Use this API to create forms, retrieve form definitions, collect and manage responses, manage workspaces, themes, and images.",
  "base_url": "https://api.typeform.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://admin.typeform.com/account#/section/tokens"
  },
  "capabilities": [
    {
      "name": "forms_list",
      "resource_group": "forms",
      "description": "List all forms in your account.",
      "detail_url": "/capabilities/forms_list"
    },
    {
      "name": "forms_create",
      "resource_group": "forms",
      "description": "Create a new form.",
      "detail_url": "/capabilities/forms_create"
    },
    {
      "name": "forms_get",
      "resource_group": "forms",
      "description": "Retrieve a form definition.",
      "detail_url": "/capabilities/forms_get"
    },
    {
      "name": "forms_update",
      "resource_group": "forms",
      "description": "Update an existing form.",
      "detail_url": "/capabilities/forms_update"
    },
    {
      "name": "forms_delete",
      "resource_group": "forms",
      "description": "Delete a form.",
      "detail_url": "/capabilities/forms_delete"
    },
    {
      "name": "responses_list",
      "resource_group": "responses",
      "description": "Retrieve responses for a form.",
      "detail_url": "/capabilities/responses_list"
    },
    {
      "name": "responses_delete",
      "resource_group": "responses",
      "description": "Delete responses for a form.",
      "detail_url": "/capabilities/responses_delete"
    },
    {
      "name": "workspaces_list",
      "resource_group": "workspaces",
      "description": "List workspaces.",
      "detail_url": "/capabilities/workspaces_list"
    },
    {
      "name": "workspaces_create",
      "resource_group": "workspaces",
      "description": "Create a workspace.",
      "detail_url": "/capabilities/workspaces_create"
    },
    {
      "name": "workspaces_get",
      "resource_group": "workspaces",
      "description": "Get workspace details.",
      "detail_url": "/capabilities/workspaces_get"
    },
    {
      "name": "workspaces_update",
      "resource_group": "workspaces",
      "description": "Update a workspace.",
      "detail_url": "/capabilities/workspaces_update"
    },
    {
      "name": "workspaces_delete",
      "resource_group": "workspaces",
      "description": "Delete a workspace.",
      "detail_url": "/capabilities/workspaces_delete"
    },
    {
      "name": "themes_list",
      "resource_group": "themes",
      "description": "List themes.",
      "detail_url": "/capabilities/themes_list"
    },
    {
      "name": "themes_create",
      "resource_group": "themes",
      "description": "Create a theme.",
      "detail_url": "/capabilities/themes_create"
    },
    {
      "name": "themes_get",
      "resource_group": "themes",
      "description": "Get theme details.",
      "detail_url": "/capabilities/themes_get"
    },
    {
      "name": "themes_update",
      "resource_group": "themes",
      "description": "Update a theme.",
      "detail_url": "/capabilities/themes_update"
    },
    {
      "name": "themes_delete",
      "resource_group": "themes",
      "description": "Delete a theme.",
      "detail_url": "/capabilities/themes_delete"
    },
    {
      "name": "images_list",
      "resource_group": "images",
      "description": "List uploaded images.",
      "detail_url": "/capabilities/images_list"
    },
    {
      "name": "images_create",
      "resource_group": "images",
      "description": "Upload a new image.",
      "detail_url": "/capabilities/images_create"
    },
    {
      "name": "images_get",
      "resource_group": "images",
      "description": "Get image details.",
      "detail_url": "/capabilities/images_get"
    },
    {
      "name": "images_delete",
      "resource_group": "images",
      "description": "Delete an image.",
      "detail_url": "/capabilities/images_delete"
    },
    {
      "name": "webhooks_get",
      "resource_group": "webhooks",
      "description": "Get webhook for a form.",
      "detail_url": "/capabilities/webhooks_get"
    },
    {
      "name": "webhooks_create",
      "resource_group": "webhooks",
      "description": "Create or update a webhook.",
      "detail_url": "/capabilities/webhooks_create"
    },
    {
      "name": "webhooks_delete",
      "resource_group": "webhooks",
      "description": "Delete a webhook.",
      "detail_url": "/capabilities/webhooks_delete"
    }
  ]
}