{
  "name": "images_create",
  "resource_group": "images",
  "description": "Upload a new image.",
  "endpoint": "/images",
  "method": "POST",
  "parameters": [
    {
      "name": "image",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Base64-encoded image data."
    },
    {
      "name": "file_name",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "File name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.typeform.com/images",
    "headers": {
      "Authorization": "Bearer {personal_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "image": "base64data...",
      "file_name": "logo.png"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "img-456",
      "src": "https://images.typeform.com/images/def"
    }
  }
}