{
  "name": "themes_get",
  "resource_group": "themes",
  "description": "Get theme details.",
  "endpoint": "/themes/{theme_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "theme_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Theme ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/themes/theme-123",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "theme-123",
      "name": "My Theme"
    }
  }
}