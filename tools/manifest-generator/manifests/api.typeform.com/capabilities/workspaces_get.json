{
  "name": "workspaces_get",
  "resource_group": "workspaces",
  "description": "Get workspace details.",
  "endpoint": "/workspaces/{workspace_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "workspace_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Workspace ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/workspaces/ws-123",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ws-123",
      "name": "My Workspace"
    }
  }
}