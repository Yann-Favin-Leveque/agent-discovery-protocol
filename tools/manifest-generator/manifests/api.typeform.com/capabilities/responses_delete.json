{
  "name": "responses_delete",
  "resource_group": "responses",
  "description": "Delete responses for a form by response IDs.",
  "endpoint": "/forms/{form_id}/responses",
  "method": "DELETE",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "included_response_ids",
      "type": "string",
      "required": true,
      "in": "query",
      "description": "Comma-separated response IDs to delete."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typeform.com/forms/abc123XYZ/responses?included_response_ids=resp-123,resp-456",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}