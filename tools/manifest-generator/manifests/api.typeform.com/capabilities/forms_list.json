{
  "name": "forms_list",
  "resource_group": "forms",
  "description": "List all forms in your Typeform account with pagination and search.",
  "endpoint": "/forms",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Page number. Default: 1."
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Forms per page. Default: 10, max: 200."
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Search by title."
    },
    {
      "name": "workspace_id",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Filter by workspace."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/forms?page=1&page_size=10",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_items": 24,
      "page_count": 3,
      "items": [
        {
          "id": "abc123XYZ",
          "title": "Customer Survey",
          "last_updated_at": "2025-01-15T10:30:00Z"
        }
      ]
    }
  }
}