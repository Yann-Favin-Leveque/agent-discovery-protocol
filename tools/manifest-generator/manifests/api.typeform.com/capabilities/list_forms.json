{
  "name": "list_forms",
  "description": "List all forms in your Typeform account. Returns form IDs, titles, last updated timestamps, and links. Results are paginated with a default page size of 10. Use this to find a specific form's ID before retrieving its details or responses. You can optionally search by keyword or filter by workspace.",
  "endpoint": "/forms",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination, starting at 1. Default: 1."
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "description": "Number of forms per page. Default: 10. Maximum: 200."
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "description": "Search keyword to filter forms by title."
    },
    {
      "name": "workspace_id",
      "type": "string",
      "required": false,
      "description": "Filter forms by workspace ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/forms?page=1&page_size=10",
    "headers": {
      "Authorization": "Bearer tfp_abc123def456ghi789"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_items": 24,
      "page_count": 3,
      "items": [
        {
          "id": "abc123XYZ",
          "title": "Customer Satisfaction Survey",
          "last_updated_at": "2025-01-15T10:30:00Z",
          "created_at": "2025-01-10T08:00:00Z",
          "self": {
            "href": "https://api.typeform.com/forms/abc123XYZ"
          },
          "_links": {
            "display": "https://form.typeform.com/to/abc123XYZ"
          }
        },
        {
          "id": "def456UVW",
          "title": "Employee Onboarding Questionnaire",
          "last_updated_at": "2025-01-14T16:45:00Z",
          "created_at": "2024-12-20T09:15:00Z",
          "self": {
            "href": "https://api.typeform.com/forms/def456UVW"
          },
          "_links": {
            "display": "https://form.typeform.com/to/def456UVW"
          }
        }
      ]
    }
  }
}
