{
  "name": "themes_list",
  "resource_group": "themes",
  "description": "List themes.",
  "endpoint": "/themes",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Page number."
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Themes per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/themes",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "theme-123",
          "name": "My Theme"
        }
      ]
    }
  }
}