{
  "name": "webhooks_delete",
  "resource_group": "webhooks",
  "description": "Delete a webhook.",
  "endpoint": "/forms/{form_id}/webhooks/{tag}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "tag",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Webhook tag name."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typeform.com/forms/abc123XYZ/webhooks/my-webhook",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}