{
  "name": "get_form",
  "description": "Retrieve the complete definition of a specific Typeform form by its ID. Returns all fields (questions) with their types, titles, properties, and validation rules, as well as the form's settings, theme, logic jumps, and thank-you screens. Use this to understand the structure of a form before retrieving or analyzing its responses.",
  "endpoint": "/forms/{form_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "required": true,
      "description": "The unique identifier of the form to retrieve."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/forms/abc123XYZ",
    "headers": {
      "Authorization": "Bearer tfp_abc123def456ghi789"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123XYZ",
      "title": "Customer Satisfaction Survey",
      "type": "quiz",
      "created_at": "2025-01-10T08:00:00Z",
      "last_updated_at": "2025-01-15T10:30:00Z",
      "settings": {
        "language": "en",
        "is_public": true,
        "progress_bar": "percentage",
        "show_progress_bar": true,
        "meta": {
          "allow_indexing": false
        }
      },
      "fields": [
        {
          "id": "field_001",
          "ref": "satisfaction_rating",
          "title": "How satisfied are you with our service?",
          "type": "opinion_scale",
          "properties": {
            "steps": 10,
            "start_at_one": true,
            "labels": {
              "left": "Not satisfied",
              "right": "Very satisfied"
            }
          },
          "validations": {
            "required": true
          }
        },
        {
          "id": "field_002",
          "ref": "feedback_text",
          "title": "What could we improve?",
          "type": "long_text",
          "properties": {},
          "validations": {
            "required": false
          }
        },
        {
          "id": "field_003",
          "ref": "recommend",
          "title": "Would you recommend us to a friend?",
          "type": "multiple_choice",
          "properties": {
            "choices": [
              { "id": "choice_01", "label": "Definitely" },
              { "id": "choice_02", "label": "Maybe" },
              { "id": "choice_03", "label": "Probably not" }
            ],
            "allow_multiple_selection": false,
            "randomize": false
          },
          "validations": {
            "required": true
          }
        }
      ],
      "_links": {
        "display": "https://form.typeform.com/to/abc123XYZ"
      }
    }
  }
}
