{
  "name": "forms_update",
  "resource_group": "forms",
  "description": "Update an existing form (replaces the entire form definition).",
  "endpoint": "/forms/{form_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "title",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Form title."
    },
    {
      "name": "fields",
      "type": "array",
      "required": false,
      "in": "body",
      "description": "Field definitions."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.typeform.com/forms/abc123XYZ",
    "headers": {
      "Authorization": "Bearer {personal_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Updated Survey",
      "fields": []
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123XYZ",
      "title": "Updated Survey"
    }
  }
}