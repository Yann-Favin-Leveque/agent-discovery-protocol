{
  "name": "forms_get",
  "resource_group": "forms",
  "description": "Retrieve the full definition of a form including all fields, logic, and settings.",
  "endpoint": "/forms/{form_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/forms/abc123XYZ",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123XYZ",
      "title": "My Survey",
      "fields": [
        {
          "id": "field1",
          "type": "short_text",
          "title": "What is your name?"
        }
      ]
    }
  }
}