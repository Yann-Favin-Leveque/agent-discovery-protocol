{
  "name": "forms_delete",
  "resource_group": "forms",
  "description": "Permanently delete a form and all its responses.",
  "endpoint": "/forms/{form_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.typeform.com/forms/abc123XYZ",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}