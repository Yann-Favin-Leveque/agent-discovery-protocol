{
  "name": "workspaces_create",
  "resource_group": "workspaces",
  "description": "Create a new workspace.",
  "endpoint": "/workspaces",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Workspace name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.typeform.com/workspaces",
    "headers": {
      "Authorization": "Bearer {personal_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "New Workspace"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "ws-456",
      "name": "New Workspace"
    }
  }
}