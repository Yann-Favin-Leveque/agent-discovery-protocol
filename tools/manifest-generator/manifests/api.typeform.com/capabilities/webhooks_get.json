{
  "name": "webhooks_get",
  "resource_group": "webhooks",
  "description": "Get webhook configuration for a form.",
  "endpoint": "/forms/{form_id}/webhooks/{tag}",
  "method": "GET",
  "parameters": [
    {
      "name": "form_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "tag",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Webhook tag name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/forms/abc123XYZ/webhooks/my-webhook",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "wh-123",
      "url": "https://example.com/webhook",
      "enabled": true
    }
  }
}