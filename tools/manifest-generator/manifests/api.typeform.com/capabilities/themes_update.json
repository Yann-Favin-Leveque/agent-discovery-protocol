{
  "name": "themes_update",
  "resource_group": "themes",
  "description": "Update a theme.",
  "endpoint": "/themes/{theme_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "theme_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Theme ID."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Theme name."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.typeform.com/themes/theme-123",
    "headers": {
      "Authorization": "Bearer {personal_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Theme"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "theme-123",
      "name": "Updated Theme"
    }
  }
}