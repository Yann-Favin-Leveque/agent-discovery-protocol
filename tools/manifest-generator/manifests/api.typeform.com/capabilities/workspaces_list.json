{
  "name": "workspaces_list",
  "resource_group": "workspaces",
  "description": "List all workspaces.",
  "endpoint": "/workspaces",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Page number."
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Search by name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/workspaces",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "ws-123",
          "name": "My Workspace"
        }
      ]
    }
  }
}