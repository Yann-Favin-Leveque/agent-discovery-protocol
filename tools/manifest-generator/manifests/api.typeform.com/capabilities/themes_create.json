{
  "name": "themes_create",
  "resource_group": "themes",
  "description": "Create a custom theme.",
  "endpoint": "/themes",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Theme name."
    },
    {
      "name": "colors",
      "type": "object",
      "required": false,
      "in": "body",
      "description": "Color configuration."
    },
    {
      "name": "font",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Font family."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.typeform.com/themes",
    "headers": {
      "Authorization": "Bearer {personal_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Brand Theme",
      "colors": {
        "question": "#000000",
        "answer": "#4FB0AE",
        "button": "#4FB0AE",
        "background": "#FFFFFF"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "theme-456",
      "name": "Brand Theme"
    }
  }
}