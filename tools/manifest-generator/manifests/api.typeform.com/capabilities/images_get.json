{
  "name": "images_get",
  "resource_group": "images",
  "description": "Get image details.",
  "endpoint": "/images/{image_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "image_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Image ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.typeform.com/images/img-123",
    "headers": {
      "Authorization": "Bearer {personal_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "img-123",
      "src": "https://images.typeform.com/images/abc"
    }
  }
}