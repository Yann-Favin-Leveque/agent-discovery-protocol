{
  "name": "update_opportunity",
  "description": "Update an opportunity's value, confidence, status, or pipeline stage in Close CRM.",
  "endpoint": "/opportunity/{opportunity_id}/",
  "method": "PUT",
  "parameters": [
    {"name": "opportunity_id", "type": "string", "description": "The ID of the opportunity to update.", "required": true, "example": "oppo_abc"},
    {"name": "value", "type": "number", "description": "Deal value in cents.", "required": false, "example": 75000},
    {"name": "confidence", "type": "number", "description": "Win confidence percentage (0-100).", "required": false, "example": 90},
    {"name": "status_type", "type": "string", "description": "Status: active, won, or lost.", "required": false, "example": "won"}
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.close.com/api/v1/opportunity/oppo_abc/",
    "headers": {"Authorization": "Basic {api_key}", "Content-Type": "application/json"},
    "body": {"value": 75000, "confidence": 90, "status_type": "won"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "oppo_abc", "lead_id": "lead_abc123", "value": 75000, "confidence": 90, "status_type": "won", "date_won": "2024-01-20T10:00:00Z"}
  }
}
