{
  "name": "tasks_update",
  "description": "Update a task.",
  "resource_group": "tasks",
  "endpoint": "/task/{id}/",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Task ID.",
      "in": "path"
    },
    {
      "name": "is_complete",
      "type": "boolean",
      "required": false,
      "description": "Mark complete.",
      "in": "body"
    },
    {
      "name": "text",
      "type": "string",
      "required": false,
      "description": "Updated text.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.close.com/api/v1/task/task_abc/",
    "body": {
      "is_complete": true
    }
  },
  "response_example": {
    "id": "task_abc",
    "is_complete": true
  }
}
