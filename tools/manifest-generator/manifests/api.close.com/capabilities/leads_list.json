{
  "name": "leads_list",
  "description": "List leads with pagination.",
  "resource_group": "leads",
  "endpoint": "/lead/",
  "method": "GET",
  "parameters": [
    {
      "name": "_limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "_skip",
      "type": "integer",
      "required": false,
      "description": "Offset.",
      "in": "query"
    },
    {
      "name": "_fields",
      "type": "string",
      "required": false,
      "description": "Comma-separated fields to return.",
      "in": "query"
    },
    {
      "name": "query",
      "type": "string",
      "required": false,
      "description": "Search query.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.close.com/api/v1/lead/?_limit=10"
  },
  "response_example": {
    "has_more": true,
    "data": [
      {
        "id": "lead_abc",
        "display_name": "Acme Corp",
        "status_label": "Potential",
        "contacts": [
          {
            "id": "cont_abc",
            "name": "Jane Doe",
            "emails": [
              {
                "email": "jane@acme.com",
                "type": "office"
              }
            ]
          }
        ]
      }
    ]
  }
}
