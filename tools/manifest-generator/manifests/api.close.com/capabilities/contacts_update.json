{
  "name": "contacts_update",
  "description": "Update a contact.",
  "resource_group": "contacts",
  "endpoint": "/contact/{id}/",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Contact ID.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Name.",
      "in": "body"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Job title.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.close.com/api/v1/contact/cont_abc/",
    "body": {
      "title": "CEO & Co-Founder"
    }
  },
  "response_example": {
    "id": "cont_abc",
    "title": "CEO & Co-Founder"
  }
}
