{
  "name": "opportunities_update",
  "description": "Update an opportunity.",
  "resource_group": "opportunities",
  "endpoint": "/opportunity/{id}/",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Opportunity ID."
    },
    {
      "name": "status_id",
      "type": "string",
      "required": false,
      "description": "Status."
    },
    {
      "name": "value",
      "type": "number",
      "required": false,
      "description": "Value."
    },
    {
      "name": "confidence",
      "type": "integer",
      "required": false,
      "description": "Confidence."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.close.com/api/v1/opportunity/oppo_abc/",
    "body": {
      "status_id": "stat_won",
      "confidence": 100
    }
  },
  "response_example": {
    "id": "oppo_abc",
    "status_label": "Won",
    "confidence": 100
  }
}