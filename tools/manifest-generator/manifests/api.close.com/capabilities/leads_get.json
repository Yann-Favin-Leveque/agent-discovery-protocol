{
  "name": "leads_get",
  "description": "Get a lead by ID.",
  "resource_group": "leads",
  "endpoint": "/lead/{id}/",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Lead ID.",
      "in": "path"
    },
    {
      "name": "_fields",
      "type": "string",
      "required": false,
      "description": "Fields to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.close.com/api/v1/lead/lead_abc/"
  },
  "response_example": {
    "id": "lead_abc",
    "display_name": "Acme Corp",
    "status_label": "Potential",
    "contacts": [
      {
        "id": "cont_abc",
        "name": "Jane Doe"
      }
    ],
    "opportunities": []
  }
}
