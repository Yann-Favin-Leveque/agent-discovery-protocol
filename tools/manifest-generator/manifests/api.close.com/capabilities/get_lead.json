{
  "name": "get_lead",
  "description": "Get detailed information about a specific lead including contacts, opportunities, and custom fields.",
  "endpoint": "/lead/{lead_id}/",
  "method": "GET",
  "parameters": [
    {"name": "lead_id", "type": "string", "description": "The ID of the lead to retrieve.", "required": true, "example": "lead_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.close.com/api/v1/lead/lead_abc123/",
    "headers": {"Authorization": "Basic {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "lead_abc123", "display_name": "Acme Corp", "status_label": "Potential", "contacts": [{"id": "cont_xyz", "name": "John Doe", "emails": [{"email": "john@acme.com"}], "phones": [{"phone": "+1234567890"}]}], "opportunities": [{"id": "oppo_abc", "value": 50000, "status_type": "active"}]}
  }
}
