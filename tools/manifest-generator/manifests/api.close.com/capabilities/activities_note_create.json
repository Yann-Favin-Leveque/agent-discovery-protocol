{
  "name": "activities_note_create",
  "description": "Create a note activity on a lead.",
  "resource_group": "activities",
  "endpoint": "/activity/note/",
  "method": "POST",
  "parameters": [
    {
      "name": "lead_id",
      "type": "string",
      "required": true,
      "description": "Lead ID."
    },
    {
      "name": "note",
      "type": "string",
      "required": true,
      "description": "Note text."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.close.com/api/v1/activity/note/",
    "body": {
      "lead_id": "lead_abc",
      "note": "Discussed pricing"
    }
  },
  "response_example": {
    "id": "acti_abc",
    "lead_id": "lead_abc",
    "note": "Discussed pricing",
    "_type": "Note"
  }
}