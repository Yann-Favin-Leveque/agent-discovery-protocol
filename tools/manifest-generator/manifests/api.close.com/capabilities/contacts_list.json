{
  "name": "contacts_list",
  "description": "List contacts.",
  "resource_group": "contacts",
  "endpoint": "/contact/",
  "method": "GET",
  "parameters": [
    {
      "name": "_limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "_skip",
      "type": "integer",
      "required": false,
      "description": "Offset.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.close.com/api/v1/contact/?_limit=10"
  },
  "response_example": {
    "has_more": true,
    "data": [
      {
        "id": "cont_abc",
        "name": "Jane Doe",
        "lead_id": "lead_abc",
        "emails": [
          {
            "email": "jane@acme.com"
          }
        ],
        "phones": [
          {
            "phone": "+15551234567"
          }
        ]
      }
    ]
  }
}
