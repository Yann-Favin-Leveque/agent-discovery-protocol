{
  "name": "activities_email_list",
  "description": "List email activities for a lead.",
  "resource_group": "activities",
  "endpoint": "/activity/email/",
  "method": "GET",
  "parameters": [
    {
      "name": "lead_id",
      "type": "string",
      "required": false,
      "description": "Filter by lead.",
      "in": "query"
    },
    {
      "name": "_limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "_skip",
      "type": "integer",
      "required": false,
      "description": "Offset.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.close.com/api/v1/activity/email/?lead_id=lead_abc&_limit=10"
  },
  "response_example": {
    "has_more": false,
    "data": [
      {
        "id": "acti_email",
        "lead_id": "lead_abc",
        "subject": "Follow up",
        "sender": "john@company.com",
        "_type": "Email"
      }
    ]
  }
}
