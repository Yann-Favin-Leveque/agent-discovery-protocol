{
  "name": "leads_merge",
  "description": "Merge two leads.",
  "resource_group": "leads",
  "endpoint": "/lead/merge/",
  "method": "POST",
  "parameters": [
    {
      "name": "source",
      "type": "string",
      "required": true,
      "description": "Source lead ID (will be merged into destination)."
    },
    {
      "name": "destination",
      "type": "string",
      "required": true,
      "description": "Destination lead ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.close.com/api/v1/lead/merge/",
    "body": {
      "source": "lead_abc",
      "destination": "lead_def"
    }
  },
  "response_example": {
    "id": "lead_def"
  }
}