{
  "name": "opportunities_list",
  "description": "List opportunities with filtering.",
  "resource_group": "opportunities",
  "endpoint": "/opportunity/",
  "method": "GET",
  "parameters": [
    {
      "name": "lead_id",
      "type": "string",
      "required": false,
      "description": "Filter by lead.",
      "in": "query"
    },
    {
      "name": "user_id",
      "type": "string",
      "required": false,
      "description": "Filter by user.",
      "in": "query"
    },
    {
      "name": "status_type",
      "type": "string",
      "required": false,
      "description": "active, won, lost.",
      "in": "query"
    },
    {
      "name": "_limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "_skip",
      "type": "integer",
      "required": false,
      "description": "Offset.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.close.com/api/v1/opportunity/?status_type=active&_limit=10"
  },
  "response_example": {
    "has_more": false,
    "data": [
      {
        "id": "oppo_abc",
        "lead_id": "lead_abc",
        "status_label": "Active",
        "value": 50000,
        "value_period": "one_time",
        "confidence": 80
      }
    ]
  }
}
