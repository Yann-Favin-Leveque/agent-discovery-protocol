{
  "name": "contacts_get",
  "description": "Get a contact by ID.",
  "resource_group": "contacts",
  "endpoint": "/contact/{id}/",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Contact ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.close.com/api/v1/contact/cont_abc/"
  },
  "response_example": {
    "id": "cont_abc",
    "name": "Jane Doe",
    "lead_id": "lead_abc",
    "title": "CEO"
  }
}
