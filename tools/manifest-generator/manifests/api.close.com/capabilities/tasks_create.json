{
  "name": "tasks_create",
  "description": "Create a task.",
  "resource_group": "tasks",
  "endpoint": "/task/",
  "method": "POST",
  "parameters": [
    {
      "name": "lead_id",
      "type": "string",
      "required": true,
      "description": "Lead ID.",
      "in": "body"
    },
    {
      "name": "text",
      "type": "string",
      "required": true,
      "description": "Task text.",
      "in": "body"
    },
    {
      "name": "due_date",
      "type": "string",
      "required": false,
      "description": "Due date YYYY-MM-DD.",
      "in": "body"
    },
    {
      "name": "assigned_to",
      "type": "string",
      "required": false,
      "description": "User ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.close.com/api/v1/task/",
    "body": {
      "lead_id": "lead_abc",
      "text": "Send proposal",
      "due_date": "2026-01-22"
    }
  },
  "response_example": {
    "id": "task_new",
    "text": "Send proposal",
    "is_complete": false
  }
}
