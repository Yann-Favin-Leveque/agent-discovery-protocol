{
  "name": "leads_update",
  "description": "Update a lead.",
  "resource_group": "leads",
  "endpoint": "/lead/{id}/",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Lead ID."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Name."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Status."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.close.com/api/v1/lead/lead_abc/",
    "body": {
      "status": "Qualified"
    }
  },
  "response_example": {
    "id": "lead_abc",
    "status_label": "Qualified"
  }
}