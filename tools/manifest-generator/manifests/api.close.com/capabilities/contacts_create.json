{
  "name": "contacts_create",
  "description": "Create a contact.",
  "resource_group": "contacts",
  "endpoint": "/contact/",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Full name.",
      "in": "body"
    },
    {
      "name": "lead_id",
      "type": "string",
      "required": false,
      "description": "Lead ID to attach to.",
      "in": "body"
    },
    {
      "name": "emails",
      "type": "array",
      "required": false,
      "description": "Email addresses.",
      "in": "body"
    },
    {
      "name": "phones",
      "type": "array",
      "required": false,
      "description": "Phone numbers.",
      "in": "body"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Job title.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.close.com/api/v1/contact/",
    "body": {
      "name": "Bob Jones",
      "lead_id": "lead_abc",
      "emails": [
        {
          "email": "bob@acme.com",
          "type": "office"
        }
      ],
      "title": "CTO"
    }
  },
  "response_example": {
    "id": "cont_new",
    "name": "Bob Jones",
    "lead_id": "lead_abc"
  }
}
