{
  "name": "search_leads",
  "description": "Search leads using Close's query language.",
  "resource_group": "search",
  "endpoint": "/data/search/",
  "method": "POST",
  "parameters": [
    {
      "name": "query",
      "type": "object",
      "required": true,
      "description": "Search query with negate, queries array of type/condition objects."
    },
    {
      "name": "_limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "_fields",
      "type": "object",
      "required": false,
      "description": "Fields to return."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.close.com/api/v1/data/search/",
    "body": {
      "query": {
        "negate": false,
        "queries": [
          {
            "type": "field_condition",
            "field": {
              "type": "regular_field",
              "field_name": "lead_name"
            },
            "condition": {
              "type": "text",
              "mode": "full_words",
              "value": "Acme"
            }
          }
        ]
      },
      "_limit": 10
    }
  },
  "response_example": {
    "data": [
      {
        "id": "lead_abc",
        "display_name": "Acme Corp"
      }
    ]
  }
}