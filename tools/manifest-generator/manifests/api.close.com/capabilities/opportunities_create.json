{
  "name": "opportunities_create",
  "description": "Create an opportunity.",
  "resource_group": "opportunities",
  "endpoint": "/opportunity/",
  "method": "POST",
  "parameters": [
    {
      "name": "lead_id",
      "type": "string",
      "required": false,
      "description": "Lead ID."
    },
    {
      "name": "status_id",
      "type": "string",
      "required": false,
      "description": "Status ID."
    },
    {
      "name": "value",
      "type": "number",
      "required": false,
      "description": "Value."
    },
    {
      "name": "value_period",
      "type": "string",
      "required": false,
      "description": "one_time, monthly, annual."
    },
    {
      "name": "confidence",
      "type": "integer",
      "required": false,
      "description": "Confidence 0-100."
    },
    {
      "name": "note",
      "type": "string",
      "required": false,
      "description": "Note."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.close.com/api/v1/opportunity/",
    "body": {
      "lead_id": "lead_abc",
      "value": 25000,
      "value_period": "annual",
      "confidence": 60
    }
  },
  "response_example": {
    "id": "oppo_new",
    "lead_id": "lead_abc",
    "value": 25000
  }
}