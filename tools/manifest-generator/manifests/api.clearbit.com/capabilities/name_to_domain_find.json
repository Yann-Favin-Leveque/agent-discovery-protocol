{
  "name": "name_to_domain_find",
  "description": "Find a company domain given the company name.",
  "endpoint": "/v1/domains/find",
  "method": "GET",
  "resource_group": "enrichment",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Company name to search for.",
      "required": true,
      "example": "Clearbit"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clearbit.com/v1/domains/find?name=Clearbit",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "Clearbit",
      "domain": "clearbit.com",
      "logo": "https://logo.clearbit.com/clearbit.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}