{
  "name": "products_get",
  "description": "Retrieve a specific product by its ID.",
  "resource_group": "products",
  "endpoint": "/products/{product_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "description": "The product ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/products/pro_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "pro_01h1vjes1y163xfj1rh1tkfb65",
        "name": "My SaaS Product"
      }
    }
  }
}
