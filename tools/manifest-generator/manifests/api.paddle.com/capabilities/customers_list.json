{
  "name": "customers_list",
  "description": "List all customers with filtering.",
  "resource_group": "customers",
  "endpoint": "/customers",
  "method": "GET",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Filter by email.",
      "required": false,
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false,
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/customers",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "ctm_01h1vjes1y163xfj1rh1tkfb65",
          "email": "user@example.com"
        }
      ]
    }
  }
}
