{
  "name": "customers_update",
  "description": "Update an existing customer.",
  "resource_group": "customers",
  "endpoint": "/customers/{customer_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    },
    {
      "name": "email",
      "type": "string",
      "description": "Updated email.",
      "required": false
    },
    {
      "name": "status",
      "type": "string",
      "description": "Set status.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/customers/ctm_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Jane Doe"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "ctm_01h1vjes1y163xfj1rh1tkfb65",
        "name": "Jane Doe"
      }
    }
  }
}