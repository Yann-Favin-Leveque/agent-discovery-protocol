{
  "name": "subscriptions_cancel",
  "description": "Cancel an active subscription.",
  "resource_group": "subscriptions",
  "endpoint": "/subscriptions/{subscription_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "subscription_id",
      "type": "string",
      "description": "The subscription ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "effective_from",
      "type": "string",
      "description": "When to cancel: immediately or next_billing_period.",
      "required": false,
      "example": "next_billing_period",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.paddle.com/subscriptions/sub_01h1vjes1y163xfj1rh1tkfb65/cancel",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "effective_from": "next_billing_period"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "sub_01h1vjes1y163xfj1rh1tkfb65",
        "status": "canceled"
      }
    }
  }
}
