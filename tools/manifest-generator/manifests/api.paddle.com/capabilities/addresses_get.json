{
  "name": "addresses_get",
  "description": "Retrieve a specific address for a customer.",
  "resource_group": "addresses",
  "endpoint": "/customers/{customer_id}/addresses/{address_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "address_id",
      "type": "string",
      "description": "The address ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/customers/ctm_01h1vjes1y163xfj1rh1tkfb65/addresses/add_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "add_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
