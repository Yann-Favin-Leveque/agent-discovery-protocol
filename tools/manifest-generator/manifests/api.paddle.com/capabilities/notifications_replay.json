{
  "name": "notifications_replay",
  "description": "Replay a notification, sending it again to the destination.",
  "resource_group": "notifications",
  "endpoint": "/notifications/{notification_id}/replay",
  "method": "POST",
  "parameters": [
    {
      "name": "notification_id",
      "type": "string",
      "description": "The notification ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.paddle.com/notifications/ntf_01h1vjes1y163xfj1rh1tkfb65/replay",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "notification_id": "ntf_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
