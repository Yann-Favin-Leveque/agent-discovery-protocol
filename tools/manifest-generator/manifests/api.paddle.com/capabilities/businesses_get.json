  "method": "GET",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "business_id",
      "type": "string",
      "description": "The business ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/customers/ctm_01h1vjes1y163xfj1rh1tkfb65/businesses/biz_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "biz_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
