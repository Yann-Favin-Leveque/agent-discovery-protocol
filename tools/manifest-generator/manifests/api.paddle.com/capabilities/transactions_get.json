{
  "name": "transactions_get",
  "description": "Retrieve a specific transaction by ID.",
  "resource_group": "transactions",
  "endpoint": "/transactions/{transaction_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "The transaction ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/transactions/txn_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "txn_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
