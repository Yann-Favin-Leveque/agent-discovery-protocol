{
  "name": "addresses_update",
  "description": "Update an existing address for a customer.",
  "resource_group": "addresses",
  "endpoint": "/customers/{customer_id}/addresses/{address_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "address_id",
      "type": "string",
      "description": "The address ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "postal_code",
      "type": "string",
      "description": "Updated postal code.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/customers/ctm_01h1vjes1y163xfj1rh1tkfb65/addresses/add_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "postal_code": "90210"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "add_01h1vjes1y163xfj1rh1tkfb65",
        "postal_code": "90210"
      }
    }
  }
}
