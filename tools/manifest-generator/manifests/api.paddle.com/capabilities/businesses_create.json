{
  "name": "businesses_create",
  "description": "Create a business entity for a customer.",
  "resource_group": "businesses",
  "endpoint": "/customers/{customer_id}/businesses",
  "method": "POST",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Business name.",
      "required": true
    },
    {
      "name": "company_number",
      "type": "string",
      "description": "Company registration number.",
      "required": false
    },
    {
      "name": "tax_identifier",
      "type": "string",
      "description": "Tax/VAT identifier.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.paddle.com/customers/ctm_01h1vjes1y163xfj1rh1tkfb65/businesses",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Corp"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "biz_01h1vjes1y163xfj1rh1tkfb65",
        "name": "Acme Corp"
      }
    }
  }
}