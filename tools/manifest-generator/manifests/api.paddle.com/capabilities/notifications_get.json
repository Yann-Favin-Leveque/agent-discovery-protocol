{
  "name": "notifications_get",
  "description": "Retrieve a specific notification.",
  "resource_group": "notifications",
  "endpoint": "/notifications/{notification_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "notification_id",
      "type": "string",
      "description": "The notification ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/notifications/ntf_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "ntf_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}