{
  "name": "create_customer",
  "description": "Create a new customer in Paddle. Customers are needed before you can create subscriptions or transactions for them. A customer record stores the email, name, and can be linked to addresses for tax calculation.",
  "endpoint": "/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "The customer's email address. Must be unique across your Paddle account.",
      "required": true,
      "example": "jane@example.com"
    },
    {
      "name": "name",
      "type": "string",
      "description": "The customer's full name.",
      "required": false,
      "example": "Jane Doe"
    },
    {
      "name": "locale",
      "type": "string",
      "description": "The customer's preferred locale (e.g. 'en' or 'fr').",
      "required": false,
      "example": "en"
    },
    {
      "name": "custom_data",
      "type": "object",
      "description": "Custom key-value pairs to store with the customer.",
      "required": false,
      "example": { "company": "Acme Corp" }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.paddle.com/customers",
    "headers": {
      "Authorization": "Bearer pdl_live_abc123def456",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "jane@example.com",
      "name": "Jane Doe",
      "locale": "en"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "ctm_01h7mrm0bmd2szhxxreadempty",
        "email": "jane@example.com",
        "name": "Jane Doe",
        "locale": "en",
        "status": "active",
        "custom_data": null,
        "created_at": "2024-03-15T10:00:00.000Z",
        "updated_at": "2024-03-15T10:00:00.000Z"
      },
      "meta": {
        "request_id": "d4e5f6a7-b8c9-0123-defa-234567890123"
      }
    }
  }
}
