{
  "name": "discounts_update",
  "description": "Update an existing discount.",
  "resource_group": "discounts",
  "endpoint": "/discounts/{discount_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "discount_id",
      "type": "string",
      "description": "The discount ID.",
      "required": true
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false
    },
    {
      "name": "status",
      "type": "string",
      "description": "Set status.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/discounts/dsc_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "status": "archived"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "dsc_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}