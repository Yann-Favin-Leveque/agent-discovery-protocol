{
  "name": "customers_create",
  "description": "Create a new customer record in Paddle.",
  "resource_group": "customers",
  "endpoint": "/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Customer email address.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Customer full name.",
      "required": false
    },
    {
      "name": "locale",
      "type": "string",
      "description": "Customer locale.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.paddle.com/customers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "name": "John Doe"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "ctm_01h1vjes1y163xfj1rh1tkfb65",
        "email": "user@example.com"
      }
    }
  }
}