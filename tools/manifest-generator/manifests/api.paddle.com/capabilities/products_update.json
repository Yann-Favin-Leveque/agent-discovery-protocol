{
  "name": "products_update",
  "description": "Update an existing product.",
  "resource_group": "products",
  "endpoint": "/products/{product_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "description": "The product ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false
    },
    {
      "name": "image_url",
      "type": "string",
      "description": "Updated image URL.",
      "required": false
    },
    {
      "name": "status",
      "type": "string",
      "description": "Set status (active, archived).",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/products/pro_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Product Name"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "pro_01h1vjes1y163xfj1rh1tkfb65",
        "name": "Updated Product Name"
      }
    }
  }
}