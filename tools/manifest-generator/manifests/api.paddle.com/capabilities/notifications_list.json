  "description": "List all notifications sent from your account.",
  "resource_group": "notifications",
  "endpoint": "/notifications",
  "method": "GET",
  "parameters": [
    {
      "name": "notification_setting_id",
      "type": "string",
      "description": "Filter by setting.",
      "required": false
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/notifications",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "ntf_01h1vjes1y163xfj1rh1tkfb65",
