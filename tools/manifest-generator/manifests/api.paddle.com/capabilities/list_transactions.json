{
  "name": "list_transactions",
  "description": "List and filter all transactions in your Paddle account. Transactions represent completed and pending payments, including subscription renewals. Use query parameters to filter by status, customer, subscription, or date range.",
  "endpoint": "/transactions",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "description": "Filter by transaction status. Values: 'draft', 'ready', 'billed', 'paid', 'completed', 'canceled', 'past_due'.",
      "required": false,
      "example": "completed"
    },
    {
      "name": "customer_id",
      "type": "string",
      "description": "Filter transactions belonging to a specific customer.",
      "required": false,
      "example": "ctm_01h7mrm0bmd2szhxxreadempty"
    },
    {
      "name": "subscription_id",
      "type": "string",
      "description": "Filter transactions linked to a specific subscription.",
      "required": false,
      "example": "sub_01h7mrm0bmd2szhxxreadempty"
    },
    {
      "name": "after",
      "type": "string",
      "description": "Cursor for pagination. Pass the value from 'meta.pagination.next' to get the next page.",
      "required": false,
      "example": "txn_01h7mrm0bmd2szhxxreadempty"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Number of results per page. Default 50, max 200.",
      "required": false,
      "example": 25
    },
    {
      "name": "order_by",
      "type": "string",
      "description": "Sort order. Format: 'field[direction]', e.g. 'created_at[DESC]'.",
      "required": false,
      "example": "created_at[DESC]"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/transactions?status=completed&per_page=25&order_by=created_at[DESC]",
    "headers": {
      "Authorization": "Bearer pdl_live_abc123def456"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "txn_01h7mrm0bmd2szhxxreadempty",
          "status": "completed",
          "customer_id": "ctm_01h7mrm0bmd2szhxxreadempty",
          "subscription_id": "sub_01h7mrm0bmd2szhxxreadempty",
          "currency_code": "USD",
          "details": {
            "totals": {
              "subtotal": "2999",
              "tax": "0",
              "total": "2999",
              "grand_total": "2999"
            }
          },
          "billed_at": "2024-03-15T10:15:00.000Z",
          "created_at": "2024-03-15T10:10:00.000Z",
          "updated_at": "2024-03-15T10:15:00.000Z"
        }
      ],
      "meta": {
        "request_id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
        "pagination": {
          "per_page": 25,
          "estimated_total": 150,
          "next": "https://api.paddle.com/transactions?after=txn_01h7mrm0bmd2szhxxreadempty&per_page=25"
        }
      }
    }
  }
}
