{
  "name": "get_subscription",
  "description": "Retrieve the full details of an existing Paddle subscription by its ID. Returns the subscription status, items, billing cycle, next billing date, and payment information. Use this to check if a subscription is active, paused, or canceled.",
  "endpoint": "/subscriptions/{subscription_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "subscription_id",
      "type": "string",
      "description": "The unique subscription ID (starts with 'sub_').",
      "required": true,
      "example": "sub_01h7mrm0bmd2szhxxreadempty"
    },
    {
      "name": "include",
      "type": "string",
      "description": "Include related entities in the response. Options: 'next_transaction', 'recurring_transaction_details'.",
      "required": false,
      "example": "next_transaction"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/subscriptions/sub_01h7mrm0bmd2szhxxreadempty",
    "headers": {
      "Authorization": "Bearer pdl_live_abc123def456"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "sub_01h7mrm0bmd2szhxxreadempty",
        "status": "active",
        "customer_id": "ctm_01h7mrm0bmd2szhxxreadempty",
        "address_id": "add_01h7mrm0bmd2szhxxreadempty",
        "business_id": null,
        "currency_code": "USD",
        "items": [
          {
            "price": {
              "id": "pri_01h7mrm0bmd2szhxxreadempty",
              "description": "Monthly subscription",
              "unit_price": { "amount": "2999", "currency_code": "USD" },
              "billing_cycle": { "interval": "month", "frequency": 1 }
            },
            "quantity": 1,
            "status": "active"
          }
        ],
        "billing_cycle": { "interval": "month", "frequency": 1 },
        "current_billing_period": {
          "starts_at": "2024-03-15T00:00:00.000Z",
          "ends_at": "2024-04-15T00:00:00.000Z"
        },
        "next_billed_at": "2024-04-15T00:00:00.000Z",
        "started_at": "2024-03-15T10:10:00.000Z",
        "first_billed_at": "2024-03-15T10:10:00.000Z",
        "created_at": "2024-03-15T10:10:00.000Z",
        "updated_at": "2024-03-15T10:10:00.000Z"
      },
      "meta": {
        "request_id": "e5f6a7b8-c9d0-1234-efab-345678901234"
      }
    }
  }
}
