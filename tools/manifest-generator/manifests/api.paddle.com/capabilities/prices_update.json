{
  "name": "prices_update",
  "description": "Update an existing price.",
  "resource_group": "prices",
  "endpoint": "/prices/{price_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "price_id",
      "type": "string",
      "description": "The price ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false,
      "in": "body"
    },
    {
      "name": "unit_price",
      "type": "object",
      "description": "Updated unit price.",
      "required": false,
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Set status.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/prices/pri_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "description": "Updated Monthly"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "pri_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
