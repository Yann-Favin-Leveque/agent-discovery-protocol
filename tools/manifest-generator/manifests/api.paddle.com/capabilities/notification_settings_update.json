{
  "name": "notification_settings_update",
  "description": "Update a notification setting.",
  "resource_group": "notification_settings",
  "endpoint": "/notification-settings/{notification_setting_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "notification_setting_id",
      "type": "string",
      "description": "The notification setting ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false,
      "in": "body"
    },
    {
      "name": "subscribed_events",
      "type": "array",
      "description": "Updated events.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/notification-settings/ntfset_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "description": "Updated webhook"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "ntfset_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
