{
  "name": "discounts_get",
  "description": "Retrieve a specific discount by ID.",
  "resource_group": "discounts",
  "endpoint": "/discounts/{discount_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "discount_id",
      "type": "string",
      "description": "The discount ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/discounts/dsc_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "dsc_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
