{
  "name": "businesses_update",
  "description": "Update an existing business for a customer.",
  "resource_group": "businesses",
  "endpoint": "/customers/{customer_id}/businesses/{business_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true
    },
    {
      "name": "business_id",
      "type": "string",
      "description": "The business ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/customers/ctm_01h1vjes1y163xfj1rh1tkfb65/businesses/biz_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Inc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "biz_01h1vjes1y163xfj1rh1tkfb65",
        "name": "Acme Inc"
      }
    }
  }
}