{
  "name": "prices_get",
  "description": "Retrieve a specific price by its ID.",
  "resource_group": "prices",
  "endpoint": "/prices/{price_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "price_id",
      "type": "string",
      "description": "The price ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/prices/pri_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "pri_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}
