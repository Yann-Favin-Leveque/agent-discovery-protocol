{
  "name": "discounts_create",
  "description": "Create a discount code that can be applied to transactions.",
  "resource_group": "discounts",
  "endpoint": "/discounts",
  "method": "POST",
  "parameters": [
    {
      "name": "amount",
      "type": "string",
      "description": "Discount amount.",
      "required": true,
      "example": "10",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Discount description.",
      "required": true,
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Type: flat, flat_per_seat, or percentage.",
      "required": true,
      "example": "percentage",
      "in": "body"
    },
    {
      "name": "code",
      "type": "string",
      "description": "Unique discount code.",
      "required": false,
      "example": "SAVE10",
      "in": "body"
    },
    {
      "name": "enabled_for_checkout",
      "type": "boolean",
      "description": "Can be used at checkout.",
      "required": false,
      "in": "body"
    },
    {
      "name": "recur",
      "type": "boolean",
      "description": "Apply to recurring payments.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.paddle.com/discounts",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "amount": "10",
      "description": "10% off",
      "type": "percentage",
      "code": "SAVE10"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "dsc_01h1vjes1y163xfj1rh1tkfb65",
        "code": "SAVE10"
      }
    }
  }
}
