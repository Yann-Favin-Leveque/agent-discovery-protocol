{
  "name": "prices_list",
  "description": "List all prices with optional filtering.",
  "resource_group": "prices",
  "endpoint": "/prices",
  "method": "GET",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "description": "Filter by product ID.",
      "required": false,
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false,
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.paddle.com/prices",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "pri_01h1vjes1y163xfj1rh1tkfb65",
          "description": "Monthly"
        }
      ]
    }
  }
}
