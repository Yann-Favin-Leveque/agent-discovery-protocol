{
  "name": "transactions_update",
  "description": "Update a draft or ready transaction.",
  "resource_group": "transactions",
  "endpoint": "/transactions/{transaction_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "The transaction ID.",
      "required": true
    },
    {
      "name": "items",
      "type": "array",
      "description": "Updated items.",
      "required": false
    },
    {
      "name": "status",
      "type": "string",
      "description": "Updated status.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.paddle.com/transactions/txn_01h1vjes1y163xfj1rh1tkfb65",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "status": "billed"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "txn_01h1vjes1y163xfj1rh1tkfb65"
      }
    }
  }
}