{
  "name": "sessions_revoke",
  "resource_group": "sessions",
  "description": "Revoke a session to log a user out.",
  "endpoint": "/v1/sessions/revoke",
  "method": "POST",
  "parameters": [
    {
      "name": "session_token",
      "type": "string",
      "required": false,
      "description": "Session token to revoke."
    },
    {
      "name": "session_jwt",
      "type": "string",
      "required": false,
      "description": "Session JWT to revoke."
    },
    {
      "name": "session_id",
      "type": "string",
      "required": false,
      "description": "Session ID to revoke."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stytch.com/v1/sessions/revoke",
    "headers": {
      "Authorization": "Basic base64(project_id:secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "session_token": "sess-token-xyz"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req-abc",
      "status_code": 200
    }
  }
}