{
  "name": "passwords_authenticate",
  "resource_group": "passwords",
  "description": "Authenticate a user with email and password.",
  "endpoint": "/v1/passwords/authenticate",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email address.",
      "in": "body"
    },
    {
      "name": "password",
      "type": "string",
      "required": true,
      "description": "Password.",
      "in": "body"
    },
    {
      "name": "session_token",
      "type": "string",
      "required": false,
      "description": "Existing session to extend.",
      "in": "body"
    },
    {
      "name": "session_duration_minutes",
      "type": "integer",
      "required": false,
      "description": "Session lifetime.",
      "in": "body"
    },
    {
      "name": "session_custom_claims",
      "type": "object",
      "required": false,
      "description": "Custom claims.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stytch.com/v1/passwords/authenticate",
    "headers": {
      "Authorization": "Basic base64(project_id:secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "alice@example.com",
      "password": "securePass123!",
      "session_duration_minutes": 60
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req-abc",
      "user_id": "user-live-abc",
      "session_token": "sess-token-xyz",
      "session_jwt": "eyJhbGciOi...",
      "user": {
        "user_id": "user-live-abc"
      }
    }
  }
}
