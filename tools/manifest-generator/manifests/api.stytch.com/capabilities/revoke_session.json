{
  "name": "revoke_session",
  "description": "Revoke an active session to log the user out. You can revoke by session_token, session_jwt, or session_id. This immediately invalidates the session.",
  "endpoint": "/v1/sessions/revoke",
  "method": "POST",
  "parameters": [
    { "name": "session_token", "type": "string", "description": "The session token to revoke. Provide one of session_token, session_jwt, or session_id.", "required": false, "example": "mZAYn5aLEqKUlZ_Ad9U_fWr38GaAQ1oFAhT8ds245v7Q" },
    { "name": "session_jwt", "type": "string", "description": "The session JWT to revoke.", "required": false, "example": "eyJ..." },
    { "name": "session_id", "type": "string", "description": "The session ID to revoke.", "required": false, "example": "session-test-eb720c42-78fb-489b-850a-4489f5e4b659" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stytch.com/v1/sessions/revoke",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Basic {base64(project_id:secret)}"
    },
    "body": {
      "session_token": "mZAYn5aLEqKUlZ_Ad9U_fWr38GaAQ1oFAhT8ds245v7Q"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "request-id-test-stytch-request",
      "status_code": 200
    }
  }
}
