{
  "name": "authenticate_session",
  "description": "Validate an existing session and optionally extend its lifetime. Accepts either a session_token or session_jwt. Returns the session details and refreshed JWT.",
  "endpoint": "/v1/sessions/authenticate",
  "method": "POST",
  "parameters": [
    { "name": "session_token", "type": "string", "description": "The session token to validate. Provide this or session_jwt.", "required": false, "example": "mZAYn5aLEqKUlZ_Ad9U_fWr38GaAQ1oFAhT8ds245v7Q" },
    { "name": "session_jwt", "type": "string", "description": "The session JWT to validate. Provide this or session_token.", "required": false, "example": "eyJ..." },
    { "name": "session_duration_minutes", "type": "integer", "description": "Extend the session to this many minutes from now.", "required": false, "example": 60 }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stytch.com/v1/sessions/authenticate",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Basic {base64(project_id:secret)}"
    },
    "body": {
      "session_token": "mZAYn5aLEqKUlZ_Ad9U_fWr38GaAQ1oFAhT8ds245v7Q",
      "session_duration_minutes": 60
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "request-id-test-stytch-request",
      "session": {
        "session_id": "session-test-eb720c42-78fb-489b-850a-4489f5e4b659",
        "user_id": "user-test-e3795c81-f849-4167-bfda-e4a6e9c280fd",
        "started_at": "2024-01-01T00:00:00Z",
        "last_accessed_at": "2024-01-01T01:00:00Z",
        "expires_at": "2024-01-01T02:00:00Z",
        "authentication_factors": [{ "type": "magic_link", "delivery_method": "email" }]
      },
      "session_token": "mZAYn5aLEqKUlZ_Ad9U_fWr38GaAQ1oFAhT8ds245v7Q",
      "session_jwt": "eyJ...",
      "user": {
        "user_id": "user-test-e3795c81-f849-4167-bfda-e4a6e9c280fd"
      },
      "status_code": 200
    }
  }
}
