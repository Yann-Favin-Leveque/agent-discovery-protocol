{
  "name": "passwords_strength_check",
  "resource_group": "passwords",
  "description": "Check password strength without creating a user.",
  "endpoint": "/v1/passwords/strength_check",
  "method": "POST",
  "parameters": [
    {
      "name": "password",
      "type": "string",
      "required": true,
      "description": "Password to check."
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Email for context-specific checks."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stytch.com/v1/passwords/strength_check",
    "headers": {
      "Authorization": "Basic base64(project_id:secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "password": "securePass123!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req-abc",
      "valid_password": true,
      "score": 4,
      "breached_password": false,
      "strength_policy": "zxcvbn",
      "feedback": {
        "suggestions": [],
        "warning": ""
      }
    }
  }
}