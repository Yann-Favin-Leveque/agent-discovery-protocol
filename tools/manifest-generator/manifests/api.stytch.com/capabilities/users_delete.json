{
  "name": "users_delete",
  "resource_group": "users",
  "description": "Permanently delete a user and all associated data.",
  "endpoint": "/v1/users/{user_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "User ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.stytch.com/v1/users/user-live-abc",
    "headers": {
      "Authorization": "Basic base64(project_id:secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req-abc",
      "user_id": "user-live-abc",
      "status_code": 200
    }
  }
}