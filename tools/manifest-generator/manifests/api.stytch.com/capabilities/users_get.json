{
  "name": "users_get",
  "resource_group": "users",
  "description": "Retrieve a user by their ID.",
  "endpoint": "/v1/users/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "User ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stytch.com/v1/users/user-live-abc",
    "headers": {
      "Authorization": "Basic base64(project_id:secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req-abc",
      "user_id": "user-live-abc",
      "user": {
        "user_id": "user-live-abc",
        "emails": [
          {
            "email": "alice@example.com",
            "verified": true
          }
        ],
        "phone_numbers": [],
        "status": "active",
        "created_at": "2024-01-15T10:30:00Z"
      }
    }
  }
}