{
  "name": "otps_sms_login_or_create",
  "resource_group": "otps",
  "description": "Send an OTP via SMS that either logs in or creates a new user.",
  "endpoint": "/v1/otps/sms/login_or_create",
  "method": "POST",
  "parameters": [
    {
      "name": "phone_number",
      "type": "string",
      "required": true,
      "description": "Phone number in E.164 format.",
      "in": "body"
    },
    {
      "name": "expiration_minutes",
      "type": "integer",
      "required": false,
      "description": "OTP expiration.",
      "in": "body"
    },
    {
      "name": "create_user_as_pending",
      "type": "boolean",
      "required": false,
      "description": "Create user as pending.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stytch.com/v1/otps/sms/login_or_create",
    "headers": {
      "Authorization": "Basic base64(project_id:secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "phone_number": "+15551234567"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req-abc",
      "user_id": "user-live-abc",
      "user_created": false,
      "phone_id": "phone-live-xyz"
    }
  }
}
