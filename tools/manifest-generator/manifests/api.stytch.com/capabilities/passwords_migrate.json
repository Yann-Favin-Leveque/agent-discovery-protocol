{
  "name": "passwords_migrate",
  "resource_group": "passwords",
  "description": "Migrate a user with an existing password hash from another system.",
  "endpoint": "/v1/passwords/migrate",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email address."
    },
    {
      "name": "hash",
      "type": "string",
      "required": true,
      "description": "Password hash."
    },
    {
      "name": "hash_type",
      "type": "string",
      "required": true,
      "description": "Hash algorithm: bcrypt, scrypt, argon2i, argon2id, sha_1, md_5, pbkdf_2."
    },
    {
      "name": "name",
      "type": "object",
      "required": false,
      "description": "User name object."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stytch.com/v1/passwords/migrate",
    "headers": {
      "Authorization": "Basic base64(project_id:secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "alice@example.com",
      "hash": "$2b$10$abc...",
      "hash_type": "bcrypt"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "req-abc",
      "user_id": "user-live-abc",
      "email_id": "email-live-xyz",
      "user_created": true
    }
  }
}