{
  "name": "sessions_jwks",
  "resource_group": "sessions",
  "description": "Retrieve the JWKS for verifying session JWTs locally.",
  "endpoint": "/v1/sessions/jwks/{project_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Your Stytch project ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stytch.com/v1/sessions/jwks/project-live-abc",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "keys": [
        {
          "kty": "RSA",
          "kid": "jwk-live-abc",
          "use": "sig",
          "alg": "RS256",
          "n": "...",
          "e": "AQAB"
        }
      ]
    }
  }
}