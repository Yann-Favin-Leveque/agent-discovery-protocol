{
  "name": "get_user",
  "description": "Retrieve a user's full profile by their user ID. Returns all associated emails, phone numbers, OAuth providers, and metadata.",
  "endpoint": "/v1/users/{user_id}",
  "method": "GET",
  "parameters": [
    { "name": "user_id", "type": "string", "description": "The unique identifier of the user (path parameter).", "required": true, "example": "user-test-e3795c81-f849-4167-bfda-e4a6e9c280fd" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stytch.com/v1/users/user-test-e3795c81-f849-4167-bfda-e4a6e9c280fd",
    "headers": {
      "Authorization": "Basic {base64(project_id:secret)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "request-id-test-stytch-request",
      "user": {
        "user_id": "user-test-e3795c81-f849-4167-bfda-e4a6e9c280fd",
        "emails": [{ "email_id": "email-test-81bf03a8", "email": "user@example.com", "verified": true }],
        "phone_numbers": [{ "phone_id": "phone-number-test-d5a3b680", "phone_number": "+14155551234", "verified": true }],
        "name": { "first_name": "Jane", "last_name": "Doe" },
        "created_at": "2024-01-01T00:00:00Z",
        "status": "active"
      },
      "status_code": 200
    }
  }
}
