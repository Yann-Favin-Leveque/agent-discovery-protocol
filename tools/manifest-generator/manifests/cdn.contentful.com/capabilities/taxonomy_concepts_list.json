{
  "name": "taxonomy_concepts_list",
  "description": "Retrieve all taxonomy concepts in a space environment. Concepts represent individual terms in a controlled vocabulary.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/taxonomy/concepts",
  "method": "GET",
  "resource_group": "taxonomy",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "description": "The space ID.",
      "required": true,
      "example": "cfexampleapi"
    },
    {
      "name": "environment_id",
      "type": "string",
      "description": "The environment ID.",
      "required": true,
      "example": "master"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/taxonomy/concepts",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": {"type": "Array"},
      "items": [
        {
          "sys": {"id": "concept1", "type": "TaxonomyConcept"},
          "prefLabel": "Technology",
          "definition": "Technology-related content"
        }
      ],
      "total": 10
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 78
  }
}