{
  "name": "entries_list",
  "description": "Retrieve content entries with filtering, full-text search, ordering, and linked content resolution via the include parameter.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/entries",
  "method": "GET",
  "resource_group": "entries",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "description": "The space ID.",
      "required": true,
      "example": "cfexampleapi"
    },
    {
      "name": "environment_id",
      "type": "string",
      "description": "The environment ID.",
      "required": true,
      "example": "master"
    },
    {
      "name": "content_type",
      "type": "string",
      "description": "Filter by content type ID.",
      "required": false,
      "example": "blogPost"
    },
    {
      "name": "select",
      "type": "string",
      "description": "Comma-separated list of fields to include in response.",
      "required": false,
      "example": "sys.id,fields.title"
    },
    {
      "name": "query",
      "type": "string",
      "description": "Full-text search query across all text and symbol fields.",
      "required": false,
      "example": "hello world"
    },
    {
      "name": "order",
      "type": "string",
      "description": "Order results by field. Prefix with - for descending.",
      "required": false,
      "example": "-sys.createdAt"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of results (default 100, max 1000).",
      "required": false,
      "example": 10
    },
    {
      "name": "skip",
      "type": "integer",
      "description": "Number of results to skip for pagination.",
      "required": false,
      "example": 0
    },
    {
      "name": "include",
      "type": "integer",
      "description": "Number of levels of linked entries/assets to resolve (0-10, default 1).",
      "required": false,
      "example": 2
    },
    {
      "name": "locale",
      "type": "string",
      "description": "Locale code to return content in. Use * for all locales.",
      "required": false,
      "example": "en-US"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/entries?content_type=blogPost&limit=10&include=2",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": {"type": "Array"},
      "total": 42,
      "skip": 0,
      "limit": 10,
      "items": [
        {
          "sys": {"id": "entry1", "type": "Entry", "contentType": {"sys": {"id": "blogPost"}}},
          "fields": {
            "title": "Hello World",
            "body": "This is my first blog post."
          }
        }
      ],
      "includes": {
        "Entry": [],
        "Asset": []
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 78
  }
}