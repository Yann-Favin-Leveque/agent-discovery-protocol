{
  "name": "get_entries",
  "description": "Retrieve content entries with filtering, full-text search, and linked content resolution. Supports complex queries including range filters, existence checks, and geographic location queries.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/entries",
  "method": "GET",
  "parameters": [
    { "name": "space_id", "type": "string", "description": "Your Contentful space ID.", "required": true, "example": "cfexampleapi" },
    { "name": "environment_id", "type": "string", "description": "Environment ID (usually 'master').", "required": true, "example": "master" },
    { "name": "content_type", "type": "string", "description": "Filter by content type ID.", "required": false, "example": "blogPost" },
    { "name": "include", "type": "number", "description": "Depth of linked entries to resolve (0-10).", "required": false, "example": 2 },
    { "name": "limit", "type": "number", "description": "Max entries to return (max 1000).", "required": false, "example": 100 },
    { "name": "skip", "type": "number", "description": "Number of entries to skip.", "required": false, "example": 0 },
    { "name": "order", "type": "string", "description": "Field to sort by (prefix with - for descending).", "required": false, "example": "-sys.createdAt" },
    { "name": "select", "type": "string", "description": "Comma-separated fields to include.", "required": false, "example": "fields.title,fields.slug" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/entries?content_type=blogPost&include=2&limit=10",
    "headers": { "Authorization": "Bearer {access_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": { "type": "Array" },
      "total": 42,
      "skip": 0,
      "limit": 10,
      "items": [
        {
          "sys": { "id": "entry_123", "type": "Entry", "contentType": { "sys": { "id": "blogPost" } }, "createdAt": "2024-01-15T10:00:00Z" },
          "fields": { "title": "Getting Started with Contentful", "slug": "getting-started", "body": "Welcome to our blog..." }
        }
      ],
      "includes": { "Entry": [], "Asset": [] }
    }
  }
}
