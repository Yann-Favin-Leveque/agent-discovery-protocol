{
  "name": "get_entry",
  "description": "Retrieve a single content entry by its ID. Returns the full entry with all fields and system metadata.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/entries/{entry_id}",
  "method": "GET",
  "parameters": [
    { "name": "space_id", "type": "string", "description": "Your Contentful space ID.", "required": true, "example": "cfexampleapi" },
    { "name": "environment_id", "type": "string", "description": "Environment ID.", "required": true, "example": "master" },
    { "name": "entry_id", "type": "string", "description": "The entry ID.", "required": true, "example": "entry_123" },
    { "name": "locale", "type": "string", "description": "Locale for localized fields.", "required": false, "example": "en-US" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/entries/entry_123",
    "headers": { "Authorization": "Bearer {access_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": { "id": "entry_123", "type": "Entry", "contentType": { "sys": { "id": "blogPost" } }, "createdAt": "2024-01-15T10:00:00Z", "updatedAt": "2024-02-01T14:30:00Z" },
      "fields": { "title": "Getting Started with Contentful", "slug": "getting-started", "body": "Welcome to our blog..." }
    }
  }
}
