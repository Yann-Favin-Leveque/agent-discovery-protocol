{
  "name": "taxonomy_concept_schemes_list",
  "description": "Retrieve all taxonomy concept schemes. Concept schemes are collections of related concepts forming a controlled vocabulary.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/taxonomy/concept_schemes",
  "method": "GET",
  "resource_group": "taxonomy",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "description": "The space ID.",
      "required": true,
      "example": "cfexampleapi"
    },
    {
      "name": "environment_id",
      "type": "string",
      "description": "The environment ID.",
      "required": true,
      "example": "master"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/taxonomy/concept_schemes",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": {"type": "Array"},
      "items": [
        {
          "sys": {"id": "scheme1", "type": "TaxonomyConceptScheme"},
          "prefLabel": "Content Categories",
          "definition": "Main content categorization scheme"
        }
      ],
      "total": 2
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 78
  }
}