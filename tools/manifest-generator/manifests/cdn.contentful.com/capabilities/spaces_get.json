{
  "name": "spaces_get",
  "description": "Retrieve metadata about a specific Contentful space including name, locales, and environment information.",
  "endpoint": "/spaces/{space_id}",
  "method": "GET",
  "resource_group": "spaces",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "description": "The ID of the Contentful space.",
      "required": true,
      "example": "cfexampleapi"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": {
        "type": "Space",
        "id": "cfexampleapi"
      },
      "name": "Contentful Example API",
      "locales": [
        {
          "code": "en-US",
          "default": true,
          "name": "English (United States)"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 78
  }
}