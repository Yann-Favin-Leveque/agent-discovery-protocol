{
  "name": "get_assets",
  "description": "Retrieve media assets (images, videos, documents) from a Contentful space. Assets include file metadata, dimensions, and CDN URLs for direct access.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/assets",
  "method": "GET",
  "parameters": [
    { "name": "space_id", "type": "string", "description": "Your Contentful space ID.", "required": true, "example": "cfexampleapi" },
    { "name": "environment_id", "type": "string", "description": "Environment ID.", "required": true, "example": "master" },
    { "name": "mimetype_group", "type": "string", "description": "Filter by MIME type group: image, video, audio, etc.", "required": false, "example": "image" },
    { "name": "limit", "type": "number", "description": "Max assets to return.", "required": false, "example": 20 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/assets?mimetype_group=image&limit=20",
    "headers": { "Authorization": "Bearer {access_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": { "type": "Array" },
      "total": 15,
      "items": [
        {
          "sys": { "id": "asset_456", "type": "Asset" },
          "fields": { "title": "Hero Image", "file": { "url": "//images.ctfassets.net/cfexampleapi/asset_456/hero.jpg", "contentType": "image/jpeg", "details": { "size": 245000, "image": { "width": 1920, "height": 1080 } } } }
        }
      ]
    }
  }
}
