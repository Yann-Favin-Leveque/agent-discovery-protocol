{
  "name": "search_content",
  "description": "Perform full-text search across all content in a Contentful space. Matches against all text fields and returns ranked results by relevance.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/entries",
  "method": "GET",
  "parameters": [
    { "name": "space_id", "type": "string", "description": "Your Contentful space ID.", "required": true, "example": "cfexampleapi" },
    { "name": "environment_id", "type": "string", "description": "Environment ID.", "required": true, "example": "master" },
    { "name": "query", "type": "string", "description": "Full-text search query.", "required": true, "example": "getting started" },
    { "name": "content_type", "type": "string", "description": "Limit search to a specific content type.", "required": false, "example": "blogPost" },
    { "name": "limit", "type": "number", "description": "Max results to return.", "required": false, "example": 10 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/entries?query=getting+started&content_type=blogPost&limit=10",
    "headers": { "Authorization": "Bearer {access_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": { "type": "Array" },
      "total": 3,
      "items": [
        {
          "sys": { "id": "entry_123", "type": "Entry", "contentType": { "sys": { "id": "blogPost" } } },
          "fields": { "title": "Getting Started with Contentful", "slug": "getting-started" }
        }
      ]
    }
  }
}
