{
  "name": "locales_list",
  "description": "Retrieve all configured locales for a space environment. Returns locale codes, names, and default locale setting.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/locales",
  "method": "GET",
  "resource_group": "locales",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "description": "The space ID.",
      "required": true,
      "example": "cfexampleapi"
    },
    {
      "name": "environment_id",
      "type": "string",
      "description": "The environment ID.",
      "required": true,
      "example": "master"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/locales",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": {"type": "Array"},
      "total": 2,
      "items": [
        {"code": "en-US", "name": "English (United States)", "default": true},
        {"code": "fr-FR", "name": "French (France)", "default": false}
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 78
  }
}