{
  "name": "get_content_types",
  "description": "Retrieve the content model — all content types and their field definitions. Use this to understand the structure of content in a space before querying entries.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/content_types",
  "method": "GET",
  "parameters": [
    { "name": "space_id", "type": "string", "description": "Your Contentful space ID.", "required": true, "example": "cfexampleapi" },
    { "name": "environment_id", "type": "string", "description": "Environment ID.", "required": true, "example": "master" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/content_types",
    "headers": { "Authorization": "Bearer {access_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": { "type": "Array" },
      "total": 3,
      "items": [
        {
          "sys": { "id": "blogPost", "type": "ContentType" },
          "name": "Blog Post",
          "description": "A blog post entry",
          "fields": [
            { "id": "title", "name": "Title", "type": "Symbol", "required": true },
            { "id": "body", "name": "Body", "type": "RichText", "required": true },
            { "id": "author", "name": "Author", "type": "Link", "linkType": "Entry" }
          ]
        }
      ]
    }
  }
}
