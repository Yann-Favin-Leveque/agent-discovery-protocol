{
  "name": "tags_get",
  "description": "Retrieve a single public tag by its ID.",
  "endpoint": "/spaces/{space_id}/environments/{environment_id}/tags/{tag_id}",
  "method": "GET",
  "resource_group": "tags",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "description": "The space ID.",
      "required": true,
      "example": "cfexampleapi"
    },
    {
      "name": "environment_id",
      "type": "string",
      "description": "The environment ID.",
      "required": true,
      "example": "master"
    },
    {
      "name": "tag_id",
      "type": "string",
      "description": "The tag ID.",
      "required": true,
      "example": "featured"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://cdn.contentful.com/spaces/cfexampleapi/environments/master/tags/featured",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sys": {"id": "featured", "type": "Tag"},
      "name": "Featured"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 78
  }
}