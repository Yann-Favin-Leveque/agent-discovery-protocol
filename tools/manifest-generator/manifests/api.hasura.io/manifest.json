{
  "spec_version": "1.0",
  "name": "Hasura",
  "description": "Hasura gives you instant GraphQL and REST APIs on your databases. Use this API to manage metadata, run GraphQL queries, execute raw SQL, and configure event triggers.",
  "base_url": "https://api.hasura.io",
  "auth": {
    "type": "api_key",
    "header": "x-hasura-admin-secret",
    "prefix": "",
    "setup_url": "https://cloud.hasura.io/projects"
  },
  "capabilities": [
    {
      "name": "graphql_query",
      "resource_group": "graphql",
      "description": "Execute GraphQL queries and mutations.",
      "detail_url": "/capabilities/graphql_query"
    },
    {
      "name": "metadata_export",
      "resource_group": "metadata",
      "description": "Export the complete Hasura metadata.",
      "detail_url": "/capabilities/metadata_export"
    },
    {
      "name": "metadata_apply",
      "resource_group": "metadata",
      "description": "Apply metadata changes (track tables, relationships, permissions).",
      "detail_url": "/capabilities/metadata_apply"
    },
    {
      "name": "metadata_reload",
      "resource_group": "metadata",
      "description": "Reload metadata from the database.",
      "detail_url": "/capabilities/metadata_reload"
    },
    {
      "name": "metadata_clear",
      "resource_group": "metadata",
      "description": "Clear all Hasura metadata.",
      "detail_url": "/capabilities/metadata_clear"
    },
    {
      "name": "schema_run_sql",
      "resource_group": "schema",
      "description": "Execute raw SQL against the database.",
      "detail_url": "/capabilities/schema_run_sql"
    },
    {
      "name": "health_check",
      "resource_group": "health",
      "description": "Check Hasura server health status.",
      "detail_url": "/capabilities/health_check"
    }
  ]
}