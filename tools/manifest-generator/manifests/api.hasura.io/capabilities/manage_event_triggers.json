{
  "name": "manage_event_triggers",
  "description": "Create and manage event triggers that fire webhooks when data changes in your database. Event triggers let you react to INSERT, UPDATE, and DELETE operations in real time.",
  "endpoint": "/v1/metadata",
  "method": "POST",
  "parameters": [
    { "name": "type", "type": "string", "description": "Must be 'pg_create_event_trigger'.", "required": true, "example": "pg_create_event_trigger" },
    { "name": "args", "type": "object", "description": "Event trigger configuration.", "required": true, "example": { "name": "user_created", "source": "default", "table": { "schema": "public", "name": "users" }, "webhook": "https://example.com/webhook", "insert": { "columns": "*" } } }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-project.hasura.app/v1/metadata",
    "headers": { "x-hasura-admin-secret": "{admin_secret}", "Content-Type": "application/json" },
    "body": { "type": "pg_create_event_trigger", "args": { "name": "user_created", "source": "default", "table": { "schema": "public", "name": "users" }, "webhook": "https://example.com/webhook", "insert": { "columns": "*" } } }
  },
  "response_example": {
    "status": 200,
    "body": { "message": "success" }
  }
}
