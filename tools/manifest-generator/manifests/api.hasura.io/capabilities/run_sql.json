{
  "name": "run_sql",
  "description": "Execute raw SQL statements against your database through Hasura. Useful for migrations, schema changes, and ad-hoc queries that go beyond GraphQL.",
  "endpoint": "/v2/query",
  "method": "POST",
  "parameters": [
    { "name": "type", "type": "string", "description": "Must be 'run_sql'.", "required": true, "example": "run_sql" },
    { "name": "args", "type": "object", "description": "Contains the SQL and options.", "required": true, "example": { "source": "default", "sql": "SELECT * FROM users LIMIT 10" } }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-project.hasura.app/v2/query",
    "headers": { "x-hasura-admin-secret": "{admin_secret}", "Content-Type": "application/json" },
    "body": { "type": "run_sql", "args": { "source": "default", "sql": "SELECT * FROM users LIMIT 10" } }
  },
  "response_example": {
    "status": 200,
    "body": { "result_type": "TuplesOk", "result": [["id", "name", "email"], ["1", "John", "john@example.com"]] }
  }
}
