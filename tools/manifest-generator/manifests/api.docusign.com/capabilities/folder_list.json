{
  "name": "folder_list",
  "description": "List folders in the account for organizing envelopes.",
  "resource_group": "folder",
  "endpoint": "/v2.1/accounts/{accountId}/folders",
  "method": "GET",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "signature"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://demo.docusign.net/restapi/v2.1/accounts/abc123/folders",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "folders": [
        {
          "folderId": "fld-123",
          "name": "Sent Items",
          "type": "sentitems"
        },
        {
          "folderId": "fld-456",
          "name": "Inbox",
          "type": "inbox"
        },
        {
          "folderId": "fld-789",
          "name": "Completed",
          "type": "completed"
        }
      ]
    }
  }
}