{
  "name": "folder_items_get",
  "description": "List envelopes in a specific folder.",
  "resource_group": "folder",
  "endpoint": "/v2.1/accounts/{accountId}/folders/{folderId}",
  "method": "GET",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "folderId",
      "type": "string",
      "required": true,
      "description": "Folder ID.",
      "in": "path"
    },
    {
      "name": "start_position",
      "type": "integer",
      "required": false,
      "description": "Pagination offset.",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "signature"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://demo.docusign.net/restapi/v2.1/accounts/abc123/folders/fld-789?count=25",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resultSetSize": "1",
      "folderItems": [
        {
          "envelopeId": "env-abc-123",
          "subject": "Contract Q1",
          "status": "completed",
          "completedDateTime": "2025-01-15T15:45:00.000Z",
          "senderName": "Jane Admin"
        }
      ]
    }
  }
}