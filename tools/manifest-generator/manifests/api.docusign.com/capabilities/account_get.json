{
  "name": "account_get",
  "description": "Retrieve account information including plan, settings, and branding configuration.",
  "resource_group": "account",
  "endpoint": "/v2.1/accounts/{accountId}",
  "method": "GET",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "signature"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://demo.docusign.net/restapi/v2.1/accounts/abc123",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "accountIdGuid": "abc123",
      "accountName": "My Company",
      "currentPlanId": "plan-123",
      "planName": "Business Pro",
      "billingPeriodStartDate": "2025-01-01",
      "billingPeriodEndDate": "2025-12-31"
    }
  }
}