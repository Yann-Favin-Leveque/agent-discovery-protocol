{
  "name": "user_list",
  "description": "List users in the account with their status and permissions.",
  "resource_group": "user",
  "endpoint": "/v2.1/accounts/{accountId}/users",
  "method": "GET",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by status: active, closed.",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "signature"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://demo.docusign.net/restapi/v2.1/accounts/abc123/users?status=active",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resultSetSize": "2",
      "users": [
        {
          "userId": "user-123",
          "userName": "Jane Admin",
          "email": "admin@example.com",
          "userStatus": "active",
          "permissionProfileName": "Account Administrator"
        }
      ]
    }
  }
}