{
  "name": "envelope_get",
  "description": "Retrieve the status, details, and metadata of a specific envelope by its ID.",
  "resource_group": "envelope",
  "endpoint": "/v2.1/accounts/{accountId}/envelopes/{envelopeId}",
  "method": "GET",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "envelopeId",
      "type": "string",
      "required": true,
      "description": "Envelope ID.",
      "in": "path"
    },
    {
      "name": "include",
      "type": "string",
      "required": false,
      "description": "Comma-separated additional data: recipients, documents, tabs, custom_fields.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "signature"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://demo.docusign.net/restapi/v2.1/accounts/abc123/envelopes/env-abc-123",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "envelopeId": "env-abc-123",
      "status": "completed",
      "emailSubject": "Please sign this document",
      "sentDateTime": "2025-01-15T14:30:00.000Z",
      "completedDateTime": "2025-01-15T15:45:00.000Z",
      "sender": {
        "userName": "Jane Admin",
        "email": "admin@example.com"
      }
    }
  }
}