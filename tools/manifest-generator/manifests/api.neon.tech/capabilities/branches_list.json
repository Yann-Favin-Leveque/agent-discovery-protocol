{
  "name": "branches_list",
  "resource_group": "branches",
  "description": "List all branches for a project.",
  "endpoint": "/projects/{project_id}/branches",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "branches": [
        {
          "id": "br-abc123",
          "name": "main",
          "primary": true
        }
      ]
    }
  }
}