{
  "name": "branches_delete",
  "resource_group": "branches",
  "description": "Delete a branch.",
  "endpoint": "/projects/{project_id}/branches/{branch_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "branch_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches/br-def456",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "branch": {
        "id": "br-def456"
      }
    }
  }
}