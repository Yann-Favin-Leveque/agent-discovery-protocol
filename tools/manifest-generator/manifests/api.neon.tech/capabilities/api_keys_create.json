{
  "name": "api_keys_create",
  "resource_group": "api_keys",
  "description": "Create an API key. The key is only returned once.",
  "endpoint": "/api_keys",
  "method": "POST",
  "parameters": [
    {
      "name": "key_name",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Key name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://console.neon.tech/api/v2/api_keys",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "key_name": "ci-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 2,
      "key": "neon_api_key_abc...",
      "name": "ci-key"
    }
  }
}