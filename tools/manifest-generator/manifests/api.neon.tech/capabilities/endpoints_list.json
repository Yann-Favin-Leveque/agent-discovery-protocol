{
  "name": "endpoints_list",
  "resource_group": "endpoints",
  "description": "List compute endpoints for a project.",
  "endpoint": "/projects/{project_id}/endpoints",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/endpoints",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "endpoints": [
        {
          "id": "ep-abc123",
          "branch_id": "br-abc123",
          "type": "read_write",
          "current_state": "active"
        }
      ]
    }
  }
}