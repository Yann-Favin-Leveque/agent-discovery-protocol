{
  "name": "roles_create",
  "resource_group": "roles",
  "description": "Create a new role.",
  "endpoint": "/projects/{project_id}/branches/{branch_id}/roles",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "branch_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch ID."
    },
    {
      "name": "role",
      "type": "object",
      "required": true,
      "in": "body",
      "description": "Role config: name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches/br-abc123/roles",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "role": {
        "name": "app_user"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "role": {
        "name": "app_user",
        "password": "generated"
      }
    }
  }
}