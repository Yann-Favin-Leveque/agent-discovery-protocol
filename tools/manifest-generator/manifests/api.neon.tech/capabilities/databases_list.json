{
  "name": "databases_list",
  "resource_group": "databases",
  "description": "List databases in a branch.",
  "endpoint": "/projects/{project_id}/branches/{branch_id}/databases",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "branch_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches/br-abc123/databases",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "databases": [
        {
          "id": 1,
          "name": "neondb",
          "owner_name": "neondb_owner"
        }
      ]
    }
  }
}