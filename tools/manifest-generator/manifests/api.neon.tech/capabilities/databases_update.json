{
  "name": "databases_update",
  "resource_group": "databases",
  "description": "Update database settings.",
  "endpoint": "/projects/{project_id}/branches/{branch_id}/databases/{database_name}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "branch_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch ID."
    },
    {
      "name": "database_name",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "database",
      "type": "object",
      "required": true,
      "in": "body",
      "description": "Fields to update."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches/br-abc123/databases/neondb",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "database": {
        "name": "newname"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "database": {
        "id": 1,
        "name": "newname"
      }
    }
  }
}