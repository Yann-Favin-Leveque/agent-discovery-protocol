{
  "name": "roles_get",
  "resource_group": "roles",
  "description": "Retrieve a specific role.",
  "endpoint": "/projects/{project_id}/branches/{branch_id}/roles/{role_name}",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "branch_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch ID."
    },
    {
      "name": "role_name",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Role name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches/br-abc123/roles/app_user",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "role": {
        "name": "app_user"
      }
    }
  }
}