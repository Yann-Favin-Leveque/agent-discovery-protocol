{
  "name": "projects_recover",
  "resource_group": "projects",
  "description": "Recover a deleted project during grace period.",
  "endpoint": "/projects/{project_id}/recover",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/recover",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "project": {
        "id": "proj-abc123"
      }
    }
  }
}