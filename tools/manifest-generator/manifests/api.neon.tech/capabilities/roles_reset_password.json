{
  "name": "roles_reset_password",
  "resource_group": "roles",
  "description": "Reset a role password.",
  "endpoint": "/projects/{project_id}/branches/{branch_id}/roles/{role_name}/reset_password",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "branch_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch ID."
    },
    {
      "name": "role_name",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Role name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches/br-abc123/roles/app_user/reset_password",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "role": {
        "name": "app_user",
        "password": "new-password"
      }
    }
  }
}