{
  "name": "roles_list",
  "resource_group": "roles",
  "description": "List roles in a branch.",
  "endpoint": "/projects/{project_id}/branches/{branch_id}/roles",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "branch_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/branches/br-abc123/roles",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "roles": [
        {
          "name": "neondb_owner",
          "protected": true
        }
      ]
    }
  }
}