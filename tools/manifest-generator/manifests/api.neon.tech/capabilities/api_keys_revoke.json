{
  "name": "api_keys_revoke",
  "resource_group": "api_keys",
  "description": "Revoke an API key (irreversible).",
  "endpoint": "/api_keys/{key_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "key_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "API key ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://console.neon.tech/api/v2/api_keys/1",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "revoked": true
    }
  }
}