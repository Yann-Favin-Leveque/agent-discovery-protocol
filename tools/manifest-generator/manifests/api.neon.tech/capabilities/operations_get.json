{
  "name": "operations_get",
  "resource_group": "operations",
  "description": "Retrieve operation details.",
  "endpoint": "/projects/{project_id}/operations/{operation_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "operation_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Operation ID (UUID)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/operations/op-abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "operation": {
        "id": "op-abc123",
        "action": "create_branch",
        "status": "finished"
      }
    }
  }
}