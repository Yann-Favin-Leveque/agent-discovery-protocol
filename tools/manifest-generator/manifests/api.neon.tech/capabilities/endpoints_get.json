{
  "name": "endpoints_get",
  "resource_group": "endpoints",
  "description": "Retrieve endpoint details.",
  "endpoint": "/projects/{project_id}/endpoints/{endpoint_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Neon project ID."
    },
    {
      "name": "endpoint_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Endpoint ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://console.neon.tech/api/v2/projects/proj-abc123/endpoints/ep-abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "endpoint": {
        "id": "ep-abc123",
        "current_state": "active"
      }
    }
  }
}