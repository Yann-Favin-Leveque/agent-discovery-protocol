{
  "name": "get_current_weather",
  "description": "Retrieve current weather conditions for any location on Earth. Returns temperature, feels-like temperature, min/max temperature, atmospheric pressure, humidity, visibility, wind speed and direction, cloud coverage, and a human-readable weather description. Data is updated approximately every 10 minutes.",
  "endpoint": "/data/2.5/weather",
  "method": "GET",
  "parameters": [
    {
      "name": "lat",
      "type": "number",
      "description": "Latitude of the location. Required along with lon.",
      "required": true,
      "example": 48.8566
    },
    {
      "name": "lon",
      "type": "number",
      "description": "Longitude of the location. Required along with lat.",
      "required": true,
      "example": 2.3522
    },
    {
      "name": "appid",
      "type": "string",
      "description": "Your API key for authentication.",
      "required": true,
      "example": "{api_key}"
    },
    {
      "name": "units",
      "type": "string",
      "description": "Units of measurement: 'standard' (Kelvin), 'metric' (Celsius), or 'imperial' (Fahrenheit).",
      "required": false,
      "example": "metric"
    },
    {
      "name": "lang",
      "type": "string",
      "description": "Language code for weather description translation (e.g. 'en', 'fr', 'de').",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.openweathermap.org/data/2.5/weather?lat=48.8566&lon=2.3522&units=metric&appid={api_key}",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "coord": { "lon": 2.3522, "lat": 48.8566 },
      "weather": [
        {
          "id": 802,
          "main": "Clouds",
          "description": "scattered clouds",
          "icon": "03d"
        }
      ],
      "main": {
        "temp": 18.5,
        "feels_like": 17.8,
        "temp_min": 16.2,
        "temp_max": 20.1,
        "pressure": 1015,
        "humidity": 62
      },
      "visibility": 10000,
      "wind": {
        "speed": 3.6,
        "deg": 220,
        "gust": 5.1
      },
      "clouds": { "all": 40 },
      "dt": 1700000000,
      "sys": {
        "country": "FR",
        "sunrise": 1699945200,
        "sunset": 1699980000
      },
      "timezone": 3600,
      "name": "Paris",
      "cod": 200
    }
  }
}
