{
  "name": "geocode_zip",
  "description": "Convert a zip/postal code to geographic coordinates.",
  "resource_group": "geocoding",
  "endpoint": "/geo/1.0/zip",
  "method": "GET",
  "parameters": [
    {
      "name": "zip",
      "type": "string",
      "required": true,
      "description": "Zip code and country code separated by comma. Example: '75001,FR'.",
      "in": "query"
    },
    {
      "name": "appid",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.openweathermap.org/geo/1.0/zip?zip=75001,FR&appid=YOUR_API_KEY"
  },
  "response_example": {
    "status": 200,
    "body": {
      "zip": "75001",
      "name": "Paris",
      "lat": 48.86,
      "lon": 2.35,
      "country": "FR"
    }
  }
}