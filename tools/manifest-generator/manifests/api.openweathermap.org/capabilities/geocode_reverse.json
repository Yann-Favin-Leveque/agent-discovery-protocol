{
  "name": "geocode_reverse",
  "description": "Convert geographic coordinates to human-readable location names (reverse geocoding).",
  "resource_group": "geocoding",
  "endpoint": "/geo/1.0/reverse",
  "method": "GET",
  "parameters": [
    {
      "name": "lat",
      "type": "number",
      "required": true,
      "description": "Latitude.",
      "in": "query"
    },
    {
      "name": "lon",
      "type": "number",
      "required": true,
      "description": "Longitude.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of results.",
      "in": "query"
    },
    {
      "name": "appid",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.openweathermap.org/geo/1.0/reverse?lat=48.8566&lon=2.3522&limit=1&appid=YOUR_API_KEY"
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "name": "Paris",
        "lat": 48.8566,
        "lon": 2.3522,
        "country": "FR",
        "state": "Ile-de-France"
      }
    ]
  }
}