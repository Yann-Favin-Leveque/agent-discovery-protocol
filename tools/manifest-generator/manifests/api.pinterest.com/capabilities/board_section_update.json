{
  "name": "board_section_update",
  "resource_group": "board_sections",
  "description": "Update a board section name.",
  "endpoint": "/boards/{board_id}/sections/{section_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "board_id",
      "type": "string",
      "description": "Board ID.",
      "required": true,
      "in": "path",
      "example": "549755885175"
    },
    {
      "name": "section_id",
      "type": "string",
      "description": "Section ID.",
      "required": true,
      "in": "path",
      "example": "549755885178"
    },
    {
      "name": "name",
      "type": "string",
      "description": "New name.",
      "required": true,
      "in": "body",
      "example": "Western Europe"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.pinterest.com/v5/boards/549755885175/sections/549755885178",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Western Europe"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "549755885178",
      "name": "Western Europe"
    }
  },
  "auth_scopes": [
    "boards:write"
  ]
}