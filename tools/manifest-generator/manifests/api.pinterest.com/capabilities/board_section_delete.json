{
  "name": "board_section_delete",
  "resource_group": "board_sections",
  "description": "Delete a section from a board.",
  "endpoint": "/boards/{board_id}/sections/{section_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "board_id",
      "type": "string",
      "description": "Board ID.",
      "required": true,
      "in": "path",
      "example": "549755885175"
    },
    {
      "name": "section_id",
      "type": "string",
      "description": "Section ID.",
      "required": true,
      "in": "path",
      "example": "549755885178"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.pinterest.com/v5/boards/549755885175/sections/549755885178",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  },
  "auth_scopes": [
    "boards:write"
  ]
}