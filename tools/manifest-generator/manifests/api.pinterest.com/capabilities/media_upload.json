{
  "name": "media_upload",
  "resource_group": "media",
  "description": "Register intent to upload media and get an upload URL.",
  "endpoint": "/media",
  "method": "POST",
  "parameters": [
    {
      "name": "media_type",
      "type": "string",
      "description": "image or video.",
      "required": true,
      "in": "body",
      "example": "image"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pinterest.com/v5/media",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "media_type": "image"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "media_id": "549755885180",
      "media_type": "image",
      "upload_url": "https://pinterest-media-upload.s3.amazonaws.com/..."
    }
  },
  "auth_scopes": [
    "pins:write"
  ]
}