{
  "name": "list_boards",
  "description": "Fetch a paginated list of boards owned by the authenticated user. Returns board names, descriptions, pin counts, privacy settings, and creation dates.",
  "endpoint": "/v5/boards",
  "method": "GET",
  "parameters": [
    {
      "name": "page_size",
      "type": "integer",
      "description": "Maximum number of boards to return per page (1-250).",
      "required": false,
      "example": 25
    },
    {
      "name": "bookmark",
      "type": "string",
      "description": "Cursor token for pagination to fetch the next page of results.",
      "required": false,
      "example": "Y2lkPTI1..."
    },
    {
      "name": "privacy",
      "type": "string",
      "description": "Filter boards by privacy setting. One of: PUBLIC, PROTECTED, ALL.",
      "required": false,
      "example": "PUBLIC"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/boards?page_size=25&privacy=PUBLIC",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "549755885175",
          "name": "Travel Inspiration",
          "description": "Beautiful places around the world",
          "pin_count": 142,
          "privacy": "PUBLIC",
          "created_at": "2023-06-15T10:00:00Z",
          "owner": {
            "username": "myaccount"
          }
        },
        {
          "id": "549755885180",
          "name": "Home Decor Ideas",
          "description": "Interior design and decor inspiration",
          "pin_count": 87,
          "privacy": "PUBLIC",
          "created_at": "2023-08-20T14:30:00Z",
          "owner": {
            "username": "myaccount"
          }
        }
      ],
      "bookmark": "Y2lkPTM1..."
    }
  }
}
