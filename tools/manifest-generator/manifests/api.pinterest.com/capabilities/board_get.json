{
  "name": "board_get",
  "resource_group": "boards",
  "description": "Get board details by ID.",
  "endpoint": "/boards/{board_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "board_id",
      "type": "string",
      "description": "Board ID.",
      "required": true,
      "in": "path",
      "example": "549755885175"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/boards/549755885175",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "549755885175",
      "name": "Travel Ideas",
      "pin_count": 42,
      "privacy": "PUBLIC"
    }
  },
  "auth_scopes": [
    "boards:read"
  ]
}