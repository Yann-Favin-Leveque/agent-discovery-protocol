{
  "name": "user_followers_list",
  "resource_group": "user_accounts",
  "description": "Get paginated followers list.",
  "endpoint": "/user_account/followers",
  "method": "GET",
  "parameters": [
    {
      "name": "bookmark",
      "type": "string",
      "description": "Pagination.",
      "required": false,
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Items per page.",
      "required": false,
      "in": "query",
      "example": 25
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/user_account/followers",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "username": "follower1"
        }
      ],
      "bookmark": "Y2Jh..."
    }
  },
  "auth_scopes": [
    "user_accounts:read"
  ]
}