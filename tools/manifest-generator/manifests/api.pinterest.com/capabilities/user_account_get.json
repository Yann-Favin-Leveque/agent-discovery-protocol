{
  "name": "user_account_get",
  "resource_group": "user_accounts",
  "description": "Retrieve the authenticated user Pinterest profile.",
  "endpoint": "/user_account",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/user_account",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "username": "myuser",
      "account_type": "BUSINESS",
      "follower_count": 1200,
      "pin_count": 482,
      "board_count": 25
    }
  },
  "auth_scopes": [
    "user_accounts:read"
  ]
}