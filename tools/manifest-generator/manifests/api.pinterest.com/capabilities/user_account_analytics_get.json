{
  "name": "user_account_analytics_get",
  "resource_group": "analytics",
  "description": "Retrieve user account analytics over a date range.",
  "endpoint": "/user_account/analytics",
  "method": "GET",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "description": "YYYY-MM-DD.",
      "required": true,
      "in": "query",
      "example": "2024-01-01"
    },
    {
      "name": "end_date",
      "type": "string",
      "description": "YYYY-MM-DD.",
      "required": true,
      "in": "query",
      "example": "2024-03-01"
    },
    {
      "name": "metric_types",
      "type": "string",
      "description": "IMPRESSION,SAVE,PIN_CLICK.",
      "required": true,
      "in": "query",
      "example": "IMPRESSION,SAVE"
    },
    {
      "name": "app_types",
      "type": "string",
      "description": "ALL,MOBILE,TABLET,WEB.",
      "required": false,
      "in": "query",
      "example": "ALL"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/user_account/analytics?start_date=2024-01-01&end_date=2024-03-01&metric_types=IMPRESSION,SAVE",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "all": {
        "daily_metrics": [
          {
            "date": "2024-03-01",
            "metrics": {
              "IMPRESSION": 5200,
              "SAVE": 42
            }
          }
        ]
      }
    }
  },
  "auth_scopes": [
    "user_accounts:read"
  ]
}