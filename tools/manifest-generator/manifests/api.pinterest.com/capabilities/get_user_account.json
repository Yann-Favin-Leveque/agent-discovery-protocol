{
  "name": "get_user_account",
  "description": "Retrieve the authenticated user's Pinterest profile including username, display name, bio, profile image, follower count, following count, and website URL.",
  "endpoint": "/v5/user_account",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/user_account",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "username": "myaccount",
      "account_type": "BUSINESS",
      "profile_image": "https://i.pinimg.com/avatars/myaccount_1234.jpg",
      "website_url": "https://example.com",
      "follower_count": 5230,
      "following_count": 312,
      "board_count": 24,
      "pin_count": 1847
    }
  }
}
