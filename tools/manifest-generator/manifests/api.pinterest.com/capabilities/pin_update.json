{
  "name": "pin_update",
  "resource_group": "pins",
  "description": "Update a pin title, description, link, board, or alt text.",
  "endpoint": "/pins/{pin_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "pin_id",
      "type": "string",
      "description": "Pin ID.",
      "required": true,
      "in": "path",
      "example": "549755885177"
    },
    {
      "name": "title",
      "type": "string",
      "description": "New title.",
      "required": false,
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "description": "New description.",
      "required": false,
      "in": "body"
    },
    {
      "name": "link",
      "type": "string",
      "description": "New URL.",
      "required": false,
      "in": "body"
    },
    {
      "name": "board_id",
      "type": "string",
      "description": "Move to board.",
      "required": false,
      "in": "body"
    },
    {
      "name": "alt_text",
      "type": "string",
      "description": "New alt text.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.pinterest.com/v5/pins/549755885177",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Updated"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "549755885177",
      "title": "Updated"
    }
  },
  "auth_scopes": [
    "pins:write"
  ]
}