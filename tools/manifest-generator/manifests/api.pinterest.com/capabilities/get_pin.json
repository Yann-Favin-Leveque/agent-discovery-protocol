{
  "name": "get_pin",
  "description": "Retrieve detailed information about a specific pin including its image, title, description, destination link, board, creation date, and engagement metrics like saves and comments.",
  "endpoint": "/v5/pins/{pin_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "pin_id",
      "type": "string",
      "description": "The unique identifier of the pin to retrieve.",
      "required": true,
      "example": "549755885176"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/pins/549755885176",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "549755885176",
      "created_at": "2024-03-01T18:30:00Z",
      "link": "https://example.com/blog/sunset-photography",
      "title": "Beautiful Sunset Photography",
      "description": "Stunning sunset captured at the Pacific coast.",
      "board_id": "549755885175",
      "board_owner": {
        "username": "myaccount"
      },
      "media": {
        "media_type": "image",
        "images": {
          "original": {
            "url": "https://i.pinimg.com/originals/ab/cd/ef.jpg",
            "width": 1200,
            "height": 800
          }
        }
      },
      "pin_metrics": {
        "save_count": 42,
        "comment_count": 3
      }
    }
  }
}
