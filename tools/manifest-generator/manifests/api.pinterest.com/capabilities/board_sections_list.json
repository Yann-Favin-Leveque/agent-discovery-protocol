{
  "name": "board_sections_list",
  "resource_group": "board_sections",
  "description": "List all sections in a board.",
  "endpoint": "/boards/{board_id}/sections",
  "method": "GET",
  "parameters": [
    {
      "name": "board_id",
      "type": "string",
      "description": "Board ID.",
      "required": true,
      "in": "path",
      "example": "549755885175"
    },
    {
      "name": "bookmark",
      "type": "string",
      "description": "Pagination.",
      "required": false,
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Items per page.",
      "required": false,
      "in": "query",
      "example": 25
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pinterest.com/v5/boards/549755885175/sections",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "549755885178",
          "name": "Europe"
        }
      ]
    }
  },
  "auth_scopes": [
    "boards:read"
  ]
}