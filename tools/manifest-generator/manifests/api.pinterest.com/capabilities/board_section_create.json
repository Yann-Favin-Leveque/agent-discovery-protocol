{
  "name": "board_section_create",
  "resource_group": "board_sections",
  "description": "Create a section in a board.",
  "endpoint": "/boards/{board_id}/sections",
  "method": "POST",
  "parameters": [
    {
      "name": "board_id",
      "type": "string",
      "description": "Board ID.",
      "required": true,
      "in": "path",
      "example": "549755885175"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Section name.",
      "required": true,
      "in": "body",
      "example": "Europe"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pinterest.com/v5/boards/549755885175/sections",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Europe"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "549755885178",
      "name": "Europe"
    }
  },
  "auth_scopes": [
    "boards:write"
  ]
}