{
  "name": "accounts_update_metadata",
  "description": "Create or update custom metadata values on an account record.",
  "endpoint": "/v1/metadata/account/custom/value",
  "method": "POST",
  "resource_group": "accounts",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "description": "The account ID to update metadata for.",
      "required": true,
      "example": "acme-corp",
      "in": "body"
    },
    {
      "name": "values",
      "type": "object",
      "description": "Key-value pairs of metadata to set.",
      "required": true,
      "example": {
        "plan": "enterprise",
        "industry": "Technology",
        "employee_count": 500
      },
      "in": "body"
    },
    {
      "name": "create",
      "type": "boolean",
      "description": "If true, create metadata fields that do not exist.",
      "required": false,
      "example": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://app.pendo.io/api/v1/metadata/account/custom/value?create=true",
    "headers": {
      "x-pendo-integration-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "accountId": "acme-corp",
      "values": {
        "plan": "enterprise",
        "industry": "Technology"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "metadata"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
