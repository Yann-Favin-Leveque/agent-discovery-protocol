{
  "name": "visitors_get",
  "description": "Retrieve visitor (user) details including metadata, account association, and last visit time.",
  "endpoint": "/v1/visitor/{visitor_id}",
  "method": "GET",
  "resource_group": "visitors",
  "parameters": [
    {
      "name": "visitor_id",
      "type": "string",
      "description": "The visitor/user ID.",
      "required": true,
      "example": "user_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.pendo.io/api/v1/visitor/user_123",
    "headers": {
      "x-pendo-integration-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "visitorId": "user_123",
      "accountId": "acme-corp",
      "metadata": {
        "auto": { "firstvisit": 1705747200000, "lastvisit": 1706006400000 },
        "custom": { "email": "john@acme.com", "plan": "enterprise", "role": "admin" }
      },
      "npsScore": 9
    }
  },
  "auth_scopes": ["visitor"],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
