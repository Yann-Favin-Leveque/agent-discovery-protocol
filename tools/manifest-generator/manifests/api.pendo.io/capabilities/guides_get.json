{
  "name": "guides_get",
  "description": "Retrieve details of a specific in-app guide including steps, targeting, and completion statistics.",
  "endpoint": "/v1/guide/{guide_id}",
  "method": "GET",
  "resource_group": "guides",
  "parameters": [
    {
      "name": "guide_id",
      "type": "string",
      "description": "The guide ID.",
      "required": true,
      "example": "guide_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.pendo.io/api/v1/guide/guide_123",
    "headers": {
      "x-pendo-integration-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "guide_123",
      "name": "Welcome Tour",
      "state": "public",
      "launchMethod": "auto",
      "steps": [
        { "id": "step_1", "type": "tooltip", "content": "Welcome to the dashboard!" },
        { "id": "step_2", "type": "tooltip", "content": "Click here to create your first project." }
      ],
      "numViews": 5000,
      "numCompletions": 3200,
      "createdAt": 1705747200000
    }
  },
  "auth_scopes": ["guide"],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
