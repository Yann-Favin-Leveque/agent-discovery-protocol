{
  "name": "pages_list",
  "description": "List all tracked pages in Pendo with view counts, unique visitors, and time-on-page data.",
  "endpoint": "/v1/page",
  "method": "GET",
  "resource_group": "pages",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://app.pendo.io/api/v1/page",
    "headers": {
      "x-pendo-integration-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "page_xyz",
        "name": "Dashboard",
        "urlRule": "/dashboard",
        "numViews": 25000,
        "numVisitors": 5000,
        "avgTimeOnPage": 45000,
        "createdAt": 1705747200000
      }
    ]
  },
  "auth_scopes": ["page"],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
