{
  "name": "reports_list",
  "description": "List all saved reports in Pendo with their types and creation dates.",
  "endpoint": "/v1/report",
  "method": "GET",
  "resource_group": "reports",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://app.pendo.io/api/v1/report",
    "headers": {
      "x-pendo-integration-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "report_abc",
        "name": "Weekly Feature Usage",
        "type": "feature_usage",
        "createdAt": 1705747200000
      }
    ]
  },
  "auth_scopes": ["report"],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
