{
  "name": "events_track",
  "description": "Send a custom server-side track event to Pendo for product analytics.",
  "endpoint": "/v1/track",
  "method": "POST",
  "resource_group": "events",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "Event type, always 'track'.",
      "required": true,
      "example": "track"
    },
    {
      "name": "event",
      "type": "string",
      "description": "Event name.",
      "required": true,
      "example": "Feature Activated"
    },
    {
      "name": "visitorId",
      "type": "string",
      "description": "Unique visitor/user ID.",
      "required": true,
      "example": "user_123"
    },
    {
      "name": "accountId",
      "type": "string",
      "description": "Account/company ID for B2B tracking.",
      "required": false,
      "example": "acme-corp"
    },
    {
      "name": "properties",
      "type": "object",
      "description": "Custom event properties.",
      "required": false,
      "example": { "feature": "export", "plan": "enterprise" }
    },
    {
      "name": "timestamp",
      "type": "number",
      "description": "Unix timestamp in milliseconds.",
      "required": false,
      "example": 1705747200000
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://app.pendo.io/api/v1/track",
    "headers": {
      "x-pendo-integration-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "type": "track",
      "event": "Feature Activated",
      "visitorId": "user_123",
      "accountId": "acme-corp",
      "properties": { "feature": "export", "plan": "enterprise" },
      "timestamp": 1705747200000
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": ["track"],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
