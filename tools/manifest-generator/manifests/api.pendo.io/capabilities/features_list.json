{
  "name": "features_list",
  "description": "List all tracked features with click counts and unique visitor analytics.",
  "endpoint": "/v1/feature",
  "method": "GET",
  "resource_group": "features",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://app.pendo.io/api/v1/feature",
    "headers": {
      "x-pendo-integration-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "feat_abc123",
        "name": "Export Button",
        "pageId": "page_xyz",
        "elementPath": "button#export",
        "numClicks": 5000,
        "numVisitors": 1200,
        "createdAt": 1705747200000
      }
    ]
  },
  "auth_scopes": ["feature"],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
