{
  "name": "channels_close",
  "description": "Close an active push notification channel, stopping all future notifications on that channel.",
  "endpoint": "/v1/channels/{channel_id}",
  "method": "DELETE",
  "resource_group": "push_notifications",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "description": "The channel ID to close (path parameter)."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cronofy.com/v1/channels/chn_abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 202,
    "body": {}
  },
  "auth_scopes": ["read_events"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
