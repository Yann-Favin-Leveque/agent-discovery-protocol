{
  "name": "channels_list",
  "description": "List all active push notification channels for the authenticated user.",
  "endpoint": "/v1/channels",
  "method": "GET",
  "resource_group": "push_notifications",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.cronofy.com/v1/channels",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "channels": [
        {
          "channel_id": "chn_abc123",
          "callback_url": "https://example.com/webhooks/cronofy/changes",
          "filters": {}
        }
      ]
    }
  },
  "auth_scopes": ["read_events"],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
