{
  "name": "calendars_list",
  "description": "List all calendars accessible to the authenticated user across all connected calendar providers (Google, Outlook, Apple, Exchange).",
  "endpoint": "/v1/calendars",
  "method": "GET",
  "resource_group": "calendars",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.cronofy.com/v1/calendars",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "calendars": [
        {
          "provider_name": "google",
          "profile_id": "pro_n23kjnwrw2",
          "profile_name": "john@example.com",
          "calendar_id": "cal_n23kjnwrw2_abc123",
          "calendar_name": "Work Calendar",
          "calendar_readonly": false,
          "calendar_deleted": false,
          "calendar_primary": true,
          "permission_level": "sandbox"
        }
      ]
    }
  },
  "auth_scopes": ["read_account"],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
