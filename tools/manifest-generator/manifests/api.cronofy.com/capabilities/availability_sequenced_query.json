{
  "name": "availability_sequenced_query",
  "description": "Find available time slots for a sequence of events that must happen in order, each with their own participants and duration requirements.",
  "endpoint": "/v1/sequenced_availability",
  "method": "POST",
  "resource_group": "scheduling",
  "parameters": [
    {
      "name": "sequence",
      "type": "array",
      "required": true,
      "description": "Ordered array of availability queries, each with 'participants', 'required_duration', and optional 'buffer'."
    },
    {
      "name": "query_periods",
      "type": "array",
      "required": true,
      "description": "Time windows for the overall sequence."
    },
    {
      "name": "response_format",
      "type": "string",
      "required": false,
      "description": "Result format: 'periods' (default) or 'slots'."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cronofy.com/v1/sequenced_availability",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {api_key}"
    },
    "body": {
      "sequence": [
        {
          "participants": [{ "members": [{ "sub": "acc_123" }], "required": "all" }],
          "required_duration": { "minutes": 30 }
        },
        {
          "participants": [{ "members": [{ "sub": "acc_456" }], "required": "all" }],
          "required_duration": { "minutes": 60 }
        }
      ],
      "query_periods": [{ "start": "2024-01-20T09:00:00Z", "end": "2024-01-20T18:00:00Z" }]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "available_periods": [
        {
          "sequence": [
            { "start": "2024-01-20T10:00:00Z", "end": "2024-01-20T10:30:00Z", "participants": [{ "sub": "acc_123" }] },
            { "start": "2024-01-20T10:30:00Z", "end": "2024-01-20T11:30:00Z", "participants": [{ "sub": "acc_456" }] }
          ]
        }
      ]
    }
  },
  "auth_scopes": ["read_free_busy"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
