{
  "spec_version": "1.0",
  "name": "Tally",
  "description": "Tally is a free form builder. Use this API to manage forms and submissions programmatically, including creating, updating, and deleting forms, and retrieving submission data.",
  "base_url": "https://api.tally.so",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://tally.so/settings/integrations"
  },
  "capabilities": [
    {
      "name": "forms_list",
      "resource_group": "forms",
      "description": "List all forms with pagination.",
      "detail_url": "/capabilities/forms_list"
    },
    {
      "name": "forms_get",
      "resource_group": "forms",
      "description": "Get a form by ID with all blocks and settings.",
      "detail_url": "/capabilities/forms_get"
    },
    {
      "name": "forms_delete",
      "resource_group": "forms",
      "description": "Delete a form (move to trash).",
      "detail_url": "/capabilities/forms_delete"
    },
    {
      "name": "submissions_list",
      "resource_group": "submissions",
      "description": "List submissions for a form.",
      "detail_url": "/capabilities/submissions_list"
    },
    {
      "name": "submissions_get",
      "resource_group": "submissions",
      "description": "Get a specific submission.",
      "detail_url": "/capabilities/submissions_get"
    },
    {
      "name": "submissions_delete",
      "resource_group": "submissions",
      "description": "Delete a submission.",
      "detail_url": "/capabilities/submissions_delete"
    }
  ]
}