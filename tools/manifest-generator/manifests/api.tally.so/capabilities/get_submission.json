{
  "name": "get_submission",
  "description": "Retrieve details of a single form submission by its ID. Returns all question-answer pairs for that specific submission.",
  "endpoint": "/forms/{formId}/submissions/{submissionId}",
  "method": "GET",
  "parameters": [
    { "name": "formId", "type": "string", "description": "The form ID.", "required": true, "example": "form_abc123" },
    { "name": "submissionId", "type": "string", "description": "The submission ID.", "required": true, "example": "sub_xyz789" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tally.so/forms/form_abc123/submissions/sub_xyz789",
    "headers": { "Authorization": "Bearer {api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "submissionId": "sub_xyz789",
      "createdAt": "2024-02-01T14:30:00Z",
      "fields": [
        { "key": "question_name", "label": "Your Name", "type": "INPUT_TEXT", "value": "Jane Doe" },
        { "key": "question_email", "label": "Email", "type": "INPUT_EMAIL", "value": "jane@example.com" },
        { "key": "question_message", "label": "Message", "type": "TEXTAREA", "value": "I'd like to learn more about your services." }
      ]
    }
  }
}
