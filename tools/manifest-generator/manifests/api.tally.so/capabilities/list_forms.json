{
  "name": "list_forms",
  "description": "Retrieve a list of all forms in your Tally workspace. Returns form metadata including name, status, creation date, and submission count.",
  "endpoint": "/forms",
  "method": "GET",
  "parameters": [
    { "name": "page", "type": "number", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "limit", "type": "number", "description": "Number of forms per page.", "required": false, "example": 20 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tally.so/forms?page=1&limit=20",
    "headers": { "Authorization": "Bearer {api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "page": 1,
      "totalNumberOfPages": 1,
      "data": [
        { "id": "form_abc123", "name": "Contact Form", "status": "PUBLISHED", "createdAt": "2024-01-15T10:00:00Z", "numberOfSubmissions": 42 }
      ]
    }
  }
}
