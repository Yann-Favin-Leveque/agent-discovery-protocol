{
  "name": "forms_get",
  "resource_group": "forms",
  "description": "Retrieve a form by ID including all blocks and settings.",
  "endpoint": "/forms/{formId}",
  "method": "GET",
  "parameters": [
    {
      "name": "formId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tally.so/forms/form-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "form-123",
      "name": "Feedback Form",
      "status": "PUBLISHED",
      "blocks": [],
      "settings": {
        "language": "en"
      }
    }
  }
}