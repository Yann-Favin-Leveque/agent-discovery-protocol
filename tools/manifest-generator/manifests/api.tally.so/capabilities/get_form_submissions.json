{
  "name": "get_form_submissions",
  "description": "Get all submissions for a specific form with filtering and pagination. Each submission contains the respondent's answers to all form questions.",
  "endpoint": "/forms/{formId}/submissions",
  "method": "GET",
  "parameters": [
    { "name": "formId", "type": "string", "description": "The form ID.", "required": true, "example": "form_abc123" },
    { "name": "page", "type": "number", "description": "Page number.", "required": false, "example": 1 },
    { "name": "limit", "type": "number", "description": "Submissions per page.", "required": false, "example": 50 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tally.so/forms/form_abc123/submissions?page=1&limit=50",
    "headers": { "Authorization": "Bearer {api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "page": 1,
      "totalNumberOfPages": 1,
      "data": [
        {
          "submissionId": "sub_xyz789",
          "createdAt": "2024-02-01T14:30:00Z",
          "fields": [
            { "key": "question_name", "label": "Your Name", "type": "INPUT_TEXT", "value": "Jane Doe" },
            { "key": "question_email", "label": "Email", "type": "INPUT_EMAIL", "value": "jane@example.com" }
          ]
        }
      ]
    }
  }
}
