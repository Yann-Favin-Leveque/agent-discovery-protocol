{
  "name": "groups_members_list",
  "description": "List all phone numbers belonging to a specific group.",
  "endpoint": "/xms/v1/{service_plan_id}/groups/{group_id}/members",
  "method": "GET",
  "resource_group": "groups",
  "parameters": [
    {
      "name": "service_plan_id",
      "type": "string",
      "required": true,
      "description": "Your Sinch service plan ID (path parameter)."
    },
    {
      "name": "group_id",
      "type": "string",
      "required": true,
      "description": "The unique group identifier (path parameter)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us.sms.api.sinch.com/xms/v1/{service_plan_id}/groups/{group_id}/members",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": ["14155550123", "14155550124", "14155550125"]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
