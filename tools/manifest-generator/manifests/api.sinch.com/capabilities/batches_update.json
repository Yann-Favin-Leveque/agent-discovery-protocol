{
  "name": "batches_update",
  "description": "Update an existing batch message that has not yet been fully delivered. You can add or remove recipients and modify the message body.",
  "endpoint": "/xms/v1/{service_plan_id}/batches/{batch_id}",
  "method": "POST",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "service_plan_id",
      "type": "string",
      "required": true,
      "description": "Your Sinch service plan ID (path parameter)."
    },
    {
      "name": "batch_id",
      "type": "string",
      "required": true,
      "description": "The unique batch identifier (path parameter)."
    },
    {
      "name": "toAdd",
      "type": "array",
      "required": false,
      "description": "Phone numbers to add to the batch."
    },
    {
      "name": "toRemove",
      "type": "array",
      "required": false,
      "description": "Phone numbers to remove from the batch."
    },
    {
      "name": "body",
      "type": "string",
      "required": false,
      "description": "New message body text."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://us.sms.api.sinch.com/xms/v1/{service_plan_id}/batches/{batch_id}",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {api_token}"
    },
    "body": {
      "toAdd": ["14155550125"],
      "body": "Updated message body"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch-id-01HXYZ",
      "to": ["14155550123", "14155550125"],
      "from": "12015550145",
      "body": "Updated message body",
      "type": "mt_text",
      "modified_at": "2024-01-15T12:05:00.000Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
