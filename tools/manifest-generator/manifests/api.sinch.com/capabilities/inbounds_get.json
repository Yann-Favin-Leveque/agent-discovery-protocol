{
  "name": "inbounds_get",
  "description": "Retrieve a specific inbound SMS message by its unique inbound message ID.",
  "endpoint": "/xms/v1/{service_plan_id}/inbounds/{inbound_id}",
  "method": "GET",
  "resource_group": "inbounds",
  "parameters": [
    {
      "name": "service_plan_id",
      "type": "string",
      "required": true,
      "description": "Your Sinch service plan ID (path parameter).",
      "in": "path"
    },
    {
      "name": "inbound_id",
      "type": "string",
      "required": true,
      "description": "The unique inbound message identifier (path parameter).",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us.sms.api.sinch.com/xms/v1/{service_plan_id}/inbounds/{inbound_id}",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "inbound-msg-01",
      "from": "14155550123",
      "to": "12015550145",
      "body": "HELP",
      "type": "mo_text",
      "received_at": "2024-01-15T12:10:00.000Z",
      "operator_id": "31002"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
