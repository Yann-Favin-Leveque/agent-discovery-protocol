{
  "name": "groups_get",
  "description": "Retrieve details of a specific phone number group by its group ID.",
  "endpoint": "/xms/v1/{service_plan_id}/groups/{group_id}",
  "method": "GET",
  "resource_group": "groups",
  "parameters": [
    {
      "name": "service_plan_id",
      "type": "string",
      "required": true,
      "description": "Your Sinch service plan ID (path parameter).",
      "in": "path"
    },
    {
      "name": "group_id",
      "type": "string",
      "required": true,
      "description": "The unique group identifier (path parameter).",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us.sms.api.sinch.com/xms/v1/{service_plan_id}/groups/{group_id}",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "group-id-01",
      "name": "VIP Customers",
      "size": 3,
      "created_at": "2024-01-15T12:00:00.000Z",
      "modified_at": "2024-01-15T12:00:00.000Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
