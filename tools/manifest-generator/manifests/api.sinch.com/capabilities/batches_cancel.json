{
  "name": "batches_cancel",
  "description": "Cancel a scheduled or queued batch that has not yet been fully delivered. Messages already delivered cannot be recalled.",
  "endpoint": "/xms/v1/{service_plan_id}/batches/{batch_id}",
  "method": "DELETE",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "service_plan_id",
      "type": "string",
      "required": true,
      "description": "Your Sinch service plan ID (path parameter)."
    },
    {
      "name": "batch_id",
      "type": "string",
      "required": true,
      "description": "The unique batch identifier (path parameter)."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://us.sms.api.sinch.com/xms/v1/{service_plan_id}/batches/{batch_id}",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch-id-01HXYZ",
      "canceled": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
