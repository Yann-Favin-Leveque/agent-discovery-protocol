{
  "name": "batches_get",
  "description": "Retrieve the details of a specific sent batch by its batch ID, including recipients, message body, and delivery status.",
  "endpoint": "/xms/v1/{service_plan_id}/batches/{batch_id}",
  "method": "GET",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "service_plan_id",
      "type": "string",
      "required": true,
      "description": "Your Sinch service plan ID (path parameter)."
    },
    {
      "name": "batch_id",
      "type": "string",
      "required": true,
      "description": "The unique batch identifier (path parameter)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us.sms.api.sinch.com/xms/v1/{service_plan_id}/batches/{batch_id}",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch-id-01HXYZ",
      "to": ["14155550123"],
      "from": "12015550145",
      "body": "Hello John, your code is 1234.",
      "type": "mt_text",
      "created_at": "2024-01-15T12:00:00.000Z",
      "modified_at": "2024-01-15T12:00:00.000Z",
      "delivery_report": "full",
      "canceled": false
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
