{
  "name": "batches_get",
  "description": "Retrieve a batch by ID.",
  "endpoint": "/v2/batches/{id}",
  "method": "GET",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Batch ID.",
      "required": true,
      "example": "batch_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/batches/batch_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch_abc123",
      "object": "Batch",
      "state": "created",
      "num_shipments": 50
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}