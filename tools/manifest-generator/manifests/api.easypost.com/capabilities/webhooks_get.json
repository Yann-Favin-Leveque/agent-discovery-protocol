{
  "name": "webhooks_get",
  "description": "Retrieve a webhook by ID.",
  "endpoint": "/v2/webhooks/{id}",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "example": "hook_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/webhooks/hook_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "hook_abc123",
      "object": "Webhook",
      "url": "https://example.com/webhook"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
