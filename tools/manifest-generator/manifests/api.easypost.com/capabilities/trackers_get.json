{
  "name": "trackers_get",
  "description": "Retrieve a tracker by ID.",
  "endpoint": "/v2/trackers/{id}",
  "method": "GET",
  "resource_group": "trackers",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Tracker ID.",
      "required": true,
      "example": "trk_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/trackers/trk_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "trk_abc123",
      "object": "Tracker",
      "tracking_code": "1Z999AA10123456784",
      "carrier": "UPS",
      "status": "delivered"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
