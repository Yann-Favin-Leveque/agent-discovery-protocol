{
  "name": "webhooks_update",
  "description": "Update a webhook's URL, secret, or headers.",
  "endpoint": "/v2/webhooks/{id}",
  "method": "PATCH",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "example": "hook_abc123"
    },
    {
      "name": "url",
      "type": "string",
      "description": "New webhook URL.",
      "required": false
    },
    {
      "name": "webhook_secret",
      "type": "string",
      "description": "New HMAC secret.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.easypost.com/v2/webhooks/hook_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "webhook": {
        "url": "https://example.com/new-webhook"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "hook_abc123",
      "url": "https://example.com/new-webhook"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}