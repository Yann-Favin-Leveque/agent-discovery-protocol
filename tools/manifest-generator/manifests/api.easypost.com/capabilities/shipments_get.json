{
  "name": "shipments_get",
  "description": "Retrieve a specific shipment by ID.",
  "endpoint": "/v2/shipments/{id}",
  "method": "GET",
  "resource_group": "shipments",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Shipment ID.",
      "required": true,
      "example": "shp_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/shipments/shp_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "shp_abc123",
      "object": "Shipment",
      "rates": [
        {
          "id": "rate_abc123",
          "carrier": "USPS",
          "service": "Priority",
          "rate": "7.58"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}