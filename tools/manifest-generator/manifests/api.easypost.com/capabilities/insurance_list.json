{
  "name": "insurance_list",
  "description": "Retrieve all insurance records with pagination.",
  "endpoint": "/v2/insurances",
  "method": "GET",
  "resource_group": "insurance",
  "parameters": [
    {
      "name": "page_size",
      "type": "integer",
      "description": "Records per page (max 100).",
      "required": false,
      "example": 20,
      "in": "query"
    },
    {
      "name": "before_id",
      "type": "string",
      "description": "Cursor for previous page.",
      "required": false,
      "in": "query"
    },
    {
      "name": "after_id",
      "type": "string",
      "description": "Cursor for next page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/insurances?page_size=20",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "insurances": [
        {
          "id": "ins_abc123",
          "amount": "100.00",
          "status": "pending"
        }
      ],
      "has_more": false
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
