{
  "name": "addresses_get",
  "description": "Retrieve an address by ID.",
  "endpoint": "/v2/addresses/{id}",
  "method": "GET",
  "resource_group": "addresses",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Address ID.",
      "required": true,
      "example": "adr_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/addresses/adr_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "adr_abc123",
      "object": "Address",
      "street1": "417 Montgomery St",
      "city": "San Francisco",
      "state": "CA",
      "zip": "94104"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
