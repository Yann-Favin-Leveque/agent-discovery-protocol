{
  "name": "batches_buy",
  "description": "Purchase postage for all shipments in a batch.",
  "endpoint": "/v2/batches/{id}/buy",
  "method": "POST",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Batch ID.",
      "required": true,
      "example": "batch_abc123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.easypost.com/v2/batches/batch_abc123/buy",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch_abc123",
      "state": "purchasing",
      "num_shipments": 50
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}