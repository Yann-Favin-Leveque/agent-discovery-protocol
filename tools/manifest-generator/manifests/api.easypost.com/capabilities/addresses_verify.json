{
  "name": "addresses_verify",
  "description": "Verify an existing address by ID.",
  "endpoint": "/v2/addresses/{id}/verify",
  "method": "GET",
  "resource_group": "addresses",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Address ID to verify.",
      "required": true,
      "example": "adr_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/addresses/adr_abc123/verify",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "address": {
        "id": "adr_abc123",
        "verifications": {
          "delivery": {
            "success": true
          }
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}