{
  "name": "parcels_get",
  "description": "Retrieve a parcel by ID.",
  "endpoint": "/v2/parcels/{id}",
  "method": "GET",
  "resource_group": "parcels",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Parcel ID.",
      "required": true,
      "example": "prcl_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/parcels/prcl_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "prcl_abc123",
      "object": "Parcel",
      "length": 10.0,
      "width": 8.0,
      "height": 4.0,
      "weight": 24.0
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}