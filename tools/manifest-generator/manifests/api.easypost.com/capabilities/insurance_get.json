{
  "name": "insurance_get",
  "description": "Retrieve insurance details by ID.",
  "endpoint": "/v2/insurances/{id}",
  "method": "GET",
  "resource_group": "insurance",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Insurance ID.",
      "required": true,
      "example": "ins_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/insurances/ins_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ins_abc123",
      "object": "Insurance",
      "tracking_code": "1Z999AA10123456784",
      "amount": "100.00",
      "status": "pending"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}