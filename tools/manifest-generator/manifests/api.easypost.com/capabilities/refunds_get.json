{
  "name": "refunds_get",
  "description": "Retrieve a refund by ID.",
  "endpoint": "/v2/refunds/{id}",
  "method": "GET",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Refund ID.",
      "required": true,
      "example": "rfnd_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/refunds/rfnd_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rfnd_abc123",
      "object": "Refund",
      "tracking_code": "1Z999AA10123456784",
      "status": "refunded"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
