{
  "name": "insurance_refund",
  "description": "Refund eligible standalone insurance.",
  "endpoint": "/v2/insurances/{id}/refund",
  "method": "POST",
  "resource_group": "insurance",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Insurance ID to refund.",
      "required": true,
      "example": "ins_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.easypost.com/v2/insurances/ins_abc123/refund",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ins_abc123",
      "status": "cancelled"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
