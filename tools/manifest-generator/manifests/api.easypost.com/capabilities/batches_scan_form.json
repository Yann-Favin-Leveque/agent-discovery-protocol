{
  "name": "batches_scan_form",
  "description": "Create a scan form for a batch.",
  "endpoint": "/v2/batches/{id}/scan_form",
  "method": "POST",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Batch ID.",
      "required": true,
      "example": "batch_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.easypost.com/v2/batches/batch_abc123/scan_form",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch_abc123",
      "scan_form": {
        "id": "sf_abc123",
        "form_url": "https://easypost-files.s3.amazonaws.com/scan_form.pdf"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
