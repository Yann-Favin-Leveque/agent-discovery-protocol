{
  "name": "addresses_create",
  "description": "Create a new address object.",
  "endpoint": "/v2/addresses",
  "method": "POST",
  "resource_group": "addresses",
  "parameters": [
    {
      "name": "street1",
      "type": "string",
      "description": "Primary street line.",
      "required": true,
      "example": "417 Montgomery St"
    },
    {
      "name": "street2",
      "type": "string",
      "description": "Secondary street line.",
      "required": false
    },
    {
      "name": "city",
      "type": "string",
      "description": "City name.",
      "required": true,
      "example": "San Francisco"
    },
    {
      "name": "state",
      "type": "string",
      "description": "State code.",
      "required": true,
      "example": "CA"
    },
    {
      "name": "zip",
      "type": "string",
      "description": "Postal code.",
      "required": true,
      "example": "94104"
    },
    {
      "name": "country",
      "type": "string",
      "description": "Country code.",
      "required": true,
      "example": "US"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Recipient name.",
      "required": false,
      "example": "John Smith"
    },
    {
      "name": "company",
      "type": "string",
      "description": "Company name.",
      "required": false
    },
    {
      "name": "phone",
      "type": "string",
      "description": "Phone number.",
      "required": false
    },
    {
      "name": "email",
      "type": "string",
      "description": "Email address.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.easypost.com/v2/addresses",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "address": {
        "street1": "417 Montgomery St",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94104",
        "country": "US",
        "name": "John Smith"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "adr_abc123",
      "object": "Address",
      "street1": "417 Montgomery St",
      "city": "San Francisco",
      "state": "CA",
      "zip": "94104",
      "country": "US"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}