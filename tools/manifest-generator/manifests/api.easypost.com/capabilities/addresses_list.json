{
  "name": "addresses_list",
  "description": "Retrieve all addresses with pagination.",
  "endpoint": "/v2/addresses",
  "method": "GET",
  "resource_group": "addresses",
  "parameters": [
    {
      "name": "page_size",
      "type": "integer",
      "description": "Records per page (max 100).",
      "required": false,
      "example": 20
    },
    {
      "name": "before_id",
      "type": "string",
      "description": "Cursor for previous page.",
      "required": false
    },
    {
      "name": "after_id",
      "type": "string",
      "description": "Cursor for next page.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.easypost.com/v2/addresses?page_size=20",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "addresses": [
        {
          "id": "adr_abc123",
          "street1": "417 Montgomery St"
        }
      ],
      "has_more": false
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}