{
  "name": "notifications_delete",
  "description": "Delete a notification configuration.",
  "resource_group": "notifications",
  "endpoint": "/b/{bucket}/notificationConfigs/{notification}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "notification",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Notification configuration ID",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
