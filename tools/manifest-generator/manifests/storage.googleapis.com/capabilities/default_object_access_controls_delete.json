{
  "name": "default_object_access_controls_delete",
  "description": "Delete a default object ACL entry.",
  "resource_group": "default_object_access_controls",
  "endpoint": "/b/{bucket}/defaultObjectAcl/{entity}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "entity",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The entity holding the permission",
      "in": "path"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
