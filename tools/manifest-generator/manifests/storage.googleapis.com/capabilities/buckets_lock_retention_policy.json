{
  "name": "buckets_lock_retention_policy",
  "description": "Irreversibly lock the retention policy on a bucket.",
  "resource_group": "buckets",
  "endpoint": "/b/{bucket}/lockRetentionPolicy",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "ifMetagenerationMatch",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Metageneration match precondition"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}