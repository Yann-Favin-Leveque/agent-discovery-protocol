{
  "name": "object_access_controls_delete",
  "description": "Delete an ACL entry for an object.",
  "resource_group": "object_access_controls",
  "endpoint": "/b/{bucket}/o/{object}/acl/{entity}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "object",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the object",
      "in": "path"
    },
    {
      "name": "entity",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The entity holding the permission",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
