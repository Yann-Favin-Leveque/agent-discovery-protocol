{
  "name": "buckets_get",
  "description": "Get metadata for a specific bucket.",
  "resource_group": "buckets",
  "endpoint": "/b/{bucket}",
  "method": "GET",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "ifMetagenerationMatch",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Return only if metageneration matches"
    },
    {
      "name": "ifMetagenerationNotMatch",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Return only if metageneration does not match"
    },
    {
      "name": "projection",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Set of properties to return"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}