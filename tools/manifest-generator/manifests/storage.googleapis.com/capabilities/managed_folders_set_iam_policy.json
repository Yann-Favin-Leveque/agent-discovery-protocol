{
  "name": "managed_folders_set_iam_policy",
  "description": "Set IAM policy for a managed folder.",
  "resource_group": "managed_folders",
  "endpoint": "/b/{bucket}/managedFolders/{managedFolder}/iam",
  "method": "PUT",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "managedFolder",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the managed folder"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}