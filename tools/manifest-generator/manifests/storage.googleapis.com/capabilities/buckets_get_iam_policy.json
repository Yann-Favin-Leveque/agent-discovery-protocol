{
  "name": "buckets_get_iam_policy",
  "description": "Get the IAM policy for a bucket.",
  "resource_group": "buckets",
  "endpoint": "/b/{bucket}/iam",
  "method": "GET",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}