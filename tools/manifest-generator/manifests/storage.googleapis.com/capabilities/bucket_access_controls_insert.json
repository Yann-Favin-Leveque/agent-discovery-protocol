{
  "name": "bucket_access_controls_insert",
  "description": "Create a new ACL entry on a bucket.",
  "resource_group": "bucket_access_controls",
  "endpoint": "/b/{bucket}/acl",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ],
  "request_example": {
    "entity": "user-example@gmail.com",
    "role": "READER"
  }
}