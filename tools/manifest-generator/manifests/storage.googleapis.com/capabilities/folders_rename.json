{
  "name": "folders_rename",
  "description": "Rename a folder.",
  "resource_group": "folders",
  "endpoint": "/b/{bucket}/folders/{sourceFolder}/renameTo/folders/{destinationFolder}",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "sourceFolder",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Source folder name",
      "in": "path"
    },
    {
      "name": "destinationFolder",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Destination folder name",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
