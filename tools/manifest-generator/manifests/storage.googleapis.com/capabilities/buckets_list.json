{
  "name": "buckets_list",
  "description": "List buckets in a project.",
  "resource_group": "buckets",
  "endpoint": "/b",
  "method": "GET",
  "parameters": [
    {
      "name": "project",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "The project ID to list buckets for",
      "in": "query"
    },
    {
      "name": "maxResults",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Maximum number of buckets to return",
      "in": "query"
    },
    {
      "name": "pageToken",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Page token for pagination",
      "in": "query"
    },
    {
      "name": "prefix",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter results to buckets with names starting with this prefix",
      "in": "query"
    },
    {
      "name": "projection",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Set of properties to return (full or noAcl)",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ],
  "response_example": {
    "kind": "storage#buckets",
    "items": [
      {
        "name": "my-bucket",
        "location": "US"
      }
    ]
  }
}
