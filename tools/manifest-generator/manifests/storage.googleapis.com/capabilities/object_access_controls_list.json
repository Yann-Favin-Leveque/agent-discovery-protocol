{
  "name": "object_access_controls_list",
  "description": "List ACL entries for an object.",
  "resource_group": "object_access_controls",
  "endpoint": "/b/{bucket}/o/{object}/acl",
  "method": "GET",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "object",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the object"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}