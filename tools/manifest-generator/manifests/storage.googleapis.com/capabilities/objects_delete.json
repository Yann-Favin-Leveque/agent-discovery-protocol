{
  "name": "objects_delete",
  "description": "Delete an object.",
  "resource_group": "objects",
  "endpoint": "/b/{bucket}/o/{object}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "object",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the object",
      "in": "path"
    },
    {
      "name": "generation",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Specific generation of the object",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
