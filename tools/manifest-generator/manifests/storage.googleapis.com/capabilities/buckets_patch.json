{
  "name": "buckets_patch",
  "description": "Patch a bucket (partial update).",
  "resource_group": "buckets",
  "endpoint": "/b/{bucket}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "ifMetagenerationMatch",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Update only if metageneration matches",
      "in": "body"
    },
    {
      "name": "predefinedAcl",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Predefined ACL to apply",
      "in": "body"
    },
    {
      "name": "projection",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Set of properties to return",
      "in": "body"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
