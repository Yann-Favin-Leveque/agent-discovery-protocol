{
  "name": "bucket_access_controls",
  "description": "Manage bucketaccesscontrols — creates a new acl entry on the specified bucket, updates an acl entry on the specified bucket, retrieves acl entries on the specified bucket. Supports standard CRUD operations through the REST API.",
  "endpoint": "/b/{bucket}/acl",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "description": "Name of a bucket.",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "userProject",
      "type": "string",
      "description": "The project to be billed for this request. Required for Requester Pays buckets.",
      "required": false,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://storage.googleapis.com/storage/v1/b/{bucket}/acl",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "bucket": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "bucket": "example_value"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
