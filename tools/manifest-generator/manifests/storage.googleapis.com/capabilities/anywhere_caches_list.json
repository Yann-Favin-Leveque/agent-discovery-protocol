{
  "name": "anywhere_caches_list",
  "description": "List Anywhere Cache instances for a bucket.",
  "resource_group": "anywhere_caches",
  "endpoint": "/b/{bucket}/anywhereCaches",
  "method": "GET",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "pageSize",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Maximum number of items to return (0-1000)"
    },
    {
      "name": "pageToken",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Page token for pagination"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}