{
  "name": "objects_restore",
  "description": "Restore a soft-deleted object.",
  "resource_group": "objects",
  "endpoint": "/b/{bucket}/o/{object}/restore",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "object",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the object"
    },
    {
      "name": "generation",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Generation of the object to restore"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}