{
  "name": "hmac_keys_list",
  "description": "List HMAC keys for a project.",
  "resource_group": "hmac_keys",
  "endpoint": "/projects/{projectId}/hmacKeys",
  "method": "GET",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID",
      "in": "path"
    },
    {
      "name": "maxResults",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Max items to return",
      "in": "query"
    },
    {
      "name": "pageToken",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Page token",
      "in": "query"
    },
    {
      "name": "serviceAccountEmail",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter by service account email",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
