{
  "name": "bucket_access_controls_list",
  "description": "List ACL entries on a bucket.",
  "resource_group": "bucket_access_controls",
  "endpoint": "/b/{bucket}/acl",
  "method": "GET",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
