{
  "name": "hmac_keys_create",
  "description": "Create a new HMAC key for a service account.",
  "resource_group": "hmac_keys",
  "endpoint": "/projects/{projectId}/hmacKeys",
  "method": "POST",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID",
      "in": "path"
    },
    {
      "name": "serviceAccountEmail",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Email of the service account",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
