{
  "name": "buckets_delete",
  "description": "Permanently delete an empty bucket.",
  "resource_group": "buckets",
  "endpoint": "/b/{bucket}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "ifMetagenerationMatch",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Delete only if metageneration matches"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}