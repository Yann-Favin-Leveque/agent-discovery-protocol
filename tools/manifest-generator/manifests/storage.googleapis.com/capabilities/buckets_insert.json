{
  "name": "buckets_insert",
  "description": "Create a new bucket.",
  "resource_group": "buckets",
  "endpoint": "/b",
  "method": "POST",
  "parameters": [
    {
      "name": "project",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "The project ID for the new bucket"
    },
    {
      "name": "predefinedAcl",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Apply a predefined set of access controls"
    },
    {
      "name": "predefinedDefaultObjectAcl",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Apply a predefined set of default object access controls"
    },
    {
      "name": "projection",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Set of properties to return"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ],
  "request_example": {
    "name": "my-new-bucket",
    "location": "US",
    "storageClass": "STANDARD"
  },
  "response_example": {
    "kind": "storage#bucket",
    "name": "my-new-bucket",
    "location": "US"
  }
}