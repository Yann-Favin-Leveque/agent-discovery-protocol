{
  "name": "buckets_relocate",
  "description": "Initiate a bucket relocation operation.",
  "resource_group": "buckets",
  "endpoint": "/b/{bucket}/relocate",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
