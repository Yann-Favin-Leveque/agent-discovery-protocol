{
  "name": "anywhere_caches_insert",
  "description": "Create an Anywhere Cache instance in a bucket.",
  "resource_group": "anywhere_caches",
  "endpoint": "/b/{bucket}/anywhereCaches",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ],
  "request_example": {
    "zone": "us-central1-a",
    "ttl": "86400s",
    "admissionPolicy": "admit-on-first-miss"
  },
  "response_example": {
    "kind": "storage#anywhereCache",
    "id": "abc123",
    "bucket": "my-bucket",
    "state": "CREATING"
  }
}
