{
  "name": "anywhere_caches",
  "description": "Manage anywherecaches — creates an anywhere cache instance, pauses an anywhere cache instance, resumes a paused or disabled anywhere cache instance. Supports standard CRUD operations through the REST API.",
  "endpoint": "/b/{bucket}/anywhereCaches",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "description": "Name of the parent bucket.",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://storage.googleapis.com/storage/v1/b/{bucket}/anywhereCaches",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "bucket": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "bucket": "example_value"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
