{
  "name": "default_object_access_controls",
  "description": "Manage defaultobjectaccesscontrols — creates a new default object acl entry on the specified bucket, updates a default object acl entry on the specified bucket, retrieves default object acl entries on the specified bucket. Supports standard CRUD operations through the REST API.",
  "endpoint": "/b/{bucket}/defaultObjectAcl",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "description": "Name of a bucket.",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "userProject",
      "type": "string",
      "description": "The project to be billed for this request. Required for Requester Pays buckets.",
      "required": false,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://storage.googleapis.com/storage/v1/b/{bucket}/defaultObjectAcl",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "bucket": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "bucket": "example_value"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
