{
  "name": "objects_insert",
  "description": "Upload a new object to a bucket.",
  "resource_group": "objects",
  "endpoint": "/upload/storage/v1/b/{bucket}/o",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "uploadType",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Upload type: media, multipart, or resumable",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Name of the object",
      "in": "body"
    },
    {
      "name": "predefinedAcl",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Predefined ACL to apply",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
