{
  "name": "objects_compose",
  "description": "Compose multiple objects into a single object.",
  "resource_group": "objects",
  "endpoint": "/b/{destinationBucket}/o/{destinationObject}/compose",
  "method": "POST",
  "parameters": [
    {
      "name": "destinationBucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Destination bucket",
      "in": "path"
    },
    {
      "name": "destinationObject",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Destination object name",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ],
  "request_example": {
    "sourceObjects": [
      {
        "name": "part1.txt"
      },
      {
        "name": "part2.txt"
      }
    ],
    "destination": {
      "contentType": "text/plain"
    }
  }
}
