{
  "name": "default_object_access_controls_insert",
  "description": "Create a new default object ACL entry.",
  "resource_group": "default_object_access_controls",
  "endpoint": "/b/{bucket}/defaultObjectAcl",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "userProject",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project to bill for Requester Pays buckets",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
