{
  "name": "managed_folders_delete",
  "description": "Delete a managed folder.",
  "resource_group": "managed_folders",
  "endpoint": "/b/{bucket}/managedFolders/{managedFolder}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "managedFolder",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the managed folder",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
