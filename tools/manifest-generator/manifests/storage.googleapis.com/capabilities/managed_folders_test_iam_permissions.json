{
  "name": "managed_folders_test_iam_permissions",
  "description": "Test IAM permissions on a managed folder.",
  "resource_group": "managed_folders",
  "endpoint": "/b/{bucket}/managedFolders/{managedFolder}/iam/testPermissions",
  "method": "GET",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "managedFolder",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the managed folder",
      "in": "path"
    },
    {
      "name": "permissions",
      "type": "array",
      "required": true,
      "location": "query",
      "description": "Permissions to test",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}
