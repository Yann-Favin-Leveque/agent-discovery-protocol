{
  "name": "objects_move",
  "description": "Move an object within the same bucket.",
  "resource_group": "objects",
  "endpoint": "/b/{bucket}/o/{sourceObject}/moveTo/b/{bucket}/o/{destinationObject}",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket",
      "in": "path"
    },
    {
      "name": "sourceObject",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Source object name",
      "in": "path"
    },
    {
      "name": "destinationObject",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Destination object name",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
