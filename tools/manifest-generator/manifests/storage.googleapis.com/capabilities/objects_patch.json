{
  "name": "objects_patch",
  "description": "Patch an object's metadata (partial update).",
  "resource_group": "objects",
  "endpoint": "/b/{bucket}/o/{object}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "object",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the object"
    },
    {
      "name": "generation",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Specific generation"
    },
    {
      "name": "predefinedAcl",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Predefined ACL"
    },
    {
      "name": "projection",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Properties to return"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control"
  ]
}