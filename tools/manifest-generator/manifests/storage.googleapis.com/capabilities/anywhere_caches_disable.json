{
  "name": "anywhere_caches_disable",
  "description": "Disable an Anywhere Cache instance.",
  "resource_group": "anywhere_caches",
  "endpoint": "/b/{bucket}/anywhereCaches/{anywhereCacheId}/disable",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "anywhereCacheId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Anywhere Cache instance"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}