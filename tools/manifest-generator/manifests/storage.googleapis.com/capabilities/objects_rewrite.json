{
  "name": "objects_rewrite",
  "description": "Rewrite an object to a new location with optional transformations.",
  "resource_group": "objects",
  "endpoint": "/b/{sourceBucket}/o/{sourceObject}/rewriteTo/b/{destinationBucket}/o/{destinationObject}",
  "method": "POST",
  "parameters": [
    {
      "name": "sourceBucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Source bucket",
      "in": "path"
    },
    {
      "name": "sourceObject",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Source object",
      "in": "path"
    },
    {
      "name": "destinationBucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Destination bucket",
      "in": "path"
    },
    {
      "name": "destinationObject",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Destination object",
      "in": "path"
    },
    {
      "name": "rewriteToken",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Token for resuming rewrite",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}
