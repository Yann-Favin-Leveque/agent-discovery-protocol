{
  "name": "objects_get",
  "description": "Get an object's metadata or download its content.",
  "resource_group": "objects",
  "endpoint": "/b/{bucket}/o/{object}",
  "method": "GET",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "object",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the object"
    },
    {
      "name": "alt",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Set to 'media' to download content"
    },
    {
      "name": "generation",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Specific generation of the object"
    },
    {
      "name": "projection",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Set of properties to return"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/cloud-platform.read-only",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_only",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}