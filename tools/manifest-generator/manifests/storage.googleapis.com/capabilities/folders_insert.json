{
  "name": "folders_insert",
  "description": "Create a new folder in a hierarchical namespace bucket.",
  "resource_group": "folders",
  "endpoint": "/b/{bucket}/folders",
  "method": "POST",
  "parameters": [
    {
      "name": "bucket",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the bucket"
    },
    {
      "name": "recursive",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Create parent folders if they don't exist"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/cloud-platform",
    "https://www.googleapis.com/auth/devstorage.full_control",
    "https://www.googleapis.com/auth/devstorage.read_write"
  ]
}