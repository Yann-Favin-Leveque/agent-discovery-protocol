{
  "name": "tasks_search",
  "description": "Search tasks in a workspace.",
  "resource_group": "tasks",
  "endpoint": "/1.0/workspaces/{workspace_gid}/tasks/search",
  "method": "GET",
  "parameters": [
    {
      "name": "workspace_gid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Workspace GID"
    },
    {
      "name": "text",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Search text"
    },
    {
      "name": "completed",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Filter by completion status"
    },
    {
      "name": "assignee.any",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter by assignee GIDs"
    },
    {
      "name": "projects.any",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter by project GIDs"
    },
    {
      "name": "due_on.before",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Due before date"
    },
    {
      "name": "due_on.after",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Due after date"
    },
    {
      "name": "sort_by",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Sort field"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}