{
  "name": "sections_get",
  "description": "Get a section by GID.",
  "resource_group": "sections",
  "endpoint": "/1.0/sections/{section_gid}",
  "method": "GET",
  "parameters": [
    {
      "name": "section_gid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Section GID",
      "in": "path"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
