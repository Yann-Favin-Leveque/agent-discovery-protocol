{
  "name": "tasks_list",
  "description": "Get multiple tasks.",
  "resource_group": "tasks",
  "endpoint": "/1.0/tasks",
  "method": "GET",
  "parameters": [
    {
      "name": "project",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project GID to filter by",
      "in": "query"
    },
    {
      "name": "section",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Section GID to filter by",
      "in": "query"
    },
    {
      "name": "workspace",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Workspace GID",
      "in": "query"
    },
    {
      "name": "assignee",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Assignee (user GID or 'me')",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Results per page (max 100)",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination offset token",
      "in": "query"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
