{
  "name": "custom_fields_get",
  "description": "Get a custom field.",
  "resource_group": "custom_fields",
  "endpoint": "/1.0/custom_fields/{custom_field_gid}",
  "method": "GET",
  "parameters": [
    {
      "name": "custom_field_gid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Custom field GID"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}