{
  "name": "tasks_create",
  "description": "Create a new task.",
  "resource_group": "tasks",
  "endpoint": "/1.0/tasks",
  "method": "POST",
  "parameters": [
    {
      "name": "data",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "Task data object"
    }
  ],
  "auth_scopes": [
    "default"
  ],
  "request_example": {
    "data": {
      "name": "New task",
      "workspace": "workspace-gid",
      "projects": [
        "project-gid"
      ],
      "assignee": "me"
    }
  },
  "response_example": {
    "data": {
      "gid": "task-gid",
      "name": "New task",
      "resource_type": "task"
    }
  }
