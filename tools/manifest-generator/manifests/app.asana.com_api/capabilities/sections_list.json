{
  "name": "sections_list",
  "description": "List sections in a project.",
  "resource_group": "sections",
  "endpoint": "/1.0/projects/{project_gid}/sections",
  "method": "GET",
  "parameters": [
    {
      "name": "project_gid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project GID",
      "in": "path"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
