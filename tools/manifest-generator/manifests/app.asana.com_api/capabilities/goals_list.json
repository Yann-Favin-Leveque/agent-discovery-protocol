{
  "name": "goals_list",
  "description": "Get goals.",
  "resource_group": "goals",
  "endpoint": "/1.0/goals",
  "method": "GET",
  "parameters": [
    {
      "name": "workspace",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Workspace GID",
      "in": "query"
    },
    {
      "name": "team",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Team GID",
      "in": "query"
    },
    {
      "name": "project",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project GID",
      "in": "query"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
