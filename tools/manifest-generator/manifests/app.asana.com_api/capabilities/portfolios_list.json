{
  "name": "portfolios_list",
  "description": "Get multiple portfolios.",
  "resource_group": "portfolios",
  "endpoint": "/1.0/portfolios",
  "method": "GET",
  "parameters": [
    {
      "name": "workspace",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Workspace GID",
      "in": "query"
    },
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Owner GID",
      "in": "query"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
