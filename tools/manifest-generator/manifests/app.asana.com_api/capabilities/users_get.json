{
  "name": "users_get",
  "description": "Get a user by GID.",
  "resource_group": "users",
  "endpoint": "/1.0/users/{user_gid}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_gid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "User GID or 'me'",
      "in": "path"
    },
    {
      "name": "opt_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated list of fields to include",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
