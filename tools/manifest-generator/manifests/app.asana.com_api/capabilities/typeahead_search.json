{
  "name": "typeahead_search",
  "description": "Get typeahead search results.",
  "resource_group": "typeahead",
  "endpoint": "/1.0/workspaces/{workspace_gid}/typeahead",
  "method": "GET",
  "parameters": [
    {
      "name": "workspace_gid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Workspace GID",
      "in": "path"
    },
    {
      "name": "resource_type",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Type to search (task, project, user, tag, portfolio)",
      "in": "query"
    },
    {
      "name": "query",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Search query",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
