{
  "name": "list_pipelines",
  "description": "List all pipelines defined in an Azure DevOps project. Returns pipeline names, IDs, folder paths, and revision numbers. Use this to discover available pipelines before triggering a run.",
  "endpoint": "/{organization}/{project}/_apis/pipelines",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "description": "The name of the Azure DevOps organization."
    },
    {
      "name": "project",
      "type": "string",
      "required": true,
      "description": "The name or ID of the project."
    },
    {
      "name": "api-version",
      "type": "string",
      "required": true,
      "description": "Version of the API to use. Use '7.1'."
    },
    {
      "name": "$top",
      "type": "integer",
      "required": false,
      "description": "Maximum number of pipelines to return."
    },
    {
      "name": "orderBy",
      "type": "string",
      "required": false,
      "description": "Field to order results by. Example: 'name asc' or 'name desc'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://dev.azure.com/my-org/MyWebApp/_apis/pipelines?api-version=7.1&$top=20"
  },
  "response_example": {
    "count": 3,
    "value": [
      {
        "id": 12,
        "name": "MyWebApp-CI",
        "folder": "\\",
        "revision": 5,
        "url": "https://dev.azure.com/my-org/MyWebApp/_apis/pipelines/12",
        "_links": {
          "self": { "href": "https://dev.azure.com/my-org/MyWebApp/_apis/pipelines/12" },
          "web": { "href": "https://dev.azure.com/my-org/MyWebApp/_build/definition?definitionId=12" }
        }
      },
      {
        "id": 15,
        "name": "MyWebApp-CD-Staging",
        "folder": "\\deploy",
        "revision": 3,
        "url": "https://dev.azure.com/my-org/MyWebApp/_apis/pipelines/15",
        "_links": {
          "self": { "href": "https://dev.azure.com/my-org/MyWebApp/_apis/pipelines/15" },
          "web": { "href": "https://dev.azure.com/my-org/MyWebApp/_build/definition?definitionId=15" }
        }
      },
      {
        "id": 18,
        "name": "MyWebApp-CD-Production",
        "folder": "\\deploy",
        "revision": 2,
        "url": "https://dev.azure.com/my-org/MyWebApp/_apis/pipelines/18",
        "_links": {
          "self": { "href": "https://dev.azure.com/my-org/MyWebApp/_apis/pipelines/18" },
          "web": { "href": "https://dev.azure.com/my-org/MyWebApp/_build/definition?definitionId=18" }
        }
      }
    ]
  }
}
