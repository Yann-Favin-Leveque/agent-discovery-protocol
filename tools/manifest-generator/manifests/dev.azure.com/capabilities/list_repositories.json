{
  "name": "list_repositories",
  "description": "List all Git repositories within an Azure DevOps project. Returns repository names, IDs, default branches, clone URLs, and size information. Useful for discovering available repos before creating pull requests or browsing code.",
  "endpoint": "/{organization}/{project}/_apis/git/repositories",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "description": "The name of the Azure DevOps organization."
    },
    {
      "name": "project",
      "type": "string",
      "required": true,
      "description": "The name or ID of the project."
    },
    {
      "name": "api-version",
      "type": "string",
      "required": true,
      "description": "Version of the API to use. Use '7.1'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://dev.azure.com/my-org/MyWebApp/_apis/git/repositories?api-version=7.1"
  },
  "response_example": {
    "count": 2,
    "value": [
      {
