{
  "name": "work_items_delete",
  "description": "Delete a work item.",
  "resource_group": "work_items",
  "endpoint": "/{organization}/{project}/_apis/wit/workitems/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Organization.",
      "in": "path"
    },
    {
      "name": "project",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project.",
      "in": "path"
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "Work item ID.",
      "in": "path"
    },
    {
      "name": "destroy",
      "type": "boolean",
      "required": false,
      "description": "Permanently delete (true) or recycle (false).",
      "in": "query"
    },
    {
      "name": "api-version",
      "type": "string",
      "required": true,
      "description": "API version.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://dev.azure.com/myorg/MyProject/_apis/wit/workitems/42?api-version=7.1",
    "headers": {
      "Authorization": "Basic base64(user:pat)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 42,
      "code": 200
    }
  }
}
