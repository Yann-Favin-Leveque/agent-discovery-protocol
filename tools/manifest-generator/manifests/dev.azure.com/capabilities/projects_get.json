{
  "name": "projects_get",
  "description": "Get a specific project by name or ID.",
  "resource_group": "projects",
  "endpoint": "/{organization}/_apis/projects/{projectId}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Organization."
    },
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID or name."
    },
    {
      "name": "api-version",
      "type": "string",
      "required": true,
      "description": "API version."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://dev.azure.com/myorg/_apis/projects/MyProject?api-version=7.1",
    "headers": {
      "Authorization": "Basic base64(user:pat)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "guid",
      "name": "MyProject",
      "description": "Main project",
      "state": "wellFormed"
    }
  }
}