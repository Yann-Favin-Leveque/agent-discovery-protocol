{
  "name": "work_items_get",
  "description": "Get a work item by ID.",
  "resource_group": "work_items",
  "endpoint": "/{organization}/{project}/_apis/wit/workitems/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Organization.",
      "in": "path"
    },
    {
      "name": "project",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project.",
      "in": "path"
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "Work item ID.",
      "in": "path"
    },
    {
      "name": "$expand",
      "type": "string",
      "required": false,
      "description": "Expand: none, relations, fields, links, all.",
      "in": "query"
    },
    {
      "name": "api-version",
      "type": "string",
      "required": true,
      "description": "API version.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://dev.azure.com/myorg/MyProject/_apis/wit/workitems/42?$expand=all&api-version=7.1",
    "headers": {
      "Authorization": "Basic base64(user:pat)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 42,
      "rev": 3,
      "fields": {
        "System.Title": "Fix login bug",
        "System.State": "Active",
        "System.WorkItemType": "Bug"
      }
    }
  }
}
