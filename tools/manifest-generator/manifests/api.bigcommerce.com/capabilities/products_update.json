{
  "name": "products_update",
  "description": "Update an existing product by ID.",
  "resource_group": "products",
  "endpoint": "/catalog/products/{productId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "productId",
      "type": "integer",
      "required": true,
      "description": "Product ID to update.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name.",
      "in": "body"
    },
    {
      "name": "price",
      "type": "number",
      "required": false,
      "description": "Updated price.",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Updated description.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/catalog/products/77",
    "headers": {
      "X-Auth-Token": "{api_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Name",
      "price": 39.99
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": 77,
        "name": "Updated Name",
        "price": 39.99
      }
    }
  }
}
