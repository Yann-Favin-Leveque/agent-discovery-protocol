{
  "name": "carts_get",
  "description": "Retrieve a cart by ID.",
  "resource_group": "carts",
  "endpoint": "/carts/{cartId}",
  "method": "GET",
  "parameters": [
    {
      "name": "cartId",
      "type": "string",
      "required": true,
      "description": "Cart UUID.",
      "example": "cart-uuid-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/carts/cart-uuid-123",
    "headers": {
      "X-Auth-Token": "{api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "cart-uuid-123",
        "cart_amount": 49.0
      }
    }
  }
}