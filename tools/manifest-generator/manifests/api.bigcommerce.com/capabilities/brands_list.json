{
  "name": "brands_list",
  "description": "Retrieve all brands in the catalog.",
  "resource_group": "brands",
  "endpoint": "/catalog/brands",
  "method": "GET",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter by brand name."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/catalog/brands",
    "headers": {
      "X-Auth-Token": "{api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "name": "Apple"
        }
      ]
    }
  }
}