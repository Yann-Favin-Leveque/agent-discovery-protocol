{
  "name": "orders_get",
  "description": "Retrieve full details of a specific order.",
  "resource_group": "orders",
  "endpoint": "/v2/orders/{orderId}",
  "method": "GET",
  "parameters": [
    {
      "name": "orderId",
      "type": "integer",
      "required": true,
      "description": "The order ID.",
      "example": 100
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v2/orders/100",
    "headers": {
      "X-Auth-Token": "{api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 100,
      "status": "Completed",
      "total_inc_tax": "89.99",
      "billing_address": {
        "first_name": "John",
        "last_name": "Doe",
        "city": "Austin"
      }
    }
  }
}