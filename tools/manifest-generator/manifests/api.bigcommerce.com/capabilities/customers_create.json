{
  "name": "customers_create",
  "description": "Create one or more new customers.",
  "resource_group": "customers",
  "endpoint": "/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Customer email.",
      "example": "john@example.com"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": true,
      "description": "First name.",
      "example": "John"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": true,
      "description": "Last name.",
      "example": "Doe"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/customers",
    "headers": {
      "X-Auth-Token": "{api_token}",
      "Content-Type": "application/json"
    },
    "body": [
      {
        "email": "john@example.com",
        "first_name": "John",
        "last_name": "Doe"
      }
    ]
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 2,
          "email": "john@example.com",
          "first_name": "John",
          "last_name": "Doe"
        }
      ]
    }
  }
}