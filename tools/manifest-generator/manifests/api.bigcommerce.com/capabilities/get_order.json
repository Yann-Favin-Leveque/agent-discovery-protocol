{
  "name": "get_order",
  "description": "Retrieve the full details of a specific order by its ID. Returns complete order information including line items, shipping addresses, billing address, payment method, order status, coupons, and tax details.",
  "endpoint": "/v2/orders/{order_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "order_id",
      "type": "integer",
      "description": "The unique numeric ID of the order to retrieve.",
      "required": true,
      "example": 100
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v2/orders/100",
    "headers": {
      "X-Auth-Token": "{api_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 100,
      "date_created": "Wed, 10 Jan 2024 11:50:00 +0000",
      "date_modified": "Wed, 10 Jan 2024 12:00:00 +0000",
      "status_id": 11,
      "status": "Awaiting Fulfillment",
      "subtotal_ex_tax": "398.00",
      "subtotal_inc_tax": "409.94",
      "total_ex_tax": "398.00",
      "total_inc_tax": "409.94",
      "total_tax": "11.94",
      "items_total": 2,
      "currency_code": "USD",
      "payment_method": "Credit Card",
      "customer_id": 1,
      "billing_address": {
        "first_name": "Bob",
        "last_name": "Norman",
        "street_1": "123 Main St",
        "city": "Austin",
        "state": "Texas",
        "zip": "78701",
        "country": "United States",
        "email": "bob@example.com"
      },
      "shipping_addresses": {
        "url": "https://api.bigcommerce.com/stores/{store_hash}/v2/orders/100/shipping_addresses",
        "resource": "/orders/100/shipping_addresses"
      },
      "products": {
        "url": "https://api.bigcommerce.com/stores/{store_hash}/v2/orders/100/products",
        "resource": "/orders/100/products"
      }
    }
  }
}
