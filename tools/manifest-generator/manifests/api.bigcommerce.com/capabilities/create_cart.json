{
  "name": "create_cart",
  "description": "Create a new shopping cart with line items, optional customer ID, and channel ID. Returns the cart object with calculated totals, tax, and a redirect URL to the storefront checkout page.",
  "endpoint": "/carts",
  "method": "POST",
  "parameters": [
    {
      "name": "line_items",
      "type": "array",
      "description": "Array of line item objects with product_id, quantity, and optionally variant_id.",
      "required": true,
      "example": [
        {
          "product_id": 77,
          "quantity": 2
        }
      ]
    },
    {
      "name": "customer_id",
      "type": "integer",
      "description": "The ID of the customer to associate with the cart.",
      "required": false,
      "example": 1
    },
    {
      "name": "channel_id",
      "type": "integer",
      "description": "The channel ID for multi-storefront setups.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/carts",
    "headers": {
      "X-Auth-Token": "{api_token}",
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "body": {
      "line_items": [
        {
          "product_id": 77,
          "quantity": 2
        }
      ],
      "customer_id": 1,
      "channel_id": 1
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "d5f3e8c0-1a2b-3c4d-5e6f-7a8b9c0d1e2f",
        "customer_id": 1,
        "channel_id": 1,
        "currency": {
          "code": "USD"
        },
        "base_amount": 50.00,
        "discount_amount": 0,
        "cart_amount": 50.00,
        "line_items": {
          "physical_items": [
            {
              "id": "a1b2c3d4",
              "product_id": 77,
              "name": "Smith Journal 13",
              "quantity": 2,
              "list_price": 25.00,
              "sale_price": 25.00,
              "extended_list_price": 50.00,
              "extended_sale_price": 50.00
            }
          ],
          "digital_items": []
        },
        "redirect_urls": {
          "checkout_url": "https://store.example.com/checkout/d5f3e8c0-1a2b-3c4d-5e6f-7a8b9c0d1e2f"
        },
        "created_time": "2024-01-10T15:00:00Z",
        "updated_time": "2024-01-10T15:00:00Z"
      },
      "meta": {}
    }
  }
}
