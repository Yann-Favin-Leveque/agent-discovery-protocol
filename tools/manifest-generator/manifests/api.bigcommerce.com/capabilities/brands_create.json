{
  "name": "brands_create",
  "description": "Create a new brand.",
  "resource_group": "brands",
  "endpoint": "/catalog/brands",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Brand name.",
      "example": "New Brand"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/catalog/brands",
    "headers": {
      "X-Auth-Token": "{api_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "New Brand"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": 2,
        "name": "New Brand"
      }
    }
  }
}