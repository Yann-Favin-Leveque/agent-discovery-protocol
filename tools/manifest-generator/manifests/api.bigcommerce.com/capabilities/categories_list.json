{
  "name": "categories_list",
  "description": "Retrieve all categories in the store.",
  "resource_group": "categories",
  "endpoint": "/catalog/categories",
  "method": "GET",
  "parameters": [
    {
      "name": "parent_id",
      "type": "integer",
      "required": false,
      "description": "Filter by parent category ID.",
      "in": "query"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter by name.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/catalog/categories",
    "headers": {
      "X-Auth-Token": "{api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 18,
          "parent_id": 0,
          "name": "Bath",
          "is_visible": true
        }
      ]
    }
  }
}
