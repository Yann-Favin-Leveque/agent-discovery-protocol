{
  "name": "list_customers",
  "description": "Retrieve a paginated list of customers from the BigCommerce store. Supports filtering by name, email, company, customer group, and date ranges. Returns customer profiles with addresses and order history stats.",
  "endpoint": "/customers",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of customers to return per page (max 250, default 50).",
      "required": false,
      "example": 50
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for pagination (default 1).",
      "required": false,
      "example": 1
    },
    {
      "name": "email:in",
      "type": "string",
      "description": "Filter customers by email address (comma-separated for multiple).",
      "required": false,
      "example": "bob@example.com"
    },
    {
      "name": "name:like",
      "type": "string",
      "description": "Filter customers by partial name match.",
      "required": false,
      "example": "Bob"
    },
    {
      "name": "company:in",
      "type": "string",
      "description": "Filter customers by company name.",
      "required": false,
      "example": "Acme Corp"
    },
    {
      "name": "customer_group_id:in",
      "type": "integer",
      "description": "Filter by customer group ID.",
      "required": false,
      "example": 1
    },
    {
      "name": "date_created:min",
      "type": "string",
      "description": "Minimum creation date filter (ISO 8601 format).",
      "required": false,
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "sort",
      "type": "string",
      "description": "Field to sort by: 'date_created', 'last_name', 'email'. Prefix with '-' for descending.",
      "required": false,
      "example": "last_name"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/customers?limit=50&sort=last_name",
    "headers": {
      "X-Auth-Token": "{api_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "email": "bob@example.com",
          "first_name": "Bob",
          "last_name": "Norman",
          "company": "",
          "phone": "555-0123",
          "date_created": "2024-01-02T08:59:11Z",
          "date_modified": "2024-01-10T15:30:00Z",
          "customer_group_id": 0,
          "addresses": {
            "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/customers/1/addresses",
            "resource": "/customers/1/addresses"
          }
        }
      ],
      "meta": {
        "pagination": {
          "total": 45,
          "count": 45,
          "per_page": 50,
          "current_page": 1,
          "total_pages": 1
        }
      }
    }
  }
}
