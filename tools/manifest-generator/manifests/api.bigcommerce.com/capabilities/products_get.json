{
  "name": "products_get",
  "description": "Retrieve a single product by ID.",
  "resource_group": "products",
  "endpoint": "/catalog/products/{productId}",
  "method": "GET",
  "parameters": [
    {
      "name": "productId",
      "type": "integer",
      "required": true,
      "description": "The product ID.",
      "example": 77,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bigcommerce.com/stores/{store_hash}/v3/catalog/products/77",
    "headers": {
      "X-Auth-Token": "{api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": 77,
        "name": "Fog Linen Chambray Towel",
        "price": 49,
        "sku": "FLC-001"
      }
    }
  }
}
