{
  "name": "payrolls_submit",
  "description": "Submit a calculated payroll for processing. This finalizes the payroll and initiates payments.",
  "endpoint": "/v1/companies/{company_id}/payrolls/{payroll_id}/submit",
  "method": "PUT",
  "resource_group": "payrolls",
  "parameters": [
    {"name": "company_id", "type": "string", "description": "The company UUID.", "required": true, "example": "7757616923531542"},
    {"name": "payroll_id", "type": "string", "description": "The payroll UUID.", "required": true, "example": "pay_789"}
  ],
  "request_example": {"method": "PUT", "url": "https://api.gusto.com/v1/companies/7757616923531542/payrolls/pay_789/submit", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": {"payroll_uuid": "pay_789", "processed": true}},
  "auth_scopes": ["payrolls:write"],
  "rate_limits": {"requests_per_minute": 60}
}
