{
  "name": "departments_list",
  "description": "List all departments in a company.",
  "endpoint": "/v1/companies/{company_id}/departments",
  "method": "GET",
  "resource_group": "departments",
  "parameters": [
    {
      "name": "company_id",
      "type": "string",
      "description": "The company UUID.",
      "required": true,
      "example": "7757616923531542",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gusto.com/v1/companies/7757616923531542/departments",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "uuid": "dept_123",
        "title": "Engineering",
        "employees": [
          {
            "uuid": "emp_123"
          }
        ]
      }
    ]
  },
  "auth_scopes": [
    "companies:read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
