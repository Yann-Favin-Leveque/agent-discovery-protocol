{
  "name": "companies_get",
  "description": "Retrieve detailed information about a company including locations, pay schedules, and compliance status.",
  "endpoint": "/v1/companies/{company_id}",
  "method": "GET",
  "resource_group": "companies",
  "parameters": [
    {
      "name": "company_id",
      "type": "string",
      "description": "The company UUID.",
      "required": true,
      "example": "7757616923531542",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gusto.com/v1/companies/7757616923531542",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "uuid": "7757616923531542",
      "name": "Acme Corp",
      "ein": "12-3456789",
      "entity_type": "LLC",
      "locations": [
        {
          "id": 1,
          "street_1": "123 Main St",
          "city": "San Francisco",
          "state": "CA"
        }
      ]
    }
  },
  "auth_scopes": [
    "companies:read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
