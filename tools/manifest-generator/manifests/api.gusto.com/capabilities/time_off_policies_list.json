{
  "name": "time_off_policies_list",
  "description": "List all time off policies for a company (PTO, sick leave, etc.).",
  "endpoint": "/v1/companies/{company_id}/time_off_policies",
  "method": "GET",
  "resource_group": "time_off",
  "parameters": [
    {"name": "company_id", "type": "string", "description": "The company UUID.", "required": true, "example": "7757616923531542"}
  ],
  "request_example": {"method": "GET", "url": "https://api.gusto.com/v1/companies/7757616923531542/time_off_policies", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": [{"uuid": "top_123", "name": "Paid Time Off", "policy_type": "vacation", "accrual_method": "per_pay_period", "accrual_rate": "3.08", "accrual_rate_unit": "hours"}]},
  "auth_scopes": ["time_off_policies:read"],
  "rate_limits": {"requests_per_minute": 60}
}
