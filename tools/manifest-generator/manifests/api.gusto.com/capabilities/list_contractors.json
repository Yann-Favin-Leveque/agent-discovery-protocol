{
  "name": "list_contractors",
  "description": "Retrieve all 1099 contractors associated with a company. Returns their personal information, payment method, onboarding status, and wage type (hourly or fixed).",
  "endpoint": "/v1/companies/{company_id}/contractors",
  "method": "GET",
  "parameters": [
    { "name": "company_id", "type": "string", "description": "The UUID of the company whose contractors to list.", "required": true, "example": "c44e6b5f-3b87-4f72-bb2a-e7ce1e8a9a1e" },
    { "name": "page", "type": "integer", "description": "Page number for paginated results.", "required": false, "example": 1 },
    { "name": "per", "type": "integer", "description": "Number of contractors per page.", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gusto.com/v1/companies/c44e6b5f-3b87-4f72-bb2a-e7ce1e8a9a1e/contractors?page=1&per=25",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "uuid": "f9d8e7c6-b5a4-3210-9876-fedcba098765",
        "first_name": "Alex",
        "last_name": "Johnson",
        "email": "alex@freelancer.com",
        "type": "Individual",
        "wage_type": "Hourly",
        "is_active": true,
        "onboarded": true
      }
    ]
  }
}
