{
  "name": "create_employee",
  "description": "Add a new W-2 employee to a company. Creates their profile with basic personal information so you can then assign jobs, configure benefits, and include them in payroll runs.",
  "endpoint": "/v1/companies/{company_id}/employees",
  "method": "POST",
  "parameters": [
    { "name": "company_id", "type": "string", "description": "The UUID of the company to add the employee to.", "required": true, "example": "c44e6b5f-3b87-4f72-bb2a-e7ce1e8a9a1e" },
    { "name": "first_name", "type": "string", "description": "Employee's first name.", "required": true, "example": "Jane" },
    { "name": "last_name", "type": "string", "description": "Employee's last name.", "required": true, "example": "Smith" },
    { "name": "email", "type": "string", "description": "Employee's email address for onboarding invitation.", "required": false, "example": "jane.smith@example.com" },
    { "name": "date_of_birth", "type": "string", "description": "Employee's date of birth in YYYY-MM-DD format.", "required": false, "example": "1990-05-15" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gusto.com/v1/companies/c44e6b5f-3b87-4f72-bb2a-e7ce1e8a9a1e/employees",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "first_name": "Jane",
      "last_name": "Smith",
      "email": "jane.smith@example.com",
      "date_of_birth": "1990-05-15"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "uuid": "e8c5a7d1-4b3f-4c2e-9a1b-d6f7e8c9a0b1",
      "first_name": "Jane",
      "last_name": "Smith",
      "email": "jane.smith@example.com",
      "date_of_birth": "1990-05-15",
      "onboarded": false
    }
  }
}
