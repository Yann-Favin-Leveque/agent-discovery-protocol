{
  "name": "employee_benefits_list",
  "description": "List all benefit enrollments for a specific employee.",
  "endpoint": "/v1/employees/{employee_id}/employee_benefits",
  "method": "GET",
  "resource_group": "benefits",
  "parameters": [
    {
      "name": "employee_id",
      "type": "string",
      "description": "The employee UUID.",
      "required": true,
      "example": "emp_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gusto.com/v1/employees/emp_123/employee_benefits",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "company_benefit_id": 1,
        "employee_deduction": "150.00",
        "company_contribution": "350.00",
        "active": true
      }
    ]
  },
  "auth_scopes": [
    "benefits:read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
