{
  "name": "company_benefits_list",
  "description": "List all benefits configured for a company (health, dental, 401k, etc.).",
  "endpoint": "/v1/companies/{company_id}/company_benefits",
  "method": "GET",
  "resource_group": "benefits",
  "parameters": [
    {"name": "company_id", "type": "string", "description": "The company UUID.", "required": true, "example": "7757616923531542"}
  ],
  "request_example": {"method": "GET", "url": "https://api.gusto.com/v1/companies/7757616923531542/company_benefits", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": [{"id": 1, "benefit_type": 1, "description": "Health Insurance", "active": true, "responsible_for_employer_taxes": false}]},
  "auth_scopes": ["benefits:read"],
  "rate_limits": {"requests_per_minute": 60}
}
