{
  "name": "companies_update",
  "description": "Update a company's details such as name or entity type.",
  "endpoint": "/v1/companies/{company_id}",
  "method": "PUT",
  "resource_group": "companies",
  "parameters": [
    {"name": "company_id", "type": "string", "description": "The company UUID.", "required": true, "example": "7757616923531542"},
    {"name": "name", "type": "string", "description": "Updated company name.", "required": false, "example": "Acme Corporation"}
  ],
  "request_example": {"method": "PUT", "url": "https://api.gusto.com/v1/companies/7757616923531542", "headers": {"Authorization": "Bearer {token}", "Content-Type": "application/json"}, "body": {"name": "Acme Corporation"}},
  "response_example": {"status": 200, "body": {"uuid": "7757616923531542", "name": "Acme Corporation"}},
  "auth_scopes": ["companies:write"],
  "rate_limits": {"requests_per_minute": 60}
}
