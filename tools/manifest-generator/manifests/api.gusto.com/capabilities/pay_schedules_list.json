{
  "name": "pay_schedules_list",
  "description": "List all pay schedules for a company.",
  "endpoint": "/v1/companies/{company_id}/pay_schedules",
  "method": "GET",
  "resource_group": "pay_schedules",
  "parameters": [
    {"name": "company_id", "type": "string", "description": "The company UUID.", "required": true, "example": "7757616923531542"}
  ],
  "request_example": {"method": "GET", "url": "https://api.gusto.com/v1/companies/7757616923531542/pay_schedules", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": [{"uuid": "ps_123", "frequency": "Every other week", "anchor_pay_date": "2024-01-12", "day_1": null, "day_2": null}]},
  "auth_scopes": ["payrolls:read"],
  "rate_limits": {"requests_per_minute": 60}
}
