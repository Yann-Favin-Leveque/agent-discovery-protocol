{
  "name": "get_company",
  "description": "Fetch detailed information about a company including its legal name, EIN, locations, pay schedules, and compliance status. Useful for verifying company setup before running payroll.",
  "endpoint": "/v1/companies/{company_id}",
  "method": "GET",
  "parameters": [
    { "name": "company_id", "type": "string", "description": "The UUID of the company to retrieve.", "required": true, "example": "c44e6b5f-3b87-4f72-bb2a-e7ce1e8a9a1e" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gusto.com/v1/companies/c44e6b5f-3b87-4f72-bb2a-e7ce1e8a9a1e",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uuid": "c44e6b5f-3b87-4f72-bb2a-e7ce1e8a9a1e",
      "name": "Acme Corp",
      "trade_name": "Acme",
      "ein": "12-3456789",
      "entity_type": "LLC",
      "company_status": "Approved",
      "locations": [
        {
          "street_1": "123 Main St",
          "city": "San Francisco",
          "state": "CA",
          "zip": "94105"
        }
      ],
      "pay_schedules": [
        {
          "frequency": "Every other week",
          "anchor_pay_date": "2025-01-17"
        }
      ]
    }
  }
}
