{
  "name": "employees_list",
  "description": "List all W-2 employees for a company with their personal details, jobs, and compensation.",
  "endpoint": "/v1/companies/{company_id}/employees",
  "method": "GET",
  "resource_group": "employees",
  "parameters": [
    {"name": "company_id", "type": "string", "description": "The company UUID.", "required": true, "example": "7757616923531542"},
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 1},
    {"name": "per", "type": "integer", "description": "Results per page.", "required": false, "example": 25}
  ],
  "request_example": {"method": "GET", "url": "https://api.gusto.com/v1/companies/7757616923531542/employees?page=1&per=25", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": [{"uuid": "emp_123", "first_name": "John", "last_name": "Doe", "email": "john@acme.com", "date_of_birth": "1990-01-15", "ssn": "XXX-XX-1234", "jobs": [{"title": "Software Engineer", "compensation": {"rate": "120000.00", "payment_unit": "Year"}}]}]},
  "auth_scopes": ["employees:read"],
  "rate_limits": {"requests_per_minute": 60}
}
