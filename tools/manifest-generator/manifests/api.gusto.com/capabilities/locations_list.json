{
  "name": "locations_list",
  "description": "List all locations (offices/work sites) for a company.",
  "endpoint": "/v1/companies/{company_id}/locations",
  "method": "GET",
  "resource_group": "locations",
  "parameters": [
    {"name": "company_id", "type": "string", "description": "The company UUID.", "required": true, "example": "7757616923531542"}
  ],
  "request_example": {"method": "GET", "url": "https://api.gusto.com/v1/companies/7757616923531542/locations", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": [{"id": 1, "street_1": "123 Main St", "city": "San Francisco", "state": "CA", "zip": "94105", "country": "US"}]},
  "auth_scopes": ["companies:read"],
  "rate_limits": {"requests_per_minute": 60}
}
