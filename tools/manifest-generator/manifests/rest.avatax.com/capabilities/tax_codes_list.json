{
  "name": "tax_codes_list",
  "description": "List available tax codes.",
  "endpoint": "/api/v2/definitions/taxcodes",
  "method": "GET",
  "resource_group": "definitions",
  "parameters": [
    {
      "name": "$filter",
      "type": "string",
      "description": "OData filter.",
      "required": false,
      "in": "query"
    },
    {
      "name": "$top",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.avatax.com/api/v2/definitions/taxcodes?$top=25",
    "headers": {
      "Authorization": "Basic {base64_credentials}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "@recordsetCount": 1000,
      "value": [
        {
          "taxCode": "P0000000",
          "description": "Tangible Personal Property"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
