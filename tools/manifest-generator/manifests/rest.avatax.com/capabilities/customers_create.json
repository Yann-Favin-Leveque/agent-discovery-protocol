{
  "name": "customers_create",
  "description": "Create one or more customer records for a company.",
  "endpoint": "/api/v2/companies/{companyId}/customers",
  "method": "POST",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "companyId",
      "type": "integer",
      "description": "Company ID.",
      "required": true,
      "example": 67890,
      "in": "path"
    },
    {
      "name": "customerCode",
      "type": "string",
      "description": "Unique customer code.",
      "required": true,
      "example": "CUST-001",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Customer name.",
      "required": true,
      "example": "John Smith",
      "in": "body"
    },
    {
      "name": "emailAddress",
      "type": "string",
      "description": "Customer email.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.avatax.com/api/v2/companies/67890/customers",
    "headers": {
      "Authorization": "Basic {base64_credentials}",
      "Content-Type": "application/json"
    },
    "body": [
      {
        "customerCode": "CUST-001",
        "name": "John Smith",
        "emailAddress": "john@example.com"
      }
    ]
  },
  "response_example": {
    "status": 201,
    "body": [
      {
        "id": 111,
        "companyId": 67890,
        "customerCode": "CUST-001",
        "name": "John Smith"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
