{
  "name": "companies_get",
  "description": "Retrieve a company by ID.",
  "endpoint": "/api/v2/companies/{id}",
  "method": "GET",
  "resource_group": "companies",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Company ID.",
      "required": true,
      "example": 67890
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.avatax.com/api/v2/companies/67890",
    "headers": {
      "Authorization": "Basic {base64_credentials}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 67890,
      "companyCode": "DEFAULT",
      "name": "My Company",
      "isActive": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}