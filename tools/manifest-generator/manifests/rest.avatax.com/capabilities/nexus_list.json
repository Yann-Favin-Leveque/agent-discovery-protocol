{
  "name": "nexus_list",
  "description": "List nexus declarations for a company.",
  "endpoint": "/api/v2/companies/{companyId}/nexus",
  "method": "GET",
  "resource_group": "nexus",
  "parameters": [
    {
      "name": "companyId",
      "type": "integer",
      "description": "Company ID.",
      "required": true,
      "example": 67890,
      "in": "path"
    },
    {
      "name": "$filter",
      "type": "string",
      "description": "OData filter.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.avatax.com/api/v2/companies/67890/nexus",
    "headers": {
      "Authorization": "Basic {base64_credentials}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "@recordsetCount": 5,
      "value": [
        {
          "id": 333,
          "companyId": 67890,
          "country": "US",
          "region": "CA",
          "jurisTypeId": "STA",
          "nexusTypeId": "SalesOrSellersUseTax"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
