{
  "name": "certificates_create",
  "description": "Create tax exemption certificates for a company.",
  "endpoint": "/api/v2/companies/{companyId}/certificates",
  "method": "POST",
  "resource_group": "certificates",
  "parameters": [
    {
      "name": "companyId",
      "type": "integer",
      "description": "Company ID.",
      "required": true,
      "example": 67890,
      "in": "path"
    },
    {
      "name": "exemptReason",
      "type": "object",
      "description": "Exemption reason.",
      "required": true,
      "in": "body"
    },
    {
      "name": "customers",
      "type": "array",
      "description": "Customer IDs linked to certificate.",
      "required": true,
      "in": "body"
    },
    {
      "name": "exposureZone",
      "type": "object",
      "description": "Tax jurisdiction for exemption.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.avatax.com/api/v2/companies/67890/certificates",
    "headers": {
      "Authorization": "Basic {base64_credentials}",
      "Content-Type": "application/json"
    },
    "body": [
      {
        "exemptReason": {
          "id": 1,
          "name": "Resale"
        },
        "customers": [
          {
            "id": 111
          }
        ],
        "exposureZone": {
          "id": 1,
          "name": "California"
        }
      }
    ]
  },
  "response_example": {
    "status": 201,
    "body": [
      {
        "id": 222,
        "status": "ACTIVE",
        "exemptReason": {
          "name": "Resale"
        }
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
