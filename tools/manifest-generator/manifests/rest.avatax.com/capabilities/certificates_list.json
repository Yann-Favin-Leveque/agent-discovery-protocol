{
  "name": "certificates_list",
  "description": "List exemption certificates for a company.",
  "endpoint": "/api/v2/companies/{companyId}/certificates",
  "method": "GET",
  "resource_group": "certificates",
  "parameters": [
    {
      "name": "companyId",
      "type": "integer",
      "description": "Company ID.",
      "required": true,
      "example": 67890,
      "in": "path"
    },
    {
      "name": "$top",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.avatax.com/api/v2/companies/67890/certificates?$top=25",
    "headers": {
      "Authorization": "Basic {base64_credentials}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "@recordsetCount": 5,
      "value": [
        {
          "id": 222,
          "status": "ACTIVE",
          "exemptReason": {
            "name": "Resale"
          }
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
