{
  "name": "nexus_create",
  "description": "Create nexus declarations for a company.",
  "endpoint": "/api/v2/companies/{companyId}/nexus",
  "method": "POST",
  "resource_group": "nexus",
  "parameters": [
    {
      "name": "companyId",
      "type": "integer",
      "description": "Company ID.",
      "required": true,
      "example": 67890,
      "in": "path"
    },
    {
      "name": "country",
      "type": "string",
      "description": "Country code.",
      "required": true,
      "example": "US",
      "in": "body"
    },
    {
      "name": "region",
      "type": "string",
      "description": "State/region code.",
      "required": true,
      "example": "CA",
      "in": "body"
    },
    {
      "name": "jurisTypeId",
      "type": "string",
      "description": "Jurisdiction type: STA, CTY, CIT, etc.",
      "required": true,
      "in": "body"
    },
    {
      "name": "nexusTypeId",
      "type": "string",
      "description": "Nexus type: SalesOrSellersUseTax.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.avatax.com/api/v2/companies/67890/nexus",
    "headers": {
      "Authorization": "Basic {base64_credentials}",
      "Content-Type": "application/json"
    },
    "body": [
      {
        "country": "US",
        "region": "CA",
        "jurisTypeId": "STA",
        "nexusTypeId": "SalesOrSellersUseTax"
      }
    ]
  },
  "response_example": {
    "status": 201,
    "body": [
      {
        "id": 333,
        "country": "US",
        "region": "CA"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
