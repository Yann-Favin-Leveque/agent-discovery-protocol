{
  "name": "training_get",
  "description": "Get the status of a training job.",
  "resource_group": "trainings",
  "endpoint": "/trainings/{training_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "training_id",
      "type": "string",
      "required": true,
      "description": "The training ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/trainings/train123",
    "headers": {
      "Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "train123",
      "status": "succeeded",
      "output": {
        "version": "new-version-id"
      }
    }
  }
}
