{
  "name": "collection_get",
  "description": "Get a specific collection of models by slug.",
  "resource_group": "collections",
  "endpoint": "/collections/{collection_slug}",
  "method": "GET",
  "parameters": [
    {"name": "collection_slug", "type": "string", "required": true, "description": "The collection slug identifier."}
  ],
  "request_example": {"method": "GET", "url": "https://api.replicate.com/v1/collections/text-to-image", "headers": {"Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"}},
  "response_example": {"status": 200, "body": {"slug": "text-to-image", "name": "Text to Image", "models": [{"owner": "stability-ai", "name": "sdxl"}]}}
}
