  "endpoint": "/models/{model_owner}/{model_name}",
  "method": "GET",
  "parameters": [
    {"name": "model_owner", "type": "string", "required": true, "description": "The model owner username."},
    {"name": "model_name", "type": "string", "required": true, "description": "The model name."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/models/stability-ai/sdxl",
