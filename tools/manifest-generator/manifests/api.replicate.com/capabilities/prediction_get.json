{
  "name": "prediction_get",
  "description": "Retrieve the current state and output of a specific prediction.",
  "resource_group": "predictions",
  "endpoint": "/predictions/{prediction_id}",
  "method": "GET",
  "parameters": [
    {"name": "prediction_id", "type": "string", "required": true, "description": "The prediction ID."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/predictions/abc123xyz",
    "headers": {"Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123xyz",
      "status": "succeeded",
      "output": ["https://replicate.delivery/pbxt/..."],
      "created_at": "2026-03-01T10:00:00Z",
      "completed_at": "2026-03-01T10:00:15Z"
    }
  }
}
