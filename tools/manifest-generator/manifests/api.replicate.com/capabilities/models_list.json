{
  "name": "models_list",
  "description": "List public models with sorting options.",
  "resource_group": "models",
  "endpoint": "/models",
  "method": "GET",
  "parameters": [
    {
      "name": "sort_by",
      "type": "string",
      "required": false,
      "description": "Field to sort by.",
      "in": "query"
    },
    {
      "name": "sort_direction",
      "type": "string",
      "required": false,
      "description": "Sort direction: 'asc' or 'desc'.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/models",
    "headers": {
      "Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "url": "https://replicate.com/stability-ai/sdxl",
          "owner": "stability-ai",
          "name": "sdxl",
          "description": "A text-to-image generative AI model",
          "run_count": 5000000
        }
      ],
      "next": null
    }
  }
}
