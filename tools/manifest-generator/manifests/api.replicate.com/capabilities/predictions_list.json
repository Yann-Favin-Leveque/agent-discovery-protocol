{
  "name": "predictions_list",
  "description": "List all predictions with optional filtering by creation date and source.",
  "resource_group": "predictions",
  "endpoint": "/predictions",
  "method": "GET",
  "parameters": [
    {
      "name": "created_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 datetime to filter predictions created after.",
      "in": "query"
    },
    {
      "name": "created_before",
      "type": "string",
      "required": false,
      "description": "ISO 8601 datetime to filter predictions created before.",
      "in": "query"
    },
    {
      "name": "source",
      "type": "string",
      "required": false,
      "description": "Filter by creation source: 'api', 'web'.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/predictions",
    "headers": {
      "Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "abc123xyz",
          "status": "succeeded",
          "version": "5c7d5dc6...",
          "created_at": "2026-03-01T10:00:00Z"
        }
      ],
      "next": "https://api.replicate.com/v1/predictions?cursor=..."
    }
  }
}
