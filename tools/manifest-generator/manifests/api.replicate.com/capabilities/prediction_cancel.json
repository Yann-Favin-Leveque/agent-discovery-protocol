{
  "name": "prediction_cancel",
  "description": "Cancel a running prediction.",
  "resource_group": "predictions",
  "endpoint": "/predictions/{prediction_id}/cancel",
  "method": "POST",
  "parameters": [
    {"name": "prediction_id", "type": "string", "required": true, "description": "The prediction ID to cancel."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.replicate.com/v1/predictions/abc123xyz/cancel",
    "headers": {"Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "abc123xyz", "status": "canceled"}
  }
}
