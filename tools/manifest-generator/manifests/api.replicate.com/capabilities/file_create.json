{
  "name": "file_create",
  "description": "Upload a file for use with predictions.",
  "resource_group": "files",
  "endpoint": "/files",
  "method": "POST",
  "parameters": [
    {"name": "content", "type": "file", "required": true, "description": "The file to upload."},
    {"name": "filename", "type": "string", "required": false, "description": "Name for the file."}
  ],
  "request_example": {"method": "POST", "url": "https://api.replicate.com/v1/files", "headers": {"Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"}, "body": "multipart/form-data with content field"},
  "response_example": {"status": 201, "body": {"id": "file123", "name": "input.png", "size": 102400, "urls": {"get": "https://api.replicate.com/v1/files/file123"}}}
}
