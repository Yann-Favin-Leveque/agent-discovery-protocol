{
  "name": "models_search",
  "description": "Search for models by text query (beta).",
  "resource_group": "search",
  "endpoint": "/search",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "Search query string.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results (1-50, default 20).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/search?query=text-to-image",
    "headers": {
      "Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "url": "https://replicate.com/stability-ai/sdxl",
          "owner": "stability-ai",
          "name": "sdxl"
        }
      ]
    }
  }
}
