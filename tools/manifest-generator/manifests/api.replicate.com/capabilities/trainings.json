{
  "name": "trainings",
  "description": "Manage trainings — cancel a training, list trainings, get a training. Supports standard CRUD operations through the REST API.",
  "endpoint": "/trainings/{training_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "training_id",
      "type": "string",
      "description": "The ID of the training you want to cancel.\n",
      "required": true,
      "example": "abc_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.replicate.com/v1/trainings/{training_id}/cancel",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "training_id": "abc_123"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "training_id": "abc_123"
      }
    }
  }
}
