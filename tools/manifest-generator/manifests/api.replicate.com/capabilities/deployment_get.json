{
  "name": "deployment_get",
  "description": "Get details about a specific deployment.",
  "resource_group": "deployments",
  "endpoint": "/deployments/{deployment_owner}/{deployment_name}",
  "method": "GET",
  "parameters": [
    {
      "name": "deployment_owner",
      "type": "string",
      "required": true,
      "description": "Deployment owner.",
      "in": "path"
    },
    {
      "name": "deployment_name",
      "type": "string",
      "required": true,
      "description": "Deployment name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/deployments/my-org/my-deployment",
    "headers": {
      "Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "owner": "my-org",
      "name": "my-deployment",
      "current_release": {
        "version": "5c7d...",
        "created_at": "2026-01-15T10:00:00Z"
      }
    }
  }
}
