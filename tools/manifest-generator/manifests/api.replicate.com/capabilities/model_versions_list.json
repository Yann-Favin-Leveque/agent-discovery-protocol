{
  "name": "model_versions_list",
  "description": "List all versions of a specific model.",
  "resource_group": "models",
  "endpoint": "/models/{model_owner}/{model_name}/versions",
  "method": "GET",
  "parameters": [
    {
      "name": "model_owner",
      "type": "string",
      "required": true,
      "description": "The model owner.",
      "in": "path"
    },
    {
      "name": "model_name",
      "type": "string",
      "required": true,
      "description": "The model name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.replicate.com/v1/models/stability-ai/sdxl/versions",
    "headers": {
      "Authorization": "Bearer r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "5c7d5dc6...",
          "created_at": "2026-01-15T10:00:00Z"
        }
      ]
    }
  }
}
