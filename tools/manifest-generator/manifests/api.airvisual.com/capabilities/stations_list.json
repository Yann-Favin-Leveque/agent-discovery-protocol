{
  "name": "stations_list",
  "description": "List all air quality monitoring stations within a specified city.",
  "resource_group": "directory",
  "endpoint": "/v2/stations",
  "method": "GET",
  "parameters": [
    {
      "name": "city",
      "type": "string",
      "required": true,
      "description": "City name.",
      "in": "query"
    },
    {
      "name": "state",
      "type": "string",
      "required": true,
      "description": "State name.",
      "in": "query"
    },
    {
      "name": "country",
      "type": "string",
      "required": true,
      "description": "Country name.",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.airvisual.com/v2/stations?city=Paris&state=Ile-de-France&country=France&key=YOUR_API_KEY"
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "station": "Paris-Centre"
        },
        {
          "station": "Paris-13eme"
        },
        {
          "station": "Paris-Stade de France"
        }
      ]
    }
  }
}