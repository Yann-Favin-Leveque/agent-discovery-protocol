{
  "name": "states_list",
  "description": "List states or provinces within a specified country that have air quality data.",
  "resource_group": "directory",
  "endpoint": "/v2/states",
  "method": "GET",
  "parameters": [
    {
      "name": "country",
      "type": "string",
      "required": true,
      "description": "Country name.",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.airvisual.com/v2/states?country=France&key=YOUR_API_KEY"
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "state": "Ile-de-France"
        },
        {
          "state": "Provence-Alpes-Cote d'Azur"
        }
      ]
    }
  }
}