{
  "name": "countries_list",
  "description": "List all countries supported by the AirVisual API that have air quality monitoring data.",
  "resource_group": "directory",
  "endpoint": "/v2/countries",
  "method": "GET",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.airvisual.com/v2/countries?key=YOUR_API_KEY"
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "country": "France"
        },
        {
          "country": "Germany"
        },
        {
          "country": "United States"
        }
      ]
    }
  }
}