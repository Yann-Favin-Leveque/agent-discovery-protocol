{
  "name": "city_ranking_get",
  "description": "Get a global ranking of major cities by current air quality (AQI), sorted from most to least polluted.",
  "resource_group": "ranking",
  "endpoint": "/v2/city_ranking",
  "method": "GET",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.airvisual.com/v2/city_ranking?key=YOUR_API_KEY"
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "city": "Delhi",
          "state": "Delhi",
          "country": "India",
          "ranking": {
            "current_aqi": 185
          }
        },
        {
          "city": "Lahore",
          "state": "Punjab",
          "country": "Pakistan",
          "ranking": {
            "current_aqi": 172
          }
        }
      ]
    }
  }
}