{
  "name": "cities_list",
  "description": "List cities within a state and country that have air quality monitoring data.",
  "resource_group": "directory",
  "endpoint": "/v2/cities",
  "method": "GET",
  "parameters": [
    {
      "name": "state",
      "type": "string",
      "required": true,
      "description": "State or province name.",
      "in": "query"
    },
    {
      "name": "country",
      "type": "string",
      "required": true,
      "description": "Country name.",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.airvisual.com/v2/cities?state=Ile-de-France&country=France&key=YOUR_API_KEY"
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "city": "Paris"
        },
        {
          "city": "Versailles"
        },
        {
          "city": "Boulogne-Billancourt"
        }
      ]
    }
  }
}