{
  "name": "health_get",
  "description": "Check the health status of the Gotenberg instance and its modules (Chromium, LibreOffice). Returns 200 when healthy, 503 when unhealthy.",
  "resource_group": "system",
  "endpoint": "/health",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "http://localhost:3000/health",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "up",
      "details": {
        "chromium": {
          "status": "up",
          "timestamp": "2026-03-01T12:00:00.000Z"
        },
        "libreoffice": {
          "status": "up",
          "timestamp": "2026-03-01T12:00:00.000Z"
        }
      }
    }
  }
}
