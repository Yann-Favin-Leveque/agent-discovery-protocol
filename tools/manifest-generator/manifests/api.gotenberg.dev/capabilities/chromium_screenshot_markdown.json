{
  "name": "chromium_screenshot_markdown",
  "description": "Take a screenshot of Markdown content rendered via an HTML wrapper using Chromium. Supports PNG, JPEG, and WebP formats.",
  "resource_group": "chromium",
  "endpoint": "/forms/chromium/screenshot/markdown",
  "method": "POST",
  "parameters": [
    {
      "name": "index.html",
      "type": "file",
      "required": true,
      "location": "formData",
      "description": "HTML wrapper file for the Markdown content.",
      "in": "body"
    },
    {
      "name": "*.md",
      "type": "file",
      "required": true,
      "location": "formData",
      "description": "One or more Markdown files.",
      "in": "body"
    },
    {
      "name": "width",
      "type": "integer",
      "required": false,
      "location": "formData",
      "description": "Screen width in pixels. Default: 800.",
      "in": "body"
    },
    {
      "name": "height",
      "type": "integer",
      "required": false,
      "location": "formData",
      "description": "Screen height in pixels. Default: 600.",
      "in": "body"
    },
    {
      "name": "format",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Image format: 'png', 'jpeg', or 'webp'. Default: 'png'.",
      "in": "body"
    },
    {
      "name": "quality",
      "type": "integer",
      "required": false,
      "location": "formData",
      "description": "Compression quality 0-100. Default: 100.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "http://localhost:3000/forms/chromium/screenshot/markdown",
    "headers": {
      "Content-Type": "multipart/form-data"
    },
    "body": "FormData with index.html and readme.md files, format=png"
  },
  "response_example": {
    "status": 200,
    "headers": {
      "Content-Type": "image/png"
    },
    "body": "<binary image content>"
  }
}
