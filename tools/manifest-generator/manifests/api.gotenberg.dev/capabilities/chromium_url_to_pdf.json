{
  "name": "chromium_url_to_pdf",
  "description": "Convert a web page at a given URL to a PDF document using Chromium. Supports custom paper size, margins, headers/footers, page ranges, JavaScript wait conditions, cookies, custom HTTP headers, PDF/A compliance, and encryption.",
  "resource_group": "chromium",
  "endpoint": "/forms/chromium/convert/url",
  "method": "POST",
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "location": "formData",
      "description": "URL of the page to convert into PDF.",
      "in": "body"
    },
    {
      "name": "paperWidth",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Paper width. Default: 8.5.",
      "in": "body"
    },
    {
      "name": "paperHeight",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Paper height. Default: 11.",
      "in": "body"
    },
    {
      "name": "marginTop",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Top margin. Default: 0.39.",
      "in": "body"
    },
    {
      "name": "marginBottom",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Bottom margin. Default: 0.39.",
      "in": "body"
    },
    {
      "name": "marginLeft",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Left margin. Default: 0.39.",
      "in": "body"
    },
    {
      "name": "marginRight",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Right margin. Default: 0.39.",
      "in": "body"
    },
    {
      "name": "landscape",
      "type": "boolean",
      "required": false,
      "location": "formData",
      "description": "Landscape orientation. Default: false.",
      "in": "body"
    },
    {
      "name": "printBackground",
      "type": "boolean",
      "required": false,
      "location": "formData",
      "description": "Include background graphics. Default: false.",
      "in": "body"
    },
    {
      "name": "scale",
      "type": "number",
      "required": false,
      "location": "formData",
      "description": "Page zoom factor. Default: 1.0.",
      "in": "body"
    },
    {
      "name": "singlePage",
      "type": "boolean",
      "required": false,
      "location": "formData",
      "description": "Force all content onto one long page. Default: false.",
      "in": "body"
    },
    {
      "name": "emulatedMediaType",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "'screen' or 'print'. Default: 'print'.",
      "in": "body"
    },
    {
      "name": "waitDelay",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Duration to wait before converting (e.g., '5s').",
      "in": "body"
    },
    {
      "name": "waitForExpression",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "JavaScript expression that must return true.",
      "in": "body"
    },
    {
      "name": "waitForSelector",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "CSS selector that must be visible before converting.",
      "in": "body"
    },
    {
      "name": "cookies",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "JSON array of cookie objects for authentication.",
      "in": "body"
    },
    {
      "name": "extraHttpHeaders",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "JSON object of custom HTTP headers.",
      "in": "body"
    },
    {
      "name": "userAgent",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Custom User-Agent header.",
      "in": "body"
    },
    {
      "name": "nativePageRanges",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Page ranges (e.g., '1-5, 8').",
      "in": "body"
    },
    {
      "name": "pdfa",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "PDF/A standard: 'PDF/A-1b', 'PDF/A-2b', 'PDF/A-3b'.",
      "in": "body"
    },
    {
      "name": "metadata",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "JSON XMP metadata.",
      "in": "body"
    },
    {
      "name": "userPassword",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Password to open PDF.",
      "in": "body"
    },
    {
      "name": "ownerPassword",
      "type": "string",
      "required": false,
      "location": "formData",
      "description": "Password for permissions.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "http://localhost:3000/forms/chromium/convert/url",
    "headers": {
      "Content-Type": "multipart/form-data"
    },
    "body": "FormData with url=https://example.com, printBackground=true, landscape=false"
  },
  "response_example": {
    "status": 200,
    "headers": {
      "Content-Type": "application/pdf"
    },
    "body": "<binary PDF content>"
  }
}
