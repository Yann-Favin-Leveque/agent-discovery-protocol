{
  "name": "albums_get_several",
  "description": "Get details for multiple albums by their Spotify IDs in a single request.",
  "resource_group": "albums",
  "endpoint": "/v1/albums",
  "method": "GET",
  "parameters": [
    {
      "name": "ids",
      "type": "string",
      "required": true,
      "description": "Comma-separated list of Spotify album IDs. Max: 20.",
      "in": "query"
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/albums?ids=382ObEPsp2rxGrnsizN5TX,4aawyAB9vmqN3uQ7FjRGTy",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "albums": [
        {
          "id": "382ObEPsp2rxGrnsizN5TX",
          "name": "TIDAL",
          "artists": [
            {
              "name": "Fiona Apple"
            }
          ]
        }
      ]
    }
  }
}
