{
  "name": "player_add_to_queue",
  "description": "Add a track or episode URI to the end of the user's playback queue.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/queue",
  "method": "POST",
  "parameters": [
    {
      "name": "uri",
      "type": "string",
      "required": true,
      "description": "Spotify URI of the track/episode."
    },
    {
      "name": "device_id",
      "type": "string",
      "required": false,
      "description": "The device ID."
    }
  ],
  "auth_scopes": [
    "user-modify-playback-state"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.spotify.com/v1/me/player/queue?uri=spotify:track:4iV5W9uYEdYUVa79Axb7Rh",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}