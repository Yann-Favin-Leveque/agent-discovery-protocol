{
  "name": "playlists_update",
  "description": "Change a playlist's name, description, or public/private state.",
  "resource_group": "playlists",
  "endpoint": "/v1/playlists/{playlist_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "playlist_id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the playlist."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "New name."
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "New description."
    },
    {
      "name": "public",
      "type": "boolean",
      "required": false,
      "description": "Whether public."
    },
    {
      "name": "collaborative",
      "type": "boolean",
      "required": false,
      "description": "Whether collaborative."
    }
  ],
  "auth_scopes": [
    "playlist-modify-public",
    "playlist-modify-private"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.spotify.com/v1/playlists/3cEYpjA9oz9GiPac4AsH4n",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Name",
      "description": "Updated description"
    }
  },
  "response_example": {
    "status": 200,
    "body": null
  }
}