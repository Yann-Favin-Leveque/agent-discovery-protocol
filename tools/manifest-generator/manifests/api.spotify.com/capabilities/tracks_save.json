{
  "name": "tracks_save",
  "description": "Save one or more tracks to the current user's liked songs.",
  "resource_group": "tracks",
  "endpoint": "/v1/me/tracks",
  "method": "PUT",
  "parameters": [
    {
      "name": "ids",
      "type": "string",
      "required": true,
      "description": "Comma-separated Spotify track IDs. Max: 50.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "user-library-modify"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.spotify.com/v1/me/tracks?ids=11dFghVXANMlKmJXsNCbNl",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": null
  }
}
