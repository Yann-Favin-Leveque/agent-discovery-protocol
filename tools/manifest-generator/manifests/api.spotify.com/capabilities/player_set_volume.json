{
  "name": "player_set_volume",
  "description": "Set the volume for the user's current playback device.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/volume",
  "method": "PUT",
  "parameters": [
    {
      "name": "volume_percent",
      "type": "integer",
      "required": true,
      "description": "Volume percentage. Range: 0-100.",
      "in": "body"
    },
    {
      "name": "device_id",
      "type": "string",
      "required": false,
      "description": "The device ID.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "user-modify-playback-state"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.spotify.com/v1/me/player/volume?volume_percent=50",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
