{
  "name": "player_get_currently_playing",
  "description": "Get the currently playing track or episode on the user's active device.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/currently-playing",
  "method": "GET",
  "parameters": [
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "user-read-currently-playing"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/me/player/currently-playing",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "is_playing": true,
      "item": {
        "name": "Song Name",
        "artists": [
          {
            "name": "Artist"
          }
        ],
        "album": {
          "name": "Album"
        }
      },
      "progress_ms": 45000
    }
  }
}
