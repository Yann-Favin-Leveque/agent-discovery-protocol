{
  "name": "artists_get_several",
  "description": "Get details for multiple artists by their Spotify IDs.",
  "resource_group": "artists",
  "endpoint": "/v1/artists",
  "method": "GET",
  "parameters": [
    {
      "name": "ids",
      "type": "string",
      "required": true,
      "description": "Comma-separated Spotify artist IDs. Max: 50.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/artists?ids=0OdUWJ0sBjDrqHygGUXeCF,2CIMQHirSU0MQqyYHq0eOx",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "artists": [
        {
          "id": "0OdUWJ0sBjDrqHygGUXeCF",
          "name": "Band of Horses"
        }
      ]
    }
  }
}
