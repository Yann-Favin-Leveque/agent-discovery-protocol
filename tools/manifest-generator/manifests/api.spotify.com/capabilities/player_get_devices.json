{
  "name": "player_get_devices",
  "description": "Get the user's available Spotify-connected devices.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/devices",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "user-read-playback-state"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/me/player/devices",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "devices": [
        {
          "id": "abc",
          "is_active": true,
          "name": "My Computer",
          "type": "Computer",
          "volume_percent": 65
        }
      ]
    }
  }
}