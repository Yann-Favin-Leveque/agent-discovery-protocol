{
  "name": "playlists_get_featured",
  "description": "Get Spotify's featured playlists for the current locale.",
  "resource_group": "playlists",
  "endpoint": "/v1/browse/featured-playlists",
  "method": "GET",
  "parameters": [
    {
      "name": "locale",
      "type": "string",
      "required": false,
      "description": "Locale code e.g. 'en_US'."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max items. Default: 20. Range: 1-50."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Index of first item. Default: 0."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/browse/featured-playlists?limit=5",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Editor's picks",
      "playlists": {
        "items": [
          {
            "id": "abc",
            "name": "Today's Top Hits"
          }
        ]
      }
    }
  }
}