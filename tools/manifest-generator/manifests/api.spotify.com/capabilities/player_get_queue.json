{
  "name": "player_get_queue",
  "description": "Get the user's current playback queue.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/queue",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "user-read-playback-state"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/me/player/queue",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "currently_playing": {
        "name": "Current Song"
      },
      "queue": [
        {
          "name": "Next Song 1"
        },
        {
          "name": "Next Song 2"
        }
      ]
    }
  }
}