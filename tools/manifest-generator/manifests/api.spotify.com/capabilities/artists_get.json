{
  "name": "artists_get",
  "description": "Get detailed information about a specific artist including name, genres, popularity, follower count, and images.",
  "resource_group": "artists",
  "endpoint": "/v1/artists/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the artist.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/artists/0OdUWJ0sBjDrqHygGUXeCF",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "0OdUWJ0sBjDrqHygGUXeCF",
      "name": "Band of Horses",
      "genres": [
        "indie rock",
        "folk rock"
      ],
      "popularity": 65,
      "followers": {
        "total": 850000
      }
    }
  }
}
