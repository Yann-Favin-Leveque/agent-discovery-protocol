{
  "name": "albums_remove_saved",
  "description": "Remove one or more albums from the current user's library.",
  "resource_group": "albums",
  "endpoint": "/v1/me/albums",
  "method": "DELETE",
  "parameters": [
    {
      "name": "ids",
      "type": "string",
      "required": true,
      "description": "Comma-separated Spotify album IDs. Max: 20."
    }
  ],
  "auth_scopes": [
    "user-library-modify"
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.spotify.com/v1/me/albums?ids=4aawyAB9vmqN3uQ7FjRGTy",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": null
  }
}