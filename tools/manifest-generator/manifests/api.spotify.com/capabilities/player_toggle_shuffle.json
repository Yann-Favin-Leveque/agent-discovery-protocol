{
  "name": "player_toggle_shuffle",
  "description": "Toggle shuffle on or off for the user's playback.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/shuffle",
  "method": "PUT",
  "parameters": [
    {
      "name": "state",
      "type": "boolean",
      "required": true,
      "description": "true to turn on shuffle, false to turn off."
    },
    {
      "name": "device_id",
      "type": "string",
      "required": false,
      "description": "The device ID."
    }
  ],
  "auth_scopes": [
    "user-modify-playback-state"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.spotify.com/v1/me/player/shuffle?state=true",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}