{
  "name": "artists_get_top_tracks",
  "description": "Get an artist's top tracks by country.",
  "resource_group": "artists",
  "endpoint": "/v1/artists/{id}/top-tracks",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the artist.",
      "in": "path"
    },
    {
      "name": "market",
      "type": "string",
      "required": true,
      "description": "ISO 3166-1 alpha-2 country code.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/artists/0OdUWJ0sBjDrqHygGUXeCF/top-tracks?market=US",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tracks": [
        {
          "id": "xyz",
          "name": "The Funeral",
          "popularity": 72,
          "album": {
            "name": "Everything All the Time"
          }
        }
      ]
    }
  }
}
