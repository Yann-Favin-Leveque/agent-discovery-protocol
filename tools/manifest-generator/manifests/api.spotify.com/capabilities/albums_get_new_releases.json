{
  "name": "albums_get_new_releases",
  "description": "Get a list of new album releases featured on Spotify.",
  "resource_group": "albums",
  "endpoint": "/v1/browse/new-releases",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max items. Default: 20. Range: 1-50.",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Index of first item. Default: 0.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/browse/new-releases?limit=10",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "albums": {
        "items": [
          {
            "id": "abc",
            "name": "New Album",
            "release_date": "2024-08-15",
            "artists": [
              {
                "name": "Artist"
              }
            ]
          }
        ]
      }
    }
  }
}
