{
  "name": "episodes_get",
  "description": "Get details for a specific podcast episode.",
  "resource_group": "episodes",
  "endpoint": "/v1/episodes/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the episode."
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/episodes/512ojhOuo1ktJprKbVcKyQ",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "512ojhOuo1ktJprKbVcKyQ",
      "name": "Episode Title",
      "description": "Episode description",
      "release_date": "2024-08-15",
      "duration_ms": 3600000,
      "show": {
        "name": "Podcast Name"
      }
    }
  }
}