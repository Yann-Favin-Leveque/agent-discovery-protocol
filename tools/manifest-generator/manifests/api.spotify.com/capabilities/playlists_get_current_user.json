{
  "name": "playlists_get_current_user",
  "description": "Get the current authenticated user's playlists.",
  "resource_group": "playlists",
  "endpoint": "/v1/me/playlists",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max items. Default: 20. Range: 1-50.",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Index of first item. Default: 0.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "playlist-read-private"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/me/playlists?limit=10",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "abc",
          "name": "My Playlist",
          "tracks": {
            "total": 25
          }
        }
      ],
      "total": 15
    }
  }
}
