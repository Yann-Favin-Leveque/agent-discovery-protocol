{
  "name": "tracks_get",
  "description": "Get detailed information about a specific track including name, artist, album, duration, and popularity.",
  "resource_group": "tracks",
  "endpoint": "/v1/tracks/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the track."
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/tracks/11dFghVXANMlKmJXsNCbNl",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "11dFghVXANMlKmJXsNCbNl",
      "name": "Cut To The Feeling",
      "artists": [
        {
          "name": "Carly Rae Jepsen"
        }
      ],
      "album": {
        "name": "Cut To The Feeling"
      },
      "duration_ms": 207000,
      "popularity": 75
    }
  }
}