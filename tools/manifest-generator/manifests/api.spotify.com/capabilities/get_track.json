{
  "name": "get_track",
  "description": "Get detailed information about a specific track including its name, artist, album, duration, popularity, and preview URL.",
  "endpoint": "/v1/tracks/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The Spotify ID of the track.",
      "required": true,
      "example": "6dGnYIeXmHdcikdzNNDMm2"
    },
    {
      "name": "market",
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code for market-specific data and track availability.",
      "required": false,
      "example": "US"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/tracks/6dGnYIeXmHdcikdzNNDMm2?market=US",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "6dGnYIeXmHdcikdzNNDMm2",
      "name": "Creep",
      "artists": [{ "id": "4Z8W4fKeB5YxbusRsdQVPb", "name": "Radiohead" }],
      "album": {
        "id": "6Eo5EkmdLvZrONzi046iC2",
        "name": "Pablo Honey",
        "release_date": "1993-02-22",
        "images": [{ "url": "https://i.scdn.co/image/...", "width": 640, "height": 640 }]
      },
      "duration_ms": 238640,
      "popularity": 82,
      "explicit": false,
      "preview_url": "https://p.scdn.co/mp3-preview/...",
      "external_urls": { "spotify": "https://open.spotify.com/track/6dGnYIeXmHdcikdzNNDMm2" }
    }
  }
}
