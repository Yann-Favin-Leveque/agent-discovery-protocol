{
  "name": "get_current_playback",
  "description": "Get information about the user's current playback state including the currently playing track, device, volume, and progress.",
  "endpoint": "/v1/me/player",
  "method": "GET",
  "parameters": [
    {
      "name": "market",
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code for market-specific track availability.",
      "required": false,
      "example": "US"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/me/player?market=US",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "is_playing": true,
      "progress_ms": 45000,
      "item": {
        "id": "6dGnYIeXmHdcikdzNNDMm2",
        "name": "Creep",
        "artists": [{ "id": "4Z8W4fKeB5YxbusRsdQVPb", "name": "Radiohead" }],
        "album": { "name": "Pablo Honey" },
        "duration_ms": 238640
      },
      "device": {
        "id": "device_abc123",
        "name": "My Laptop",
        "type": "Computer",
        "volume_percent": 75,
        "is_active": true
      },
      "shuffle_state": false,
      "repeat_state": "off"
    }
  }
}
