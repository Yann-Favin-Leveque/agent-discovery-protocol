{
  "name": "users_get_current",
  "description": "Get the current authenticated user's Spotify profile.",
  "resource_group": "users",
  "endpoint": "/v1/me",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "user-read-private",
    "user-read-email"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/me",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "smedjan",
      "display_name": "JM Wizzler",
      "email": "jm@example.com",
      "country": "SE",
      "product": "premium",
      "followers": {
        "total": 150
      }
    }
  }
}