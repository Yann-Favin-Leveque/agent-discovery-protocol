{
  "name": "shows_get",
  "description": "Get details for a specific podcast show.",
  "resource_group": "shows",
  "endpoint": "/v1/shows/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the show."
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/shows/38bS44xjbVVZ3No3ByF1dJ",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "38bS44xjbVVZ3No3ByF1dJ",
      "name": "Podcast Name",
      "publisher": "Publisher",
      "total_episodes": 150
    }
  }
}