{
  "name": "albums_get",
  "description": "Get detailed information about a specific album including its tracks, release date, label, and artist info.",
  "resource_group": "albums",
  "endpoint": "/v1/albums/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the album.",
      "in": "path"
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/albums/4aawyAB9vmqN3uQ7FjRGTy",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "4aawyAB9vmqN3uQ7FjRGTy",
      "name": "Global Warming",
      "artists": [
        {
          "name": "Pitbull"
        }
      ],
      "release_date": "2012-11-16",
      "total_tracks": 18
    }
  }
}
