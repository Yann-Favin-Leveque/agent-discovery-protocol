{
  "name": "users_unfollow_artists",
  "description": "Unfollow one or more artists or users.",
  "resource_group": "users",
  "endpoint": "/v1/me/following",
  "method": "DELETE",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "'artist' or 'user'."
    },
    {
      "name": "ids",
      "type": "string",
      "required": true,
      "description": "Comma-separated IDs. Max: 50."
    }
  ],
  "auth_scopes": [
    "user-follow-modify"
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.spotify.com/v1/me/following?type=artist&ids=2CIMQHirSU0MQqyYHq0eOx",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}