{
  "name": "users_follow_artists",
  "description": "Follow one or more artists or users on Spotify.",
  "resource_group": "users",
  "endpoint": "/v1/me/following",
  "method": "PUT",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "'artist' or 'user'.",
      "in": "body"
    },
    {
      "name": "ids",
      "type": "string",
      "required": true,
      "description": "Comma-separated IDs. Max: 50.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "user-follow-modify"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.spotify.com/v1/me/following?type=artist&ids=2CIMQHirSU0MQqyYHq0eOx",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
