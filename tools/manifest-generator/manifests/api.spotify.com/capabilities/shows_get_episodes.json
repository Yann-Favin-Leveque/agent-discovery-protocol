{
  "name": "shows_get_episodes",
  "description": "Get the episodes of a specific podcast show.",
  "resource_group": "shows",
  "endpoint": "/v1/shows/{id}/episodes",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the show."
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max items. Default: 20. Range: 1-50."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Index of first item. Default: 0."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/shows/38bS44xjbVVZ3No3ByF1dJ/episodes?limit=5",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "abc",
          "name": "Episode 1",
          "release_date": "2024-08-15",
          "duration_ms": 3600000
        }
      ],
      "total": 150
    }
  }
}