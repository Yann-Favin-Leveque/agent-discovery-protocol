{
  "name": "player_set_repeat",
  "description": "Set the repeat mode: track, context, or off.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/repeat",
  "method": "PUT",
  "parameters": [
    {
      "name": "state",
      "type": "string",
      "required": true,
      "description": "'track', 'context', or 'off'."
    },
    {
      "name": "device_id",
      "type": "string",
      "required": false,
      "description": "The device ID."
    }
  ],
  "auth_scopes": [
    "user-modify-playback-state"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.spotify.com/v1/me/player/repeat?state=track",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}