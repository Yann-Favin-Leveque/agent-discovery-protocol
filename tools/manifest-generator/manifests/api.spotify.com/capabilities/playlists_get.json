{
  "name": "playlists_get",
  "description": "Get details for a specific playlist including its name, description, owner, and track listing.",
  "resource_group": "playlists",
  "endpoint": "/v1/playlists/{playlist_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "playlist_id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the playlist."
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code."
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Filters for the response."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/playlists/3cEYpjA9oz9GiPac4AsH4n",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "3cEYpjA9oz9GiPac4AsH4n",
      "name": "My Playlist",
      "description": "A great playlist",
      "owner": {
        "display_name": "User"
      },
      "tracks": {
        "total": 25
      }
    }
  }
}