{
  "name": "playlists_remove_items",
  "description": "Remove one or more items from a playlist.",
  "resource_group": "playlists",
  "endpoint": "/v1/playlists/{playlist_id}/tracks",
  "method": "DELETE",
  "parameters": [
    {
      "name": "playlist_id",
      "type": "string",
      "required": true,
      "description": "The Spotify ID of the playlist."
    },
    {
      "name": "tracks",
      "type": "array",
      "required": true,
      "description": "Array of objects with 'uri' field."
    }
  ],
  "auth_scopes": [
    "playlist-modify-public",
    "playlist-modify-private"
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.spotify.com/v1/playlists/3cEYpjA9oz9GiPac4AsH4n/tracks",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "tracks": [
        {
          "uri": "spotify:track:4iV5W9uYEdYUVa79Axb7Rh"
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "snapshot_id": "abc123"
    }
  }
}