{
  "name": "get_artist",
  "description": "Retrieve an artist's profile including their name, genres, popularity, follower count, and images. Can also fetch their top tracks and related artists.",
  "endpoint": "/v1/artists/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The Spotify ID of the artist.",
      "required": true,
      "example": "4Z8W4fKeB5YxbusRsdQVPb"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/artists/4Z8W4fKeB5YxbusRsdQVPb",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "4Z8W4fKeB5YxbusRsdQVPb",
      "name": "Radiohead",
      "genres": ["alternative rock", "art rock", "permanent wave", "rock"],
      "popularity": 80,
      "followers": { "total": 9500000 },
      "images": [
        { "url": "https://i.scdn.co/image/...", "width": 640, "height": 640 }
      ],
      "external_urls": { "spotify": "https://open.spotify.com/artist/4Z8W4fKeB5YxbusRsdQVPb" }
    }
  }
}
