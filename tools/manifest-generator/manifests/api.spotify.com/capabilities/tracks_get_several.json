{
  "name": "tracks_get_several",
  "description": "Get details for multiple tracks by their Spotify IDs.",
  "resource_group": "tracks",
  "endpoint": "/v1/tracks",
  "method": "GET",
  "parameters": [
    {
      "name": "ids",
      "type": "string",
      "required": true,
      "description": "Comma-separated Spotify track IDs. Max: 50.",
      "in": "query"
    },
    {
      "name": "market",
      "type": "string",
      "required": false,
      "description": "ISO 3166-1 alpha-2 country code.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/tracks?ids=11dFghVXANMlKmJXsNCbNl,4iV5W9uYEdYUVa79Axb7Rh",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tracks": [
        {
          "id": "11dFghVXANMlKmJXsNCbNl",
          "name": "Cut To The Feeling"
        }
      ]
    }
  }
}
