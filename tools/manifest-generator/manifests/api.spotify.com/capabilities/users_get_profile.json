{
  "name": "users_get_profile",
  "description": "Get a public user's Spotify profile.",
  "resource_group": "users",
  "endpoint": "/v1/users/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "The user's Spotify ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.spotify.com/v1/users/smedjan",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "smedjan",
      "display_name": "JM Wizzler",
      "followers": {
        "total": 150
      }
    }
  }
}