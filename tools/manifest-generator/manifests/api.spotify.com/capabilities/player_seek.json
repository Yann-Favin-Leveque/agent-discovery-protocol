{
  "name": "player_seek",
  "description": "Seek to a position in the currently playing track.",
  "resource_group": "player",
  "endpoint": "/v1/me/player/seek",
  "method": "PUT",
  "parameters": [
    {
      "name": "position_ms",
      "type": "integer",
      "required": true,
      "description": "Position in milliseconds to seek to."
    },
    {
      "name": "device_id",
      "type": "string",
      "required": false,
      "description": "The device ID."
    }
  ],
  "auth_scopes": [
    "user-modify-playback-state"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.spotify.com/v1/me/player/seek?position_ms=25000",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}