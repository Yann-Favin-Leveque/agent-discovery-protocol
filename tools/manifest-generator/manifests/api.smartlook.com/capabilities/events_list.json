{
  "name": "events_list",
  "description": "List tracked events with filtering by name, date range, and aggregation options.",
  "endpoint": "/api/v1/events",
  "method": "GET",
  "resource_group": "events",
  "parameters": [
    {
      "name": "event_name",
      "type": "string",
      "description": "Filter by event name.",
      "required": false,
      "example": "click_cta"
    },
    {
      "name": "from",
      "type": "string",
      "description": "Start date (ISO 8601).",
      "required": false,
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "to",
      "type": "string",
      "description": "End date (ISO 8601).",
      "required": false,
      "example": "2024-01-31T23:59:59Z"
    },
    {
      "name": "limit",
      "type": "number",
      "description": "Maximum results to return.",
      "required": false,
      "example": 50
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/events?from=2024-01-01T00:00:00Z&to=2024-01-31T23:59:59Z",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        { "name": "click_cta", "count": 1500, "unique_visitors": 800 },
        { "name": "form_submit", "count": 320, "unique_visitors": 310 }
      ],
      "total_count": 15
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
