{
  "name": "events_get",
  "description": "Retrieve detailed information about a specific tracked event.",
  "endpoint": "/api/v1/events/{event_id}",
  "method": "GET",
  "resource_group": "events",
  "parameters": [
    {
      "name": "event_id",
      "type": "string",
      "description": "The event ID.",
      "required": true,
      "example": "evt_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/events/evt_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "evt_abc123",
      "name": "click_cta",
      "count": 1500,
      "unique_visitors": 800,
      "created_at": "2024-01-01T00:00:00Z"
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
