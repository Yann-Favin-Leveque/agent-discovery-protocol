{
  "name": "sessions_get",
  "description": "Get detailed information about a specific session recording including pages, events, and playback URL.",
  "endpoint": "/api/v1/sessions/{session_id}",
  "method": "GET",
  "resource_group": "sessions",
  "parameters": [
    {
      "name": "session_id",
      "type": "string",
      "description": "The session/recording ID.",
      "required": true,
      "example": "rec_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/sessions/rec_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rec_abc123",
      "visitor_id": "vis_123",
      "duration": 95000,
      "pages": [
        { "url": "https://example.com", "time_on_page": 30000 },
        { "url": "https://example.com/pricing", "time_on_page": 45000 }
      ],
      "events": [
        { "name": "click_cta", "timestamp": "2024-01-20T10:01:00Z" }
      ],
      "playback_url": "https://app.smartlook.com/recording/rec_abc123"
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
