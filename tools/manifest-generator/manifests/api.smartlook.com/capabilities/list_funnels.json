{
  "name": "list_funnels",
  "description": "List configured funnels with their conversion rates and step-by-step breakdown.",
  "endpoint": "/funnels",
  "method": "GET",
  "parameters": [
    {"name": "limit", "type": "number", "description": "Max results.", "required": false, "example": 10}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.smartlook.com/v2/funnels?limit=10",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": [{"id": "funnel_123", "name": "Signup Flow", "conversion_rate": 25.5, "steps": [{"name": "Landing Page", "count": 1000}, {"name": "Signup Form", "count": 400}, {"name": "Verification", "count": 255}]}]}
  }
}
