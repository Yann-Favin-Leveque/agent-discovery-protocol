{
  "name": "visitors_get",
  "description": "Retrieve detailed information about a specific visitor including properties and session count.",
  "endpoint": "/api/v1/visitors/{visitor_id}",
  "method": "GET",
  "resource_group": "visitors",
  "parameters": [
    {
      "name": "visitor_id",
      "type": "string",
      "description": "The visitor ID.",
      "required": true,
      "example": "vis_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/visitors/vis_123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "vis_123",
      "uid": "user_456",
      "properties": { "name": "John Doe", "email": "john@example.com", "plan": "enterprise" },
      "sessions_count": 42,
      "first_seen": "2024-01-01T00:00:00Z",
      "last_seen": "2024-01-20T10:00:00Z",
      "country": "US"
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
