{
  "name": "get_recording",
  "description": "Get detailed information about a specific session recording including pages, events, and playback URL.",
  "endpoint": "/recordings/{recording_id}",
  "method": "GET",
  "parameters": [
    {"name": "recording_id", "type": "string", "description": "Recording ID.", "required": true, "example": "rec_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.smartlook.com/v2/recordings/rec_abc123",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "rec_abc123", "visitor_id": "vis_123", "duration": 95000, "pages": [{"url": "https://example.com", "time_on_page": 30000}, {"url": "https://example.com/pricing", "time_on_page": 45000}], "events": [{"name": "click_cta", "timestamp": "2024-01-20T10:01:00Z"}], "playback_url": "https://app.smartlook.com/recording/rec_abc123"}
  }
}
