{
  "name": "statistics_get",
  "description": "Retrieve API usage statistics for your project.",
  "endpoint": "/api/v1/statistics",
  "method": "GET",
  "resource_group": "project",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/statistics",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_sessions": 50000,
      "total_visitors": 12000,
      "total_events": 150000,
      "api_calls_today": 250,
      "api_calls_limit": 10000
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
