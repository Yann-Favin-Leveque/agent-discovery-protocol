{
  "name": "get_heatmap",
  "description": "Retrieve heatmap data for a specific page showing click and scroll patterns.",
  "endpoint": "/heatmaps",
  "method": "GET",
  "parameters": [
    {"name": "url", "type": "string", "description": "Page URL to get heatmap for.", "required": true, "example": "https://example.com/pricing"},
    {"name": "type", "type": "string", "description": "Heatmap type: click or scroll.", "required": false, "example": "click"},
    {"name": "from", "type": "string", "description": "Start date.", "required": false, "example": "2024-01-01T00:00:00Z"},
    {"name": "to", "type": "string", "description": "End date.", "required": false, "example": "2024-01-31T23:59:59Z"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.smartlook.com/v2/heatmaps?url=https://example.com/pricing&type=click",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"url": "https://example.com/pricing", "type": "click", "sample_size": 3000, "data_points": [{"x": 450, "y": 320, "weight": 85}, {"x": 600, "y": 500, "weight": 45}]}
  }
}
