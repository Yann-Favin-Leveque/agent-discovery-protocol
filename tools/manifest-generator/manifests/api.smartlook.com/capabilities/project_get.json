{
  "name": "project_get",
  "description": "Retrieve information about the current project including settings and API token details.",
  "endpoint": "/api/v1/me",
  "method": "GET",
  "resource_group": "project",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/me",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "project_id": "proj_abc123",
      "name": "My Web App",
      "created_at": "2024-01-01T00:00:00Z",
      "plan": "business"
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
