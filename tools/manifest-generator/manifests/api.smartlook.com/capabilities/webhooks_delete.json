{
  "name": "webhooks_delete",
  "description": "Delete a webhook and stop receiving notifications.",
  "endpoint": "/api/v1/webhooks/{webhook_id}",
  "method": "DELETE",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "The webhook ID to delete.",
      "required": true,
      "example": "wh_abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.eu.smartlook.cloud/api/v1/webhooks/wh_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": ["write"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
