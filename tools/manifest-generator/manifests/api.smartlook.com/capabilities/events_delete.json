{
  "name": "events_delete",
  "description": "Delete a tracked event definition from Smartlook.",
  "endpoint": "/api/v1/events/{event_id}",
  "method": "DELETE",
  "resource_group": "events",
  "parameters": [
    {
      "name": "event_id",
      "type": "string",
      "description": "The event ID to delete.",
      "required": true,
      "example": "evt_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.eu.smartlook.cloud/api/v1/events/evt_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
