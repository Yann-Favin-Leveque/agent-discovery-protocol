{
  "name": "webhooks_get",
  "description": "Retrieve details of a specific webhook.",
  "endpoint": "/api/v1/webhooks/{webhook_id}",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "The webhook ID.",
      "required": true,
      "example": "wh_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/webhooks/wh_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "wh_abc123",
      "url": "https://example.com/webhooks/smartlook",
      "events": ["session.created", "visitor.identified"],
      "created_at": "2024-01-20T10:00:00Z"
    }
  },
  "auth_scopes": ["read"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
