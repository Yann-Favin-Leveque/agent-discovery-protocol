{
  "name": "funnels_list",
  "description": "List configured funnels with their conversion rates and step-by-step breakdown.",
  "endpoint": "/api/v1/funnels",
  "method": "GET",
  "resource_group": "funnels",
  "parameters": [
    {
      "name": "limit",
      "type": "number",
      "description": "Maximum results to return.",
      "required": false,
      "example": 10,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/funnels?limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "funnel_123",
          "name": "Signup Flow",
          "conversion_rate": 25.5,
          "steps": [
            {
              "name": "Landing Page",
              "count": 1000
            },
            {
              "name": "Signup Form",
              "count": 400
            },
            {
              "name": "Verification",
              "count": 255
            }
          ]
        }
      ]
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
