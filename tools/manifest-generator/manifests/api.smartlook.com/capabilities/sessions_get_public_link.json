{
  "name": "sessions_get_public_link",
  "description": "Generate a shareable public link for a session recording.",
  "endpoint": "/api/v1/sessions/{session_id}/public",
  "method": "GET",
  "resource_group": "sessions",
  "parameters": [
    {
      "name": "session_id",
      "type": "string",
      "description": "The session/recording ID.",
      "required": true,
      "example": "rec_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/sessions/rec_abc123/public",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "public_url": "https://app.smartlook.com/public/recording/rec_abc123?token=xyz"
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
