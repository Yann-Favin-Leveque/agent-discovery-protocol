{
  "name": "visitors_delete",
  "description": "Delete a specific visitor and all associated data from Smartlook.",
  "endpoint": "/api/v1/visitors/{visitor_id}",
  "method": "DELETE",
  "resource_group": "visitors",
  "parameters": [
    {
      "name": "visitor_id",
      "type": "string",
      "description": "The visitor ID to delete.",
      "required": true,
      "example": "vis_123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.eu.smartlook.cloud/api/v1/visitors/vis_123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": ["write"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
