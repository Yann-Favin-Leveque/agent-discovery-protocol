{
  "name": "identify_user",
  "description": "Set identity and custom properties for a visitor in Smartlook for user-level analytics.",
  "endpoint": "/identify",
  "method": "POST",
  "parameters": [
    {"name": "visitor_id", "type": "string", "description": "Smartlook visitor ID.", "required": true, "example": "vis_123"},
    {"name": "uid", "type": "string", "description": "Your internal user ID.", "required": true, "example": "user_456"},
    {"name": "properties", "type": "object", "description": "Custom user properties.", "required": false, "example": {"name": "John Doe", "email": "john@example.com", "plan": "enterprise"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.smartlook.com/v2/identify",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"visitor_id": "vis_123", "uid": "user_456", "properties": {"name": "John Doe", "email": "john@example.com", "plan": "enterprise"}}
  },
  "response_example": {
    "status": 200,
    "body": {"success": true}
  }
}
