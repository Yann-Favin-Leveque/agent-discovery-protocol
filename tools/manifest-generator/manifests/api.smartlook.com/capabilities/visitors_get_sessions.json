{
  "name": "visitors_get_sessions",
  "description": "Retrieve all session recordings for a specific visitor.",
  "endpoint": "/api/v1/visitors/{visitor_id}/sessions",
  "method": "GET",
  "resource_group": "visitors",
  "parameters": [
    {
      "name": "visitor_id",
      "type": "string",
      "description": "The visitor ID.",
      "required": true,
      "example": "vis_123",
      "in": "path"
    },
    {
      "name": "limit",
      "type": "number",
      "description": "Maximum results to return.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.eu.smartlook.cloud/api/v1/visitors/vis_123/sessions?limit=25",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "rec_abc123",
          "duration": 95000,
          "pages_count": 4,
          "started_at": "2024-01-20T10:00:00Z"
        },
        {
          "id": "rec_def456",
          "duration": 45000,
          "pages_count": 2,
          "started_at": "2024-01-19T15:00:00Z"
        }
      ],
      "total_count": 42
    }
  },
  "auth_scopes": [
    "read"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
