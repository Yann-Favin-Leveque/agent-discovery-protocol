{
  "name": "carrier_accounts_list",
  "description": "List all carrier accounts.",
  "endpoint": "/carrier_accounts",
  "method": "GET",
  "resource_group": "carrier_accounts",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "in": "query"
    },
    {
      "name": "results",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/carrier_accounts",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 3,
      "results": [
        {
          "object_id": "carrier_abc123",
          "carrier": "usps",
          "account_id": "12345"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
