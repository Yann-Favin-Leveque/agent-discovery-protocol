{
  "name": "rates_get",
  "description": "Retrieve a specific rate by object ID.",
  "endpoint": "/rates/{rate_id}",
  "method": "GET",
  "resource_group": "rates",
  "parameters": [
    {
      "name": "rate_id",
      "type": "string",
      "description": "Rate object ID.",
      "required": true,
      "example": "rate_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/rates/rate_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "rate_abc123",
      "provider": "USPS",
      "servicelevel": {
        "name": "Priority Mail"
      },
      "amount": "7.58",
      "currency": "USD",
      "estimated_days": 3
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
