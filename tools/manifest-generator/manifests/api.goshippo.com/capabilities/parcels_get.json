{
  "name": "parcels_get",
  "description": "Retrieve a parcel by object ID.",
  "endpoint": "/parcels/{parcel_id}",
  "method": "GET",
  "resource_group": "parcels",
  "parameters": [
    {
      "name": "parcel_id",
      "type": "string",
      "description": "Parcel object ID.",
      "required": true,
      "example": "prcl_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/parcels/prcl_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "prcl_abc123",
      "length": "10.0000",
      "width": "8.0000",
      "height": "4.0000",
      "weight": "2.0000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
