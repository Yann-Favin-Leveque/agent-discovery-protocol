{
  "name": "refunds_get",
  "description": "Retrieve a refund by object ID.",
  "endpoint": "/refunds/{refund_id}",
  "method": "GET",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "refund_id",
      "type": "string",
      "description": "Refund object ID.",
      "required": true,
      "example": "rfnd_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/refunds/rfnd_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "rfnd_abc123",
      "transaction": "txn_abc123",
      "status": "SUCCESS"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
