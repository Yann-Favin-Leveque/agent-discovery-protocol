{
  "name": "batches_purchase",
  "description": "Purchase labels for all valid shipments in a batch.",
  "endpoint": "/batches/{batch_id}/purchase",
  "method": "POST",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "batch_id",
      "type": "string",
      "description": "Batch object ID.",
      "required": true,
      "example": "batch_abc123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.goshippo.com/batches/batch_abc123/purchase",
    "headers": {
      "Authorization": "ShippoToken {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "batch_abc123",
      "status": "PURCHASING"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}