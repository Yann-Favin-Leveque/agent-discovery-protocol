{
  "name": "refunds_list",
  "description": "List all refund requests.",
  "endpoint": "/refunds",
  "method": "GET",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "in": "query"
    },
    {
      "name": "results",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/refunds",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 5,
      "results": [
        {
          "object_id": "rfnd_abc123",
          "status": "SUCCESS"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
