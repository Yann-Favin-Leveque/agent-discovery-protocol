{
  "name": "orders_list",
  "description": "List all orders.",
  "endpoint": "/orders",
  "method": "GET",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "in": "query"
    },
    {
      "name": "results",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/orders",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 20,
      "results": [
        {
          "object_id": "order_abc123",
          "order_number": "ORD-001",
          "order_status": "PAID"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
