{
  "name": "addresses_get",
  "description": "Retrieve an address by object ID.",
  "endpoint": "/addresses/{address_id}",
  "method": "GET",
  "resource_group": "addresses",
  "parameters": [
    {
      "name": "address_id",
      "type": "string",
      "description": "Address object ID.",
      "required": true,
      "example": "adr_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/addresses/adr_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "adr_abc123",
      "name": "John Smith",
      "street1": "417 Montgomery St",
      "is_complete": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}