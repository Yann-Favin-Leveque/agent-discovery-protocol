{
  "name": "transactions_get",
  "description": "Retrieve a transaction (label purchase) by ID.",
  "endpoint": "/transactions/{transaction_id}",
  "method": "GET",
  "resource_group": "transactions",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Transaction object ID.",
      "required": true,
      "example": "txn_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/transactions/txn_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "txn_abc123",
      "object_status": "SUCCESS",
      "tracking_number": "1Z999AA10123456784",
      "label_url": "https://shippo-delivery.s3.amazonaws.com/label.pdf"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
