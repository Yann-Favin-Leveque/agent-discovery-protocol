{
  "name": "carrier_accounts_update",
  "description": "Update a carrier account.",
  "endpoint": "/carrier_accounts/{carrier_account_id}",
  "method": "PUT",
  "resource_group": "carrier_accounts",
  "parameters": [
    {
      "name": "carrier_account_id",
      "type": "string",
      "description": "Carrier account object ID.",
      "required": true,
      "example": "carrier_abc123"
    },
    {
      "name": "parameters",
      "type": "object",
      "description": "Updated carrier credentials.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.goshippo.com/carrier_accounts/carrier_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "parameters": {
        "account_number": "654321"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "carrier_abc123",
      "carrier": "ups",
      "active": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}