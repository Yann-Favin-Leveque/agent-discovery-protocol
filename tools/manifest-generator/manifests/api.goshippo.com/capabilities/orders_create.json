{
  "name": "orders_create",
  "description": "Create a new order to fulfill.",
  "endpoint": "/orders",
  "method": "POST",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "to_address",
      "type": "object",
      "description": "Destination address.",
      "required": true
    },
    {
      "name": "line_items",
      "type": "array",
      "description": "Array of order line items.",
      "required": true
    },
    {
      "name": "order_number",
      "type": "string",
      "description": "Order reference number.",
      "required": false,
      "example": "ORD-001"
    },
    {
      "name": "order_status",
      "type": "string",
      "description": "Order status.",
      "required": false,
      "example": "PAID"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.goshippo.com/orders",
    "headers": {
      "Authorization": "ShippoToken {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "to_address": {
        "name": "John Smith",
        "street1": "417 Montgomery St",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94104",
        "country": "US"
      },
      "line_items": [
        {
          "title": "Widget",
          "quantity": 2,
          "total_price": "25.00",
          "currency": "USD",
          "weight": "0.5",
          "weight_unit": "lb"
        }
      ],
      "order_number": "ORD-001"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "object_id": "order_abc123",
      "order_number": "ORD-001",
      "order_status": "PAID"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}