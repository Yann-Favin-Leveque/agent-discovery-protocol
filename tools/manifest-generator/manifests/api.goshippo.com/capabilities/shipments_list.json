{
  "name": "shipments_list",
  "description": "List all shipments.",
  "endpoint": "/shipments",
  "method": "GET",
  "resource_group": "shipments",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false
    },
    {
      "name": "results",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 25
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/shipments?results=25",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 100,
      "results": [
        {
          "object_id": "shp_abc123",
          "status": "SUCCESS",
          "address_from": {},
          "address_to": {},
          "rates": []
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}