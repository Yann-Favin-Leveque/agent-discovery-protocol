{
  "name": "manifests_get",
  "description": "Retrieve a manifest by object ID.",
  "endpoint": "/manifests/{manifest_id}",
  "method": "GET",
  "resource_group": "manifests",
  "parameters": [
    {
      "name": "manifest_id",
      "type": "string",
      "description": "Manifest object ID.",
      "required": true,
      "example": "mnfst_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/manifests/mnfst_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "mnfst_abc123",
      "status": "SUCCESS",
      "documents": [
        "https://shippo-delivery.s3.amazonaws.com/manifest.pdf"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
