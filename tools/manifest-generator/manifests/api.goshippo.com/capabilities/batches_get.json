{
  "name": "batches_get",
  "description": "Retrieve a batch by object ID.",
  "endpoint": "/batches/{batch_id}",
  "method": "GET",
  "resource_group": "batches",
  "parameters": [
    {
      "name": "batch_id",
      "type": "string",
      "description": "Batch object ID.",
      "required": true,
      "example": "batch_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/batches/batch_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "batch_abc123",
      "status": "VALID",
      "batch_shipments": {
        "count": 50
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
