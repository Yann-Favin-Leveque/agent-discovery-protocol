{
  "name": "addresses_validate",
  "description": "Validate an existing address.",
  "endpoint": "/addresses/{address_id}/validate",
  "method": "GET",
  "resource_group": "addresses",
  "parameters": [
    {
      "name": "address_id",
      "type": "string",
      "description": "Address object ID.",
      "required": true,
      "example": "adr_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/addresses/adr_abc123/validate",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "adr_abc123",
      "validation_results": {
        "is_valid": true,
        "messages": []
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}