{
  "name": "addresses_list",
  "description": "List all address objects in the account.",
  "endpoint": "/addresses",
  "method": "GET",
  "resource_group": "addresses",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "results",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/addresses?results=25",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 50,
      "results": [
        {
          "object_id": "adr_abc123",
          "name": "John Smith",
          "street1": "417 Montgomery St",
          "city": "San Francisco",
          "state": "CA",
          "zip": "94104",
          "country": "US"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
