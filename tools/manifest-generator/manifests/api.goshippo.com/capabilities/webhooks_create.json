{
  "name": "webhooks_create",
  "description": "Create a webhook for event notifications.",
  "endpoint": "/webhooks",
  "method": "POST",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "description": "Webhook destination URL.",
      "required": true,
      "example": "https://example.com/webhook",
      "in": "body"
    },
    {
      "name": "event",
      "type": "string",
      "description": "Event type (track_updated, transaction_created, etc.).",
      "required": true,
      "example": "track_updated",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.goshippo.com/webhooks",
    "headers": {
      "Authorization": "ShippoToken {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://example.com/webhook",
      "event": "track_updated"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "object_id": "wh_abc123",
      "url": "https://example.com/webhook",
      "event": "track_updated",
      "active": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
