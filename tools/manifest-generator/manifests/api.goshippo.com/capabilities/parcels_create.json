{
  "name": "parcels_create",
  "description": "Create a parcel with dimensions and weight.",
  "endpoint": "/parcels",
  "method": "POST",
  "resource_group": "parcels",
  "parameters": [
    {
      "name": "length",
      "type": "string",
      "description": "Length.",
      "required": true,
      "example": "10"
    },
    {
      "name": "width",
      "type": "string",
      "description": "Width.",
      "required": true,
      "example": "8"
    },
    {
      "name": "height",
      "type": "string",
      "description": "Height.",
      "required": true,
      "example": "4"
    },
    {
      "name": "distance_unit",
      "type": "string",
      "description": "Unit: in, cm, ft, mm.",
      "required": true,
      "example": "in"
    },
    {
      "name": "weight",
      "type": "string",
      "description": "Weight.",
      "required": true,
      "example": "2"
    },
    {
      "name": "mass_unit",
      "type": "string",
      "description": "Unit: lb, oz, g, kg.",
      "required": true,
      "example": "lb"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.goshippo.com/parcels",
    "headers": {
      "Authorization": "ShippoToken {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "length": "10",
      "width": "8",
      "height": "4",
      "distance_unit": "in",
      "weight": "2",
      "mass_unit": "lb"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "object_id": "prcl_abc123",
      "length": "10.0000",
      "width": "8.0000",
      "height": "4.0000",
      "weight": "2.0000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}