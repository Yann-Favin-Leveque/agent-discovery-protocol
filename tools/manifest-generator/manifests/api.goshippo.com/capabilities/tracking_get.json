{
  "name": "tracking_get",
  "description": "Get tracking status for a shipment.",
  "endpoint": "/tracks/{carrier}/{tracking_number}",
  "method": "GET",
  "resource_group": "tracking",
  "parameters": [
    {
      "name": "carrier",
      "type": "string",
      "description": "Carrier token (e.g., usps, ups, fedex).",
      "required": true,
      "example": "usps",
      "in": "path"
    },
    {
      "name": "tracking_number",
      "type": "string",
      "description": "Tracking number.",
      "required": true,
      "example": "1Z999AA10123456784",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/tracks/usps/1Z999AA10123456784",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tracking_number": "1Z999AA10123456784",
      "carrier": "usps",
      "tracking_status": {
        "status": "TRANSIT",
        "status_details": "In transit"
      },
      "tracking_history": []
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
