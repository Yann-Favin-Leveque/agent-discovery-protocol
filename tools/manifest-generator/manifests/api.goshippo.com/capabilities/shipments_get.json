{
  "name": "shipments_get",
  "description": "Retrieve a shipment by object ID.",
  "endpoint": "/shipments/{shipment_id}",
  "method": "GET",
  "resource_group": "shipments",
  "parameters": [
    {
      "name": "shipment_id",
      "type": "string",
      "description": "Shipment object ID.",
      "required": true,
      "example": "shp_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/shipments/shp_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "shp_abc123",
      "status": "SUCCESS",
      "rates": []
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
