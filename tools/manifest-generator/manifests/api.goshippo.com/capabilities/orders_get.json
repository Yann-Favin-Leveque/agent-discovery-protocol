{
  "name": "orders_get",
  "description": "Retrieve an order by object ID.",
  "endpoint": "/orders/{order_id}",
  "method": "GET",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "order_id",
      "type": "string",
      "description": "Order object ID.",
      "required": true,
      "example": "order_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.goshippo.com/orders/order_abc123",
    "headers": {
      "Authorization": "ShippoToken {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object_id": "order_abc123",
      "order_number": "ORD-001",
      "order_status": "PAID"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
