{
  "name": "payment_intents_get",
  "description": "Retrieve a PaymentIntent by ID.",
  "endpoint": "/v1/payment_intents/{id}",
  "method": "GET",
  "resource_group": "payment_intents",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "PaymentIntent ID",
      "required": true,
      "example": "pi_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/payment_intents/pi_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pi_abc123",
      "object": "payment_intent",
      "amount": 2000,
      "status": "succeeded"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}