{
  "name": "customers_delete",
  "description": "Delete a customer and cancel all active subscriptions.",
  "endpoint": "/v1/customers/{id}",
  "method": "DELETE",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Customer ID",
      "required": true,
      "example": "cus_abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.stripe.com/v1/customers/cus_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cus_abc123",
      "object": "customer",
      "deleted": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}