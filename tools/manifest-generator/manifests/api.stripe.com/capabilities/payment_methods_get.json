{
  "name": "payment_methods_get",
  "description": "Retrieve a PaymentMethod by ID.",
  "endpoint": "/v1/payment_methods/{id}",
  "method": "GET",
  "resource_group": "payment_methods",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "PaymentMethod ID",
      "required": true,
      "example": "pm_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/payment_methods/pm_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pm_abc123",
      "type": "card",
      "card": {
        "brand": "visa",
        "last4": "4242"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}