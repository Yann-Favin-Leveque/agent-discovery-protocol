{
  "name": "invoices_create",
  "description": "Create a draft invoice for a customer.",
  "endpoint": "/v1/invoices",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "customer",
      "type": "string",
      "description": "Customer ID",
      "required": true,
      "example": "cus_abc123"
    },
    {
      "name": "auto_advance",
      "type": "boolean",
      "description": "Auto-finalize after creation",
      "required": false,
      "example": true
    },
    {
      "name": "collection_method",
      "type": "string",
      "description": "charge_automatically or send_invoice",
      "required": false,
      "example": "send_invoice"
    },
    {
      "name": "days_until_due",
      "type": "integer",
      "description": "Days until invoice is due",
      "required": false,
      "example": 30
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stripe.com/v1/invoices",
    "headers": {
      "Authorization": "Bearer sk_test_xxx",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": "customer=cus_abc123&collection_method=send_invoice&days_until_due=30"
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "in_abc123",
      "object": "invoice",
      "status": "draft",
      "customer": "cus_abc123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}