{
  "name": "checkout_sessions_get",
  "description": "Retrieve a Checkout Session by ID.",
  "endpoint": "/v1/checkout/sessions/{id}",
  "method": "GET",
  "resource_group": "checkout_sessions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Checkout Session ID",
      "required": true,
      "example": "cs_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/checkout/sessions/cs_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cs_abc123",
      "payment_status": "paid",
      "customer": "cus_abc123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}