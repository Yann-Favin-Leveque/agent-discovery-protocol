{
  "name": "refunds_get",
  "description": "Retrieve a refund by ID.",
  "endpoint": "/v1/refunds/{id}",
  "method": "GET",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Refund ID",
      "required": true,
      "example": "re_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/refunds/re_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "re_abc123",
      "amount": 1000,
      "status": "succeeded"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}