{
  "name": "subscriptions_list",
  "description": "List subscriptions with optional customer or status filter.",
  "endpoint": "/v1/subscriptions",
  "method": "GET",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "customer",
      "type": "string",
      "description": "Filter by customer",
      "required": false,
      "example": "cus_abc123",
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status: active, past_due, canceled, etc.",
      "required": false,
      "example": "active",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results",
      "required": false,
      "example": 10,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/subscriptions?customer=cus_abc123&status=active",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "list",
      "data": [
        {
          "id": "sub_abc123",
          "status": "active"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
