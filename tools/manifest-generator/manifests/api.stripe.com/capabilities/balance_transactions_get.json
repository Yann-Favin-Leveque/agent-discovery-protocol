{
  "name": "balance_transactions_get",
  "description": "Retrieve a specific balance transaction.",
  "endpoint": "/v1/balance_transactions/{id}",
  "method": "GET",
  "resource_group": "balance",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Balance transaction ID",
      "required": true,
      "example": "txn_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/balance_transactions/txn_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "txn_abc123",
      "amount": 2000,
      "type": "charge",
      "net": 1942
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}