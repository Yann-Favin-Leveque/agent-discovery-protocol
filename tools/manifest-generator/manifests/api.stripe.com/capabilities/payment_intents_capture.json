{
  "name": "payment_intents_capture",
  "description": "Capture a previously authorized PaymentIntent.",
  "endpoint": "/v1/payment_intents/{id}/capture",
  "method": "POST",
  "resource_group": "payment_intents",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "PaymentIntent ID",
      "required": true,
      "example": "pi_abc123"
    },
    {
      "name": "amount_to_capture",
      "type": "integer",
      "description": "Amount to capture (partial capture)",
      "required": false,
      "example": 1500
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stripe.com/v1/payment_intents/pi_abc123/capture",
    "headers": {
      "Authorization": "Bearer sk_test_xxx",
      "Content-Type": "application/x-www-form-urlencoded"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pi_abc123",
      "status": "succeeded",
      "amount_captured": 2000
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}