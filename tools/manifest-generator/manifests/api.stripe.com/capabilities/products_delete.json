{
  "name": "products_delete",
  "description": "Delete a product (must have no active prices).",
  "endpoint": "/v1/products/{id}",
  "method": "DELETE",
  "resource_group": "products",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Product ID",
      "required": true,
      "example": "prod_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.stripe.com/v1/products/prod_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "prod_abc123",
      "deleted": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
