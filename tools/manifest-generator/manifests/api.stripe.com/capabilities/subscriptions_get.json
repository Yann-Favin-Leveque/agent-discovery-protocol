{
  "name": "subscriptions_get",
  "description": "Retrieve a subscription by ID.",
  "endpoint": "/v1/subscriptions/{id}",
  "method": "GET",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID",
      "required": true,
      "example": "sub_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/subscriptions/sub_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sub_abc123",
      "status": "active",
      "customer": "cus_abc123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}