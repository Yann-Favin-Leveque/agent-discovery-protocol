{
  "name": "charges_get",
  "description": "Retrieve a charge by ID.",
  "endpoint": "/v1/charges/{id}",
  "method": "GET",
  "resource_group": "charges",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Charge ID",
      "required": true,
      "example": "ch_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/charges/ch_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ch_abc123",
      "amount": 2000,
      "currency": "usd",
      "status": "succeeded"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}