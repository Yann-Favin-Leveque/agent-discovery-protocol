{
  "name": "prices_get",
  "description": "Retrieve a price by ID.",
  "endpoint": "/v1/prices/{id}",
  "method": "GET",
  "resource_group": "prices",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Price ID",
      "required": true,
      "example": "price_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/prices/price_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "price_abc123",
      "unit_amount": 2000,
      "currency": "usd"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}