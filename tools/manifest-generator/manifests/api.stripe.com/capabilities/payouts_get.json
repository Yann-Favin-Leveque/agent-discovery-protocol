{
  "name": "payouts_get",
  "description": "Retrieve a payout by ID.",
  "endpoint": "/v1/payouts/{id}",
  "method": "GET",
  "resource_group": "payouts",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payout ID",
      "required": true,
      "example": "po_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/payouts/po_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "po_abc123",
      "amount": 10000,
      "status": "paid"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
