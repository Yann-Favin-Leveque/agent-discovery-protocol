{
  "name": "customers_get",
  "description": "Retrieve a customer by ID.",
  "endpoint": "/v1/customers/{id}",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Customer ID",
      "required": true,
      "example": "cus_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/customers/cus_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cus_abc123",
      "email": "john@example.com",
      "name": "John Doe"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
