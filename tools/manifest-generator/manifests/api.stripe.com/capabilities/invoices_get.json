{
  "name": "invoices_get",
  "description": "Retrieve an invoice by ID.",
  "endpoint": "/v1/invoices/{id}",
  "method": "GET",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "in_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/invoices/in_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "in_abc123",
      "status": "open",
      "amount_due": 2000,
      "customer": "cus_abc123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}