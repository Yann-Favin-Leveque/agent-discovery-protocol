{
  "name": "invoices_finalize",
  "description": "Finalize a draft invoice so it can be paid.",
  "endpoint": "/v1/invoices/{id}/finalize",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "in_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stripe.com/v1/invoices/in_abc123/finalize",
    "headers": {
      "Authorization": "Bearer sk_test_xxx",
      "Content-Type": "application/x-www-form-urlencoded"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "in_abc123",
      "status": "open"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
