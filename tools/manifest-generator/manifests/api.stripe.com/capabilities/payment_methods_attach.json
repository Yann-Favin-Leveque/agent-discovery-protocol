{
  "name": "payment_methods_attach",
  "description": "Attach a PaymentMethod to a Customer.",
  "endpoint": "/v1/payment_methods/{id}/attach",
  "method": "POST",
  "resource_group": "payment_methods",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "PaymentMethod ID",
      "required": true,
      "example": "pm_abc123",
      "in": "path"
    },
    {
      "name": "customer",
      "type": "string",
      "description": "Customer ID to attach to",
      "required": true,
      "example": "cus_abc123",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stripe.com/v1/payment_methods/pm_abc123/attach",
    "headers": {
      "Authorization": "Bearer sk_test_xxx",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": "customer=cus_abc123"
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pm_abc123",
      "customer": "cus_abc123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
