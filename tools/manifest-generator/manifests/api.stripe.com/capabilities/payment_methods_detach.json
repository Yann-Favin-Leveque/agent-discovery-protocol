{
  "name": "payment_methods_detach",
  "description": "Detach a PaymentMethod from a Customer.",
  "endpoint": "/v1/payment_methods/{id}/detach",
  "method": "POST",
  "resource_group": "payment_methods",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "PaymentMethod ID",
      "required": true,
      "example": "pm_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stripe.com/v1/payment_methods/pm_abc123/detach",
    "headers": {
      "Authorization": "Bearer sk_test_xxx",
      "Content-Type": "application/x-www-form-urlencoded"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pm_abc123",
      "customer": null
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
