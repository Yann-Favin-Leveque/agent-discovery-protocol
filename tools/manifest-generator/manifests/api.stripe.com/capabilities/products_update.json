{
  "name": "products_update",
  "description": "Update a product's name, description, or metadata.",
  "endpoint": "/v1/products/{id}",
  "method": "POST",
  "resource_group": "products",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Product ID",
      "required": true,
      "example": "prod_abc123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name",
      "required": false,
      "example": "Enterprise Plan",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stripe.com/v1/products/prod_abc123",
    "headers": {
      "Authorization": "Bearer sk_test_xxx",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": "name=Enterprise Plan"
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "prod_abc123",
      "name": "Enterprise Plan"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
