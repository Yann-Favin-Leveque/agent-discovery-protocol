{
  "name": "products_list",
  "description": "List all products.",
  "endpoint": "/v1/products",
  "method": "GET",
  "resource_group": "products",
  "parameters": [
    {
      "name": "active",
      "type": "boolean",
      "description": "Filter by active status",
      "required": false,
      "example": true,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results",
      "required": false,
      "example": 10,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.stripe.com/v1/products?active=true",
    "headers": {
      "Authorization": "Bearer sk_test_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "list",
      "data": [
        {
          "id": "prod_abc123",
          "name": "Pro Plan"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
