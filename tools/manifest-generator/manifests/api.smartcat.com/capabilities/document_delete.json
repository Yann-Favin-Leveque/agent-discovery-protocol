{
  "name": "document_delete",
  "description": "Delete one or more documents from a project.",
  "resource_group": "documents",
  "endpoint": "/api/integration/v1/document",
  "method": "DELETE",
  "parameters": [
    {
      "name": "documentIds",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Comma-separated document IDs in format 'docId_languageId'."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://smartcat.com/api/integration/v1/document?documentIds=doc-uuid-456_fr,doc-uuid-456_de",
    "headers": {
      "Authorization": "Basic {base64(accountId:apiKey)}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
