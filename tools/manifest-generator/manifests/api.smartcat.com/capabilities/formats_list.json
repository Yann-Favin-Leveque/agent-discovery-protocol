{
  "name": "formats_list",
  "description": "List all supported file formats for document translation (280+ formats including Office, JSON, HTML, XLIFF, etc.).",
  "resource_group": "directory",
  "endpoint": "/api/integration/v1/directory/formats",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://smartcat.com/api/integration/v1/directory/formats",
    "headers": {
      "Authorization": "Basic {base64(accountId:apiKey)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      { "extension": ".docx", "name": "Microsoft Word" },
      { "extension": ".json", "name": "JSON" },
      { "extension": ".xliff", "name": "XLIFF" },
      { "extension": ".html", "name": "HTML" },
      { "extension": ".po", "name": "Gettext PO" }
    ]
  }
}
