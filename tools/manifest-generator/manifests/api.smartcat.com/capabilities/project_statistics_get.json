{
  "name": "project_statistics_get",
  "description": "Get word count and translation memory match statistics for a project, including exact matches, fuzzy matches, and new words.",
  "resource_group": "projects",
  "endpoint": "/api/integration/v1/project/{projectId}/statistics",
  "method": "GET",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The unique project ID.",
      "in": "path"
    },
    {
      "name": "onlyExactMatches",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "If true, return only exact match statistics.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://smartcat.com/api/integration/v1/project/project-uuid-123/statistics?onlyExactMatches=false",
    "headers": {
      "Authorization": "Basic {base64(accountId:apiKey)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "statistics": [
        {
          "language": "fr",
          "totalWords": 5000,
          "exactMatches": 1200,
          "fuzzyMatches": 800,
          "newWords": 3000
        }
      ]
    }
  }
}
