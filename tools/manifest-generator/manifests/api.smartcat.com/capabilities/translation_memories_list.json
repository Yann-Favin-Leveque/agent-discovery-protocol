{
  "name": "translation_memories_list",
  "description": "List all translation memories available in the account for reuse across projects.",
  "resource_group": "translation_memories",
  "endpoint": "/api/integration/v1/translationmemory",
  "method": "GET",
  "parameters": [
    {
      "name": "batchSize",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Number of translation memories to return per batch.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://smartcat.com/api/integration/v1/translationmemory?batchSize=50",
    "headers": {
      "Authorization": "Basic {base64(accountId:apiKey)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "tm-uuid-123",
        "name": "General EN-FR TM",
        "sourceLanguage": "en",
        "targetLanguage": "fr",
        "segmentCount": 15000,
        "createdAt": "2026-01-15T10:00:00.000Z"
      }
    ]
  }
}
