{
  "name": "project_complete",
  "description": "Mark a translation project as complete. This finalizes the project status.",
  "resource_group": "projects",
  "endpoint": "/api/integration/v1/project/complete",
  "method": "POST",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "The unique project ID to mark as complete.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://smartcat.com/api/integration/v1/project/complete?projectId=project-uuid-123",
    "headers": {
      "Authorization": "Basic {base64(accountId:apiKey)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "project-uuid-123",
      "status": "completed"
    }
  }
}
