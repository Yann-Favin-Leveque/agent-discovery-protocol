{
  "name": "project_translation_memories_get",
  "description": "Get translation memories attached to a specific project.",
  "resource_group": "translation_memories",
  "endpoint": "/api/integration/v1/project/{project_id}/translationmemories",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The unique project ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://smartcat.com/api/integration/v1/project/project-uuid-123/translationmemories",
    "headers": {
      "Authorization": "Basic {base64(accountId:apiKey)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "tm-uuid-123",
        "matchThreshold": 75,
        "isWritable": true
      }
    ]
  }
}
