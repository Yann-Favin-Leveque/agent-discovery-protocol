{
  "name": "pipelines_stop",
  "description": "Stop a running pipeline.",
  "resource_group": "pipelines",
  "endpoint": "/repositories/{workspace}/{repo_slug}/pipelines/{pipeline_uuid}/stopPipeline",
  "method": "POST",
  "parameters": [
    {
      "name": "workspace",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Workspace.",
      "in": "path"
    },
    {
      "name": "repo_slug",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repo slug.",
      "in": "path"
    },
    {
      "name": "pipeline_uuid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Pipeline UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bitbucket.org/2.0/repositories/myworkspace/my-project/pipelines/{uuid}/stopPipeline",
    "headers": {
      "Authorization": "Bearer oauth-token"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
