{
  "name": "repos_get",
  "description": "Get a specific repository.",
  "resource_group": "repositories",
  "endpoint": "/repositories/{workspace}/{repo_slug}",
  "method": "GET",
  "parameters": [
    {
      "name": "workspace",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Workspace.",
      "in": "path"
    },
    {
      "name": "repo_slug",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repo slug.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bitbucket.org/2.0/repositories/myworkspace/my-project",
    "headers": {
      "Authorization": "Bearer oauth-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "slug": "my-project",
      "full_name": "myworkspace/my-project",
      "is_private": true,
      "mainbranch": {
        "name": "main"
      }
    }
  }
}
