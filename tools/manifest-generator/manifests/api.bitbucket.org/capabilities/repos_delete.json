{
  "name": "repos_delete",
  "description": "Delete a repository.",
  "resource_group": "repositories",
  "endpoint": "/repositories/{workspace}/{repo_slug}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "workspace",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Workspace."
    },
    {
      "name": "repo_slug",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repo slug."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.bitbucket.org/2.0/repositories/myworkspace/old-project",
    "headers": {
      "Authorization": "Bearer oauth-token"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}