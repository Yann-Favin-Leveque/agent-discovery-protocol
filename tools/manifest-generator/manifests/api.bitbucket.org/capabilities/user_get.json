{
  "name": "user_get",
  "description": "Get the current authenticated user.",
  "resource_group": "users",
  "endpoint": "/user",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.bitbucket.org/2.0/user",
    "headers": {
      "Authorization": "Bearer oauth-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "display_name": "Jane Doe",
      "username": "janedoe",
      "uuid": "{user-uuid}",
      "account_id": "12345"
    }
  }
}