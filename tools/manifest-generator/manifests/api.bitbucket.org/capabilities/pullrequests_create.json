{
  "name": "pullrequests_create",
  "description": "Create a new pull request.",
  "resource_group": "pull_requests",
  "endpoint": "/repositories/{workspace}/{repo_slug}/pullrequests",
  "method": "POST",
  "parameters": [
    {
      "name": "workspace",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Workspace.",
      "in": "path"
    },
    {
      "name": "repo_slug",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repo slug.",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "PR title.",
      "in": "body"
    },
    {
      "name": "source",
      "type": "object",
      "required": true,
      "description": "Source: {branch: {name: 'feature-branch'}}.",
      "in": "body"
    },
    {
      "name": "destination",
      "type": "object",
      "required": false,
      "description": "Destination: {branch: {name: 'main'}}.",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "PR description.",
      "in": "body"
    },
    {
      "name": "close_source_branch",
      "type": "boolean",
      "required": false,
      "description": "Delete source branch after merge.",
      "in": "body"
    },
    {
      "name": "reviewers",
      "type": "array",
      "required": false,
      "description": "Reviewer objects.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bitbucket.org/2.0/repositories/myworkspace/my-project/pullrequests",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer oauth-token"
    },
    "body": {
      "title": "Add dark mode",
      "source": {
        "branch": {
          "name": "feature/dark-mode"
        }
      },
      "destination": {
        "branch": {
          "name": "main"
        }
      },
      "close_source_branch": true
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2,
      "title": "Add dark mode",
      "state": "OPEN"
    }
  }
}
