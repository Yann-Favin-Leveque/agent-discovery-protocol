{
  "spec_version": "1.0",
  "name": "Bitbucket Cloud REST API",
  "description": "Bitbucket Cloud provides Git repository hosting, pull requests, pipelines CI/CD, and team collaboration. Use this API to manage repositories, branches, pull requests, issues, pipelines, and workspaces.",
  "base_url": "https://api.bitbucket.org/2.0",
  "auth": {
    "type": "oauth2",
    "authorization_url": "https://bitbucket.org/site/oauth2/authorize",
    "token_url": "https://bitbucket.org/site/oauth2/access_token",
    "scopes": [
      "repository",
      "repository:write",
      "repository:admin",
      "pullrequest",
      "pullrequest:write",
      "pipeline",
      "pipeline:write",
      "account",
      "email",
      "team"
    ]
  },
  "capabilities": [
    {
      "name": "repos_list",
      "resource_group": "repositories",
      "description": "List repositories for a workspace.",
      "detail_url": "/capabilities/repos_list"
    },
    {
      "name": "repos_get",
      "resource_group": "repositories",
      "description": "Get a specific repository.",
      "detail_url": "/capabilities/repos_get"
    },
    {
      "name": "repos_create",
      "resource_group": "repositories",
      "description": "Create a new repository.",
      "detail_url": "/capabilities/repos_create"
    },
    {
      "name": "repos_delete",
      "resource_group": "repositories",
      "description": "Delete a repository.",
      "detail_url": "/capabilities/repos_delete"
    },
    {
      "name": "pullrequests_list",
      "resource_group": "pull_requests",
      "description": "List pull requests for a repository.",
      "detail_url": "/capabilities/pullrequests_list"
    },
    {
      "name": "pullrequests_get",
      "resource_group": "pull_requests",
      "description": "Get a specific pull request.",
      "detail_url": "/capabilities/pullrequests_get"
    },
    {
      "name": "pullrequests_create",
      "resource_group": "pull_requests",
      "description": "Create a new pull request.",
      "detail_url": "/capabilities/pullrequests_create"
    },
    {
      "name": "pullrequests_merge",
      "resource_group": "pull_requests",
      "description": "Merge a pull request.",
      "detail_url": "/capabilities/pullrequests_merge"
    },
    {
      "name": "pullrequests_approve",
      "resource_group": "pull_requests",
      "description": "Approve a pull request.",
      "detail_url": "/capabilities/pullrequests_approve"
    },
    {
      "name": "pullrequests_decline",
      "resource_group": "pull_requests",
      "description": "Decline a pull request.",
      "detail_url": "/capabilities/pullrequests_decline"
    },
    {
      "name": "pipelines_list",
      "resource_group": "pipelines",
      "description": "List pipelines for a repository.",
      "detail_url": "/capabilities/pipelines_list"
    },
    {
      "name": "pipelines_create",
      "resource_group": "pipelines",
      "description": "Trigger a new pipeline run.",
      "detail_url": "/capabilities/pipelines_create"
    },
    {
      "name": "pipelines_stop",
      "resource_group": "pipelines",
      "description": "Stop a running pipeline.",
      "detail_url": "/capabilities/pipelines_stop"
    },
    {
      "name": "branches_list",
      "resource_group": "branches",
      "description": "List branches in a repository.",
      "detail_url": "/capabilities/branches_list"
    },
    {
      "name": "commits_list",
      "resource_group": "commits",
      "description": "List commits for a repository.",
      "detail_url": "/capabilities/commits_list"
    },
    {
      "name": "user_get",
      "resource_group": "users",
      "description": "Get the current authenticated user.",
      "detail_url": "/capabilities/user_get"
    }
  ]
}