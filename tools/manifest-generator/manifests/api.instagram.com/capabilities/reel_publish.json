{
  "name": "reel_publish",
  "resource_group": "publishing",
  "description": "Create a media container for a reel (short video) to be published to the authenticated user's Instagram feed.",
  "endpoint": "/{user_id}/media",
  "method": "POST",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "The Instagram user ID.",
      "required": true,
      "in": "path",
      "example": "17841400000000000"
    },
    {
      "name": "video_url",
      "type": "string",
      "description": "The public URL of the video file.",
      "required": true,
      "in": "body",
      "example": "https://example.com/reel.mp4"
    },
    {
      "name": "media_type",
      "type": "string",
      "description": "Must be set to REELS for reel publishing.",
      "required": true,
      "in": "body",
      "example": "REELS"
    },
    {
      "name": "caption",
      "type": "string",
      "description": "The caption for the reel.",
      "required": false,
      "in": "body",
      "example": "Check out this video! #reels"
    },
    {
      "name": "share_to_feed",
      "type": "boolean",
      "description": "Whether to also share the reel to the main feed.",
      "required": false,
      "in": "body",
      "example": true
    },
    {
      "name": "cover_url",
      "type": "string",
      "description": "Public URL of the cover image for the reel.",
      "required": false,
      "in": "body",
      "example": "https://example.com/cover.jpg"
    },
    {
      "name": "thumb_offset",
      "type": "integer",
      "description": "Offset in milliseconds for the cover image thumbnail.",
      "required": false,
      "in": "body",
      "example": 2000
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v21.0/17841400000000000/media",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "video_url": "https://example.com/reel.mp4",
      "media_type": "REELS",
      "caption": "Check out this video! #reels",
      "share_to_feed": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "17854360000000004"
    }
  },
  "auth_scopes": ["instagram_content_publish"]
}
