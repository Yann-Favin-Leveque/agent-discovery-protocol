{
  "name": "comment_delete",
  "resource_group": "comments",
  "description": "Delete a comment on one of the authenticated user's media posts.",
  "endpoint": "/{comment_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "comment_id",
      "type": "string",
      "description": "The ID of the comment to delete.",
      "required": true,
      "in": "path",
      "example": "17858890000000000"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://graph.facebook.com/v21.0/17858890000000000",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  },
  "auth_scopes": ["instagram_manage_comments"]
}
