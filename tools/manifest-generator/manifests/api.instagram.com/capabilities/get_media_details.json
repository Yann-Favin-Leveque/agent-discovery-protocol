{
  "name": "get_media_details",
  "description": "Retrieve detailed information about a specific Instagram media object including its caption, media type (IMAGE, VIDEO, CAROUSEL_ALBUM), permalink, thumbnail URL, and timestamp.",
  "endpoint": "/v18.0/{media_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "media_id",
      "type": "string",
      "description": "The unique identifier of the media object.",
      "required": true,
      "example": "17854360123456789"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields to return for the media object.",
      "required": false,
      "example": "id,caption,media_type,media_url,permalink,thumbnail_url,timestamp,like_count,comments_count"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.facebook.com/v18.0/17854360123456789?fields=id,caption,media_type,media_url,permalink,timestamp,like_count,comments_count&access_token={access_token}",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "17854360123456789",
      "caption": "Beautiful sunset at the beach #nature",
      "media_type": "IMAGE",
      "media_url": "https://scontent.cdninstagram.com/v/t51.2885-15/photo.jpg",
      "permalink": "https://www.instagram.com/p/ABC123/",
      "timestamp": "2024-03-01T18:30:00+0000",
      "like_count": 342,
      "comments_count": 18
    }
  }
}
