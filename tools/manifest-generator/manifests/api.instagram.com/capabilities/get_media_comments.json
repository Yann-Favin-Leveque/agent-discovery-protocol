{
  "name": "get_media_comments",
  "description": "Retrieve a paginated list of comments on a specific media post. Returns each comment's text, username of the commenter, timestamp, and like count.",
  "endpoint": "/v18.0/{media_id}/comments",
  "method": "GET",
  "parameters": [
    {
      "name": "media_id",
      "type": "string",
      "description": "The unique identifier of the media object to get comments for.",
      "required": true,
      "example": "17854360123456789"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of comment fields to return.",
      "required": false,
      "example": "id,text,username,timestamp,like_count,replies"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of comments to return per page.",
      "required": false,
      "example": 25
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.facebook.com/v18.0/17854360123456789/comments?fields=id,text,username,timestamp,like_count&limit=25&access_token={access_token}",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "17858893123456789",
          "text": "Stunning photo! Where was this taken?",
          "username": "traveler99",
          "timestamp": "2024-03-01T19:15:00+0000",
          "like_count": 5
        },
        {
          "id": "17858893987654321",
          "text": "Love the colors!",
          "username": "photofan",
          "timestamp": "2024-03-01T20:00:00+0000",
          "like_count": 2
        }
      ],
      "paging": {
        "cursors": {
          "before": "QVFIUkF...",
          "after": "QVFIUmR..."
        }
      }
    }
  }
}
