{
  "name": "get_user_profile",
  "description": "Retrieve the authenticated Instagram user's profile information including username, bio, account type, follower count, following count, and total media count. Uses the Instagram Graph API via Facebook's graph endpoint.",
  "endpoint": "/v18.0/me",
  "method": "GET",
  "parameters": [
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of profile fields to return.",
      "required": false,
      "example": "id,username,name,biography,followers_count,follows_count,media_count,profile_picture_url,website"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.facebook.com/v18.0/me?fields=id,username,name,biography,followers_count,follows_count,media_count,profile_picture_url,website&access_token={access_token}",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "17841400123456789",
      "username": "myaccount",
      "name": "My Account",
      "biography": "Official account for demonstrations.",
      "followers_count": 15420,
      "follows_count": 342,
      "media_count": 287,
      "profile_picture_url": "https://scontent.cdninstagram.com/v/t51.2885-19/photo.jpg",
      "website": "https://example.com"
    }
  }
}
