{
  "name": "image_edit_inpaint",
  "description": "Edit specific regions of an image by providing a mask and a text prompt describing what to generate in the masked area.",
  "resource_group": "edit",
  "endpoint": "/v2beta/stable-image/edit/inpaint",
  "method": "POST",
  "parameters": [
    {
      "name": "image",
      "type": "file",
      "required": true,
      "description": "The source image.",
      "in": "body"
    },
    {
      "name": "mask",
      "type": "file",
      "required": true,
      "description": "Mask indicating areas to inpaint (white = edit).",
      "in": "body"
    },
    {
      "name": "prompt",
      "type": "string",
      "required": true,
      "description": "Description of what to generate in the masked area.",
      "in": "body"
    },
    {
      "name": "negative_prompt",
      "type": "string",
      "required": false,
      "description": "What to exclude.",
      "in": "body"
    },
    {
      "name": "output_format",
      "type": "string",
      "required": false,
      "description": "Output format.",
      "in": "body"
    },
    {
      "name": "seed",
      "type": "integer",
      "required": false,
      "description": "Random seed.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stability.ai/v2beta/stable-image/edit/inpaint",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "Accept": "image/*"
    },
    "body": "multipart/form-data: image=@photo.jpg&mask=@mask.png&prompt='A golden retriever sitting'"
  },
  "response_example": {
    "status": 200,
    "body": "Binary edited image content"
  }
}
