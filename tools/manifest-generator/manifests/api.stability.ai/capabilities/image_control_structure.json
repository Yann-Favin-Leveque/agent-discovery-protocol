{
  "name": "image_control_structure",
  "description": "Generate images that follow the structural composition of a reference image.",
  "resource_group": "control",
  "endpoint": "/v2beta/stable-image/control/structure",
  "method": "POST",
  "parameters": [
    {"name": "image", "type": "file", "required": true, "description": "Reference image for structural guidance."},
    {"name": "prompt", "type": "string", "required": true, "description": "Description of the desired output."},
    {"name": "negative_prompt", "type": "string", "required": false, "description": "What to exclude."},
    {"name": "control_strength", "type": "number", "required": false, "description": "How closely to follow the structure (0.0-1.0)."},
    {"name": "output_format", "type": "string", "required": false, "description": "Output format."},
    {"name": "seed", "type": "integer", "required": false, "description": "Random seed."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stability.ai/v2beta/stable-image/control/structure",
    "headers": {"Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx", "Accept": "image/*"},
    "body": "multipart/form-data: image=@reference.jpg&prompt='A watercolor painting'&control_strength=0.8"
  },
  "response_example": {"status": 200, "body": "Binary generated image content"}
}
