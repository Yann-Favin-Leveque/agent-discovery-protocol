{
  "name": "image_upscale_creative",
  "description": "Upscale an image with creative enhancement that adds AI-generated detail. Returns a generation ID for async result retrieval.",
  "resource_group": "upscale",
  "endpoint": "/v2beta/stable-image/upscale/creative",
  "method": "POST",
  "parameters": [
    {
      "name": "image",
      "type": "file",
      "required": true,
      "description": "The image to upscale.",
      "in": "body"
    },
    {
      "name": "prompt",
      "type": "string",
      "required": true,
      "description": "Description to guide creative upscaling.",
      "in": "body"
    },
    {
      "name": "output_format",
      "type": "string",
      "required": false,
      "description": "Output format.",
      "in": "body"
    },
    {
      "name": "creativity",
      "type": "number",
      "required": false,
      "description": "Creativity level (0.0-0.35).",
      "in": "body"
    },
    {
      "name": "seed",
      "type": "integer",
      "required": false,
      "description": "Random seed.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.stability.ai/v2beta/stable-image/upscale/creative",
    "headers": {
      "Authorization": "Bearer sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    },
    "body": "multipart/form-data: image=@photo.jpg&prompt='Enhanced landscape'"
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "gen-abc123"
    }
  }
}
