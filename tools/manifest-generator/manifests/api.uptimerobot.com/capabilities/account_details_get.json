{
  "name": "account_details_get",
  "description": "Retrieve account information including plan type, monitor limits, monitor interval, and usage statistics.",
  "resource_group": "account",
  "endpoint": "/v2/getAccountDetails",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Your UptimeRobot API key.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uptimerobot.com/v2/getAccountDetails",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "api_key": "ur-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "stat": "ok",
      "account": {
        "email": "user@example.com",
        "monitor_limit": 50,
        "monitor_interval": 300,
        "up_monitors": 45,
        "down_monitors": 1,
        "paused_monitors": 4
      }
    }
  }
}
