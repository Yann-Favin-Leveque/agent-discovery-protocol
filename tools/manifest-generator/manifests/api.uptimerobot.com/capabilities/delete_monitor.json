{
  "name": "delete_monitor",
  "description": "Permanently delete an existing monitor by its ID. This action cannot be undone and all historical data for the monitor will be lost. The API key is passed in the POST body.",
  "endpoint": "/v2/deleteMonitor",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Your UptimeRobot API key (sent in POST body)."
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "The monitor ID to delete."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uptimerobot.com/v2/deleteMonitor",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "api_key": "ur1234567-abcdef0123456789abcdef01",
      "format": "json",
      "id": 784561236
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "stat": "ok",
      "monitor": {
        "id": 784561236
      }
    }
  }
}
