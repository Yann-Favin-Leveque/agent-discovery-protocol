{
  "name": "edit_monitor",
  "description": "Edit an existing monitor's configuration including its URL, friendly name, monitoring interval, status, and alert contacts. You must provide the monitor ID. Only include the fields you want to change. The API key is passed in the POST body.",
  "endpoint": "/v2/editMonitor",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Your UptimeRobot API key (sent in POST body)."
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "The monitor ID to edit."
    },
    {
      "name": "friendly_name",
      "type": "string",
      "required": false,
      "description": "Updated human-readable name for the monitor."
    },
    {
      "name": "url",
      "type": "string",
      "required": false,
      "description": "Updated URL or IP address to monitor."
    },
    {
      "name": "status",
      "type": "integer",
      "required": false,
      "description": "Set monitor status: 0=pause, 1=resume."
    },
    {
      "name": "interval",
      "type": "integer",
      "required": false,
      "description": "Updated monitoring interval in seconds."
    },
    {
      "name": "alert_contacts",
      "type": "string",
      "required": false,
      "description": "Updated alert contact IDs (format: 'id_threshold_recurrence')."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uptimerobot.com/v2/editMonitor",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "api_key": "ur1234567-abcdef0123456789abcdef01",
      "format": "json",
      "id": 784561234,
      "friendly_name": "Production Website (Primary)",
      "interval": 60,
      "status": 1
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "stat": "ok",
      "monitor": {
        "id": 784561234
      }
    }
  }
}
