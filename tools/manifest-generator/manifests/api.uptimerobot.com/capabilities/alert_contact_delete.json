{
  "name": "alert_contact_delete",
  "description": "Delete an existing alert contact by its ID.",
  "resource_group": "alert_contacts",
  "endpoint": "/v2/deleteAlertContact",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Your UptimeRobot API key."
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "The ID of the alert contact to delete."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uptimerobot.com/v2/deleteAlertContact",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "api_key": "ur-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "id": 111222
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "stat": "ok",
      "alertcontact": {
        "id": "111222"
      }
    }
  }
}
