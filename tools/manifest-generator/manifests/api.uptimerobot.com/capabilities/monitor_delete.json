{
  "name": "monitor_delete",
  "description": "Permanently delete an existing monitor by its ID.",
  "resource_group": "monitors",
  "endpoint": "/v2/deleteMonitor",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Your UptimeRobot API key.",
      "in": "body"
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "The ID of the monitor to delete.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uptimerobot.com/v2/deleteMonitor",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "api_key": "ur-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "id": 12345678
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "stat": "ok",
      "monitor": {
        "id": 12345678
      }
    }
  }
}
