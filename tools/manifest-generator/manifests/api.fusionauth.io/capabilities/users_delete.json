{
  "name": "users_delete",
  "resource_group": "users",
  "description": "Delete a user by ID. Optionally soft-delete (deactivate) instead of hard delete.",
  "endpoint": "/api/user/{userId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": true,
      "description": "User UUID.",
      "in": "path"
    },
    {
      "name": "hardDelete",
      "type": "boolean",
      "required": false,
      "description": "Permanently delete. Default false (deactivate).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://fusionauth.example.com/api/user/user-uuid?hardDelete=true",
    "headers": {
      "Authorization": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
