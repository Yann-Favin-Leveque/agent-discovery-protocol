{
  "name": "tenants_create",
  "resource_group": "tenants",
  "description": "Create a new tenant for multi-tenant deployments.",
  "endpoint": "/api/tenant",
  "method": "POST",
  "parameters": [
    {
      "name": "tenant",
      "type": "object",
      "required": true,
      "description": "Tenant object with name, issuer, emailConfiguration, etc."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://fusionauth.example.com/api/tenant",
    "headers": {
      "Authorization": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "tenant": {
        "name": "Acme Tenant",
        "issuer": "https://acme.example.com"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tenant": {
        "id": "tenant-uuid",
        "name": "Acme Tenant",
        "issuer": "https://acme.example.com"
      }
    }
  }
}