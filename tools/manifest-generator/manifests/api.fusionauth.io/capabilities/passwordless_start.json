{
  "name": "passwordless_start",
  "resource_group": "passwordless",
  "description": "Start a passwordless login by sending a magic link or code to the user.",
  "endpoint": "/api/passwordless/start",
  "method": "POST",
  "parameters": [
    {
      "name": "loginId",
      "type": "string",
      "required": true,
      "description": "Email or phone of the user.",
      "in": "body"
    },
    {
      "name": "applicationId",
      "type": "string",
      "required": true,
      "description": "Application UUID.",
      "in": "body"
    },
    {
      "name": "state",
      "type": "object",
      "required": false,
      "description": "State data to return after authentication.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://fusionauth.example.com/api/passwordless/start",
    "headers": {
      "Authorization": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "loginId": "alice@example.com",
      "applicationId": "app-uuid"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": "passwordless-code"
    }
  }
}
