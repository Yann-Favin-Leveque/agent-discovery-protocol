{
  "name": "retrieve_user",
  "description": "Retrieve a user's full profile by their user ID, email, or username. Returns all user data including registrations, group memberships, and custom data.",
  "endpoint": "/api/user",
  "method": "GET",
  "parameters": [
    { "name": "userId", "type": "string", "description": "The user's UUID (path parameter: /api/user/{userId}).", "required": false, "example": "00000000-0000-0001-0000-000000000000" },
    { "name": "email", "type": "string", "description": "Look up the user by email (query parameter).", "required": false, "example": "jane@example.com" },
    { "name": "username", "type": "string", "description": "Look up the user by username (query parameter).", "required": false, "example": "janedoe" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fusionauth.io/api/user?email=jane@example.com",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "id": "00000000-0000-0001-0000-000000000000",
        "email": "jane@example.com",
        "firstName": "Jane",
        "lastName": "Doe",
        "active": true,
        "verified": true,
        "mobilePhone": "+14155551234",
        "insertInstant": 1704067200000,
        "lastLoginInstant": 1704153600000,
        "registrations": [
          {
            "applicationId": "10000000-0000-0002-0000-000000000001",
            "roles": ["admin"],
            "verified": true
          }
        ],
        "memberships": [
          {
            "groupId": "30000000-0000-0001-0000-000000000000"
          }
        ]
      }
    }
  }
}
