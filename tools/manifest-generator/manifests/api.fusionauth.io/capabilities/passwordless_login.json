{
  "name": "passwordless_login",
  "resource_group": "passwordless",
  "description": "Complete a passwordless login by providing the code from the magic link.",
  "endpoint": "/api/passwordless/login",
  "method": "POST",
  "parameters": [
    {
      "name": "code",
      "type": "string",
      "required": true,
      "description": "The passwordless code.",
      "in": "body"
    },
    {
      "name": "twoFactorTrustId",
      "type": "string",
      "required": false,
      "description": "Two-factor trust ID if device is trusted.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://fusionauth.example.com/api/passwordless/login",
    "headers": {
      "Authorization": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "code": "passwordless-code"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "token": "eyJhbGciOi...",
      "refreshToken": "refresh-token",
      "user": {
        "id": "user-uuid",
        "email": "alice@example.com"
      }
    }
  }
}
