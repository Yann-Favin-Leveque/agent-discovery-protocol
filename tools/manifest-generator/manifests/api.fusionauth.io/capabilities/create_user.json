{
  "name": "create_user",
  "description": "Create a new user in FusionAuth. You can include registration to an application in the same request. Returns the full user object with a generated user ID.",
  "endpoint": "/api/user",
  "method": "POST",
  "parameters": [
    { "name": "user.email", "type": "string", "description": "The user's email address.", "required": true, "example": "jane@example.com" },
    { "name": "user.password", "type": "string", "description": "The user's password. If omitted, the user must use passwordless login.", "required": false, "example": "super-secret-password" },
    { "name": "user.firstName", "type": "string", "description": "The user's first name.", "required": false, "example": "Jane" },
    { "name": "user.lastName", "type": "string", "description": "The user's last name.", "required": false, "example": "Doe" },
    { "name": "user.mobilePhone", "type": "string", "description": "The user's mobile phone number.", "required": false, "example": "+14155551234" },
    { "name": "registration.applicationId", "type": "string", "description": "UUID of the application to register the user to in the same request.", "required": false, "example": "10000000-0000-0002-0000-000000000001" },
    { "name": "registration.roles", "type": "array", "description": "Roles to assign to the user for the application.", "required": false, "example": ["admin"] },
    { "name": "sendSetPasswordEmail", "type": "boolean", "description": "Whether to send a setup-password email to the user.", "required": false, "example": false }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.fusionauth.io/api/user",
    "headers": {
      "Authorization": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "user": {
        "email": "jane@example.com",
        "password": "super-secret-password",
        "firstName": "Jane",
        "lastName": "Doe"
      },
      "registration": {
        "applicationId": "10000000-0000-0002-0000-000000000001",
        "roles": ["admin"]
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "id": "00000000-0000-0001-0000-000000000000",
        "email": "jane@example.com",
        "firstName": "Jane",
        "lastName": "Doe",
        "active": true,
        "verified": false,
        "insertInstant": 1704067200000,
        "lastLoginInstant": 0,
        "registrations": [
          {
            "applicationId": "10000000-0000-0002-0000-000000000001",
            "id": "20000000-0000-0002-0000-000000000000",
            "roles": ["admin"]
          }
        ]
      }
    }
  }
}
