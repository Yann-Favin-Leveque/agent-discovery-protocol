{
  "name": "applications_get",
  "resource_group": "applications",
  "description": "Retrieve an application by ID.",
  "endpoint": "/api/application/{applicationId}",
  "method": "GET",
  "parameters": [
    {
      "name": "applicationId",
      "type": "string",
      "required": true,
      "description": "Application UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://fusionauth.example.com/api/application/app-uuid",
    "headers": {
      "Authorization": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "application": {
        "id": "app-uuid",
        "name": "My App",
        "roles": [
          {
            "name": "admin"
          },
          {
            "name": "user"
          }
        ]
      }
    }
  }
}