{
  "name": "users_change_password",
  "resource_group": "users",
  "description": "Change a user's password by providing the current and new password.",
  "endpoint": "/api/user/change-password/{userId}",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": true,
      "description": "User UUID.",
      "in": "path"
    },
    {
      "name": "currentPassword",
      "type": "string",
      "required": true,
      "description": "Current password."
    },
    {
      "name": "password",
      "type": "string",
      "required": true,
      "description": "New password."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://fusionauth.example.com/api/user/change-password/user-uuid",
    "headers": {
      "Authorization": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "currentPassword": "oldPass",
      "password": "newSecurePass!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}