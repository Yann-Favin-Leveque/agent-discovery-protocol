{
  "name": "groups_update",
  "resource_group": "groups",
  "description": "Update a group.",
  "endpoint": "/api/group/{groupId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "groupId",
      "type": "string",
      "required": true,
      "description": "Group UUID.",
      "in": "path"
    },
    {
      "name": "group",
      "type": "object",
      "required": true,
      "description": "Updated group object.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://fusionauth.example.com/api/group/group-uuid",
    "headers": {
      "Authorization": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "group": {
        "name": "Super Admins"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "group": {
        "id": "group-uuid",
        "name": "Super Admins"
      }
    }
  }
}
