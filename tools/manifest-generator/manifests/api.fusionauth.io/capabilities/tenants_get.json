{
  "name": "tenants_get",
  "resource_group": "tenants",
  "description": "Retrieve a tenant by ID.",
  "endpoint": "/api/tenant/{tenantId}",
  "method": "GET",
  "parameters": [
    {
      "name": "tenantId",
      "type": "string",
      "required": true,
      "description": "Tenant UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://fusionauth.example.com/api/tenant/tenant-uuid",
    "headers": {
      "Authorization": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tenant": {
        "id": "tenant-uuid",
        "name": "Acme Tenant"
      }
    }
  }
}