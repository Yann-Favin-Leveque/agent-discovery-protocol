{
  "name": "applications_delete",
  "resource_group": "applications",
  "description": "Delete an application.",
  "endpoint": "/api/application/{applicationId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "applicationId",
      "type": "string",
      "required": true,
      "description": "Application UUID.",
      "in": "path"
    },
    {
      "name": "hardDelete",
      "type": "boolean",
      "required": false,
      "description": "Permanently delete. Default false."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://fusionauth.example.com/api/application/app-uuid?hardDelete=true",
    "headers": {
      "Authorization": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}