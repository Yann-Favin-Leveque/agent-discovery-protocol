{
  "name": "applications_update",
  "resource_group": "applications",
  "description": "Update an application's settings.",
  "endpoint": "/api/application/{applicationId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "applicationId",
      "type": "string",
      "required": true,
      "description": "Application UUID.",
      "in": "path"
    },
    {
      "name": "application",
      "type": "object",
      "required": true,
      "description": "Updated application object."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://fusionauth.example.com/api/application/app-uuid",
    "headers": {
      "Authorization": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "application": {
        "name": "My Updated App"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "application": {
        "id": "app-uuid",
        "name": "My Updated App"
      }
    }
  }
}