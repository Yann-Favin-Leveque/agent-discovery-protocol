{
  "name": "registrations_get",
  "resource_group": "registrations",
  "description": "Retrieve a user's registration for a specific application.",
  "endpoint": "/api/user/registration/{userId}/{applicationId}",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": true,
      "description": "User UUID.",
      "in": "path"
    },
    {
      "name": "applicationId",
      "type": "string",
      "required": true,
      "description": "Application UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://fusionauth.example.com/api/user/registration/user-uuid/app-uuid",
    "headers": {
      "Authorization": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "registration": {
        "applicationId": "app-uuid",
        "userId": "user-uuid",
        "roles": [
          "user"
        ]
      }
    }
  }
}