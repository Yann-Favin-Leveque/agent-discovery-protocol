{
  "name": "groups_get",
  "resource_group": "groups",
  "description": "Retrieve a group by ID.",
  "endpoint": "/api/group/{groupId}",
  "method": "GET",
  "parameters": [
    {
      "name": "groupId",
      "type": "string",
      "required": true,
      "description": "Group UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://fusionauth.example.com/api/group/group-uuid",
    "headers": {
      "Authorization": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "group": {
        "id": "group-uuid",
        "name": "Administrators",
        "tenantId": "tenant-uuid"
      }
    }
  }
}