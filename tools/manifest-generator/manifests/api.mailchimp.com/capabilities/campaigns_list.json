{
  "name": "campaigns_list",
  "description": "List all campaigns in your account.",
  "endpoint": "/3.0/campaigns",
  "method": "GET",
  "resource_group": "campaigns",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "Filter: regular, plaintext, absplit, rss, variate.",
      "required": false,
      "example": "regular"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter: save, paused, schedule, sending, sent.",
      "required": false,
      "example": "sent"
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 10
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/campaigns?status=sent&count=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "campaigns": [
        {
          "id": "camp123",
          "type": "regular",
          "status": "sent",
          "settings": {
            "subject_line": "March Newsletter"
          }
        }
      ],
      "total_items": 50
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}