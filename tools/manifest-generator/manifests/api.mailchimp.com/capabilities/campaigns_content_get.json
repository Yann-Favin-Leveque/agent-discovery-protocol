{
  "name": "campaigns_content_get",
  "description": "Retrieve the content of a campaign.",
  "endpoint": "/3.0/campaigns/{campaign_id}/content",
  "method": "GET",
  "resource_group": "campaigns",
  "parameters": [
    {
      "name": "campaign_id",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "example": "camp123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/campaigns/camp123/content",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "html": "<html><body><h1>Hello!</h1></body></html>",
      "plain_text": "Hello!"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
