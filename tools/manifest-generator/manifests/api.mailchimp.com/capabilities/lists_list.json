{
  "name": "lists_list",
  "description": "List all audiences (lists) in your Mailchimp account.",
  "endpoint": "/3.0/lists",
  "method": "GET",
  "resource_group": "lists",
  "parameters": [
    {
      "name": "count",
      "type": "integer",
      "description": "Number of results (max 1000).",
      "required": false,
      "example": 10,
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Results to skip.",
      "required": false,
      "example": 0,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/lists?count=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "lists": [
        {
          "id": "abc123",
          "name": "My Audience",
          "stats": {
            "member_count": 5000
          }
        }
      ],
      "total_items": 1
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
