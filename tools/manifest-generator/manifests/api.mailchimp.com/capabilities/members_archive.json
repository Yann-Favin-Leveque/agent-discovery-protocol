{
  "name": "members_archive",
  "description": "Archive (soft delete) a subscriber from an audience.",
  "endpoint": "/3.0/lists/{list_id}/members/{subscriber_hash}",
  "method": "DELETE",
  "resource_group": "members",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "Audience ID.",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "subscriber_hash",
      "type": "string",
      "description": "MD5 hash of email.",
      "required": true,
      "example": "hash123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://us1.api.mailchimp.com/3.0/lists/abc123/members/hash123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}