{
  "name": "templates_update",
  "description": "Update a template's name or HTML.",
  "endpoint": "/3.0/templates/{template_id}",
  "method": "PATCH",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "template_id",
      "type": "integer",
      "description": "Template ID.",
      "required": true,
      "example": 12345,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "Updated Template",
      "in": "body"
    },
    {
      "name": "html",
      "type": "string",
      "description": "Updated HTML.",
      "required": false,
      "example": "<html><body>Updated!</body></html>",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://us1.api.mailchimp.com/3.0/templates/12345",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Template"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345,
      "name": "Updated Template"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
