{
  "name": "list_templates",
  "description": "Retrieve all email templates available in your Mailchimp account. Includes user-created templates and default templates, with information about layout, sections, and image locations. Templates can be used as the basis for campaigns.",
  "endpoint": "/3.0/templates",
  "method": "GET",
  "parameters": [
    {
      "name": "count",
      "type": "integer",
      "description": "The number of templates to return per request (maximum 1000).",
      "required": false,
      "example": 10
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "The number of templates to skip before returning results for pagination.",
      "required": false,
      "example": 0
    },
    {
      "name": "created_by",
      "type": "string",
      "description": "Filter results by who created the template: 'user' for user-created or 'mailchimp' for system templates.",
      "required": false,
      "example": "user"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailchimp.com/3.0/templates?count=10&offset=0",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "templates": [
