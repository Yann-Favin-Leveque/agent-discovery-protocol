{
  "name": "add_member",
  "description": "Add a new subscriber to a specific audience. Requires the list ID and subscriber email address. Supports custom merge fields (like name, address), interests (tags), and subscription status. Can automatically subscribe, update existing members, or validate email addresses.",
  "endpoint": "/3.0/lists/{list_id}/members",
  "method": "POST",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "The ID of the audience (list) to add the member to.",
      "required": true,
      "example": "abc123def456"
    },
    {
      "name": "email_address",
      "type": "string",
      "description": "The email address of the subscriber.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "status",
      "type": "string",
      "description": "The subscription status: 'subscribed', 'unsubscribed', 'cleaned', or 'pending'.",
      "required": false,
      "example": "subscribed"
    },
    {
      "name": "merge_fields",
      "type": "object",
      "description": "Custom merge fields like FNAME (first name), LNAME (last name), and others defined in your list.",
      "required": false,
      "example": { "FNAME": "John", "LNAME": "Doe" }
    },
    {
      "name": "interests",
      "type": "object",
      "description": "An object with interest group IDs as keys and boolean values indicating the subscriber's interest status.",
      "required": false,
      "example": { "interest_id_1": true, "interest_id_2": false }
    },
    {
      "name": "language",
      "type": "string",
      "description": "The subscriber's preferred email language (e.g., 'en', 'es', 'fr').",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mailchimp.com/3.0/lists/abc123def456/members",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "newsubscriber@example.com",
      "status": "subscribed",
      "merge_fields": {
        "FNAME": "Jane",
        "LNAME": "Smith"
      },
      "interests": {
        "interest_id_1": true,
        "interest_id_2": false
      },
      "language": "en"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123def456789",
      "email_address": "newsubscriber@example.com",
      "unique_email_id": "def456789abc123",
      "email_type": "html",
