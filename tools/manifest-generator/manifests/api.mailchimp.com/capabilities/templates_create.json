{
  "name": "templates_create",
  "description": "Create a new email template.",
  "endpoint": "/3.0/templates",
  "method": "POST",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Template name.",
      "required": true,
      "example": "Welcome Email",
      "in": "body"
    },
    {
      "name": "html",
      "type": "string",
      "description": "HTML content.",
      "required": true,
      "example": "<html><body>Welcome!</body></html>",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://us1.api.mailchimp.com/3.0/templates",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Welcome Email",
      "html": "<html><body>Welcome!</body></html>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12346,
      "name": "Welcome Email",
      "type": "user"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
