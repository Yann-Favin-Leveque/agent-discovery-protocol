{
  "name": "campaigns_get",
  "description": "Retrieve details of a specific campaign.",
  "endpoint": "/3.0/campaigns/{campaign_id}",
  "method": "GET",
  "resource_group": "campaigns",
  "parameters": [
    {
      "name": "campaign_id",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "example": "camp123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/campaigns/camp123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "camp123",
      "type": "regular",
      "status": "sent",
      "settings": {
        "subject_line": "March Newsletter",
        "from_name": "Acme"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}