{
  "name": "members_add_or_update",
  "description": "Add or update a subscriber using PUT (upsert by email).",
  "endpoint": "/3.0/lists/{list_id}/members/{subscriber_hash}",
  "method": "PUT",
  "resource_group": "members",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "Audience ID.",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "subscriber_hash",
      "type": "string",
      "description": "MD5 hash of email.",
      "required": true,
      "example": "hash123"
    },
    {
      "name": "email_address",
      "type": "string",
      "description": "Email address.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "status_if_new",
      "type": "string",
      "description": "Status if new subscriber.",
      "required": true,
      "example": "subscribed"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://us1.api.mailchimp.com/3.0/lists/abc123/members/hash123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "user@example.com",
      "status_if_new": "subscribed",
      "merge_fields": {
        "FNAME": "John"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "hash123",
      "email_address": "user@example.com",
      "status": "subscribed"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}