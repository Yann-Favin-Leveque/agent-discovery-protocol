{
  "name": "templates_list",
  "description": "List all email templates.",
  "endpoint": "/3.0/templates",
  "method": "GET",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "Filter: user, base, gallery.",
      "required": false,
      "example": "user",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 10,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/templates?type=user&count=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "templates": [
        {
          "id": 12345,
          "name": "Monthly Newsletter",
          "type": "user"
        }
      ],
      "total_items": 15
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
