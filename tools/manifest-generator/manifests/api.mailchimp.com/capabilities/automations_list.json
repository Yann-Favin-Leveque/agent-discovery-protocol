{
  "name": "automations_list",
  "description": "List all automations (automated email series).",
  "endpoint": "/3.0/automations",
  "method": "GET",
  "resource_group": "automations",
  "parameters": [
    {
      "name": "count",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 10
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/automations?count=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "automations": [
        {
          "id": "auto123",
          "status": "sending",
          "settings": {
            "title": "Welcome Series"
          }
        }
      ],
      "total_items": 3
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}