{
  "name": "templates_get",
  "description": "Retrieve a specific template.",
  "endpoint": "/3.0/templates/{template_id}",
  "method": "GET",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "template_id",
      "type": "integer",
      "description": "Template ID.",
      "required": true,
      "example": 12345,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/templates/12345",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345,
      "name": "Monthly Newsletter",
      "type": "user",
      "html": "<html>...</html>"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
