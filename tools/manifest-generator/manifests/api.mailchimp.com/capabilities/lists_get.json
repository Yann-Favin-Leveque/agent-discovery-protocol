{
  "name": "lists_get",
  "description": "Retrieve details of a specific audience by its ID.",
  "endpoint": "/3.0/lists/{list_id}",
  "method": "GET",
  "resource_group": "lists",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "Audience/list ID.",
      "required": true,
      "example": "abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/lists/abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "name": "My Audience",
      "stats": {
        "member_count": 5000,
        "open_rate": 25.5
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
