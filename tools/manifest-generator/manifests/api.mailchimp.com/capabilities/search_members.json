{
  "name": "search_members",
  "description": "Search for members across all audiences in your Mailchimp account. Search by email address, merge fields, or engagement metrics. Returns matching subscriber records with their subscription status, engagement data, and custom field values.",
  "endpoint": "/3.0/search-members",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "The search query term (typically an email address or name).",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "list_id",
      "type": "string",
      "description": "Limit search results to a specific list ID. If omitted, searches all lists.",
      "required": false,
      "example": "abc123def456"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "The number of results to skip before returning results for pagination.",
      "required": false,
      "example": 0
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailchimp.com/3.0/search-members?query=user@example.com",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "exact_matches": {
        "members": [
          {
            "id": "abc123def456789",
            "email_address": "user@example.com",
            "email_type": "html",
            "status": "subscribed",
            "merge_fields": {
              "FNAME": "John",
              "LNAME": "Doe"
            },
            "interests": {
              "interest_id_1": true
            },
            "stats": {
              "avg_open_rate": 25.5,
              "avg_click_rate": 3.2
            },
            "member_rating": 4,
            "last_changed": "2024-01-15T14:22:00+00:00",
            "language": "en",
            "vip": false,
            "list_id": "abc123def456"
          }
        ],
        "total_items": 1
      },
      "full_search": {
        "members": [
          {
            "id": "def789abc123456",
            "email_address": "user.doe@example.com",
            "email_type": "html",
            "status": "subscribed",
            "merge_fields": {
              "FNAME": "John",
              "LNAME": "Doe"
            },
            "stats": {
              "avg_open_rate": 18.2,
              "avg_click_rate": 1.5
            },
            "member_rating": 3,
            "last_changed": "2024-01-10T09:15:00+00:00",
            "language": "en",
            "vip": false,
            "list_id": "xyz789abc123"
          }
        ],
        "total_items": 1
      }
    }
  }
}
