{
  "name": "members_get",
  "description": "Retrieve a specific subscriber by their email hash.",
  "endpoint": "/3.0/lists/{list_id}/members/{subscriber_hash}",
  "method": "GET",
  "resource_group": "members",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "Audience ID.",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "subscriber_hash",
      "type": "string",
      "description": "MD5 hash of lowercase email.",
      "required": true,
      "example": "hash123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/lists/abc123/members/hash123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "hash123",
      "email_address": "user@example.com",
      "status": "subscribed",
      "merge_fields": {
        "FNAME": "John"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}