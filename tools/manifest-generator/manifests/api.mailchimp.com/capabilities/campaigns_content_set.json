{
  "name": "campaigns_content_set",
  "description": "Set the HTML content for a campaign.",
  "endpoint": "/3.0/campaigns/{campaign_id}/content",
  "method": "PUT",
  "resource_group": "campaigns",
  "parameters": [
    {
      "name": "campaign_id",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "example": "camp123"
    },
    {
      "name": "html",
      "type": "string",
      "description": "HTML content.",
      "required": false,
      "example": "<html><body><h1>Hello!</h1></body></html>"
    },
    {
      "name": "template",
      "type": "object",
      "description": "Template to use.",
      "required": false,
      "example": {
        "id": 12345
      }
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://us1.api.mailchimp.com/3.0/campaigns/camp123/content",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "html": "<html><body><h1>Hello!</h1></body></html>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "html": "<html><body><h1>Hello!</h1></body></html>"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}