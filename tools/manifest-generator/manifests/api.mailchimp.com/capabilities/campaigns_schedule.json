{
  "name": "campaigns_schedule",
  "description": "Schedule a campaign to send at a future date/time.",
  "endpoint": "/3.0/campaigns/{campaign_id}/actions/schedule",
  "method": "POST",
  "resource_group": "campaigns",
  "parameters": [
    {
      "name": "campaign_id",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "example": "camp123"
    },
    {
      "name": "schedule_time",
      "type": "string",
      "description": "ISO 8601 send time.",
      "required": true,
      "example": "2024-03-15T10:00:00+00:00"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://us1.api.mailchimp.com/3.0/campaigns/camp123/actions/schedule",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "schedule_time": "2024-03-15T10:00:00+00:00"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}