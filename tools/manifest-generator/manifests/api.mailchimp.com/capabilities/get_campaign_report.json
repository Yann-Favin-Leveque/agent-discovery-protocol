{
  "name": "get_campaign_report",
  "description": "Retrieve detailed performance metrics for a sent campaign including open rates, click rates, bounce rates, unsubscribes, conversions, and more. Access subscriber-level engagement data or high-level aggregate statistics.",
  "endpoint": "/3.0/reports/{campaign_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "campaign_id",
      "type": "string",
      "description": "The ID of the campaign to get the report for.",
      "required": true,
      "example": "campaign123abc456"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailchimp.com/3.0/reports/campaign123abc456",
    "headers": {
