{
  "name": "members_tags_update",
  "description": "Add or remove tags from a subscriber.",
  "endpoint": "/3.0/lists/{list_id}/members/{subscriber_hash}/tags",
  "method": "POST",
  "resource_group": "members",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "Audience ID.",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "subscriber_hash",
      "type": "string",
      "description": "MD5 hash of email.",
      "required": true,
      "example": "hash123"
    },
    {
      "name": "tags",
      "type": "array",
      "description": "Tags with status active/inactive.",
      "required": true,
      "example": [
        {
          "name": "vip",
          "status": "active"
        },
        {
          "name": "trial",
          "status": "inactive"
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://us1.api.mailchimp.com/3.0/lists/abc123/members/hash123/tags",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "tags": [
        {
          "name": "vip",
          "status": "active"
        }
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}