{
  "name": "automations_get",
  "description": "Retrieve details of a specific automation.",
  "endpoint": "/3.0/automations/{workflow_id}",
  "method": "GET",
  "resource_group": "automations",
  "parameters": [
    {
      "name": "workflow_id",
      "type": "string",
      "description": "Automation workflow ID.",
      "required": true,
      "example": "auto123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://us1.api.mailchimp.com/3.0/automations/auto123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "auto123",
      "status": "sending",
      "settings": {
        "title": "Welcome Series"
      },
      "emails_sent": 1500
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
