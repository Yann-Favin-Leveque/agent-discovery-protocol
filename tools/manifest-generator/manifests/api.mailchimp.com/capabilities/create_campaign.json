{
  "name": "create_campaign",
  "description": "Create a new email campaign with a target audience, subject line, and email content. Supports multiple campaign types including regular email, A/B testing, automation, and RSS campaigns. Campaigns can be sent immediately or scheduled for later.",
  "endpoint": "/3.0/campaigns",
  "method": "POST",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "Campaign type: 'regular', 'plaintext', 'absplit', 'rss', or 'variate'.",
      "required": true,
      "example": "regular"
    },
    {
      "name": "recipients",
      "type": "object",
      "description": "The audience (list) to send the campaign to. Specify list_id and optional segment_id or conditions.",
      "required": true,
      "example": { "list_id": "abc123def456" }
    },
    {
      "name": "settings",
      "type": "object",
      "description": "Campaign settings including subject_line, from_name, reply_to, and other options.",
      "required": true,
      "example": { "subject_line": "Welcome to our newsletter!", "from_name": "Example", "reply_to": "reply@example.com" }
    },
    {
      "name": "content",
      "type": "object",
      "description": "The campaign email content. Provide either html or plain_text, or template_id.",
      "required": false,
      "example": { "html": "<html><body>Hello!</body></html>" }
    },
    {
      "name": "template_id",
      "type": "integer",
      "description": "ID of a saved template to use as the basis for the campaign.",
      "required": false,
      "example": 12345
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mailchimp.com/3.0/campaigns",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "type": "regular",
      "recipients": {
        "list_id": "abc123def456"
      },
      "settings": {
        "subject_line": "Welcome to our newsletter!",
        "from_name": "Example Company",
        "reply_to": "reply@example.com",
        "title": "Newsletter Jan 2024"
      },
      "content": {
        "html": "<html><body><h1>Welcome!</h1><p>Thank you for subscribing to our newsletter.</p></body></html>"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "campaign123abc456",
      "type": "regular",
      "create_time": "2024-01-20T12:00:00+00:00",
      "archive_url": "https://mailchimp.com/campaigns/archive/campaign123abc456",
      "long_archive_url": "https://example.us2.campaign-archive.com/home/?u=abc123&id=campaign123abc456",
      "status": "draft",
      "emails_sent": 0,
      "send_time": "",
      "content_type": "html",
      "needs_block_refresh": false,
      "recipients": {
        "list_id": "abc123def456",
        "list_is_active": true,
        "list_name": "Newsletter Subscribers",
        "segment_text": "",
        "recipient_count": 5000
      },
      "settings": {
        "subject_line": "Welcome to our newsletter!",
        "preview_text": "",
        "title": "Newsletter Jan 2024",
        "from_name": "Example Company",
        "reply_to": "reply@example.com",
        "use_conversation": false,
        "to_name": "*|FNAME|* *|LNAME|*",
        "folder_id": "",
        "authenticate": false,
        "auto_footer": false,
        "inline_css": false,
        "auto_tweet": false,
        "fb_comments": true,
        "timewarp": false,
        "track_opens": true,
        "track_clicks": true,
        "google_analytics": "",
        "salesforce": { "campaign": "", "notes": "" },
        "highrise": { "campaign": "" },
        "capsule": { "notes": "" },
        "getresponse": { "campaign": "" }
      },
      "tracking": {
