{
  "name": "lists_update",
  "description": "Update an audience's settings.",
  "endpoint": "/3.0/lists/{list_id}",
  "method": "PATCH",
  "resource_group": "lists",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "Audience ID.",
      "required": true,
      "example": "abc123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "Updated Newsletter",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://us1.api.mailchimp.com/3.0/lists/abc123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Newsletter"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "name": "Updated Newsletter"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
