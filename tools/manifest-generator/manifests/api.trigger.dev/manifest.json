{
  "spec_version": "1.0",
  "name": "Trigger.dev",
  "description": "Background jobs and workflow orchestration platform for TypeScript. Trigger tasks, manage runs, queues, schedules, deployments, and environment variables via REST API.",
  "base_url": "https://api.trigger.dev",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer"
  },
  "capabilities": [
    {
      "name": "task_trigger",
      "description": "Trigger a task by its identifier with a payload.",
      "detail_url": "/capabilities/task_trigger",
      "resource_group": "task"
    },
    {
      "name": "task_batch_trigger",
      "description": "Batch trigger a task with up to 1000 payloads.",
      "detail_url": "/capabilities/task_batch_trigger",
      "resource_group": "task"
    },
    {
      "name": "tasks_batch",
      "description": "Batch trigger multiple different tasks in one request.",
      "detail_url": "/capabilities/tasks_batch",
      "resource_group": "task"
    },
    {
      "name": "run_list",
      "description": "List runs with filtering and pagination.",
      "detail_url": "/capabilities/run_list",
      "resource_group": "run"
    },
    {
      "name": "run_get",
      "description": "Retrieve details of a specific run.",
      "detail_url": "/capabilities/run_get",
      "resource_group": "run"
    },
    {
      "name": "run_cancel",
      "description": "Cancel an in-progress run.",
      "detail_url": "/capabilities/run_cancel",
      "resource_group": "run"
    },
    {
      "name": "run_replay",
      "description": "Replay a completed or failed run.",
      "detail_url": "/capabilities/run_replay",
      "resource_group": "run"
    },
    {
      "name": "run_reschedule",
      "description": "Reschedule a delayed run.",
      "detail_url": "/capabilities/run_reschedule",
      "resource_group": "run"
    },
    {
      "name": "run_result",
      "description": "Get the execution result of a completed run.",
      "detail_url": "/capabilities/run_result",
      "resource_group": "run"
    },
    {
      "name": "run_tags_add",
      "description": "Add tags to a run.",
      "detail_url": "/capabilities/run_tags_add",
      "resource_group": "run"
    },
    {
      "name": "run_metadata_update",
      "description": "Update metadata on a run.",
      "detail_url": "/capabilities/run_metadata_update",
      "resource_group": "run"
    },
    {
      "name": "run_events",
      "description": "Return all OTel span events for a run.",
      "detail_url": "/capabilities/run_events",
      "resource_group": "run"
    },
    {
      "name": "run_trace",
      "description": "Return the full OTel trace tree for a run.",
      "detail_url": "/capabilities/run_trace",
      "resource_group": "run"
    },
    {
      "name": "batch_create",
      "description": "Create a batch record for grouping runs.",
      "detail_url": "/capabilities/batch_create",
      "resource_group": "batch"
    },
    {
      "name": "batch_get",
      "description": "Retrieve batch details.",
      "detail_url": "/capabilities/batch_get",
      "resource_group": "batch"
    },
    {
      "name": "batch_results",
      "description": "Get results of all completed runs in a batch.",
      "detail_url": "/capabilities/batch_results",
      "resource_group": "batch"
    },
    {
      "name": "schedule_create",
      "description": "Create a new cron schedule for a task.",
      "detail_url": "/capabilities/schedule_create",
      "resource_group": "schedule"
    },
    {
      "name": "schedule_list",
      "description": "List all schedules with pagination.",
      "detail_url": "/capabilities/schedule_list",
      "resource_group": "schedule"
    },
    {
      "name": "schedule_get",
      "description": "Retrieve a specific schedule by ID.",
      "detail_url": "/capabilities/schedule_get",
      "resource_group": "schedule"
    },
    {
      "name": "schedule_update",
      "description": "Update a schedule.",
      "detail_url": "/capabilities/schedule_update",
      "resource_group": "schedule"
    },
    {
      "name": "schedule_delete",
      "description": "Delete a schedule.",
      "detail_url": "/capabilities/schedule_delete",
      "resource_group": "schedule"
    },
    {
      "name": "schedule_activate",
      "description": "Activate a deactivated schedule.",
      "detail_url": "/capabilities/schedule_activate",
      "resource_group": "schedule"
    },
    {
      "name": "schedule_deactivate",
      "description": "Deactivate an active schedule.",
      "detail_url": "/capabilities/schedule_deactivate",
      "resource_group": "schedule"
    },
    {
      "name": "schedule_timezones",
      "description": "List all supported timezones for schedules.",
      "detail_url": "/capabilities/schedule_timezones",
      "resource_group": "schedule"
    },
    {
      "name": "queue_list",
      "description": "List all queues with pagination.",
      "detail_url": "/capabilities/queue_list",
      "resource_group": "queue"
    },
    {
      "name": "queue_get",
      "description": "Retrieve a queue by ID.",
      "detail_url": "/capabilities/queue_get",
      "resource_group": "queue"
    },
    {
      "name": "queue_pause",
      "description": "Pause or resume a queue.",
      "detail_url": "/capabilities/queue_pause",
      "resource_group": "queue"
    },
    {
      "name": "envvar_list",
      "description": "List environment variables.",
      "detail_url": "/capabilities/envvar_list",
      "resource_group": "envvar"
    },
    {
      "name": "envvar_create",
      "description": "Create an environment variable.",
      "detail_url": "/capabilities/envvar_create",
      "resource_group": "envvar"
    },
    {
      "name": "envvar_get",
      "description": "Retrieve an environment variable.",
      "detail_url": "/capabilities/envvar_get",
      "resource_group": "envvar"
    },
    {
      "name": "envvar_update",
      "description": "Update an environment variable.",
      "detail_url": "/capabilities/envvar_update",
      "resource_group": "envvar"
    },
    {
      "name": "envvar_delete",
      "description": "Delete an environment variable.",
      "detail_url": "/capabilities/envvar_delete",
      "resource_group": "envvar"
    },
    {
      "name": "envvar_import",
      "description": "Import multiple environment variables.",
      "detail_url": "/capabilities/envvar_import",
      "resource_group": "envvar"
    }
  ]
}