{
  "name": "run_replay",
  "description": "Create a replay (re-execution) of a completed or failed run.",
  "resource_group": "run",
  "endpoint": "/api/v3/runs/{runId}/replay",
  "method": "POST",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.trigger.dev/api/v3/runs/run_abc123/replay",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "run_new456"
    }
  }
}