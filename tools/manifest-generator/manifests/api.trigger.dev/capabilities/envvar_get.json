{
  "name": "envvar_get",
  "description": "Retrieve a specific environment variable.",
  "resource_group": "envvar",
  "endpoint": "/api/v3/envvars/{envVarId}",
  "method": "GET",
  "parameters": [
    {
      "name": "envVarId",
      "type": "string",
      "description": "Environment variable ID (path parameter).",
      "required": true,
      "example": "ev_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/envvars/ev_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ev_abc",
      "key": "API_KEY",
      "value": "sk_live_xxx"
    }
  }
}
