{
  "name": "run_trace",
  "description": "Return the full OpenTelemetry trace tree for a run.",
  "resource_group": "run",
  "endpoint": "/api/v3/runs/{runId}/trace",
  "method": "GET",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/runs/run_abc123/trace",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "traceId": "trace_abc",
      "spans": []
    }
  }
}