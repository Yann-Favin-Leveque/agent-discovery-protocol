{
  "name": "run_result",
  "description": "Get the execution result (output) of a completed run.",
  "resource_group": "run",
  "endpoint": "/api/v3/runs/{runId}/result",
  "method": "GET",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/runs/run_abc123/result",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "output": {
        "result": "processed"
      }
    }
  }
}