{
  "name": "envvar_create",
  "description": "Create a new environment variable.",
  "resource_group": "envvar",
  "endpoint": "/api/v3/envvars",
  "method": "POST",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Variable name.",
      "required": true,
      "example": "API_KEY"
    },
    {
      "name": "value",
      "type": "string",
      "description": "Variable value.",
      "required": true,
      "example": "sk_live_xxx"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.trigger.dev/api/v3/envvars",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "key": "API_KEY",
      "value": "sk_live_xxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ev_abc",
      "key": "API_KEY"
    }
  }
}