{
  "name": "schedule_timezones",
  "description": "List all supported IANA timezones for schedules.",
  "resource_group": "schedule",
  "endpoint": "/api/v3/schedules/timezones",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/schedules/timezones",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "timezones": [
        "America/New_York",
        "Europe/London",
        "Asia/Tokyo"
      ]
    }
  }
}