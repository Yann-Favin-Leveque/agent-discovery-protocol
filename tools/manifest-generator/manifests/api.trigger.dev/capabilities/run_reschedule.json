{
  "name": "run_reschedule",
  "description": "Reschedule a delayed run to a new time.",
  "resource_group": "run",
  "endpoint": "/api/v3/runs/{runId}/reschedule",
  "method": "POST",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123"
    },
    {
      "name": "delay",
      "type": "string",
      "description": "New delay duration (e.g. 1h, 30m).",
      "required": false,
      "example": "1h"
    },
    {
      "name": "timestamp",
      "type": "string",
      "description": "New scheduled time (ISO 8601).",
      "required": false,
      "example": "2024-02-01T12:00:00Z"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.trigger.dev/api/v3/runs/run_abc123/reschedule",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "delay": "1h"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "run_abc123",
      "scheduledAt": "2024-02-01T13:00:00Z"
    }
  }
}