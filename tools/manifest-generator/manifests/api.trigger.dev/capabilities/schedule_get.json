{
  "name": "schedule_get",
  "description": "Retrieve a specific schedule by ID.",
  "resource_group": "schedule",
  "endpoint": "/api/v3/schedules/{scheduleId}",
  "method": "GET",
  "parameters": [
    {
      "name": "scheduleId",
      "type": "string",
      "description": "Schedule ID (path parameter).",
      "required": true,
      "example": "sched_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/schedules/sched_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sched_abc",
      "taskIdentifier": "my-task",
      "cron": "0 9 * * 1-5",
      "active": true,
      "timezone": "America/New_York"
    }
  }
}
