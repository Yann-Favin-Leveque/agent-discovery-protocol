{
  "name": "batch_create",
  "description": "Create a batch record for grouping multiple runs together.",
  "resource_group": "batch",
  "endpoint": "/api/v3/batches",
  "method": "POST",
  "parameters": [
    {
      "name": "parentRunId",
      "type": "string",
      "description": "Parent run ID that owns this batch.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.trigger.dev/api/v3/batches",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch_abc"
    }
  }
}
