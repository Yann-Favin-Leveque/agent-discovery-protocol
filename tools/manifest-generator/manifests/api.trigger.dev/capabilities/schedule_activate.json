{
  "name": "schedule_activate",
  "description": "Activate a deactivated schedule.",
  "resource_group": "schedule",
  "endpoint": "/api/v3/schedules/{scheduleId}/activate",
  "method": "POST",
  "parameters": [
    {
      "name": "scheduleId",
      "type": "string",
      "description": "Schedule ID (path parameter).",
      "required": true,
      "example": "sched_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.trigger.dev/api/v3/schedules/sched_abc/activate",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sched_abc",
      "active": true
    }
  }
}
