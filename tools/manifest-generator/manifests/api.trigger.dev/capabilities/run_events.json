{
  "name": "run_events",
  "description": "Return all OpenTelemetry span events for a run.",
  "resource_group": "run",
  "endpoint": "/api/v3/runs/{runId}/events",
  "method": "GET",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/runs/run_abc123/events",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "events": [
        {
          "name": "task.start",
          "timestamp": "2024-01-01T00:00:00Z",
          "attributes": {}
        }
      ]
    }
  }
}
