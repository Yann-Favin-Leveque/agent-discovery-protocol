{
  "name": "envvar_delete",
  "description": "Delete an environment variable.",
  "resource_group": "envvar",
  "endpoint": "/api/v3/envvars/{envVarId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "envVarId",
      "type": "string",
      "description": "Environment variable ID (path parameter).",
      "required": true,
      "example": "ev_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.trigger.dev/api/v3/envvars/ev_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
