{
  "name": "run_get",
  "description": "Retrieve details of a specific run by ID.",
  "resource_group": "run",
  "endpoint": "/api/v3/runs/{runId}",
  "method": "GET",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/runs/run_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "run_abc123",
      "taskIdentifier": "my-task",
      "status": "COMPLETED",
      "createdAt": "2024-01-01T00:00:00Z",
      "output": {
        "result": "done"
      }
    }
  }
}