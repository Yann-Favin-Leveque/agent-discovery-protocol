{
  "name": "batch_get",
  "description": "Retrieve details of a specific batch.",
  "resource_group": "batch",
  "endpoint": "/api/v3/batches/{batchId}",
  "method": "GET",
  "parameters": [
    {
      "name": "batchId",
      "type": "string",
      "description": "Batch ID (path parameter).",
      "required": true,
      "example": "batch_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/batches/batch_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch_abc",
      "runs": [
        "run_1",
        "run_2"
      ],
      "status": "COMPLETED"
    }
  }
}