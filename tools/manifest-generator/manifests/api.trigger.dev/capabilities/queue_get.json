{
  "name": "queue_get",
  "description": "Retrieve a specific queue by ID.",
  "resource_group": "queue",
  "endpoint": "/api/v3/queues/{queueId}",
  "method": "GET",
  "parameters": [
    {
      "name": "queueId",
      "type": "string",
      "description": "Queue ID (path parameter).",
      "required": true,
      "example": "queue_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.trigger.dev/api/v3/queues/queue_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "queue_abc",
      "name": "default",
      "concurrencyLimit": 10,
      "paused": false
    }
  }
}