{
  "name": "run_metadata_update",
  "description": "Update metadata key-value pairs on a run.",
  "resource_group": "run",
  "endpoint": "/api/v3/runs/{runId}/metadata",
  "method": "PATCH",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123"
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Metadata key-value pairs to set.",
      "required": true,
      "example": {
        "customer_id": "cust_123"
      }
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.trigger.dev/api/v3/runs/run_abc123/metadata",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "metadata": {
        "customer_id": "cust_123"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "run_abc123",
      "metadata": {
        "customer_id": "cust_123"
      }
    }
  }
}