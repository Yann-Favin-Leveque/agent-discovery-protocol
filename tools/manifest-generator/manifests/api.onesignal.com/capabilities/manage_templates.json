{
  "name": "manage_templates",
  "description": "Create, update, and manage reusable message templates for notifications, emails, and SMS. Templates save time when sending similar messages repeatedly.",
  "endpoint": "/templates",
  "method": "POST",
  "parameters": [
    { "name": "app_id", "type": "string", "description": "Your OneSignal App ID.", "required": true, "example": "5eb5a37e-b458-11e3-ac11-000c2940e62c" },
    { "name": "name", "type": "string", "description": "Template name.", "required": true, "example": "Welcome Email" },
    { "name": "contents", "type": "object", "description": "Message content by language.", "required": true, "example": { "en": "Welcome to our app! Get started here." } },
    { "name": "headings", "type": "object", "description": "Message headings by language.", "required": false, "example": { "en": "Welcome!" } }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.onesignal.com/templates",
    "headers": { "Authorization": "Basic {rest_api_key}", "Content-Type": "application/json" },
    "body": {
      "app_id": "5eb5a37e-b458-11e3-ac11-000c2940e62c",
      "name": "Welcome Email",
      "contents": { "en": "Welcome to our app!" },
      "headings": { "en": "Welcome!" }
    }
  },
  "response_example": {
    "status": 201,
    "body": { "id": "tmpl_xyz789", "name": "Welcome Email" }
  }
}
