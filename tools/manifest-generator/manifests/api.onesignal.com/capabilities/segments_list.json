{
  "name": "segments_list",
  "description": "List all segments for an app.",
  "resource_group": "segments",
  "endpoint": "/api/v1/apps/{app_id}/segments",
  "method": "GET",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "required": true,
      "description": "App ID.",
      "in": "path"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Pagination offset.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.onesignal.com/api/v1/apps/app-uuid/segments",
    "headers": {
      "Authorization": "Basic <rest_api_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 5,
      "offset": 0,
      "limit": 50,
      "segments": [
        {
          "id": "seg-uuid",
          "name": "Premium Users",
          "is_active": true
        }
      ]
    }
  }
}
