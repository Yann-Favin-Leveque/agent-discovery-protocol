{
  "name": "apps_list",
  "description": "List all OneSignal apps for the authenticated account.",
  "resource_group": "apps",
  "endpoint": "/api/v1/apps",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.onesignal.com/api/v1/apps",
    "headers": {
      "Authorization": "Basic <user_auth_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "app-uuid",
        "name": "My App",
        "players": 10000,
        "messageable_players": 9500,
        "created_at": "2024-01-01T00:00:00Z"
      }
    ]
  }
}