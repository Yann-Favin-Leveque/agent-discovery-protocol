{
  "name": "templates_list",
  "description": "List all message templates for an app.",
  "resource_group": "templates",
  "endpoint": "/api/v1/apps/{app_id}/templates",
  "method": "GET",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "required": true,
      "description": "App ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.onesignal.com/api/v1/apps/app-uuid/templates",
    "headers": {
      "Authorization": "Basic <rest_api_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "templates": [
        {
          "id": "tmpl-uuid",
          "name": "Welcome Template"
        }
      ]
    }
  }
}