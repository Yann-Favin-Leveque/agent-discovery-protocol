{
  "name": "send_notification",
  "description": "Send push notifications, emails, or SMS to specific users, segments, or all subscribers. Supports rich content, action buttons, scheduling, and multi-language targeting.",
  "endpoint": "/notifications",
  "method": "POST",
  "parameters": [
    { "name": "app_id", "type": "string", "description": "Your OneSignal App ID.", "required": true, "example": "5eb5a37e-b458-11e3-ac11-000c2940e62c" },
    { "name": "included_segments", "type": "array", "description": "Segments to target (e.g., ['Active Users', 'Subscribed Users']).", "required": false, "example": ["Subscribed Users"] },
    { "name": "include_aliases", "type": "object", "description": "Target specific users by alias.", "required": false, "example": { "external_id": ["user_123"] } },
    { "name": "contents", "type": "object", "description": "Notification content by language.", "required": true, "example": { "en": "Hello! Check out our new feature." } },
    { "name": "headings", "type": "object", "description": "Notification title by language.", "required": false, "example": { "en": "New Feature Available" } },
    { "name": "url", "type": "string", "description": "URL to open when notification is clicked.", "required": false, "example": "https://example.com/feature" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.onesignal.com/notifications",
    "headers": { "Authorization": "Basic {rest_api_key}", "Content-Type": "application/json" },
    "body": {
      "app_id": "5eb5a37e-b458-11e3-ac11-000c2940e62c",
      "included_segments": ["Subscribed Users"],
      "contents": { "en": "Hello! Check out our new feature." },
      "headings": { "en": "New Feature Available" },
      "url": "https://example.com/feature"
    }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "458dcec4-cf53-11e3-add2-000c2940e62c", "recipients": 15000, "external_id": null }
  }
}
