{
  "name": "manage_users",
  "description": "Create, update, and manage user profiles and their subscriptions (push, email, SMS). Users can have multiple aliases and subscriptions across channels.",
  "endpoint": "/apps/{app_id}/users",
  "method": "POST",
  "parameters": [
    { "name": "app_id", "type": "string", "description": "Your OneSignal App ID.", "required": true, "example": "5eb5a37e-b458-11e3-ac11-000c2940e62c" },
    { "name": "identity", "type": "object", "description": "User identity aliases.", "required": true, "example": { "external_id": "user_123" } },
    { "name": "properties", "type": "object", "description": "User properties like tags, language, timezone.", "required": false, "example": { "tags": { "plan": "premium" }, "language": "en" } },
    { "name": "subscriptions", "type": "array", "description": "User subscriptions (push tokens, email, phone).", "required": false, "example": [{ "type": "Email", "token": "user@example.com" }] }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.onesignal.com/apps/5eb5a37e-b458-11e3-ac11-000c2940e62c/users",
    "headers": { "Authorization": "Basic {rest_api_key}", "Content-Type": "application/json" },
    "body": {
      "identity": { "external_id": "user_123" },
      "properties": { "tags": { "plan": "premium" } },
      "subscriptions": [{ "type": "Email", "token": "user@example.com" }]
    }
  },
  "response_example": {
    "status": 201,
    "body": { "identity": { "external_id": "user_123", "onesignal_id": "abc-def-123" } }
  }
}
