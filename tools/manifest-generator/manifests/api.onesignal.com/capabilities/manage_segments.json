{
  "name": "manage_segments",
  "description": "Create and delete user segments based on filters. Segments group users by attributes like tags, session count, location, and more for targeted messaging.",
  "endpoint": "/apps/{app_id}/segments",
  "method": "POST",
  "parameters": [
    { "name": "app_id", "type": "string", "description": "Your OneSignal App ID.", "required": true, "example": "5eb5a37e-b458-11e3-ac11-000c2940e62c" },
    { "name": "name", "type": "string", "description": "Segment name.", "required": true, "example": "Premium Users" },
    { "name": "filters", "type": "array", "description": "Array of filter rules.", "required": true, "example": [{ "field": "tag", "key": "plan", "relation": "=", "value": "premium" }] }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.onesignal.com/apps/5eb5a37e-b458-11e3-ac11-000c2940e62c/segments",
    "headers": { "Authorization": "Basic {rest_api_key}", "Content-Type": "application/json" },
    "body": { "name": "Premium Users", "filters": [{ "field": "tag", "key": "plan", "relation": "=", "value": "premium" }] }
  },
  "response_example": {
    "status": 201,
    "body": { "success": true, "id": "seg_abc123" }
  }
}
