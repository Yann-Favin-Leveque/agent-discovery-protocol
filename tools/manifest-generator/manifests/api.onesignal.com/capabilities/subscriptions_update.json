{
  "name": "subscriptions_update",
  "description": "Update a subscription's properties.",
  "resource_group": "subscriptions",
  "endpoint": "/api/v1/subscriptions/{subscription_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "subscription_id",
      "type": "string",
      "required": true,
      "description": "Subscription ID.",
      "in": "path"
    },
    {
      "name": "subscription",
      "type": "object",
      "required": true,
      "description": "Updated subscription properties.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.onesignal.com/api/v1/subscriptions/sub-uuid",
    "headers": {
      "Authorization": "Basic <rest_api_key>",
      "Content-Type": "application/json"
    },
    "body": {
      "subscription": {
        "enabled": false
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscription": {
        "id": "sub-uuid",
        "enabled": false
      }
    }
  }
}
