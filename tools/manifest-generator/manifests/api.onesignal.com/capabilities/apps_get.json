{
  "name": "apps_get",
  "description": "View details of a single app.",
  "resource_group": "apps",
  "endpoint": "/api/v1/apps/{app_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "required": true,
      "description": "App ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.onesignal.com/api/v1/apps/app-uuid",
    "headers": {
      "Authorization": "Basic <user_auth_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "app-uuid",
      "name": "My App",
      "players": 10000,
      "messageable_players": 9500
    }
  }
}