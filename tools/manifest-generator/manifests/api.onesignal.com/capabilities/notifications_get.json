{
  "name": "notifications_get",
  "description": "Retrieve details and analytics for a sent notification.",
  "resource_group": "notifications",
  "endpoint": "/api/v1/notifications/{notification_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "notification_id",
      "type": "string",
      "required": true,
      "description": "Notification ID.",
      "in": "path"
    },
    {
      "name": "app_id",
      "type": "string",
      "required": true,
      "description": "App ID (query parameter).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.onesignal.com/api/v1/notifications/notif-uuid?app_id=app-uuid",
    "headers": {
      "Authorization": "Basic <rest_api_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "notif-uuid",
      "contents": {
        "en": "Hello World!"
      },
      "headings": {
        "en": "Welcome"
      },
      "successful": 950,
      "failed": 50,
      "converted": 100,
      "remaining": 0,
      "queued_at": 1718841600,
      "completed_at": 1718841660
    }
  }
}
