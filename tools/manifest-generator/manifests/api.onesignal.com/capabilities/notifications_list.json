{
  "name": "notifications_list",
  "description": "List sent notifications for an app with pagination.",
  "resource_group": "notifications",
  "endpoint": "/api/v1/notifications",
  "method": "GET",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "required": true,
      "description": "App ID."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page (max 50)."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Pagination offset."
    },
    {
      "name": "kind",
      "type": "integer",
      "required": false,
      "description": "Notification kind filter."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.onesignal.com/api/v1/notifications?app_id=app-uuid&limit=10",
    "headers": {
      "Authorization": "Basic <rest_api_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 100,
      "offset": 0,
      "limit": 10,
      "notifications": [
        {
          "id": "notif-uuid",
          "contents": {
            "en": "Hello"
          },
          "successful": 950
        }
      ]
    }
  }
}