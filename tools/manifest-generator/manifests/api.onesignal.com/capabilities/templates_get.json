{
  "name": "templates_get",
  "description": "Retrieve a specific template by ID.",
  "resource_group": "templates",
  "endpoint": "/api/v1/apps/{app_id}/templates/{template_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "required": true,
      "description": "App ID."
    },
    {
      "name": "template_id",
      "type": "string",
      "required": true,
      "description": "Template ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.onesignal.com/api/v1/apps/app-uuid/templates/tmpl-uuid",
    "headers": {
      "Authorization": "Basic <rest_api_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tmpl-uuid",
      "name": "Welcome Template",
      "contents": {
        "en": "Welcome!"
      }
    }
  }
}