{
  "name": "notifications_cancel",
  "description": "Cancel a scheduled or currently sending notification.",
  "resource_group": "notifications",
  "endpoint": "/api/v1/notifications/{notification_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "notification_id",
      "type": "string",
      "required": true,
      "description": "Notification ID to cancel.",
      "in": "path"
    },
    {
      "name": "app_id",
      "type": "string",
      "required": true,
      "description": "App ID (query parameter).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.onesignal.com/api/v1/notifications/notif-uuid?app_id=app-uuid",
    "headers": {
      "Authorization": "Basic <rest_api_key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}
