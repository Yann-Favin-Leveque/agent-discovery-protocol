{
  "name": "tags_get",
  "description": "Get details of a specific tag.",
  "resource_group": "tags",
  "endpoint": "/repositories/{namespace}/{repository}/tags/{tag}/",
  "method": "GET",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace.",
      "in": "path"
    },
    {
      "name": "repository",
      "type": "string",
      "required": true,
      "description": "Repository.",
      "in": "path"
    },
    {
      "name": "tag",
      "type": "string",
      "required": true,
      "description": "Tag name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/repositories/my-org/my-app/tags/latest/"
  },
  "response_example": {
    "name": "latest",
    "full_size": 50000000,
    "last_updated": "2026-01-20T14:00:00Z",
    "images": [
      {
        "architecture": "amd64",
        "os": "linux",
        "digest": "sha256:abc123",
        "size": 50000000
      }
    ]
  }
}
