{
  "name": "delete_tag",
  "description": "Delete a specific tag from a Docker Hub repository.",
  "endpoint": "/repositories/{namespace}/{repository}/tags/{tag}/",
  "method": "DELETE",
  "parameters": [
    {"name": "namespace", "type": "string", "description": "Repository namespace.", "required": true, "example": "myorg"},
    {"name": "repository", "type": "string", "description": "Repository name.", "required": true, "example": "my-app"},
    {"name": "tag", "type": "string", "description": "Tag name to delete.", "required": true, "example": "v1.0.0-beta"}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://hub.docker.com/v2/repositories/myorg/my-app/tags/v1.0.0-beta/",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
