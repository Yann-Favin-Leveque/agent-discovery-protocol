{
  "name": "webhooks_list",
  "description": "List webhooks for a repository.",
  "resource_group": "webhooks",
  "endpoint": "/repositories/{namespace}/{repository}/webhooks/",
  "method": "GET",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace."
    },
    {
      "name": "repository",
      "type": "string",
      "required": true,
      "description": "Repository."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/repositories/my-org/my-app/webhooks/"
  },
  "response_example": {
    "count": 1,
    "results": [
      {
        "id": "wh-abc",
        "name": "deploy-hook",
        "hook_url": "https://example.com/hook",
        "active": true
      }
    ]
  }
}