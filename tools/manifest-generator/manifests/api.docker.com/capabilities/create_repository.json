{
  "name": "create_repository",
  "description": "Create a new repository in a user or organization namespace on Docker Hub.",
  "endpoint": "/repositories/{namespace}/",
  "method": "POST",
  "parameters": [
    {"name": "namespace", "type": "string", "description": "Docker Hub username or organization.", "required": true, "example": "myorg"},
    {"name": "name", "type": "string", "description": "Repository name.", "required": true, "example": "my-app"},
    {"name": "description", "type": "string", "description": "Short description of the repository.", "required": false, "example": "My application container image"},
    {"name": "is_private", "type": "boolean", "description": "Whether the repository is private.", "required": false, "example": false}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://hub.docker.com/v2/repositories/myorg/",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"name": "my-app", "description": "My application container image", "is_private": false}
  },
  "response_example": {
    "status": 201,
    "body": {"name": "my-app", "namespace": "myorg", "description": "My application container image", "is_private": false, "last_updated": "2024-01-20T10:00:00Z"}
  }
}
