{
  "name": "get_repository_details",
  "description": "Get detailed information about a Docker Hub repository including description, pull count, and star count.",
  "endpoint": "/repositories/{namespace}/{repository}/",
  "method": "GET",
  "parameters": [
    {"name": "namespace", "type": "string", "description": "Repository namespace.", "required": true, "example": "library"},
    {"name": "repository", "type": "string", "description": "Repository name.", "required": true, "example": "nginx"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/repositories/library/nginx/",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"name": "nginx", "namespace": "library", "description": "Official build of Nginx.", "full_description": "# Quick reference...", "star_count": 18000, "pull_count": 5000000000, "last_updated": "2024-01-20T10:00:00Z", "is_private": false}
  }
}
