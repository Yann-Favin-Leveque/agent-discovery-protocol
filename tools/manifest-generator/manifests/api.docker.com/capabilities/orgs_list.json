{
  "name": "orgs_list",
  "description": "List organizations the user belongs to.",
  "resource_group": "organizations",
  "endpoint": "/user/orgs/",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page.",
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "description": "Page size.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/user/orgs/"
  },
  "response_example": {
    "count": 2,
    "results": [
      {
        "orgname": "my-org",
        "full_name": "My Organization",
        "date_joined": "2025-01-01T00:00:00Z"
      }
    ]
  }
}
