{
  "name": "user_get",
  "description": "Get authenticated user info.",
  "resource_group": "user",
  "endpoint": "/users/{username}/",
  "method": "GET",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "required": true,
      "description": "Username."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/users/myuser/"
  },
  "response_example": {
    "id": "user-abc",
    "username": "myuser",
    "full_name": "John Doe",
    "date_joined": "2025-01-01T00:00:00Z"
  }
}