{
  "name": "webhooks_create",
  "description": "Create a webhook for a repository.",
  "resource_group": "webhooks",
  "endpoint": "/repositories/{namespace}/{repository}/webhooks/",
  "method": "POST",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace.",
      "in": "path"
    },
    {
      "name": "repository",
      "type": "string",
      "required": true,
      "description": "Repository.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Webhook name.",
      "in": "body"
    },
    {
      "name": "hook_url",
      "type": "string",
      "required": true,
      "description": "Webhook URL.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://hub.docker.com/v2/repositories/my-org/my-app/webhooks/",
    "body": {
      "name": "deploy",
      "hook_url": "https://example.com/hook"
    }
  },
  "response_example": {
    "id": "wh-new",
    "name": "deploy",
    "hook_url": "https://example.com/hook",
    "active": true
  }
}
