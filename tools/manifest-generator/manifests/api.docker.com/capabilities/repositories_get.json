{
  "name": "repositories_get",
  "description": "Get repository details.",
  "resource_group": "repositories",
  "endpoint": "/repositories/{namespace}/{repository}/",
  "method": "GET",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace.",
      "in": "path"
    },
    {
      "name": "repository",
      "type": "string",
      "required": true,
      "description": "Repository name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/repositories/my-org/my-app/"
  },
  "response_example": {
    "name": "my-app",
    "namespace": "my-org",
    "description": "My application",
    "star_count": 10,
    "pull_count": 5000,
    "is_private": false,
    "last_updated": "2026-01-20T14:00:00Z"
  }
}
