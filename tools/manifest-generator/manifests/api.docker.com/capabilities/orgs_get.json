{
  "name": "orgs_get",
  "description": "Get organization details.",
  "resource_group": "organizations",
  "endpoint": "/orgs/{orgname}/",
  "method": "GET",
  "parameters": [
    {
      "name": "orgname",
      "type": "string",
      "required": true,
      "description": "Organization name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/orgs/my-org/"
  },
  "response_example": {
    "orgname": "my-org",
    "full_name": "My Organization",
    "date_joined": "2025-01-01T00:00:00Z"
  }
}