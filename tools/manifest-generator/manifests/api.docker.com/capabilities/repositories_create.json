{
  "name": "repositories_create",
  "description": "Create a new repository.",
  "resource_group": "repositories",
  "endpoint": "/repositories/{namespace}/",
  "method": "POST",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Repository name."
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Description."
    },
    {
      "name": "is_private",
      "type": "boolean",
      "required": false,
      "description": "Private repository."
    },
    {
      "name": "full_description",
      "type": "string",
      "required": false,
      "description": "Full README markdown."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://hub.docker.com/v2/repositories/my-org/",
    "body": {
      "name": "new-repo",
      "description": "A new repo",
      "is_private": false
    }
  },
  "response_example": {
    "name": "new-repo",
    "namespace": "my-org",
    "description": "A new repo"
  }
}