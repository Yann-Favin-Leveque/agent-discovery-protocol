{
  "name": "orgs_members_list",
  "description": "List organization members.",
  "resource_group": "organizations",
  "endpoint": "/orgs/{orgname}/members/",
  "method": "GET",
  "parameters": [
    {
      "name": "orgname",
      "type": "string",
      "required": true,
      "description": "Organization name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://hub.docker.com/v2/orgs/my-org/members/"
  },
  "response_example": {
    "count": 3,
    "results": [
      {
        "username": "john",
        "full_name": "John Doe",
        "is_admin": true
      }
    ]
  }
}
