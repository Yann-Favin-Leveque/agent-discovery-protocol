{
  "name": "tags_delete",
  "description": "Delete a tag from a repository.",
  "resource_group": "tags",
  "endpoint": "/repositories/{namespace}/{repository}/tags/{tag}/",
  "method": "DELETE",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace."
    },
    {
      "name": "repository",
      "type": "string",
      "required": true,
      "description": "Repository."
    },
    {
      "name": "tag",
      "type": "string",
      "required": true,
      "description": "Tag to delete."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://hub.docker.com/v2/repositories/my-org/my-app/tags/old-tag/"
  },
  "response_example": null
}