{
  "name": "webhooks_delete",
  "description": "Delete a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/repositories/{namespace}/{repository}/webhooks/{webhook_id}/",
  "method": "DELETE",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace."
    },
    {
      "name": "repository",
      "type": "string",
      "required": true,
      "description": "Repository."
    },
    {
      "name": "webhook_id",
      "type": "string",
      "required": true,
      "description": "Webhook ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://hub.docker.com/v2/repositories/my-org/my-app/webhooks/wh-abc/"
  },
  "response_example": null
}