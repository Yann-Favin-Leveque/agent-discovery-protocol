{
  "name": "repositories_update",
  "description": "Update repository details.",
  "resource_group": "repositories",
  "endpoint": "/repositories/{namespace}/{repository}/",
  "method": "PATCH",
  "parameters": [
    {
      "name": "namespace",
      "type": "string",
      "required": true,
      "description": "Namespace."
    },
    {
      "name": "repository",
      "type": "string",
      "required": true,
      "description": "Repository."
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Short description."
    },
    {
      "name": "full_description",
      "type": "string",
      "required": false,
      "description": "Full README."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://hub.docker.com/v2/repositories/my-org/my-app/",
    "body": {
      "description": "Updated description"
    }
  },
  "response_example": {
    "name": "my-app",
    "description": "Updated description"
  }
}