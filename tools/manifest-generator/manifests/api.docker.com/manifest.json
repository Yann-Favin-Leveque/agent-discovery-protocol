{
  "spec_version": "1.0",
  "name": "Docker Hub",
  "description": "Docker Hub is the world's largest container image registry. Search, manage, and distribute container images, repositories, tags, and organizations.",
  "base_url": "https://hub.docker.com/v2",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://hub.docker.com/settings/security"
  },
  "capabilities": [
    {
      "name": "images_search",
      "resource_group": "images",
      "description": "Search Docker Hub for container images.",
      "detail_url": "/capabilities/images_search"
    },
    {
      "name": "repositories_list",
      "resource_group": "repositories",
      "description": "List repositories for a namespace.",
      "detail_url": "/capabilities/repositories_list"
    },
    {
      "name": "repositories_get",
      "resource_group": "repositories",
      "description": "Get repository details.",
      "detail_url": "/capabilities/repositories_get"
    },
    {
      "name": "repositories_create",
      "resource_group": "repositories",
      "description": "Create a new repository.",
      "detail_url": "/capabilities/repositories_create"
    },
    {
      "name": "repositories_update",
      "resource_group": "repositories",
      "description": "Update repository details.",
      "detail_url": "/capabilities/repositories_update"
    },
    {
      "name": "repositories_delete",
      "resource_group": "repositories",
      "description": "Delete a repository.",
      "detail_url": "/capabilities/repositories_delete"
    },
    {
      "name": "tags_list",
      "resource_group": "tags",
      "description": "List tags for a repository.",
      "detail_url": "/capabilities/tags_list"
    },
    {
      "name": "tags_get",
      "resource_group": "tags",
      "description": "Get details of a specific tag.",
      "detail_url": "/capabilities/tags_get"
    },
    {
      "name": "tags_delete",
      "resource_group": "tags",
      "description": "Delete a tag from a repository.",
      "detail_url": "/capabilities/tags_delete"
    },
    {
      "name": "user_get",
      "resource_group": "user",
      "description": "Get authenticated user info.",
      "detail_url": "/capabilities/user_get"
    },
    {
      "name": "orgs_list",
      "resource_group": "organizations",
      "description": "List organizations the user belongs to.",
      "detail_url": "/capabilities/orgs_list"
    },
    {
      "name": "orgs_get",
      "resource_group": "organizations",
      "description": "Get organization details.",
      "detail_url": "/capabilities/orgs_get"
    },
    {
      "name": "orgs_members_list",
      "resource_group": "organizations",
      "description": "List organization members.",
      "detail_url": "/capabilities/orgs_members_list"
    },
    {
      "name": "webhooks_list",
      "resource_group": "webhooks",
      "description": "List webhooks for a repository.",
      "detail_url": "/capabilities/webhooks_list"
    },
    {
      "name": "webhooks_create",
      "resource_group": "webhooks",
      "description": "Create a webhook for a repository.",
      "detail_url": "/capabilities/webhooks_create"
    },
    {
      "name": "webhooks_delete",
      "resource_group": "webhooks",
      "description": "Delete a webhook.",
      "detail_url": "/capabilities/webhooks_delete"
    }
  ]
}