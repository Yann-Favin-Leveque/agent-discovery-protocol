{
  "name": "passwords_list",
  "resource_group": "passwords",
  "description": "List all connection passwords for a database branch.",
  "endpoint": "/organizations/{organization}/databases/{database}/branches/{branch}/passwords",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "branch",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/branches/main/passwords",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "pw-123",
          "name": "app-password",
          "role": "readwriter"
        }
      ]
    }
  }
}