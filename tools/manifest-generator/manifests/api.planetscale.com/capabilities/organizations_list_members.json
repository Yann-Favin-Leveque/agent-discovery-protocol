{
  "name": "organizations_list_members",
  "resource_group": "organizations",
  "description": "List members of an organization.",
  "endpoint": "/organizations/{organization}/members",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme/members",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "mem-123",
          "email": "john@acme.com",
          "role": "admin"
        }
      ]
    }
  }
}