{
  "name": "webhooks_test",
  "resource_group": "webhooks",
  "description": "Send a test event to a webhook endpoint.",
  "endpoint": "/organizations/{organization}/databases/{database}/webhooks/{webhook_id}/test",
  "method": "POST",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "webhook_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Webhook ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/webhooks/wh-123/test",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "delivered": true
    }
  }
}