{
  "name": "deploy_queue_get",
  "resource_group": "deploy_requests",
  "description": "Get the current deploy queue for a database.",
  "endpoint": "/organizations/{organization}/databases/{database}/deploy-queue",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/deploy-queue",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": []
    }
  }
}