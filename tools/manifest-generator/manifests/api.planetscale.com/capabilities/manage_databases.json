{
  "name": "manage_databases",
  "description": "Create, list, get, and delete databases in your PlanetScale organization. Use this to provision new MySQL-compatible databases or inspect existing ones.",
  "endpoint": "/v1/organizations/{organization}/databases",
  "method": "GET",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name.", "required": true, "example": "my-org" },
    { "name": "page", "type": "number", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "number", "description": "Number of results per page.", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/my-org/databases",
    "headers": { "Authorization": "Bearer {access_token}", "Content-Type": "application/json" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        { "id": "db_123", "name": "my-database", "region": { "slug": "us-east" }, "created_at": "2024-01-15T10:00:00Z", "state": "ready" }
      ]
    }
  }
}
