{
  "name": "branches_promote",
  "resource_group": "branches",
  "description": "Promote a development branch to production status.",
  "endpoint": "/organizations/{organization}/databases/{database}/branches/{branch}/promote",
  "method": "POST",
  "parameters": [
    {"name": "organization", "type": "string", "required": true, "in": "path", "description": "Organization name slug."},
    {"name": "database", "type": "string", "required": true, "in": "path", "description": "Database name."},
    {"name": "branch", "type": "string", "required": true, "in": "path", "description": "Branch name to promote."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/branches/main/promote",
    "headers": {"Authorization": "Bearer {access_token}"}
  },
  "response_example": {"status": 200, "body": {"id": "br-123", "name": "main", "production": true}}
}
