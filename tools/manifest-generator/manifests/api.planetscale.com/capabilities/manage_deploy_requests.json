{
  "name": "manage_deploy_requests",
  "description": "Create, review, and deploy schema change requests between branches. Deploy requests are how schema changes move from development branches to production safely.",
  "endpoint": "/v1/organizations/{organization}/databases/{database}/deploy-requests",
  "method": "POST",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name.", "required": true, "example": "my-org" },
    { "name": "database", "type": "string", "description": "The database name.", "required": true, "example": "my-database" },
    { "name": "branch", "type": "string", "description": "The source branch name.", "required": true, "example": "add-users-table" },
    { "name": "into_branch", "type": "string", "description": "The target branch to deploy into.", "required": false, "example": "main" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.planetscale.com/v1/organizations/my-org/databases/my-database/deploy-requests",
    "headers": { "Authorization": "Bearer {access_token}", "Content-Type": "application/json" },
    "body": { "branch": "add-users-table", "into_branch": "main" }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "dr_789",
      "branch": "add-users-table",
      "into_branch": "main",
      "state": "open",
      "created_at": "2024-02-05T14:00:00Z"
    }
  }
}
