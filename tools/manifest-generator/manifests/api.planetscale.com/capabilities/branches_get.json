{
  "name": "branches_get",
  "resource_group": "branches",
  "description": "Retrieve details of a specific database branch.",
  "endpoint": "/organizations/{organization}/databases/{database}/branches/{branch}",
  "method": "GET",
  "parameters": [
    {"name": "organization", "type": "string", "required": true, "in": "path", "description": "Organization name slug."},
    {"name": "database", "type": "string", "required": true, "in": "path", "description": "Database name."},
    {"name": "branch", "type": "string", "required": true, "in": "path", "description": "Branch name."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/branches/main",
    "headers": {"Authorization": "Bearer {access_token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "br-123", "name": "main", "state": "ready", "production": true, "parent_branch": null, "created_at": "2024-01-10T00:00:00Z"}
  }
}
