{
  "name": "organizations_get",
  "resource_group": "organizations",
  "description": "Retrieve details of a specific organization.",
  "endpoint": "/organizations/{organization}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "org-123",
      "name": "acme"
    }
  }
}