{
  "name": "databases_delete",
  "resource_group": "databases",
  "description": "Permanently delete a database and all its branches, deploy requests, and passwords.",
  "endpoint": "/organizations/{organization}/databases/{database}",
  "method": "DELETE",
  "parameters": [
    {"name": "organization", "type": "string", "required": true, "in": "path", "description": "Organization name slug."},
    {"name": "database", "type": "string", "required": true, "in": "path", "description": "Database name."}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-database",
    "headers": {"Authorization": "Bearer {access_token}"}
  },
  "response_example": {"status": 204, "body": null}
}
