{
  "name": "backups_delete",
  "resource_group": "backups",
  "description": "Delete a database backup.",
  "endpoint": "/organizations/{organization}/databases/{database}/branches/{branch}/backups/{backup_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "branch",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch name."
    },
    {
      "name": "backup_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Backup ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/branches/main/backups/bk-123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}