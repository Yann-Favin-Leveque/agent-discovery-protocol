{
  "name": "passwords_create",
  "resource_group": "passwords",
  "description": "Create a new connection password for a database branch. The plain text password is only returned once.",
  "endpoint": "/organizations/{organization}/databases/{database}/branches/{branch}/passwords",
  "method": "POST",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "branch",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch name."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Password display name."
    },
    {
      "name": "role",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Password role: readwriter, reader, or admin."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/branches/main/passwords",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "app-password",
      "role": "readwriter"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "pw-456",
      "name": "app-password",
      "plain_text": "pscale_pw_abc123...",
      "hostname": "aws.connect.psdb.cloud",
      "username": "abc123def456"
    }
  }
}