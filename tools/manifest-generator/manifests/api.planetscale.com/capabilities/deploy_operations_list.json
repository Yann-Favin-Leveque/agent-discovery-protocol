{
  "name": "deploy_operations_list",
  "resource_group": "deploy_requests",
  "description": "List deploy operations for a specific deploy request.",
  "endpoint": "/organizations/{organization}/databases/{database}/deploy-requests/{number}/operations",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "number",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Deploy request number."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/deploy-requests/1/operations",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "op-123",
          "state": "complete",
          "operation_type": "alter_table"
        }
      ]
    }
  }
}