{
  "name": "webhooks_delete",
  "resource_group": "webhooks",
  "description": "Delete a webhook.",
  "endpoint": "/organizations/{organization}/databases/{database}/webhooks/{webhook_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "webhook_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Webhook ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/webhooks/wh-123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}