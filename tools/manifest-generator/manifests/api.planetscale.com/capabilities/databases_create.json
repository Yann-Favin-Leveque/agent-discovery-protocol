{
  "name": "databases_create",
  "resource_group": "databases",
  "description": "Create a new database in your PlanetScale organization with specified name, cluster size, and region.",
  "endpoint": "/organizations/{organization}/databases",
  "method": "POST",
  "parameters": [
    {"name": "organization", "type": "string", "required": true, "in": "path", "description": "Organization name slug.", "example": "acme"},
    {"name": "name", "type": "string", "required": true, "in": "body", "description": "Name of the database."},
    {"name": "cluster_size", "type": "string", "required": true, "in": "body", "description": "Database cluster size name (e.g., PS_10, PS_80)."},
    {"name": "region", "type": "string", "required": false, "in": "body", "description": "Region to deploy the database in. Defaults to organization default."},
    {"name": "kind", "type": "string", "required": false, "in": "body", "description": "Database type: mysql or postgresql."},
    {"name": "replicas", "type": "integer", "required": false, "in": "body", "description": "Number of replicas. 0 for non-HA, 2+ for HA."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases",
    "headers": {"Authorization": "Bearer {access_token}", "Content-Type": "application/json"},
    "body": {"name": "my-database", "cluster_size": "PS_10", "region": "us-east-1"}
  },
  "response_example": {
    "status": 201,
    "body": {"id": "db-abc123", "name": "my-database", "state": "pending", "kind": "mysql", "region": {"slug": "us-east-1"}, "ready": false, "created_at": "2024-06-15T10:00:00Z"}
  }
}
