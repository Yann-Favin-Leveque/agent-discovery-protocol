{
  "name": "manage_passwords",
  "description": "Create and manage connection passwords (credentials) for database branches. Passwords are used to connect to your PlanetScale databases from applications.",
  "endpoint": "/v1/organizations/{organization}/databases/{database}/branches/{branch}/passwords",
  "method": "POST",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name.", "required": true, "example": "my-org" },
    { "name": "database", "type": "string", "description": "The database name.", "required": true, "example": "my-database" },
    { "name": "branch", "type": "string", "description": "The branch name.", "required": true, "example": "main" },
    { "name": "role", "type": "string", "description": "The role for the password (reader, writer, readwriter, admin).", "required": false, "example": "readwriter" },
    { "name": "name", "type": "string", "description": "A display name for the password.", "required": false, "example": "production-app" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.planetscale.com/v1/organizations/my-org/databases/my-database/branches/main/passwords",
    "headers": { "Authorization": "Bearer {access_token}", "Content-Type": "application/json" },
    "body": { "role": "readwriter", "name": "production-app" }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "pw_abc",
      "name": "production-app",
      "role": "readwriter",
      "plain_text": "pscale_pw_xxxxxxxxxxxx",
      "connection_strings": {
        "general": "mysql://username:password@host:3306/my-database"
      }
    }
  }
}
