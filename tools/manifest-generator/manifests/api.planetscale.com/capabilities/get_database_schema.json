{
  "name": "get_database_schema",
  "description": "Retrieve the schema of a database branch including tables, columns, and indexes. Use this to inspect the current state of your database structure.",
  "endpoint": "/v1/organizations/{organization}/databases/{database}/branches/{branch}/schema",
  "method": "GET",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name.", "required": true, "example": "my-org" },
    { "name": "database", "type": "string", "description": "The database name.", "required": true, "example": "my-database" },
    { "name": "branch", "type": "string", "description": "The branch name.", "required": true, "example": "main" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/my-org/databases/my-database/branches/main/schema",
    "headers": { "Authorization": "Bearer {access_token}", "Content-Type": "application/json" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tables": [
        {
          "name": "users",
          "columns": [
            { "name": "id", "type": "bigint", "nullable": false },
            { "name": "email", "type": "varchar(255)", "nullable": false },
            { "name": "created_at", "type": "datetime", "nullable": false }
          ]
        }
      ]
    }
  }
}
