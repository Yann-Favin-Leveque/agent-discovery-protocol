{
  "name": "branches_disable_safe_migrations",
  "resource_group": "branches",
  "description": "Disable safe migrations on a branch to allow direct schema changes.",
  "endpoint": "/organizations/{organization}/databases/{database}/branches/{branch}/safe-migrations",
  "method": "DELETE",
  "parameters": [
    {"name": "organization", "type": "string", "required": true, "in": "path", "description": "Organization name slug."},
    {"name": "database", "type": "string", "required": true, "in": "path", "description": "Database name."},
    {"name": "branch", "type": "string", "required": true, "in": "path", "description": "Branch name."}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/branches/main/safe-migrations",
    "headers": {"Authorization": "Bearer {access_token}"}
  },
  "response_example": {"status": 200, "body": {"safe_migrations_enabled": false}}
}
