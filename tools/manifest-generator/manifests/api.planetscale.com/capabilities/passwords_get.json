{
  "name": "passwords_get",
  "resource_group": "passwords",
  "description": "Retrieve a specific connection password metadata.",
  "endpoint": "/organizations/{organization}/databases/{database}/branches/{branch}/passwords/{password_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "branch",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Branch name."
    },
    {
      "name": "password_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Password ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/branches/main/passwords/pw-123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pw-123",
      "name": "app-password",
      "role": "readwriter"
    }
  }
}