{
  "name": "webhooks_get",
  "resource_group": "webhooks",
  "description": "Retrieve details of a specific webhook.",
  "endpoint": "/organizations/{organization}/databases/{database}/webhooks/{webhook_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization name slug."
    },
    {
      "name": "database",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    },
    {
      "name": "webhook_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Webhook ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.planetscale.com/v1/organizations/acme/databases/my-db/webhooks/wh-123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "wh-123",
      "url": "https://example.com/webhook"
    }
  }
}