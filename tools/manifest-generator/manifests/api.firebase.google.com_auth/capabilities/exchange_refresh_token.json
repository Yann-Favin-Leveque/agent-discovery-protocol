{
  "name": "exchange_refresh_token",
  "description": "Exchange a refresh token for a new ID token. Use this to maintain user sessions when the ID token expires (default: 1 hour).",
  "endpoint": "/token",
  "method": "POST",
  "resource_group": "tokens",
  "parameters": [
    {
      "name": "grant_type",
      "type": "string",
      "description": "The grant type. Always 'refresh_token'.",
      "required": true,
      "example": "refresh_token"
    },
    {
      "name": "refresh_token",
      "type": "string",
      "description": "The refresh token to exchange.",
      "required": true,
      "example": "AEu4IL3..."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://securetoken.googleapis.com/v1/token?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "grant_type": "refresh_token",
      "refresh_token": "AEu4IL3..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "access_token": "eyJhbGciOiJSUzI1NiIs...",
      "expires_in": "3600",
      "token_type": "Bearer",
      "refresh_token": "AEu4IL3...",
      "id_token": "eyJhbGciOiJSUzI1NiIs...",
      "user_id": "ZY1rJK0eYLg...",
      "project_id": "my-firebase-project"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}