{
  "name": "link_email_password",
  "description": "Link an email/password credential to an existing user account (e.g., to upgrade an anonymous account). Requires the user's current ID token.",
  "endpoint": "/accounts:update",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "idToken",
      "type": "string",
      "description": "The ID token of the user to link to.",
      "required": true,
      "example": "eyJhbGciOiJSUzI1NiIs..."
    },
    {
      "name": "email",
      "type": "string",
      "description": "The email to link.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "password",
      "type": "string",
      "description": "The password for the new credential.",
      "required": true,
      "example": "securePassword123"
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "description": "Whether to return updated tokens.",
      "required": true,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:update?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "idToken": "eyJhbGciOiJSUzI1NiIs...",
      "email": "user@example.com",
      "password": "securePassword123",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "localId": "ZY1rJK0eYLg...",
      "email": "user@example.com",
      "idToken": "eyJhbGciOiJSUzI1NiIs...",
      "refreshToken": "AEu4IL3...",
      "expiresIn": "3600"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}