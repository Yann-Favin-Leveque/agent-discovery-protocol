{
  "name": "sign_in_email",
  "description": "Sign in an existing user with their email and password. Returns an ID token (JWT), refresh token, user's local ID, email, and whether the email has been verified. Returns an error if the credentials are invalid or the account is disabled.",
  "endpoint": "/accounts:signInWithPassword",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "password",
      "type": "string",
      "description": "The user's password.",
      "required": true,
      "example": "securepassword123"
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "description": "Whether to return an ID and refresh token. Should always be true.",
      "required": true,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=YOUR_API_KEY",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "password": "securepassword123",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "idToken": "eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...",
      "email": "user@example.com",
      "refreshToken": "AMf-vBx9kD8...",
      "expiresIn": "3600",
      "localId": "a1b2c3d4e5f67890",
      "registered": true,
      "displayName": "",
      "emailVerified": false
    }
  }
}
