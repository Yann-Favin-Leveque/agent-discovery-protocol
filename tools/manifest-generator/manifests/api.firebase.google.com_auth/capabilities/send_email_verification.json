{
  "name": "send_email_verification",
  "description": "Send an email verification message to the authenticated user. Requires a valid ID token from a signed-in user.",
  "endpoint": "/accounts:sendOobCode",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "requestType",
      "type": "string",
      "description": "The type of OOB code. Use 'VERIFY_EMAIL'.",
      "required": true,
      "example": "VERIFY_EMAIL"
    },
    {
      "name": "idToken",
      "type": "string",
      "description": "The ID token of the user to verify.",
      "required": true,
      "example": "eyJhbGciOiJSUzI1NiIs..."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:sendOobCode?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "requestType": "VERIFY_EMAIL",
      "idToken": "eyJhbGciOiJSUzI1NiIs..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "kind": "identitytoolkit#GetOobConfirmationCodeResponse",
      "email": "user@example.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}