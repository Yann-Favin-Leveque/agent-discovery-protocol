{
  "name": "delete_account",
  "description": "Delete the authenticated user's account permanently. Requires the user's current ID token.",
  "endpoint": "/accounts:delete",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    {
      "name": "idToken",
      "type": "string",
      "description": "The ID token of the user to delete.",
      "required": true,
      "example": "eyJhbGciOiJSUzI1NiIs..."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:delete?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "idToken": "eyJhbGciOiJSUzI1NiIs..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "kind": "identitytoolkit#DeleteAccountResponse"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}