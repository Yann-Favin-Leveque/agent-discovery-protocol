{
  "name": "update_profile",
  "description": "Update the authenticated user's profile attributes including display name, photo URL, email, and password.",
  "endpoint": "/accounts:update",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    {
      "name": "idToken",
      "type": "string",
      "description": "The ID token of the authenticated user.",
      "required": true,
      "example": "eyJhbGciOiJSUzI1NiIs...",
      "in": "body"
    },
    {
      "name": "displayName",
      "type": "string",
      "description": "New display name.",
      "required": false,
      "example": "Jane Smith",
      "in": "body"
    },
    {
      "name": "photoUrl",
      "type": "string",
      "description": "New photo URL.",
      "required": false,
      "example": "https://example.com/new-photo.jpg",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "description": "New email address.",
      "required": false,
      "example": "newemail@example.com",
      "in": "body"
    },
    {
      "name": "password",
      "type": "string",
      "description": "New password (min 6 characters).",
      "required": false,
      "example": "newPassword123",
      "in": "body"
    },
    {
      "name": "deleteAttribute",
      "type": "array",
      "description": "Attributes to delete: DISPLAY_NAME, PHOTO_URL.",
      "required": false,
      "example": [
        "PHOTO_URL"
      ],
      "in": "body"
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "description": "Whether to return a new ID and refresh token.",
      "required": false,
      "example": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:update?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "idToken": "eyJhbGciOiJSUzI1NiIs...",
      "displayName": "Jane Smith",
      "photoUrl": "https://example.com/new-photo.jpg",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "localId": "ZY1rJK0eYLg...",
      "email": "user@example.com",
      "displayName": "Jane Smith",
      "photoUrl": "https://example.com/new-photo.jpg",
      "idToken": "eyJhbGciOiJSUzI1NiIs...",
      "refreshToken": "AEu4IL3...",
      "expiresIn": "3600"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
