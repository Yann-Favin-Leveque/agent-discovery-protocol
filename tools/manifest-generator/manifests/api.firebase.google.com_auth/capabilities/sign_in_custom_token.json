{
  "name": "sign_in_custom_token",
  "description": "Sign in using a custom token generated by your server with the Firebase Admin SDK. Returns a Firebase ID token and refresh token.",
  "endpoint": "/accounts:signInWithCustomToken",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "description": "The custom token generated by your server.",
      "required": true,
      "example": "eyJhbGciOiJSUzI1NiIs..."
    },
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "description": "Whether to return an ID and refresh token.",
      "required": true,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithCustomToken?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "token": "eyJhbGciOiJSUzI1NiIs...",
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "idToken": "eyJhbGciOiJSUzI1NiIs...",
      "refreshToken": "AEu4IL3...",
      "expiresIn": "3600"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}