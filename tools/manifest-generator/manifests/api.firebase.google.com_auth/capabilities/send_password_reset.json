{
  "name": "send_password_reset",
  "description": "Send a password reset email to the specified email address. The email contains a link for the user to set a new password.",
  "endpoint": "/accounts:sendOobCode",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "requestType",
      "type": "string",
      "description": "The type of OOB code to send. Use 'PASSWORD_RESET'.",
      "required": true,
      "example": "PASSWORD_RESET"
    },
    {
      "name": "email",
      "type": "string",
      "description": "The email address to send the password reset to.",
      "required": true,
      "example": "user@example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:sendOobCode?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "requestType": "PASSWORD_RESET",
      "email": "user@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "kind": "identitytoolkit#GetOobConfirmationCodeResponse",
      "email": "user@example.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}