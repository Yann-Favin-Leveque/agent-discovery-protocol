{
  "name": "confirm_email_verification",
  "description": "Confirm an email verification using the OOB code from the verification email. Marks the user's email as verified.",
  "endpoint": "/accounts:update",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "oobCode",
      "type": "string",
      "description": "The OOB code from the verification email.",
      "required": true,
      "example": "DEF456..."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:update?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "oobCode": "DEF456..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "localId": "ZY1rJK0eYLg...",
      "email": "user@example.com",
      "emailVerified": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}