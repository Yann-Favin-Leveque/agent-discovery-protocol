{
  "name": "sign_in_anonymous",
  "description": "Sign in anonymously without credentials. Creates a temporary anonymous user that can later be linked to a permanent account.",
  "endpoint": "/accounts:signUp",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "returnSecureToken",
      "type": "boolean",
      "description": "Whether to return an ID and refresh token.",
      "required": true,
      "example": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "returnSecureToken": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "idToken": "eyJhbGciOiJSUzI1NiIs...",
      "refreshToken": "AEu4IL3...",
      "expiresIn": "3600",
      "localId": "Anon1rJK0eY..."
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
