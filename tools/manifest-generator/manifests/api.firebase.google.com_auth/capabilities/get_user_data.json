{
  "name": "get_user_data",
  "description": "Retrieve profile information for the authenticated user. Returns email, display name, photo URL, provider info, and email verification status.",
  "endpoint": "/accounts:lookup",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    {
      "name": "idToken",
      "type": "string",
      "description": "The ID token of the authenticated user.",
      "required": true,
      "example": "eyJhbGciOiJSUzI1NiIs..."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:lookup?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "idToken": "eyJhbGciOiJSUzI1NiIs..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "kind": "identitytoolkit#GetAccountInfoResponse",
      "users": [
        {
          "localId": "ZY1rJK0eYLg...",
          "email": "user@example.com",
          "emailVerified": true,
          "displayName": "John Doe",
          "photoUrl": "https://example.com/photo.jpg",
          "providerUserInfo": [
            {"providerId": "password", "federatedId": "user@example.com", "email": "user@example.com"}
          ],
          "validSince": "1705420800",
          "lastLoginAt": "1705507200000",
          "createdAt": "1705420800000"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}