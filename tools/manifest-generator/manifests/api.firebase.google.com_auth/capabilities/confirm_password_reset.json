{
  "name": "confirm_password_reset",
  "description": "Confirm a password reset using the OOB code from the reset email. Sets the new password for the user.",
  "endpoint": "/accounts:resetPassword",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "oobCode",
      "type": "string",
      "description": "The OOB code from the password reset email.",
      "required": true,
      "example": "ABC123...",
      "in": "body"
    },
    {
      "name": "newPassword",
      "type": "string",
      "description": "The new password to set.",
      "required": true,
      "example": "newSecurePassword456",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://identitytoolkit.googleapis.com/v1/accounts:resetPassword?key=AIzaSy...",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "oobCode": "ABC123...",
      "newPassword": "newSecurePassword456"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "kind": "identitytoolkit#ResetPasswordResponse",
      "email": "user@example.com",
      "requestType": "PASSWORD_RESET"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
