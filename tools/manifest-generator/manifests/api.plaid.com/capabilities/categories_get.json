{
  "name": "categories_get",
  "description": "Get all transaction categories used by Plaid.",
  "resource_group": "transactions",
  "endpoint": "/categories/get",
  "method": "POST",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://production.plaid.com/categories/get",
    "headers": {
      "Content-Type": "application/json",
      "PLAID-CLIENT-ID": "your_client_id",
      "PLAID-SECRET": "your_secret"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "categories": [
        {
          "category_id": "10000000",
          "hierarchy": [
            "Bank Fees"
          ]
        },
        {
          "category_id": "10001000",
          "hierarchy": [
            "Bank Fees",
            "Overdraft"
          ]
        }
      ],
      "request_id": "abc"
    }
  }
}