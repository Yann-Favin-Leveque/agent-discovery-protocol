{
  "name": "auth_get",
  "description": "Retrieve bank account and routing numbers for ACH payments.",
  "resource_group": "auth",
  "endpoint": "/auth/get",
  "method": "POST",
  "parameters": [
    {
      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "The access token.",
      "in": "body"
    },
    {
      "name": "options",
      "type": "object",
      "required": false,
      "description": "Options with account_ids filter.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://production.plaid.com/auth/get",
    "headers": {
      "Content-Type": "application/json",
      "PLAID-CLIENT-ID": "your_client_id",
      "PLAID-SECRET": "your_secret"
    },
    "body": {
      "access_token": "access-production-abc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "numbers": {
        "ach": [
          {
            "account_id": "acc_abc",
            "account": "9876543210",
            "routing": "021000021"
          }
        ]
      },
      "request_id": "abc"
    }
  }
}
