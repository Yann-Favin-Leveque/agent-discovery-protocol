{
  "name": "item_remove",
  "description": "Remove an Item and revoke the access token.",
  "resource_group": "items",
  "endpoint": "/item/remove",
  "method": "POST",
  "parameters": [
    {
      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "The access token for the Item.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://production.plaid.com/item/remove",
    "headers": {
      "Content-Type": "application/json",
      "PLAID-CLIENT-ID": "your_client_id",
      "PLAID-SECRET": "your_secret"
    },
    "body": {
      "access_token": "access-production-abc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "request_id": "abc"
    }
  }
}
