{
  "name": "transfer_get",
  "description": "Retrieve information about a specific transfer.",
  "resource_group": "transfer",
  "endpoint": "/transfer/get",
  "method": "POST",
  "parameters": [
    {
      "name": "transfer_id",
      "type": "string",
      "required": true,
      "description": "The transfer ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://production.plaid.com/transfer/get",
    "headers": {
      "Content-Type": "application/json",
      "PLAID-CLIENT-ID": "your_client_id",
      "PLAID-SECRET": "your_secret"
    },
    "body": {
      "transfer_id": "xfer_abc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "transfer": {
        "id": "xfer_abc",
        "amount": "100.00",
        "status": "posted"
      },
      "request_id": "abc"
    }
  }
}
