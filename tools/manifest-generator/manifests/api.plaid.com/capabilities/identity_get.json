{
  "name": "identity_get",
  "description": "Retrieve identity info (names, emails, phones, addresses) from the institution.",
  "resource_group": "identity",
  "endpoint": "/identity/get",
  "method": "POST",
  "parameters": [
    {
      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "The access token."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://production.plaid.com/identity/get",
    "headers": {
      "Content-Type": "application/json",
      "PLAID-CLIENT-ID": "your_client_id",
      "PLAID-SECRET": "your_secret"
    },
    "body": {
      "access_token": "access-production-abc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "accounts": [
        {
          "account_id": "acc_abc",
          "owners": [
            {
              "names": [
                "John Doe"
              ],
              "emails": [
                {
                  "data": "john@example.com"
                }
              ],
              "phone_numbers": [
                {
                  "data": "555-1234"
                }
              ]
            }
          ]
        }
      ],
      "request_id": "abc"
    }
  }
}