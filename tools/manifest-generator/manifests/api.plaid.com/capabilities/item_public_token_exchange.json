{
  "name": "item_public_token_exchange",
  "description": "Exchange a public token from Link for an access token.",
  "resource_group": "items",
  "endpoint": "/item/public_token/exchange",
  "method": "POST",
  "parameters": [
    {
      "name": "public_token",
      "type": "string",
      "required": true,
      "description": "The public token from Plaid Link."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://production.plaid.com/item/public_token/exchange",
    "headers": {
      "Content-Type": "application/json",
      "PLAID-CLIENT-ID": "your_client_id",
      "PLAID-SECRET": "your_secret"
    },
    "body": {
      "public_token": "public-production-abc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "access_token": "access-production-abc",
      "item_id": "item_abc",
      "request_id": "abc"
    }
  }
}