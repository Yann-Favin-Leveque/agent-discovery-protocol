{
  "name": "documents_create",
  "resource_group": "documents",
  "description": "Create a new blank Google Docs document with the specified title.",
  "endpoint": "/v1/documents",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Title of the new document",
      "example": "Project Proposal",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://docs.googleapis.com/v1/documents",
    "headers": {
      "Authorization": "Bearer GOOGLE_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Project Proposal"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "documentId": "1BxiMVs0XRA5nFMdKvBdBZjgmUii_abc",
      "title": "Project Proposal",
      "body": {
        "content": [
          {
            "endIndex": 1,
            "sectionBreak": {
              "sectionStyle": {
                "columnSeparatorStyle": "NONE",
                "contentDirection": "LEFT_TO_RIGHT"
              }
            }
          }
        ]
      },
      "revisionId": "ALm37BWLBK_abc",
      "suggestionsViewMode": "SUGGESTIONS_INLINE"
    }
  }
}
