{
  "name": "documents_batch_update",
  "resource_group": "documents",
  "description": "Apply one or more updates to a document atomically. Supports inserting text, deleting content, formatting, creating tables, adding images, and more.",
  "endpoint": "/v1/documents/{documentId}:batchUpdate",
  "method": "POST",
  "parameters": [
    {
      "name": "documentId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "The ID of the document to update",
      "example": "1BxiMVs0XRA5nFMdKvBdBZjgmUii_abc"
    },
    {
      "name": "requests",
      "type": "array",
      "required": true,
      "description": "Array of update request objects (insertText, deleteContentRange, updateTextStyle, insertTable, insertInlineImage, replaceAllText, etc.)",
      "example": [
        {
          "insertText": {
            "location": {
              "index": 1
            },
            "text": "Hello World!\n"
          }
        },
        {
          "updateTextStyle": {
            "range": {
              "startIndex": 1,
              "endIndex": 13
            },
            "textStyle": {
              "bold": true
            },
            "fields": "bold"
          }
        }
      ],
      "in": "body"
    },
    {
      "name": "writeControl",
      "type": "object",
      "required": false,
      "description": "Write control for conflict handling",
      "example": {
        "requiredRevisionId": "ALm37BWLBK_abc"
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://docs.googleapis.com/v1/documents/1BxiMVs0XRA5nFMdKvBdBZjgmUii_abc:batchUpdate",
    "headers": {
      "Authorization": "Bearer GOOGLE_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "requests": [
        {
          "insertText": {
            "location": {
              "index": 1
            },
            "text": "Hello World!\n"
          }
        },
        {
          "updateTextStyle": {
            "range": {
              "startIndex": 1,
              "endIndex": 13
            },
            "textStyle": {
              "bold": true
            },
            "fields": "bold"
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "documentId": "1BxiMVs0XRA5nFMdKvBdBZjgmUii_abc",
      "replies": [
        {},
        {}
      ],
      "writeControl": {
        "requiredRevisionId": "ALm37BWLBK_xyz"
      }
    }
  }
}
