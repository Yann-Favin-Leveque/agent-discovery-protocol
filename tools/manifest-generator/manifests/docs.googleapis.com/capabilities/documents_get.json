{
  "name": "documents_get",
  "resource_group": "documents",
  "description": "Retrieve the latest version of a Google Docs document including all content, styling, and structure.",
  "endpoint": "/v1/documents/{documentId}",
  "method": "GET",
  "parameters": [
    {
      "name": "documentId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "The ID of the document to retrieve",
      "example": "1BxiMVs0XRA5nFMdKvBdBZjgmUii_abc"
    },
    {
      "name": "suggestionsViewMode",
      "type": "string",
      "required": false,
      "description": "View mode for suggestions (SUGGESTIONS_INLINE, PREVIEW_SUGGESTIONS_ACCEPTED, PREVIEW_WITHOUT_SUGGESTIONS)",
      "example": "SUGGESTIONS_INLINE",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://docs.googleapis.com/v1/documents/1BxiMVs0XRA5nFMdKvBdBZjgmUii_abc",
    "headers": {
      "Authorization": "Bearer GOOGLE_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "documentId": "1BxiMVs0XRA5nFMdKvBdBZjgmUii_abc",
      "title": "Project Proposal",
      "body": {
        "content": [
          {
            "endIndex": 1,
            "sectionBreak": {}
          },
          {
            "startIndex": 1,
            "endIndex": 15,
            "paragraph": {
              "elements": [
                {
                  "startIndex": 1,
                  "endIndex": 15,
                  "textRun": {
                    "content": "Hello World!\n",
                    "textStyle": {}
                  }
                }
              ],
              "paragraphStyle": {
                "namedStyleType": "NORMAL_TEXT"
              }
            }
          }
        ]
      },
      "revisionId": "ALm37BWLBK_def"
    }
  }
}
