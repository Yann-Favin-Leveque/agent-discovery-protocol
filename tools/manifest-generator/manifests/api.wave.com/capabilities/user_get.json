{
  "name": "user_get",
  "description": "Retrieve the authenticated user's profile information.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "user",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "query { user { id defaultEmail firstName lastName } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "user": {
          "id": "QnVzaW5lc3M6...",
          "defaultEmail": "user@example.com",
          "firstName": "John",
          "lastName": "Doe"
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}