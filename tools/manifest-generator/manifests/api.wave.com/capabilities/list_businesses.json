{
  "name": "list_businesses",
  "description": "Retrieve all businesses associated with the authenticated user's Wave account. Returns business IDs, names, currency, and other metadata needed for subsequent API calls.",
  "endpoint": "/graphql/public",
  "method": "POST",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql/public",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "query { businesses { edges { node { id name currency { code } } } } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "businesses": {
          "edges": [
            {
              "node": {
                "id": "QnVzaW5lc3M6YTBiMWMyZDM=",
                "name": "My Small Business",
                "currency": { "code": "USD" }
              }
            }
          ]
        }
      }
    }
  }
}
