{
  "name": "sales_taxes_create",
  "description": "Create a new sales tax for a business.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "taxes",
  "parameters": [
    {
      "name": "businessId",
      "type": "string",
      "description": "Business ID",
      "required": true,
      "example": "QnVzaW5lc3M6...",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Tax name",
      "required": true,
      "example": "GST",
      "in": "body"
    },
    {
      "name": "rate",
      "type": "number",
      "description": "Tax rate percentage",
      "required": true,
      "example": "5.0",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "mutation ($input: SalesTaxCreateInput!) { salesTaxCreate(input: $input) { salesTax { id name rate } didSucceed inputErrors { path message } } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "salesTaxCreate": {
          "salesTax": {
            "id": "VGF4Ojo...",
            "name": "GST",
            "rate": 5
          },
          "didSucceed": true,
          "inputErrors": []
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
