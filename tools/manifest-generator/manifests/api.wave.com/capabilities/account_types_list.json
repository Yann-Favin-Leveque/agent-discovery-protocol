{
  "name": "account_types_list",
  "description": "List all available account types.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "reference",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "query { accountTypes { name value normalBalanceType } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "accountTypes": [
          {
            "name": "Asset",
            "value": "ASSET",
            "normalBalanceType": "DEBIT"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}