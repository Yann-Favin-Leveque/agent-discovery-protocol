{
  "name": "countries_list",
  "description": "List all countries available in Wave.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "reference",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "query { countries { code name currency { code } } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "countries": [
          {
            "code": "US",
            "name": "United States",
            "currency": {
              "code": "USD"
            }
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}