{
  "name": "business_get",
  "description": "Retrieve detailed information about a specific business.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "businesses",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Business ID (globally unique)",
      "required": true,
      "example": "QnVzaW5lc3M6...",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "query ($id: ID!) { business(id: $id) { id name address { city province country } currency { code } } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "business": {
          "id": "QnVzaW5lc3M6...",
          "name": "My Business",
          "currency": {
            "code": "USD"
          }
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
