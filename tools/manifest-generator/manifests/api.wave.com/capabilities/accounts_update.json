{
  "name": "accounts_update",
  "description": "Update an existing account.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "accounts",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Account ID",
      "required": true,
      "example": "QWNjb3VudDo6...",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name",
      "required": false,
      "example": "SaaS Subscriptions",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "mutation ($input: AccountPatchInput!) { accountPatch(input: $input) { account { id name } didSucceed inputErrors { path message } } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "accountPatch": {
          "account": {
            "id": "QWNjb3VudDo6...",
            "name": "SaaS Subscriptions"
          },
          "didSucceed": true,
          "inputErrors": []
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
