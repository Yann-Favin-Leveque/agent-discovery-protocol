{
  "name": "account_subtypes_list",
  "description": "List all available account subtypes.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "reference",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "query { accountSubtypes { name value type { name } } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "accountSubtypes": [
          {
            "name": "Cash And Bank",
            "value": "CASH_AND_BANK",
            "type": {
              "name": "Asset"
            }
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}