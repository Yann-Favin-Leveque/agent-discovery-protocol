{
  "name": "currencies_list",
  "description": "List all supported currencies.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "reference",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://gql.waveapps.com/graphql",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "query { currencies { code name symbol } }"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "currencies": [
          {
            "code": "USD",
            "name": "US Dollar",
            "symbol": "$"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}