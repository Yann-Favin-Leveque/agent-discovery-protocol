{
  "name": "instructors_list",
  "description": "List all instructors in the Coursera catalog with pagination and field selection.",
  "endpoint": "/api/instructors.v1",
  "method": "GET",
  "resource_group": "instructors",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "description": "Pagination offset index.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of results to return.",
      "required": false,
      "example": 20
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields (e.g. firstName,lastName,title,department,photo,bio).",
      "required": false,
      "example": "firstName,lastName,title,department,photo,bio"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coursera.org/api/instructors.v1?start=0&limit=10&fields=firstName,lastName,title,department,photo",
    "headers": {},
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "elements": [
        {
          "id": "andrewng",
          "firstName": "Andrew",
          "lastName": "Ng",
          "title": "Adjunct Professor",
          "department": "Computer Science",
          "photo": "https://coursera-instructor-photos.s3.amazonaws.com/andrewng.jpg"
        }
      ],
      "paging": {
        "next": 10,
        "total": 3000
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
