{
  "name": "partners_list",
  "description": "List all partner institutions (universities and companies) that offer courses on Coursera.",
  "endpoint": "/api/partners.v1",
  "method": "GET",
  "resource_group": "partners",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "description": "Pagination offset index.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of results to return.",
      "required": false,
      "example": 20
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields (e.g. name,shortName,description,logo,homeLink,location).",
      "required": false,
      "example": "name,shortName,description,logo,homeLink"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coursera.org/api/partners.v1?start=0&limit=10&fields=name,shortName,description,logo,homeLink",
    "headers": {},
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "elements": [
        {
          "id": "stanford",
          "name": "Stanford University",
          "shortName": "Stanford",
          "description": "Stanford University is one of the world's leading research universities...",
          "logo": "https://coursera-university-assets.s3.amazonaws.com/stanford/logo.png",
          "homeLink": "https://www.stanford.edu"
        }
      ],
      "paging": {
        "next": 10,
        "total": 300
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
