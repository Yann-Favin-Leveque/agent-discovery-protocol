{
  "name": "partners_get",
  "description": "Retrieve detailed information about a specific partner institution by its ID.",
  "endpoint": "/api/partners.v1/{id}",
  "method": "GET",
  "resource_group": "partners",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The unique partner identifier.",
      "required": true,
      "example": "stanford",
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields to include.",
      "required": false,
      "example": "name,shortName,description,logo,homeLink,location",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coursera.org/api/partners.v1/stanford?fields=name,shortName,description,logo,homeLink,location",
    "headers": {},
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "elements": [
        {
          "id": "stanford",
          "name": "Stanford University",
          "shortName": "Stanford",
          "description": "Stanford University is one of the world's leading research universities...",
          "logo": "https://coursera-university-assets.s3.amazonaws.com/stanford/logo.png",
          "homeLink": "https://www.stanford.edu",
          "location": "Stanford, CA, USA"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
