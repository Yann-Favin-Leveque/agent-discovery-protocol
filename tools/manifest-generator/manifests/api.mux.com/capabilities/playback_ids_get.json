{
  "name": "playback_ids_get",
  "resource_group": "playback_ids",
  "description": "Retrieve the asset or live stream ID associated with a playback ID.",
  "endpoint": "/video/v1/playback-ids/{playback_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "playback_id",
      "type": "string",
      "required": true,
      "description": "Playback ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/playback-ids/playback_xyz",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "playback_xyz",
        "policy": "public",
        "object": {
          "id": "asset_abc123",
          "type": "asset"
        }
      }
    }
  }
}