{
  "name": "signing_keys_delete",
  "resource_group": "signing_keys",
  "description": "Delete a URL signing key.",
  "endpoint": "/video/v1/signing-keys/{signing_key_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "signing_key_id",
      "type": "string",
      "required": true,
      "description": "Signing key ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mux.com/video/v1/signing-keys/key_abc",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}