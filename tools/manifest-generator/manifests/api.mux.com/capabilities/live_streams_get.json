{
  "name": "live_streams_get",
  "resource_group": "live_streams",
  "description": "Get details of a live stream.",
  "endpoint": "/video/v1/live-streams/{live_stream_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "live_stream_id",
      "type": "string",
      "required": true,
      "description": "Live stream ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/live-streams/stream_abc",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "stream_abc",
        "stream_key": "live_xyz",
        "status": "idle",
        "playback_ids": [
          {
            "id": "playback_xyz",
            "policy": "public"
          }
        ]
      }
    }
  }
}