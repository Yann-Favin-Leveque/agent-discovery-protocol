{
  "name": "live_streams_reset_key",
  "resource_group": "live_streams",
  "description": "Reset the stream key for a live stream.",
  "endpoint": "/video/v1/live-streams/{live_stream_id}/reset-stream-key",
  "method": "POST",
  "parameters": [
    {
      "name": "live_stream_id",
      "type": "string",
      "required": true,
      "description": "Live stream ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mux.com/video/v1/live-streams/stream_abc/reset-stream-key",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "stream_abc",
        "stream_key": "live_new_xyz"
      }
    }
  }
}