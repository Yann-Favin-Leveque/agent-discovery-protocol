{
  "name": "list_assets",
  "description": "Retrieve a paginated list of all video assets in your Mux environment. Useful for browsing your video library or finding specific assets.",
  "endpoint": "/video/v1/assets",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of assets to return per page. Maximum is 100.",
      "required": false,
      "example": 25
    },
    {
      "name": "page",
      "type": "integer",
      "description": "The page number to retrieve, starting at 1.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/assets?limit=25&page=1",
    "headers": {
      "Authorization": "Basic {base64(token_id:token_secret)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "asset_abc123",
          "status": "ready",
          "duration": 120.5,
          "max_stored_resolution": "HD",
          "playback_ids": [
            { "id": "playback_xyz789", "policy": "public" }
          ],
          "created_at": "2024-01-15T10:30:00Z"
        }
      ]
    }
  }
}
