{
  "name": "signing_keys_get",
  "resource_group": "signing_keys",
  "description": "Retrieve a URL signing key (without private key).",
  "endpoint": "/video/v1/signing-keys/{signing_key_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "signing_key_id",
      "type": "string",
      "required": true,
      "description": "Signing key ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/signing-keys/key_abc",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "key_abc",
        "created_at": "2024-01-15T10:30:00Z"
      }
    }
  }
}