{
  "name": "direct_uploads_list",
  "resource_group": "direct_uploads",
  "description": "List all direct uploads.",
  "endpoint": "/video/v1/uploads",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/uploads?limit=10",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "upload_abc",
          "status": "asset_created",
          "asset_id": "asset_abc123"
        }
      ]
    }
  }
}
