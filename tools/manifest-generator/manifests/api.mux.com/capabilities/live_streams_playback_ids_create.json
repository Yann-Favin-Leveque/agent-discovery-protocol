{
  "name": "live_streams_playback_ids_create",
  "resource_group": "live_streams",
  "description": "Create a playback ID for a live stream.",
  "endpoint": "/video/v1/live-streams/{live_stream_id}/playback-ids",
  "method": "POST",
  "parameters": [
    {
      "name": "live_stream_id",
      "type": "string",
      "required": true,
      "description": "Live stream ID.",
      "in": "path"
    },
    {
      "name": "policy",
      "type": "string",
      "required": true,
      "description": "Policy: public or signed.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mux.com/video/v1/live-streams/stream_abc/playback-ids",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "policy": "public"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "playback_new",
        "policy": "public"
      }
    }
  }
}
