{
  "name": "direct_uploads_cancel",
  "resource_group": "direct_uploads",
  "description": "Cancel a direct upload.",
  "endpoint": "/video/v1/uploads/{upload_id}/cancel",
  "method": "PUT",
  "parameters": [
    {
      "name": "upload_id",
      "type": "string",
      "required": true,
      "description": "Upload ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.mux.com/video/v1/uploads/upload_abc/cancel",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "upload_abc",
        "status": "cancelled"
      }
    }
  }
}