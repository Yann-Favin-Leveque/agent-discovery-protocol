{
  "name": "assets_playback_ids_delete",
  "resource_group": "assets",
  "description": "Delete a playback ID from an asset.",
  "endpoint": "/video/v1/assets/{asset_id}/playback-ids/{playback_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "asset_id",
      "type": "string",
      "required": true,
      "description": "Asset ID.",
      "in": "path"
    },
    {
      "name": "playback_id",
      "type": "string",
      "required": true,
      "description": "Playback ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mux.com/video/v1/assets/asset_abc123/playback-ids/playback_xyz",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}