{
  "name": "playback_restrictions_get",
  "resource_group": "playback_restrictions",
  "description": "Retrieve a playback restriction.",
  "endpoint": "/video/v1/playback-restrictions/{playback_restriction_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "playback_restriction_id",
      "type": "string",
      "required": true,
      "description": "Restriction ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/playback-restrictions/restriction_abc",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "restriction_abc",
        "referrer": {
          "allowed_domains": [
            "example.com"
          ]
        }
      }
    }
  }
}