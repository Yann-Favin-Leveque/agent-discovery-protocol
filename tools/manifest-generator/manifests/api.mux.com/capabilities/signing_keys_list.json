{
  "name": "signing_keys_list",
  "resource_group": "signing_keys",
  "description": "List all URL signing keys.",
  "endpoint": "/video/v1/signing-keys",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/signing-keys",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "key_abc",
          "created_at": "2024-01-15T10:30:00Z"
        }
      ]
    }
  }
}
