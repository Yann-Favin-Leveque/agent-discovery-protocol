{
  "name": "direct_uploads_get",
  "resource_group": "direct_uploads",
  "description": "Get details of a direct upload.",
  "endpoint": "/video/v1/uploads/{upload_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "upload_id",
      "type": "string",
      "required": true,
      "description": "Upload ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/uploads/upload_abc",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "upload_abc",
        "status": "asset_created",
        "asset_id": "asset_abc123"
      }
    }
  }
}