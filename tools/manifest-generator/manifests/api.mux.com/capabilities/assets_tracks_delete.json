{
  "name": "assets_tracks_delete",
  "resource_group": "assets",
  "description": "Delete a text track from an asset.",
  "endpoint": "/video/v1/assets/{asset_id}/tracks/{track_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "asset_id",
      "type": "string",
      "required": true,
      "description": "Asset ID.",
      "in": "path"
    },
    {
      "name": "track_id",
      "type": "string",
      "required": true,
      "description": "Track ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mux.com/video/v1/assets/asset_abc123/tracks/track_abc",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}