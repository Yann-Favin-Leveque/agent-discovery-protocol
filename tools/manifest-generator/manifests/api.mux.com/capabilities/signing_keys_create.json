{
  "name": "signing_keys_create",
  "resource_group": "signing_keys",
  "description": "Create a URL signing key for signed playback.",
  "endpoint": "/video/v1/signing-keys",
  "method": "POST",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://api.mux.com/video/v1/signing-keys",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "key_abc",
        "private_key": "-----BEGIN RSA PRIVATE KEY-----...",
        "created_at": "2024-01-15T10:30:00Z"
      }
    }
  }
}