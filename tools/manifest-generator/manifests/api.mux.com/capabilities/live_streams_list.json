{
  "name": "live_streams_list",
  "resource_group": "live_streams",
  "description": "List all live streams.",
  "endpoint": "/video/v1/live-streams",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/live-streams?limit=10",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "stream_abc",
          "status": "idle",
          "playback_ids": [
            {
              "id": "playback_xyz",
              "policy": "public"
            }
          ],
          "created_at": "2024-01-15T10:30:00Z"
        }
      ]
    }
  }
}