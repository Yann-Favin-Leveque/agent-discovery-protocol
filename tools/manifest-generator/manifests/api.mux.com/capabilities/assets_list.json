{
  "name": "assets_list",
  "resource_group": "assets",
  "description": "List all video assets with pagination.",
  "endpoint": "/video/v1/assets",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results per page. Default 25."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/video/v1/assets?limit=10&page=1",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "asset_abc123",
          "status": "ready",
          "duration": 120.5,
          "playback_ids": [
            {
              "id": "playback_xyz",
              "policy": "public"
            }
          ],
          "created_at": "2024-01-15T10:30:00Z"
        }
      ]
    }
  }
}