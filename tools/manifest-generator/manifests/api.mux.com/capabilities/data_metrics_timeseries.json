{
  "name": "data_metrics_timeseries",
  "resource_group": "data",
  "description": "Get metric values over time.",
  "endpoint": "/data/v1/metrics/timeseries",
  "method": "GET",
  "parameters": [
    {
      "name": "timeframe[]",
      "type": "string",
      "required": false,
      "description": "Time range."
    },
    {
      "name": "filters[]",
      "type": "string",
      "required": false,
      "description": "Filters."
    },
    {
      "name": "measurement",
      "type": "string",
      "required": false,
      "description": "Measurement type."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/data/v1/metrics/timeseries?timeframe[]=1702656000&timeframe[]=1702742400",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "date": "2024-01-15",
          "views": 5000,
          "viewer_experience_score": 0.94
        }
      ]
    }
  }
}