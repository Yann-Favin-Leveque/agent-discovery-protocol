{
  "name": "data_video_views_list",
  "resource_group": "data",
  "description": "List video views with filtering and pagination.",
  "endpoint": "/data/v1/video-views",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number."
    },
    {
      "name": "viewer_id",
      "type": "string",
      "required": false,
      "description": "Filter by viewer."
    },
    {
      "name": "filters[]",
      "type": "string",
      "required": false,
      "description": "Metric filters."
    },
    {
      "name": "timeframe[]",
      "type": "string",
      "required": false,
      "description": "Unix timestamp range."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/data/v1/video-views?limit=10",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "view_abc",
          "viewer_experience_score": 0.95,
          "video_title": "My Video",
          "view_start": "2024-01-15T10:30:00Z"
        }
      ],
      "total_row_count": 100
    }
  }
}