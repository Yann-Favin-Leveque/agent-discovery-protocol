{
  "name": "data_video_views_get",
  "resource_group": "data",
  "description": "Get detailed info about a specific video view.",
  "endpoint": "/data/v1/video-views/{video_view_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "video_view_id",
      "type": "string",
      "required": true,
      "description": "Video view ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mux.com/data/v1/video-views/view_abc",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "view_abc",
        "viewer_experience_score": 0.95,
        "player_startup_time": 250,
        "video_startup_time": 1200,
        "rebuffer_percentage": 0.01
      }
    }
  }
}