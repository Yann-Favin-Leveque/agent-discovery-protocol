{
  "name": "live_streams_disable",
  "resource_group": "live_streams",
  "description": "Disable a live stream, preventing new ingest.",
  "endpoint": "/video/v1/live-streams/{live_stream_id}/disable",
  "method": "PUT",
  "parameters": [
    {
      "name": "live_stream_id",
      "type": "string",
      "required": true,
      "description": "Live stream ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.mux.com/video/v1/live-streams/stream_abc/disable",
    "headers": {
      "Authorization": "Basic base64(token_id:token_secret)",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "stream_abc",
        "status": "disabled"
      }
    }
  }
}