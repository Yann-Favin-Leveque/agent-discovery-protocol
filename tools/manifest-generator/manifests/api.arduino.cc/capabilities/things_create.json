{
  "name": "things_create",
  "description": "Create a new thing.",
  "resource_group": "things",
  "endpoint": "/iot/v2/things",
  "method": "PUT",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Thing name.",
      "required": true
    },
    {
      "name": "device_id",
      "type": "string",
      "description": "Associated device ID.",
      "required": false
    },
    {
      "name": "timezone",
      "type": "string",
      "description": "Timezone.",
      "required": false,
      "example": "America/New_York"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api2.arduino.cc/iot/v2/things",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Temperature Sensor",
      "timezone": "America/New_York"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "thing_2",
      "name": "Temperature Sensor"
    }
  }
}