{
  "name": "properties_list",
  "description": "List all properties of a thing.",
  "resource_group": "properties",
  "endpoint": "/iot/v2/things/{thingId}/properties",
  "method": "GET",
  "parameters": [
    {
      "name": "thingId",
      "type": "string",
      "description": "Thing ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/things/thing_1/properties",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "prop_1",
        "name": "temperature",
        "type": "FLOAT",
        "last_value": 22.5,
        "update_strategy": "ON_CHANGE"
      }
    ]
  }
}