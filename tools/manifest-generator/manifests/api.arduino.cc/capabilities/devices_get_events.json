{
  "name": "devices_get_events",
  "description": "Get device events.",
  "resource_group": "devices",
  "endpoint": "/iot/v2/devices/{id}/events",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max events.",
      "required": false,
      "in": "query"
    },
    {
      "name": "start",
      "type": "string",
      "description": "Start timestamp.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/devices/dev_1/events",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "event": "connect",
        "timestamp": "2024-06-01T10:00:00Z"
      }
    ]
  }
}
