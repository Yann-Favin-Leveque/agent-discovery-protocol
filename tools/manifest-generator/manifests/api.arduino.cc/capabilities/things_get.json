{
  "name": "things_get",
  "description": "Get a thing by ID.",
  "resource_group": "things",
  "endpoint": "/iot/v2/things/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Thing ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/things/thing_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "thing_1",
      "name": "Temperature Sensor",
      "device_id": "dev_1",
      "properties": [
        {
          "id": "prop_1",
          "name": "temperature",
          "type": "FLOAT",
          "last_value": 22.5
        }
      ]
    }
  }
}