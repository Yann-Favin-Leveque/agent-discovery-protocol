{
  "name": "manage_dashboards",
  "description": "List, create, or update IoT dashboards. Dashboards contain widgets (gauges, charts, switches, sliders) bound to thing properties for real-time visualization and control. Use this to build monitoring UIs or retrieve existing dashboard configurations.",
  "endpoint": "/iot/v2/dashboards",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/dashboards",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "dash-1234-abcd-5678-ef90",
        "name": "Home Monitoring",
        "widgets": [
          {
            "id": "w1",
            "type": "gauge",
            "name": "Temperature",
            "linked_property": "p1a2b3c4-d5e6-7890-abcd-ef1234567890"
          },
          {
            "id": "w2",
            "type": "switch",
            "name": "LED Control",
            "linked_property": "p2a2b3c4-d5e6-7890-abcd-ef1234567891"
          }
        ],
        "updated_at": "2025-12-01T10:00:00.000Z"
      }
    ]
  }
}
