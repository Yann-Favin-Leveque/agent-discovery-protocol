{
  "name": "devices_list",
  "description": "List all physical devices.",
  "resource_group": "devices",
  "endpoint": "/iot/v2/devices",
  "method": "GET",
  "parameters": [
    {
      "name": "tags",
      "type": "string",
      "description": "Filter by tags.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/devices",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "dev_1",
        "name": "Arduino MKR",
        "type": "mkrwifi1010",
        "connection_type": "wifi",
        "connected": true
      }
    ]
  }
}