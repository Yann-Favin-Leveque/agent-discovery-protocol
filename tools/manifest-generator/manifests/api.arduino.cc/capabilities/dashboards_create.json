{
  "name": "dashboards_create",
  "description": "Create a dashboard.",
  "resource_group": "dashboards",
  "endpoint": "/iot/v2/dashboards",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Dashboard name.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api2.arduino.cc/iot/v2/dashboards",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "New Dashboard"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "dash_2",
      "name": "New Dashboard"
    }
  }
}