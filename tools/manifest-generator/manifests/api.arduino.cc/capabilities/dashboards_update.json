{
  "name": "dashboards_update",
  "description": "Update a dashboard.",
  "resource_group": "dashboards",
  "endpoint": "/iot/v2/dashboards/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Dashboard ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api2.arduino.cc/iot/v2/dashboards/dash_1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Dashboard"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dash_1",
      "name": "Updated Dashboard"
    }
  }
}