{
  "name": "properties_get",
  "description": "Get a property value.",
  "resource_group": "properties",
  "endpoint": "/iot/v2/things/{thingId}/properties/{propertyId}",
  "method": "GET",
  "parameters": [
    {
      "name": "thingId",
      "type": "string",
      "description": "Thing ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "propertyId",
      "type": "string",
      "description": "Property ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/things/thing_1/properties/prop_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "prop_1",
      "name": "temperature",
      "last_value": 22.5,
      "value_updated_at": "2024-06-01T10:00:00Z"
    }
  }
}
