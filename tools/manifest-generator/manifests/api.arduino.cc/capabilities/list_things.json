{
  "name": "list_things",
  "description": "List all things in your Arduino IoT Cloud account. A 'thing' is a logical representation of a device with its associated properties (variables). Returns each thing's ID, name, device binding, timezone, and property summaries.",
  "endpoint": "/iot/v2/things",
  "method": "GET",
  "parameters": [
    {
      "name": "show_properties",
      "type": "boolean",
      "description": "If true, include the full list of properties for each thing.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/things?show_properties=true",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "name": "Weather Station",
        "device_id": "d1e2f3a4-b5c6-7890-abcd-ef1234567890",
        "timezone": "America/New_York",
        "properties_count": 3,
        "properties": [
          {
            "id": "p1a2b3c4-d5e6-7890-abcd-ef1234567890",
            "name": "temperature",
            "type": "FLOAT",
            "last_value": 22.5,
            "update_at": "2025-12-01T18:30:00.000Z"
          }
        ]
      }
    ]
  }
}
