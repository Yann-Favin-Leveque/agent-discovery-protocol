{
  "name": "list_devices",
  "description": "List all physical devices registered in your Arduino IoT Cloud account. Returns each device's ID, name, board type, serial number, connection status, and which thing it is linked to. Useful for inventory and checking device health.",
  "endpoint": "/iot/v2/devices",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/devices",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "d1e2f3a4-b5c6-7890-abcd-ef1234567890",
        "name": "My Arduino Nano 33 IoT",
        "type": "mkrwifi1010",
        "serial": "ABCD1234EF567890",
        "fqbn": "arduino:samd:nano_33_iot",
        "connection_type": "wifi",
        "connected": true,
        "thing": {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "name": "Weather Station"
        }
      }
    ]
  }
}
