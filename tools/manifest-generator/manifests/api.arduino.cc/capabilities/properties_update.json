{
  "name": "properties_update",
  "description": "Write a value to a property.",
  "resource_group": "properties",
  "endpoint": "/iot/v2/things/{thingId}/properties/{propertyId}/publish",
  "method": "PUT",
  "parameters": [
    {
      "name": "thingId",
      "type": "string",
      "description": "Thing ID.",
      "required": true
    },
    {
      "name": "propertyId",
      "type": "string",
      "description": "Property ID.",
      "required": true
    },
    {
      "name": "value",
      "type": "any",
      "description": "New property value.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api2.arduino.cc/iot/v2/things/thing_1/properties/prop_1/publish",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "value": 25.0
    }
  },
  "response_example": {
    "status": 200,
    "body": null
  }
}