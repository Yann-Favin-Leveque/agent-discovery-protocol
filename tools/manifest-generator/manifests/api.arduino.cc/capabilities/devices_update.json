{
  "name": "devices_update",
  "description": "Update device info.",
  "resource_group": "devices",
  "endpoint": "/iot/v2/devices/{id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api2.arduino.cc/iot/v2/devices/dev_1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Device"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dev_1",
      "name": "Updated Device"
    }
  }
}
