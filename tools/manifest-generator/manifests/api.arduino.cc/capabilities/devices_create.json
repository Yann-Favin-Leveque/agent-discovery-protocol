{
  "name": "devices_create",
  "description": "Register a new device.",
  "resource_group": "devices",
  "endpoint": "/iot/v2/devices",
  "method": "PUT",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Device name.",
      "required": true,
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Device type.",
      "required": true,
      "example": "mkrwifi1010",
      "in": "body"
    },
    {
      "name": "connection_type",
      "type": "string",
      "description": "wifi, eth, lora, etc.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api2.arduino.cc/iot/v2/devices",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "New Device",
      "type": "mkrwifi1010"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "dev_2",
      "name": "New Device"
    }
  }
}
