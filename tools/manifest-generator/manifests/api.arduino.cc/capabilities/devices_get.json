{
  "name": "devices_get",
  "description": "Get device details.",
  "resource_group": "devices",
  "endpoint": "/iot/v2/devices/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Device ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/devices/dev_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dev_1",
      "name": "Arduino MKR",
      "type": "mkrwifi1010",
      "connected": true,
      "thing": {
        "id": "thing_1"
      }
    }
  }
}