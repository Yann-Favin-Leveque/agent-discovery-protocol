{
  "name": "things_list",
  "description": "List all things.",
  "resource_group": "things",
  "endpoint": "/iot/v2/things",
  "method": "GET",
  "parameters": [
    {
      "name": "show_deleted",
      "type": "boolean",
      "description": "Include deleted things.",
      "required": false,
      "in": "query"
    },
    {
      "name": "tags",
      "type": "string",
      "description": "Filter by tags.",
      "required": false,
      "in": "query"
    },
    {
      "name": "X-Organization",
      "type": "string",
      "description": "Organization ID header.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/things",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "thing_1",
        "name": "Temperature Sensor",
        "device_id": "dev_1",
        "properties_count": 3
      }
    ]
  }
}
