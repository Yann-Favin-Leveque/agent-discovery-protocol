{
  "name": "things_update",
  "description": "Update a thing.",
  "resource_group": "things",
  "endpoint": "/iot/v2/things/{id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Thing ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "device_id",
      "type": "string",
      "description": "Updated device.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api2.arduino.cc/iot/v2/things/thing_1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Sensor"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "thing_1",
      "name": "Updated Sensor"
    }
  }
}
