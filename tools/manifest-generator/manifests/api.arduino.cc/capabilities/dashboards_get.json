{
  "name": "dashboards_get",
  "description": "Get a dashboard.",
  "resource_group": "dashboards",
  "endpoint": "/iot/v2/dashboards/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Dashboard ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.arduino.cc/iot/v2/dashboards/dash_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dash_1",
      "name": "Home Dashboard",
      "widgets": [
        {
          "id": "w_1",
          "type": "gauge",
          "name": "Temperature"
        }
      ]
    }
  }
}
