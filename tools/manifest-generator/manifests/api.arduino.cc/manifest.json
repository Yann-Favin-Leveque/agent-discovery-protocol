{
  "spec_version": "1.0",
  "name": "Arduino IoT Cloud",
  "description": "Arduino IoT Cloud is a platform for connecting, managing, and monitoring IoT devices. Organize devices into things with typed properties that sync between hardware and cloud, manage dashboards for visualization, and access time-series data.",
  "base_url": "https://api2.arduino.cc",
  "auth": {
    "type": "oauth2",
    "description": "OAuth2 client credentials flow. Obtain a token via POST https://api2.arduino.cc/iot/v1/clients/token with client_id and client_secret.",
    "setup_url": "https://cloud.arduino.cc/home/api-keys",
    "authorization_url": "https://login.arduino.cc/oauth/authorize",
    "token_url": "https://login.arduino.cc/oauth/token"
  },
  "capabilities": [
    {
      "name": "things_list",
      "resource_group": "things",
      "description": "List all things with properties and connection status.",
      "detail_url": "/capabilities/things_list"
    },
    {
      "name": "things_get",
      "resource_group": "things",
      "description": "Get a specific thing by ID.",
      "detail_url": "/capabilities/things_get"
    },
    {
      "name": "things_create",
      "resource_group": "things",
      "description": "Create a new thing.",
      "detail_url": "/capabilities/things_create"
    },
    {
      "name": "things_update",
      "resource_group": "things",
      "description": "Update a thing.",
      "detail_url": "/capabilities/things_update"
    },
    {
      "name": "things_delete",
      "resource_group": "things",
      "description": "Delete a thing.",
      "detail_url": "/capabilities/things_delete"
    },
    {
      "name": "properties_list",
      "resource_group": "properties",
      "description": "List all properties of a thing.",
      "detail_url": "/capabilities/properties_list"
    },
    {
      "name": "properties_get",
      "resource_group": "properties",
      "description": "Get a specific property value.",
      "detail_url": "/capabilities/properties_get"
    },
    {
      "name": "properties_update",
      "resource_group": "properties",
      "description": "Write a new value to a property.",
      "detail_url": "/capabilities/properties_update"
    },
    {
      "name": "properties_create",
      "resource_group": "properties",
      "description": "Create a new property on a thing.",
      "detail_url": "/capabilities/properties_create"
    },
    {
      "name": "properties_delete",
      "resource_group": "properties",
      "description": "Delete a property from a thing.",
      "detail_url": "/capabilities/properties_delete"
    },
    {
      "name": "properties_timeseries",
      "resource_group": "properties",
      "description": "Get historical time-series data for a property.",
      "detail_url": "/capabilities/properties_timeseries"
    },
    {
      "name": "devices_list",
      "resource_group": "devices",
      "description": "List all physical devices.",
      "detail_url": "/capabilities/devices_list"
    },
    {
      "name": "devices_get",
      "resource_group": "devices",
      "description": "Get device details.",
      "detail_url": "/capabilities/devices_get"
    },
    {
      "name": "devices_create",
      "resource_group": "devices",
      "description": "Register a new device.",
      "detail_url": "/capabilities/devices_create"
    },
    {
      "name": "devices_update",
      "resource_group": "devices",
      "description": "Update device info.",
      "detail_url": "/capabilities/devices_update"
    },
    {
      "name": "devices_delete",
      "resource_group": "devices",
      "description": "Delete a device.",
      "detail_url": "/capabilities/devices_delete"
    },
    {
      "name": "devices_get_events",
      "resource_group": "devices",
      "description": "Get device events.",
      "detail_url": "/capabilities/devices_get_events"
    },
    {
      "name": "dashboards_list",
      "resource_group": "dashboards",
      "description": "List all dashboards.",
      "detail_url": "/capabilities/dashboards_list"
    },
    {
      "name": "dashboards_get",
      "resource_group": "dashboards",
      "description": "Get a specific dashboard.",
      "detail_url": "/capabilities/dashboards_get"
    },
    {
      "name": "dashboards_create",
      "resource_group": "dashboards",
      "description": "Create a new dashboard.",
      "detail_url": "/capabilities/dashboards_create"
    },
    {
      "name": "dashboards_update",
      "resource_group": "dashboards",
      "description": "Update a dashboard.",
      "detail_url": "/capabilities/dashboards_update"
    },
    {
      "name": "dashboards_delete",
      "resource_group": "dashboards",
      "description": "Delete a dashboard.",
      "detail_url": "/capabilities/dashboards_delete"
    }
  ]
}