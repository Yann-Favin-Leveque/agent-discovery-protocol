{
  "name": "directories_get",
  "resource_group": "directory_sync",
  "description": "Retrieve a single directory by ID.",
  "endpoint": "/directories/{directory_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "directory_id",
      "type": "string",
      "required": true,
      "description": "Directory ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/directories/dir_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dir_abc",
      "name": "Acme Directory",
      "type": "okta scim v2.0",
      "state": "linked"
    }
  }
}