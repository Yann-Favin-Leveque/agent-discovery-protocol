{
  "name": "user_management_users_list",
  "resource_group": "user_management",
  "description": "List all users managed by AuthKit.",
  "endpoint": "/user_management/users",
  "method": "GET",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by email."
    },
    {
      "name": "organization_id",
      "type": "string",
      "required": false,
      "description": "Filter by organization."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "before",
      "type": "string",
      "required": false,
      "description": "Cursor."
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Cursor."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/user_management/users?limit=10",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "user_abc",
          "email": "alice@example.com",
          "first_name": "Alice",
          "last_name": "Johnson",
          "email_verified": true,
          "created_at": "2024-01-15T10:30:00Z"
        }
      ]
    }
  }
}