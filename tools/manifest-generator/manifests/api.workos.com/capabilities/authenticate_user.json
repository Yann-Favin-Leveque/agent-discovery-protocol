{
  "name": "authenticate_user",
  "description": "Authenticate a user through WorkOS AuthKit. Exchange an authorization code for a user profile and session token after the user completes login via email, password, magic auth, or social provider.",
  "endpoint": "/user_management/authenticate",
  "method": "POST",
  "parameters": [
    { "name": "code", "type": "string", "description": "The authorization code received from the AuthKit callback.", "required": true, "example": "01E2TRB2FGMD2RG5K69GF73HT6" },
    { "name": "client_id", "type": "string", "description": "Your WorkOS client ID.", "required": true, "example": "client_01E2TRB2FGMD2RG5K69GF73HT6" },
    { "name": "grant_type", "type": "string", "description": "The grant type. Use 'authorization_code'.", "required": true, "example": "authorization_code" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.workos.com/user_management/authenticate",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "code": "01E2TRB2FGMD2RG5K69GF73HT6",
      "client_id": "client_01E2TRB2FGMD2RG5K69GF73HT6",
      "grant_type": "authorization_code"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "id": "user_01EHZNVPK3SFK441A1RGBFSHRT",
        "object": "user",
        "email": "jane@acme.com",
        "first_name": "Jane",
        "last_name": "Doe",
        "email_verified": true,
        "created_at": "2024-01-01T00:00:00.000Z",
        "updated_at": "2024-01-01T00:00:00.000Z"
      },
      "access_token": "eyJ...",
      "refresh_token": "rft_01E2TRB2FGMD2RG5K69GF73HT6"
    }
  }
}
