{
  "name": "create_organization",
  "description": "Create a new organization representing one of your customer companies. Organizations group users and SSO connections. You can optionally attach verified domains.",
  "endpoint": "/organizations",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "The name of the organization.", "required": true, "example": "Acme Corp" },
    { "name": "domains", "type": "array", "description": "List of verified email domains associated with this organization.", "required": false, "example": ["acme.com"] },
    { "name": "allow_profiles_outside_organization", "type": "boolean", "description": "Whether to allow users with non-organization email domains to SSO into this org.", "required": false, "example": false }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.workos.com/organizations",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Corp",
      "domains": ["acme.com"],
      "allow_profiles_outside_organization": false
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "org_01EHZNVPK3SFK441A1RGBFSHRT",
      "object": "organization",
      "name": "Acme Corp",
      "allow_profiles_outside_organization": false,
      "domains": [
        { "id": "org_domain_01EHZNVPK3SFK441A1RGBFPQ5E", "domain": "acme.com", "object": "organization_domain" }
      ],
      "created_at": "2024-01-01T00:00:00.000Z",
      "updated_at": "2024-01-01T00:00:00.000Z"
    }
  }
}
