{
  "name": "user_management_magic_auth_send",
  "resource_group": "user_management",
  "description": "Send a magic auth code to a user's email for passwordless login.",
  "endpoint": "/user_management/magic_auth/send",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email to send magic auth code to."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.workos.com/user_management/magic_auth/send",
    "headers": {
      "Authorization": "Bearer sk_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "alice@example.com"
    }
  },
  "response_example": {
    "status": 201,
    "body": {}
  }
}