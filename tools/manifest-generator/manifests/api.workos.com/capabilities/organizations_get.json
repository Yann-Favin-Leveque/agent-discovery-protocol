{
  "name": "organizations_get",
  "resource_group": "organizations",
  "description": "Retrieve a single organization by ID.",
  "endpoint": "/organizations/{organization_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/organizations/org_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "org_abc",
      "name": "Acme Corp",
      "domains": [
        {
          "id": "dom_abc",
          "domain": "acme.com"
        }
      ]
    }
  }
}