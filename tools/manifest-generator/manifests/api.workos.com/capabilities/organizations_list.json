{
  "name": "organizations_list",
  "resource_group": "organizations",
  "description": "List all organizations in your WorkOS environment.",
  "endpoint": "/organizations",
  "method": "GET",
  "parameters": [
    {
      "name": "domains",
      "type": "array",
      "required": false,
      "description": "Filter by domain(s)."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "before",
      "type": "string",
      "required": false,
      "description": "Cursor."
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Cursor."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/organizations?limit=10",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "org_abc",
          "name": "Acme Corp",
          "domains": [
            {
              "id": "dom_abc",
              "domain": "acme.com"
            }
          ],
          "created_at": "2024-01-15T10:30:00Z"
        }
      ]
    }
  }
}