{
  "name": "organizations_update",
  "resource_group": "organizations",
  "description": "Update an organization's name or domains.",
  "endpoint": "/organizations/{organization_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name.",
      "in": "body"
    },
    {
      "name": "domains",
      "type": "array",
      "required": false,
      "description": "Updated domains.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.workos.com/organizations/org_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Corporation"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "org_abc",
      "name": "Acme Corporation"
    }
  }
}
