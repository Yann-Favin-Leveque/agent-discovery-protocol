{
  "name": "user_management_users_get",
  "resource_group": "user_management",
  "description": "Retrieve a single AuthKit user by ID.",
  "endpoint": "/user_management/users/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "User ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/user_management/users/user_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_abc",
      "email": "alice@example.com",
      "first_name": "Alice",
      "last_name": "Johnson",
      "email_verified": true
    }
  }
}