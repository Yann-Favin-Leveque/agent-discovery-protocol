{
  "name": "list_directory_groups",
  "description": "List groups from a directory sync connection. Returns group names and membership counts synced from the identity provider.",
  "endpoint": "/directory_groups",
  "method": "GET",
  "parameters": [
    { "name": "directory", "type": "string", "description": "The directory ID to list groups from.", "required": true, "example": "directory_01EHZNVPK3SFK441A1RGBFSHRT" },
    { "name": "user", "type": "string", "description": "Filter groups that contain this directory user ID.", "required": false, "example": "" },
    { "name": "limit", "type": "integer", "description": "Maximum number of groups to return (1-100). Defaults to 10.", "required": false, "example": 10 },
    { "name": "after", "type": "string", "description": "Pagination cursor.", "required": false, "example": "" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/directory_groups?directory=directory_01EHZNVPK3SFK441A1RGBFSHRT&limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "directory_group_01EHZNVPK3SFK441A1RGBFPQ5E",
          "object": "directory_group",
          "directory_id": "directory_01EHZNVPK3SFK441A1RGBFSHRT",
          "idp_id": "group-12345",
          "name": "Engineering",
          "created_at": "2024-01-01T00:00:00.000Z",
          "updated_at": "2024-01-01T00:00:00.000Z"
        }
      ],
      "list_metadata": {
        "before": null,
        "after": "directory_group_01EHZNVPK3SFK441A1RGBFPQ5E"
      }
    }
  }
}
