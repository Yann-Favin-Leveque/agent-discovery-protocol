{
  "name": "audit_log_exports_get",
  "resource_group": "audit_logs",
  "description": "Retrieve the status and download URL of an audit log export.",
  "endpoint": "/audit_logs/exports/{audit_log_export_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "audit_log_export_id",
      "type": "string",
      "required": true,
      "description": "Export ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/audit_logs/exports/ale_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ale_abc",
      "state": "ready",
      "url": "https://exports.workos.com/ale_abc.csv"
    }
  }
}