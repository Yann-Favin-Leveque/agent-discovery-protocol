{
  "name": "directory_groups_get",
  "resource_group": "directory_sync",
  "description": "Retrieve a single directory group.",
  "endpoint": "/directory_groups/{directory_group_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "directory_group_id",
      "type": "string",
      "required": true,
      "description": "Directory group ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/directory_groups/dir_grp_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dir_grp_abc",
      "name": "Engineering",
      "directory_id": "dir_abc"
    }
  }
}