{
  "name": "user_management_password_reset_confirm",
  "resource_group": "user_management",
  "description": "Reset a user's password using the reset token.",
  "endpoint": "/user_management/password_reset/confirm",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "description": "Password reset token.",
      "in": "body"
    },
    {
      "name": "new_password",
      "type": "string",
      "required": true,
      "description": "New password.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.workos.com/user_management/password_reset/confirm",
    "headers": {
      "Authorization": "Bearer sk_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "token": "reset-token-xyz",
      "new_password": "newSecurePass!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "id": "user_abc",
        "email": "alice@example.com"
      }
    }
  }
}
