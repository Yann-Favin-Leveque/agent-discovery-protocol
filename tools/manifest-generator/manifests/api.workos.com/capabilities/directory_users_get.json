{
  "name": "directory_users_get",
  "resource_group": "directory_sync",
  "description": "Retrieve a single directory user.",
  "endpoint": "/directory_users/{directory_user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "directory_user_id",
      "type": "string",
      "required": true,
      "description": "Directory user ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/directory_users/dir_usr_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dir_usr_abc",
      "first_name": "Alice",
      "last_name": "Johnson",
      "emails": [
        {
          "primary": true,
          "value": "alice@acme.com"
        }
      ]
    }
  }
}