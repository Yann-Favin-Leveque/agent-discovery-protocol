{
  "name": "list_organizations",
  "description": "List all organizations in your WorkOS environment. Organizations represent your customer companies. Supports pagination and optional filtering by domain.",
  "endpoint": "/organizations",
  "method": "GET",
  "parameters": [
    { "name": "limit", "type": "integer", "description": "Maximum number of organizations to return (1-100). Defaults to 10.", "required": false, "example": 10 },
    { "name": "before", "type": "string", "description": "Pagination cursor for fetching records before this ID.", "required": false, "example": "" },
    { "name": "after", "type": "string", "description": "Pagination cursor for fetching records after this ID.", "required": false, "example": "" },
    { "name": "order", "type": "string", "description": "Sort order: 'asc' or 'desc'. Defaults to 'desc'.", "required": false, "example": "desc" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/organizations?limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
