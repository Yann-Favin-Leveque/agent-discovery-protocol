{
  "name": "user_management_users_update",
  "resource_group": "user_management",
  "description": "Update an AuthKit user.",
  "endpoint": "/user_management/users/{user_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "User ID.",
      "in": "path"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "Updated first name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Updated last name.",
      "in": "body"
    },
    {
      "name": "email_verified",
      "type": "boolean",
      "required": false,
      "description": "Email verification status.",
      "in": "body"
    },
    {
      "name": "password",
      "type": "string",
      "required": false,
      "description": "New password.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.workos.com/user_management/users/user_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "first_name": "Alice",
      "last_name": "Smith"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_abc",
      "first_name": "Alice",
      "last_name": "Smith"
    }
  }
}
