{
  "name": "list_directory_users",
  "description": "List users provisioned from a directory sync connection. Returns user profiles synced from identity providers like Okta, Azure AD, or Google Workspace.",
  "endpoint": "/directory_users",
  "method": "GET",
  "parameters": [
    { "name": "directory", "type": "string", "description": "The directory ID to list users from.", "required": true, "example": "directory_01EHZNVPK3SFK441A1RGBFSHRT" },
    { "name": "group", "type": "string", "description": "Filter users by directory group ID.", "required": false, "example": "" },
    { "name": "limit", "type": "integer", "description": "Maximum number of users to return (1-100). Defaults to 10.", "required": false, "example": 10 },
    { "name": "after", "type": "string", "description": "Pagination cursor.", "required": false, "example": "" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/directory_users?directory=directory_01EHZNVPK3SFK441A1RGBFSHRT&limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "directory_user_01EHZNVPK3SFK441A1RGBFSHRT",
          "object": "directory_user",
          "directory_id": "directory_01EHZNVPK3SFK441A1RGBFSHRT",
          "idp_id": "12345",
          "first_name": "Jane",
          "last_name": "Doe",
          "email": "jane@acme.com",
          "username": "jane.doe",
          "state": "active",
          "groups": [
            { "id": "directory_group_01EHZNVPK3SFK441A1RGBFPQ5E", "name": "Engineering" }
          ],
          "raw_attributes": {},
          "created_at": "2024-01-01T00:00:00.000Z",
          "updated_at": "2024-01-01T00:00:00.000Z"
        }
      ],
      "list_metadata": {
        "before": null,
        "after": "directory_user_01EHZNVPK3SFK441A1RGBFSHRT"
      }
    }
  }
}
