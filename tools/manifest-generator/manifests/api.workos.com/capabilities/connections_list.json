{
  "name": "connections_list",
  "resource_group": "sso",
  "description": "List all SSO connections. Filter by organization or connection type.",
  "endpoint": "/connections",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": false,
      "description": "Filter by organization."
    },
    {
      "name": "connection_type",
      "type": "string",
      "required": false,
      "description": "Filter by type: OktaSAML, AzureSAML, GoogleSAML, etc."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results. Default 10."
    },
    {
      "name": "before",
      "type": "string",
      "required": false,
      "description": "Cursor for backward pagination."
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Cursor for forward pagination."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/connections?organization_id=org_xxx",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "conn_abc",
          "connection_type": "OktaSAML",
          "name": "Acme Okta",
          "state": "active",
          "organization_id": "org_xxx",
          "created_at": "2024-01-15T10:30:00Z"
        }
      ],
      "list_metadata": {
        "before": null,
        "after": "conn_next"
      }
    }
  }
}