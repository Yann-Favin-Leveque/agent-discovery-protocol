      "in": "query"
    },
    {
      "name": "user_id",
      "type": "string",
      "required": false,
      "description": "Filter by user.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "before",
      "type": "string",
      "required": false,
      "description": "Cursor.",
      "in": "query"
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Cursor.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
