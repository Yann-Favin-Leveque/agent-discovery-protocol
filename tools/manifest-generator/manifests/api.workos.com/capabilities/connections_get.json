{
  "name": "connections_get",
  "resource_group": "sso",
  "description": "Retrieve details of a single SSO connection.",
  "endpoint": "/connections/{connection_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "connection_id",
      "type": "string",
      "required": true,
      "description": "Connection ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.workos.com/connections/conn_abc",
    "headers": {
      "Authorization": "Bearer sk_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "conn_abc",
      "connection_type": "OktaSAML",
      "name": "Acme Okta",
      "state": "active",
      "organization_id": "org_xxx"
    }
  }
}