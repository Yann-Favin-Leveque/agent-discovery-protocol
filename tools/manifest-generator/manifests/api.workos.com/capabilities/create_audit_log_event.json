{
  "name": "create_audit_log_event",
  "description": "Create an immutable audit log event to record user activity for compliance, security, and debugging. Events include an action, actor, targets, and metadata.",
  "endpoint": "/audit_logs/events",
  "method": "POST",
  "parameters": [
    { "name": "organization_id", "type": "string", "description": "The organization this event belongs to.", "required": true, "example": "org_01EHZNVPK3SFK441A1RGBFSHRT" },
    { "name": "event", "type": "object", "description": "The audit log event object containing action, actor, targets, and metadata.", "required": true, "example": {
      "action": "user.login",
      "occurred_at": "2024-01-01T00:00:00.000Z",
      "actor": { "type": "user", "id": "user_01EHZNVPK3SFK441A1RGBFSHRT", "name": "Jane Doe" },
      "targets": [{ "type": "team", "id": "team_01EHZNVPK3SFK441A1RGBFSHRT", "name": "Engineering" }],
      "context": { "location": "1.2.3.4", "user_agent": "Mozilla/5.0" }
    }}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.workos.com/audit_logs/events",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "organization_id": "org_01EHZNVPK3SFK441A1RGBFSHRT",
      "event": {
        "action": "user.login",
        "occurred_at": "2024-01-01T00:00:00.000Z",
        "actor": { "type": "user", "id": "user_01EHZNVPK3SFK441A1RGBFSHRT", "name": "Jane Doe" },
        "targets": [{ "type": "team", "id": "team_01EHZNVPK3SFK441A1RGBFSHRT", "name": "Engineering" }],
        "context": { "location": "1.2.3.4", "user_agent": "Mozilla/5.0" }
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true
    }
  }
}
