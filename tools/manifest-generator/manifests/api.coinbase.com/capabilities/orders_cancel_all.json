{
  "name": "orders_cancel_all",
  "description": "Cancel all open orders, optionally filtered by product.",
  "endpoint": "/orders",
  "method": "DELETE",
  "resource_group": "orders",
  "parameters": [
    {"name": "product_id", "type": "string", "description": "Only cancel orders for this product.", "required": false, "example": "BTC-USD"}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.exchange.coinbase.com/orders?product_id=BTC-USD",
    "headers": {"CB-ACCESS-KEY": "{api_key}", "CB-ACCESS-SIGN": "{signature}", "CB-ACCESS-TIMESTAMP": "{timestamp}", "CB-ACCESS-PASSPHRASE": "{passphrase}"}
  },
  "response_example": {
    "status": 200,
    "body": ["d0c5340b-6d6c-49d9-b567-48c4bfca13d2"]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
