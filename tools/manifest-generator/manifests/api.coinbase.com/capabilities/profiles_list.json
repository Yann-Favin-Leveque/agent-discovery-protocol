{
  "name": "profiles_list",
  "description": "List all trading profiles (portfolios) for the authenticated user.",
  "endpoint": "/profiles",
  "method": "GET",
  "resource_group": "profiles",
  "parameters": [
    {"name": "active", "type": "boolean", "description": "Only return active profiles.", "required": false, "example": true}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/profiles?active=true",
    "headers": {"CB-ACCESS-KEY": "{api_key}", "CB-ACCESS-SIGN": "{signature}", "CB-ACCESS-TIMESTAMP": "{timestamp}", "CB-ACCESS-PASSPHRASE": "{passphrase}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": "86602c68-306a-4500-ac73-4ce56a91d83c", "user_id": "user123", "name": "default", "active": true, "is_default": true, "created_at": "2023-01-01T00:00:00.000Z"}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
