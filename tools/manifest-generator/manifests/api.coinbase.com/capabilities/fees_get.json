{
  "name": "fees_get",
  "description": "Get the current maker and taker fee rates for your account based on 30-day trailing volume.",
  "endpoint": "/fees",
  "method": "GET",
  "resource_group": "fees",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/fees",
    "headers": {"CB-ACCESS-KEY": "{api_key}", "CB-ACCESS-SIGN": "{signature}", "CB-ACCESS-TIMESTAMP": "{timestamp}", "CB-ACCESS-PASSPHRASE": "{passphrase}"}
  },
  "response_example": {
    "status": 200,
    "body": {"maker_fee_rate": "0.0040", "taker_fee_rate": "0.0060", "usd_volume": "25000.00"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
