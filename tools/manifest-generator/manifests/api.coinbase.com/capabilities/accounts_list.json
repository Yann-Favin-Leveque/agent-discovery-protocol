{
  "name": "accounts_list",
  "description": "List all trading accounts for a profile with current balances, holds, and available funds.",
  "endpoint": "/accounts",
  "method": "GET",
  "resource_group": "accounts",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/accounts",
    "headers": {"CB-ACCESS-KEY": "{api_key}", "CB-ACCESS-SIGN": "{signature}", "CB-ACCESS-TIMESTAMP": "{timestamp}", "CB-ACCESS-PASSPHRASE": "{passphrase}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890", "currency": "BTC", "balance": "1.5000000000000000", "hold": "0.0000000000000000", "available": "1.5000000000000000", "profile_id": "default", "trading_enabled": true}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
