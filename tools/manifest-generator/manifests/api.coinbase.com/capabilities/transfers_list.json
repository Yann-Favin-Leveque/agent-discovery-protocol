{
  "name": "transfers_list",
  "description": "List all deposits and withdrawals for the current profile.",
  "endpoint": "/transfers",
  "method": "GET",
  "resource_group": "transfers",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "Filter by type: deposit or withdraw.",
      "required": false,
      "example": "deposit",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "example": 100,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/transfers?type=deposit&limit=100",
    "headers": {
      "CB-ACCESS-KEY": "{api_key}",
      "CB-ACCESS-SIGN": "{signature}",
      "CB-ACCESS-TIMESTAMP": "{timestamp}",
      "CB-ACCESS-PASSPHRASE": "{passphrase}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "593533d2-ff31-46e0-b22e-ca754d39c5ab",
        "type": "deposit",
        "amount": "1.00000000",
        "currency": "BTC",
        "completed_at": "2024-06-15T10:00:00.000Z"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
