{
  "name": "products_get",
  "description": "Get details of a specific trading pair including min/max sizes and increments.",
  "endpoint": "/products/{product_id}",
  "method": "GET",
  "resource_group": "products",
  "parameters": [
    {"name": "product_id", "type": "string", "description": "Trading pair ID.", "required": true, "example": "BTC-USD"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/products/BTC-USD",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "BTC-USD", "base_currency": "BTC", "quote_currency": "USD", "base_min_size": "0.00000001", "status": "online"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
