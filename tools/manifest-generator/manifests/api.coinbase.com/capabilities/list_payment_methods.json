{
  "name": "list_payment_methods",
  "description": "List all payment methods (bank accounts, credit cards, debit cards) linked to the authenticated user's Coinbase account. Needed to specify payment methods when placing buy or sell orders.",
  "endpoint": "/v2/payment-methods",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.coinbase.com/v2/payment-methods",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "pm-12345",
          "type": "ach_bank_account",
          "name": "Chase Checking ****1234",
          "currency": "USD",
          "primary_buy": true,
          "primary_sell": true,
          "allow_buy": true,
          "allow_sell": true,
          "allow_deposit": true,
          "allow_withdraw": true,
          "verified": true
        }
      ]
    }
  }
}
