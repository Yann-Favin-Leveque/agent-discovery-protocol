{
  "name": "list_accounts",
  "description": "List all cryptocurrency accounts (wallets) and their balances for the authenticated user. Each account represents a different cryptocurrency such as BTC, ETH, or USDC.",
  "endpoint": "/v2/accounts",
  "method": "GET",
  "parameters": [
    { "name": "limit", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 },
    { "name": "order", "type": "string", "description": "Result order: 'asc' or 'desc'.", "required": false, "example": "desc" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.coinbase.com/v2/accounts?limit=25",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "name": "BTC Wallet",
          "primary": true,
          "type": "wallet",
          "currency": { "code": "BTC", "name": "Bitcoin" },
          "balance": { "amount": "1.50000000", "currency": "BTC" },
          "native_balance": { "amount": "75000.00", "currency": "USD" }
        }
      ],
      "pagination": { "ending_before": null, "starting_after": null, "limit": 25, "order": "desc" }
    }
  }
}
