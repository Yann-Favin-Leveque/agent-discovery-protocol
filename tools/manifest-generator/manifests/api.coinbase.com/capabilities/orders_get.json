{
  "name": "orders_get",
  "description": "Get details of a specific order by its ID.",
  "endpoint": "/orders/{order_id}",
  "method": "GET",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "order_id",
      "type": "string",
      "description": "Order UUID.",
      "required": true,
      "example": "d0c5340b-6d6c-49d9-b567-48c4bfca13d2",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/orders/d0c5340b-6d6c-49d9-b567-48c4bfca13d2",
    "headers": {
      "CB-ACCESS-KEY": "{api_key}",
      "CB-ACCESS-SIGN": "{signature}",
      "CB-ACCESS-TIMESTAMP": "{timestamp}",
      "CB-ACCESS-PASSPHRASE": "{passphrase}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "d0c5340b-6d6c-49d9-b567-48c4bfca13d2",
      "product_id": "BTC-USD",
      "side": "buy",
      "type": "limit",
      "size": "0.01",
      "price": "50000.00",
      "status": "open",
      "filled_size": "0.00",
      "fill_fees": "0.00"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
