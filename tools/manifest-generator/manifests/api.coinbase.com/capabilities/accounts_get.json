{
  "name": "accounts_get",
  "description": "Get a single trading account by its ID with current balance details.",
  "endpoint": "/accounts/{account_id}",
  "method": "GET",
  "resource_group": "accounts",
  "parameters": [
    {"name": "account_id", "type": "string", "description": "Account UUID.", "required": true, "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/accounts/a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "headers": {"CB-ACCESS-KEY": "{api_key}", "CB-ACCESS-SIGN": "{signature}", "CB-ACCESS-TIMESTAMP": "{timestamp}", "CB-ACCESS-PASSPHRASE": "{passphrase}"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890", "currency": "BTC", "balance": "1.5000000000000000", "hold": "0.0000000000000000", "available": "1.5000000000000000"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
