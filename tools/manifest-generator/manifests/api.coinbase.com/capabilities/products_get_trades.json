{
  "name": "products_get_trades",
  "description": "List the latest public trades for a product.",
  "endpoint": "/products/{product_id}/trades",
  "method": "GET",
  "resource_group": "products",
  "parameters": [
    {"name": "product_id", "type": "string", "description": "Trading pair ID.", "required": true, "example": "BTC-USD"},
    {"name": "limit", "type": "integer", "description": "Number of trades to return.", "required": false, "example": 50}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/products/BTC-USD/trades?limit=50",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": [{"time": "2024-06-15T10:00:00.000Z", "trade_id": 86334519, "price": "50123.45", "size": "0.001", "side": "buy"}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
