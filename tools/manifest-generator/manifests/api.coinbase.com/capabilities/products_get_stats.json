{
  "name": "products_get_stats",
  "description": "Get 24-hour trading statistics for a product including open, high, low, volume, and last price.",
  "endpoint": "/products/{product_id}/stats",
  "method": "GET",
  "resource_group": "products",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "description": "Trading pair ID.",
      "required": true,
      "example": "BTC-USD",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/products/BTC-USD/stats",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "open": "49500.00",
      "high": "50500.00",
      "low": "49200.00",
      "last": "50123.45",
      "volume": "12345.67890000",
      "volume_30day": "345678.90000000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
