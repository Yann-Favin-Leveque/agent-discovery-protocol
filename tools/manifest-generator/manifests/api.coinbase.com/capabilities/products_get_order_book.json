{
  "name": "products_get_order_book",
  "description": "Get the current order book (bids and asks) for a trading pair at specified depth level.",
  "endpoint": "/products/{product_id}/book",
  "method": "GET",
  "resource_group": "products",
  "parameters": [
    {"name": "product_id", "type": "string", "description": "Trading pair ID.", "required": true, "example": "BTC-USD"},
    {"name": "level", "type": "integer", "description": "Detail level: 1 (best bid/ask), 2 (top 50), 3 (full book).", "required": false, "example": 2}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/products/BTC-USD/book?level=2",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {"bids": [["50120.00", "0.5", 1]], "asks": [["50125.00", "0.3", 1]], "sequence": 123456789}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
