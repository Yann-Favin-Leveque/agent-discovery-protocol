{
  "name": "products_get_ticker",
  "description": "Get real-time ticker data for a trading pair including last price, bid, ask, and 24hr volume.",
  "endpoint": "/products/{product_id}/ticker",
  "method": "GET",
  "resource_group": "products",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "description": "Trading pair ID.",
      "required": true,
      "example": "BTC-USD",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.exchange.coinbase.com/products/BTC-USD/ticker",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "trade_id": 86334519,
      "price": "50123.45",
      "size": "0.001",
      "bid": "50120.00",
      "ask": "50125.00",
      "volume": "12345.67890000",
      "time": "2024-06-15T10:00:00.000Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
