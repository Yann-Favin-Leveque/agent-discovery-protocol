{
  "name": "orders_cancel",
  "description": "Cancel a specific open order by its ID.",
  "endpoint": "/orders/{order_id}",
  "method": "DELETE",
  "resource_group": "orders",
  "parameters": [
    {"name": "order_id", "type": "string", "description": "Order UUID to cancel.", "required": true, "example": "d0c5340b-6d6c-49d9-b567-48c4bfca13d2"}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.exchange.coinbase.com/orders/d0c5340b-6d6c-49d9-b567-48c4bfca13d2",
    "headers": {"CB-ACCESS-KEY": "{api_key}", "CB-ACCESS-SIGN": "{signature}", "CB-ACCESS-TIMESTAMP": "{timestamp}", "CB-ACCESS-PASSPHRASE": "{passphrase}"}
  },
  "response_example": {
    "status": 200,
    "body": "d0c5340b-6d6c-49d9-b567-48c4bfca13d2"
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
