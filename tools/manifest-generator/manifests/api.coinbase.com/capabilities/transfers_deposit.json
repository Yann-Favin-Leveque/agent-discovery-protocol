{
  "name": "transfers_deposit",
  "description": "Deposit funds from a Coinbase wallet account into your Exchange trading account.",
  "endpoint": "/deposits/coinbase-account",
  "method": "POST",
  "resource_group": "transfers",
  "parameters": [
    {"name": "amount", "type": "string", "description": "Amount to deposit.", "required": true, "example": "1.0"},
    {"name": "currency", "type": "string", "description": "Currency code.", "required": true, "example": "BTC"},
    {"name": "coinbase_account_id", "type": "string", "description": "Source Coinbase account UUID.", "required": true, "example": "c1b2a3d4-e5f6-7890-abcd-ef1234567890"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.exchange.coinbase.com/deposits/coinbase-account",
    "headers": {"CB-ACCESS-KEY": "{api_key}", "CB-ACCESS-SIGN": "{signature}", "CB-ACCESS-TIMESTAMP": "{timestamp}", "CB-ACCESS-PASSPHRASE": "{passphrase}", "Content-Type": "application/json"},
    "body": {"amount": "1.0", "currency": "BTC", "coinbase_account_id": "c1b2a3d4-e5f6-7890-abcd-ef1234567890"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "593533d2-ff31-46e0-b22e-ca754d39c5ab", "amount": "1.00000000", "currency": "BTC"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 600}
}
