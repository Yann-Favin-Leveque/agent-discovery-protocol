{
  "name": "contracts_sign",
  "resource_group": "Contracts",
  "endpoint": "/rest/v2/contracts/{contract_id}/signatures",
  "method": "POST",
  "description": "Sign a contract on behalf of the client.",
  "parameters": [
    {
      "name": "contract_id",
      "type": "string",
      "required": true,
      "description": "Contract ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.letsdeel.com/rest/v2/contracts/ct-1/signatures",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "ct-1",
        "status": "active"
      }
    }
  }
}