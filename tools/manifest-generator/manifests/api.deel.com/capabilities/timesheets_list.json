{
  "name": "timesheets_list",
  "resource_group": "Timesheets",
  "endpoint": "/rest/v2/contracts/{contract_id}/timesheets",
  "method": "GET",
  "description": "List timesheets for a specific contract.",
  "parameters": [
    {
      "name": "contract_id",
      "type": "string",
      "required": true,
      "description": "Contract ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/contracts/ct-1/timesheets",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "ts-1",
          "date_from": "2024-11-01",
          "date_to": "2024-11-15",
          "quantity": 80,
          "status": "approved"
        }
      ]
    }
  }
}
