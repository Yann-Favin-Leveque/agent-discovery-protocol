{
  "name": "contracts_update",
  "resource_group": "Contracts",
  "endpoint": "/rest/v2/contracts/{contract_id}",
  "method": "PATCH",
  "description": "Add an external ID to a contract for integration purposes.",
  "parameters": [
    {
      "name": "contract_id",
      "type": "string",
      "required": true,
      "description": "Contract ID."
    },
    {
      "name": "external_id",
      "type": "string",
      "required": true,
      "description": "External system identifier."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.letsdeel.com/rest/v2/contracts/ct-1",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "external_id": "EXT-123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "ct-1",
        "external_id": "EXT-123"
      }
    }
  }
}