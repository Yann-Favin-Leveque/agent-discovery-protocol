{
  "name": "payments_list",
  "resource_group": "Payments",
  "endpoint": "/rest/v2/payments",
  "method": "GET",
  "description": "List all payments across contracts.",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Pagination offset."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/payments?limit=25",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "pay-1",
          "amount": 8000,
          "currency": "USD",
          "status": "paid",
          "paid_at": "2024-11-01T00:00:00Z"
        }
      ]
    }
  }
}