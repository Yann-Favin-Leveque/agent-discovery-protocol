{
  "name": "payments_breakdown_get",
  "resource_group": "Payments",
  "endpoint": "/rest/v2/payments/{payment_id}/breakdown",
  "method": "GET",
  "description": "Get a detailed breakdown of a specific payment.",
  "parameters": [
    {
      "name": "payment_id",
      "type": "string",
      "required": true,
      "description": "Payment ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/payments/pay-1/breakdown",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "pay-1",
        "items": [
          {
            "description": "Monthly salary",
            "amount": 8000
          }
        ]
      }
    }
  }
}