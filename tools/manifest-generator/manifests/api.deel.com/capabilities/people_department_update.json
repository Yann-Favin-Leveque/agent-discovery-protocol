{
  "name": "people_department_update",
  "resource_group": "People",
  "endpoint": "/rest/v2/people/{worker_id}/department",
  "method": "PUT",
  "description": "Update a worker's department assignment.",
  "parameters": [
    {
      "name": "worker_id",
      "type": "string",
      "required": true,
      "description": "Worker ID."
    },
    {
      "name": "department_id",
      "type": "string",
      "required": true,
      "description": "Department ID."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.letsdeel.com/rest/v2/people/worker-1/department",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "department_id": "dept-1"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "worker-1",
        "department": "Engineering"
      }
    }
  }
}