{
  "name": "candidates_update",
  "resource_group": "Candidates",
  "endpoint": "/rest/v2/candidates/{candidate_id}",
  "method": "PATCH",
  "description": "Update candidate details.",
  "parameters": [
    {
      "name": "candidate_id",
      "type": "string",
      "required": true,
      "description": "Candidate ID."
    },
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Updated fields."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.letsdeel.com/rest/v2/candidates/cand-1",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "data": {
        "phone": "+1-555-0000"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "cand-1"
      }
    }
  }
}