{
  "name": "list_contracts",
  "description": "Retrieve all contracts in your Deel organization. Contracts represent the legal agreement between your company and a worker. Supports filtering by contract type, status, and worker country.",
  "endpoint": "/rest/v2/contracts",
  "method": "GET",
  "parameters": [
    { "name": "types", "type": "string", "description": "Filter by contract type: 'pay_as_you_go_contractor', 'fixed_contractor', 'direct_employee', or 'eor_employee'.", "required": false, "example": "pay_as_you_go_contractor" },
    { "name": "statuses", "type": "string", "description": "Filter by contract status: 'in_progress', 'waiting', 'cancelled', or 'completed'.", "required": false, "example": "in_progress" },
    { "name": "country", "type": "string", "description": "Filter by worker country (ISO 3166-1 alpha-2 code).", "required": false, "example": "US" },
    { "name": "limit", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 50 },
    { "name": "offset", "type": "integer", "description": "Number of results to skip for pagination.", "required": false, "example": 0 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deel.com/rest/v2/contracts?statuses=in_progress&limit=50",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "contract-001",
          "type": "pay_as_you_go_contractor",
          "status": "in_progress",
          "title": "Frontend Developer",
          "worker": {
            "id": "worker-001",
            "name": "Maria Garcia",
            "email": "maria@example.com",
            "country": "ES"
          },
          "compensation": {
            "amount": 5000,
            "currency": "USD",
            "cycle": "monthly"
          },
          "start_date": "2025-01-01"
        }
      ],
      "page": { "total": 1, "offset": 0, "limit": 50 }
    }
  }
}
