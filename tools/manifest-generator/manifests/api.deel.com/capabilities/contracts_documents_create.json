{
  "name": "contracts_documents_create",
  "resource_group": "Contracts",
  "endpoint": "/rest/v2/contracts/{contract_id}/documents",
  "method": "POST",
  "description": "Attach a document to a contract.",
  "parameters": [
    {
      "name": "contract_id",
      "type": "string",
      "required": true,
      "description": "Contract ID."
    },
    {
      "name": "file",
      "type": "file",
      "required": true,
      "description": "Document file."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.letsdeel.com/rest/v2/contracts/ct-1/documents",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "multipart/form-data"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "doc-1",
        "name": "offer_letter.pdf"
      }
    }
  }
}