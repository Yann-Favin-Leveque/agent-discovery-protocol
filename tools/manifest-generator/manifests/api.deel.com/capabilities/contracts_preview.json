{
  "name": "contracts_preview",
  "resource_group": "Contracts",
  "endpoint": "/rest/v2/contracts/{contract_id}/preview",
  "method": "GET",
  "description": "Get an HTML preview of a contract document.",
  "parameters": [
    {
      "name": "contract_id",
      "type": "string",
      "required": true,
      "description": "Contract ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/contracts/ct-1/preview",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "html": "<html>Contract preview...</html>"
      }
    }
  }
}