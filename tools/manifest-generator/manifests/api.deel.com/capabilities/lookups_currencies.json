{
  "name": "lookups_currencies",
  "resource_group": "Lookups",
  "endpoint": "/rest/v2/lookups/currencies",
  "method": "GET",
  "description": "List all supported currencies.",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/lookups/currencies",
    "headers": {
