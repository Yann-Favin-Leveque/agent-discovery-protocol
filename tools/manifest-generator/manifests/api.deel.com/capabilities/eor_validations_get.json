{
  "name": "eor_validations_get",
  "resource_group": "EOR",
  "endpoint": "/rest/v2/eor/validations/{country_code}",
  "method": "GET",
  "description": "Get country-specific hiring requirements and validations.",
  "parameters": [
    {
      "name": "country_code",
      "type": "string",
      "required": true,
      "description": "ISO country code.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/eor/validations/DE",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "country": "DE",
        "required_fields": [
          "tax_id",
          "social_security"
        ],
        "probation_period": "6 months"
      }
    }
  }
}
