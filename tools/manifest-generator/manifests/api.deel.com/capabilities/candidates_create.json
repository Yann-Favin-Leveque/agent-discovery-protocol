{
  "name": "candidates_create",
  "resource_group": "Candidates",
  "endpoint": "/rest/v2/candidates",
  "method": "POST",
  "description": "Add a candidate to Deel for potential hiring.",
  "parameters": [
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Candidate details.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.letsdeel.com/rest/v2/candidates",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "data": {
        "first_name": "Alex",
        "last_name": "Kim",
        "email": "alex@example.com"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "cand-1",
        "first_name": "Alex"
      }
    }
  }
}
