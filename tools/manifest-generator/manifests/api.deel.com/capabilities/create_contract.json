{
  "name": "create_contract",
  "description": "Create a new employment or contractor contract in Deel. Define the worker, compensation, scope of work, and compliance details. Deel handles country-specific labor law requirements automatically.",
  "endpoint": "/rest/v2/contracts",
  "method": "POST",
  "parameters": [
    { "name": "type", "type": "string", "description": "Contract type: 'pay_as_you_go_contractor', 'fixed_contractor', 'direct_employee', or 'eor_employee'.", "required": true, "example": "pay_as_you_go_contractor" },
    { "name": "title", "type": "string", "description": "Job title for the contract.", "required": true, "example": "Senior Frontend Developer" },
    { "name": "scope_of_work", "type": "string", "description": "Description of the work to be performed.", "required": true, "example": "Develop and maintain the company's web application frontend." },
    { "name": "worker_email", "type": "string", "description": "Email address of the worker to invite.", "required": true, "example": "maria@example.com" },
    { "name": "compensation_amount", "type": "number", "description": "Payment amount per cycle.", "required": true, "example": 5000 },
    { "name": "compensation_currency", "type": "string", "description": "ISO 4217 currency code for compensation.", "required": true, "example": "USD" },
    { "name": "compensation_cycle", "type": "string", "description": "Payment frequency: 'monthly', 'semi_monthly', 'biweekly', or 'weekly'.", "required": false, "example": "monthly" },
    { "name": "start_date", "type": "string", "description": "Contract start date in YYYY-MM-DD format.", "required": true, "example": "2025-02-01" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.deel.com/rest/v2/contracts",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "type": "pay_as_you_go_contractor",
      "title": "Senior Frontend Developer",
      "scope_of_work": "Develop and maintain the company's web application frontend.",
      "worker_email": "maria@example.com",
      "compensation": {
        "amount": 5000,
        "currency": "USD",
        "cycle": "monthly"
      },
      "start_date": "2025-02-01"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "contract-002",
        "type": "pay_as_you_go_contractor",
        "status": "waiting",
        "title": "Senior Frontend Developer",
        "worker_email": "maria@example.com",
        "compensation": {
          "amount": 5000,
          "currency": "USD",
          "cycle": "monthly"
        },
        "start_date": "2025-02-01"
      }
    }
  }
}
