{
  "name": "contracts_get",
  "resource_group": "Contracts",
  "endpoint": "/rest/v2/contracts/{contract_id}",
  "method": "GET",
  "description": "Retrieve a specific contract with full details.",
  "parameters": [
    {
      "name": "contract_id",
      "type": "string",
      "required": true,
      "description": "Contract ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/contracts/ct-1",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "ct-1",
        "type": "contractor",
        "status": "active",
        "title": "Software Engineer"
      }
    }
  }
}
