{
  "name": "people_create",
  "resource_group": "People",
  "endpoint": "/rest/v2/people",
  "method": "POST",
  "description": "Create a new worker (employee) in Deel.",
  "parameters": [
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Worker details including name, email, country, and job info."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.letsdeel.com/rest/v2/people",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "data": {
        "first_name": "Jane",
        "last_name": "Smith",
        "email": "jane@example.com",
        "country": "US"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "worker-1",
        "first_name": "Jane",
        "last_name": "Smith"
      }
    }
  }
}