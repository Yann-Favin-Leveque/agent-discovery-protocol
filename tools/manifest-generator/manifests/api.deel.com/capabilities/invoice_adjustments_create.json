  "parameters": [
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Invoice adjustment details.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.letsdeel.com/rest/v2/invoice-adjustments",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "data": {
        "contract_id": "ct-1",
        "amount": 200,
        "description": "Equipment reimbursement"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": "ia-1",
        "amount": 200
      }
    }
  }
}
