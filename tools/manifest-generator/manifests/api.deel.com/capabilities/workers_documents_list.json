{
  "name": "workers_documents_list",
  "resource_group": "Workers",
  "endpoint": "/rest/v2/workers/{worker_id}/documents",
  "method": "GET",
  "description": "List all documents for a worker.",
  "parameters": [
    {
      "name": "worker_id",
      "type": "string",
      "required": true,
      "description": "Worker ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/workers/worker-1/documents",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "doc-1",
          "name": "passport.pdf",
          "type": "identity"
        }
      ]
    }
  }
}