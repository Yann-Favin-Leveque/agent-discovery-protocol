{
  "name": "people_get",
  "resource_group": "People",
  "endpoint": "/rest/v2/people/{worker_id}",
  "method": "GET",
  "description": "Retrieve a single worker's profile and contract details.",
  "parameters": [
    {
      "name": "worker_id",
      "type": "string",
      "required": true,
      "description": "Worker ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.letsdeel.com/rest/v2/people/worker-1",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "worker-1",
        "first_name": "Jane",
        "last_name": "Smith",
        "email": "jane@example.com",
        "contracts": [
          {
            "id": "ct-1"
          }
        ]
      }
    }
  }
}
