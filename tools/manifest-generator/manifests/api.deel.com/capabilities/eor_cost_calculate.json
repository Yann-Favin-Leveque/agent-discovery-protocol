{
  "name": "eor_cost_calculate",
  "resource_group": "EOR",
  "endpoint": "/rest/v2/eor/employment_cost",
  "method": "POST",
  "description": "Calculate estimated employment costs for a country.",
  "parameters": [
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Country, salary amount, and currency."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.letsdeel.com/rest/v2/eor/employment_cost",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "data": {
        "country": "DE",
        "salary": 80000,
        "currency": "EUR"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "total_cost": 96000,
        "employer_costs": 16000,
        "currency": "EUR"
      }
    }
  }
}