{
  "name": "list_payments",
  "description": "Retrieve payment history across all contracts in your organization. Shows amounts, currencies, payment dates, processing statuses, and associated contract details. Useful for financial reconciliation.",
  "endpoint": "/rest/v2/payments",
  "method": "GET",
  "parameters": [
    { "name": "contract_id", "type": "string", "description": "Filter payments by a specific contract ID.", "required": false, "example": "contract-001" },
    { "name": "status", "type": "string", "description": "Filter by payment status: 'pending', 'processing', 'completed', or 'failed'.", "required": false, "example": "completed" },
    { "name": "from_date", "type": "string", "description": "Start of date range (YYYY-MM-DD).", "required": false, "example": "2025-01-01" },
    { "name": "to_date", "type": "string", "description": "End of date range (YYYY-MM-DD).", "required": false, "example": "2025-03-31" },
    { "name": "limit", "type": "integer", "description": "Number of results per page.", "required": false, "example": 50 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deel.com/rest/v2/payments?status=completed&from_date=2025-01-01&to_date=2025-03-31&limit=50",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "payment-001",
          "contract_id": "contract-001",
          "worker_name": "Maria Garcia",
          "amount": 5000,
          "currency": "USD",
          "status": "completed",
          "payment_date": "2025-01-31",
          "description": "January 2025 - Monthly payment"
        }
      ],
      "page": { "total": 1, "offset": 0, "limit": 50 }
    }
  }
}
