{
  "name": "auth_tokens_create",
  "description": "Create a new authentication token.",
  "endpoint": "/v3/user/tokens",
  "method": "POST",
  "resource_group": "authentication",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Token name",
      "required": true,
      "example": "CI/CD Token"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v3/user/tokens",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "CI/CD Token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "token": {
        "id": "tok_456",
        "name": "CI/CD Token",
        "token": "vercel_xxxxx"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}