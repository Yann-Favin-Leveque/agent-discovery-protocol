{
  "name": "teams_create",
  "description": "Create a new team.",
  "endpoint": "/v1/teams",
  "method": "POST",
  "resource_group": "teams",
  "parameters": [
    {
      "name": "slug",
      "type": "string",
      "description": "Team URL slug",
      "required": true,
      "example": "my-team",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Team display name",
      "required": false,
      "example": "My Team",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v1/teams",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "slug": "my-team",
      "name": "My Team"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "team_123",
      "slug": "my-team"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
