{
  "name": "deployments_events_get",
  "description": "Get build logs and events for a deployment.",
  "endpoint": "/v3/deployments/{idOrUrl}/events",
  "method": "GET",
  "resource_group": "deployments",
  "parameters": [
    {
      "name": "idOrUrl",
      "type": "string",
      "description": "Deployment ID or URL",
      "required": true,
      "example": "dpl_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v3/deployments/dpl_123/events",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "type": "stdout",
        "text": "Building...",
        "created": 1609459200000
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
