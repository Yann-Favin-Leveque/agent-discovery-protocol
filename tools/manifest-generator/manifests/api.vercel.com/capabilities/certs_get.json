{
  "name": "certs_get",
  "description": "Get SSL certificate details.",
  "endpoint": "/v8/certs/{id}",
  "method": "GET",
  "resource_group": "certs",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Certificate ID",
      "required": true,
      "example": "cert_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v8/certs/cert_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cert_123",
      "cns": [
        "example.com"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
