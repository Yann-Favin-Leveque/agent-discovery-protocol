{
  "name": "edge_configs_create",
  "description": "Create a new Edge Config for key-value data at the edge.",
  "endpoint": "/v1/edge-config",
  "method": "POST",
  "resource_group": "edge_config",
  "parameters": [
    {
      "name": "slug",
      "type": "string",
      "description": "Edge Config slug",
      "required": true,
      "example": "my-config"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v1/edge-config",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "slug": "my-config"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ecfg_456",
      "slug": "my-config"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}