{
  "name": "project_domains_add",
  "description": "Add a domain to a project.",
  "endpoint": "/v10/projects/{idOrName}/domains",
  "method": "POST",
  "resource_group": "projects",
  "parameters": [
    {
      "name": "idOrName",
      "type": "string",
      "description": "Project ID or name",
      "required": true,
      "example": "my-app",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v10/projects/my-app/domains",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "example.com",
      "projectId": "prj_123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
