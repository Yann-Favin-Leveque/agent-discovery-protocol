{
  "name": "deployments_cancel",
  "description": "Cancel a deployment currently building.",
  "endpoint": "/v12/deployments/{id}/cancel",
  "method": "PATCH",
  "resource_group": "deployments",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Deployment ID",
      "required": true,
      "example": "dpl_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.vercel.com/v12/deployments/dpl_123/cancel",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "uid": "dpl_123",
      "readyState": "CANCELED"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
