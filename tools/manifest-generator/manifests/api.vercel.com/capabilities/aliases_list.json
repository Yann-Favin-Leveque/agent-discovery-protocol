{
  "name": "aliases_list",
  "description": "List all aliases.",
  "endpoint": "/v4/aliases",
  "method": "GET",
  "resource_group": "aliases",
  "parameters": [
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID",
      "required": false,
      "example": "team_123",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v4/aliases",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "aliases": [
        {
          "uid": "alias_123",
          "alias": "my-app.vercel.app"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
