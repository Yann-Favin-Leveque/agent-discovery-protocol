{
  "name": "certs_issue",
  "description": "Issue a new SSL certificate.",
  "endpoint": "/v8/certs",
  "method": "POST",
  "resource_group": "certs",
  "parameters": [
    {
      "name": "cns",
      "type": "array",
      "description": "Common names (domains)",
      "required": true,
      "example": [
        "example.com"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v8/certs",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "cns": [
        "example.com"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cert_456",
      "cns": [
        "example.com"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
