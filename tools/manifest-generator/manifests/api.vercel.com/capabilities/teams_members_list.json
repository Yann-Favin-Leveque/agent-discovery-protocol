{
  "name": "teams_members_list",
  "description": "List all members of a team.",
  "endpoint": "/v3/teams/{teamId}/members",
  "method": "GET",
  "resource_group": "teams",
  "parameters": [
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID",
      "required": true,
      "example": "team_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v3/teams/team_123/members",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "members": [
        {
          "uid": "user_123",
          "role": "OWNER",
          "email": "owner@example.com"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}