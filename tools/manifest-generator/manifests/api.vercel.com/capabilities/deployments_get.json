{
  "name": "deployments_get",
  "description": "Get a deployment by ID or URL.",
  "endpoint": "/v13/deployments/{idOrUrl}",
  "method": "GET",
  "resource_group": "deployments",
  "parameters": [
    {
      "name": "idOrUrl",
      "type": "string",
      "description": "Deployment ID or URL",
      "required": true,
      "example": "dpl_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v13/deployments/dpl_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dpl_123",
      "url": "my-app-abc.vercel.app",
      "readyState": "READY"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}