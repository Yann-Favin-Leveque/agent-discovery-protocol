{
  "name": "dns_records_list",
  "description": "List DNS records for a domain.",
  "endpoint": "/v4/domains/{domain}/records",
  "method": "GET",
  "resource_group": "dns",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v4/domains/example.com/records",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "records": [
        {
          "id": "rec_123",
          "type": "A",
          "name": "",
          "value": "76.76.21.21"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
