{
  "name": "dns_records_delete",
  "description": "Delete a DNS record.",
  "endpoint": "/v2/domains/{domain}/records/{recordId}",
  "method": "DELETE",
  "resource_group": "dns",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com",
      "in": "path"
    },
    {
      "name": "recordId",
      "type": "string",
      "description": "DNS record ID",
      "required": true,
      "example": "rec_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.vercel.com/v2/domains/example.com/records/rec_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
