{
  "name": "teams_get",
  "description": "Get information about a specific team.",
  "endpoint": "/v2/teams/{teamId}",
  "method": "GET",
  "resource_group": "teams",
  "parameters": [
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID",
      "required": true,
      "example": "team_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v2/teams/team_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "team_123",
      "name": "My Team",
      "slug": "my-team"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
