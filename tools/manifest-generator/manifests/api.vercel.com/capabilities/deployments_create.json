{
  "name": "deployments_create",
  "description": "Create a new deployment from a Git source or file uploads.",
  "endpoint": "/v13/deployments",
  "method": "POST",
  "resource_group": "deployments",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Project name",
      "required": true,
      "example": "my-app"
    },
    {
      "name": "gitSource",
      "type": "object",
      "description": "Git source configuration",
      "required": false,
      "example": {
        "type": "github",
        "ref": "main",
        "repoId": 123456
      }
    },
    {
      "name": "target",
      "type": "string",
      "description": "Deployment target (production, preview, staging)",
      "required": false,
      "example": "production"
    },
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID",
      "required": false,
      "example": "team_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v13/deployments",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "my-app",
      "target": "production",
      "gitSource": {
        "type": "github",
        "ref": "main",
        "repoId": 123456
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dpl_456",
      "url": "my-app-xyz.vercel.app",
      "readyState": "BUILDING"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}