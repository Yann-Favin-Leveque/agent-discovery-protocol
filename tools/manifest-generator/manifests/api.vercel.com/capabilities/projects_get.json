{
  "name": "projects_get",
  "description": "Find a project by its ID or name.",
  "endpoint": "/v9/projects/{idOrName}",
  "method": "GET",
  "resource_group": "projects",
  "parameters": [
    {
      "name": "idOrName",
      "type": "string",
      "description": "Project ID or name",
      "required": true,
      "example": "my-app"
    },
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID",
      "required": false,
      "example": "team_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v9/projects/my-app",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "prj_123",
      "name": "my-app",
      "framework": "nextjs",
      "link": {
        "type": "github",
        "repo": "user/my-app"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}