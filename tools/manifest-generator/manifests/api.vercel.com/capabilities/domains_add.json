{
  "name": "domains_add",
  "description": "Add or transfer a domain to your Vercel account.",
  "endpoint": "/v7/domains",
  "method": "POST",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v7/domains",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "domain": {
        "name": "example.com"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
