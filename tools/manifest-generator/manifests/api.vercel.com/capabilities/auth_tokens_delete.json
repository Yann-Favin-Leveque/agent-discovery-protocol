{
  "name": "auth_tokens_delete",
  "description": "Delete an authentication token.",
  "endpoint": "/v3/user/tokens/{tokenId}",
  "method": "DELETE",
  "resource_group": "authentication",
  "parameters": [
    {
      "name": "tokenId",
      "type": "string",
      "description": "Token ID",
      "required": true,
      "example": "tok_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.vercel.com/v3/user/tokens/tok_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
