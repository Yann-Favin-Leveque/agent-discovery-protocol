{
  "name": "deployments_promote",
  "description": "Promote a deployment to production.",
  "endpoint": "/v10/projects/{projectId}/promote/{deploymentId}",
  "method": "POST",
  "resource_group": "deployments",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "description": "Project ID",
      "required": true,
      "example": "prj_123",
      "in": "path"
    },
    {
      "name": "deploymentId",
      "type": "string",
      "description": "Deployment ID to promote",
      "required": true,
      "example": "dpl_new",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v10/projects/prj_123/promote/dpl_new",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "PROMOTED"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
