{
  "name": "env_vars_delete",
  "description": "Remove an environment variable from a project.",
  "endpoint": "/v9/projects/{idOrName}/env/{id}",
  "method": "DELETE",
  "resource_group": "environment",
  "parameters": [
    {
      "name": "idOrName",
      "type": "string",
      "description": "Project ID or name",
      "required": true,
      "example": "my-app"
    },
    {
      "name": "id",
      "type": "string",
      "description": "Environment variable ID",
      "required": true,
      "example": "env_123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.vercel.com/v9/projects/my-app/env/env_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}