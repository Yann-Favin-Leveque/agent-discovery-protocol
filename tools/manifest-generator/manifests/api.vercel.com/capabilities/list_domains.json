{
  "name": "list_domains",
  "description": "List all domains registered in your Vercel account. Returns domain names, verification status, nameserver configuration, and whether DNS is managed by Vercel or externally.",
  "endpoint": "/v5/domains",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Maximum number of domains to return. Default is 20."
    },
    {
      "name": "since",
      "type": "string",
      "required": false,
      "description": "Timestamp in milliseconds. Returns domains created after this timestamp for pagination."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v5/domains?limit=20"
  },
  "response_example": {
    "domains": [
      {
        "name": "myapp.com",
        "apexName": "myapp.com",
        "verified": true,
        "nameservers": [
          "ns1.vercel-dns.com",
          "ns2.vercel-dns.com"
        ],
        "serviceType": "external",
        "cdnEnabled": true,
        "createdAt": 1700000000000,
        "boughtAt": null,
        "transferredAt": null
      },
      {
        "name": "staging.myapp.com",
        "apexName": "myapp.com",
        "verified": true,
        "nameservers": [
          "ns1.vercel-dns.com",
          "ns2.vercel-dns.com"
        ],
        "serviceType": "external",
        "cdnEnabled": true,
        "createdAt": 1702000000000,
        "boughtAt": null,
        "transferredAt": null
      }
    ],
    "pagination": {
      "count": 2,
      "next": null
    }
  }
}
