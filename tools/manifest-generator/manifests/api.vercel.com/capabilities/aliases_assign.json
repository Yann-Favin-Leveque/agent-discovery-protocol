{
  "name": "aliases_assign",
  "description": "Assign an alias to a deployment.",
  "endpoint": "/v2/deployments/{id}/aliases",
  "method": "POST",
  "resource_group": "aliases",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Deployment ID",
      "required": true,
      "example": "dpl_123"
    },
    {
      "name": "alias",
      "type": "string",
      "description": "Alias domain",
      "required": true,
      "example": "my-app.vercel.app"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v2/deployments/dpl_123/aliases",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "alias": "my-app.vercel.app"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uid": "alias_456",
      "alias": "my-app.vercel.app"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}