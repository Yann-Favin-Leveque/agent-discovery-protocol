{
  "name": "project_domains_delete",
  "description": "Remove a domain from a project.",
  "endpoint": "/v9/projects/{idOrName}/domains/{domain}",
  "method": "DELETE",
  "resource_group": "projects",
  "parameters": [
    {
      "name": "idOrName",
      "type": "string",
      "description": "Project ID or name",
      "required": true,
      "example": "my-app",
      "in": "path"
    },
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.vercel.com/v9/projects/my-app/domains/example.com",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
