{
  "name": "webhooks_list",
  "description": "List all webhooks.",
  "endpoint": "/v1/webhooks",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID",
      "required": false,
      "example": "team_123",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v1/webhooks",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "wh_123",
        "url": "https://example.com/webhook",
        "events": [
          "deployment.created"
        ]
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
