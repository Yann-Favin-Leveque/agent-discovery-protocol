{
  "name": "domains_list",
  "description": "List all domains in your Vercel account.",
  "endpoint": "/v5/domains",
  "method": "GET",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID",
      "required": false,
      "example": "team_123",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v5/domains",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "domains": [
        {
          "name": "example.com",
          "verified": true
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
