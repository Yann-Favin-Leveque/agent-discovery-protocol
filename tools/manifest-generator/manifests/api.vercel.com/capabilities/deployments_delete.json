{
  "name": "deployments_delete",
  "description": "Delete a deployment.",
  "endpoint": "/v13/deployments/{id}",
  "method": "DELETE",
  "resource_group": "deployments",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Deployment ID",
      "required": true,
      "example": "dpl_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.vercel.com/v13/deployments/dpl_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "uid": "dpl_123",
      "state": "DELETED"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
