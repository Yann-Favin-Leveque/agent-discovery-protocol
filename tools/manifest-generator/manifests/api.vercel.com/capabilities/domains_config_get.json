{
  "name": "domains_config_get",
  "description": "Get DNS configuration status for a domain.",
  "endpoint": "/v6/domains/{domain}/config",
  "method": "GET",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v6/domains/example.com/config",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "configuredBy": "CNAME",
      "misconfigured": false
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}