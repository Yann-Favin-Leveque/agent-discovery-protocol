{
  "name": "project_domains_verify",
  "description": "Verify DNS configuration for a project domain.",
  "endpoint": "/v9/projects/{idOrName}/domains/{domain}/verify",
  "method": "POST",
  "resource_group": "projects",
  "parameters": [
    {
      "name": "idOrName",
      "type": "string",
      "description": "Project ID or name",
      "required": true,
      "example": "my-app"
    },
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.vercel.com/v9/projects/my-app/domains/example.com/verify",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "example.com",
      "verified": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}