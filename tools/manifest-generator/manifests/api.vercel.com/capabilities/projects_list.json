{
  "name": "projects_list",
  "description": "Retrieve a list of all projects in your Vercel account.",
  "endpoint": "/v10/projects",
  "method": "GET",
  "resource_group": "projects",
  "parameters": [
    {
      "name": "teamId",
      "type": "string",
      "description": "Team ID to list projects for",
      "required": false,
      "example": "team_123"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of projects to return",
      "required": false,
      "example": "20"
    },
    {
      "name": "search",
      "type": "string",
      "description": "Search projects by name",
      "required": false,
      "example": "my-app"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v10/projects",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "projects": [
        {
          "id": "prj_123",
          "name": "my-app",
          "framework": "nextjs"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}