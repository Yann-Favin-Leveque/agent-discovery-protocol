{
  "name": "get_project",
  "description": "Get detailed information about a specific Vercel project by its ID or name. Returns the project's framework, build settings, linked Git repository, root directory, environment variables count, and latest deployment details.",
  "endpoint": "/v9/projects/{idOrName}",
  "method": "GET",
  "parameters": [
    {
      "name": "idOrName",
      "type": "string",
      "required": true,
      "description": "The project ID (e.g., 'prj_a1b2c3d4') or the project name (e.g., 'my-nextjs-app')."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v9/projects/my-nextjs-app"
  },
  "response_example": {
