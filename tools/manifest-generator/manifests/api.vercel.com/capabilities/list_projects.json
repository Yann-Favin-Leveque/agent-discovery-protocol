{
  "name": "list_projects",
  "description": "List all projects in your Vercel account. Returns project names, IDs, framework detection results, latest deployment status, and linked Git repositories. Supports pagination via limit and offset parameters.",
  "endpoint": "/v9/projects",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Maximum number of projects to return. Default is 20, maximum is 100."
    },
    {
      "name": "from",
      "type": "string",
      "required": false,
      "description": "Timestamp in milliseconds to paginate results. Returns projects created before this timestamp."
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "description": "Search string to filter projects by name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v9/projects?limit=10"
  },
