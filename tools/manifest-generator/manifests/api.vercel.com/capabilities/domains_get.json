{
  "name": "domains_get",
  "description": "Get information about a single domain.",
  "endpoint": "/v5/domains/{domain}",
  "method": "GET",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v5/domains/example.com",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "domain": {
        "name": "example.com",
        "verified": true
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}