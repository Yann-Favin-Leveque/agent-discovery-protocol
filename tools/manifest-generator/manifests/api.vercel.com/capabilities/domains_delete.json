{
  "name": "domains_delete",
  "description": "Remove a domain from your account.",
  "endpoint": "/v6/domains/{domain}",
  "method": "DELETE",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.vercel.com/v6/domains/example.com",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "uid": "dom_123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}