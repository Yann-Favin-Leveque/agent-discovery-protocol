{
  "name": "edge_config_items_list",
  "description": "Get all items in an Edge Config.",
  "endpoint": "/v1/edge-config/{edgeConfigId}/items",
  "method": "GET",
  "resource_group": "edge_config",
  "parameters": [
    {
      "name": "edgeConfigId",
      "type": "string",
      "description": "Edge Config ID",
      "required": true,
      "example": "ecfg_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vercel.com/v1/edge-config/ecfg_123/items",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "key": "feature_flag",
        "value": true
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
