{
  "name": "contacts_create",
  "description": "Create a new contact for domain registrations.",
  "resource_group": "contacts",
  "endpoint": "/{account}/contacts",
  "method": "POST",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "first_name",
      "type": "string",
      "required": true,
      "description": "First name."
    },
    {
      "name": "last_name",
      "type": "string",
      "required": true,
      "description": "Last name."
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email."
    },
    {
      "name": "phone",
      "type": "string",
      "required": true,
      "description": "Phone."
    },
    {
      "name": "address1",
      "type": "string",
      "required": true,
      "description": "Address."
    },
    {
      "name": "city",
      "type": "string",
      "required": true,
      "description": "City."
    },
    {
      "name": "state_province",
      "type": "string",
      "required": true,
      "description": "State."
    },
    {
      "name": "postal_code",
      "type": "string",
      "required": true,
      "description": "Postal code."
    },
    {
      "name": "country",
      "type": "string",
      "required": true,
      "description": "Country code."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dnsimple.com/v2/1010/contacts",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "first_name": "John",
      "last_name": "Doe",
      "email": "john@example.com",
      "phone": "+15555555555",
      "address1": "123 Main",
      "city": "Anytown",
      "state_province": "CA",
      "postal_code": "90001",
      "country": "US"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": 2,
        "first_name": "John",
        "last_name": "Doe",
        "email": "john@example.com"
      }
    }
  }
}