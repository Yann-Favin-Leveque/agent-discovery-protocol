{
  "name": "webhooks_create",
  "description": "Register a new webhook endpoint.",
  "resource_group": "webhooks",
  "endpoint": "/{account}/webhooks",
  "method": "POST",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "url",
      "type": "string",
      "required": true,
      "description": "Webhook endpoint URL."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dnsimple.com/v2/1010/webhooks",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://example.com/webhook"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": 2,
        "url": "https://example.com/webhook"
      }
    }
  }
}