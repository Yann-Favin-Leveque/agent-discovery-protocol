{
  "name": "zone_records_get",
  "description": "Retrieve details of a specific DNS record.",
  "resource_group": "zones",
  "endpoint": "/{account}/zones/{zone}/records/{record}",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "zone",
      "type": "string",
      "required": true,
      "description": "Zone name.",
      "in": "path"
    },
    {
      "name": "record",
      "type": "integer",
      "required": true,
      "description": "Record ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/zones/example.com/records/1",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": 1,
        "zone_id": "example.com",
        "name": "www",
        "type": "A",
        "content": "192.0.2.1",
        "ttl": 3600
      }
    }
  }
}
