{
  "name": "domain_delegation_get",
  "description": "List the name servers a domain is delegated to.",
  "resource_group": "registrar",
  "endpoint": "/{account}/registrar/domains/{domain}/delegation",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/registrar/domains/example.com/delegation",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        "ns1.dnsimple.com",
        "ns2.dnsimple-edge.net"
      ]
    }
  }
}
