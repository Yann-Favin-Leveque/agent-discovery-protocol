  "resource_group": "accounts",
  "endpoint": "/accounts",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/accounts",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "email": "user@example.com",
          "plan_identifier": "gold",
          "created_at": "2024-01-01T00:00:00Z"
        }
      ]
    }
  }
}