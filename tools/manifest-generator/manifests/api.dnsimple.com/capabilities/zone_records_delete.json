{
  "name": "zone_records_delete",
  "description": "Permanently delete a DNS record from a zone.",
  "resource_group": "zones",
  "endpoint": "/{account}/zones/{zone}/records/{record}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "zone",
      "type": "string",
      "required": true,
      "description": "Zone name."
    },
    {
      "name": "record",
      "type": "integer",
      "required": true,
      "description": "Record ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dnsimple.com/v2/1010/zones/example.com/records/1",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}