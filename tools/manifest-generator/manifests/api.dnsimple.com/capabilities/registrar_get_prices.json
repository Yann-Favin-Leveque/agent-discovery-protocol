{
  "name": "registrar_get_prices",
  "description": "Retrieve registration, renewal, and transfer prices for a domain.",
  "resource_group": "registrar",
  "endpoint": "/{account}/registrar/domains/{domain}/prices",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/registrar/domains/example.com/prices",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "domain": "example.com",
        "premium": false,
        "registration_price": 14.0,
        "renewal_price": 14.0,
        "transfer_price": 14.0
      }
    }
  }
}