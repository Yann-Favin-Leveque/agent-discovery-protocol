{
  "name": "domains_get",
  "description": "Retrieve details of an existing domain.",
  "resource_group": "domains",
  "endpoint": "/{account}/domains/{domain}",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name or ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/domains/example.com",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": 1,
        "account_id": 1010,
        "name": "example.com",
        "state": "registered",
        "auto_renew": true,
        "expires_on": "2025-01-01"
      }
    }
  }
}
