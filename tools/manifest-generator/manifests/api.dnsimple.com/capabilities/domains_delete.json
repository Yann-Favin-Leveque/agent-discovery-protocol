{
  "name": "domains_delete",
  "description": "Permanently delete a domain from the account.",
  "resource_group": "domains",
  "endpoint": "/{account}/domains/{domain}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name or ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dnsimple.com/v2/1010/domains/example.com",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}