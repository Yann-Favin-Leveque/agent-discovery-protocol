{
  "name": "identity_whoami",
  "description": "Retrieve details about the currently authenticated user or account.",
  "resource_group": "identity",
  "endpoint": "/whoami",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/whoami",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "user": {
          "id": 1,
          "email": "user@example.com"
        },
        "account": {
          "id": 1
        }
      }
    }
  }
}