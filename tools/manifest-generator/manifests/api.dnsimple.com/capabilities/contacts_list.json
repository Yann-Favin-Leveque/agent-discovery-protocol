{
  "name": "contacts_list",
  "description": "List all contacts in the account.",
  "resource_group": "contacts",
  "endpoint": "/{account}/contacts",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/contacts",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "account_id": 1010,
          "first_name": "John",
          "last_name": "Doe",
          "email": "john@example.com",
          "phone": "+1 555 555 5555"
        }
      ]
    }
  }
}