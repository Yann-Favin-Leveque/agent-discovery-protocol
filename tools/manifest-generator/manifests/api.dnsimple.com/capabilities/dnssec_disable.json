{
  "name": "dnssec_disable",
  "description": "Disable DNSSEC for a domain.",
  "resource_group": "dnssec",
  "endpoint": "/{account}/domains/{domain}/dnssec",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dnsimple.com/v2/1010/domains/example.com/dnssec",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
