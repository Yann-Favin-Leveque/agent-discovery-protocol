{
  "name": "email_forwards_delete",
  "description": "Delete an email forward.",
  "resource_group": "email_forwards",
  "endpoint": "/{account}/domains/{domain}/email_forwards/{emailforward}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name.",
      "in": "path"
    },
    {
      "name": "emailforward",
      "type": "integer",
      "required": true,
      "description": "Email forward ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dnsimple.com/v2/1010/domains/example.com/email_forwards/1",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
