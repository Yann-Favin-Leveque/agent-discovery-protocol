      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "webhook",
      "type": "integer",
      "required": true,
      "description": "Webhook ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dnsimple.com/v2/1010/webhooks/1",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
