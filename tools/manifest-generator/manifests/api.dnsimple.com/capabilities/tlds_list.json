{
  "name": "tlds_list",
  "description": "List all TLDs supported for registration and transfer.",
  "resource_group": "tlds",
  "endpoint": "/tlds",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/tlds",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "tld": "com",
          "tld_type": 1,
          "whois_privacy": true,
          "auto_renew_only": false,
          "registration_enabled": true
        }
      ]
    }
  }
}