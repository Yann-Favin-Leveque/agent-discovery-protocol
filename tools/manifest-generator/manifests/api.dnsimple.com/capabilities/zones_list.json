{
  "name": "zones_list",
  "description": "List all DNS zones in the account.",
  "resource_group": "zones",
  "endpoint": "/{account}/zones",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "name_like",
      "type": "string",
      "required": false,
      "description": "Filter by name."
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort field."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/zones",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "account_id": 1010,
          "name": "example.com",
          "reverse": false,
          "secondary": false
        }
      ]
    }
  }
}