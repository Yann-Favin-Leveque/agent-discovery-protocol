{
  "name": "zone_records_list",
  "description": "List all DNS records for a zone with optional filtering by name and type.",
  "resource_group": "zones",
  "endpoint": "/{account}/zones/{zone}/records",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "zone",
      "type": "string",
      "required": true,
      "description": "Zone name (e.g., 'example.com')."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter records by exact name."
    },
    {
      "name": "name_like",
      "type": "string",
      "required": false,
      "description": "Filter by name substring."
    },
    {
      "name": "type",
      "type": "string",
      "required": false,
      "description": "Filter by record type (A, AAAA, CNAME, MX, TXT)."
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort field."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/zones/example.com/records",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "zone_id": "example.com",
          "name": "",
          "type": "A",
          "content": "192.0.2.1",
          "ttl": 3600,
          "priority": null,
          "regions": [
            "global"
          ]
        }
      ]
    }
  }
}