{
  "name": "registrar_renew_domain",
  "description": "Renew an existing domain registration.",
  "resource_group": "registrar",
  "endpoint": "/{account}/registrar/domains/{domain}/renewals",
  "method": "POST",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name."
    },
    {
      "name": "period",
      "type": "integer",
      "required": false,
      "description": "Renewal period in years."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dnsimple.com/v2/1010/registrar/domains/example.com/renewals",
    "headers": {
      "Authorization": "Bearer <token>",
      "Content-Type": "application/json"
    },
    "body": {
      "period": 1
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "id": 1,
        "domain_id": 1,
        "period": 1,
        "state": "new"
      }
    }
  }
}