{
  "name": "webhooks_list",
  "description": "List all registered webhooks.",
  "resource_group": "webhooks",
  "endpoint": "/{account}/webhooks",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/webhooks",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "url": "https://example.com/webhook"
        }
      ]
    }
  }
}