{
  "name": "email_forwards_list",
  "description": "List email forwards for a domain.",
  "resource_group": "email_forwards",
  "endpoint": "/{account}/domains/{domain}/email_forwards",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID."
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/domains/example.com/email_forwards",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": 1,
          "domain_id": 1,
          "alias_email": "info@example.com",
          "destination_email": "john@gmail.com"
        }
      ]
    }
  }
}