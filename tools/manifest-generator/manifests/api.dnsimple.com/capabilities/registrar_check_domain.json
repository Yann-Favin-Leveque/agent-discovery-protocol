{
  "name": "registrar_check_domain",
  "description": "Check domain availability for registration.",
  "resource_group": "registrar",
  "endpoint": "/{account}/registrar/domains/{domain}/check",
  "method": "GET",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "required": true,
      "description": "Account ID.",
      "in": "path"
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Domain name to check.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dnsimple.com/v2/1010/registrar/domains/example.com/check",
    "headers": {
      "Authorization": "Bearer <token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "domain": "example.com",
        "available": false,
        "premium": false
      }
    }
  }
}
