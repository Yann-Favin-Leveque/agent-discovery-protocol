{
  "name": "identity",
  "description": "Manage identity — exchange authorization code for access token, whoami. Supports standard CRUD operations through the REST API.",
  "endpoint": "/oauth/access_token",
  "method": "POST",
  "parameters": [
    {
      "name": "client_id",
      "type": "string",
      "description": "The client_id field.",
      "required": true,
      "example": "abc_123"
    },
    {
      "name": "client_secret",
      "type": "string",
      "description": "The client_secret field.",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "code",
      "type": "string",
      "description": "The code field.",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "grant_type",
      "type": "string",
      "description": "The grant_type field.",
      "required": true,
      "example": "authorization_code"
    },
    {
      "name": "redirect_uri",
      "type": "string",
      "description": "Must match the redirect_uri from the authorization request (used for validation only).",
      "required": true,
      "example": "https://example.com"
    },
    {
      "name": "state",
      "type": "string",
      "description": "Must match the state from the authorization request.",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dnsimple.com/v2/oauth/access_token",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "client_id": "abc_123",
      "client_secret": "example_value",
      "code": "example_value",
      "grant_type": "authorization_code",
      "redirect_uri": "https://example.com",
      "state": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "client_id": "abc_123",
        "client_secret": "example_value",
        "code": "example_value",
        "grant_type": "authorization_code",
        "redirect_uri": "https://example.com",
        "state": "example_value"
      }
    }
  }
}
