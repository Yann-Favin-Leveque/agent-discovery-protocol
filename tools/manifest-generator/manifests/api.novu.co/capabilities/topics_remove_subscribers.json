{
  "name": "topics_remove_subscribers",
  "description": "Remove subscribers from a topic.",
  "resource_group": "topics",
  "endpoint": "/v1/topics/{topicKey}/subscribers",
  "method": "DELETE",
  "parameters": [
    {
      "name": "topicKey",
      "type": "string",
      "required": true,
      "description": "Topic key."
    },
    {
      "name": "subscribers",
      "type": "array",
      "required": true,
      "description": "Subscriber IDs to remove."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.novu.co/v1/topics/product-updates/subscribers",
    "headers": {
      "Authorization": "ApiKey <key>",
      "Content-Type": "application/json"
    },
    "body": {
      "subscribers": [
        "user1"
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}