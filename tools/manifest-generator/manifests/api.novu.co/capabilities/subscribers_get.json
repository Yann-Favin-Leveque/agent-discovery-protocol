{
  "name": "subscribers_get",
  "description": "Retrieve a subscriber by their unique ID.",
  "resource_group": "subscribers",
  "endpoint": "/v1/subscribers/{subscriberId}",
  "method": "GET",
  "parameters": [
    {
      "name": "subscriberId",
      "type": "string",
      "required": true,
      "description": "Subscriber ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.novu.co/v1/subscribers/user123",
    "headers": {
      "Authorization": "ApiKey <key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "subscriberId": "user123",
        "firstName": "John",
        "lastName": "Doe",
        "email": "user@example.com"
      }
    }
  }
}