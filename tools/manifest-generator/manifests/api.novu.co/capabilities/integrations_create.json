{
  "name": "integrations_create",
  "description": "Create a new channel integration (email, SMS, push, chat provider).",
  "resource_group": "integrations",
  "endpoint": "/v1/integrations",
  "method": "POST",
  "parameters": [
    {
      "name": "providerId",
      "type": "string",
      "required": true,
      "description": "Provider identifier (e.g., 'sendgrid', 'twilio', 'fcm').",
      "in": "body"
    },
    {
      "name": "channel",
      "type": "string",
      "required": true,
      "description": "Channel type: email, sms, push, chat, in_app.",
      "in": "body"
    },
    {
      "name": "credentials",
      "type": "object",
      "required": true,
      "description": "Provider-specific credentials.",
      "in": "body"
    },
    {
      "name": "active",
      "type": "boolean",
      "required": false,
      "description": "Whether integration is active.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.novu.co/v1/integrations",
    "headers": {
      "Authorization": "ApiKey <key>",
      "Content-Type": "application/json"
    },
    "body": {
      "providerId": "sendgrid",
      "channel": "email",
      "credentials": {
        "apiKey": "SG.xxx"
      },
      "active": true
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "_id": "int2",
        "providerId": "sendgrid",
        "channel": "email",
        "active": true
      }
    }
  }
}
