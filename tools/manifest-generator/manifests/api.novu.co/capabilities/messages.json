{
  "name": "messages",
  "description": "Manage messages — list all messages, delete a message, delete messages by transactionid. Supports standard CRUD operations through the REST API.",
  "endpoint": "/v1/messages",
  "method": "GET",
  "parameters": [
    {
      "name": "channel",
      "type": "string",
      "description": "The channel parameter.",
      "required": false,
      "example": "example_value"
    },
    {
      "name": "subscriberId",
      "type": "string",
      "description": "The subscriberId parameter.",
      "required": false,
      "example": "abc_123"
    },
    {
      "name": "transactionId",
      "type": "string[]",
      "description": "The transactionId parameter.",
      "required": false,
      "example": [
        "value1"
      ]
    },
    {
      "name": "contextKeys",
      "type": "string[]",
      "description": "Filter by exact context keys, order insensitive (format: \"type:id\")",
      "required": false,
      "example": [
        "tenant:org-123",
        "region:us-east-1"
      ]
    },
    {
      "name": "page",
      "type": "number",
      "description": "The page parameter.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "number",
      "description": "The limit parameter.",
      "required": false,
      "example": 10
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.novu.co/v1/messages",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {}
    }
  }
}
