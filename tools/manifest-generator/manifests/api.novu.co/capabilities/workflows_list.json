{
  "name": "workflows_list",
  "description": "List all notification workflows.",
  "resource_group": "workflows",
  "endpoint": "/v1/workflows",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.novu.co/v1/workflows",
    "headers": {
      "Authorization": "ApiKey <key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "_id": "wf1",
          "name": "Welcome",
          "triggers": [
            {
              "identifier": "welcome-flow"
            }
          ],
          "active": true,
          "steps": []
        }
      ],
      "totalCount": 1
    }
  }
}
