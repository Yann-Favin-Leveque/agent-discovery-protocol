{
  "name": "topics_list",
  "description": "List all topics with pagination.",
  "resource_group": "topics",
  "endpoint": "/v1/topics",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "pageSize",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "required": false,
      "description": "Filter by topic key.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.novu.co/v1/topics",
    "headers": {
      "Authorization": "ApiKey <key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "_id": "topic123",
          "key": "product-updates",
          "name": "Product Updates",
          "subscribers": []
        }
      ],
      "totalCount": 1,
      "page": 0,
      "pageSize": 10
    }
  }
}
