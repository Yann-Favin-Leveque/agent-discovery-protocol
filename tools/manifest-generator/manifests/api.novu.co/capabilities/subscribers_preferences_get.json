{
  "name": "subscribers_preferences_get",
  "description": "Retrieve notification preferences for a subscriber.",
  "resource_group": "subscribers",
  "endpoint": "/v1/subscribers/{subscriberId}/preferences",
  "method": "GET",
  "parameters": [
    {
      "name": "subscriberId",
      "type": "string",
      "required": true,
      "description": "Subscriber ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.novu.co/v1/subscribers/user123/preferences",
    "headers": {
      "Authorization": "ApiKey <key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "template": {
            "_id": "wf1",
            "name": "Welcome"
          },
          "preference": {
            "enabled": true,
            "channels": {
              "email": true,
              "in_app": true,
              "sms": false,
              "push": false
            }
          }
        }
      ]
    }
  }
}