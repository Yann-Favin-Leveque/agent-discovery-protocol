{
  "name": "subscribers_update",
  "description": "Update an existing subscriber's properties.",
  "resource_group": "subscribers",
  "endpoint": "/v1/subscribers/{subscriberId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "subscriberId",
      "type": "string",
      "required": true,
      "description": "Subscriber ID."
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Updated email."
    },
    {
      "name": "firstName",
      "type": "string",
      "required": false,
      "description": "Updated first name."
    },
    {
      "name": "lastName",
      "type": "string",
      "required": false,
      "description": "Updated last name."
    },
    {
      "name": "phone",
      "type": "string",
      "required": false,
      "description": "Updated phone."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.novu.co/v1/subscribers/user123",
    "headers": {
      "Authorization": "ApiKey <key>",
      "Content-Type": "application/json"
    },
    "body": {
      "firstName": "Jane"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "subscriberId": "user123",
        "firstName": "Jane"
      }
    }
  }
}