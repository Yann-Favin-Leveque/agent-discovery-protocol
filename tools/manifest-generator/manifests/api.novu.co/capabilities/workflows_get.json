{
  "name": "workflows_get",
  "description": "Retrieve a specific workflow by ID.",
  "resource_group": "workflows",
  "endpoint": "/v1/workflows/{workflowId}",
  "method": "GET",
  "parameters": [
    {
      "name": "workflowId",
      "type": "string",
      "required": true,
      "description": "Workflow ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.novu.co/v1/workflows/wf1",
    "headers": {
      "Authorization": "ApiKey <key>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "_id": "wf1",
        "name": "Welcome",
        "triggers": [
          {
            "identifier": "welcome-flow"
          }
        ],
        "active": true,
        "steps": [
          {
            "_id": "step1",
            "template": {
              "type": "email"
            }
          }
        ]
      }
    }
  }
}
