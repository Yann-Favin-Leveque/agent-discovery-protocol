{
  "name": "topics_create",
  "description": "Create a new topic for grouping subscribers.",
  "resource_group": "topics",
  "endpoint": "/v1/topics",
  "method": "POST",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "Unique topic key."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Topic display name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.novu.co/v1/topics",
    "headers": {
      "Authorization": "ApiKey <key>",
      "Content-Type": "application/json"
    },
    "body": {
      "key": "product-updates",
      "name": "Product Updates"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "_id": "topic123",
        "key": "product-updates",
        "name": "Product Updates"
      }
    }
  }
}