{
  "name": "render_resize",
  "resource_group": "rendering",
  "description": "Resize an image by specifying width, height, and fit mode via URL parameters.",
  "endpoint": "/{image_path}",
  "method": "GET",
  "parameters": [
    {
      "name": "w",
      "type": "integer",
      "required": false,
      "description": "Width in pixels."
    },
    {
      "name": "h",
      "type": "integer",
      "required": false,
      "description": "Height in pixels."
    },
    {
      "name": "fit",
      "type": "string",
      "required": false,
      "description": "Fit mode: clip, crop, fill, fillmax, max, min, scale."
    },
    {
      "name": "ar",
      "type": "string",
      "required": false,
      "description": "Aspect ratio (e.g. 16:9)."
    },
    {
      "name": "dpr",
      "type": "number",
      "required": false,
      "description": "Device pixel ratio. Default 1."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://my-source.imgix.net/images/photo.jpg?w=400&h=300&fit=crop",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<binary image data>"
  }
}