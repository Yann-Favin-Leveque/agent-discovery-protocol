{
  "name": "sources_list",
  "resource_group": "sources",
  "description": "List all imgix sources in your account.",
  "endpoint": "/api/v1/sources",
  "method": "GET",
  "parameters": [
    {
      "name": "page[number]",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "page[size]",
      "type": "integer",
      "required": false,
      "description": "Page size.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.imgix.com/api/v1/sources",
    "headers": {
      "Authorization": "Bearer imgix-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "source-id",
          "type": "sources",
          "attributes": {
            "name": "My Source",
            "deployment": {
              "type": "webfolder",
              "imgix_subdomains": [
                "my-source"
              ]
            },
            "deployment_status": "deployed",
            "enabled": true
          }
        }
      ]
    }
  }
}
