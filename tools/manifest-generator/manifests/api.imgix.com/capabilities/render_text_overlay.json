{
  "name": "render_text_overlay",
  "resource_group": "rendering",
  "description": "Render text on top of an image with font, size, color control.",
  "endpoint": "/{image_path}",
  "method": "GET",
  "parameters": [
    {
      "name": "txt",
      "type": "string",
      "required": true,
      "description": "Text to overlay (or base64 encoded).",
      "in": "query"
    },
    {
      "name": "txt-size",
      "type": "integer",
      "required": false,
      "description": "Font size in pixels.",
      "in": "query"
    },
    {
      "name": "txt-color",
      "type": "string",
      "required": false,
      "description": "Text color (hex without #).",
      "in": "query"
    },
    {
      "name": "txt-font",
      "type": "string",
      "required": false,
      "description": "Font name (e.g. Avenir-Heavy).",
      "in": "query"
    },
    {
      "name": "txt-align",
      "type": "string",
      "required": false,
      "description": "Alignment: top, middle, bottom, left, center, right.",
      "in": "query"
    },
    {
      "name": "txt-pad",
      "type": "integer",
      "required": false,
      "description": "Padding in pixels.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://my-source.imgix.net/images/photo.jpg?txt=Hello+World&txt-size=48&txt-color=ffffff&txt-align=center,middle",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<binary image data>"
  }
}
