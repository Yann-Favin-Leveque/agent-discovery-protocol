{
  "name": "assets_get",
  "resource_group": "assets",
  "description": "Get details for a single asset.",
  "endpoint": "/api/v1/sources/{source_id}/assets/{origin_path}",
  "method": "GET",
  "parameters": [
    {
      "name": "source_id",
      "type": "string",
      "required": true,
      "description": "Source ID.",
      "in": "path"
    },
    {
      "name": "origin_path",
      "type": "string",
      "required": true,
      "description": "Asset origin path.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.imgix.com/api/v1/sources/source-id/assets/images/photo.jpg",
    "headers": {
      "Authorization": "Bearer imgix-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "images/photo.jpg",
        "type": "assets",
        "attributes": {
          "origin_path": "images/photo.jpg",
          "media_width": 1200,
          "media_height": 800,
          "content_type": "image/jpeg"
        }
      }
    }
  }
}