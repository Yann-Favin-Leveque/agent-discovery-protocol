{
  "name": "list_sources",
  "description": "List all imgix sources in your account via the Management API. Returns source names, domains, deployment status, and configuration details. This is a REST API endpoint, unlike the rendering URL parameters.",
  "endpoint": "/api/v1/sources",
  "method": "GET",
  "parameters": [
    { "name": "page[number]", "type": "integer", "description": "Page number for pagination (starts at 0).", "required": false, "example": 0 },
    { "name": "page[size]", "type": "integer", "description": "Number of sources per page.", "required": false, "example": 10 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.imgix.com/api/v1/sources?page[number]=0&page[size]=10",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "source-id-uuid",
          "type": "sources",
          "attributes": {
            "name": "My Image Source",
            "deployment_status": "deployed",
            "enabled": true,
            "secure_url_token": null,
            "deployment": {
              "type": "s3",
              "s3_bucket": "my-images-bucket",
              "s3_prefix": ""
            },
            "domains": ["my-source.imgix.net"],
            "date_deployed": 1704067200
          }
        }
      ],
      "jsonapi": { "version": "1.0" },
      "meta": {
        "pagination": {
          "currentPage": 0,
          "hasNextPage": false,
          "totalRecords": 1
        }
      }
    }
  }
}
