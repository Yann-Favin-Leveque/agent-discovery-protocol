{
  "name": "sources_update",
  "resource_group": "sources",
  "description": "Update a source configuration.",
  "endpoint": "/api/v1/sources/{source_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "source_id",
      "type": "string",
      "required": true,
      "description": "Source ID.",
      "in": "path"
    },
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "JSON:API source object with updated attributes.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.imgix.com/api/v1/sources/source-id",
    "headers": {
      "Authorization": "Bearer imgix-api-key",
      "Content-Type": "application/vnd.api+json"
    },
    "body": {
      "data": {
        "id": "source-id",
        "type": "sources",
        "attributes": {
          "name": "Updated Source Name"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "source-id",
        "type": "sources",
        "attributes": {
          "name": "Updated Source Name"
        }
      }
    }
  }
}
