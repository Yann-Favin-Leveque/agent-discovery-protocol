{
  "name": "sources_get",
  "resource_group": "sources",
  "description": "Retrieve details for a single source.",
  "endpoint": "/api/v1/sources/{source_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "source_id",
      "type": "string",
      "required": true,
      "description": "Source ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.imgix.com/api/v1/sources/source-id",
    "headers": {
      "Authorization": "Bearer imgix-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "source-id",
        "type": "sources",
        "attributes": {
          "name": "My Source",
          "deployment_status": "deployed"
        }
      }
    }
  }
}