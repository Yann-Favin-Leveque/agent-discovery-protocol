{
  "name": "assets_add",
  "resource_group": "assets",
  "description": "Queue a path from your origin to be added to imgix for processing.",
  "endpoint": "/api/v1/sources/{source_id}/assets/add/{origin_path}",
  "method": "POST",
  "parameters": [
    {
      "name": "source_id",
      "type": "string",
      "required": true,
      "description": "Source ID.",
      "in": "path"
    },
    {
      "name": "origin_path",
      "type": "string",
      "required": true,
      "description": "Origin path to add.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.imgix.com/api/v1/sources/source-id/assets/add/images/photo.jpg",
    "headers": {
      "Authorization": "Bearer imgix-api-key",
      "Content-Type": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "images/photo.jpg",
        "type": "assets"
      }
    }
  }
}