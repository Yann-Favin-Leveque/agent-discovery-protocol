{
  "name": "render_format",
  "resource_group": "rendering",
  "description": "Convert image format and optimize quality via URL parameters.",
  "endpoint": "/{image_path}",
  "method": "GET",
  "parameters": [
    {
      "name": "fm",
      "type": "string",
      "required": false,
      "description": "Output format: webp, avif, png, jpg, gif, blurhash.",
      "in": "query"
    },
    {
      "name": "auto",
      "type": "string",
      "required": false,
      "description": "Auto optimizations: compress, format, enhance.",
      "in": "query"
    },
    {
      "name": "q",
      "type": "integer",
      "required": false,
      "description": "Quality 0-100. Default 75.",
      "in": "query"
    },
    {
      "name": "lossless",
      "type": "boolean",
      "required": false,
      "description": "Enable lossless compression.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://my-source.imgix.net/images/photo.jpg?auto=format,compress&q=80",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<binary image data>"
  }
}
