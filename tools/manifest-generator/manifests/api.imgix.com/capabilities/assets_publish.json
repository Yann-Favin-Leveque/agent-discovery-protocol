{
  "name": "assets_publish",
  "resource_group": "assets",
  "description": "Restore a previously unpublished asset to CDN delivery.",
  "endpoint": "/api/v1/publish",
  "method": "POST",
  "parameters": [
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Publish request with url and source_id.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.imgix.com/api/v1/publish",
    "headers": {
      "Authorization": "Bearer imgix-api-key",
      "Content-Type": "application/vnd.api+json"
    },
    "body": {
      "data": {
        "type": "publishes",
        "attributes": {
          "url": "https://my-source.imgix.net/images/photo.jpg",
          "source_id": "source-id"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
