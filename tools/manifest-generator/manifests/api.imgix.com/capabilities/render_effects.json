{
  "name": "render_effects",
  "resource_group": "rendering",
  "description": "Apply visual effects: blur, sharpen, sepia, monochrome, contrast adjustments.",
  "endpoint": "/{image_path}",
  "method": "GET",
  "parameters": [
    {
      "name": "blur",
      "type": "integer",
      "required": false,
      "description": "Blur amount 0-2000.",
      "in": "query"
    },
    {
      "name": "sharp",
      "type": "integer",
      "required": false,
      "description": "Sharpen amount 0-100.",
      "in": "query"
    },
    {
      "name": "sepia",
      "type": "integer",
      "required": false,
      "description": "Sepia tone 0-100.",
      "in": "query"
    },
    {
      "name": "monochrome",
      "type": "string",
      "required": false,
      "description": "Monochrome tint color (hex).",
      "in": "query"
    },
    {
      "name": "con",
      "type": "integer",
      "required": false,
      "description": "Contrast adjustment -100 to 100.",
      "in": "query"
    },
    {
      "name": "bri",
      "type": "integer",
      "required": false,
      "description": "Brightness adjustment -100 to 100.",
      "in": "query"
    },
    {
      "name": "sat",
      "type": "integer",
      "required": false,
      "description": "Saturation adjustment -100 to 100.",
      "in": "query"
    },
    {
      "name": "hue",
      "type": "integer",
      "required": false,
      "description": "Hue shift 0-359.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://my-source.imgix.net/images/photo.jpg?blur=20&sepia=80",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<binary image data>"
  }
}
