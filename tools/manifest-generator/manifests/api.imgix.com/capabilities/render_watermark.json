{
  "name": "render_watermark",
  "resource_group": "rendering",
  "description": "Overlay a watermark image on top of a base image.",
  "endpoint": "/{image_path}",
  "method": "GET",
  "parameters": [
    {
      "name": "mark",
      "type": "string",
      "required": true,
      "description": "URL of the watermark image.",
      "in": "query"
    },
    {
      "name": "mark-w",
      "type": "integer",
      "required": false,
      "description": "Watermark width.",
      "in": "query"
    },
    {
      "name": "mark-h",
      "type": "integer",
      "required": false,
      "description": "Watermark height.",
      "in": "query"
    },
    {
      "name": "mark-align",
      "type": "string",
      "required": false,
      "description": "Position: top, middle, bottom, left, center, right.",
      "in": "query"
    },
    {
      "name": "mark-alpha",
      "type": "integer",
      "required": false,
      "description": "Opacity 0-100.",
      "in": "query"
    },
    {
      "name": "mark-pad",
      "type": "integer",
      "required": false,
      "description": "Padding.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://my-source.imgix.net/images/photo.jpg?mark=https://my-source.imgix.net/logo.png&mark-w=100&mark-align=bottom,right&mark-alpha=50&mark-pad=10",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<binary image data>"
  }
}
