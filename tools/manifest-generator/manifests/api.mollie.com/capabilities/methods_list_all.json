{
  "name": "methods_list_all",
  "description": "List all payment methods known to Mollie, including disabled ones.",
  "resource_group": "methods",
  "endpoint": "/v2/methods/all",
  "method": "GET",
  "parameters": [
    {
      "name": "locale",
      "type": "string",
      "description": "Language for names.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/methods/all",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 15,
      "_embedded": {
        "methods": [
          {
            "resource": "method",
            "id": "ideal",
            "description": "iDEAL",
            "status": "activated"
          }
        ]
      }
    }
  }
}
