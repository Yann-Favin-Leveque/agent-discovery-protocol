{
  "name": "payments_update",
  "description": "Update payment details such as description or metadata.",
  "resource_group": "payments",
  "endpoint": "/v2/payments/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The payment ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false,
      "in": "body"
    },
    {
      "name": "redirectUrl",
      "type": "string",
      "description": "Updated redirect URL.",
      "required": false,
      "in": "body"
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Updated metadata.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "description": "Updated"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "payment",
      "id": "tr_7UhSN1zuXS",
      "description": "Updated"
    }
  }
}
