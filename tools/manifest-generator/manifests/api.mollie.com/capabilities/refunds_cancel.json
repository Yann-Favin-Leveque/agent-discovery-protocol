{
  "name": "refunds_cancel",
  "description": "Cancel a refund that has not yet been processed.",
  "resource_group": "refunds",
  "endpoint": "/v2/payments/{paymentId}/refunds/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "paymentId",
      "type": "string",
      "description": "The payment ID.",
      "required": true
    },
    {
      "name": "id",
      "type": "string",
      "description": "The refund ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS/refunds/re_4qqhO89gsT",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204
  }
}