{
  "name": "shipments_create",
  "description": "Create a shipment for an order to trigger fulfillment.",
  "resource_group": "shipments",
  "endpoint": "/v2/orders/{orderId}/shipments",
  "method": "POST",
  "parameters": [
    {
      "name": "orderId",
      "type": "string",
      "description": "The order ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "lines",
      "type": "array",
      "description": "Order lines to ship.",
      "required": false,
      "in": "body"
    },
    {
      "name": "tracking",
      "type": "object",
      "description": "Tracking information.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mollie.com/v2/orders/ord_pbjz8x/shipments",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "tracking": {
        "carrier": "PostNL",
        "code": "3SKABA000000000"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "resource": "shipment",
      "id": "shp_3wmsgCJN4U",
      "orderId": "ord_pbjz8x"
    }
  }
}
