{
  "name": "methods_get",
  "description": "Retrieve details of a specific payment method.",
  "resource_group": "methods",
  "endpoint": "/v2/methods/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payment method ID (e.g. ideal, creditcard).",
      "required": true,
      "example": "ideal",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/methods/ideal",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "method",
      "id": "ideal",
      "description": "iDEAL"
    }
  }
}
