{
  "name": "mandates_revoke",
  "description": "Revoke an existing mandate so it can no longer be used for payments.",
  "resource_group": "mandates",
  "endpoint": "/v2/customers/{customerId}/mandates/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "The customer ID.",
      "required": true
    },
    {
      "name": "id",
      "type": "string",
      "description": "The mandate ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mollie.com/v2/customers/cst_8wmqcHMN4U/mandates/mdt_h3gAaD5zP",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204
  }
}