{
  "name": "payments_get",
  "description": "Retrieve details and status of an existing payment by ID.",
  "resource_group": "payments",
  "endpoint": "/v2/payments/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The payment ID.",
      "required": true,
      "example": "tr_7UhSN1zuXS",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "payment",
      "id": "tr_7UhSN1zuXS",
      "status": "paid",
      "amount": {
        "currency": "EUR",
        "value": "10.00"
      }
    }
  }
}
