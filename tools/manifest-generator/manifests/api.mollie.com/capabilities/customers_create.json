{
  "name": "customers_create",
  "description": "Create a customer record to associate payments and enable recurring billing.",
  "resource_group": "customers",
  "endpoint": "/v2/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Full name of the customer.",
      "required": false,
      "example": "John Doe"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Email address of the customer.",
      "required": false,
      "example": "john@example.com"
    },
    {
      "name": "locale",
      "type": "string",
      "description": "Language preference.",
      "required": false
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Custom metadata.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mollie.com/v2/customers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "John Doe",
      "email": "john@example.com"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "resource": "customer",
      "id": "cst_8wmqcHMN4U",
      "name": "John Doe",
      "email": "john@example.com"
    }
  }
}