{
  "name": "captures_get",
  "description": "Retrieve details of a specific capture.",
  "resource_group": "captures",
  "endpoint": "/v2/payments/{paymentId}/captures/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "paymentId",
      "type": "string",
      "description": "The payment ID.",
      "required": true
    },
    {
      "name": "id",
      "type": "string",
      "description": "The capture ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS/captures/cpt_4qqhO89gsT",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "capture",
      "id": "cpt_4qqhO89gsT"
    }
  }
}