{
  "name": "customers_list",
  "description": "List all customers on your account.",
  "resource_group": "customers",
  "endpoint": "/v2/customers",
  "method": "GET",
  "parameters": [
    {
      "name": "from",
      "type": "string",
      "description": "Offset customer ID.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/customers",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "_embedded": {
        "customers": [
          {
            "resource": "customer",
            "id": "cst_8wmqcHMN4U"
          }
        ]
      }
    }
  }
}