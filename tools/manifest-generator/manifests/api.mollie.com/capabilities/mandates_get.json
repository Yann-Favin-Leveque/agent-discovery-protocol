{
  "name": "mandates_get",
  "description": "Retrieve the details of a specific mandate.",
  "resource_group": "mandates",
  "endpoint": "/v2/customers/{customerId}/mandates/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "The customer ID.",
      "required": true
    },
    {
      "name": "id",
      "type": "string",
      "description": "The mandate ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/customers/cst_8wmqcHMN4U/mandates/mdt_h3gAaD5zP",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "mandate",
      "id": "mdt_h3gAaD5zP",
      "status": "valid"
    }
  }
}