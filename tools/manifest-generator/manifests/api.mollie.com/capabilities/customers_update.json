{
  "name": "customers_update",
  "description": "Update an existing customer details.",
  "resource_group": "customers",
  "endpoint": "/v2/customers/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Updated email.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.mollie.com/v2/customers/cst_8wmqcHMN4U",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Jane Doe"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "customer",
      "id": "cst_8wmqcHMN4U",
      "name": "Jane Doe"
    }
  }
}
