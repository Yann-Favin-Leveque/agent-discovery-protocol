{
  "name": "subscriptions_list",
  "description": "List all subscriptions for a specific customer.",
  "resource_group": "subscriptions",
  "endpoint": "/v2/customers/{customerId}/subscriptions",
  "method": "GET",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "The customer ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/customers/cst_8wmqcHMN4U/subscriptions",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "_embedded": {
        "subscriptions": [
          {
            "resource": "subscription",
            "id": "sub_rVKGtNd6s3"
          }
        ]
      }
    }
  }
}