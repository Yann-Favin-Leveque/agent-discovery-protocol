{
  "name": "shipments_get",
  "description": "Retrieve the details of a specific shipment.",
  "resource_group": "shipments",
  "endpoint": "/v2/orders/{orderId}/shipments/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "orderId",
      "type": "string",
      "description": "The order ID.",
      "required": true
    },
    {
      "name": "id",
      "type": "string",
      "description": "The shipment ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/orders/ord_pbjz8x/shipments/shp_3wmsgCJN4U",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "shipment",
      "id": "shp_3wmsgCJN4U"
    }
  }
}