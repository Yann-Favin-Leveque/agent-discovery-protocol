{
  "name": "orders_update",
  "description": "Update an existing order.",
  "resource_group": "orders",
  "endpoint": "/v2/orders/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The order ID.",
      "required": true
    },
    {
      "name": "billingAddress",
      "type": "object",
      "description": "Updated billing address.",
      "required": false
    },
    {
      "name": "orderNumber",
      "type": "string",
      "description": "Updated order number.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.mollie.com/v2/orders/ord_pbjz8x",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "orderNumber": "ORD-002"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "order",
      "id": "ord_pbjz8x",
      "orderNumber": "ORD-002"
    }
  }
}