{
  "name": "balances_get",
  "description": "Retrieve a specific balance by its ID.",
  "resource_group": "balances",
  "endpoint": "/v2/balances/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The balance ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/balances/bal_gVMhHKqSSR",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "balance",
      "id": "bal_gVMhHKqSSR",
      "currency": "EUR",
      "availableAmount": {
        "currency": "EUR",
        "value": "905.25"
      }
    }
  }
}