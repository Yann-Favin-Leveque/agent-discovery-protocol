{
  "name": "chargebacks_get",
  "description": "Retrieve details of a specific chargeback.",
  "resource_group": "chargebacks",
  "endpoint": "/v2/payments/{paymentId}/chargebacks/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "paymentId",
      "type": "string",
      "description": "The payment ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The chargeback ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS/chargebacks/chb_n9z0tp",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "chargeback",
      "id": "chb_n9z0tp",
      "amount": {
        "currency": "EUR",
        "value": "10.00"
      }
    }
  }
}
