  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The order ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/orders/ord_pbjz8x",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "order",
      "id": "ord_pbjz8x",
      "status": "created"
    }
  }
}
