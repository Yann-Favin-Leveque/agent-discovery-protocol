  "name": "payments_cancel",
  "description": "Cancel a payment that has not been completed.",
  "resource_group": "payments",
  "endpoint": "/v2/payments/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The payment ID.",
      "required": true
    }
  ],
  "request_example": {
