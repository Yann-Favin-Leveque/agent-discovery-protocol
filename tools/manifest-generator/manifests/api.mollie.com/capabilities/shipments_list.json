{
  "name": "shipments_list",
  "description": "List all shipments for a specific order.",
  "resource_group": "shipments",
  "endpoint": "/v2/orders/{orderId}/shipments",
  "method": "GET",
  "parameters": [
    {
      "name": "orderId",
      "type": "string",
      "description": "The order ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/orders/ord_pbjz8x/shipments",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "_embedded": {
        "shipments": [
          {
            "resource": "shipment",
            "id": "shp_3wmsgCJN4U"
          }
        ]
      }
    }
  }
}
