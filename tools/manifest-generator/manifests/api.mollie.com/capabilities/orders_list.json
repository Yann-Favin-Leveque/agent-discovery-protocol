{
  "name": "orders_list",
  "description": "List all orders with pagination.",
  "resource_group": "orders",
  "endpoint": "/v2/orders",
  "method": "GET",
  "parameters": [
    {
      "name": "from",
      "type": "string",
      "description": "Offset order ID.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/orders",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "_embedded": {
        "orders": [
          {
            "resource": "order",
            "id": "ord_pbjz8x"
          }
        ]
      }
    }
  }
}