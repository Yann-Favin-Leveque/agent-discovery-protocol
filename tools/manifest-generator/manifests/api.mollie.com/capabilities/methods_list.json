{
  "name": "methods_list",
  "description": "List all enabled payment methods for your account.",
  "resource_group": "methods",
  "endpoint": "/v2/methods",
  "method": "GET",
  "parameters": [
    {
      "name": "locale",
      "type": "string",
      "description": "Language for names.",
      "required": false
    },
    {
      "name": "amount",
      "type": "object",
      "description": "Filter by amount.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/methods",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 5,
      "_embedded": {
        "methods": [
          {
            "resource": "method",
            "id": "ideal",
            "description": "iDEAL"
          }
        ]
      }
    }
  }
}