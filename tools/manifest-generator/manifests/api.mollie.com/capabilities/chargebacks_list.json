{
  "name": "chargebacks_list",
  "description": "List all chargebacks for a specific payment.",
  "resource_group": "chargebacks",
  "endpoint": "/v2/payments/{paymentId}/chargebacks",
  "method": "GET",
  "parameters": [
    {
      "name": "paymentId",
      "type": "string",
      "description": "The payment ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS/chargebacks",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "_embedded": {
        "chargebacks": [
          {
            "resource": "chargeback",
            "id": "chb_n9z0tp"
          }
        ]
      }
    }
  }
}
