{
  "name": "mandates_list",
  "description": "List all mandates for a specific customer.",
  "resource_group": "mandates",
  "endpoint": "/v2/customers/{customerId}/mandates",
  "method": "GET",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/customers/cst_8wmqcHMN4U/mandates",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "_embedded": {
        "mandates": [
          {
            "resource": "mandate",
            "id": "mdt_h3gAaD5zP"
          }
        ]
      }
    }
  }
}
