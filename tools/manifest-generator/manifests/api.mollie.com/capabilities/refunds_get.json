{
  "name": "refunds_get",
  "description": "Retrieve details of a specific refund.",
  "resource_group": "refunds",
  "endpoint": "/v2/payments/{paymentId}/refunds/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "paymentId",
      "type": "string",
      "description": "The payment ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The refund ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS/refunds/re_4qqhO89gsT",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "refund",
      "id": "re_4qqhO89gsT",
      "status": "pending"
    }
  }
}
