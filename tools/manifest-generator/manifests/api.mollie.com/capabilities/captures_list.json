{
  "name": "captures_list",
  "description": "List all captures for a specific payment.",
  "resource_group": "captures",
  "endpoint": "/v2/payments/{paymentId}/captures",
  "method": "GET",
  "parameters": [
    {
      "name": "paymentId",
      "type": "string",
      "description": "The payment ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/payments/tr_7UhSN1zuXS/captures",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "_embedded": {
        "captures": [
          {
            "resource": "capture",
            "id": "cpt_4qqhO89gsT"
          }
        ]
      }
    }
  }
}