{
  "name": "customers_get",
  "description": "Retrieve the details of a specific customer.",
  "resource_group": "customers",
  "endpoint": "/v2/customers/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The customer ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/customers/cst_8wmqcHMN4U",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "customer",
      "id": "cst_8wmqcHMN4U",
      "name": "John Doe"
    }
  }
}