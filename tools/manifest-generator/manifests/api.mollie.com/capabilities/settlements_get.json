{
  "name": "settlements_get",
  "description": "Retrieve the details of a specific settlement.",
  "resource_group": "settlements",
  "endpoint": "/v2/settlements/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The settlement ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mollie.com/v2/settlements/stl_jDk30akdN",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resource": "settlement",
      "id": "stl_jDk30akdN",
      "status": "paidout",
      "amount": {
        "currency": "EUR",
        "value": "39.75"
      }
    }
  }
}
