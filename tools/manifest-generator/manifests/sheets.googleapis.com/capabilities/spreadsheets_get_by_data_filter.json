{
  "name": "spreadsheets_get_by_data_filter",
  "description": "Get spreadsheet data matching data filters.",
  "resource_group": "spreadsheets",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}:getByDataFilter",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "dataFilters",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Data filters to match"
    },
    {
      "name": "includeGridData",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Include cell data"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive"
  ]
}