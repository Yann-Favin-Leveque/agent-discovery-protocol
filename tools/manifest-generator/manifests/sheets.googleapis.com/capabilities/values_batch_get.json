{
  "name": "values_batch_get",
  "description": "Get values from multiple ranges.",
  "resource_group": "values",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/values:batchGet",
  "method": "GET",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "ranges",
      "type": "array",
      "required": true,
      "location": "query",
      "description": "List of A1 notation ranges to retrieve"
    },
    {
      "name": "majorDimension",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Major dimension"
    },
    {
      "name": "valueRenderOption",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Value render option"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive"
  ]
}