{
  "name": "sheets_copy_to",
  "description": "Copy a sheet to another spreadsheet.",
  "resource_group": "sheets",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/sheets/{sheetId}:copyTo",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet",
      "in": "path"
    },
    {
      "name": "sheetId",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "The ID of the sheet to copy",
      "in": "path"
    },
    {
      "name": "destinationSpreadsheetId",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "ID of the destination spreadsheet",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.file"
  ]
}
