{
  "name": "spreadsheets_get",
  "description": "Get a spreadsheet by ID including metadata and sheets.",
  "resource_group": "spreadsheets",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}",
  "method": "GET",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "ranges",
      "type": "array",
      "required": false,
      "location": "query",
      "description": "Ranges to retrieve"
    },
    {
      "name": "includeGridData",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Include cell data in response"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Field mask for partial response"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive"
  ]
}