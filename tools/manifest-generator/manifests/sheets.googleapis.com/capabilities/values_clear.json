{
  "name": "values_clear",
  "description": "Clear values from a range.",
  "resource_group": "values",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/values/{range}:clear",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet",
      "in": "path"
    },
    {
      "name": "range",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The A1 notation range (e.g., Sheet1!A1:B10)",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.file"
  ]
}
