{
  "name": "developer_metadata_get",
  "description": "Get developer metadata by ID.",
  "resource_group": "developer_metadata",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/developerMetadata/{metadataId}",
  "method": "GET",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "metadataId",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "The ID of the developer metadata"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive"
  ]
}