{
  "name": "developer_metadata_search",
  "description": "Search for developer metadata matching filters.",
  "resource_group": "developer_metadata",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/developerMetadata:search",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "dataFilters",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Data filters to match metadata"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive"
  ]
}