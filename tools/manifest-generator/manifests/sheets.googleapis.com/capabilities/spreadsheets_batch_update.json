{
  "name": "spreadsheets_batch_update",
  "description": "Apply one or more updates to a spreadsheet.",
  "resource_group": "spreadsheets",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}:batchUpdate",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet",
      "in": "path"
    },
    {
      "name": "requests",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "List of update requests to apply",
      "in": "body"
    },
    {
      "name": "includeSpreadsheetInResponse",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Include full spreadsheet in response",
      "in": "body"
    },
    {
      "name": "responseRanges",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "Ranges to include in response",
      "in": "body"
    },
    {
      "name": "responseIncludeGridData",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Include grid data in response",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.file"
  ],
  "request_example": {
    "requests": [
      {
        "addSheet": {
          "properties": {
            "title": "New Sheet"
          }
        }
      }
    ]
  }
}
