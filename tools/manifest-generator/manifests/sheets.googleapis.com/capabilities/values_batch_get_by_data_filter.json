{
  "name": "values_batch_get_by_data_filter",
  "description": "Get values matching data filters.",
  "resource_group": "values",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/values:batchGetByDataFilter",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "dataFilters",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Data filters to match"
    },
    {
      "name": "majorDimension",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Major dimension"
    },
    {
      "name": "valueRenderOption",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Value render option"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets.readonly",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive"
  ]
}