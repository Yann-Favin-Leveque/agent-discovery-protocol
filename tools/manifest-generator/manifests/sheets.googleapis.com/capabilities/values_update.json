{
  "name": "values_update",
  "description": "Set values in a range of a spreadsheet.",
  "resource_group": "values",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/values/{range}",
  "method": "PUT",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "range",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The A1 notation range (e.g., Sheet1!A1:B10)"
    },
    {
      "name": "valueInputOption",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "How input data should be interpreted (RAW or USER_ENTERED)"
    },
    {
      "name": "values",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "2D array of values to write"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.file"
  ],
  "request_example": {
    "values": [
      [
        "Name",
        "Age"
      ],
      [
        "Bob",
        "25"
      ]
    ]
  }
}