{
  "name": "values_batch_clear_by_data_filter",
  "description": "Clear values matching data filters.",
  "resource_group": "values",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/values:batchClearByDataFilter",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the spreadsheet"
    },
    {
      "name": "dataFilters",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Data filters to match"
    }
  ],
  "auth_scopes": [
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.file"
  ]
}