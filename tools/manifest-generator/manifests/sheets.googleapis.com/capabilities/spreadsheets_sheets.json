{
  "name": "spreadsheets_sheets",
  "description": "Manage spreadsheets sheets — copies a single sheet from a spreadsheet to another spreadsheet. returns the properties of the newly created sheet. Supports standard CRUD operations through the REST API.",
  "endpoint": "/v4/spreadsheets/{spreadsheetId}/sheets/{sheetId}:copyTo",
  "method": "POST",
  "parameters": [
    {
      "name": "spreadsheetId",
      "type": "string",
      "description": "The ID of the spreadsheet containing the sheet to copy.",
      "required": true,
      "example": "abc_123"
    },
    {
      "name": "sheetId",
      "type": "integer",
      "description": "The ID of the sheet to copy.",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://sheets.googleapis.com/v4/spreadsheets/{spreadsheetId}/sheets/{sheetId}:copyTo",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "spreadsheetId": "abc_123",
      "sheetId": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "spreadsheetId": "abc_123",
        "sheetId": "example_value"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.file",
    "https://www.googleapis.com/auth/drive.readonly",
    "https://www.googleapis.com/auth/spreadsheets",
    "https://www.googleapis.com/auth/spreadsheets.readonly"
  ]
}
