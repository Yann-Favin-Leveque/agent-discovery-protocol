{
  "spec_version": "1.0",
  "name": "Google Sheets API",
  "description": "Google Sheets API provides programmatic access to create, read, and modify Google Sheets spreadsheets. Supports cell value operations, batch updates, spreadsheet metadata, sheets management, and developer metadata.",
  "base_url": "https://sheets.googleapis.com",
  "auth": {
    "type": "oauth2",
    "authorization_url": "https://accounts.google.com/o/oauth2/v2/auth",
    "token_url": "https://oauth2.googleapis.com/token",
    "scopes": [
      "https://www.googleapis.com/auth/drive",
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.readonly",
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/spreadsheets.readonly"
    ]
  },
  "capabilities": [
    {
      "name": "spreadsheets_create",
      "description": "Create a new spreadsheet.",
      "resource_group": "spreadsheets",
      "detail_url": "/capabilities/spreadsheets_create"
    },
    {
      "name": "spreadsheets_get",
      "description": "Get a spreadsheet by ID including metadata and sheets.",
      "resource_group": "spreadsheets",
      "detail_url": "/capabilities/spreadsheets_get"
    },
    {
      "name": "spreadsheets_get_by_data_filter",
      "description": "Get spreadsheet data matching data filters.",
      "resource_group": "spreadsheets",
      "detail_url": "/capabilities/spreadsheets_get_by_data_filter"
    },
    {
      "name": "spreadsheets_batch_update",
      "description": "Apply one or more updates to a spreadsheet.",
      "resource_group": "spreadsheets",
      "detail_url": "/capabilities/spreadsheets_batch_update"
    },
    {
      "name": "sheets_copy_to",
      "description": "Copy a sheet to another spreadsheet.",
      "resource_group": "sheets",
      "detail_url": "/capabilities/sheets_copy_to"
    },
    {
      "name": "developer_metadata_get",
      "description": "Get developer metadata by ID.",
      "resource_group": "developer_metadata",
      "detail_url": "/capabilities/developer_metadata_get"
    },
    {
      "name": "developer_metadata_search",
      "description": "Search for developer metadata matching filters.",
      "resource_group": "developer_metadata",
      "detail_url": "/capabilities/developer_metadata_search"
    },
    {
      "name": "values_get",
      "description": "Get values from a range in a spreadsheet.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_get"
    },
    {
      "name": "values_update",
      "description": "Set values in a range of a spreadsheet.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_update"
    },
    {
      "name": "values_append",
      "description": "Append values to a spreadsheet range.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_append"
    },
    {
      "name": "values_clear",
      "description": "Clear values from a range.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_clear"
    },
    {
      "name": "values_batch_get",
      "description": "Get values from multiple ranges.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_batch_get"
    },
    {
      "name": "values_batch_update",
      "description": "Set values in multiple ranges.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_batch_update"
    },
    {
      "name": "values_batch_clear",
      "description": "Clear values from multiple ranges.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_batch_clear"
    },
    {
      "name": "values_batch_get_by_data_filter",
      "description": "Get values matching data filters.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_batch_get_by_data_filter"
    },
    {
      "name": "values_batch_update_by_data_filter",
      "description": "Set values matching data filters.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_batch_update_by_data_filter"
    },
    {
      "name": "values_batch_clear_by_data_filter",
      "description": "Clear values matching data filters.",
      "resource_group": "values",
      "detail_url": "/capabilities/values_batch_clear_by_data_filter"
    }
  ]
}