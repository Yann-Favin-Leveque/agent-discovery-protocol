{
  "name": "image_classify",
  "description": "Classify images into categories using image classification models.",
  "resource_group": "image_classification",
  "endpoint": "/models/{model_id}",
  "method": "POST",
  "parameters": [
    {"name": "model_id", "type": "string", "required": true, "description": "Model ID (e.g. 'google/vit-base-patch16-224')."},
    {"name": "data", "type": "file", "required": true, "description": "Image file to classify (sent as binary)."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://router.huggingface.co/models/google/vit-base-patch16-224",
    "headers": {"Authorization": "Bearer hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx", "Content-Type": "image/jpeg"},
    "body": "Binary image content"
  },
  "response_example": {"status": 200, "body": [{"label": "Egyptian cat", "score": 0.92}, {"label": "tabby", "score": 0.05}]}
}
