{
  "name": "text_translate",
  "description": "Translate text from one language to another using translation models.",
  "resource_group": "translation",
  "endpoint": "/models/{model_id}",
  "method": "POST",
  "parameters": [
    {
      "name": "model_id",
      "type": "string",
      "required": true,
      "description": "Model ID (e.g. 'Helsinki-NLP/opus-mt-en-de').",
      "in": "path"
    },
    {
      "name": "inputs",
      "type": "string",
      "required": true,
      "description": "Text to translate.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://router.huggingface.co/models/Helsinki-NLP/opus-mt-en-de",
    "headers": {
      "Authorization": "Bearer hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "inputs": "Hello, how are you?"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "translation_text": "Hallo, wie geht es Ihnen?"
      }
    ]
  }
}
