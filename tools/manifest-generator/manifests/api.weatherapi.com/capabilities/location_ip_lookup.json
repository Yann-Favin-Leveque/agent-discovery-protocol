{
  "name": "location_ip_lookup",
  "description": "Get location, timezone, and basic weather information from an IP address.",
  "resource_group": "location",
  "endpoint": "/v1/ip.json",
  "method": "GET",
  "parameters": [
    {
      "name": "q",
      "type": "string",
      "required": true,
      "description": "Location query: city name, lat/lon, US/UK/Canada postal code, IP address, or 'auto:ip'.",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.weatherapi.com/v1/ip.json?key=YOUR_API_KEY&q=86.215.45.100"
  },
  "response_example": {
    "status": 200,
    "body": {
      "ip": "86.215.45.100",
      "type": "ipv4",
      "continent_code": "EU",
      "continent_name": "Europe",
      "country_code": "FR",
      "country_name": "France",
      "city": "Paris",
      "lat": 48.87,
      "lon": 2.33,
      "tz_id": "Europe/Paris",
      "localtime": "2025-01-15 14:30"
    }
  }
}