{
  "name": "sports_get",
  "description": "Get weather-based suitability information for sports events (football, cricket, golf) at a location.",
  "resource_group": "sports",
  "endpoint": "/v1/sports.json",
  "method": "GET",
  "parameters": [
    {
      "name": "q",
      "type": "string",
      "required": true,
      "description": "Location query: city name, lat/lon, US/UK/Canada postal code, IP address, or 'auto:ip'.",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.weatherapi.com/v1/sports.json?key=YOUR_API_KEY&q=Paris"
  },
  "response_example": {
    "status": 200,
    "body": {
      "football": [
        {
          "stadium": "Parc des Princes",
          "country": "France",
          "region": "Ile-de-France",
          "tournament": "Ligue 1",
          "start": "2025-01-15 20:00",
          "match": "PSG vs Lyon"
        }
      ],
      "cricket": [],
      "golf": []
    }
  }
}