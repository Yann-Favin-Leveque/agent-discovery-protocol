{
  "name": "get_history",
  "description": "Retrieve historical weather data for a specific past date at a location. Returns the same level of detail as the forecast endpoint, including daily summary (high/low temps, precipitation, humidity) and hourly breakdowns for that day. Available for dates since January 1, 2010.",
  "endpoint": "/v1/history.json",
  "method": "GET",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Your API key for authentication.",
      "required": true,
      "example": "{api_key}"
    },
    {
      "name": "q",
      "type": "string",
      "description": "Location query. Can be city name, lat/lon, zip code, or IP address.",
      "required": true,
      "example": "Paris"
    },
    {
      "name": "dt",
      "type": "string",
      "description": "Historical date in YYYY-MM-DD format. Must be a past date.",
      "required": true,
      "example": "2024-01-01"
    },
    {
      "name": "lang",
      "type": "string",
      "description": "Language code for condition text.",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.weatherapi.com/v1/history.json?key={api_key}&q=Paris&dt=2024-01-01",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "location": {
        "name": "Paris",
        "region": "Ile-de-France",
        "country": "France",
        "lat": 48.87,
        "lon": 2.33
      },
      "forecast": {
        "forecastday": [
          {
            "date": "2024-01-01",
            "day": {
              "maxtemp_c": 8.2,
              "mintemp_c": 3.1,
              "avgtemp_c": 5.6,
              "totalprecip_mm": 2.4,
              "avghumidity": 78,
              "maxwind_kph": 22.3,
              "condition": { "text": "Moderate rain", "code": 1189 }
            },
            "hour": [
              {
                "time": "2024-01-01 00:00",
                "temp_c": 4.8,
                "condition": { "text": "Overcast", "code": 1009 },
                "wind_kph": 12.5,
                "humidity": 82,
                "precip_mm": 0.0
              }
            ]
          }
        ]
      }
    }
  }
}
