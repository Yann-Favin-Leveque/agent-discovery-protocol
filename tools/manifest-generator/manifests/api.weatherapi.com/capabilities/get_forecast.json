{
  "name": "get_forecast",
  "description": "Retrieve a weather forecast for up to 14 days. Each day includes daily high/low temperatures, chance of rain/snow, total precipitation, max wind, average humidity, UV index, sunrise/sunset, and a condition summary. Hourly breakdowns provide temperature, wind, humidity, chance of rain, and weather condition for each hour of the day.",
  "endpoint": "/v1/forecast.json",
  "method": "GET",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Your API key for authentication.",
      "required": true,
      "example": "{api_key}"
    },
    {
      "name": "q",
      "type": "string",
      "description": "Location query. Can be city name, lat/lon, zip code, postcode, IP address, or 'auto:ip'.",
      "required": true,
      "example": "Paris"
    },
    {
      "name": "days",
      "type": "integer",
      "description": "Number of forecast days (1-14). Free tier supports up to 3 days.",
      "required": true,
      "example": 3
    },
    {
      "name": "aqi",
      "type": "string",
      "description": "Include air quality data. 'yes' or 'no'.",
      "required": false,
      "example": "no"
    },
    {
      "name": "alerts",
      "type": "string",
      "description": "Include weather alerts. 'yes' or 'no'.",
      "required": false,
      "example": "yes"
    },
    {
      "name": "lang",
      "type": "string",
      "description": "Language code for condition text.",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.weatherapi.com/v1/forecast.json?key={api_key}&q=Paris&days=3&alerts=yes",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "location": {
        "name": "Paris",
        "region": "Ile-de-France",
        "country": "France",
        "lat": 48.87,
        "lon": 2.33,
        "localtime": "2024-01-15 14:30"
      },
      "current": {
        "temp_c": 18.5,
        "condition": { "text": "Partly cloudy", "code": 1003 }
      },
      "forecast": {
        "forecastday": [
          {
            "date": "2024-01-15",
            "day": {
              "maxtemp_c": 20.1,
              "mintemp_c": 12.3,
              "avgtemp_c": 16.2,
              "totalprecip_mm": 0.8,
              "avghumidity": 65,
              "daily_chance_of_rain": 30,
              "daily_chance_of_snow": 0,
              "maxwind_kph": 18.4,
              "uv": 3.0,
              "condition": { "text": "Partly cloudy", "code": 1003 }
            },
            "astro": {
              "sunrise": "08:42 AM",
              "sunset": "05:12 PM",
              "moonrise": "10:30 AM",
              "moonset": "09:45 PM",
              "moon_phase": "Waxing Crescent"
            },
            "hour": [
              {
                "time": "2024-01-15 00:00",
                "temp_c": 13.2,
                "condition": { "text": "Clear", "code": 1000 },
                "wind_kph": 8.6,
                "humidity": 72,
                "chance_of_rain": 0
              }
            ]
          }
        ]
      },
      "alerts": { "alert": [] }
    }
  }
}
