{
  "name": "search_location",
  "description": "Search for locations by name with autocomplete support. Returns a list of matching cities, towns, and places with their full names, regions, countries, and geographic coordinates. Useful for building location pickers or resolving ambiguous place names before calling weather endpoints.",
  "endpoint": "/v1/search.json",
  "method": "GET",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Your API key for authentication.",
      "required": true,
      "example": "{api_key}"
    },
    {
      "name": "q",
      "type": "string",
      "description": "Search query. Partial city names are supported for autocomplete behavior.",
      "required": true,
      "example": "Lon"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.weatherapi.com/v1/search.json?key={api_key}&q=Lon",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 2801268,
        "name": "London",
        "region": "City of London, Greater London",
        "country": "United Kingdom",
        "lat": 51.52,
        "lon": -0.11,
        "url": "london-city-of-london-greater-london-united-kingdom"
      },
      {
        "id": 315398,
        "name": "Londonderry",
        "region": "Londonderry",
        "country": "United Kingdom",
        "lat": 55.0,
        "lon": -7.33,
        "url": "londonderry-united-kingdom"
      }
    ]
  }
}
