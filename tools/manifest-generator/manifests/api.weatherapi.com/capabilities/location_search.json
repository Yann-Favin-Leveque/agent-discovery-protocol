{
  "name": "location_search",
  "description": "Search for locations by name with autocomplete support. Returns matching cities with coordinates, country, and region.",
  "resource_group": "location",
  "endpoint": "/v1/search.json",
  "method": "GET",
  "parameters": [
    {
      "name": "q",
      "type": "string",
      "required": true,
      "description": "Location query: city name, lat/lon, US/UK/Canada postal code, IP address, or 'auto:ip'.",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "API key.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.weatherapi.com/v1/search.json?key=YOUR_API_KEY&q=Pari"
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 2988507,
        "name": "Paris",
        "region": "Ile-de-France",
        "country": "France",
        "lat": 48.87,
        "lon": 2.33,
        "url": "paris-ile-de-france-france"
      },
      {
        "id": 4717560,
        "name": "Paris",
        "region": "Texas",
        "country": "USA",
        "lat": 33.66,
        "lon": -95.56,
        "url": "paris-texas-united-states-of-america"
      }
    ]
  }
}