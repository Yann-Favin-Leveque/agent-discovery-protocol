{
  "name": "get_current_weather",
  "description": "Retrieve real-time weather conditions for any location. Returns temperature (Celsius and Fahrenheit), wind speed and direction, humidity, pressure, cloud cover, UV index, visibility, feels-like temperature, and a weather condition description with icon. Optionally includes air quality data with PM2.5, PM10, O3, NO2, SO2, and CO concentrations.",
  "endpoint": "/v1/current.json",
  "method": "GET",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Your API key for authentication.",
      "required": true,
      "example": "{api_key}"
    },
    {
      "name": "q",
      "type": "string",
      "description": "Location query. Can be city name, lat/lon (e.g. '48.85,2.35'), US zip code, UK postcode, IP address, or 'auto:ip' for auto-detect.",
      "required": true,
      "example": "Paris"
    },
    {
      "name": "aqi",
      "type": "string",
      "description": "Include air quality data. 'yes' or 'no'.",
      "required": false,
      "example": "yes"
    },
    {
      "name": "lang",
      "type": "string",
      "description": "Language code for condition text (e.g. 'fr', 'de', 'es').",
      "required": false,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.weatherapi.com/v1/current.json?key={api_key}&q=Paris&aqi=yes",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "location": {
        "name": "Paris",
        "region": "Ile-de-France",
        "country": "France",
        "lat": 48.87,
        "lon": 2.33,
        "tz_id": "Europe/Paris",
        "localtime": "2024-01-15 14:30"
      },
      "current": {
        "temp_c": 18.5,
        "temp_f": 65.3,
        "is_day": 1,
        "condition": {
          "text": "Partly cloudy",
          "icon": "//cdn.weatherapi.com/weather/64x64/day/116.png",
          "code": 1003
        },
        "wind_mph": 8.1,
        "wind_kph": 13.0,
        "wind_dir": "SW",
        "pressure_mb": 1015.0,
        "humidity": 62,
        "cloud": 40,
        "feelslike_c": 17.8,
        "feelslike_f": 64.0,
        "vis_km": 10.0,
        "uv": 3.0,
        "air_quality": {
          "pm2_5": 8.4,
          "pm10": 12.1,
          "o3": 68.5,
          "no2": 15.2,
          "so2": 3.8,
          "co": 230.3,
          "us-epa-index": 1,
          "gb-defra-index": 2
        }
      }
    }
  }
}
