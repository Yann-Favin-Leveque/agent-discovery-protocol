{
  "name": "companies_update",
  "description": "Update an existing company record by ID.",
  "resource_group": "companies",
  "endpoint": "/companies/{company_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "company_id",
      "type": "integer",
      "required": true,
      "description": "The ID of the company to update",
      "location": "path",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated company name",
      "in": "body"
    },
    {
      "name": "address",
      "type": "object",
      "required": false,
      "description": "Updated address",
      "in": "body"
    },
    {
      "name": "custom_fields",
      "type": "array",
      "required": false,
      "description": "Updated custom field values",
      "in": "body"
    }
  ],
  "request_example": {
    "name": "Acme Corporation"
  },
  "response_example": {
    "id": 67890,
    "name": "Acme Corporation",
    "date_modified": 1609459200
  },
  "auth_scopes": []
}
