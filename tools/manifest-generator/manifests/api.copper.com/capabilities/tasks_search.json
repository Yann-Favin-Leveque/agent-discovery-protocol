{
  "name": "tasks_search",
  "description": "Search and filter tasks.",
  "resource_group": "tasks",
  "endpoint": "/tasks/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "integer", "required": false, "description": "Page number"},
    {"name": "page_size", "type": "integer", "required": false, "description": "Results per page"},
    {"name": "assignee_ids", "type": "array", "required": false, "description": "Filter by assignee IDs"},
    {"name": "statuses", "type": "array", "required": false, "description": "Filter by task statuses"}
  ],
  "request_example": {"page_size": 25, "statuses": ["Open"]},
  "response_example": [{"id": 1, "name": "Follow up", "status": "Open", "due_date": 1609459200}],
  "auth_scopes": []
}
