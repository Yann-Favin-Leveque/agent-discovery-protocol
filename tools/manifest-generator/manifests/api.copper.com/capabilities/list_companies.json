{
  "name": "list_companies",
  "description": "List and search company records in Copper CRM.",
  "endpoint": "/companies/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "number", "description": "Page number.", "required": false, "example": 1},
    {"name": "page_size", "type": "number", "description": "Results per page.", "required": false, "example": 25},
    {"name": "name", "type": "string", "description": "Filter by company name.", "required": false, "example": "Acme"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.copper.com/developer_api/v1/companies/search",
    "headers": {"X-PW-AccessToken": "{api_key}", "X-PW-Application": "developer_api", "X-PW-UserEmail": "user@example.com", "Content-Type": "application/json"},
    "body": {"page_number": 1, "page_size": 25}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": 456, "name": "Acme Corp", "email_domain": "acme.com", "details": "Enterprise software company", "date_created": 1705747200}]
  }
}
