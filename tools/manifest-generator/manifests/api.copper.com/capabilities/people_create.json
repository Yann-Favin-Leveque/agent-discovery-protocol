{
  "name": "people_create",
  "description": "Create a new person (contact) record with name, email, and contact details.",
  "resource_group": "people",
  "endpoint": "/people",
  "method": "POST",
  "parameters": [
    {"name": "name", "type": "string", "required": true, "description": "Full name of the person"},
    {"name": "emails", "type": "array", "required": false, "description": "Array of email objects with email and category"},
    {"name": "phone_numbers", "type": "array", "required": false, "description": "Array of phone number objects"},
    {"name": "company_id", "type": "integer", "required": false, "description": "Associated company ID"},
    {"name": "contact_type_id", "type": "integer", "required": false, "description": "Contact type ID"},
    {"name": "title", "type": "string", "required": false, "description": "Job title"},
    {"name": "assignee_id", "type": "integer", "required": false, "description": "User ID to assign this person to"},
    {"name": "custom_fields", "type": "array", "required": false, "description": "Custom field values"}
  ],
  "request_example": {
    "name": "John Smith",
    "emails": [{"email": "john@example.com", "category": "work"}],
    "company_id": 67890,
    "title": "CEO"
  },
  "response_example": {
    "id": 12345,
    "name": "John Smith",
    "date_created": 1609459200
  },
  "auth_scopes": []
}
