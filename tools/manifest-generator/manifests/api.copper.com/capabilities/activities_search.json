{
  "name": "activities_search",
  "description": "Search and filter activities.",
  "resource_group": "activities",
  "endpoint": "/activities/search",
  "method": "POST",
  "parameters": [
    {
      "name": "page_number",
      "type": "integer",
      "required": false,
      "description": "Page number",
      "in": "body"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "description": "Results per page",
      "in": "body"
    },
    {
      "name": "parent",
      "type": "object",
      "required": false,
      "description": "Filter by parent entity",
      "in": "body"
    },
    {
      "name": "activity_types",
      "type": "array",
      "required": false,
      "description": "Filter by activity type IDs",
      "in": "body"
    }
  ],
  "request_example": {
    "page_size": 25
  },
  "response_example": [
    {
      "id": 1,
      "type": {
        "id": 0,
        "name": "Note"
      },
      "details": "Meeting notes"
    }
  ],
  "auth_scopes": []
}
