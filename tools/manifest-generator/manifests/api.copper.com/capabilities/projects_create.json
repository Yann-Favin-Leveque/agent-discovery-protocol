{
  "name": "projects_create",
  "description": "Create a new project record.",
  "resource_group": "projects",
  "endpoint": "/projects",
  "method": "POST",
  "parameters": [
    {"name": "name", "type": "string", "required": true, "description": "Project name"},
    {"name": "assignee_id", "type": "integer", "required": false, "description": "User ID to assign"},
    {"name": "status", "type": "string", "required": false, "description": "Project status"},
    {"name": "details", "type": "string", "required": false, "description": "Project details/description"},
    {"name": "tags", "type": "array", "required": false, "description": "Tags for the project"}
  ],
  "request_example": {"name": "Website Redesign", "assignee_id": 123},
  "response_example": {"id": 1, "name": "Website Redesign", "date_created": 1609459200},
  "auth_scopes": []
}
