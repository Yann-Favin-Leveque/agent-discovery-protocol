{
  "name": "companies_search",
  "description": "Search and filter company records with sorting and pagination.",
  "resource_group": "companies",
  "endpoint": "/companies/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "integer", "required": false, "description": "Page number starting at 1"},
    {"name": "page_size", "type": "integer", "required": false, "description": "Results per page"},
    {"name": "sort_by", "type": "string", "required": false, "description": "Field to sort by"},
    {"name": "sort_direction", "type": "string", "required": false, "description": "Sort order: asc or desc"},
    {"name": "name", "type": "string", "required": false, "description": "Filter by company name"},
    {"name": "tags", "type": "array", "required": false, "description": "Filter by tags"}
  ],
  "request_example": {"page_size": 25, "sort_by": "name"},
  "response_example": [{"id": 67890, "name": "Acme Corp"}],
  "auth_scopes": []
}
