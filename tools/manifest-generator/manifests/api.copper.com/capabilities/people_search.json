{
  "name": "people_search",
  "description": "Search and filter people records with sorting and pagination.",
  "resource_group": "people",
  "endpoint": "/people/search",
  "method": "POST",
  "parameters": [
    {
      "name": "page_number",
      "type": "integer",
      "required": false,
      "description": "Page number starting at 1",
      "in": "body"
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "description": "Results per page, default 20",
      "in": "body"
    },
    {
      "name": "sort_by",
      "type": "string",
      "required": false,
      "description": "Field to sort by",
      "in": "body"
    },
    {
      "name": "sort_direction",
      "type": "string",
      "required": false,
      "description": "Sort order: asc or desc",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter by name",
      "in": "body"
    },
    {
      "name": "emails",
      "type": "string",
      "required": false,
      "description": "Filter by email",
      "in": "body"
    },
    {
      "name": "company_ids",
      "type": "array",
      "required": false,
      "description": "Filter by company IDs",
      "in": "body"
    },
    {
      "name": "contact_type_ids",
      "type": "array",
      "required": false,
      "description": "Filter by contact type IDs",
      "in": "body"
    },
    {
      "name": "tags",
      "type": "array",
      "required": false,
      "description": "Filter by tags",
      "in": "body"
    }
  ],
  "request_example": {
    "page_size": 25,
    "sort_by": "name",
    "sort_direction": "asc"
  },
  "response_example": [
    {
      "id": 12345,
      "name": "John Smith",
      "emails": [
        {
          "email": "john@example.com"
        }
      ]
    }
  ],
  "auth_scopes": []
}
