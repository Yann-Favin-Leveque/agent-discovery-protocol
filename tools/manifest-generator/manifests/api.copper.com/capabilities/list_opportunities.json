{
  "name": "list_opportunities",
  "description": "List and filter sales opportunities in Copper by pipeline, status, and other criteria.",
  "endpoint": "/opportunities/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "number", "description": "Page number.", "required": false, "example": 1},
    {"name": "page_size", "type": "number", "description": "Results per page.", "required": false, "example": 25},
    {"name": "pipeline_ids", "type": "array", "description": "Filter by pipeline IDs.", "required": false, "example": [1]},
    {"name": "status_ids", "type": "array", "description": "Filter by status IDs (0=Open, 1=Won, 2=Lost).", "required": false, "example": [0]}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.copper.com/developer_api/v1/opportunities/search",
    "headers": {"X-PW-AccessToken": "{api_key}", "X-PW-Application": "developer_api", "X-PW-UserEmail": "user@example.com", "Content-Type": "application/json"},
    "body": {"page_number": 1, "page_size": 25, "status_ids": [0]}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": 101, "name": "Enterprise Deal", "monetary_value": 50000, "pipeline_id": 1, "pipeline_stage_id": 3, "status": "Open", "close_date": "2024-06-01"}]
  }
}
