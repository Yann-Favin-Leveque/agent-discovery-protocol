{
  "name": "leads_upsert",
  "description": "Create or update a lead by matching on email or a custom field value.",
  "resource_group": "leads",
  "endpoint": "/leads/upsert",
  "method": "PUT",
  "parameters": [
    {"name": "name", "type": "string", "required": true, "description": "Full name of the lead"},
    {"name": "email", "type": "object", "required": false, "description": "Email used for matching existing leads"},
    {"name": "company_name", "type": "string", "required": false, "description": "Company name"},
    {"name": "custom_fields", "type": "array", "required": false, "description": "Custom field values"}
  ],
  "request_example": {
    "name": "Jane Doe",
    "email": {"email": "jane@example.com", "category": "work"},
    "company_name": "Acme Corp"
  },
  "response_example": {
    "id": 12345,
    "name": "Jane Doe"
  },
  "auth_scopes": []
}
