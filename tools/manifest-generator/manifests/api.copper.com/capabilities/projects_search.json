{
  "name": "projects_search",
  "description": "Search and filter project records.",
  "resource_group": "projects",
  "endpoint": "/projects/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "integer", "required": false, "description": "Page number"},
    {"name": "page_size", "type": "integer", "required": false, "description": "Results per page"},
    {"name": "sort_by", "type": "string", "required": false, "description": "Field to sort by"},
    {"name": "assignee_ids", "type": "array", "required": false, "description": "Filter by assignee IDs"},
    {"name": "tags", "type": "array", "required": false, "description": "Filter by tags"}
  ],
  "request_example": {"page_size": 25},
  "response_example": [{"id": 1, "name": "Website Redesign", "status": "Open"}],
  "auth_scopes": []
}
