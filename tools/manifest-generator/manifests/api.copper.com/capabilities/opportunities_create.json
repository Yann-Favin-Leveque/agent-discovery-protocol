{
  "name": "opportunities_create",
  "description": "Create a new sales opportunity with value, pipeline, and stage.",
  "resource_group": "opportunities",
  "endpoint": "/opportunities",
  "method": "POST",
  "parameters": [
    {"name": "name", "type": "string", "required": true, "description": "Opportunity name"},
    {"name": "pipeline_id", "type": "integer", "required": true, "description": "Pipeline ID to place the opportunity in"},
    {"name": "pipeline_stage_id", "type": "integer", "required": false, "description": "Stage ID within the pipeline"},
    {"name": "monetary_value", "type": "number", "required": false, "description": "Deal value"},
    {"name": "primary_contact_id", "type": "integer", "required": false, "description": "Primary contact person ID"},
    {"name": "company_id", "type": "integer", "required": false, "description": "Associated company ID"},
    {"name": "close_date", "type": "string", "required": false, "description": "Expected close date"},
    {"name": "assignee_id", "type": "integer", "required": false, "description": "User ID to assign this opportunity to"},
    {"name": "custom_fields", "type": "array", "required": false, "description": "Custom field values"}
  ],
  "request_example": {
    "name": "Enterprise Deal",
    "pipeline_id": 1,
    "monetary_value": 50000,
    "primary_contact_id": 12345
  },
  "response_example": {"id": 11111, "name": "Enterprise Deal", "date_created": 1609459200},
  "auth_scopes": []
}
