{
  "name": "leads_search",
  "description": "Search and filter lead records with pagination, sorting, and field-based filters.",
  "resource_group": "leads",
  "endpoint": "/leads/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "integer", "required": false, "description": "Page number starting at 1"},
    {"name": "page_size", "type": "integer", "required": false, "description": "Results per page, default 20"},
    {"name": "sort_by", "type": "string", "required": false, "description": "Field to sort by (name, company_name, date_created, etc.)"},
    {"name": "sort_direction", "type": "string", "required": false, "description": "Sort order: asc or desc"},
    {"name": "name", "type": "string", "required": false, "description": "Filter by full name"},
    {"name": "emails", "type": "string", "required": false, "description": "Filter by email address"},
    {"name": "assignee_ids", "type": "array", "required": false, "description": "Filter by assigned user IDs"},
    {"name": "status_ids", "type": "array", "required": false, "description": "Filter by lead status IDs"},
    {"name": "tags", "type": "array", "required": false, "description": "Filter by tags"},
    {"name": "minimum_monetary_value", "type": "number", "required": false, "description": "Minimum monetary value filter"},
    {"name": "maximum_monetary_value", "type": "number", "required": false, "description": "Maximum monetary value filter"}
  ],
  "request_example": {
    "page_size": 10,
    "sort_by": "date_created",
    "sort_direction": "desc",
    "status_ids": [1]
  },
  "response_example": [
    {
      "id": 12345,
      "name": "Jane Doe",
      "email": {"email": "jane@example.com", "category": "work"},
      "status": "New",
      "company_name": "Acme Corp"
    }
  ],
  "auth_scopes": []
}
