{
  "name": "tasks_create",
  "description": "Create a new task with due date and assignee.",
  "resource_group": "tasks",
  "endpoint": "/tasks",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Task name",
      "in": "body"
    },
    {
      "name": "due_date",
      "type": "integer",
      "required": false,
      "description": "Due date as Unix timestamp",
      "in": "body"
    },
    {
      "name": "assignee_id",
      "type": "integer",
      "required": false,
      "description": "User to assign the task to",
      "in": "body"
    },
    {
      "name": "related_resource",
      "type": "object",
      "required": false,
      "description": "Related entity (type and id)",
      "in": "body"
    },
    {
      "name": "details",
      "type": "string",
      "required": false,
      "description": "Task details",
      "in": "body"
    }
  ],
  "request_example": {
    "name": "Follow up with client",
    "due_date": 1609459200,
    "assignee_id": 123
  },
  "response_example": {
    "id": 1,
    "name": "Follow up with client",
    "date_created": 1609459200
  },
  "auth_scopes": []
}
