{
  "name": "search_people",
  "description": "Search for people (contacts) in Copper CRM by name, email, phone, or custom field values.",
  "endpoint": "/people/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "number", "description": "Page number for pagination (starts at 1).", "required": false, "example": 1},
    {"name": "page_size", "type": "number", "description": "Number of results per page (max 200).", "required": false, "example": 25},
    {"name": "name", "type": "string", "description": "Filter by full name.", "required": false, "example": "John Doe"},
    {"name": "emails", "type": "array", "description": "Filter by email addresses.", "required": false, "example": ["john@example.com"]}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.copper.com/developer_api/v1/people/search",
    "headers": {"X-PW-AccessToken": "{api_key}", "X-PW-Application": "developer_api", "X-PW-UserEmail": "user@example.com", "Content-Type": "application/json"},
    "body": {"page_number": 1, "page_size": 25, "emails": ["john@example.com"]}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": 123, "name": "John Doe", "emails": [{"email": "john@example.com", "category": "work"}], "company_id": 456, "title": "CEO", "date_created": 1705747200}]
  }
}
