{
  "name": "opportunities_search",
  "description": "Search and filter opportunity records by pipeline, status, and other criteria.",
  "resource_group": "opportunities",
  "endpoint": "/opportunities/search",
  "method": "POST",
  "parameters": [
    {"name": "page_number", "type": "integer", "required": false, "description": "Page number"},
    {"name": "page_size", "type": "integer", "required": false, "description": "Results per page"},
    {"name": "sort_by", "type": "string", "required": false, "description": "Field to sort by"},
    {"name": "pipeline_ids", "type": "array", "required": false, "description": "Filter by pipeline IDs"},
    {"name": "status_ids", "type": "array", "required": false, "description": "Filter by status IDs"},
    {"name": "assignee_ids", "type": "array", "required": false, "description": "Filter by assignee IDs"},
    {"name": "company_ids", "type": "array", "required": false, "description": "Filter by company IDs"}
  ],
  "request_example": {"pipeline_ids": [1], "page_size": 25},
  "response_example": [{"id": 11111, "name": "Enterprise Deal", "monetary_value": 50000, "status": "Open"}],
  "auth_scopes": []
}
