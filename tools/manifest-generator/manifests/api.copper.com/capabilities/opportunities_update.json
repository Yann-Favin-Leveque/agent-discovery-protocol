{
  "name": "opportunities_update",
  "description": "Update an existing opportunity record by ID.",
  "resource_group": "opportunities",
  "endpoint": "/opportunities/{opportunity_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "opportunity_id",
      "type": "integer",
      "required": true,
      "description": "The ID of the opportunity to update",
      "location": "path",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name",
      "in": "body"
    },
    {
      "name": "monetary_value",
      "type": "number",
      "required": false,
      "description": "Updated deal value",
      "in": "body"
    },
    {
      "name": "pipeline_stage_id",
      "type": "integer",
      "required": false,
      "description": "Updated pipeline stage",
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Updated status (Open, Won, Lost, Abandoned)",
      "in": "body"
    },
    {
      "name": "close_date",
      "type": "string",
      "required": false,
      "description": "Updated close date",
      "in": "body"
    }
  ],
  "request_example": {
    "monetary_value": 75000,
    "pipeline_stage_id": 3
  },
  "response_example": {
    "id": 11111,
    "monetary_value": 75000,
    "date_modified": 1609459200
  },
  "auth_scopes": []
}
