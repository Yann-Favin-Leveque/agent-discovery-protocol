{
  "name": "people_fetch_by_email",
  "description": "Look up a person record by their email address.",
  "resource_group": "people",
  "endpoint": "/people/fetch_by_email",
  "method": "POST",
  "parameters": [
    {"name": "email", "type": "string", "required": true, "description": "Email address to search for"}
  ],
  "request_example": {"email": "john@example.com"},
  "response_example": {"id": 12345, "name": "John Smith", "emails": [{"email": "john@example.com", "category": "work"}]},
  "auth_scopes": []
}
