{
  "name": "leads_update",
  "description": "Update an existing lead record by ID with new field values.",
  "resource_group": "leads",
  "endpoint": "/leads/{lead_id}",
  "method": "PUT",
  "parameters": [
    {"name": "lead_id", "type": "integer", "required": true, "description": "The ID of the lead to update", "location": "path"},
    {"name": "name", "type": "string", "required": false, "description": "Updated full name"},
    {"name": "email", "type": "object", "required": false, "description": "Updated email object"},
    {"name": "status_id", "type": "integer", "required": false, "description": "Updated status ID"},
    {"name": "assignee_id", "type": "integer", "required": false, "description": "Updated assignee user ID"},
    {"name": "monetary_value", "type": "number", "required": false, "description": "Updated monetary value"},
    {"name": "custom_fields", "type": "array", "required": false, "description": "Updated custom field values"}
  ],
  "request_example": {
    "name": "Jane Smith",
    "status_id": 2,
    "monetary_value": 10000
  },
  "response_example": {
    "id": 12345,
    "name": "Jane Smith",
    "status_id": 2,
    "date_modified": 1609459200
  },
  "auth_scopes": []
}
