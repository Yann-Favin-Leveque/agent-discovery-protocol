{
  "name": "people_update",
  "description": "Update an existing person record by ID.",
  "resource_group": "people",
  "endpoint": "/people/{person_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "person_id",
      "type": "integer",
      "required": true,
      "description": "The ID of the person to update",
      "location": "path",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated full name",
      "in": "body"
    },
    {
      "name": "emails",
      "type": "array",
      "required": false,
      "description": "Updated emails",
      "in": "body"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Updated job title",
      "in": "body"
    },
    {
      "name": "custom_fields",
      "type": "array",
      "required": false,
      "description": "Updated custom field values",
      "in": "body"
    }
  ],
  "request_example": {
    "name": "John Smith Jr.",
    "title": "CTO"
  },
  "response_example": {
    "id": 12345,
    "name": "John Smith Jr.",
    "title": "CTO",
    "date_modified": 1609459200
  },
  "auth_scopes": []
}
