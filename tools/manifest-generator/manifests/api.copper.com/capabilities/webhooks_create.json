{
  "name": "webhooks_create",
  "description": "Create a webhook subscription for entity events.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks",
  "method": "POST",
  "parameters": [
    {"name": "target", "type": "string", "required": true, "description": "URL to receive webhook events"},
    {"name": "type", "type": "string", "required": true, "description": "Entity type (lead, person, company, opportunity, etc.)"},
    {"name": "event", "type": "string", "required": true, "description": "Event type (new, update, delete)"}
  ],
  "request_example": {"target": "https://example.com/webhook", "type": "lead", "event": "new"},
  "response_example": {"id": 1, "target": "https://example.com/webhook", "type": "lead", "event": "new"},
  "auth_scopes": []
}
