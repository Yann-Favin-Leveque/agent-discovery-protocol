{
  "name": "leads_create",
  "description": "Create a new lead record with name, email, phone, and company details.",
  "resource_group": "leads",
  "endpoint": "/leads",
  "method": "POST",
  "parameters": [
    {"name": "name", "type": "string", "required": true, "description": "Full name of the lead"},
    {"name": "email", "type": "object", "required": false, "description": "Email object with email and category fields"},
    {"name": "phone_numbers", "type": "array", "required": false, "description": "Array of phone number objects"},
    {"name": "company_name", "type": "string", "required": false, "description": "Company name for the lead"},
    {"name": "title", "type": "string", "required": false, "description": "Job title"},
    {"name": "assignee_id", "type": "integer", "required": false, "description": "User ID to assign the lead to"},
    {"name": "status_id", "type": "integer", "required": false, "description": "Lead status ID"},
    {"name": "customer_source_id", "type": "integer", "required": false, "description": "Customer source ID"},
    {"name": "monetary_value", "type": "number", "required": false, "description": "Monetary value of the lead"},
    {"name": "custom_fields", "type": "array", "required": false, "description": "Custom field values array"}
  ],
  "request_example": {
    "name": "Jane Doe",
    "email": {"email": "jane@example.com", "category": "work"},
    "company_name": "Acme Corp",
    "title": "VP of Sales",
    "assignee_id": 67890,
    "monetary_value": 5000
  },
  "response_example": {
    "id": 12345,
    "name": "Jane Doe",
    "email": {"email": "jane@example.com", "category": "work"},
    "company_name": "Acme Corp",
    "date_created": 1609459200
  },
  "auth_scopes": []
}
