{
  "name": "companies_create",
  "description": "Create a new company record.",
  "resource_group": "companies",
  "endpoint": "/companies",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Company name",
      "in": "body"
    },
    {
      "name": "address",
      "type": "object",
      "required": false,
      "description": "Address object with street, city, state, postal_code, country",
      "in": "body"
    },
    {
      "name": "phone_numbers",
      "type": "array",
      "required": false,
      "description": "Array of phone number objects",
      "in": "body"
    },
    {
      "name": "websites",
      "type": "array",
      "required": false,
      "description": "Array of website objects",
      "in": "body"
    },
    {
      "name": "assignee_id",
      "type": "integer",
      "required": false,
      "description": "User ID to assign this company to",
      "in": "body"
    },
    {
      "name": "contact_type_id",
      "type": "integer",
      "required": false,
      "description": "Contact type ID",
      "in": "body"
    },
    {
      "name": "custom_fields",
      "type": "array",
      "required": false,
      "description": "Custom field values",
      "in": "body"
    }
  ],
  "request_example": {
    "name": "Acme Corp",
    "address": {
      "city": "San Francisco",
      "state": "CA"
    }
  },
  "response_example": {
    "id": 67890,
    "name": "Acme Corp",
    "date_created": 1609459200
  },
  "auth_scopes": []
}
