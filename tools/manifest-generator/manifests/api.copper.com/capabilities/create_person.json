{
  "name": "create_person",
  "description": "Create a new person (contact) in Copper CRM with name, email, phone, and company association.",
  "endpoint": "/people",
  "method": "POST",
  "parameters": [
    {"name": "name", "type": "string", "description": "Full name of the person.", "required": true, "example": "Jane Smith"},
    {"name": "emails", "type": "array", "description": "Array of email objects.", "required": false, "example": [{"email": "jane@example.com", "category": "work"}]},
    {"name": "phone_numbers", "type": "array", "description": "Array of phone number objects.", "required": false, "example": [{"number": "+1234567890", "category": "work"}]},
    {"name": "company_id", "type": "number", "description": "ID of the associated company.", "required": false, "example": 456}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.copper.com/developer_api/v1/people",
    "headers": {"X-PW-AccessToken": "{api_key}", "X-PW-Application": "developer_api", "X-PW-UserEmail": "user@example.com", "Content-Type": "application/json"},
    "body": {"name": "Jane Smith", "emails": [{"email": "jane@example.com", "category": "work"}], "phone_numbers": [{"number": "+1234567890", "category": "work"}]}
  },
  "response_example": {
    "status": 200,
    "body": {"id": 789, "name": "Jane Smith", "emails": [{"email": "jane@example.com", "category": "work"}], "date_created": 1705747200}
  }
}
