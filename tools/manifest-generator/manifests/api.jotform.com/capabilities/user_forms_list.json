{
  "name": "user_forms_list",
  "resource_group": "user",
  "description": "List all forms owned by the user.",
  "endpoint": "/user/forms",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Start index."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    },
    {
      "name": "filter",
      "type": "object",
      "required": false,
      "in": "query",
      "description": "Filter criteria."
    },
    {
      "name": "orderby",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Sort field."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/user/forms?limit=20",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": [
        {
          "id": "123456",
          "title": "Contact Form",
          "status": "ENABLED",
          "count": "50"
        }
      ]
    }
  }
}