{
  "name": "submissions_update",
  "resource_group": "submissions",
  "description": "Update a submission.",
  "endpoint": "/submission/{submissionID}",
  "method": "POST",
  "parameters": [
    {
      "name": "submissionID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Submission ID."
    },
    {
      "name": "submission",
      "type": "object",
      "required": true,
      "in": "body",
      "description": "Fields to update."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.jotform.com/submission/sub-123",
    "headers": {
      "APIKEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "submission[1]": "Jane Doe"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": "Submission updated"
    }
  }
}