{
  "name": "get_user_info",
  "description": "Retrieve your JotForm account info, usage stats, and settings. Useful for checking your plan limits and current usage.",
  "endpoint": "/user",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/user",
    "headers": { "APIKEY": "{api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "responseCode": 200,
      "content": {
        "username": "johndoe",
        "name": "John Doe",
        "email": "john@example.com",
        "account_type": "FREE",
        "usage": { "submissions": "150", "ssl_submissions": "150", "form_count": "5" }
      }
    }
  }
}
