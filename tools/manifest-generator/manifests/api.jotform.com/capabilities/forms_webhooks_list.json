{
  "name": "forms_webhooks_list",
  "resource_group": "webhooks",
  "description": "List webhooks for a form.",
  "endpoint": "/form/{formID}/webhooks",
  "method": "GET",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456/webhooks",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "0": "https://example.com/webhook"
      }
    }
  }
}