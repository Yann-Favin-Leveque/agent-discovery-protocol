{
  "name": "user_submissions_list",
  "resource_group": "user",
  "description": "List all submissions across all forms.",
  "endpoint": "/user/submissions",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Start index."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/user/submissions",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": [
        {
          "id": "sub-123",
          "form_id": "123456",
          "created_at": "2025-01-15"
        }
      ]
    }
  }
}