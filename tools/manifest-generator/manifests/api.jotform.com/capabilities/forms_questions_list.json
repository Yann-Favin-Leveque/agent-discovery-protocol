{
  "name": "forms_questions_list",
  "resource_group": "forms",
  "description": "List all questions in a form.",
  "endpoint": "/form/{formID}/questions",
  "method": "GET",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456/questions",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "1": {
          "type": "control_textbox",
          "text": "Name",
          "name": "name"
        }
      }
    }
  }
}