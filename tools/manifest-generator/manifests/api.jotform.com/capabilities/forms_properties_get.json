{
  "name": "forms_properties_get",
  "resource_group": "forms",
  "description": "Get form configuration properties.",
  "endpoint": "/form/{formID}/properties",
  "method": "GET",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456/properties",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "title": "Contact Form",
        "activeRedirect": "default"
      }
    }
  }
}