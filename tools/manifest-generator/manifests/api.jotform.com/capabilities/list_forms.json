{
  "name": "list_forms",
  "description": "Retrieve all forms in your JotForm account with metadata including form title, status, creation date, and submission count.",
  "endpoint": "/user/forms",
  "method": "GET",
  "parameters": [
    { "name": "offset", "type": "number", "description": "Start index for pagination.", "required": false, "example": 0 },
    { "name": "limit", "type": "number", "description": "Number of forms to return.", "required": false, "example": 20 },
    { "name": "filter", "type": "object", "description": "Filter criteria as JSON.", "required": false, "example": { "status": "ENABLED" } },
    { "name": "orderby", "type": "string", "description": "Field to order by.", "required": false, "example": "created_at" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/user/forms?limit=20",
    "headers": { "APIKEY": "{api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "responseCode": 200,
      "content": [
        { "id": "123456789", "title": "Contact Form", "status": "ENABLED", "created_at": "2024-01-15 10:00:00", "count": "42", "url": "https://form.jotform.com/123456789" }
      ]
    }
  }
}
