{
  "name": "folders_create",
  "resource_group": "folders",
  "description": "Create a folder.",
  "endpoint": "/folder",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Folder name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.jotform.com/folder",
    "headers": {
      "APIKEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "New Folder"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "id": "folder-2",
        "name": "New Folder"
      }
    }
  }
}