{
  "name": "folders_get",
  "resource_group": "folders",
  "description": "Get folder details.",
  "endpoint": "/folder/{folderID}",
  "method": "GET",
  "parameters": [
    {
      "name": "folderID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Folder ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/folder/folder-1",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "id": "folder-1",
        "name": "My Folder"
      }
    }
  }
}