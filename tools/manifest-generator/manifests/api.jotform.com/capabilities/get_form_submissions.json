{
  "name": "get_form_submissions",
  "description": "Get all submissions for a specific form. Returns all answers for each submission along with metadata like submission date and status.",
  "endpoint": "/form/{formID}/submissions",
  "method": "GET",
  "parameters": [
    { "name": "formID", "type": "string", "description": "The form ID.", "required": true, "example": "123456789" },
    { "name": "offset", "type": "number", "description": "Start index.", "required": false, "example": 0 },
    { "name": "limit", "type": "number", "description": "Max results.", "required": false, "example": 20 },
    { "name": "filter", "type": "object", "description": "Filter criteria.", "required": false, "example": { "status": "ACTIVE" } }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456789/submissions?limit=20",
    "headers": { "APIKEY": "{api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "responseCode": 200,
      "content": [
        {
          "id": "5551234567890",
          "form_id": "123456789",
          "created_at": "2024-02-01 14:30:00",
          "status": "ACTIVE",
          "answers": {
            "1": { "name": "fullName", "text": "Full Name", "answer": { "first": "Jane", "last": "Doe" } },
            "2": { "name": "email", "text": "Email", "answer": "jane@example.com" }
          }
        }
      ]
    }
  }
}
