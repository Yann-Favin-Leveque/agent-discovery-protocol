{
  "name": "forms_questions_update",
  "resource_group": "forms",
  "description": "Update a question.",
  "endpoint": "/form/{formID}/question/{questionID}",
  "method": "POST",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "questionID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Question ID."
    },
    {
      "name": "question",
      "type": "object",
      "required": true,
      "in": "body",
      "description": "Fields to update."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.jotform.com/form/123456/question/1",
    "headers": {
      "APIKEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "question[text]": "Full Name"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "text": "Full Name"
      }
    }
  }
}