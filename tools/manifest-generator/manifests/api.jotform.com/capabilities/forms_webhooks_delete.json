{
  "name": "forms_webhooks_delete",
  "resource_group": "webhooks",
  "description": "Delete a webhook.",
  "endpoint": "/form/{formID}/webhooks/{webhookID}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "webhookID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Webhook ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.jotform.com/form/123456/webhooks/0",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": "Webhook deleted"
    }
  }
}