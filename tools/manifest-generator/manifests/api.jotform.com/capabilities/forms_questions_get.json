{
  "name": "forms_questions_get",
  "resource_group": "forms",
  "description": "Get a specific question.",
  "endpoint": "/form/{formID}/question/{questionID}",
  "method": "GET",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "questionID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Question ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456/question/1",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "type": "control_textbox",
        "text": "Name"
      }
    }
  }
}