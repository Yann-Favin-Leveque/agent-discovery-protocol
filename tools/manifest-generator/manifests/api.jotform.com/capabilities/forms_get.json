{
  "name": "forms_get",
  "resource_group": "forms",
  "description": "Get form details and metadata.",
  "endpoint": "/form/{formID}",
  "method": "GET",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "id": "123456",
        "title": "Contact Form",
        "status": "ENABLED"
      }
    }
  }
}