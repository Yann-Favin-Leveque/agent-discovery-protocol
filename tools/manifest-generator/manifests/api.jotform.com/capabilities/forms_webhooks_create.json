{
  "name": "forms_webhooks_create",
  "resource_group": "webhooks",
  "description": "Register a webhook for a form.",
  "endpoint": "/form/{formID}/webhooks",
  "method": "POST",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "webhookURL",
      "type": "string",
      "required": true,
      "in": "body",
      "description": "Webhook URL."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.jotform.com/form/123456/webhooks",
    "headers": {
      "APIKEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "webhookURL": "https://example.com/webhook"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": "Webhook added"
    }
  }
}