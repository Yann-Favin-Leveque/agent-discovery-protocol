{
  "name": "forms_submissions_list",
  "resource_group": "submissions",
  "description": "List submissions for a form.",
  "endpoint": "/form/{formID}/submissions",
  "method": "GET",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Start index."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    },
    {
      "name": "filter",
      "type": "object",
      "required": false,
      "in": "query",
      "description": "Filter criteria."
    },
    {
      "name": "orderby",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Sort field."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456/submissions?limit=20",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": [
        {
          "id": "sub-123",
          "created_at": "2025-01-15",
          "answers": {}
        }
      ]
    }
  }
}