{
  "name": "manage_form_questions",
  "description": "Add, update, or delete questions on a form. Use this to modify form structure programmatically.",
  "endpoint": "/form/{formID}/questions",
  "method": "GET",
  "parameters": [
    { "name": "formID", "type": "string", "description": "The form ID.", "required": true, "example": "123456789" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/form/123456789/questions",
    "headers": { "APIKEY": "{api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "responseCode": 200,
      "content": {
        "1": { "name": "fullName", "type": "control_fullname", "text": "Full Name", "order": "1", "required": "Yes" },
        "2": { "name": "email", "type": "control_email", "text": "Email", "order": "2", "required": "Yes" }
      }
    }
  }
}
