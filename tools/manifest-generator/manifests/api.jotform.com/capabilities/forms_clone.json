{
  "name": "forms_clone",
  "resource_group": "forms",
  "description": "Clone a form with all its settings.",
  "endpoint": "/form/{formID}/clone",
  "method": "POST",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID to clone."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.jotform.com/form/123456/clone",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "id": "789013",
        "title": "Copy of Contact Form"
      }
    }
  }
}