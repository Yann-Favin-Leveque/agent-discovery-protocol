{
  "name": "manage_webhooks",
  "description": "Register and manage webhooks to receive real-time notifications when forms are submitted. Webhooks POST submission data to your specified URL.",
  "endpoint": "/form/{formID}/webhooks",
  "method": "POST",
  "parameters": [
    { "name": "formID", "type": "string", "description": "The form ID.", "required": true, "example": "123456789" },
    { "name": "webhookURL", "type": "string", "description": "The URL to receive webhook POST requests.", "required": true, "example": "https://example.com/webhook" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.jotform.com/form/123456789/webhooks",
    "headers": { "APIKEY": "{api_key}", "Content-Type": "application/x-www-form-urlencoded" },
    "body": { "webhookURL": "https://example.com/webhook" }
  },
  "response_example": {
    "status": 200,
    "body": { "responseCode": 200, "content": { "0": "https://example.com/webhook" } }
  }
}
