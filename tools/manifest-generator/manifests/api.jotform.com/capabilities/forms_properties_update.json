{
  "name": "forms_properties_update",
  "resource_group": "forms",
  "description": "Update form properties.",
  "endpoint": "/form/{formID}/properties",
  "method": "POST",
  "parameters": [
    {
      "name": "formID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Form ID."
    },
    {
      "name": "properties",
      "type": "object",
      "required": true,
      "in": "body",
      "description": "Properties to update."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.jotform.com/form/123456/properties",
    "headers": {
      "APIKEY": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "properties[title]": "Updated Form"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": "Properties updated"
    }
  }
}