{
  "name": "submissions_get",
  "resource_group": "submissions",
  "description": "Get a specific submission.",
  "endpoint": "/submission/{submissionID}",
  "method": "GET",
  "parameters": [
    {
      "name": "submissionID",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Submission ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.jotform.com/submission/sub-123",
    "headers": {
      "APIKEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "content": {
        "id": "sub-123",
        "form_id": "123456",
        "answers": {}
      }
    }
  }
}