{
  "name": "customers_get",
  "description": "Retrieve details of a specific customer.",
  "resource_group": "customers",
  "endpoint": "/v1/customers/{customer_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/customers/cust_1Aa00000000003",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cust_1Aa00000000003",
      "name": "John Doe"
    }
  }
}
