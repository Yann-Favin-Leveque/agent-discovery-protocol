{
  "name": "settlements_get",
  "description": "Retrieve details of a specific settlement.",
  "resource_group": "settlements",
  "endpoint": "/v1/settlements/{settlement_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "settlement_id",
      "type": "string",
      "description": "The settlement ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/settlements/setl_DBJOWzybf0sJbb",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "setl_DBJOWzybf0sJbb",
      "amount": 100000
    }
  }
}