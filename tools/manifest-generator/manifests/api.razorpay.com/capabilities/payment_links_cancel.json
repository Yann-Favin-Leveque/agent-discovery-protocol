{
  "name": "payment_links_cancel",
  "description": "Cancel an existing payment link.",
  "resource_group": "payment_links",
  "endpoint": "/v1/payment_links/{plink_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "plink_id",
      "type": "string",
      "description": "The payment link ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.razorpay.com/v1/payment_links/plink_ExjpAUN3gVHrPJ/cancel",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "plink_ExjpAUN3gVHrPJ",
      "status": "cancelled"
    }
  }
}