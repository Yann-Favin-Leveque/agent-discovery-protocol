{
  "name": "create_customer",
  "description": "Create a customer record in Razorpay. Customers are needed for saving payment methods (tokens), creating subscriptions, and enabling recurring payments. Once created, a customer can be linked to payments and orders.",
  "endpoint": "/v1/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "The customer's full name.",
      "required": true,
      "example": "Raj Kumar"
    },
    {
      "name": "email",
      "type": "string",
      "description": "The customer's email address.",
      "required": true,
      "example": "raj@example.com"
    },
    {
      "name": "contact",
      "type": "string",
      "description": "The customer's phone number with country code.",
      "required": true,
      "example": "+919876543210"
    },
    {
      "name": "fail_existing",
      "type": "string",
      "description": "If '1', the request fails if a customer with the same details already exists. If '0' (default), returns the existing customer.",
      "required": false,
      "example": "0"
    },
    {
      "name": "gstin",
      "type": "string",
      "description": "The customer's GSTIN (Indian GST identification number).",
      "required": false,
      "example": "29ABCDE1234F1Z5"
    },
    {
      "name": "notes",
      "type": "object",
      "description": "Key-value pairs for additional information.",
      "required": false,
      "example": { "internal_id": "cust_789" }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.razorpay.com/v1/customers",
    "headers": {
      "Authorization": "Basic cnpwX3Rlc3RfMTIzOnNlY3JldF80NTY=",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Raj Kumar",
      "email": "raj@example.com",
      "contact": "+919876543210",
      "fail_existing": "0",
      "notes": { "internal_id": "cust_789" }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cust_1Aa00000000003",
      "entity": "customer",
      "name": "Raj Kumar",
      "email": "raj@example.com",
      "contact": "+919876543210",
      "gstin": null,
      "notes": { "internal_id": "cust_789" },
      "created_at": 1710489000
    }
  }
}
