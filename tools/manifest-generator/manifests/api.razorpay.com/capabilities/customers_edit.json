{
  "name": "customers_edit",
  "description": "Update an existing customer.",
  "resource_group": "customers",
  "endpoint": "/v1/customers/{customer_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Updated email.",
      "required": false,
      "in": "body"
    },
    {
      "name": "contact",
      "type": "string",
      "description": "Updated phone.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.razorpay.com/v1/customers/cust_1Aa00000000003",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Jane Doe"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cust_1Aa00000000003",
      "name": "Jane Doe"
    }
  }
}
