{
  "name": "refunds_list",
  "description": "List all refunds with optional filtering.",
  "resource_group": "refunds",
  "endpoint": "/v1/refunds",
  "method": "GET",
  "parameters": [
    {
      "name": "from",
      "type": "integer",
      "description": "Unix timestamp to filter from.",
      "required": false
    },
    {
      "name": "to",
      "type": "integer",
      "description": "Unix timestamp to filter to.",
      "required": false
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Number of refunds to fetch.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/refunds?count=10",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entity": "collection",
      "count": 1,
      "items": [
        {
          "id": "rfnd_FgR9UMzgmKDvRH"
        }
      ]
    }
  }
}