{
  "name": "items_create",
  "description": "Create an item that can be used in invoices and payment links.",
  "resource_group": "items",
  "endpoint": "/v1/items",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Item name.",
      "required": true
    },
    {
      "name": "amount",
      "type": "integer",
      "description": "Item amount in smallest unit.",
      "required": true
    },
    {
      "name": "currency",
      "type": "string",
      "description": "ISO currency code.",
      "required": true
    },
    {
      "name": "description",
      "type": "string",
      "description": "Item description.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.razorpay.com/v1/items",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Test item",
      "amount": 100,
      "currency": "INR"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "item_DBJOWzybf0sJbb",
      "name": "Test item"
    }
  }
}