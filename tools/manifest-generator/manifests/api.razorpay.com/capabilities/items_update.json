{
  "name": "items_update",
  "description": "Update an existing item.",
  "resource_group": "items",
  "endpoint": "/v1/items/{item_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "item_id",
      "type": "string",
      "description": "The item ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "amount",
      "type": "integer",
      "description": "Updated amount.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.razorpay.com/v1/items/item_DBJOWzybf0sJbb",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated item"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "item_DBJOWzybf0sJbb"
    }
  }
}
