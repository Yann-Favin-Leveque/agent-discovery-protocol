{
  "name": "orders_get",
  "description": "Retrieve details of a specific order by its ID.",
  "resource_group": "orders",
  "endpoint": "/v1/orders/{order_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "order_id",
      "type": "string",
      "description": "The order ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/orders/order_DBJOWzybf0sJbb",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "order_DBJOWzybf0sJbb",
      "status": "created"
    }
  }
}
