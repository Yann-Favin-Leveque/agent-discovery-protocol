{
  "name": "invoices_cancel",
  "description": "Cancel a draft or issued invoice.",
  "resource_group": "invoices",
  "endpoint": "/v1/invoices/{invoice_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "The invoice ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.razorpay.com/v1/invoices/inv_DBJOWzybf0sJbb/cancel",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "inv_DBJOWzybf0sJbb",
      "status": "cancelled"
    }
  }
}