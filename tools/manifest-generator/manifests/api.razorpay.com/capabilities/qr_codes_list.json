{
  "name": "qr_codes_list",
  "description": "List all QR codes.",
  "resource_group": "qr_codes",
  "endpoint": "/v1/payments/qr_codes",
  "method": "GET",
  "parameters": [
    {
      "name": "count",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "in": "query"
    }
