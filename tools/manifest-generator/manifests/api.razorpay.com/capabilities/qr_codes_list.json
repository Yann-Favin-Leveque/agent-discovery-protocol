    "url": "https://api.razorpay.com/v1/payments/qr_codes",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entity": "collection",
      "items": [
        {
          "id": "qr_DBJOWzybf0sJbb"
        }
      ]
    }
