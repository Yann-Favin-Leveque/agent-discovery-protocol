{
  "name": "payments_edit",
  "description": "Update an existing payment with additional notes.",
  "resource_group": "payments",
  "endpoint": "/v1/payments/{payment_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "payment_id",
      "type": "string",
      "description": "The payment ID.",
      "required": true
    },
    {
      "name": "notes",
      "type": "object",
      "description": "Updated notes.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.razorpay.com/v1/payments/pay_FgR9UMzgmKDvRH",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}",
      "Content-Type": "application/json"
    },
    "body": {
      "notes": {
        "key": "value"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pay_FgR9UMzgmKDvRH"
    }
  }
}