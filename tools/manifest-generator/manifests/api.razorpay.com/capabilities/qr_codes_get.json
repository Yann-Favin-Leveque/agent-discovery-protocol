{
  "name": "qr_codes_get",
  "description": "Retrieve a specific QR code.",
  "resource_group": "qr_codes",
  "endpoint": "/v1/payments/qr_codes/{qr_code_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "qr_code_id",
      "type": "string",
      "description": "The QR code ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/payments/qr_codes/qr_DBJOWzybf0sJbb",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "qr_DBJOWzybf0sJbb"
    }
  }
}
