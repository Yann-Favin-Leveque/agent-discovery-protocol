{
  "name": "qr_codes_close",
  "description": "Close a QR code so it can no longer accept payments.",
  "resource_group": "qr_codes",
  "endpoint": "/v1/payments/qr_codes/{qr_code_id}/close",
  "method": "POST",
  "parameters": [
    {
      "name": "qr_code_id",
      "type": "string",
      "description": "The QR code ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.razorpay.com/v1/payments/qr_codes/qr_DBJOWzybf0sJbb/close",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "qr_DBJOWzybf0sJbb",
      "close_reason": "on_demand"
    }
  }
}