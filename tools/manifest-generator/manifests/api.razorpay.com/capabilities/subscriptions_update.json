{
  "name": "subscriptions_update",
  "description": "Update a subscription.",
  "resource_group": "subscriptions",
  "endpoint": "/v1/subscriptions/{subscription_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "subscription_id",
      "type": "string",
      "description": "The subscription ID.",
      "required": true
    },
    {
      "name": "plan_id",
      "type": "string",
      "description": "New plan ID.",
      "required": false
    },
    {
      "name": "quantity",
      "type": "integer",
      "description": "Updated quantity.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.razorpay.com/v1/subscriptions/sub_DBJOWzybf0sJbb",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}",
      "Content-Type": "application/json"
    },
    "body": {
      "quantity": 2
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sub_DBJOWzybf0sJbb"
    }
  }
}