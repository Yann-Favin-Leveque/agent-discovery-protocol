{
  "name": "payments_get",
  "description": "Retrieve details of a specific payment.",
  "resource_group": "payments",
  "endpoint": "/v1/payments/{payment_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "payment_id",
      "type": "string",
      "description": "The payment ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/payments/pay_FgR9UMzgmKDvRH",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pay_FgR9UMzgmKDvRH",
      "amount": 50000,
      "currency": "INR",
      "status": "captured"
    }
  }
}
