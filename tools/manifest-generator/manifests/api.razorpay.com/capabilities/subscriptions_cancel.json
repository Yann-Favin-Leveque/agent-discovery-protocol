{
  "name": "subscriptions_cancel",
  "description": "Cancel an active subscription.",
  "resource_group": "subscriptions",
  "endpoint": "/v1/subscriptions/{subscription_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "subscription_id",
      "type": "string",
      "description": "The subscription ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "cancel_at_cycle_end",
      "type": "boolean",
      "description": "Cancel at end of current billing cycle.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.razorpay.com/v1/subscriptions/sub_DBJOWzybf0sJbb/cancel",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}",
      "Content-Type": "application/json"
    },
    "body": {
      "cancel_at_cycle_end": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sub_DBJOWzybf0sJbb",
      "status": "cancelled"
    }
  }
}
