  "endpoint": "/v1/invoices/{invoice_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "The invoice ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/invoices/inv_DBJOWzybf0sJbb",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "inv_DBJOWzybf0sJbb"
    }
  }
}