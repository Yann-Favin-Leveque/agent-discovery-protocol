{
  "name": "refunds_get",
  "description": "Retrieve details of a specific refund.",
  "resource_group": "refunds",
  "endpoint": "/v1/refunds/{refund_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "refund_id",
      "type": "string",
      "description": "The refund ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/refunds/rfnd_FgR9UMzgmKDvRH",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rfnd_FgR9UMzgmKDvRH",
      "amount": 50000
    }
  }
}