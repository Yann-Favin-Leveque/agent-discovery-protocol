{
  "name": "payments_fetch_card_details",
  "description": "Fetch card details for a specific payment.",
  "resource_group": "payments",
  "endpoint": "/v1/payments/{payment_id}/card",
  "method": "GET",
  "parameters": [
    {
      "name": "payment_id",
      "type": "string",
      "description": "The payment ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/payments/pay_FgR9UMzgmKDvRH/card",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "Visa",
      "network": "Visa",
      "last4": "1234"
    }
  }
}
