{
  "name": "transfers_get",
  "description": "Retrieve a specific transfer.",
  "resource_group": "transfers",
  "endpoint": "/v1/transfers/{transfer_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "transfer_id",
      "type": "string",
      "description": "The transfer ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.razorpay.com/v1/transfers/trf_DBJOWzybf0sJbb",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "trf_DBJOWzybf0sJbb"
    }
  }
}
