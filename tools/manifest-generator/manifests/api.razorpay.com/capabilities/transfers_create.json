{
  "name": "transfers_create",
  "description": "Create a transfer to route payment to a linked account.",
  "resource_group": "transfers",
  "endpoint": "/v1/transfers",
  "method": "POST",
  "parameters": [
    {
      "name": "account",
      "type": "string",
      "description": "Linked account ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "amount",
      "type": "integer",
      "description": "Transfer amount in smallest unit.",
      "required": true,
      "in": "body"
    },
    {
      "name": "currency",
      "type": "string",
      "description": "ISO currency code.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.razorpay.com/v1/transfers",
    "headers": {
      "Authorization": "Basic {key_id}:{key_secret}",
      "Content-Type": "application/json"
    },
    "body": {
      "account": "acc_CPRsN1LkFccllA",
      "amount": 100,
      "currency": "INR"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "trf_DBJOWzybf0sJbb",
      "amount": 100
    }
  }
}
