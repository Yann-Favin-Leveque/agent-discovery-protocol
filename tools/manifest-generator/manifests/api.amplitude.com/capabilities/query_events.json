{
  "name": "query_events",
  "description": "Query event segmentation data with filters, date ranges, and property grouping.",
  "endpoint": "/2/events/segmentation",
  "method": "GET",
  "parameters": [
    {"name": "e", "type": "string", "description": "JSON-encoded event specification.", "required": true, "example": "{\"event_type\":\"purchase\"}"},
    {"name": "start", "type": "string", "description": "Start date (YYYYMMDD).", "required": true, "example": "20240101"},
    {"name": "end", "type": "string", "description": "End date (YYYYMMDD).", "required": true, "example": "20240131"},
    {"name": "m", "type": "string", "description": "Metric type: uniques, totals, avg.", "required": false, "example": "totals"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://amplitude.com/api/2/events/segmentation?e={\"event_type\":\"purchase\"}&start=20240101&end=20240131&m=totals",
    "headers": {"Authorization": "Basic {api_key_and_secret_base64}"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"series": [42, 55, 38, 67], "seriesMeta": [{"segmentIndex": 0}], "xValues": ["2024-01-01", "2024-01-08", "2024-01-15", "2024-01-22"]}}
  }
}
