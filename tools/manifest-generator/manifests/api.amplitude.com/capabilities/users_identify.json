{
  "name": "users_identify",
  "description": "Set user ID or update user properties via the Identify API.",
  "resource_group": "ingestion",
  "endpoint": "/identify",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Project API key"
    },
    {
      "name": "identification",
      "type": "object",
      "required": true,
      "description": "Identification object with user_id, device_id, and user_properties"
    }
  ],
  "request_example": {
    "api_key": "YOUR_KEY",
    "identification": {
      "user_id": "user_123",
      "user_properties": {
        "$set": {
          "plan": "pro",
          "company": "Acme"
        }
      }
    }
  },
  "response_example": "success",
  "auth_scopes": []
}
