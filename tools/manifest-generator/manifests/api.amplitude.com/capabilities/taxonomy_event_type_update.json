{
  "name": "taxonomy_event_type_update",
  "description": "Update an existing event type in the taxonomy.",
  "resource_group": "taxonomy",
  "endpoint": "/2/taxonomy/event/{event_type}",
  "method": "PUT",
  "parameters": [
    {
      "name": "event_type",
      "type": "string",
      "required": true,
      "description": "Event type name",
      "location": "path",
      "in": "path"
    },
    {
      "name": "new_event_type",
      "type": "string",
      "required": false,
      "description": "Renamed event type",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Updated description",
      "in": "body"
    },
    {
      "name": "category",
      "type": "string",
      "required": false,
      "description": "Updated category",
      "in": "body"
    }
  ],
  "request_example": {
    "description": "User completed a purchase",
    "category": "Revenue"
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
