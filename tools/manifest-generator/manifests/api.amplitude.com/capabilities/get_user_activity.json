{
  "name": "get_user_activity",
  "description": "Get the complete event stream for a specific user by user ID or Amplitude ID.",
  "endpoint": "/2/useractivity",
  "method": "GET",
  "parameters": [
    {"name": "user", "type": "string", "description": "User ID to look up.", "required": true, "example": "user_123"},
    {"name": "offset", "type": "number", "description": "Pagination offset.", "required": false, "example": 0},
    {"name": "limit", "type": "number", "description": "Max events to return.", "required": false, "example": 100}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://amplitude.com/api/2/useractivity?user=user_123&limit=100",
    "headers": {"Authorization": "Basic {api_key_and_secret_base64}"}
  },
  "response_example": {
    "status": 200,
    "body": {"events": [{"event_type": "purchase", "event_time": "2024-01-20 10:00:00", "event_properties": {"item": "Pro Plan", "amount": 99.99}}, {"event_type": "$pageview", "event_time": "2024-01-20 09:55:00"}], "userData": {"user_id": "user_123", "num_events": 250}}
  }
}
