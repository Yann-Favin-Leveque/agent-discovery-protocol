{
  "name": "dashboard_active_users",
  "description": "Get active and new user counts for a date range.",
  "resource_group": "dashboard",
  "endpoint": "/2/users",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "string",
      "required": true,
      "description": "Start date YYYYMMDD",
      "location": "query"
    },
    {
      "name": "end",
      "type": "string",
      "required": true,
      "description": "End date YYYYMMDD",
      "location": "query"
    },
    {
      "name": "m",
      "type": "string",
      "required": false,
      "description": "Metric: active or new",
      "location": "query"
    },
    {
      "name": "i",
      "type": "integer",
      "required": false,
      "description": "Interval: 1, 7, or 30 days",
      "location": "query"
    },
    {
      "name": "g",
      "type": "string",
      "required": false,
      "description": "Group by property",
      "location": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "data": {
      "series": [
        [
          100,
          120,
          150
        ]
      ],
      "seriesLabels": [
        "All Users"
      ],
      "xValues": [
        "2025-01-01",
        "2025-01-02"
      ]
    }
  },
  "auth_scopes": []
}
