{
  "name": "get_funnel",
  "description": "Analyze a conversion funnel between specified events to identify drop-off points.",
  "endpoint": "/2/funnels",
  "method": "GET",
  "parameters": [
    {"name": "e", "type": "string", "description": "JSON-encoded array of funnel step events.", "required": true, "example": "[{\"event_type\":\"view_page\"},{\"event_type\":\"sign_up\"},{\"event_type\":\"purchase\"}]"},
    {"name": "start", "type": "string", "description": "Start date (YYYYMMDD).", "required": true, "example": "20240101"},
    {"name": "end", "type": "string", "description": "End date (YYYYMMDD).", "required": true, "example": "20240131"},
    {"name": "n", "type": "string", "description": "Conversion window type: day, week, month.", "required": false, "example": "week"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://amplitude.com/api/2/funnels?e=[{\"event_type\":\"view_page\"},{\"event_type\":\"sign_up\"},{\"event_type\":\"purchase\"}]&start=20240101&end=20240131",
    "headers": {"Authorization": "Basic {api_key_and_secret_base64}"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": [{"stepEvents": ["view_page", "sign_up", "purchase"], "stepTransitionData": [{"transitionPercentage": 25.0, "stepCount": 1000}, {"transitionPercentage": 20.0, "stepCount": 250}, {"transitionPercentage": 100.0, "stepCount": 50}]}]}
  }
}
