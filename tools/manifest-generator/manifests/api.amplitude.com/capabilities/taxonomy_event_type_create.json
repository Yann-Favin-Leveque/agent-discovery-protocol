{
  "name": "taxonomy_event_type_create",
  "description": "Create a new event type in the taxonomy.",
  "resource_group": "taxonomy",
  "endpoint": "/2/taxonomy/event",
  "method": "POST",
  "parameters": [
    {
      "name": "event_type",
      "type": "string",
      "required": true,
      "description": "Event type name",
      "in": "body"
    },
    {
      "name": "category",
      "type": "string",
      "required": false,
      "description": "Category name",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Description",
      "in": "body"
    }
  ],
  "request_example": {
    "event_type": "purchase",
    "category": "Commerce",
    "description": "User made a purchase"
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
