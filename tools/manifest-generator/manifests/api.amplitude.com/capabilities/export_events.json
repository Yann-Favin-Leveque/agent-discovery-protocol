{
  "name": "export_events",
  "description": "Export raw event data for a specific date range. Returns gzipped JSON.",
  "endpoint": "/2/export",
  "method": "GET",
  "parameters": [
    {"name": "start", "type": "string", "description": "Start date and hour (YYYYMMDDTHH).", "required": true, "example": "20240101T00"},
    {"name": "end", "type": "string", "description": "End date and hour (YYYYMMDDTHH).", "required": true, "example": "20240102T00"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://amplitude.com/api/2/export?start=20240101T00&end=20240102T00",
    "headers": {"Authorization": "Basic {api_key_and_secret_base64}"}
  },
  "response_example": {
    "status": 200,
    "body": {"event_type": "purchase", "user_id": "user_123", "event_time": "2024-01-01 15:30:00", "event_properties": {"item": "Pro Plan"}}
  }
}
