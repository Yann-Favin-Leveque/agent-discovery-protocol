{
  "name": "dashboard_funnels",
  "description": "Analyze a conversion funnel between specified events.",
  "resource_group": "dashboard",
  "endpoint": "/2/funnels",
  "method": "GET",
  "parameters": [
    {
      "name": "e",
      "type": "string",
      "required": true,
      "description": "Events JSON array (multiple)",
      "location": "query"
    },
    {
      "name": "start",
      "type": "string",
      "required": true,
      "description": "Start date",
      "location": "query"
    },
    {
      "name": "end",
      "type": "string",
      "required": true,
      "description": "End date",
      "location": "query"
    },
    {
      "name": "mode",
      "type": "string",
      "required": false,
      "description": "ordered, unordered, or sequential",
      "location": "query"
    },
    {
      "name": "cs",
      "type": "integer",
      "required": false,
      "description": "Conversion window in seconds",
      "location": "query"
    },
    {
      "name": "s",
      "type": "string",
      "required": false,
      "description": "Segments",
      "location": "query"
    },
    {
      "name": "g",
      "type": "string",
      "required": false,
      "description": "Group by",
      "location": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "data": {
      "steps": [
        {
          "count": 1000
        },
        {
          "count": 500
        }
      ]
    }
  },
  "auth_scopes": []
}
