{
  "name": "sync_products_get",
  "description": "Get a specific synchronized product.",
  "resource_group": "sync_products",
  "endpoint": "/sync/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Sync product ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/sync/products/123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "sync_product": {
          "id": 123,
          "name": "Custom T-Shirt"
        },
        "sync_variants": [
          {
            "id": 456,
            "variant_id": 4011,
            "retail_price": "25.00"
          }
        ]
      }
    }
  }
}
