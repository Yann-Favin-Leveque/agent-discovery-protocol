{
  "name": "estimate_order_cost",
  "description": "Calculate estimated costs for an order including product, printing, and shipping costs before actually placing it. Useful for displaying prices to customers or validating order feasibility.",
  "endpoint": "/orders/estimate",
  "method": "POST",
  "parameters": [
    {
      "name": "recipient",
      "type": "object",
      "description": "Shipping destination details including address, city, state, country code, and zip for accurate cost calculation.",
      "required": true,
      "example": {
        "address1": "123 Main St",
        "city": "Los Angeles",
        "state_code": "CA",
        "country_code": "US",
        "zip": "90001"
      }
    },
    {
      "name": "items",
      "type": "array",
      "description": "Array of items to estimate, each with variant_id, quantity, and files.",
      "required": true,
      "example": [
        {
          "variant_id": 4011,
          "quantity": 2,
          "files": [
            {
              "url": "https://example.com/design.png"
            }
          ]
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.printful.com/orders/estimate",
    "headers": {
      "Authorization": "Bearer YOUR_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "recipient": {
        "address1": "123 Main St",
        "city": "Los Angeles",
        "state_code": "CA",
        "country_code": "US",
        "zip": "90001"
      },
      "items": [
        {
          "variant_id": 4011,
          "quantity": 2,
          "files": [
            {
              "url": "https://example.com/design.png"
            }
          ]
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "costs": {
          "currency": "USD",
          "subtotal": "17.90",
          "discount": "0.00",
          "shipping": "3.99",
          "tax": "1.57",
          "total": "23.46"
        },
        "retail_costs": {
          "currency": "USD",
          "subtotal": "39.98",
          "discount": "0.00",
          "shipping": "5.99",
          "tax": "3.50",
          "total": "49.47"
        }
      }
    }
  }
}
