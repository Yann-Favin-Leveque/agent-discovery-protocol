{
  "name": "mockup_tasks_get",
  "description": "Retrieve mockup task results.",
  "resource_group": "mockups",
  "endpoint": "/mockup-tasks/{task_key}",
  "method": "GET",
  "parameters": [
    {
      "name": "task_key",
      "type": "string",
      "required": true,
      "description": "Task key from creation.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/mockup-tasks/task-uuid",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "task_key": "task-uuid",
        "status": "completed",
        "mockups": [
          {
            "variant_ids": [
              4011
            ],
            "mockup_url": "https://files.cdn.printful.com/mockup.jpg"
          }
        ]
      }
    }
  }
}
