{
  "name": "get_shipping_rates",
  "description": "Calculate available shipping rates and delivery estimates for a given set of items and destination address. Returns multiple shipping options with prices and estimated delivery times.",
  "endpoint": "/shipping/rates",
  "method": "POST",
  "parameters": [
    {
      "name": "recipient",
      "type": "object",
      "description": "Destination address with country_code, state_code, city, and zip for rate calculation.",
      "required": true,
      "example": {
        "country_code": "US",
        "state_code": "CA",
        "city": "Los Angeles",
        "zip": "90001"
      }
    },
    {
      "name": "items",
      "type": "array",
      "description": "Array of items with variant_id and quantity to calculate shipping for.",
      "required": true,
      "example": [
        {
          "variant_id": 4011,
          "quantity": 1
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.printful.com/shipping/rates",
    "headers": {
      "Authorization": "Bearer YOUR_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "recipient": {
        "country_code": "US",
        "state_code": "CA",
        "city": "Los Angeles",
        "zip": "90001"
      },
      "items": [
        {
          "variant_id": 4011,
          "quantity": 1
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": [
        {
          "id": "STANDARD",
          "name": "Flat Rate (3-4 business days after fulfillment)",
          "rate": "3.99",
          "currency": "USD",
          "minDeliveryDays": 3,
          "maxDeliveryDays": 4
        },
        {
          "id": "EXPRESS",
          "name": "Express (1-2 business days after fulfillment)",
          "rate": "8.99",
          "currency": "USD",
          "minDeliveryDays": 1,
          "maxDeliveryDays": 2
        }
      ]
    }
  }
}
