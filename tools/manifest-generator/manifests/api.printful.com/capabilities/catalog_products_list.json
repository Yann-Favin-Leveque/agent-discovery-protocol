{
  "name": "catalog_products_list",
  "description": "Browse the Printful product catalog.",
  "resource_group": "catalog",
  "endpoint": "/products",
  "method": "GET",
  "parameters": [
    {
      "name": "category_id",
      "type": "string",
      "required": false,
      "description": "Filter by category ID (comma-separated)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/products",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": [
        {
          "id": 71,
          "type": "T-SHIRT",
          "brand": "Gildan",
          "title": "Unisex Basic Softstyle T-Shirt",
          "variant_count": 60
        }
      ]
    }
  }
}