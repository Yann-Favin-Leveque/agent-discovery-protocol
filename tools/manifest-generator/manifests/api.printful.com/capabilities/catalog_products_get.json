{
  "name": "catalog_products_get",
  "description": "Get product details with all variants.",
  "resource_group": "catalog",
  "endpoint": "/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Product ID.",
      "example": 71
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/products/71",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "product": {
          "id": 71,
          "title": "Unisex Basic Softstyle T-Shirt"
        },
        "variants": [
          {
            "id": 4011,
            "name": "S / Black",
            "size": "S",
            "color": "Black",
            "price": "8.95"
          }
        ]
      }
    }
  }
}