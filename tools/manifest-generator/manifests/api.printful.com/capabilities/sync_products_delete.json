{
  "name": "sync_products_delete",
  "description": "Delete a synchronized product.",
  "resource_group": "sync_products",
  "endpoint": "/sync/products/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Sync product ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.printful.com/sync/products/123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "id": 123,
        "deleted": true
      }
    }
  }
}
