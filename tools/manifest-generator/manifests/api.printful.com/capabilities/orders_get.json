{
  "name": "orders_get",
  "description": "Get order details and fulfillment status.",
  "resource_group": "orders",
  "endpoint": "/orders/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Order ID.",
      "example": 1234,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/orders/1234",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "id": 1234,
        "status": "fulfilled",
        "shipping": "STANDARD",
        "shipments": [
          {
            "carrier": "USPS",
            "tracking_number": "9400111899223"
          }
        ]
      }
    }
  }
}
