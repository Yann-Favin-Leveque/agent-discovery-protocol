{
  "name": "orders_confirm",
  "description": "Confirm a draft order for fulfillment.",
  "resource_group": "orders",
  "endpoint": "/orders/{id}/confirm",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Order ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.printful.com/orders/1235/confirm",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "id": 1235,
        "status": "pending"
      }
    }
  }
}