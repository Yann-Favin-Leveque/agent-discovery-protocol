{
  "name": "countries_list",
  "description": "Retrieve the list of supported countries.",
  "resource_group": "countries",
  "endpoint": "/countries",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/countries",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": [
        {
          "code": "US",
          "name": "United States",
          "states": [
            {
              "code": "CA",
              "name": "California"
            }
          ]
        }
      ]
    }
  }
}