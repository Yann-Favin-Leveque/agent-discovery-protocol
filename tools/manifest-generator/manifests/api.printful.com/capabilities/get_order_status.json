{
  "name": "get_order_status",
  "description": "Retrieve the current status and details of an existing order including fulfillment progress, tracking info, and shipment details. Use the Printful order ID or your external order ID.",
  "endpoint": "/orders/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Printful order ID (integer) or external order ID prefixed with '@' (e.g., @my-order-123).",
      "required": true,
      "example": "13"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/orders/13",
    "headers": {
      "Authorization": "Bearer YOUR_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "id": 13,
        "external_id": "order-abc-123",
        "status": "fulfilled",
        "shipping": "STANDARD",
        "created": 1602607640,
        "updated": 1602807640,
        "recipient": {
          "name": "John Doe",
