{
  "name": "catalog_variant_get",
  "description": "Get information about a specific variant.",
  "resource_group": "catalog",
  "endpoint": "/products/variant/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Variant ID.",
      "example": 4011,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/products/variant/4011",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "variant": {
          "id": 4011,
          "product_id": 71,
          "name": "S / Black",
          "size": "S",
          "color": "Black",
          "price": "8.95"
        }
      }
    }
  }
}
