{
  "name": "create_order",
  "description": "Submit a new print-on-demand order with recipient details, product variants, and print file URLs for fulfillment. The order is created as a draft by default and must be confirmed separately.",
  "endpoint": "/orders",
  "method": "POST",
  "parameters": [
    {
      "name": "recipient",
      "type": "object",
      "description": "Shipping recipient details including name, address, city, state, country code, and zip.",
      "required": true,
      "example": {
        "name": "John Doe",
        "address1": "123 Main St",
        "city": "Los Angeles",
        "state_code": "CA",
        "country_code": "US",
        "zip": "90001"
      }
    },
    {
      "name": "items",
      "type": "array",
      "description": "Array of order items, each specifying a variant_id, quantity, and files array with print file URLs.",
      "required": true,
      "example": [
        {
          "variant_id": 4011,
          "quantity": 1,
          "files": [
            {
              "url": "https://example.com/design.png"
            }
          ]
        }
      ]
    },
    {
      "name": "confirm",
      "type": "boolean",
      "description": "If true, the order is immediately submitted for fulfillment. If false (default), created as draft.",
      "required": false,
      "example": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.printful.com/orders",
    "headers": {
      "Authorization": "Bearer YOUR_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "recipient": {
        "name": "John Doe",
        "address1": "123 Main St",
        "city": "Los Angeles",
        "state_code": "CA",
        "country_code": "US",
        "zip": "90001"
      },
      "items": [
        {
          "variant_id": 4011,
          "quantity": 1,
          "files": [
            {
              "url": "https://example.com/design.png"
            }
          ]
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "id": 13,
        "status": "draft",
        "shipping": "STANDARD",
        "created": 1602607640,
        "recipient": {
          "name": "John Doe",
          "address1": "123 Main St",
          "city": "Los Angeles",
          "state_code": "CA",
          "country_code": "US",
          "zip": "90001"
        },
        "items": [
          {
            "id": 1,
            "variant_id": 4011,
            "quantity": 1,
            "price": "8.95",
            "retail_price": "19.99"
          }
        ],
        "costs": {
          "subtotal": "8.95",
          "shipping": "3.99",
          "tax": "0.00",
          "total": "12.94"
        }
      }
    }
  }
}
