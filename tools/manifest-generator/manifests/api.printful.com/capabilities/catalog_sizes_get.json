{
  "name": "catalog_sizes_get",
  "description": "Get size guide for a specific product.",
  "resource_group": "catalog",
  "endpoint": "/products/{id}/sizes",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Product ID."
    },
    {
      "name": "unit",
      "type": "string",
      "required": false,
      "description": "Unit: inches or cm."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/products/71/sizes?unit=inches",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": {
        "available_sizes": [
          "S",
          "M",
          "L",
          "XL",
          "2XL"
        ]
      }
    }
  }
}