{
  "name": "list_catalog_products",
  "description": "Browse the Printful product catalog to find available products like t-shirts, mugs, posters, and other printable items. Returns product IDs, titles, types, and brand information.",
  "endpoint": "/products",
  "method": "GET",
  "parameters": [
    {
      "name": "category_id",
      "type": "string",
      "description": "Filter products by category ID to narrow results to a specific product type.",
      "required": false,
      "example": "24"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/products",
    "headers": {
      "Authorization": "Bearer YOUR_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": [
        {
          "id": 71,
          "type": "T-SHIRT",
          "type_name": "T-Shirt",
          "title": "Unisex Staple T-Shirt | Bella + Canvas 3001",
          "brand": "Bella + Canvas",
          "model": "3001",
          "image": "https://files.cdn.printful.com/products/71/product_1550054505.jpg",
          "variant_count": 252,
          "currency": "USD",
          "is_discontinued": false
        }
      ]
    }
  }
}
