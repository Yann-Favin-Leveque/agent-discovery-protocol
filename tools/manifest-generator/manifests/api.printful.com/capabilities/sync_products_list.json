{
  "name": "sync_products_list",
  "description": "List synchronized products.",
  "resource_group": "sync_products",
  "endpoint": "/sync/products",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Result offset."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter: synced, unsynced, all."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.printful.com/sync/products",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "code": 200,
      "result": [
        {
          "id": 123,
          "external_id": "ext-001",
          "name": "Custom T-Shirt",
          "synced": 3
        }
      ]
    }
  }
}