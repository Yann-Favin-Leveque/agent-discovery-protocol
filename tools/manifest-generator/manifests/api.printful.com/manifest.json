{
  "spec_version": "1.0",
  "name": "Printful",
  "description": "Printful is a print-on-demand fulfillment service that lets you create custom products, manage orders, and generate product mockups. It handles printing, warehousing, and shipping so you can sell custom merchandise without inventory.",
  "base_url": "https://api.printful.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://www.printful.com/dashboard/developer/api-keys"
  },
  "capabilities": [
    {
      "name": "catalog_products_list",
      "description": "Browse the Printful product catalog to find available printable items.",
      "resource_group": "catalog",
      "detail_url": "/capabilities/catalog_products_list"
    },
    {
      "name": "catalog_products_get",
      "description": "Get detailed product information with variants, sizes, colors, and pricing.",
      "resource_group": "catalog",
      "detail_url": "/capabilities/catalog_products_get"
    },
    {
      "name": "catalog_variant_get",
      "description": "Get information about a specific product variant.",
      "resource_group": "catalog",
      "detail_url": "/capabilities/catalog_variant_get"
    },
    {
      "name": "catalog_sizes_get",
      "description": "Get size guide for a specific product.",
      "resource_group": "catalog",
      "detail_url": "/capabilities/catalog_sizes_get"
    },
    {
      "name": "sync_products_list",
      "description": "List synchronized products in your store.",
      "resource_group": "sync_products",
      "detail_url": "/capabilities/sync_products_list"
    },
    {
      "name": "sync_products_create",
      "description": "Create a new synchronized product.",
      "resource_group": "sync_products",
      "detail_url": "/capabilities/sync_products_create"
    },
    {
      "name": "sync_products_get",
      "description": "Get a specific synchronized product.",
      "resource_group": "sync_products",
      "detail_url": "/capabilities/sync_products_get"
    },
    {
      "name": "sync_products_update",
      "description": "Update a synchronized product.",
      "resource_group": "sync_products",
      "detail_url": "/capabilities/sync_products_update"
    },
    {
      "name": "sync_products_delete",
      "description": "Delete a synchronized product.",
      "resource_group": "sync_products",
      "detail_url": "/capabilities/sync_products_delete"
    },
    {
      "name": "orders_list",
      "description": "List all orders.",
      "resource_group": "orders",
      "detail_url": "/capabilities/orders_list"
    },
    {
      "name": "orders_create",
      "description": "Create a new print-on-demand order.",
      "resource_group": "orders",
      "detail_url": "/capabilities/orders_create"
    },
    {
      "name": "orders_get",
      "description": "Get order details and fulfillment status.",
      "resource_group": "orders",
      "detail_url": "/capabilities/orders_get"
    },
    {
      "name": "orders_cancel",
      "description": "Cancel an order.",
      "resource_group": "orders",
      "detail_url": "/capabilities/orders_cancel"
    },
    {
      "name": "orders_confirm",
      "description": "Confirm a draft order for fulfillment.",
      "resource_group": "orders",
      "detail_url": "/capabilities/orders_confirm"
    },
    {
      "name": "orders_estimate",
      "description": "Estimate order costs before placing.",
      "resource_group": "orders",
      "detail_url": "/capabilities/orders_estimate"
    },
    {
      "name": "shipping_rates_get",
      "description": "Calculate shipping rates for items and destination.",
      "resource_group": "shipping",
      "detail_url": "/capabilities/shipping_rates_get"
    },
    {
      "name": "mockup_tasks_create",
      "description": "Create a mockup generation task.",
      "resource_group": "mockups",
      "detail_url": "/capabilities/mockup_tasks_create"
    },
    {
      "name": "mockup_tasks_get",
      "description": "Retrieve mockup task results.",
      "resource_group": "mockups",
      "detail_url": "/capabilities/mockup_tasks_get"
    },
    {
      "name": "countries_list",
      "description": "Retrieve the list of countries.",
      "resource_group": "countries",
      "detail_url": "/capabilities/countries_list"
    },
    {
      "name": "stores_get",
      "description": "Get store information.",
      "resource_group": "stores",
      "detail_url": "/capabilities/stores_get"
    }
  ]
}