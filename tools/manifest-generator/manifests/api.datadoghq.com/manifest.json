{
  "spec_version": "1.0",
  "name": "Datadog",
  "description": "Datadog is a monitoring and analytics platform for cloud infrastructure, applications, and logs. Query metrics, manage monitors and dashboards, search logs, handle incidents, and run synthetic tests through the API.",
  "base_url": "https://api.datadoghq.com",
  "auth": {
    "type": "api_key",
    "header": "DD-API-KEY",
    "prefix": "",
    "setup_url": "https://app.datadoghq.com/organization-settings/api-keys"
  },
  "capabilities": [
    {
      "name": "metrics_query",
      "description": "Query timeseries metric data with aggregation and grouping.",
      "resource_group": "metrics",
      "detail_url": "/capabilities/metrics_query"
    },
    {
      "name": "metrics_list",
      "description": "List actively reported metrics with filtering.",
      "resource_group": "metrics",
      "detail_url": "/capabilities/metrics_list"
    },
    {
      "name": "metrics_submit",
      "description": "Submit metric data points.",
      "resource_group": "metrics",
      "detail_url": "/capabilities/metrics_submit"
    },
    {
      "name": "events_list",
      "description": "List events with filtering by time, source, and tags.",
      "resource_group": "events",
      "detail_url": "/capabilities/events_list"
    },
    {
      "name": "events_create",
      "description": "Create a new event.",
      "resource_group": "events",
      "detail_url": "/capabilities/events_create"
    },
    {
      "name": "monitors_list",
      "description": "List all monitors with optional filtering.",
      "resource_group": "monitors",
      "detail_url": "/capabilities/monitors_list"
    },
    {
      "name": "monitors_get",
      "description": "Get a specific monitor by ID.",
      "resource_group": "monitors",
      "detail_url": "/capabilities/monitors_get"
    },
    {
      "name": "monitors_create",
      "description": "Create a new monitor with query and alert conditions.",
      "resource_group": "monitors",
      "detail_url": "/capabilities/monitors_create"
    },
    {
      "name": "monitors_update",
      "description": "Update an existing monitor.",
      "resource_group": "monitors",
      "detail_url": "/capabilities/monitors_update"
    },
    {
      "name": "monitors_delete",
      "description": "Delete a monitor by ID.",
      "resource_group": "monitors",
      "detail_url": "/capabilities/monitors_delete"
    },
    {
      "name": "dashboards_list",
      "description": "List all dashboards.",
      "resource_group": "dashboards",
      "detail_url": "/capabilities/dashboards_list"
    },
    {
      "name": "dashboards_get",
      "description": "Get a specific dashboard by ID.",
      "resource_group": "dashboards",
      "detail_url": "/capabilities/dashboards_get"
    },
    {
      "name": "dashboards_create",
      "description": "Create a new dashboard with widgets.",
      "resource_group": "dashboards",
      "detail_url": "/capabilities/dashboards_create"
    },
    {
      "name": "dashboards_delete",
      "description": "Delete a dashboard by ID.",
      "resource_group": "dashboards",
      "detail_url": "/capabilities/dashboards_delete"
    },
    {
      "name": "logs_search",
      "description": "Search and filter log entries.",
      "resource_group": "logs",
      "detail_url": "/capabilities/logs_search"
    },
    {
      "name": "logs_submit",
      "description": "Submit log entries to Datadog.",
      "resource_group": "logs",
      "detail_url": "/capabilities/logs_submit"
    },
    {
      "name": "incidents_list",
      "description": "List incidents with optional filtering.",
      "resource_group": "incidents",
      "detail_url": "/capabilities/incidents_list"
    },
    {
      "name": "incidents_create",
      "description": "Create a new incident.",
      "resource_group": "incidents",
      "detail_url": "/capabilities/incidents_create"
    },
    {
      "name": "hosts_list",
      "description": "List all hosts reporting to Datadog.",
      "resource_group": "hosts",
      "detail_url": "/capabilities/hosts_list"
    },
    {
      "name": "service_checks_submit",
      "description": "Submit a service check result.",
      "resource_group": "service_checks",
      "detail_url": "/capabilities/service_checks_submit"
    },
    {
      "name": "downtimes_list",
      "description": "List all scheduled downtimes.",
      "resource_group": "downtimes",
      "detail_url": "/capabilities/downtimes_list"
    },
    {
      "name": "downtimes_create",
      "description": "Schedule a new downtime.",
      "resource_group": "downtimes",
      "detail_url": "/capabilities/downtimes_create"
    },
    {
      "name": "synthetics_tests_list",
      "description": "List all synthetic tests.",
      "resource_group": "synthetics",
      "detail_url": "/capabilities/synthetics_tests_list"
    },
    {
      "name": "synthetics_test_create",
      "description": "Create a new synthetic API or browser test.",
      "resource_group": "synthetics",
      "detail_url": "/capabilities/synthetics_test_create"
    }
  ]
}
