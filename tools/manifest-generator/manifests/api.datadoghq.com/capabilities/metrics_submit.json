{
  "name": "metrics_submit",
  "description": "Submit metric data points.",
  "resource_group": "metrics",
  "endpoint": "/api/v2/series",
  "method": "POST",
  "parameters": [
    {
      "name": "series",
      "type": "array",
      "required": true,
      "description": "Array of metric series with metric name, points, type, tags",
      "in": "body"
    }
  ],
  "request_example": {
    "series": [
      {
        "metric": "custom.metric",
        "type": "gauge",
        "points": [
          {
            "timestamp": 1609459200,
            "value": 42
          }
        ],
        "tags": [
          "env:prod"
        ]
      }
    ]
  },
  "response_example": {
    "errors": []
  },
  "auth_scopes": []
}
