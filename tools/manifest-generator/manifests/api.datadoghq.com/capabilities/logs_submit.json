{
  "name": "logs_submit",
  "description": "Submit log entries to Datadog.",
  "resource_group": "logs",
  "endpoint": "/api/v2/logs",
  "method": "POST",
  "parameters": [
    {
      "name": "body",
      "type": "array",
      "required": true,
      "description": "Array of log entries with message, ddsource, ddtags, hostname"
    }
