{
  "name": "events_create",
  "description": "Create a new event.",
  "resource_group": "events",
  "endpoint": "/api/v2/events",
  "method": "POST",
  "parameters": [
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Event data with title, text, tags",
      "in": "body"
    }
  ],
  "request_example": {
    "data": {
      "type": "event",
      "attributes": {
        "title": "Deploy v2.0",
        "text": "Deployed version 2.0 to production",
        "tags": [
          "env:prod"
        ]
      }
    }
  },
  "response_example": {
    "data": {
      "id": "evt_123",
      "type": "event"
    }
  },
  "auth_scopes": []
}
