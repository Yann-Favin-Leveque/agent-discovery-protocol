{
  "name": "monitors_list",
  "description": "List all monitors with optional filtering.",
  "resource_group": "monitors",
  "endpoint": "/api/v1/monitor",
  "method": "GET",
  "parameters": [
    {
      "name": "group_states",
      "type": "string",
      "required": false,
      "description": "Filter by states: alert, warn, no data, ok",
      "location": "query"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter by name",
      "location": "query"
    },
    {
      "name": "tags",
      "type": "string",
      "required": false,
      "description": "Filter by tags",
      "location": "query"
    },
    {
      "name": "monitor_tags",
      "type": "string",
      "required": false,
      "description": "Filter by monitor tags",
      "location": "query"
    }
  ],
  "request_example": {},
  "response_example": [
    {
      "id": 1,
      "name": "CPU Monitor",
      "type": "metric alert",
      "query": "avg(last_5m):avg:system.cpu.user{*} > 90"
    }
  ],
  "auth_scopes": []
}
