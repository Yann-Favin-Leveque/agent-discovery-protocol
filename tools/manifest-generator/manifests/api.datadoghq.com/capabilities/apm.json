{
  "name": "apm",
  "description": "Manage apm — get service list. Supports standard CRUD operations through the REST API.",
  "endpoint": "/api/v2/apm/services",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[env]",
      "type": "string",
      "description": "Filter services by environment. Can be set to `*` to return all services across all environments.",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.{site}/api/v2/apm/services",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "filter[env]": "example_value"
      }
    }
  },
  "auth_scopes": [
    "apm_api_catalog_read",
    "apm_api_catalog_write",
    "apm_read",
    "apm_service_catalog_read",
    "apm_service_catalog_write"
  ]
}
