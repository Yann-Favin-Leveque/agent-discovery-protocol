{
  "name": "metrics_list",
  "description": "List actively reported metrics with filtering.",
  "resource_group": "metrics",
  "endpoint": "/api/v2/metrics",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[configured]",
      "type": "boolean",
      "required": false,
      "description": "Filter configured metrics",
      "location": "query",
      "in": "query"
    },
    {
      "name": "filter[tags_configured]",
      "type": "string",
      "required": false,
      "description": "Filter by tag configuration",
      "location": "query",
      "in": "query"
    },
    {
      "name": "filter[metric_type]",
      "type": "string",
      "required": false,
      "description": "Filter by type: gauge, count, rate",
      "location": "query",
      "in": "query"
    },
    {
      "name": "window[seconds]",
      "type": "integer",
      "required": false,
      "description": "Number of seconds to look back",
      "location": "query",
      "in": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "data": [
      {
        "id": "system.cpu.user",
        "type": "metrics",
        "attributes": {
          "metric_type": "gauge"
        }
      }
    ]
  },
  "auth_scopes": []
}
