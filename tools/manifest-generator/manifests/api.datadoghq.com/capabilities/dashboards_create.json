{
  "name": "dashboards_create",
  "description": "Create a new dashboard with widgets.",
  "resource_group": "dashboards",
  "endpoint": "/api/v1/dashboard",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Dashboard title"
    },
    {
      "name": "widgets",
      "type": "array",
      "required": true,
      "description": "Array of widget definitions"
    },
    {
      "name": "layout_type",
      "type": "string",
      "required": true,
      "description": "ordered or free"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Dashboard description"
    }
  ],
  "request_example": {
    "title": "My Dashboard",
    "layout_type": "ordered",
    "widgets": []
  },
  "response_example": {
    "id": "def-456",
    "title": "My Dashboard"
  },
  "auth_scopes": []
}
