{
  "name": "guilds_channels_list",
  "resource_group": "guilds",
  "description": "List all channels in a guild.",
  "endpoint": "/v10/guilds/{guild_id}/channels",
  "method": "GET",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/guilds/444444444444444444/channels",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "123456789012345678",
        "type": 0,
        "name": "general",
        "position": 0
      },
      {
        "id": "234567890123456789",
        "type": 2,
        "name": "Voice Chat",
        "position": 1
      }
    ]
  }
}