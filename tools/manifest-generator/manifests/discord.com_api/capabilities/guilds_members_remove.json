{
  "name": "guilds_members_remove",
  "resource_group": "guilds",
  "description": "Remove (kick) a member from a guild.",
  "endpoint": "/v10/guilds/{guild_id}/members/{user_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    },
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "User ID to remove",
      "example": "333333333333333333"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://discord.com/api/v10/guilds/444444444444444444/members/333333333333333333",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}