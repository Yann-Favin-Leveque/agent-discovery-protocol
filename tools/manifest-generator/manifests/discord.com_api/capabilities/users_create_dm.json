{
  "name": "users_create_dm",
  "resource_group": "users",
  "description": "Create a DM channel with a user.",
  "endpoint": "/v10/users/@me/channels",
  "method": "POST",
  "parameters": [
    {
      "name": "recipient_id",
      "type": "string",
      "required": true,
      "description": "User ID to create DM with",
      "example": "333333333333333333"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://discord.com/api/v10/users/@me/channels",
    "headers": {
      "Authorization": "Bot BOT_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "recipient_id": "333333333333333333"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "999999999999999999",
      "type": 1,
      "recipients": [
        {
          "id": "333333333333333333",
          "username": "User1"
        }
      ]
    }
  }
}