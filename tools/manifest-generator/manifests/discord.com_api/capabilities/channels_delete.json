{
  "name": "channels_delete",
  "resource_group": "channels",
  "description": "Delete a channel or close a DM.",
  "endpoint": "/v10/channels/{channel_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://discord.com/api/v10/channels/123456789012345678",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "123456789012345678",
      "type": 0,
      "name": "deleted-channel"
    }
  }
}