{
  "name": "threads_join",
  "resource_group": "threads",
  "description": "Join a thread.",
  "endpoint": "/v10/channels/{channel_id}/thread-members/@me",
  "method": "PUT",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Thread channel ID",
      "example": "555555555555555555"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://discord.com/api/v10/channels/555555555555555555/thread-members/@me",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}