{
  "name": "threads_active_list",
  "resource_group": "threads",
  "description": "List all active threads in a guild.",
  "endpoint": "/v10/guilds/{guild_id}/threads/active",
  "method": "GET",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/guilds/444444444444444444/threads/active",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "threads": [
        {
          "id": "555555555555555555",
          "name": "Active thread",
          "type": 11
        }
      ],
      "members": [
        {
          "id": "333333333333333333"
        }
      ]
    }
  }
}