{
  "name": "guilds_channels_create",
  "resource_group": "guilds",
  "description": "Create a new channel in a guild.",
  "endpoint": "/v10/guilds/{guild_id}/channels",
  "method": "POST",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Channel name",
      "example": "project-updates",
      "in": "body"
    },
    {
      "name": "type",
      "type": "integer",
      "required": false,
      "description": "Channel type (0=text, 2=voice, 4=category, 5=announcement, 13=stage, 15=forum)",
      "example": 0,
      "in": "body"
    },
    {
      "name": "topic",
      "type": "string",
      "required": false,
      "description": "Channel topic",
      "example": "Project update discussions",
      "in": "body"
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": false,
      "description": "Category ID to place channel under",
      "example": "666666666666666666",
      "in": "body"
    },
    {
      "name": "nsfw",
      "type": "boolean",
      "required": false,
      "description": "Whether NSFW",
      "example": false,
      "in": "body"
    },
    {
      "name": "rate_limit_per_user",
      "type": "integer",
      "required": false,
      "description": "Slowmode seconds",
      "example": 0,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://discord.com/api/v10/guilds/444444444444444444/channels",
    "headers": {
      "Authorization": "Bot BOT_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "project-updates",
      "type": 0,
      "topic": "Project update discussions"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "777777777777777777",
      "type": 0,
      "name": "project-updates",
      "guild_id": "444444444444444444",
      "topic": "Project update discussions"
    }
  }
}
