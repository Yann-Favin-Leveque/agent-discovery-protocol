{
  "name": "channels_pins_list",
  "resource_group": "channels",
  "description": "List all pinned messages in a channel.",
  "endpoint": "/v10/channels/{channel_id}/pins",
  "method": "GET",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/channels/123456789012345678/pins",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "111111111111111111",
        "content": "Pinned message!",
        "pinned": true
      }
    ]
  }
}