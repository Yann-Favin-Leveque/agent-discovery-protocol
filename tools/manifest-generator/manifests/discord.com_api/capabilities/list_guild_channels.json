{
  "name": "list_guild_channels",
  "description": "Get all channels in a guild.",
  "endpoint": "/v10/guilds/{guild_id}/channels",
  "method": "GET",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "description": "The ID of the guild.",
      "required": true,
      "example": "123456789"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/guilds/123456789/channels",
    "headers": {
      "Authorization": "Bot YOUR_BOT_TOKEN",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "123456789",
        "name": "general",
        "type": 0,
        "guild_id": "123456789",
        "position": 0,
        "permission_overwrites": [],
        "topic": null,
        "nsfw": false,
        "last_message_id": null,
        "bitrate": null,
        "user_limit": null,
        "rate_limit_per_user": 0,
        "parent_id": null,
        "rtc_region": null
      },
      {
        "id": "987654321",
        "name": "announcements",
        "type": 0,
        "guild_id": "123456789",
        "position": 1,
        "permission_overwrites": [],
        "topic": "Important announcements",
        "nsfw": false,
        "last_message_id": null,
        "bitrate": null,
        "user_limit": null,
        "rate_limit_per_user": 0,
        "parent_id": null,
        "rtc_region": null
      }
    ]
  }
}
