{
  "name": "threads_members_list",
  "resource_group": "threads",
  "description": "List members of a thread.",
  "endpoint": "/v10/channels/{channel_id}/thread-members",
  "method": "GET",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Thread channel ID",
      "example": "555555555555555555"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/channels/555555555555555555/thread-members",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "333333333333333333",
        "user_id": "333333333333333333",
        "join_timestamp": "2025-03-15T10:00:00.000000+00:00"
      }
    ]
  }
}