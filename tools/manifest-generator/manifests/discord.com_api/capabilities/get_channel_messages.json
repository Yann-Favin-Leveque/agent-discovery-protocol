{
  "name": "get_channel_messages",
  "description": "Fetch messages from a channel.",
  "endpoint": "/v10/channels/{channel_id}/messages",
  "method": "GET",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "description": "The ID of the channel.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max number of messages to return (1-100, default 50).",
      "required": false,
      "example": 50
    },
    {
      "name": "before",
      "type": "string",
      "description": "Get messages before this message ID.",
      "required": false,
      "example": "987654321"
    },
    {
      "name": "after",
      "type": "string",
      "description": "Get messages after this message ID.",
      "required": false,
      "example": "987654321"
    },
    {
      "name": "around",
      "type": "string",
      "description": "Get messages around this message ID.",
      "required": false,
      "example": "987654321"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/channels/123456789/messages?limit=50",
    "headers": {
      "Authorization": "Bot YOUR_BOT_TOKEN",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "987654321",
        "channel_id": "123456789",
        "author": {
          "id": "user_id",
          "username": "UserName",
          "discriminator": "0001"
        },
        "content": "Hello everyone!",
        "timestamp": "2024-03-01T12:00:00.000000+00:00",
        "edited_timestamp": null,
        "tts": false,
        "mention_everyone": false,
        "mentions": [],
        "mention_roles": [],
        "pinned": false,
        "type": 0
      }
    ]
  }
}
