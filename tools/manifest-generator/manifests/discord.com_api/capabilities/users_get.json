{
  "name": "users_get",
  "resource_group": "users",
  "description": "Get a user by their ID.",
  "endpoint": "/v10/users/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "User ID",
      "example": "333333333333333333"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/users/333333333333333333",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "333333333333333333",
      "username": "User1",
      "avatar": "def456"
    }
  }
}