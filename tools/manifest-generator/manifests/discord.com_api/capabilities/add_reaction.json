{
  "name": "add_reaction",
  "description": "Add an emoji reaction to a message.",
  "endpoint": "/v10/channels/{channel_id}/messages/{message_id}/reactions/{emoji}/@me",
  "method": "PUT",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "description": "The ID of the channel.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "message_id",
      "type": "string",
      "description": "The ID of the message.",
      "required": true,
      "example": "987654321"
    },
    {
      "name": "emoji",
      "type": "string",
      "description": "The emoji to react with (URL-encoded if custom emoji, e.g., 'name:id' format).",
      "required": true,
      "example": "👍"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://discord.com/api/v10/channels/123456789/messages/987654321/reactions/%F0%9F%91%8D/@me",
    "headers": {
      "Authorization": "Bot YOUR_BOT_TOKEN",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
