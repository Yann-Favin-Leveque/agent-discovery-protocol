{
  "name": "messages_crosspost",
  "resource_group": "messages",
  "description": "Crosspost (publish) a message in an announcement channel to following channels.",
  "endpoint": "/v10/channels/{channel_id}/messages/{message_id}/crosspost",
  "method": "POST",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Announcement channel ID",
      "example": "123456789012345678"
    },
    {
      "name": "message_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Message ID to crosspost",
      "example": "111111111111111111"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://discord.com/api/v10/channels/123456789012345678/messages/111111111111111111/crosspost",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "111111111111111111",
      "flags": 1
    }
  }
}