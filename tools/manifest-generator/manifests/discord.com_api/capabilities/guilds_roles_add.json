{
  "name": "guilds_roles_add",
  "resource_group": "guilds",
  "description": "Add a role to a guild member.",
  "endpoint": "/v10/guilds/{guild_id}/members/{user_id}/roles/{role_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    },
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "User ID",
      "example": "333333333333333333"
    },
    {
      "name": "role_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Role ID to add",
      "example": "888888888888888888"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://discord.com/api/v10/guilds/444444444444444444/members/333333333333333333/roles/888888888888888888",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}