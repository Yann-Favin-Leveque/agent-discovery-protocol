{
  "name": "guilds_members_get",
  "resource_group": "guilds",
  "description": "Retrieve a specific guild member.",
  "endpoint": "/v10/guilds/{guild_id}/members/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    },
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "User ID",
      "example": "333333333333333333"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/guilds/444444444444444444/members/333333333333333333",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "id": "333333333333333333",
        "username": "User1"
      },
      "nick": "Nickname",
      "roles": [
        "888888888888888888"
      ],
      "joined_at": "2025-01-15T10:00:00.000000+00:00"
    }
  }
}