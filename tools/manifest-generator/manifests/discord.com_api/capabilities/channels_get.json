{
  "name": "channels_get",
  "resource_group": "channels",
  "description": "Retrieve a channel by its ID.",
  "endpoint": "/v10/channels/{channel_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/channels/123456789012345678",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "123456789012345678",
      "type": 0,
      "name": "general",
      "guild_id": "444444444444444444",
      "position": 0,
      "topic": "General discussion"
    }
  }
}