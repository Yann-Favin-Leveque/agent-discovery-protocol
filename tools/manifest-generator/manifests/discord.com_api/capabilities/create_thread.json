{
  "name": "create_thread",
  "description": "Create a thread in a channel.",
  "endpoint": "/v10/channels/{channel_id}/threads",
  "method": "POST",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "description": "The ID of the channel.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "name",
      "type": "string",
      "description": "The name of the thread (1-100 characters).",
      "required": true,
      "example": "thread-name"
    },
    {
      "name": "auto_archive_duration",
      "type": "integer",
      "description": "Duration in minutes before auto-archiving (60, 1440, 4320, 10080).",
      "required": false,
      "example": 1440
    },
    {
      "name": "type",
      "type": "integer",
      "description": "Thread type (10=news_thread, 11=public_thread, 12=private_thread).",
      "required": false,
      "example": 11
    },
    {
      "name": "invitable",
      "type": "boolean",
      "description": "Whether non-moderators can add other non-moderators to a private thread.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://discord.com/api/v10/channels/123456789/threads",
    "headers": {
      "Authorization": "Bot YOUR_BOT_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "thread-name",
      "auto_archive_duration": 1440,
      "type": 11,
      "invitable": true
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "666666666",
      "name": "thread-name",
      "type": 11,
      "guild_id": "123456789",
      "parent_id": "123456789",
      "owner_id": "bot_id",
      "message_count": 0,
      "member_count": 1,
      "rate_limit_per_user": 0,
      "thread_metadata": {
        "archived": false,
        "auto_archive_duration": 1440,
        "archive_timestamp": null,
        "locked": false,
        "create_timestamp": "2024-03-01T12:00:00.000000+00:00"
      },
      "permissions": "0"
    }
  }
}
