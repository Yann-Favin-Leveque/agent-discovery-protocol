{
  "name": "reactions_delete_all",
  "resource_group": "reactions",
  "description": "Remove all reactions from a message.",
  "endpoint": "/v10/channels/{channel_id}/messages/{message_id}/reactions",
  "method": "DELETE",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    },
    {
      "name": "message_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Message ID",
      "example": "111111111111111111"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://discord.com/api/v10/channels/123456789012345678/messages/111111111111111111/reactions",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}