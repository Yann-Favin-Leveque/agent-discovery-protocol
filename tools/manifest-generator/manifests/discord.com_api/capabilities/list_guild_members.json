{
  "name": "list_guild_members",
  "description": "Get members of a guild.",
  "endpoint": "/v10/guilds/{guild_id}/members",
  "method": "GET",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "description": "The ID of the guild.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max number of members to return (1-1000, default 1).",
      "required": false,
      "example": 100
    },
    {
      "name": "after",
      "type": "string",
      "description": "Get members after this user ID (for pagination).",
      "required": false,
      "example": "user_id"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/guilds/123456789/members?limit=100",
    "headers": {
      "Authorization": "Bot YOUR_BOT_TOKEN",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "user": {
          "id": "user_id_1",
          "username": "Member1",
          "discriminator": "0001"
        },
        "nick": "Nickname",
        "roles": ["role_id"],
        "joined_at": "2024-03-01T12:00:00.000000+00:00",
        "deaf": false,
        "mute": false
      },
      {
        "user": {
          "id": "user_id_2",
          "username": "Member2",
          "discriminator": "0002"
        },
        "nick": null,
        "roles": [],
        "joined_at": "2024-03-01T13:00:00.000000+00:00",
        "deaf": false,
        "mute": false
      }
    ]
  }
}
