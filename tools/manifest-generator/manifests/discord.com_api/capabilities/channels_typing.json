{
  "name": "channels_typing",
  "resource_group": "channels",
  "description": "Send a typing indicator in a channel.",
  "endpoint": "/v10/channels/{channel_id}/typing",
  "method": "POST",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://discord.com/api/v10/channels/123456789012345678/typing",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}