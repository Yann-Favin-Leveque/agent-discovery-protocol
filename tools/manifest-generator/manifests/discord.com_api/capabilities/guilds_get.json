{
  "name": "guilds_get",
  "resource_group": "guilds",
  "description": "Retrieve a guild (server) by its ID.",
  "endpoint": "/v10/guilds/{guild_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    },
    {
      "name": "with_counts",
      "type": "boolean",
      "required": false,
      "description": "Include approximate member and presence counts",
      "example": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/guilds/444444444444444444?with_counts=true",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "444444444444444444",
      "name": "My Server",
      "icon": "abc123",
      "owner_id": "555555555555555555",
      "approximate_member_count": 150,
      "approximate_presence_count": 42
    }
  }
}