{
  "name": "messages_get",
  "resource_group": "messages",
  "description": "Retrieve a specific message by ID from a channel.",
  "endpoint": "/v10/channels/{channel_id}/messages/{message_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    },
    {
      "name": "message_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Message ID",
      "example": "111111111111111111"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/channels/123456789012345678/messages/111111111111111111",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "111111111111111111",
      "content": "Hello!",
      "channel_id": "123456789012345678"
    }
  }
}