{
  "name": "channels_pins_add",
  "resource_group": "channels",
  "description": "Pin a message in a channel (max 50 pins).",
  "endpoint": "/v10/channels/{channel_id}/pins/{message_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    },
    {
      "name": "message_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Message ID to pin",
      "example": "111111111111111111"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://discord.com/api/v10/channels/123456789012345678/pins/111111111111111111",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}