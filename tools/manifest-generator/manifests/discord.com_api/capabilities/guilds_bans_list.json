{
  "name": "guilds_bans_list",
  "resource_group": "guilds",
  "description": "List all bans in a guild.",
  "endpoint": "/v10/guilds/{guild_id}/bans",
  "method": "GET",
  "parameters": [
    {
      "name": "guild_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Guild ID",
      "example": "444444444444444444"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max bans to return",
      "example": 100,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://discord.com/api/v10/guilds/444444444444444444/bans",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "reason": "Spam",
        "user": {
          "id": "999999999999999999",
          "username": "banned_user"
        }
      }
    ]
  }
}
