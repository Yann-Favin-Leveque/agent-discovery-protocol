{
  "name": "reactions_create",
  "resource_group": "reactions",
  "description": "Add a reaction emoji to a message.",
  "endpoint": "/v10/channels/{channel_id}/messages/{message_id}/reactions/{emoji}/@me",
  "method": "PUT",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Channel ID",
      "example": "123456789012345678"
    },
    {
      "name": "message_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Message ID",
      "example": "111111111111111111"
    },
    {
      "name": "emoji",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "URL-encoded emoji (Unicode or custom name:id)",
      "example": "%F0%9F%91%8D"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://discord.com/api/v10/channels/123456789012345678/messages/111111111111111111/reactions/%F0%9F%91%8D/@me",
    "headers": {
      "Authorization": "Bot BOT_TOKEN"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}