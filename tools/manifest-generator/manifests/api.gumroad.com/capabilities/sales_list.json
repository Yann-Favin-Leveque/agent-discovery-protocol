{
  "name": "sales_list",
  "description": "Retrieve a paginated list of sales with optional date filtering.",
  "resource_group": "sales",
  "endpoint": "/v2/sales",
  "method": "GET",
  "parameters": [
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Only sales after this date (YYYY-MM-DD).",
      "in": "query"
    },
    {
      "name": "before",
      "type": "string",
      "required": false,
      "description": "Only sales before this date.",
      "in": "query"
    },
    {
      "name": "product_id",
      "type": "string",
      "required": false,
      "description": "Filter by product ID.",
      "in": "query"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by buyer email.",
      "in": "query"
    },
    {
      "name": "page_key",
      "type": "string",
      "required": false,
      "description": "Pagination key from previous response.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/sales?after=2024-01-01",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "sales": [
        {
          "id": "sale_01",
          "email": "buyer@example.com",
          "product_id": "abc123",
          "product_name": "My E-Book",
          "price": 999,
          "created_at": "2024-01-15T10:30:00Z"
        }
      ],
      "next_page_key": "page2"
    }
  }
}
