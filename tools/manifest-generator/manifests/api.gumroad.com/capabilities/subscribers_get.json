{
  "name": "subscribers_get",
  "description": "Retrieve a specific subscriber.",
  "resource_group": "subscribers",
  "endpoint": "/v2/subscribers/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Subscriber ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/subscribers/sub_01",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "subscriber": {
        "id": "sub_01",
        "email": "subscriber@example.com",
        "status": "alive"
      }
    }
  }
}
