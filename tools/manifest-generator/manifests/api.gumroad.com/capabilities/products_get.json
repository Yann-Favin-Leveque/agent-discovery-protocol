{
  "name": "products_get",
  "description": "Fetch detailed information about a specific product.",
  "resource_group": "products",
  "endpoint": "/v2/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Product ID.",
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/products/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "product": {
        "id": "abc123",
        "name": "My E-Book",
        "price": 999,
        "description": "A great e-book",
        "sales_count": 42
      }
    }
  }
}