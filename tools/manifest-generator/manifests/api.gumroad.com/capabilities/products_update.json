{
  "name": "products_update",
  "description": "Update an existing product.",
  "resource_group": "products",
  "endpoint": "/v2/products/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Product ID."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name."
    },
    {
      "name": "price",
      "type": "integer",
      "required": false,
      "description": "Updated price in cents."
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Updated description."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.gumroad.com/v2/products/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "price": 1499
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "product": {
        "id": "abc123",
        "price": 1499
      }
    }
  }
}