{
  "name": "subscribers_list",
  "description": "Retrieve subscribers for a specific product.",
  "resource_group": "subscribers",
  "endpoint": "/v2/products/{product_id}/subscribers",
  "method": "GET",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "required": true,
      "description": "Product ID.",
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/products/abc123/subscribers",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "subscribers": [
        {
          "id": "sub_01",
          "email": "subscriber@example.com",
          "status": "alive",
          "created_at": "2024-01-01T00:00:00Z"
        }
      ]
    }
  }
}