{
  "name": "products_list",
  "description": "Retrieve all products for the authenticated user.",
  "resource_group": "products",
  "endpoint": "/v2/products",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/products",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "products": [
        {
          "id": "abc123",
          "name": "My E-Book",
          "price": 999,
          "currency": "usd",
          "url": "https://gumroad.com/l/abc123",
          "sales_count": 42,
          "published": true
        }
      ]
    }
  }
}