{
  "name": "list_products",
  "description": "Retrieve all products for the authenticated user including their names, prices, URLs, sales counts, and publication status. Returns the complete product catalog for the seller account.",
  "endpoint": "/v2/products",
  "method": "GET",
  "parameters": [
    {
      "name": "access_token",
      "type": "string",
      "description": "Your Gumroad API access token for authentication.",
      "required": true,
      "example": "your_access_token"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/products",
    "headers": {
      "Authorization": "Bearer YOUR_ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "products": [
        {
          "id": "abc123",
          "name": "Ultimate Design Kit",
          "description": "A comprehensive design resource pack.",
          "price": 2900,
          "currency": "usd",
          "short_url": "https://gum.co/abc123",
          "published": true,
          "sales_count": 150,
          "sales_usd_cents": 435000,
          "url": "https://example.gumroad.com/l/abc123",
          "preview_url": "https://example.com/preview.jpg",
          "custom_fields": [],
          "is_tiered_membership": false
        }
      ]
    }
  }
}
