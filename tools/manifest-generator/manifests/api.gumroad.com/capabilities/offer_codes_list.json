{
  "name": "offer_codes_list",
  "description": "List all offer codes for a product.",
  "resource_group": "offer_codes",
  "endpoint": "/v2/products/{product_id}/offer_codes",
  "method": "GET",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "required": true,
      "description": "Product ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/products/abc123/offer_codes",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "offer_codes": [
        {
          "id": "oc_01",
          "name": "SUMMER",
          "amount_off": 500,
          "max_purchase_count": 100
        }
      ]
    }
  }
}
