{
  "name": "products_delete",
  "description": "Permanently delete a product.",
  "resource_group": "products",
  "endpoint": "/v2/products/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Product ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.gumroad.com/v2/products/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "message": "Product was deleted."
    }
  }
}
