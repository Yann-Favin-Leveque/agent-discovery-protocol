{
  "name": "sales_get",
  "description": "Retrieve details of a specific sale.",
  "resource_group": "sales",
  "endpoint": "/v2/sales/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Sale ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/sales/sale_01",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "sale": {
        "id": "sale_01",
        "email": "buyer@example.com",
        "price": 999,
        "product_id": "abc123"
      }
    }
  }
}
