{
  "name": "list_sales",
  "description": "Retrieve a paginated list of sales for the authenticated user, with optional filtering by date range, product, and email. Useful for revenue tracking and customer analytics.",
  "endpoint": "/v2/sales",
  "method": "GET",
  "parameters": [
    {
      "name": "after",
      "type": "string",
      "description": "Only return sales after this date (ISO 8601 format: YYYY-MM-DD).",
      "required": false,
      "example": "2024-01-01"
    },
    {
      "name": "before",
      "type": "string",
      "description": "Only return sales before this date (ISO 8601 format: YYYY-MM-DD).",
      "required": false,
      "example": "2024-12-31"
    },
    {
      "name": "product_id",
      "type": "string",
      "description": "Filter sales to a specific product by its ID.",
      "required": false,
      "example": "abc123"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Filter sales by buyer email address.",
      "required": false,
      "example": "buyer@example.com"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for pagination (starts at 1).",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/sales?after=2024-01-01&before=2024-12-31&page=1",
    "headers": {
      "Authorization": "Bearer YOUR_ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "sales": [
        {
          "id": "sale_abc123",
          "email": "buyer@example.com",
          "seller_id": "seller_xyz",
          "product_id": "abc123",
          "product_name": "Ultimate Design Kit",
          "timestamp": "2024-03-15T14:30:00Z",
          "price": 2900,
          "currency": "usd",
          "quantity": 1,
          "refunded": false,
          "disputed": false,
          "license_key": "XXXX-XXXX-XXXX-XXXX",
          "order_number": 12345
        }
      ],
      "next_page_url": "https://api.gumroad.com/v2/sales?after=2024-01-01&before=2024-12-31&page=2",
      "next_page_key": "2024-03-15T14:30:00Z"
    }
  }
}
