{
  "name": "user_get",
  "description": "Retrieve the authenticated user profile.",
  "resource_group": "user",
  "endpoint": "/v2/user",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/user",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "user": {
        "name": "Creator Name",
        "email": "creator@example.com",
        "url": "https://gumroad.com/creator"
      }
    }
  }
}