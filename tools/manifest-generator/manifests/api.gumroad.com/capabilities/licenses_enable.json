{
  "name": "licenses_enable",
  "description": "Enable a disabled license key.",
  "resource_group": "licenses",
  "endpoint": "/v2/licenses/enable",
  "method": "PUT",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "required": true,
      "description": "Product ID.",
      "in": "body"
    },
    {
      "name": "license_key",
      "type": "string",
      "required": true,
      "description": "License key to enable.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.gumroad.com/v2/licenses/enable",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "product_id": "abc123",
      "license_key": "ABCD-1234-EFGH-5678"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "purchase": {
        "license_key": "ABCD-1234-EFGH-5678",
        "disabled": false
      }
    }
  }
}
