{
  "name": "list_subscribers",
  "description": "Retrieve active subscribers for a specific product, including their status, payment amounts, and subscription dates. Useful for managing membership products and recurring revenue tracking.",
  "endpoint": "/v2/products/{product_id}/subscribers",
  "method": "GET",
  "parameters": [
    {
      "name": "product_id",
      "type": "string",
      "description": "The product ID to retrieve subscribers for. Must be a membership/subscription product.",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Filter subscribers by email address.",
      "required": false,
      "example": "subscriber@example.com"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for pagination (starts at 1).",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/products/abc123/subscribers?page=1",
    "headers": {
      "Authorization": "Bearer YOUR_ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "subscribers": [
        {
          "id": "sub_xyz789",
          "email": "subscriber@example.com",
          "status": "alive",
          "created_at": "2024-01-10T08:00:00Z",
          "user_requested_cancellation_at": null,
          "charge_occurrence_count": 3,
          "ended_at": null,
          "failed_at": null,
          "free_trial_ends_at": null,
          "license_key": "YYYY-YYYY-YYYY-YYYY"
        }
      ]
    }
  }
}
