{
  "name": "get_product",
  "description": "Fetch detailed information about a specific product including description, pricing tiers, variants, custom fields, and sales data. Use the product ID from list_products.",
  "endpoint": "/v2/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The unique product ID to retrieve.",
      "required": true,
      "example": "abc123"
    },
    {
      "name": "access_token",
      "type": "string",
      "description": "Your Gumroad API access token for authentication.",
      "required": true,
      "example": "your_access_token"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gumroad.com/v2/products/abc123",
    "headers": {
      "Authorization": "Bearer YOUR_ACCESS_TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "product": {
        "id": "abc123",
        "name": "Ultimate Design Kit",
        "description": "A comprehensive design resource pack with 500+ icons, templates, and mockups.",
        "price": 2900,
        "currency": "usd",
        "short_url": "https://gum.co/abc123",
        "published": true,
        "sales_count": 150,
        "sales_usd_cents": 435000,
        "custom_fields": [
          {
            "name": "Company Name",
            "required": true
          }
        ],
        "variants": [
          {
            "title": "License Type",
            "options": [
              {
                "name": "Personal",
                "price_difference": 0
              },
              {
                "name": "Commercial",
                "price_difference": 2000
              }
            ]
          }
        ],
        "is_tiered_membership": false,
        "created_at": "2024-01-10T12:00:00Z",
        "updated_at": "2024-03-01T15:30:00Z"
      }
    }
  }
}
