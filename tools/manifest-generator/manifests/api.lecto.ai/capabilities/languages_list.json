{
  "name": "languages_list",
  "description": "List all supported languages with their ISO codes, names, and whether they are supported as source and/or target languages.",
  "resource_group": "languages",
  "endpoint": "/v1/translate/languages",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.lecto.ai/v1/translate/languages",
    "headers": {
      "X-API-Key": "your-lecto-api-key",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "languages": [
        {
          "code": "en",
          "name": "English",
          "source": true,
          "target": true
        },
        {
          "code": "fr",
          "name": "French",
          "source": true,
          "target": true
        },
        {
          "code": "de",
          "name": "German",
          "source": true,
          "target": true
        }
      ]
    }
  }
}
