{
  "name": "account_info",
  "description": "Retrieve account information including subscription plan, usage statistics, and active status.",
  "resource_group": "account",
  "endpoint": "/v1/account/info",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.lecto.ai/v1/account/info",
    "headers": {
      "X-API-Key": "your-lecto-api-key",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "plan": "pro",
      "status": "active",
      "usage": {
        "characters_used": 150000,
        "characters_limit": 1000000
      },
      "period_start": "2026-02-01T00:00:00.000Z",
      "period_end": "2026-03-01T00:00:00.000Z"
    }
  }
}
