{
  "name": "list_languages",
  "description": "List all languages supported by the Lecto AI translation API. Returns language codes and their human-readable names. Use this to discover available source and target languages before making translation requests.",
  "endpoint": "/v1/translate/languages",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.lecto.ai/v1/translate/languages",
    "headers": {
      "X-API-Key": "your-api-key-here",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "languages": [
        { "code": "en", "name": "English" },
        { "code": "es", "name": "Spanish" },
        { "code": "fr", "name": "French" },
        { "code": "de", "name": "German" },
        { "code": "it", "name": "Italian" },
        { "code": "pt", "name": "Portuguese" },
        { "code": "zh", "name": "Chinese" },
        { "code": "ja", "name": "Japanese" },
        { "code": "ko", "name": "Korean" },
        { "code": "ar", "name": "Arabic" },
        { "code": "hi", "name": "Hindi" },
        { "code": "ru", "name": "Russian" },
        { "code": "nl", "name": "Dutch" },
        { "code": "pl", "name": "Polish" },
        { "code": "sv", "name": "Swedish" }
      ]
    }
  }
}
