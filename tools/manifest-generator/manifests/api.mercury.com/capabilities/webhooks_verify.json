{
  "name": "webhooks_verify",
  "description": "Verify a webhook endpoint by confirming its reachability.",
  "endpoint": "/webhook/verify",
  "method": "POST",
  "resource_group": "webhooks",
  "parameters": [
    { "name": "webhookId", "type": "string", "description": "The webhook identifier to verify", "required": true, "example": "wh_001" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mercury.com/webhook/verify",
    "headers": { "Authorization": "Bearer {token}", "Content-Type": "application/json" },
    "body": { "webhookId": "wh_001" }
  },
  "response_example": {
    "status": 200,
    "body": { "verified": true }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 10 }
}
