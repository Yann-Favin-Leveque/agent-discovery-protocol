{
  "name": "invoices_cancel",
  "description": "Cancel an existing invoice.",
  "endpoint": "/api/v1/ar/invoices/{invoiceId}/cancel",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "invoiceId",
      "type": "string",
      "description": "The invoice identifier to cancel",
      "required": true,
      "example": "inv_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mercury.com/api/v1/ar/invoices/inv_001/cancel",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "inv_001",
      "status": "cancelled"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
