{
  "name": "accounts_statements_list",
  "description": "Retrieve account statements for a specific Mercury bank account.",
  "endpoint": "/api/v1/account/{accountId}/statements",
  "method": "GET",
  "resource_group": "accounts",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "description": "The unique identifier of the account",
      "required": true,
      "example": "acc_123abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/account/acc_123abc/statements",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "statements": [
        {
          "id": "stmt_789",
          "month": "2025-01",
          "url": "https://api.mercury.com/statements/stmt_789.pdf"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
