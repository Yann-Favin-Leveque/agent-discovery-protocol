{
  "name": "list_accounts",
  "description": "List all bank accounts associated with your Mercury organization. Returns checking and savings accounts with their names, balances, and account types.",
  "endpoint": "/api/v1/accounts",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/accounts",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "accounts": [
        {
          "id": "acc-12345-abcde",
          "name": "Mercury Checking",
          "type": "checking",
          "status": "active",
          "currentBalance": 150000.00,
          "availableBalance": 148500.00,
          "routingNumber": "084106768",
          "accountNumber": "1234567890",
          "createdAt": "2025-01-15T10:00:00Z"
        }
      ]
    }
  }
}
