{
  "name": "customers_get",
  "description": "Retrieve details for a specific customer by ID.",
  "endpoint": "/api/v1/ar/customers/{customerId}",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    { "name": "customerId", "type": "string", "description": "The customer identifier", "required": true, "example": "cust_001" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/ar/customers/cust_001",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "cust_001", "name": "Acme Corp", "email": "billing@acme.com" }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
