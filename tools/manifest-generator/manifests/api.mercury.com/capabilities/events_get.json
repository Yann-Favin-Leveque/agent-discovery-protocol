{
  "name": "events_get",
  "description": "Retrieve details of a specific event by ID.",
  "endpoint": "/api/v1/event/{eventId}",
  "method": "GET",
  "resource_group": "events",
  "parameters": [
    { "name": "eventId", "type": "string", "description": "The event identifier", "required": true, "example": "evt_001" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/event/evt_001",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "evt_001", "type": "transaction.created", "data": {}, "createdAt": "2025-01-15T10:30:00Z" }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
