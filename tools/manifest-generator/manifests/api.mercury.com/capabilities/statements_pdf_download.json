{
  "name": "statements_pdf_download",
  "description": "Download an account statement as a PDF file.",
  "endpoint": "/api/v1/statement/pdf",
  "method": "GET",
  "resource_group": "statements",
  "parameters": [
    { "name": "accountId", "type": "string", "description": "The account ID", "required": true, "example": "acc_123abc" },
    { "name": "month", "type": "string", "description": "Statement month in YYYY-MM format", "required": true, "example": "2025-01" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/statement/pdf?accountId=acc_123abc&month=2025-01",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": "<PDF binary content>"
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 30 }
}
