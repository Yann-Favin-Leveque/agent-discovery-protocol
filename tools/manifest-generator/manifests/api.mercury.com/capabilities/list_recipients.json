{
  "name": "list_recipients",
  "description": "List all saved payment recipients in your Mercury account. Returns recipient names, payment methods, and statuses. Use this to find recipient IDs before sending payments.",
  "endpoint": "/api/v1/recipients",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/recipients",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "recipients": [
        {
          "id": "rec-xyz-789",
          "name": "Acme Consulting LLC",
          "emails": ["payments@acme.com"],
          "paymentMethod": "ach",
          "status": "active",
          "createdAt": "2026-01-10T09:00:00Z"
        },
        {
          "id": "rec-abc-456",
          "name": "Cloud Hosting Inc",
          "emails": ["billing@cloudhosting.com"],
          "paymentMethod": "domesticWire",
          "status": "active",
          "createdAt": "2026-02-05T11:00:00Z"
        }
      ]
    }
  }
}
