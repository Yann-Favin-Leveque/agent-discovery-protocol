      "recipients": [
        { "id": "rcp_456def", "name": "Acme Corp", "emails": ["billing@acme.com"], "paymentMethod": "ach" }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
