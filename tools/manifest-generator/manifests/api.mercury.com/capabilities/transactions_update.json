{
  "name": "transactions_update",
  "description": "Update metadata on a transaction such as notes or categories.",
  "endpoint": "/api/v1/transaction/{transactionId}",
  "method": "PATCH",
  "resource_group": "transactions",
  "parameters": [
    { "name": "transactionId", "type": "string", "description": "The unique transaction identifier", "required": true, "example": "txn_abc123" },
    { "name": "note", "type": "string", "description": "A note or memo to attach to the transaction", "required": false, "example": "Q1 cloud hosting" },
    { "name": "categoryId", "type": "string", "description": "Category ID to assign to the transaction", "required": false, "example": "cat_tech" }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.mercury.com/api/v1/transaction/txn_abc123",
    "headers": { "Authorization": "Bearer {token}", "Content-Type": "application/json" },
    "body": { "note": "Q1 cloud hosting", "categoryId": "cat_tech" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "txn_abc123", "note": "Q1 cloud hosting", "categoryId": "cat_tech" }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 30 }
}
