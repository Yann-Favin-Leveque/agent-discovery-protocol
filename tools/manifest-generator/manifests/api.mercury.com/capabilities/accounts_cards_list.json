{
  "name": "accounts_cards_list",
  "description": "List all debit cards associated with a specific Mercury account.",
  "endpoint": "/api/v1/account/{accountId}/cards",
  "method": "GET",
  "resource_group": "accounts",
  "parameters": [
    { "name": "accountId", "type": "string", "description": "The unique identifier of the account", "required": true, "example": "acc_123abc" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/account/acc_123abc/cards",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "cards": [
        { "id": "card_456", "lastFourDigits": "1234", "status": "active", "type": "debit" }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
