{
  "name": "webhooks_get",
  "description": "Retrieve details of a specific webhook endpoint by ID.",
  "endpoint": "/webhook/{webhookId}",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [
    { "name": "webhookId", "type": "string", "description": "The webhook identifier", "required": true, "example": "wh_001" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/webhook/wh_001",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "wh_001", "url": "https://myapp.com/webhooks/mercury", "status": "active", "events": ["transaction.created"] }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
