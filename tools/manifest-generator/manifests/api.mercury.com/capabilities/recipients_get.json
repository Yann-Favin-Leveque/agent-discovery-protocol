{
  "name": "recipients_get",
  "description": "Retrieve details for a specific payment recipient by ID.",
  "endpoint": "/api/v1/recipient/{recipientId}",
  "method": "GET",
  "resource_group": "recipients",
  "parameters": [
    { "name": "recipientId", "type": "string", "description": "The unique recipient identifier", "required": true, "example": "rcp_456def" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/recipient/rcp_456def",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rcp_456def",
      "name": "Acme Corp",
      "emails": ["billing@acme.com"],
      "paymentMethod": "ach",
      "routingNumber": "021000089",
      "accountNumber": "****7890"
    }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
