{
  "name": "invoices_pdf_download",
  "description": "Download the PDF version of an invoice by its slug.",
  "endpoint": "/api/v1/ar/invoices/{slug}/pdf",
  "method": "GET",
  "resource_group": "invoices",
  "parameters": [
    { "name": "slug", "type": "string", "description": "The invoice slug identifier", "required": true, "example": "INV-2025-001" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/ar/invoices/INV-2025-001/pdf",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": "<PDF binary content>"
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 30 }
}
