{
  "name": "get_account_details",
  "description": "Get detailed information about a specific Mercury bank account including current balance, available balance, routing number, and account number. Useful for verifying balances before initiating payments.",
  "endpoint": "/api/v1/account/{account_id}",
  "method": "GET",
  "parameters": [
    { "name": "account_id", "type": "string", "description": "The unique identifier of the Mercury account.", "required": true, "example": "acc-12345-abcde" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/account/acc-12345-abcde",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "acc-12345-abcde",
      "name": "Mercury Checking",
      "type": "checking",
      "status": "active",
      "currentBalance": 150000.00,
      "availableBalance": 148500.00,
      "routingNumber": "084106768",
      "accountNumber": "1234567890",
      "legalBusinessName": "Startup Inc.",
      "createdAt": "2025-01-15T10:00:00Z"
    }
  }
}
