{
  "name": "create_recipient",
  "description": "Create a new payment recipient with their bank account details. Recipients must be created before you can send payments to them. Supports both ACH and wire transfer recipients.",
  "endpoint": "/api/v1/recipients",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "The name of the recipient (person or company).", "required": true, "example": "Acme Consulting LLC" },
    { "name": "emails", "type": "array", "description": "Email addresses to notify when payment is sent.", "required": false, "example": ["payments@acme.com"] },
    { "name": "paymentMethod", "type": "string", "description": "Payment method: 'ach' or 'domesticWire'.", "required": true, "example": "ach" },
    { "name": "routingNumber", "type": "string", "description": "The recipient's bank routing number.", "required": true, "example": "021000021" },
    { "name": "accountNumber", "type": "string", "description": "The recipient's bank account number.", "required": true, "example": "9876543210" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mercury.com/api/v1/recipients",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Consulting LLC",
      "emails": ["payments@acme.com"],
      "paymentMethod": "ach",
      "routingNumber": "021000021",
      "accountNumber": "9876543210"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rec-xyz-789",
      "name": "Acme Consulting LLC",
      "emails": ["payments@acme.com"],
      "paymentMethod": "ach",
      "status": "active",
      "createdAt": "2026-03-01T12:00:00Z"
    }
  }
}
