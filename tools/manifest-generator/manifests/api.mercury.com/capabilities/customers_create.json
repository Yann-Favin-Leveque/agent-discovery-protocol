{
  "name": "customers_create",
  "description": "Create a new accounts receivable customer.",
  "endpoint": "/api/v1/ar/customers",
  "method": "POST",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Customer name",
      "required": true,
      "example": "Acme Corp",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Customer email address",
      "required": true,
      "example": "billing@acme.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mercury.com/api/v1/ar/customers",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Corp",
      "email": "billing@acme.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cust_new001",
      "name": "Acme Corp",
      "email": "billing@acme.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
