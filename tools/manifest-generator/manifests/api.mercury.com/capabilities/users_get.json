{
  "name": "users_get",
  "description": "Retrieve details of a specific user by ID.",
  "endpoint": "/api/v1/user/{userId}",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    { "name": "userId", "type": "string", "description": "The user identifier", "required": true, "example": "usr_001" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/user/usr_001",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "usr_001", "name": "John Doe", "email": "john@startup.com", "role": "admin" }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
