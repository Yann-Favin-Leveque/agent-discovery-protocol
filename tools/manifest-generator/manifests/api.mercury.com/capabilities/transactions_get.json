{
  "name": "transactions_get",
  "description": "Retrieve detailed information about a specific transaction by its ID.",
  "endpoint": "/api/v1/transaction/{transactionId}",
  "method": "GET",
  "resource_group": "transactions",
  "parameters": [
    { "name": "transactionId", "type": "string", "description": "The unique transaction identifier", "required": true, "example": "txn_abc123" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/transaction/txn_abc123",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "txn_abc123",
      "amount": -1500.00,
      "counterpartyName": "AWS",
      "status": "sent",
      "kind": "externalTransfer",
      "postedAt": "2025-01-15T10:30:00Z",
      "note": "Cloud hosting"
    }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
