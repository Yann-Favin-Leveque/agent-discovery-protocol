{
  "name": "invoices_get",
  "description": "Retrieve details of a specific invoice by ID.",
  "endpoint": "/api/v1/ar/invoices/{invoiceId}",
  "method": "GET",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "invoiceId",
      "type": "string",
      "description": "The invoice identifier",
      "required": true,
      "example": "inv_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/ar/invoices/inv_001",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "inv_001",
      "customerName": "Acme Corp",
      "amount": 5000,
      "status": "sent",
      "dueDate": "2025-02-15"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
