{
  "name": "accounts_list",
  "description": "List all bank accounts associated with your Mercury organization, including checking and savings accounts.",
  "endpoint": "/api/v1/accounts",
  "method": "GET",
  "resource_group": "accounts",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/accounts",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "accounts": [
        {
          "id": "acc_123",
          "name": "Checking",
          "type": "checking",
          "currentBalance": 50000.00,
          "availableBalance": 48000.00,
          "routingNumber": "021000089",
          "accountNumber": "1234567890",
          "status": "active"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
