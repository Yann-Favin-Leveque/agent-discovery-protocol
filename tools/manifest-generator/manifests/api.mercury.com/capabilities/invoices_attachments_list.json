{
  "name": "invoices_attachments_list",
  "description": "List all attachments for a specific invoice.",
  "endpoint": "/api/v1/ar/invoices/{invoiceId}/attachments",
  "method": "GET",
  "resource_group": "invoices",
  "parameters": [
    { "name": "invoiceId", "type": "string", "description": "The invoice identifier", "required": true, "example": "inv_001" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mercury.com/api/v1/ar/invoices/inv_001/attachments",
    "headers": { "Authorization": "Bearer {token}" }
  },
  "response_example": {
    "status": 200,
    "body": { "attachments": [{ "id": "att_inv_001", "fileName": "contract.pdf" }] }
  },
  "auth_scopes": [],
  "rate_limits": { "requests_per_minute": 60 }
}
