{
  "name": "videos_upload",
  "description": "Upload a video to a Facebook Page.",
  "resource_group": "videos",
  "endpoint": "/v21.0/{page_id}/videos",
  "method": "POST",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "description": "Page ID.",
      "in": "path"
    },
    {
      "name": "file_url",
      "type": "string",
      "required": false,
      "description": "URL of the video file.",
      "in": "body"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Video title.",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Video description.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v21.0/111222333/videos",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "file_url": "https://example.com/video.mp4",
      "title": "Product Demo",
      "description": "Check out our new product"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "video_123"
    }
  }
}
