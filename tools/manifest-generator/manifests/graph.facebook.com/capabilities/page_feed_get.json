{
  "name": "page_feed_get",
  "description": "Retrieve recent posts from a Page feed.",
  "resource_group": "pages",
  "endpoint": "/v21.0/{page_id}/feed",
  "method": "GET",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "description": "Page ID."
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Fields: message, created_time, likes.summary(true), comments.summary(true)."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of posts to return."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.facebook.com/v21.0/111222333/feed?fields=message,created_time,likes.summary(true)&limit=10",
    "headers": {
      "Authorization": "Bearer {page_access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "111222333_444555666",
          "message": "Hello world!",
          "created_time": "2024-01-15T12:00:00+0000",
          "likes": {
            "summary": {
              "total_count": 42
            }
          }
        }
      ]
    }
  }
}