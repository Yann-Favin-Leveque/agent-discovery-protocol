{
  "name": "post_get",
  "description": "Retrieve a specific post by ID.",
  "resource_group": "posts",
  "endpoint": "/v21.0/{post_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "post_id",
      "type": "string",
      "required": true,
      "description": "Post ID.",
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Fields to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.facebook.com/v21.0/111222333_444555666?fields=id,message,created_time,likes.summary(true)",
    "headers": {
      "Authorization": "Bearer {page_access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "111222333_444555666",
      "message": "Hello world!",
      "created_time": "2024-01-15T12:00:00+0000"
    }
  }
}
