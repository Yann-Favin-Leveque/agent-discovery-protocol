{
  "name": "post_comments_create",
  "description": "Reply to a post with a comment.",
  "resource_group": "comments",
  "endpoint": "/v21.0/{post_id}/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "post_id",
      "type": "string",
      "required": true,
      "description": "Post ID."
    },
    {
      "name": "message",
      "type": "string",
      "required": true,
      "description": "Comment text.",
      "example": "Thanks for your feedback!"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v21.0/111222333_444555666/comments",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "message": "Thanks for your feedback!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "comment_02"
    }
  }
}