{
  "name": "pages_list",
  "description": "List all Pages managed by the authenticated user.",
  "resource_group": "pages",
  "endpoint": "/v21.0/me/accounts",
  "method": "GET",
  "parameters": [
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Fields: id, name, access_token, category."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://graph.facebook.com/v21.0/me/accounts?fields=id,name,access_token,category",
    "headers": {
      "Authorization": "Bearer {user_access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "111222333",
          "name": "My Business Page",
          "access_token": "page_token_here",
          "category": "Business"
        }
      ]
    }
  }
}