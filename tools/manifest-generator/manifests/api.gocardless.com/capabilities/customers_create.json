{
  "name": "customers_create",
  "description": "Create a new customer record.",
  "resource_group": "customers",
  "endpoint": "/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Customer email.",
      "required": false
    },
    {
      "name": "given_name",
      "type": "string",
      "description": "First name.",
      "required": false
    },
    {
      "name": "family_name",
      "type": "string",
      "description": "Last name.",
      "required": false
    },
    {
      "name": "company_name",
      "type": "string",
      "description": "Company name.",
      "required": false
    },
    {
      "name": "address_line1",
      "type": "string",
      "description": "Address line 1.",
      "required": false
    },
    {
      "name": "city",
      "type": "string",
      "description": "City.",
      "required": false
    },
    {
      "name": "postal_code",
      "type": "string",
      "description": "Postal code.",
      "required": false
    },
    {
      "name": "country_code",
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gocardless.com/customers",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "customers": {
        "email": "john@example.com",
        "given_name": "John",
        "family_name": "Doe",
        "country_code": "GB"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "customers": {
        "id": "CU000123",
        "email": "john@example.com"
      }
    }
  }
}