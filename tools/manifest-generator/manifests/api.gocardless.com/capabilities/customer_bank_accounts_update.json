{
  "name": "customer_bank_accounts_update",
  "description": "Update a customer bank account.",
  "resource_group": "customer_bank_accounts",
  "endpoint": "/customer_bank_accounts/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Bank account ID.",
      "required": true
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Updated metadata.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.gocardless.com/customer_bank_accounts/BA000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "customer_bank_accounts": {
        "metadata": {}
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer_bank_accounts": {
        "id": "BA000123"
      }
    }
  }
}