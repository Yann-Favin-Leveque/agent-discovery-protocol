{
  "name": "creditors_get",
  "description": "Retrieve a specific creditor.",
  "resource_group": "creditors",
  "endpoint": "/creditors/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Creditor ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/creditors/CR000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "creditors": {
        "id": "CR000123",
        "name": "My Company"
      }
    }
  }
}