{
  "name": "refunds_list",
  "description": "List all refunds.",
  "resource_group": "refunds",
  "endpoint": "/refunds",
  "method": "GET",
  "parameters": [
    {
      "name": "payment",
      "type": "string",
      "description": "Filter by payment.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/refunds",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refunds": [
        {
          "id": "RF000123"
        }
      ]
    }
  }
}