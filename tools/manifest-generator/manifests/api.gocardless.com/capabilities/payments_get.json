{
  "name": "payments_get",
  "description": "Retrieve details of a single payment.",
  "resource_group": "payments",
  "endpoint": "/payments/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payment ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/payments/PM000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payments": {
        "id": "PM000123",
        "status": "confirmed"
      }
    }
  }
}