{
  "name": "customers_list",
  "description": "List all customers.",
  "resource_group": "customers",
  "endpoint": "/customers",
  "method": "GET",
  "parameters": [
    {
      "name": "created_at[gte]",
      "type": "string",
      "description": "Filter by creation date.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/customers",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customers": [
        {
          "id": "CU000123"
        }
      ]
    }
  }
}