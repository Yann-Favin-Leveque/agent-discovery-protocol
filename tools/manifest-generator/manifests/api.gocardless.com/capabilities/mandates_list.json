{
  "name": "mandates_list",
  "description": "List all mandates.",
  "resource_group": "mandates",
  "endpoint": "/mandates",
  "method": "GET",
  "parameters": [
    {
      "name": "customer",
      "type": "string",
      "description": "Filter by customer.",
      "required": false,
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/mandates",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "mandates": [
        {
          "id": "MD000123"
        }
      ]
    }
  }
}
