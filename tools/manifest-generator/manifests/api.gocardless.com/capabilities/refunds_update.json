{
  "name": "refunds_update",
  "description": "Update a refund.",
  "resource_group": "refunds",
  "endpoint": "/refunds/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Refund ID.",
      "required": true
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Updated metadata.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.gocardless.com/refunds/RF000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "refunds": {
        "metadata": {}
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refunds": {
        "id": "RF000123"
      }
    }
  }
}