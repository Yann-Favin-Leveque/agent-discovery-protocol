{
  "name": "mandates_get",
  "description": "Retrieve a specific mandate.",
  "resource_group": "mandates",
  "endpoint": "/mandates/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Mandate ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/mandates/MD000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "mandates": {
        "id": "MD000123",
        "status": "active"
      }
    }
  }
}
