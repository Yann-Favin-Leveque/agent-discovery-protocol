{
  "name": "subscriptions_update",
  "description": "Update a subscription.",
  "resource_group": "subscriptions",
  "endpoint": "/subscriptions/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    },
    {
      "name": "amount",
      "type": "integer",
      "description": "Updated amount.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.gocardless.com/subscriptions/SB000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "subscriptions": {
        "name": "Updated plan"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriptions": {
        "id": "SB000123"
      }
    }
  }
}