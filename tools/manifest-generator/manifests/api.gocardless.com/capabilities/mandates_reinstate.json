{
  "name": "mandates_reinstate",
  "description": "Reinstate a cancelled mandate.",
  "resource_group": "mandates",
  "endpoint": "/mandates/{id}/actions/reinstate",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Mandate ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gocardless.com/mandates/MD000123/actions/reinstate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "data": {}
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "mandates": {
        "id": "MD000123",
        "status": "active"
      }
    }
  }
}
