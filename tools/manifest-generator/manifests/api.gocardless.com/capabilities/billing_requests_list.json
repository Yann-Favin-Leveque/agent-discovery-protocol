{
  "name": "billing_requests_list",
  "description": "List all billing requests.",
  "resource_group": "billing_requests",
  "endpoint": "/billing_requests",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/billing_requests",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "billing_requests": [
        {
          "id": "BRQ000123"
        }
      ]
    }
  }
}