{
  "name": "payments_cancel",
  "description": "Cancel a pending payment before it is submitted to the bank.",
  "resource_group": "payments",
  "endpoint": "/payments/{id}/actions/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payment ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gocardless.com/payments/PM000123/actions/cancel",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "data": {}
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payments": {
        "id": "PM000123",
        "status": "cancelled"
      }
    }
  }
}