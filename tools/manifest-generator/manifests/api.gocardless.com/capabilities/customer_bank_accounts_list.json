{
  "name": "customer_bank_accounts_list",
  "description": "List all customer bank accounts.",
  "resource_group": "customer_bank_accounts",
  "endpoint": "/customer_bank_accounts",
  "method": "GET",
  "parameters": [
    {
      "name": "customer",
      "type": "string",
      "description": "Filter by customer ID.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/customer_bank_accounts",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer_bank_accounts": [
        {
          "id": "BA000123"
        }
      ]
    }
  }
}
