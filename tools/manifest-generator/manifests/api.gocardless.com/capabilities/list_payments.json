{
  "name": "list_payments",
  "description": "List and filter all direct debit payments in your GoCardless account. Payments can be filtered by status, customer, mandate, or date range. Results are paginated with cursor-based navigation.",
  "endpoint": "/payments",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "description": "Filter by payment status: 'pending_customer_approval', 'pending_submission', 'submitted', 'confirmed', 'paid_out', 'cancelled', 'customer_approval_denied', 'failed', 'charged_back'.",
      "required": false,
      "example": "paid_out"
    },
    {
      "name": "customer",
      "type": "string",
      "description": "Filter by customer ID.",
      "required": false,
      "example": "CU000260S506AT"
    },
    {
      "name": "mandate",
      "type": "string",
      "description": "Filter by mandate ID.",
      "required": false,
      "example": "MD000AMA19XGEC"
    },
    {
      "name": "created_at[gte]",
      "type": "string",
      "description": "Filter payments created on or after this ISO 8601 date.",
      "required": false,
      "example": "2024-03-01T00:00:00Z"
    },
    {
      "name": "created_at[lte]",
      "type": "string",
      "description": "Filter payments created on or before this ISO 8601 date.",
      "required": false,
      "example": "2024-03-31T23:59:59Z"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of records to return per page. Default 50, max 500.",
      "required": false,
      "example": 50
    },
    {
      "name": "after",
      "type": "string",
      "description": "Cursor for pagination. Pass the ID from the last record of the previous page.",
      "required": false,
      "example": "PM000260S506AT"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/payments?status=paid_out&limit=50",
    "headers": {
      "Authorization": "Bearer your_access_token_here",
      "GoCardless-Version": "2015-07-06"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "payments": [
        {
          "id": "PM000260S506AT",
          "created_at": "2024-03-15T10:00:00.000Z",
          "charge_date": "2024-03-20",
          "amount": 5000,
          "currency": "GBP",
          "status": "paid_out",
          "reference": "ACME-1234",
          "description": "Invoice #1234",
          "metadata": { "invoice_id": "1234" },
          "links": {
            "mandate": "MD000AMA19XGEC",
            "creditor": "CR000035GKW1F7",
            "payout": "PO000260S506AT"
          }
        }
      ],
      "meta": {
        "cursors": {
          "before": null,
          "after": "PM000260S506AT"
        },
        "limit": 50
      }
    }
  }
}
