{
  "name": "customers_update",
  "description": "Update a customer record.",
  "resource_group": "customers",
  "endpoint": "/customers/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Updated email.",
      "required": false,
      "in": "body"
    },
    {
      "name": "given_name",
      "type": "string",
      "description": "Updated first name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.gocardless.com/customers/CU000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "customers": {
        "given_name": "Jane"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customers": {
        "id": "CU000123",
        "given_name": "Jane"
      }
    }
  }
}
