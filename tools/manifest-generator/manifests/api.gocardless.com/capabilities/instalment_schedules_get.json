{
  "name": "instalment_schedules_get",
  "description": "Retrieve a specific instalment schedule.",
  "resource_group": "instalment_schedules",
  "endpoint": "/instalment_schedules/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Instalment schedule ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/instalment_schedules/IS000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "instalment_schedules": {
        "id": "IS000123"
      }
    }
  }
}
