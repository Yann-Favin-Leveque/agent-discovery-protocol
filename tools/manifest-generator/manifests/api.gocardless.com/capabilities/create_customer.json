{
  "name": "create_customer",
  "description": "Create a new customer in GoCardless. Customers store the personal details of the person or company you are collecting payments from. After creating a customer, you can add their bank account details and set up mandates for direct debit collection.",
  "endpoint": "/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "The customer's email address.",
      "required": true,
      "example": "jane@example.com"
    },
    {
      "name": "given_name",
      "type": "string",
      "description": "The customer's first name.",
      "required": false,
      "example": "Jane"
    },
    {
      "name": "family_name",
      "type": "string",
      "description": "The customer's last name.",
      "required": false,
      "example": "Doe"
    },
    {
      "name": "company_name",
      "type": "string",
      "description": "The customer's company name (for business customers).",
      "required": false,
      "example": "Acme Ltd"
    },
    {
      "name": "address_line1",
      "type": "string",
      "description": "The first line of the customer's address.",
      "required": false,
      "example": "10 Downing Street"
    },
    {
      "name": "city",
      "type": "string",
      "description": "The customer's city.",
      "required": false,
      "example": "London"
    },
    {
      "name": "postal_code",
      "type": "string",
      "description": "The customer's postal or ZIP code.",
      "required": false,
      "example": "SW1A 2AA"
    },
    {
      "name": "country_code",
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code.",
      "required": false,
      "example": "GB"
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Key-value pairs to store custom data. Max 3 keys.",
      "required": false,
      "example": { "internal_id": "cust_789" }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gocardless.com/customers",
    "headers": {
      "Authorization": "Bearer your_access_token_here",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "customers": {
        "email": "jane@example.com",
        "given_name": "Jane",
        "family_name": "Doe",
        "address_line1": "10 Downing Street",
        "city": "London",
        "postal_code": "SW1A 2AA",
        "country_code": "GB",
        "metadata": { "internal_id": "cust_789" }
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "customers": {
        "id": "CU000260S506AT",
        "created_at": "2024-03-15T10:00:00.000Z",
        "email": "jane@example.com",
        "given_name": "Jane",
        "family_name": "Doe",
        "company_name": null,
        "address_line1": "10 Downing Street",
        "address_line2": null,
        "city": "London",
        "region": null,
        "postal_code": "SW1A 2AA",
        "country_code": "GB",
        "language": "en",
        "metadata": { "internal_id": "cust_789" }
      }
    }
  }
}
