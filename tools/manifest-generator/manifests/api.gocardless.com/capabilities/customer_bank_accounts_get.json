{
  "name": "customer_bank_accounts_get",
  "description": "Retrieve a customer bank account.",
  "resource_group": "customer_bank_accounts",
  "endpoint": "/customer_bank_accounts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Bank account ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/customer_bank_accounts/BA000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer_bank_accounts": {
        "id": "BA000123"
      }
    }
  }
}