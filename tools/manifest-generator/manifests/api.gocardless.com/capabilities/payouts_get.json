{
  "name": "payouts_get",
  "description": "Retrieve a specific payout.",
  "resource_group": "payouts",
  "endpoint": "/payouts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payout ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/payouts/PO000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payouts": {
        "id": "PO000123",
        "amount": 100000,
        "currency": "GBP"
      }
    }
  }
}