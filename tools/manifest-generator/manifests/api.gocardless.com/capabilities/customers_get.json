{
  "name": "customers_get",
  "description": "Retrieve a specific customer.",
  "resource_group": "customers",
  "endpoint": "/customers/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Customer ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/customers/CU000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customers": {
        "id": "CU000123"
      }
    }
  }
}