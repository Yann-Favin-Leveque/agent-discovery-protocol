{
  "name": "creditors_update",
  "description": "Update a creditor.",
  "resource_group": "creditors",
  "endpoint": "/creditors/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Creditor ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.gocardless.com/creditors/CR000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "creditors": {
        "name": "Updated Company"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "creditors": {
        "id": "CR000123",
        "name": "Updated Company"
      }
    }
  }
}