{
  "name": "instalment_schedules_list",
  "description": "List all instalment schedules.",
  "resource_group": "instalment_schedules",
  "endpoint": "/instalment_schedules",
  "method": "GET",
  "parameters": [
    {
      "name": "mandate",
      "type": "string",
      "description": "Filter by mandate.",
      "required": false,
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/instalment_schedules",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "instalment_schedules": [
        {
          "id": "IS000123"
        }
      ]
    }
  }
}
