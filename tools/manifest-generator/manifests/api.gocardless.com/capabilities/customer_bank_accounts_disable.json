{
  "name": "customer_bank_accounts_disable",
  "description": "Disable a customer bank account.",
  "resource_group": "customer_bank_accounts",
  "endpoint": "/customer_bank_accounts/{id}/actions/disable",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Bank account ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gocardless.com/customer_bank_accounts/BA000123/actions/disable",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "data": {}
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer_bank_accounts": {
        "id": "BA000123",
        "enabled": false
      }
    }
  }
}
