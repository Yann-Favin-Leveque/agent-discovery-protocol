{
  "name": "refunds_get",
  "description": "Retrieve a specific refund.",
  "resource_group": "refunds",
  "endpoint": "/refunds/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Refund ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/refunds/RF000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refunds": {
        "id": "RF000123"
      }
    }
  }
}
