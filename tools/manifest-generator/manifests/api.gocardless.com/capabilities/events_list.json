{
  "name": "events_list",
  "description": "List all events.",
  "resource_group": "events",
  "endpoint": "/events",
  "method": "GET",
  "parameters": [
    {
      "name": "resource_type",
      "type": "string",
      "description": "Filter by resource type.",
      "required": false,
      "in": "query"
    },
    {
      "name": "action",
      "type": "string",
      "description": "Filter by action.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/events",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "events": [
        {
          "id": "EV000123"
        }
      ]
    }
  }
}
