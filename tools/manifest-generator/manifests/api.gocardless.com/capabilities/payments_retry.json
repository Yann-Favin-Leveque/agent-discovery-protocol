{
  "name": "payments_retry",
  "description": "Retry a failed payment.",
  "resource_group": "payments",
  "endpoint": "/payments/{id}/actions/retry",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payment ID.",
      "required": true
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Updated metadata.",
      "required": false
    },
    {
      "name": "charge_date",
      "type": "string",
      "description": "New charge date.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gocardless.com/payments/PM000123/actions/retry",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "data": {}
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payments": {
        "id": "PM000123",
        "status": "pending_submission"
      }
    }
  }
}