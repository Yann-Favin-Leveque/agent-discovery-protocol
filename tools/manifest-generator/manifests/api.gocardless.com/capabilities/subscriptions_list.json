{
  "name": "subscriptions_list",
  "description": "List all subscriptions.",
  "resource_group": "subscriptions",
  "endpoint": "/subscriptions",
  "method": "GET",
  "parameters": [
    {
      "name": "mandate",
      "type": "string",
      "description": "Filter by mandate.",
      "required": false,
      "in": "query"
    },
    {
      "name": "customer",
      "type": "string",
      "description": "Filter by customer.",
      "required": false,
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/subscriptions",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriptions": [
        {
          "id": "SB000123"
        }
      ]
    }
  }
}
