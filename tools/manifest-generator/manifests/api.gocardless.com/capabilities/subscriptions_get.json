{
  "name": "subscriptions_get",
  "description": "Retrieve a specific subscription.",
  "resource_group": "subscriptions",
  "endpoint": "/subscriptions/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/subscriptions/SB000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriptions": {
        "id": "SB000123",
        "status": "active"
      }
    }
  }
}
