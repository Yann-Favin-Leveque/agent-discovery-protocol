{
  "name": "subscriptions_cancel",
  "description": "Cancel an active subscription.",
  "resource_group": "subscriptions",
  "endpoint": "/subscriptions/{id}/actions/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.gocardless.com/subscriptions/SB000123/actions/cancel",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "GoCardless-Version": "2015-07-06"
    },
    "body": {
      "data": {}
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriptions": {
        "id": "SB000123",
        "status": "cancelled"
      }
    }
  }
}