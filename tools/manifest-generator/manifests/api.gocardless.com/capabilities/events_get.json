{
  "name": "events_get",
  "description": "Retrieve a specific event.",
  "resource_group": "events",
  "endpoint": "/events/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Event ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.gocardless.com/events/EV000123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "GoCardless-Version": "2015-07-06"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "events": {
        "id": "EV000123",
        "resource_type": "payments",
        "action": "confirmed"
      }
    }
  }
}