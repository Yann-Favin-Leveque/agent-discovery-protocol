{
  "name": "fiat_map",
  "description": "Return a mapping of all supported fiat currencies to unique CoinMarketCap IDs.",
  "resource_group": "fiat",
  "endpoint": "/v1/fiat/map",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "description": "Offset.",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Results.",
      "required": false,
      "example": 100,
      "in": "query"
    },
    {
      "name": "sort",
      "type": "string",
      "description": "Sort: id or name.",
      "required": false,
      "example": "id",
      "in": "query"
    },
    {
      "name": "include_metals",
      "type": "boolean",
      "description": "Include precious metals.",
      "required": false,
      "example": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/fiat/map",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": [
        {
          "id": 2781,
          "name": "United States Dollar",
          "sign": "$",
          "symbol": "USD"
        }
      ]
    }
  }
}
