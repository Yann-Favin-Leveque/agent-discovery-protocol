{
  "name": "exchange_market_pairs",
  "description": "Return all active market pairs for a given exchange.",
  "resource_group": "exchange",
  "endpoint": "/v1/exchange/market-pairs/latest",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Exchange ID.",
      "required": false,
      "example": "270"
    },
    {
      "name": "slug",
      "type": "string",
      "description": "Exchange slug.",
      "required": false,
      "example": "binance"
    },
    {
      "name": "start",
      "type": "integer",
      "description": "Offset.",
      "required": false,
      "example": 1
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Results.",
      "required": false,
      "example": 10
    },
    {
      "name": "convert",
      "type": "string",
      "description": "Quote currency.",
      "required": false,
      "example": "USD"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/exchange/market-pairs/latest?slug=binance&limit=10",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": {
        "id": 270,
        "name": "Binance",
        "num_market_pairs": 1500,
        "market_pairs": []
      }
    }
  }
}