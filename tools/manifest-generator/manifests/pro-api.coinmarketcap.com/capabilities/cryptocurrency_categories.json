{
  "name": "cryptocurrency_categories",
  "description": "Return a paginated list of all cryptocurrency categories with token count, market cap, and volume.",
  "resource_group": "cryptocurrency",
  "endpoint": "/v1/cryptocurrency/categories",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "description": "Offset.",
      "required": false,
      "example": 1
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Results.",
      "required": false,
      "example": 10
    },
    {
      "name": "id",
      "type": "string",
      "description": "Filter by category ID.",
      "required": false
    },
    {
      "name": "slug",
      "type": "string",
      "description": "Filter by slug.",
      "required": false
    },
    {
      "name": "symbol",
      "type": "string",
      "description": "Filter by cryptocurrency symbol.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/cryptocurrency/categories?limit=10",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": [
        {
          "id": "6051a82566fc1b42617d6dc6",
          "name": "DeFi",
          "num_tokens": 500,
          "market_cap": 50000000000
        }
      ]
    }
  }
}