{
  "name": "key_info",
  "description": "Return API key details and usage statistics for the calling API key.",
  "resource_group": "key",
  "endpoint": "/v1/key/info",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/key/info",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": {
        "plan": {
          "credit_limit_daily": 333,
          "credit_limit_monthly": 10000
        },
        "usage": {
          "current_day": {
            "credits_used": 10
          }
        }
      }
    }
  }
}