{
  "name": "global_metrics_quotes_latest",
  "description": "Return the latest global aggregate cryptocurrency market metrics including total market cap and 24h volume.",
  "resource_group": "global_metrics",
  "endpoint": "/v1/global-metrics/quotes/latest",
  "method": "GET",
  "parameters": [
    {
      "name": "convert",
      "type": "string",
      "description": "Quote currency.",
      "required": false,
      "example": "USD",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/global-metrics/quotes/latest",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": {
        "active_cryptocurrencies": 10000,
        "quote": {
          "USD": {
            "total_market_cap": 2500000000000,
            "total_volume_24h": 80000000000
          }
        }
      }
    }
  }
}
