{
  "name": "cryptocurrency_listings_latest",
  "description": "Return a paginated list of all active cryptocurrencies with latest market data including price, market cap, and volume.",
  "resource_group": "cryptocurrency",
  "endpoint": "/v1/cryptocurrency/listings/latest",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "description": "Offset (1-based).",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Results (1-5000).",
      "required": false,
      "example": 100,
      "in": "query"
    },
    {
      "name": "price_min",
      "type": "number",
      "description": "Minimum USD price filter.",
      "required": false,
      "in": "query"
    },
    {
      "name": "price_max",
      "type": "number",
      "description": "Maximum USD price filter.",
      "required": false,
      "in": "query"
    },
    {
      "name": "market_cap_min",
      "type": "number",
      "description": "Minimum market cap filter.",
      "required": false,
      "in": "query"
    },
    {
      "name": "sort",
      "type": "string",
      "description": "Sort: market_cap, name, symbol, price, volume_24h, percent_change_24h.",
      "required": false,
      "example": "market_cap",
      "in": "query"
    },
    {
      "name": "sort_dir",
      "type": "string",
      "description": "Sort direction: asc or desc.",
      "required": false,
      "example": "desc",
      "in": "query"
    },
    {
      "name": "cryptocurrency_type",
      "type": "string",
      "description": "Type: all, coins, or tokens.",
      "required": false,
      "example": "all",
      "in": "query"
    },
    {
      "name": "convert",
      "type": "string",
      "description": "Quote currencies (comma-separated).",
      "required": false,
      "example": "USD",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/cryptocurrency/listings/latest?limit=10&convert=USD",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": [
        {
          "id": 1,
          "name": "Bitcoin",
          "symbol": "BTC",
          "cmc_rank": 1,
          "quote": {
            "USD": {
              "price": 65000,
              "market_cap": 1270000000000
            }
          }
        }
      ]
    }
  }
}
