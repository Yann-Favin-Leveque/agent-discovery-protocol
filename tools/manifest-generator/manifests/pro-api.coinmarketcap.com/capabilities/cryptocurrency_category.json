{
  "name": "cryptocurrency_category",
  "description": "Return metadata and list of cryptocurrencies for a single category by ID.",
  "resource_group": "cryptocurrency",
  "endpoint": "/v1/cryptocurrency/category",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The category ID.",
      "required": true,
      "example": "6051a82566fc1b42617d6dc6"
    },
    {
      "name": "start",
      "type": "integer",
      "description": "Offset.",
      "required": false,
      "example": 1
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Results.",
      "required": false,
      "example": 10
    },
    {
      "name": "convert",
      "type": "string",
      "description": "Quote currency.",
      "required": false,
      "example": "USD"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/cryptocurrency/category?id=6051a82566fc1b42617d6dc6",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": {
        "id": "6051a82566fc1b42617d6dc6",
        "name": "DeFi",
        "num_tokens": 500,
        "coins": []
      }
    }
  }
}