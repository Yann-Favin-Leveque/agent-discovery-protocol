{
  "name": "cryptocurrency_listings_new",
  "description": "Return a paginated list of the most recently added cryptocurrencies on CoinMarketCap.",
  "resource_group": "cryptocurrency",
  "endpoint": "/v1/cryptocurrency/listings/new",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "description": "Offset.",
      "required": false,
      "example": 1
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Results (1-5000).",
      "required": false,
      "example": 10
    },
    {
      "name": "convert",
      "type": "string",
      "description": "Quote currency.",
      "required": false,
      "example": "USD"
    },
    {
      "name": "sort_dir",
      "type": "string",
      "description": "Sort direction: asc or desc.",
      "required": false,
      "example": "desc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/cryptocurrency/listings/new?limit=10",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": [
        {
          "id": 28301,
          "name": "NewCoin",
          "symbol": "NEW",
          "date_added": "2024-01-15T00:00:00.000Z"
        }
      ]
    }
  }
}