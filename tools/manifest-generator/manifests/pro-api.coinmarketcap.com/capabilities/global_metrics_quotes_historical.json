{
  "name": "global_metrics_quotes_historical",
  "description": "Return historical global aggregate cryptocurrency market metrics over a time period.",
  "resource_group": "global_metrics",
  "endpoint": "/v1/global-metrics/quotes/historical",
  "method": "GET",
  "parameters": [
    {
      "name": "time_start",
      "type": "string",
      "description": "Start (ISO 8601).",
      "required": false,
      "example": "2024-01-01"
    },
    {
      "name": "time_end",
      "type": "string",
      "description": "End (ISO 8601).",
      "required": false,
      "example": "2024-01-31"
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Number of intervals.",
      "required": false,
      "example": 10
    },
    {
      "name": "interval",
      "type": "string",
      "description": "Interval: daily, weekly, monthly.",
      "required": false,
      "example": "daily"
    },
    {
      "name": "convert",
      "type": "string",
      "description": "Quote currency.",
      "required": false,
      "example": "USD"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/global-metrics/quotes/historical?time_start=2024-01-01&time_end=2024-01-31",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": {
        "quotes": []
      }
    }
  }
}