{
  "name": "exchange_info",
  "description": "Return static metadata for one or more exchanges including name, logo, website, and launch date.",
  "resource_group": "exchange",
  "endpoint": "/v1/exchange/info",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Exchange IDs (comma-separated).",
      "required": false,
      "example": "270"
    },
    {
      "name": "slug",
      "type": "string",
      "description": "Exchange slugs (comma-separated).",
      "required": false,
      "example": "binance"
    },
    {
      "name": "aux",
      "type": "string",
      "description": "Supplemental fields.",
      "required": false,
      "example": "urls,logo,description"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/exchange/info?slug=binance",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": {
        "270": {
          "id": 270,
          "name": "Binance",
          "slug": "binance"
        }
      }
    }
  }
}