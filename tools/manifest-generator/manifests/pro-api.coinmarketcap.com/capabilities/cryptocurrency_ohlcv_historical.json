{
  "name": "cryptocurrency_ohlcv_historical",
  "description": "Return historical OHLCV data for a cryptocurrency over a given time period.",
  "resource_group": "cryptocurrency",
  "endpoint": "/v1/cryptocurrency/ohlcv/historical",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "CoinMarketCap ID.",
      "required": false,
      "example": "1",
      "in": "query"
    },
    {
      "name": "symbol",
      "type": "string",
      "description": "Symbol.",
      "required": false,
      "example": "BTC",
      "in": "query"
    },
    {
      "name": "time_period",
      "type": "string",
      "description": "Time period: daily, hourly.",
      "required": false,
      "example": "daily",
      "in": "query"
    },
    {
      "name": "time_start",
      "type": "string",
      "description": "Start date (ISO 8601).",
      "required": false,
      "example": "2024-01-01",
      "in": "query"
    },
    {
      "name": "time_end",
      "type": "string",
      "description": "End date (ISO 8601).",
      "required": false,
      "example": "2024-01-31",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "description": "Intervals (1-10000).",
      "required": false,
      "example": 30,
      "in": "query"
    },
    {
      "name": "interval",
      "type": "string",
      "description": "Interval: daily, weekly, monthly.",
      "required": false,
      "example": "daily",
      "in": "query"
    },
    {
      "name": "convert",
      "type": "string",
      "description": "Quote currency.",
      "required": false,
      "example": "USD",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://pro-api.coinmarketcap.com/v1/cryptocurrency/ohlcv/historical?symbol=BTC&time_start=2024-01-01&time_end=2024-01-31",
    "headers": {
      "X-CMC_PRO_API_KEY": "{api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": {
        "error_code": 0
      },
      "data": {
        "id": 1,
        "name": "Bitcoin",
        "quotes": [
          {
            "time_open": "2024-01-01",
            "quote": {
              "USD": {
                "open": 42000,
                "high": 43000,
                "low": 41500,
                "close": 42500,
                "volume": 20000000000
              }
            }
          }
        ]
      }
    }
  }
}
