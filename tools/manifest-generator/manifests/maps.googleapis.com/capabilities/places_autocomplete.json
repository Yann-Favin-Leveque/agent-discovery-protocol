{
  "name": "places_autocomplete",
  "description": "Get place predictions as the user types. Returns autocomplete suggestions with place IDs for addresses, businesses, and points of interest.",
  "endpoint": "/maps/api/place/autocomplete/json",
  "method": "GET",
  "resource_group": "places",
  "parameters": [
    {
      "name": "input",
      "type": "string",
      "description": "Text input for autocomplete predictions.",
      "required": true,
      "example": "Googleplex",
      "in": "query"
    },
    {
      "name": "key",
      "type": "string",
      "description": "Google Maps API key.",
      "required": true,
      "example": "AIzaSy...",
      "in": "query"
    },
    {
      "name": "types",
      "type": "string",
      "description": "Restrict results by place type (e.g., geocode, address, establishment). Pipe-separated, max 5.",
      "required": false,
      "example": "establishment",
      "in": "query"
    },
    {
      "name": "components",
      "type": "string",
      "description": "Country filter using ISO 3166-1 Alpha-2 codes (e.g., country:us). Pipe-separated, max 5.",
      "required": false,
      "example": "country:us",
      "in": "query"
    },
    {
      "name": "location",
      "type": "string",
      "description": "Location bias as latitude,longitude.",
      "required": false,
      "example": "37.7749,-122.4194",
      "in": "query"
    },
    {
      "name": "radius",
      "type": "integer",
      "description": "Radius in meters for location bias.",
      "required": false,
      "example": 5000,
      "in": "query"
    },
    {
      "name": "strictbounds",
      "type": "boolean",
      "description": "Restrict results strictly within the location/radius bounds.",
      "required": false,
      "example": false,
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Character position in input for matching.",
      "required": false,
      "example": 3,
      "in": "query"
    },
    {
      "name": "language",
      "type": "string",
      "description": "Language for results.",
      "required": false,
      "example": "en",
      "in": "query"
    },
    {
      "name": "sessiontoken",
      "type": "string",
      "description": "Session token for billing optimization.",
      "required": false,
      "example": "",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://maps.googleapis.com/maps/api/place/autocomplete/json?input=Googleplex&types=establishment&key=AIzaSy...",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "predictions": [
        {
          "description": "Googleplex, Amphitheatre Parkway, Mountain View, CA, USA",
          "place_id": "ChIJj61dQgK6j4AR4GeTYWZsKWw",
          "structured_formatting": {
            "main_text": "Googleplex",
            "secondary_text": "Amphitheatre Parkway, Mountain View, CA, USA"
          },
          "types": [
            "establishment",
            "point_of_interest"
          ]
        }
      ],
      "status": "OK"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 3000
  }
}
