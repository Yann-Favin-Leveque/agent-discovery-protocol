{
  "spec_version": "1.0",
  "name": "SurveyMonkey",
  "description": "SurveyMonkey is an online survey platform. Use this API to create and manage surveys, collect responses, manage collectors, and handle contacts for survey distribution.",
  "base_url": "https://api.surveymonkey.com",
  "auth": {
    "type": "oauth2",
    "authorization_url": "https://api.surveymonkey.com/oauth/authorize",
    "token_url": "https://api.surveymonkey.com/oauth/token",
    "scopes": [
      "surveys_read",
      "surveys_write",
      "responses_read",
      "responses_write",
      "collectors_read",
      "collectors_write",
      "contacts_read",
      "contacts_write",
      "users_read"
    ]
  },
  "capabilities": [
    {
      "name": "surveys_list",
      "resource_group": "surveys",
      "description": "List surveys.",
      "detail_url": "/capabilities/surveys_list"
    },
    {
      "name": "surveys_create",
      "resource_group": "surveys",
      "description": "Create a survey.",
      "detail_url": "/capabilities/surveys_create"
    },
    {
      "name": "surveys_get",
      "resource_group": "surveys",
      "description": "Get survey details.",
      "detail_url": "/capabilities/surveys_get"
    },
    {
      "name": "surveys_get_details",
      "resource_group": "surveys",
      "description": "Get full survey with pages and questions.",
      "detail_url": "/capabilities/surveys_get_details"
    },
    {
      "name": "surveys_update",
      "resource_group": "surveys",
      "description": "Update a survey.",
      "detail_url": "/capabilities/surveys_update"
    },
    {
      "name": "surveys_delete",
      "resource_group": "surveys",
      "description": "Delete a survey.",
      "detail_url": "/capabilities/surveys_delete"
    },
    {
      "name": "responses_list",
      "resource_group": "responses",
      "description": "List survey responses.",
      "detail_url": "/capabilities/responses_list"
    },
    {
      "name": "responses_list_bulk",
      "resource_group": "responses",
      "description": "List full expanded responses.",
      "detail_url": "/capabilities/responses_list_bulk"
    },
    {
      "name": "responses_get",
      "resource_group": "responses",
      "description": "Get a single response.",
      "detail_url": "/capabilities/responses_get"
    },
    {
      "name": "responses_create",
      "resource_group": "responses",
      "description": "Create a response.",
      "detail_url": "/capabilities/responses_create"
    },
    {
      "name": "collectors_list",
      "resource_group": "collectors",
      "description": "List survey collectors.",
      "detail_url": "/capabilities/collectors_list"
    },
    {
      "name": "collectors_create",
      "resource_group": "collectors",
      "description": "Create a collector.",
      "detail_url": "/capabilities/collectors_create"
    },
    {
      "name": "collectors_get",
      "resource_group": "collectors",
      "description": "Get collector details.",
      "detail_url": "/capabilities/collectors_get"
    },
    {
      "name": "collectors_update",
      "resource_group": "collectors",
      "description": "Update a collector.",
      "detail_url": "/capabilities/collectors_update"
    },
    {
      "name": "collectors_delete",
      "resource_group": "collectors",
      "description": "Delete a collector.",
      "detail_url": "/capabilities/collectors_delete"
    },
    {
      "name": "users_get_me",
      "resource_group": "users",
      "description": "Get current user details.",
      "detail_url": "/capabilities/users_get_me"
    },
    {
      "name": "survey_categories_list",
      "resource_group": "surveys",
      "description": "List survey categories.",
      "detail_url": "/capabilities/survey_categories_list"
    },
    {
      "name": "survey_templates_list",
      "resource_group": "surveys",
      "description": "List survey templates.",
      "detail_url": "/capabilities/survey_templates_list"
    }
  ]
}