{
  "name": "surveys_list",
  "resource_group": "surveys",
  "description": "List surveys owned or shared with the user.",
  "endpoint": "/v3/surveys",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Page number."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    },
    {
      "name": "sort_by",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Sort: title, date_modified, num_responses."
    },
    {
      "name": "sort_order",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "ASC or DESC."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Search by title."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/surveys?page=1&per_page=50",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "123456",
          "title": "Customer Survey",
          "nickname": "Q4 Survey"
        }
      ],
      "per_page": 50,
      "page": 1,
      "total": 10
    }
  }
}