{
  "name": "surveys_get_details",
  "resource_group": "surveys",
  "description": "Get expanded survey with all pages, questions, and answer choices.",
  "endpoint": "/v3/surveys/{id}/details",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Survey ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/surveys/123456/details",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "123456",
      "title": "Customer Survey",
      "pages": [
        {
          "id": "p1",
          "questions": [
            {
              "id": "q1",
              "headings": [
                {
                  "heading": "How satisfied are you?"
                }
              ]
            }
          ]
        }
      ]
    }
  }
}