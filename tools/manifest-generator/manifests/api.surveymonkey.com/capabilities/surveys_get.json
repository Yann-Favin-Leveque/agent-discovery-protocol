{
  "name": "surveys_get",
  "resource_group": "surveys",
  "description": "Get survey metadata.",
  "endpoint": "/v3/surveys/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Survey ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/surveys/123456",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "123456",
      "title": "Customer Survey",
      "question_count": 10,
      "response_count": 50
    }
  }
}