{
  "name": "survey_categories_list",
  "resource_group": "surveys",
  "description": "List survey categories for filtering templates.",
  "endpoint": "/v3/survey_categories",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Page number."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/survey_categories",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "name": "customer_feedback",
          "id": "cat-1"
        }
      ]
    }
  }
}