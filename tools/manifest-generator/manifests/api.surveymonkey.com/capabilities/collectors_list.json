{
  "name": "collectors_list",
  "resource_group": "collectors",
  "description": "List collectors for a survey.",
  "endpoint": "/v3/surveys/{survey_id}/collectors",
  "method": "GET",
  "parameters": [
    {
      "name": "survey_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Survey ID."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Page number."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/surveys/123456/collectors",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "coll-123",
          "name": "Web Link",
          "type": "weblink",
          "status": "open"
        }
      ]
    }
  }
}