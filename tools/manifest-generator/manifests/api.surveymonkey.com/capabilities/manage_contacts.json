{
  "name": "manage_contacts",
  "description": "Create and manage contact lists for survey distribution. Contacts can be organized into groups and used with email collectors.",
  "endpoint": "/v3/contact_lists",
  "method": "GET",
  "parameters": [
    { "name": "page", "type": "number", "description": "Page number.", "required": false, "example": 1 },
    { "name": "per_page", "type": "number", "description": "Results per page.", "required": false, "example": 50 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/contact_lists",
    "headers": { "Authorization": "Bearer {access_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        { "id": "cl_123", "name": "Customers Q1 2024", "member_count": 250 }
      ]
    }
  }
}
