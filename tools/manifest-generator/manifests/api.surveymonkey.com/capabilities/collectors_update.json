{
  "name": "collectors_update",
  "resource_group": "collectors",
  "description": "Update a collector.",
  "endpoint": "/v3/collectors/{collector_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "collector_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Collector ID."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "New name."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "open, closed, or new."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.surveymonkey.com/v3/collectors/coll-123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "status": "closed"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "coll-123",
      "status": "closed"
    }
  }
}