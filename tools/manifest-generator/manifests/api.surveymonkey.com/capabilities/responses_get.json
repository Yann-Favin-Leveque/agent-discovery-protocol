{
  "name": "responses_get",
  "resource_group": "responses",
  "description": "Get a single response with all details.",
  "endpoint": "/v3/surveys/{survey_id}/responses/{response_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "survey_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Survey ID."
    },
    {
      "name": "response_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Response ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/surveys/123456/responses/resp-1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "resp-1",
      "response_status": "completed",
      "pages": []
    }
  }
}