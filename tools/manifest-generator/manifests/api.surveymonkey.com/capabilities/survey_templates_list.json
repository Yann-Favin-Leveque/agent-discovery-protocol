{
  "name": "survey_templates_list",
  "resource_group": "surveys",
  "description": "List available survey templates.",
  "endpoint": "/v3/survey_templates",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Page number."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "in": "query",
      "description": "Results per page."
    },
    {
      "name": "category",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Filter by category."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/survey_templates",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "tmpl-1",
          "title": "Customer Satisfaction",
          "category": "customer_feedback"
        }
      ]
    }
  }
}