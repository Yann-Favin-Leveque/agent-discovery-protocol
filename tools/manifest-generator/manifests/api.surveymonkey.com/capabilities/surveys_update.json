{
  "name": "surveys_update",
  "resource_group": "surveys",
  "description": "Update survey title, nickname, or language.",
  "endpoint": "/v3/surveys/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Survey ID."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "New title."
    },
    {
      "name": "nickname",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "New nickname."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.surveymonkey.com/v3/surveys/123456",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Updated Survey"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "123456",
      "title": "Updated Survey"
    }
  }
}