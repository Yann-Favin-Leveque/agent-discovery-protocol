{
  "name": "surveys_create",
  "resource_group": "surveys",
  "description": "Create a new survey.",
  "endpoint": "/v3/surveys",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Survey title. Default: New Survey."
    },
    {
      "name": "from_template_id",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Template to copy from."
    },
    {
      "name": "from_survey_id",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Survey to copy from."
    },
    {
      "name": "nickname",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Internal nickname."
    },
    {
      "name": "language",
      "type": "string",
      "required": false,
      "in": "body",
      "description": "Survey language."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.surveymonkey.com/v3/surveys",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "New Survey"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "789012",
      "title": "New Survey"
    }
  }
}