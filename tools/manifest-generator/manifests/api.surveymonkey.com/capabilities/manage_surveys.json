{
  "name": "manage_surveys",
  "description": "Create, list, update, and delete surveys. You can create surveys from scratch or from templates, and manage their settings and status.",
  "endpoint": "/v3/surveys",
  "method": "GET",
  "parameters": [
    { "name": "page", "type": "number", "description": "Page number.", "required": false, "example": 1 },
    { "name": "per_page", "type": "number", "description": "Results per page.", "required": false, "example": 50 },
    { "name": "sort_by", "type": "string", "description": "Sort field: title, date_modified, num_responses.", "required": false, "example": "date_modified" },
    { "name": "sort_order", "type": "string", "description": "Sort direction: ASC or DESC.", "required": false, "example": "DESC" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/surveys?per_page=50",
    "headers": { "Authorization": "Bearer {access_token}", "Content-Type": "application/json" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        { "id": "123456789", "title": "Customer Satisfaction Survey", "nickname": "", "href": "https://api.surveymonkey.com/v3/surveys/123456789", "response_count": 42 }
      ],
      "per_page": 50,
      "page": 1,
      "total": 5
    }
  }
}
