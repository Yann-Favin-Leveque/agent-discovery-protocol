{
  "name": "collectors_get",
  "resource_group": "collectors",
  "description": "Get collector details.",
  "endpoint": "/v3/collectors/{collector_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "collector_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Collector ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.surveymonkey.com/v3/collectors/coll-123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "coll-123",
      "name": "Web Link",
      "type": "weblink",
      "status": "open"
    }
  }
}