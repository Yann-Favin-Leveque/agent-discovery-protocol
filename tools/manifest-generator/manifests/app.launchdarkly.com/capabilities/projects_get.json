{
  "name": "projects_get",
  "description": "Retrieve a specific project by key including its environments.",
  "resource_group": "projects",
  "endpoint": "/projects/{projectKey}",
  "method": "GET",
  "parameters": [
    {"name": "projectKey", "type": "string", "description": "The project key.", "required": true, "example": "my-project"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.launchdarkly.com/api/v2/projects/my-project",
    "headers": {"Authorization": "{api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"key": "my-project", "name": "My Project", "environments": {"production": {"key": "production", "name": "Production"}, "test": {"key": "test", "name": "Test"}}}
  },
  "rate_limits": {"requests_per_minute": 120}
}