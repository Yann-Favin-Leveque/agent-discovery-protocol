{
  "name": "segments_delete",
  "description": "Delete a segment.",
  "resource_group": "segments",
  "endpoint": "/segments/{projectKey}/{envKey}/{segmentKey}",
  "method": "DELETE",
  "parameters": [
    {"name": "projectKey", "type": "string", "description": "The project key.", "required": true, "example": "my-project"},
    {"name": "envKey", "type": "string", "description": "The environment key.", "required": true, "example": "production"},
    {"name": "segmentKey", "type": "string", "description": "The segment key to delete.", "required": true, "example": "old-segment"}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://app.launchdarkly.com/api/v2/segments/my-project/production/old-segment",
    "headers": {"Authorization": "{api_key}"}
  },
  "response_example": {"status": 204, "body": {}},
  "rate_limits": {"requests_per_minute": 120}
}