{
  "name": "environments_delete",
  "description": "Delete an environment from a project.",
  "resource_group": "environments",
  "endpoint": "/projects/{projectKey}/environments/{envKey}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "projectKey",
      "type": "string",
      "description": "The project key.",
      "required": true,
      "example": "my-project",
      "in": "path"
    },
    {
      "name": "envKey",
      "type": "string",
      "description": "The environment key to delete.",
      "required": true,
      "example": "old-env",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://app.launchdarkly.com/api/v2/projects/my-project/environments/old-env",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "rate_limits": {
    "requests_per_minute": 120
  }
}
