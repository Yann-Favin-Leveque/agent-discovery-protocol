{
  "name": "flags_delete",
  "description": "Delete a feature flag from a project. This is irreversible.",
  "resource_group": "flags",
  "endpoint": "/flags/{projectKey}/{flagKey}",
  "method": "DELETE",
  "parameters": [
    {"name": "projectKey", "type": "string", "description": "The project key.", "required": true, "example": "my-project"},
    {"name": "flagKey", "type": "string", "description": "The feature flag key to delete.", "required": true, "example": "old-feature"}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://app.launchdarkly.com/api/v2/flags/my-project/old-feature",
    "headers": {"Authorization": "{api_key}"}
  },
  "response_example": {"status": 204, "body": {}},
  "rate_limits": {"requests_per_minute": 120}
}