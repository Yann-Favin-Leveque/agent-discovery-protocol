{
  "name": "projects_list",
  "description": "List all projects in the LaunchDarkly account.",
  "resource_group": "projects",
  "endpoint": "/projects",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results to return.",
      "required": false,
      "example": 20,
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "example": 0,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.launchdarkly.com/api/v2/projects",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "key": "my-project",
          "name": "My Project",
          "tags": []
        }
      ],
      "totalCount": 3
    }
  },
  "rate_limits": {
    "requests_per_minute": 120
  }
}
