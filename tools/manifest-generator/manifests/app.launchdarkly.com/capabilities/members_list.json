{
  "name": "members_list",
  "description": "List all account members.",
  "resource_group": "members",
  "endpoint": "/members",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "example": 20,
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.launchdarkly.com/api/v2/members",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "_id": "mem_123",
          "email": "dev@example.com",
          "role": "writer",
          "firstName": "Jane",
          "lastName": "Doe"
        }
      ],
      "totalCount": 10
    }
  },
  "rate_limits": {
    "requests_per_minute": 120
  }
}
