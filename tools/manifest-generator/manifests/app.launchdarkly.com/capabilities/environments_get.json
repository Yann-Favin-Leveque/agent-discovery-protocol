{
  "name": "environments_get",
  "description": "Retrieve a specific environment by key.",
  "resource_group": "environments",
  "endpoint": "/projects/{projectKey}/environments/{envKey}",
  "method": "GET",
  "parameters": [
    {
      "name": "projectKey",
      "type": "string",
      "description": "The project key.",
      "required": true,
      "example": "my-project",
      "in": "path"
    },
    {
      "name": "envKey",
      "type": "string",
      "description": "The environment key.",
      "required": true,
      "example": "production",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.launchdarkly.com/api/v2/projects/my-project/environments/production",
    "headers": {
      "Authorization": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "key": "production",
      "name": "Production",
      "color": "417505",
      "apiKey": "sdk-prod-xxxxx"
    }
  },
  "rate_limits": {
    "requests_per_minute": 120
  }
}
