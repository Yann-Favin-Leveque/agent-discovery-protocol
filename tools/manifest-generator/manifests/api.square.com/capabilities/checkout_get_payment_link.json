{
  "name": "checkout_get_payment_link",
  "description": "Retrieve a specific payment link by ID.",
  "endpoint": "/v2/online-checkout/payment-links/{id}",
  "method": "GET",
  "resource_group": "checkout",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payment link ID",
      "required": true,
      "example": "link_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/online-checkout/payment-links/link_abc",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payment_link": {
        "id": "link_abc",
        "url": "https://square.link/u/abc123"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
