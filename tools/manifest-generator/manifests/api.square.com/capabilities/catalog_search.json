{
  "name": "catalog_search",
  "description": "Search catalog objects by name, attribute values, or custom queries.",
  "endpoint": "/v2/catalog/search",
  "method": "POST",
  "resource_group": "catalog",
  "parameters": [
    {
      "name": "object_types",
      "type": "array",
      "description": "Types to search",
      "required": false,
      "example": [
        "ITEM"
      ]
    },
    {
      "name": "query",
      "type": "object",
      "description": "Search query",
      "required": false,
      "example": {
        "text_query": {
          "keywords": [
            "coffee"
          ]
        }
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/catalog/search",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "object_types": [
        "ITEM"
      ],
      "query": {
        "text_query": {
          "keywords": [
            "coffee"
          ]
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "objects": [
        {
          "type": "ITEM",
          "id": "item_123",
          "item_data": {
            "name": "Coffee"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}