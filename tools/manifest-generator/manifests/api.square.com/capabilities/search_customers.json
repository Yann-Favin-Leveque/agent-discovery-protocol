{
  "name": "search_customers",
  "description": "Search and retrieve customers by name, email, phone number, or other criteria. Supports complex filtering and pagination.",
  "endpoint": "/v2/customers/search",
  "method": "POST",
  "parameters": [
    {
      "name": "query",
      "type": "object",
      "description": "Search criteria with filter and sort fields. Supports filtering by name, phone, email, creation date, and more.",
      "required": false,
      "example": {"filter": {"name_filter": {"exact": "John Doe"}}}
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Optional. Maximum number of results to return (1-100, default 10).",
      "required": false,
      "example": 25
    },
    {
      "name": "cursor",
      "type": "string",
      "description": "Optional. Pagination cursor for retrieving the next page of results.",
      "required": false,
      "example": "cursor_token_here"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/customers/search",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": {
        "filter": {
          "creation_source_filter": {
            "values": ["MANUAL"]
          }
        }
      },
      "limit": 25
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customers": [
        {
          "id": "CUST12345",
          "given_name": "John",
          "family_name": "Doe",
          "email_address": "john.doe@example.com",
          "phone_number": "+1-555-123-4567",
          "created_at": "2026-03-01T10:30:00Z",
          "updated_at": "2026-03-01T10:30:00Z"
        },
        {
          "id": "CUST67890",
          "given_name": "Jane",
          "family_name": "Smith",
          "email_address": "jane.smith@example.com",
          "phone_number": "+1-555-987-6543",
          "created_at": "2026-02-28T15:45:00Z",
          "updated_at": "2026-02-28T15:45:00Z"
        }
      ],
      "cursor": "next_cursor_token"
    }
  }
}
