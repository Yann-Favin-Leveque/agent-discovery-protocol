{
  "name": "customers_update",
  "description": "Update a customer profile.",
  "endpoint": "/v2/customers/{customer_id}",
  "method": "PUT",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "Customer ID",
      "required": true,
      "example": "cust_789"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://connect.squareup.com/v2/customers/cust_789",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "newemail@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer": {
        "id": "cust_789",
        "email_address": "newemail@example.com"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}