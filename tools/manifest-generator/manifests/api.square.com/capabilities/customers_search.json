{
  "name": "customers_search",
  "description": "Search customer profiles by name, email, phone, or custom filters.",
  "endpoint": "/v2/customers/search",
  "method": "POST",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "query",
      "type": "object",
      "description": "Search query with filters and sorting",
      "required": true,
      "example": {
        "filter": {
          "email_address": {
            "exact": "john@example.com"
          }
        }
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/customers/search",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": {
        "filter": {
          "email_address": {
            "exact": "john@example.com"
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customers": [
        {
          "id": "cust_789",
          "email_address": "john@example.com"
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
