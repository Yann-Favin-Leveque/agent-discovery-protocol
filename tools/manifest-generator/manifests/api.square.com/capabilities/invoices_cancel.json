{
  "name": "invoices_cancel",
  "description": "Cancel a published invoice.",
  "endpoint": "/v2/invoices/{invoice_id}/cancel",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "Invoice ID to cancel",
      "required": true,
      "example": "inv_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/invoices/inv_abc/cancel",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "version": 2
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "invoice": {
        "id": "inv_abc",
        "status": "CANCELED"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
