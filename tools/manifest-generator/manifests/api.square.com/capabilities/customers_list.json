{
  "name": "customers_list",
  "description": "List all customer profiles.",
  "endpoint": "/v2/customers",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "cursor",
      "type": "string",
      "description": "Pagination cursor",
      "required": false,
      "example": "",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results per page",
      "required": false,
      "example": 100,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/customers",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customers": [
        {
          "id": "cust_789",
          "given_name": "John",
          "family_name": "Doe"
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
