{
  "name": "refunds_create",
  "description": "Issue a refund for a completed payment.",
  "endpoint": "/v2/refunds",
  "method": "POST",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "payment_id",
      "type": "string",
      "description": "Original payment ID to refund",
      "required": true,
      "example": "pay_123"
    },
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key for idempotency",
      "required": true,
      "example": "refund-key-123"
    },
    {
      "name": "amount_money",
      "type": "object",
      "description": "Refund amount",
      "required": true,
      "example": {
        "amount": 50,
        "currency": "USD"
      }
    },
    {
      "name": "reason",
      "type": "string",
      "description": "Reason for refund",
      "required": false,
      "example": "Customer returned item"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/refunds",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "payment_id": "pay_123",
      "idempotency_key": "refund-key-123",
      "amount_money": {
        "amount": 50,
        "currency": "USD"
      },
      "reason": "Customer returned item"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refund": {
        "id": "ref_456",
        "status": "PENDING",
        "amount_money": {
          "amount": 50,
          "currency": "USD"
        }
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}