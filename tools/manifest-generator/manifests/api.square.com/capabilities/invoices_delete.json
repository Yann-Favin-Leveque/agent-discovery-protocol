{
  "name": "invoices_delete",
  "description": "Delete a draft invoice.",
  "endpoint": "/v2/invoices/{invoice_id}",
  "method": "DELETE",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "Invoice ID to delete",
      "required": true,
      "example": "inv_abc"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://connect.squareup.com/v2/invoices/inv_abc?version=1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}