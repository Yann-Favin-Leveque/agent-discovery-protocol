{
  "name": "refunds_get",
  "description": "Retrieve a specific refund by ID.",
  "endpoint": "/v2/refunds/{refund_id}",
  "method": "GET",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "refund_id",
      "type": "string",
      "description": "Refund ID",
      "required": true,
      "example": "ref_456",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/refunds/ref_456",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refund": {
        "id": "ref_456",
        "status": "COMPLETED",
        "amount_money": {
          "amount": 50,
          "currency": "USD"
        }
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
