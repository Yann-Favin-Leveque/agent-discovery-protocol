{
  "name": "orders_pay",
  "description": "Pay for an order with one or more payment IDs.",
  "endpoint": "/v2/orders/{order_id}/pay",
  "method": "POST",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "order_id",
      "type": "string",
      "description": "Order ID to pay",
      "required": true,
      "example": "order_abc"
    },
    {
      "name": "payment_ids",
      "type": "array",
      "description": "Payment IDs to apply",
      "required": true,
      "example": [
        "pay_123"
      ]
    },
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key",
      "required": true,
      "example": "pay-order-key"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/orders/order_abc/pay",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "idempotency_key": "pay-order-key",
      "payment_ids": [
        "pay_123"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "id": "order_abc",
        "state": "COMPLETED"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}