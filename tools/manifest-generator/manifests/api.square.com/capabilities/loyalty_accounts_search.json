{
  "name": "loyalty_accounts_search",
  "description": "Search loyalty accounts by phone number, customer ID, or other criteria.",
  "endpoint": "/v2/loyalty/accounts/search",
  "method": "POST",
  "resource_group": "loyalty",
  "parameters": [
    {
      "name": "query",
      "type": "object",
      "description": "Search query",
      "required": true,
      "example": {
        "mappings": [
          {
            "phone_number": "+15551234567"
          }
        ]
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/loyalty/accounts/search",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": {
        "mappings": [
          {
            "phone_number": "+15551234567"
          }
        ]
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "loyalty_accounts": [
        {
          "id": "loyalty_abc",
          "balance": 150
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
