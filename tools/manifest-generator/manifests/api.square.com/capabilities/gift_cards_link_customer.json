{
  "name": "gift_cards_link_customer",
  "description": "Link a customer to a gift card.",
  "endpoint": "/v2/gift-cards/{gift_card_id}/link-customer",
  "method": "POST",
  "resource_group": "gift_cards",
  "parameters": [
    {
      "name": "gift_card_id",
      "type": "string",
      "description": "Gift card ID",
      "required": true,
      "example": "gc_abc"
    },
    {
      "name": "customer_id",
      "type": "string",
      "description": "Customer ID to link",
      "required": true,
      "example": "cust_789"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/gift-cards/gc_abc/link-customer",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "customer_id": "cust_789"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "gift_card": {
        "id": "gc_abc",
        "customer_ids": [
          "cust_789"
        ]
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}