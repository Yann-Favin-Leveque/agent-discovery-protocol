{
  "name": "payments_create",
  "description": "Process a payment using a payment source (card nonce, card on file, etc.).",
  "endpoint": "/v2/payments",
  "method": "POST",
  "resource_group": "payments",
  "parameters": [
    {
      "name": "source_id",
      "type": "string",
      "description": "Payment source ID (card nonce, card ID)",
      "required": true,
      "example": "cnon:card-nonce-ok",
      "in": "body"
    },
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key to prevent duplicate payments",
      "required": true,
      "example": "unique-key-123",
      "in": "body"
    },
    {
      "name": "amount_money",
      "type": "object",
      "description": "Payment amount with currency",
      "required": true,
      "example": {
        "amount": 100,
        "currency": "USD"
      },
      "in": "body"
    },
    {
      "name": "location_id",
      "type": "string",
      "description": "Location to process payment at",
      "required": false,
      "example": "LOCATION_ID",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/payments",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "source_id": "cnon:card-nonce-ok",
      "idempotency_key": "unique-key-123",
      "amount_money": {
        "amount": 100,
        "currency": "USD"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payment": {
        "id": "pay_123",
        "status": "COMPLETED",
        "amount_money": {
          "amount": 100,
          "currency": "USD"
        }
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
