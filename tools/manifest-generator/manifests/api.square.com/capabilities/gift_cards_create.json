{
  "name": "gift_cards_create",
  "description": "Create a digital gift card or register a physical gift card.",
  "endpoint": "/v2/gift-cards",
  "method": "POST",
  "resource_group": "gift_cards",
  "parameters": [
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key",
      "required": true,
      "example": "gc-key-123"
    },
    {
      "name": "location_id",
      "type": "string",
      "description": "Location ID",
      "required": true,
      "example": "LOCATION_ID"
    },
    {
      "name": "type",
      "type": "string",
      "description": "DIGITAL or PHYSICAL",
      "required": true,
      "example": "DIGITAL"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/gift-cards",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "idempotency_key": "gc-key-123",
      "location_id": "LOCATION_ID",
      "type": "DIGITAL"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "gift_card": {
        "id": "gc_abc",
        "type": "DIGITAL",
        "state": "ACTIVE",
        "balance_money": {
          "amount": 0,
          "currency": "USD"
        }
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}