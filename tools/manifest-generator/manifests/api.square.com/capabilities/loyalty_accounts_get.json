{
  "name": "loyalty_accounts_get",
  "description": "Retrieve a specific loyalty account.",
  "endpoint": "/v2/loyalty/accounts/{account_id}",
  "method": "GET",
  "resource_group": "loyalty",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Loyalty account ID",
      "required": true,
      "example": "loyalty_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/loyalty/accounts/loyalty_abc",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "loyalty_account": {
        "id": "loyalty_abc",
        "balance": 150
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
