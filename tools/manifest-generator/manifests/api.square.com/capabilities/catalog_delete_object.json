{
  "name": "catalog_delete_object",
  "description": "Delete a catalog object by ID.",
  "endpoint": "/v2/catalog/object/{object_id}",
  "method": "DELETE",
  "resource_group": "catalog",
  "parameters": [
    {
      "name": "object_id",
      "type": "string",
      "description": "Object ID to delete",
      "required": true,
      "example": "item_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://connect.squareup.com/v2/catalog/object/item_123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted_object_ids": [
        "item_123"
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
