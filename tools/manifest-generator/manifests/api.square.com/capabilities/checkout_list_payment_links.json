{
  "name": "checkout_list_payment_links",
  "description": "List all payment links.",
  "endpoint": "/v2/online-checkout/payment-links",
  "method": "GET",
  "resource_group": "checkout",
  "parameters": [
    {
      "name": "cursor",
      "type": "string",
      "description": "Pagination cursor",
      "required": false,
      "example": ""
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/online-checkout/payment-links",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payment_links": [
        {
          "id": "link_abc",
          "url": "https://square.link/u/abc123"
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}