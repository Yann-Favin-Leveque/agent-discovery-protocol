{
  "name": "create_customer",
  "description": "Create a new customer record with contact information, email, and phone number for future transactions and customer management.",
  "endpoint": "/v2/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "given_name",
      "type": "string",
      "description": "The customer's first name.",
      "required": true,
      "example": "John"
    },
    {
      "name": "family_name",
      "type": "string",
      "description": "The customer's last name.",
      "required": true,
      "example": "Doe"
    },
    {
      "name": "email_address",
      "type": "string",
      "description": "Optional. The customer's email address.",
      "required": false,
      "example": "john.doe@example.com"
    },
    {
      "name": "phone_number",
      "type": "string",
      "description": "Optional. The customer's phone number.",
      "required": false,
      "example": "+1-555-123-4567"
    },
    {
      "name": "address",
      "type": "object",
      "description": "Optional. The customer's address with address_line_1, city, state, and postal_code fields.",
      "required": false,
      "example": {"address_line_1": "123 Main St", "city": "San Francisco", "state": "CA", "postal_code": "94102"}
    },
    {
      "name": "note",
      "type": "string",
      "description": "Optional. Internal notes about the customer.",
      "required": false,
      "example": "VIP customer"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/customers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "given_name": "John",
      "family_name": "Doe",
      "email_address": "john.doe@example.com",
      "phone_number": "+1-555-123-4567",
      "address": {
        "address_line_1": "123 Main St",
        "city": "San Francisco",
        "state": "CA",
        "postal_code": "94102"
      },
      "note": "VIP customer"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer": {
        "id": "CUST12345",
        "given_name": "John",
        "family_name": "Doe",
        "email_address": "john.doe@example.com",
        "phone_number": "+1-555-123-4567",
        "address": {
          "address_line_1": "123 Main St",
          "city": "San Francisco",
          "state": "CA",
          "postal_code": "94102",
          "country": "US"
        },
        "note": "VIP customer",
        "created_at": "2026-03-01T10:30:00Z",
        "updated_at": "2026-03-01T10:30:00Z"
      }
    }
  }
}
