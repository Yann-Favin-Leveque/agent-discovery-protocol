{
  "name": "list_orders",
  "description": "Search and retrieve orders with detailed information including items, totals, fulfillment status, and customer details. Supports filtering by date, status, location, and customer.",
  "endpoint": "/v2/orders/search",
  "method": "POST",
  "parameters": [
    {
      "name": "query",
      "type": "object",
      "description": "Search criteria with filter and sort fields. Supports filtering by creation date, updated date, closed date, and fulfillment status.",
      "required": false,
      "example": {"filter": {"date_time_filter": {"closed_at": {"start_at": "2026-01-01T00:00:00Z"}}}}
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Optional. Maximum number of results to return (1-100, default 10).",
      "required": false,
      "example": 25
    },
    {
      "name": "cursor",
      "type": "string",
      "description": "Optional. Pagination cursor for retrieving the next page of results.",
      "required": false,
      "example": "cursor_token_here"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/orders/search",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": {
        "filter": {
          "date_time_filter": {
            "created_at": {
              "start_at": "2026-01-01T00:00:00Z",
              "end_at": "2026-03-01T23:59:59Z"
            }
          }
        }
      },
      "limit": 25,
      "sort": {
        "sort_field": "CREATED_AT",
        "sort_order": "DESC"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "orders": [
        {
          "id": "ORDER123",
          "reference_id": "ref_123",
          "location_id": "loc_123",
          "customer_id": "CUST12345",
          "created_at": "2026-03-01T10:30:00Z",
          "updated_at": "2026-03-01T10:30:00Z",
          "state": "COMPLETED",
          "line_items": [
            {
              "uid": "line_1",
              "name": "Coffee",
              "quantity": "2",
              "quantity_unit": {
                "measurement_unit": {
                  "type": "TYPE_GENERIC",
                  "custom_unit": {
                    "name": "cup"
                  }
                }
              },
              "gross_sales_money": {
                "amount": 600,
                "currency": "USD"
              },
              "total_tax_money": {
                "amount": 50,
                "currency": "USD"
              },
              "total_money": {
                "amount": 650,
                "currency": "USD"
              }
            }
          ],
          "total_money": {
            "amount": 650,
            "currency": "USD"
          },
          "total_tax_money": {
            "amount": 50,
            "currency": "USD"
          },
          "fulfillments": [
            {
              "uid": "fulfill_1",
              "state": "COMPLETED",
              "type": "DELIVERY"
            }
          ]
        }
      ],
      "cursor": "next_cursor_token"
    }
  }
}
