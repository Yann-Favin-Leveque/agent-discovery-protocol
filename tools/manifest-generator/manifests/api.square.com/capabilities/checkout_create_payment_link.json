{
  "name": "checkout_create_payment_link",
  "description": "Create a Square-hosted checkout page (payment link).",
  "endpoint": "/v2/online-checkout/payment-links",
  "method": "POST",
  "resource_group": "checkout",
  "parameters": [
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key",
      "required": true,
      "example": "link-key-123"
    },
    {
      "name": "order",
      "type": "object",
      "description": "Order details for the payment link",
      "required": true,
      "example": {
        "location_id": "LOCATION_ID",
        "line_items": [
          {
            "name": "Donation",
            "quantity": "1",
            "base_price_money": {
              "amount": 1000,
              "currency": "USD"
            }
          }
        ]
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/online-checkout/payment-links",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "idempotency_key": "link-key-123",
      "quick_pay": {
        "name": "Donation",
        "price_money": {
          "amount": 1000,
          "currency": "USD"
        },
        "location_id": "LOCATION_ID"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payment_link": {
        "id": "link_abc",
        "url": "https://square.link/u/abc123",
        "order_id": "order_def"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}