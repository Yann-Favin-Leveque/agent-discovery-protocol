{
  "name": "locations_list",
  "description": "List all business locations.",
  "endpoint": "/v2/locations",
  "method": "GET",
  "resource_group": "locations",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/locations",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "locations": [
        {
          "id": "LOCATION_ID",
          "name": "Main Store",
          "address": {
            "address_line_1": "123 Main St"
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}