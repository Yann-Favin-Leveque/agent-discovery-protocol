{
  "name": "payments_update",
  "description": "Update an APPROVED payment before completion.",
  "endpoint": "/v2/payments/{payment_id}",
  "method": "PUT",
  "resource_group": "payments",
  "parameters": [
    {
      "name": "payment_id",
      "type": "string",
      "description": "Payment ID",
      "required": true,
      "example": "pay_123"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://connect.squareup.com/v2/payments/pay_123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "payment": {
        "tip_money": {
          "amount": 50,
          "currency": "USD"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payment": {
        "id": "pay_123",
        "status": "APPROVED"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}