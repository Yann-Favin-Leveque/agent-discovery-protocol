{
  "name": "invoices_create",
  "description": "Create a draft invoice for an order with payment schedules and delivery method.",
  "endpoint": "/v2/invoices",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "invoice",
      "type": "object",
      "description": "Invoice object",
      "required": true,
      "example": {
        "location_id": "LOCATION_ID",
        "order_id": "order_abc",
        "primary_recipient": {
          "customer_id": "cust_789"
        },
        "payment_requests": [
          {
            "request_type": "BALANCE",
            "due_date": "2026-04-01"
          }
        ],
        "delivery_method": "EMAIL"
      }
    },
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key",
      "required": true,
      "example": "inv-key-123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/invoices",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "invoice": {
        "location_id": "LOCATION_ID",
        "order_id": "order_abc",
        "payment_requests": [
          {
            "request_type": "BALANCE",
            "due_date": "2026-04-01"
          }
        ]
      },
      "idempotency_key": "inv-key-123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "invoice": {
        "id": "inv_abc",
        "status": "DRAFT",
        "order_id": "order_abc"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}