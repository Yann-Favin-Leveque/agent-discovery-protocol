{
  "name": "subscriptions_create",
  "description": "Enroll a customer in a subscription plan.",
  "endpoint": "/v2/subscriptions",
  "method": "POST",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "location_id",
      "type": "string",
      "description": "Location ID",
      "required": true,
      "example": "LOCATION_ID",
      "in": "body"
    },
    {
      "name": "plan_variation_id",
      "type": "string",
      "description": "Catalog plan variation ID",
      "required": true,
      "example": "plan_var_123",
      "in": "body"
    },
    {
      "name": "customer_id",
      "type": "string",
      "description": "Customer ID",
      "required": true,
      "example": "cust_789",
      "in": "body"
    },
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key",
      "required": true,
      "example": "sub-key-123",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/subscriptions",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "idempotency_key": "sub-key-123",
      "location_id": "LOCATION_ID",
      "plan_variation_id": "plan_var_123",
      "customer_id": "cust_789"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscription": {
        "id": "sub_abc",
        "status": "ACTIVE",
        "plan_variation_id": "plan_var_123"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
