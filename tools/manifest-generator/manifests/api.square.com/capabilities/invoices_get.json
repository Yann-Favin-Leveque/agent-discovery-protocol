{
  "name": "invoices_get",
  "description": "Retrieve a specific invoice by ID.",
  "endpoint": "/v2/invoices/{invoice_id}",
  "method": "GET",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "inv_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/invoices/inv_abc",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "invoice": {
        "id": "inv_abc",
        "status": "DRAFT",
        "order_id": "order_abc"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}