{
  "name": "catalog_batch_upsert",
  "description": "Create or update up to 10,000 catalog objects in a single batch.",
  "endpoint": "/v2/catalog/batch-upsert",
  "method": "POST",
  "resource_group": "catalog",
  "parameters": [
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Unique key",
      "required": true,
      "example": "batch-key-123"
    },
    {
      "name": "batches",
      "type": "array",
      "description": "Array of object batches",
      "required": true,
      "example": [
        {
          "objects": [
            {
              "type": "ITEM",
              "id": "#item1",
              "item_data": {
                "name": "Item 1"
              }
            }
          ]
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/catalog/batch-upsert",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "idempotency_key": "batch-key-123",
      "batches": [
        {
          "objects": [
            {
              "type": "ITEM",
              "id": "#item1",
              "item_data": {
                "name": "Item 1"
              }
            }
          ]
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "objects": [
        {
          "type": "ITEM",
          "id": "item_new_1"
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}