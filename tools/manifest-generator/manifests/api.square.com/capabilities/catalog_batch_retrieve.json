{
  "name": "catalog_batch_retrieve",
  "description": "Retrieve multiple catalog objects by their IDs.",
  "endpoint": "/v2/catalog/batch-retrieve",
  "method": "POST",
  "resource_group": "catalog",
  "parameters": [
    {
      "name": "object_ids",
      "type": "array",
      "description": "Array of object IDs",
      "required": true,
      "example": [
        "item_123",
        "item_456"
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/catalog/batch-retrieve",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "object_ids": [
        "item_123",
        "item_456"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "objects": [
        {
          "type": "ITEM",
          "id": "item_123"
        },
        {
          "type": "ITEM",
          "id": "item_456"
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}