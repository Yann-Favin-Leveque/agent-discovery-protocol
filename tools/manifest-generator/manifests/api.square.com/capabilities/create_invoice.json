{
  "name": "create_invoice",
  "description": "Generate and send invoices to customers with payment links, due dates, and itemized line items. Invoices can be sent via email or retrieved as a link.",
  "endpoint": "/v2/invoices",
  "method": "POST",
  "parameters": [
    {
      "name": "invoice",
      "type": "object",
      "description": "The invoice object containing customer ID, line items, payment request, and delivery method.",
      "required": true,
      "example": {"customer_id": "CUST12345", "order_id": "ORDER123", "payment_requests": [{"request_type": "BALANCE"}], "delivery_method": "EMAIL"}
    },
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Optional. A unique identifier for the request to prevent duplicate invoices. Use a UUID.",
      "required": false,
      "example": "f51c4f88-9b8e-4a0a-9b8e-9b8e9b8e9b8e"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://connect.squareup.com/v2/invoices",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "invoice": {
        "customer_id": "CUST12345",
        "order_id": "ORDER123",
        "delivery_method": "EMAIL",
        "invoice_number": "INV-001",
        "title": "Invoice",
        "description": "Payment for services rendered",
        "scheduled_at": "2026-03-02T00:00:00Z",
        "payment_requests": [
          {
            "request_type": "BALANCE",
            "due_date": "2026-03-15"
          }
        ]
      },
      "idempotency_key": "f51c4f88-9b8e-4a0a-9b8e-9b8e9b8e9b8e"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "invoice": {
        "id": "inv_abc123",
        "version": 1,
        "customer_id": "CUST12345",
        "order_id": "ORDER123",
        "invoice_number": "INV-001",
        "title": "Invoice",
        "description": "Payment for services rendered",
        "status": "DRAFT",
        "delivery_method": "EMAIL",
        "scheduled_at": "2026-03-02T00:00:00Z",
        "created_at": "2026-03-01T10:30:00Z",
        "updated_at": "2026-03-01T10:30:00Z",
        "public_url": "https://squareup.com/i/invoice/inv_abc123",
        "payment_requests": [
          {
            "uid": "req_1",
            "request_type": "BALANCE",
            "due_date": "2026-03-15"
          }
        ]
      }
    }
  }
}
