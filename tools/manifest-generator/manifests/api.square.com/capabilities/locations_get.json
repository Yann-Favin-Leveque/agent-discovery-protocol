{
  "name": "locations_get",
  "description": "Retrieve a specific location by ID.",
  "endpoint": "/v2/locations/{location_id}",
  "method": "GET",
  "resource_group": "locations",
  "parameters": [
    {
      "name": "location_id",
      "type": "string",
      "description": "Location ID",
      "required": true,
      "example": "LOCATION_ID"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/locations/LOCATION_ID",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "location": {
        "id": "LOCATION_ID",
        "name": "Main Store"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}