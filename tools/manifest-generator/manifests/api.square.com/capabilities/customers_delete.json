{
  "name": "customers_delete",
  "description": "Delete a customer profile.",
  "endpoint": "/v2/customers/{customer_id}",
  "method": "DELETE",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "Customer ID to delete",
      "required": true,
      "example": "cust_789",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://connect.squareup.com/v2/customers/cust_789",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
