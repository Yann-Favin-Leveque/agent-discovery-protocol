{
  "name": "customers_get",
  "description": "Retrieve a specific customer profile by ID.",
  "endpoint": "/v2/customers/{customer_id}",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "Customer ID",
      "required": true,
      "example": "cust_789",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/customers/cust_789",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer": {
        "id": "cust_789",
        "given_name": "John",
        "family_name": "Doe",
        "email_address": "john@example.com"
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
