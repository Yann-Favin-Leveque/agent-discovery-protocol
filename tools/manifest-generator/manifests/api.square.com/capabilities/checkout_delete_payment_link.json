{
  "name": "checkout_delete_payment_link",
  "description": "Delete a payment link.",
  "endpoint": "/v2/online-checkout/payment-links/{id}",
  "method": "DELETE",
  "resource_group": "checkout",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Payment link ID to delete",
      "required": true,
      "example": "link_abc"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://connect.squareup.com/v2/online-checkout/payment-links/link_abc",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}