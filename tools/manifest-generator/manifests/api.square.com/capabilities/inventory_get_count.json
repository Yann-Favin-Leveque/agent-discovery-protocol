{
  "name": "inventory_get_count",
  "description": "Retrieve current inventory count for a specific catalog object.",
  "endpoint": "/v2/inventory/{catalog_object_id}",
  "method": "GET",
  "resource_group": "inventory",
  "parameters": [
    {
      "name": "catalog_object_id",
      "type": "string",
      "description": "Catalog object ID",
      "required": true,
      "example": "item_var_123",
      "in": "path"
    },
    {
      "name": "location_ids",
      "type": "string",
      "description": "Comma-separated location IDs",
      "required": false,
      "example": "LOCATION_ID",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/inventory/item_var_123?location_ids=LOCATION_ID",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "counts": [
        {
          "catalog_object_id": "item_var_123",
          "quantity": "10",
          "state": "IN_STOCK"
        }
      ]
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
