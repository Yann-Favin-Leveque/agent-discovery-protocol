{
  "name": "gift_cards_get",
  "description": "Retrieve a specific gift card by ID.",
  "endpoint": "/v2/gift-cards/{id}",
  "method": "GET",
  "resource_group": "gift_cards",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Gift card ID",
      "required": true,
      "example": "gc_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://connect.squareup.com/v2/gift-cards/gc_abc",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "gift_card": {
        "id": "gc_abc",
        "state": "ACTIVE",
        "balance_money": {
          "amount": 2500,
          "currency": "USD"
        }
      }
    }
  },
  "auth_scopes": [
    "PAYMENTS_WRITE",
    "PAYMENTS_READ",
    "CUSTOMERS_WRITE",
    "CUSTOMERS_READ",
    "ORDERS_WRITE",
    "ORDERS_READ",
    "ITEMS_WRITE",
    "ITEMS_READ",
    "INVOICES_WRITE",
    "INVOICES_READ"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}