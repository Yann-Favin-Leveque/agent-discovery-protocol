{
  "name": "contact_update",
  "description": "Update a contact's information.",
  "resource_group": "contact",
  "endpoint": "/public/v1/contacts/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Contact ID.",
      "in": "path"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "New email.",
      "in": "body"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "New first name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "New last name.",
      "in": "body"
    },
    {
      "name": "company",
      "type": "string",
      "required": false,
      "description": "New company.",
      "in": "body"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.pandadoc.com/public/v1/contacts/contact-abc-123",
    "headers": {
      "Authorization": "API-Key YOUR_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "company": "Acme Inc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "contact-abc-123",
      "company": "Acme Inc"
    }
  }
}