{
  "name": "contact_get",
  "description": "Retrieve a specific contact by ID.",
  "resource_group": "contact",
  "endpoint": "/public/v1/contacts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Contact ID.",
      "in": "path"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.pandadoc.com/public/v1/contacts/contact-abc-123",
    "headers": {
      "Authorization": "API-Key YOUR_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "contact-abc-123",
      "email": "john@acme.com",
      "first_name": "John",
      "last_name": "Doe",
      "company": "Acme Corporation",
      "job_title": "CEO"
    }
  }
}