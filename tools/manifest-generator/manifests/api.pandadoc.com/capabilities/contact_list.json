{
  "name": "contact_list",
  "description": "List contacts with search and filtering.",
  "resource_group": "contact",
  "endpoint": "/public/v1/contacts",
  "method": "GET",
  "parameters": [
    {
      "name": "q",
      "type": "string",
      "required": false,
      "description": "Search query.",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.pandadoc.com/public/v1/contacts?q=acme&count=25",
    "headers": {
      "Authorization": "API-Key YOUR_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1,
      "results": [
        {
          "id": "contact-abc-123",
          "email": "john@acme.com",
          "first_name": "John",
          "last_name": "Doe",
          "company": "Acme Corporation"
        }
      ]
    }
  }
}