{
  "name": "document_get",
  "description": "Retrieve the current status, metadata, and basic details of a specific document.",
  "resource_group": "document",
  "endpoint": "/public/v1/documents/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Document ID.",
      "in": "path"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.pandadoc.com/public/v1/documents/doc-abc-123",
    "headers": {
      "Authorization": "API-Key YOUR_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "doc-abc-123",
      "name": "Service Agreement - Acme Corp",
      "status": "document.completed",
      "date_created": "2025-01-15T14:30:00.000Z",
      "date_modified": "2025-01-15T16:00:00.000Z",
      "date_completed": "2025-01-15T16:00:00.000Z",
      "recipients": [
        {
          "email": "client@acme.com",
          "first_name": "John",
          "last_name": "Doe",
          "role": "Client",
          "has_completed": true
        }
      ]
    }
  }
}