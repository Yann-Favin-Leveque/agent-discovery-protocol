{
  "name": "contact_create",
  "description": "Create a new contact in PandaDoc for use as a document recipient.",
  "resource_group": "contact",
  "endpoint": "/public/v1/contacts",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Contact email.",
      "in": "body"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "company",
      "type": "string",
      "required": false,
      "description": "Company name.",
      "in": "body"
    },
    {
      "name": "job_title",
      "type": "string",
      "required": false,
      "description": "Job title.",
      "in": "body"
    },
    {
      "name": "phone",
      "type": "string",
      "required": false,
      "description": "Phone number.",
      "in": "body"
    },
    {
      "name": "state",
      "type": "string",
      "required": false,
      "description": "State.",
      "in": "body"
    },
    {
      "name": "country",
      "type": "string",
      "required": false,
      "description": "Country.",
      "in": "body"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "POST",
    "url": "https://api.pandadoc.com/public/v1/contacts",
    "headers": {
      "Authorization": "API-Key YOUR_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "john@acme.com",
      "first_name": "John",
      "last_name": "Doe",
      "company": "Acme Corporation",
      "job_title": "CEO"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "contact-abc-123",
      "email": "john@acme.com",
      "first_name": "John",
      "last_name": "Doe",
      "company": "Acme Corporation"
    }
  }
}