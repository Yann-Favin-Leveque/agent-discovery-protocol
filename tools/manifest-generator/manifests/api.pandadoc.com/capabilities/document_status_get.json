{
  "name": "document_status_get",
  "description": "Get the current lifecycle status of a document and completion progress.",
  "resource_group": "document",
  "endpoint": "/public/v1/documents/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Document ID.",
      "in": "path"
    }
  ],
  "auth_scopes": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.pandadoc.com/public/v1/documents/doc-abc-123",
    "headers": {
      "Authorization": "API-Key YOUR_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "doc-abc-123",
      "name": "Service Agreement",
      "status": "document.sent",
      "date_created": "2025-01-15T14:30:00.000Z"
    }
  }
}