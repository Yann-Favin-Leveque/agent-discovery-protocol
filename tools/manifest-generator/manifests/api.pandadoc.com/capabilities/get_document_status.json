{
  "name": "get_document_status",
  "description": "Retrieve the current status and full details of a specific document. Returns metadata, recipient completion status, creation and expiration dates, and document lifecycle state (draft, sent, completed, viewed, paid, etc.).",
  "endpoint": "/public/v1/documents/{id}/details",
  "method": "GET",
  "parameters": [
    { "name": "id", "type": "string", "description": "The unique ID of the document to retrieve.", "required": true, "example": "msFYActMfJHqNTKH8YSvF1" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pandadoc.com/public/v1/documents/msFYActMfJHqNTKH8YSvF1/details",
    "headers": {
      "Authorization": "API-Key {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "msFYActMfJHqNTKH8YSvF1",
      "name": "Sales Agreement - Acme Corp",
      "status": "document.sent",
      "date_created": "2026-01-15T10:30:00.000Z",
      "date_modified": "2026-01-15T11:00:00.000Z",
      "expiration_date": "2026-02-15T10:30:00.000Z",
      "version": "1",
      "recipients": [
        {
          "email": "john@example.com",
          "first_name": "John",
          "last_name": "Doe",
          "role": "Signer",
          "has_completed": false
        }
      ],
      "tags": ["sales"],
      "metadata": { "opportunity_id": "OPP-12345" }
    }
  }
}
