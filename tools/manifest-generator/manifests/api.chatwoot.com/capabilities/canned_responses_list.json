{
  "name": "canned_responses_list",
  "description": "List all canned (pre-saved) responses available for agents to use in conversations.",
  "endpoint": "/api/v1/accounts/{account_id}/canned_responses",
  "method": "GET",
  "resource_group": "canned_responses",
  "parameters": [
    {"name": "account_id", "type": "integer", "description": "Account ID.", "required": true, "example": 1},
    {"name": "search", "type": "string", "description": "Filter by short code.", "required": false, "example": "greeting"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/canned_responses?search=greeting",
    "headers": {"api_access_token": "{token}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": 1, "short_code": "greeting", "content": "Hello! How can I help you today?"}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 250}
}
