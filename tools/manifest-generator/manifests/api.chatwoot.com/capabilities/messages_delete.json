{
  "name": "messages_delete",
  "description": "Delete a specific message from a conversation.",
  "endpoint": "/api/v1/accounts/{account_id}/conversations/{conversation_id}/messages/{message_id}",
  "method": "DELETE",
  "resource_group": "messages",
  "parameters": [
    {"name": "account_id", "type": "integer", "description": "Account ID.", "required": true, "example": 1},
    {"name": "conversation_id", "type": "integer", "description": "Conversation ID.", "required": true, "example": 101},
    {"name": "message_id", "type": "integer", "description": "Message ID.", "required": true, "example": 1002}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/conversations/101/messages/1002",
    "headers": {"api_access_token": "{token}"}
  },
  "response_example": {"status": 200, "body": {}},
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 250}
}
