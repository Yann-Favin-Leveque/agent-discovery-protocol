{
  "name": "agents_list",
  "description": "List all agents in the account.",
  "endpoint": "/api/v1/accounts/{account_id}/agents",
  "method": "GET",
  "resource_group": "agents",
  "parameters": [
    {"name": "account_id", "type": "integer", "description": "Account ID.", "required": true, "example": 1}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/agents",
    "headers": {"api_access_token": "{token}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": 5, "name": "Agent Smith", "email": "smith@company.com", "role": "agent", "availability_status": "online"}]
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 250}
}
