{
  "name": "conversations_get",
  "description": "Get full details of a specific conversation including messages, participants, and metadata.",
  "endpoint": "/api/v1/accounts/{account_id}/conversations/{conversation_id}",
  "method": "GET",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "description": "Account ID.",
      "required": true,
      "example": 1,
      "in": "path"
    },
    {
      "name": "conversation_id",
      "type": "integer",
      "description": "Conversation ID.",
      "required": true,
      "example": 101,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/conversations/101",
    "headers": {
      "api_access_token": "{token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 101,
      "inbox_id": 1,
      "status": "open",
      "priority": null,
      "assignee": {
        "id": 5,
        "name": "Agent Smith"
      },
      "contact": {
        "id": 42,
        "name": "John Doe"
      },
      "messages": []
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
