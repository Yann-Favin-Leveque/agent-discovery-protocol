{
  "name": "messages_list",
  "description": "List all messages in a specific conversation with pagination.",
  "endpoint": "/api/v1/accounts/{account_id}/conversations/{conversation_id}/messages",
  "method": "GET",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "description": "Account ID.",
      "required": true,
      "example": 1,
      "in": "path"
    },
    {
      "name": "conversation_id",
      "type": "integer",
      "description": "Conversation ID.",
      "required": true,
      "example": 101,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/conversations/101/messages",
    "headers": {
      "api_access_token": "{token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payload": [
        {
          "id": 1001,
          "content": "Hello, I need help with my order.",
          "message_type": 0,
          "created_at": 1718438400,
          "sender": {
            "id": 42,
            "name": "John Doe"
          }
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
