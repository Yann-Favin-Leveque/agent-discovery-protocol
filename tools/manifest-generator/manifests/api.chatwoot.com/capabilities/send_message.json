{
  "name": "send_message",
  "description": "Send a message to an existing conversation as an agent, bot, or on behalf of a contact.",
  "endpoint": "/api/v1/accounts/{account_id}/conversations/{conversation_id}/messages",
  "method": "POST",
  "parameters": [
    { "name": "account_id", "type": "number", "required": true, "description": "The account ID" },
    { "name": "conversation_id", "type": "number", "required": true, "description": "The conversation ID" },
    { "name": "content", "type": "string", "required": true, "description": "The message content" },
    { "name": "message_type", "type": "string", "required": false, "description": "Type: outgoing, activity, incoming" },
    { "name": "private", "type": "boolean", "required": false, "description": "Whether this is a private note visible only to agents" }
  ],
  "request_example": {
    "content": "Hello! How can I help you today?",
    "message_type": "outgoing",
    "private": false
  },
  "response_example": {
    "id": 1234,
    "content": "Hello! How can I help you today?",
    "message_type": "outgoing",
    "conversation_id": 42,
    "created_at": 1706000000
  }
}
