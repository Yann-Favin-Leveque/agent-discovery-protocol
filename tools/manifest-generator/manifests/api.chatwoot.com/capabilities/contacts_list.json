{
  "name": "contacts_list",
  "description": "List all contacts in the account with pagination.",
  "endpoint": "/api/v1/accounts/{account_id}/contacts",
  "method": "GET",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "description": "Account ID.",
      "required": true,
      "example": 1,
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/contacts?page=1",
    "headers": {
      "api_access_token": "{token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "payload": [
        {
          "id": 42,
          "name": "John Doe",
          "email": "john@example.com",
          "phone_number": "+1234567890"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
