{
  "name": "update_conversation_status",
  "description": "Change the status of a conversation to open, resolved, pending, or snoozed.",
  "endpoint": "/api/v1/accounts/{account_id}/conversations/{conversation_id}/toggle_status",
  "method": "POST",
  "parameters": [
    { "name": "account_id", "type": "number", "required": true, "description": "The account ID" },
    { "name": "conversation_id", "type": "number", "required": true, "description": "The conversation ID" },
    { "name": "status", "type": "string", "required": true, "description": "New status: open, resolved, pending, snoozed" }
  ],
  "request_example": {
    "status": "resolved"
  },
  "response_example": {
    "id": 42,
    "status": "resolved",
    "updated_at": "2025-01-15T10:30:00Z"
  }
}
