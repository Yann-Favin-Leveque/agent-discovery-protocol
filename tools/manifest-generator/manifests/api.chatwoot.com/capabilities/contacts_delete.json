    },
    {
      "name": "contact_id",
      "type": "integer",
      "description": "Contact ID.",
      "required": true,
      "example": 42,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/contacts/42",
    "headers": {
      "api_access_token": "{token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
