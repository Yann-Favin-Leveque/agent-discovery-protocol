{
  "name": "inboxes_list",
  "description": "List all inboxes (channels) configured in the account.",
  "endpoint": "/api/v1/accounts/{account_id}/inboxes",
  "method": "GET",
  "resource_group": "inboxes",
  "parameters": [
    {"name": "account_id", "type": "integer", "description": "Account ID.", "required": true, "example": 1}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/inboxes",
    "headers": {"api_access_token": "{token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"payload": [{"id": 1, "name": "Website Chat", "channel_type": "Channel::WebWidget", "greeting_enabled": true}]}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 250}
}
