{
  "name": "agents_create",
  "description": "Add a new agent to the account.",
  "endpoint": "/api/v1/accounts/{account_id}/agents",
  "method": "POST",
  "resource_group": "agents",
  "parameters": [
    {"name": "account_id", "type": "integer", "description": "Account ID.", "required": true, "example": 1},
    {"name": "name", "type": "string", "description": "Agent name.", "required": true, "example": "New Agent"},
    {"name": "email", "type": "string", "description": "Agent email.", "required": true, "example": "newagent@company.com"},
    {"name": "role", "type": "string", "description": "Role: agent or administrator.", "required": false, "example": "agent"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/agents",
    "headers": {"api_access_token": "{token}", "Content-Type": "application/json"},
    "body": {"name": "New Agent", "email": "newagent@company.com", "role": "agent"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": 6, "name": "New Agent", "email": "newagent@company.com", "role": "agent"}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 250}
}
