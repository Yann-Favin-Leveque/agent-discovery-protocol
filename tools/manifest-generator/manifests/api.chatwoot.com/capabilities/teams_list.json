{
  "name": "teams_list",
  "description": "List all teams in the account.",
  "endpoint": "/api/v1/accounts/{account_id}/teams",
  "method": "GET",
  "resource_group": "teams",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "description": "Account ID.",
      "required": true,
      "example": 1,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chatwoot.com/api/v1/accounts/1/teams",
    "headers": {
      "api_access_token": "{token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "name": "Support",
        "description": "Support team",
        "allow_auto_assign": true
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
