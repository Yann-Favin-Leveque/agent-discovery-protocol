{
  "name": "contacts_get",
  "description": "Retrieve a specific contact by their contact ID.",
  "endpoint": "/v1/contacts/get",
  "method": "GET",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The contact ID to retrieve (query parameter).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.boldsign.com/v1/contacts/get?id=contact_001",
    "headers": {
      "X-API-KEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "contact_001",
      "name": "John Doe",
      "email": "john@example.com",
      "phoneNumber": "+14155550100",
      "companyName": "Acme Corp",
      "jobTitle": "CTO"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
