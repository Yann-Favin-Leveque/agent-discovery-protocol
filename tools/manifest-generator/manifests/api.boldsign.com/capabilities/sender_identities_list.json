{
  "name": "sender_identities_list",
  "description": "List all sender identities configured for your account, including verified and pending identities.",
  "endpoint": "/v1/senderIdentities/list",
  "method": "GET",
  "resource_group": "sender_identities",
  "parameters": [
    {
      "name": "Page",
      "type": "integer",
      "required": false,
      "description": "Page number. Default 1."
    },
    {
      "name": "PageSize",
      "type": "integer",
      "required": false,
      "description": "Items per page. Default 10."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.boldsign.com/v1/senderIdentities/list?Page=1&PageSize=20",
    "headers": {
      "X-API-KEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "pageDetails": { "page": 1, "pageSize": 20, "totalRecordsCount": 2 },
      "result": [
        {
          "name": "Company Legal",
          "email": "legal@example.com",
          "status": "Verified"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
