{
  "name": "templates_get",
  "description": "Retrieve details of a specific template including its roles, form fields, and configuration.",
  "endpoint": "/v1/template/properties",
  "method": "GET",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "templateId",
      "type": "string",
      "required": true,
      "description": "The template ID to retrieve (query parameter)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.boldsign.com/v1/template/properties?templateId=tmpl_abc123",
    "headers": {
      "X-API-KEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "templateId": "tmpl_abc123",
      "title": "NDA Template",
      "description": "Standard non-disclosure agreement",
      "roles": [{ "roleIndex": 1, "name": "Signer", "signerType": "Signer" }],
      "formFields": [],
      "createdDate": "2024-01-10T10:00:00Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 200
  }
}
