{
  "name": "templates_delete",
  "description": "Delete a document template by its template ID. This action cannot be undone.",
  "endpoint": "/v1/template/delete",
  "method": "DELETE",
  "resource_group": "templates",
  "parameters": [
    {
      "name": "templateId",
      "type": "string",
      "required": true,
      "description": "The template ID to delete (query parameter).",
