    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.boldsign.com/v1/template/delete?templateId=tmpl_abc123",
    "headers": {
      "X-API-KEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
