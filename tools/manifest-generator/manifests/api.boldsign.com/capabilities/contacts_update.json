{
  "name": "contacts_update",
  "description": "Update an existing contact's details by their contact ID.",
  "endpoint": "/v1/contacts/update",
  "method": "PUT",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The contact ID to update (query parameter).",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Updated email address.",
      "in": "body"
    },
    {
      "name": "phoneNumber",
      "type": "string",
      "required": false,
      "description": "Updated phone number.",
      "in": "body"
    },
    {
      "name": "companyName",
      "type": "string",
      "required": false,
      "description": "Updated company name.",
      "in": "body"
    },
    {
      "name": "jobTitle",
      "type": "string",
      "required": false,
      "description": "Updated job title.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.boldsign.com/v1/contacts/update?id=contact_001",
    "headers": {
      "Content-Type": "application/json",
      "X-API-KEY": "{api_key}"
    },
    "body": {
      "jobTitle": "CEO",
      "companyName": "Acme Corp International"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
