{
  "name": "documents_download",
  "description": "Download the completed signed document as a PDF file.",
  "endpoint": "/v1/document/download",
  "method": "GET",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "documentId",
      "type": "string",
      "required": true,
      "description": "The document ID to download (query parameter).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.boldsign.com/v1/document/download?documentId=doc_abc123def456",
    "headers": {
      "X-API-KEY": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "(PDF binary content)"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
