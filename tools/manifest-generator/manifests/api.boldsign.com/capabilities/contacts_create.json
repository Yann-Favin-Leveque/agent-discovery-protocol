{
  "name": "contacts_create",
  "description": "Create a new contact with name, email, phone number, company, and job title details.",
  "endpoint": "/v1/contacts/create",
  "method": "POST",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Full name of the contact.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email address of the contact.",
      "in": "body"
    },
    {
      "name": "phoneNumber",
      "type": "string",
      "required": false,
      "description": "Phone number of the contact.",
      "in": "body"
    },
    {
      "name": "companyName",
      "type": "string",
      "required": false,
      "description": "Company or organization name.",
      "in": "body"
    },
    {
      "name": "jobTitle",
      "type": "string",
      "required": false,
      "description": "Job title of the contact.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.boldsign.com/v1/contacts/create",
    "headers": {
      "Content-Type": "application/json",
      "X-API-KEY": "{api_key}"
    },
    "body": {
      "name": "Jane Smith",
      "email": "jane@example.com",
      "phoneNumber": "+14155550123",
      "companyName": "Widget Co",
      "jobTitle": "VP Engineering"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "contact_002"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
