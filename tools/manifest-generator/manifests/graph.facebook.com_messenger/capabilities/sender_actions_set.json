{
  "name": "sender_actions_set",
  "description": "Send typing indicators or mark messages as read to provide real-time feedback to users.",
  "endpoint": "/me/messages",
  "method": "POST",
  "resource_group": "sender_actions",
  "parameters": [
    {
      "name": "recipient_id",
      "type": "string",
      "description": "The PSID of the Messenger recipient.",
      "required": true,
      "example": "1234567890",
      "in": "body"
    },
    {
      "name": "sender_action",
      "type": "string",
      "description": "The sender action: typing_on, typing_off, or mark_seen.",
      "required": true,
      "example": "typing_on",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messages",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "recipient": {
        "id": "1234567890"
      },
      "sender_action": "typing_on"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "recipient_id": "1234567890"
    }
  },
  "auth_scopes": [
    "pages_messaging"
  ],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
