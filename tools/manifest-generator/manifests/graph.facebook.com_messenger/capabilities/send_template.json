{
  "name": "send_template",
  "description": "Send structured message templates including buttons, generic templates with images, and quick reply options for interactive user engagement.",
  "endpoint": "/me/messages",
  "method": "POST",
  "parameters": [
    {
      "name": "recipient_id",
      "type": "string",
      "description": "The user ID of the Messenger recipient.",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "template_type",
      "type": "string",
      "description": "The type of template: 'button', 'generic', 'list', or 'receipt'.",
      "required": true,
      "example": "button"
    },
    {
      "name": "template_text",
      "type": "string",
      "description": "The main text or title for the template.",
      "required": true,
      "example": "Choose an option"
    },
    {
      "name": "buttons",
      "type": "array",
      "description": "Array of button objects with type, title, and payload/url.",
      "required": false,
      "example": [
        {
          "type": "postback",
          "title": "Yes",
          "payload": "yes_response"
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messages",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "recipient": {
        "id": "1234567890"
      },
      "message": {
        "attachment": {
          "type": "template",
          "payload": {
            "template_type": "button",
            "text": "Choose an option",
            "buttons": [
              {
                "type": "postback",
                "title": "Yes",
                "payload": "yes_response"
              },
              {
                "type": "postback",
                "title": "No",
                "payload": "no_response"
              }
            ]
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "recipient_id": "1234567890",
      "message_id": "mid.1457764197618:41d102a3e1ae206a38"
    }
  }
}
