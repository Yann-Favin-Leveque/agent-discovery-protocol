{
  "name": "messenger_profile_set_whitelisted_domains",
  "description": "Set the list of whitelisted domains for Messenger Extensions, webview buttons, and checkbox plugin.",
  "endpoint": "/me/messenger_profile",
  "method": "POST",
  "resource_group": "messenger_profile",
  "parameters": [
    {
      "name": "whitelisted_domains",
      "type": "array",
      "description": "Array of domain URLs to whitelist (must use HTTPS).",
      "required": true,
      "example": ["https://example.com", "https://app.example.com"]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messenger_profile",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "whitelisted_domains": ["https://example.com", "https://app.example.com"]
    }
  },
  "response_example": {
    "status": 200,
    "body": { "result": "success" }
  },
  "auth_scopes": ["pages_messaging"],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
