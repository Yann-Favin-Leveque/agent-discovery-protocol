{
  "name": "messages_send_template",
  "description": "Send structured message templates including button, generic, receipt, or media templates for rich interactive experiences.",
  "endpoint": "/me/messages",
  "method": "POST",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "recipient_id",
      "type": "string",
      "description": "The PSID of the Messenger recipient.",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "template_type",
      "type": "string",
      "description": "Template type: button, generic, receipt, media, airline_boardingpass, airline_checkin, airline_itinerary, or airline_update.",
      "required": true,
      "example": "generic"
    },
    {
      "name": "template_payload",
      "type": "object",
      "description": "Template-specific payload with elements, buttons, text, etc.",
      "required": true,
      "example": {
        "template_type": "generic",
        "elements": [{ "title": "Product", "subtitle": "Description", "image_url": "https://example.com/img.jpg" }]
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messages",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "messaging_type": "RESPONSE",
      "recipient": { "id": "1234567890" },
      "message": {
        "attachment": {
          "type": "template",
          "payload": {
            "template_type": "generic",
            "elements": [
              {
                "title": "Welcome to Our Store",
                "image_url": "https://example.com/store.jpg",
                "subtitle": "Browse our collection",
                "buttons": [
                  { "type": "web_url", "url": "https://example.com/shop", "title": "Shop Now" },
                  { "type": "postback", "title": "View Cart", "payload": "VIEW_CART" }
                ]
              }
            ]
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "recipient_id": "1234567890",
      "message_id": "mid.1457764197618:41d102a3e1ae206a38"
    }
  },
  "auth_scopes": ["pages_messaging"],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
