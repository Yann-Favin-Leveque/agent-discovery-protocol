{
  "name": "send_attachment",
  "description": "Send files, images, audio, or video attachments to Messenger users. Upload media directly or reference URLs to enrich conversations with rich content.",
  "endpoint": "/me/messages",
  "method": "POST",
  "parameters": [
    {
      "name": "recipient_id",
      "type": "string",
      "description": "The user ID of the Messenger recipient.",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "attachment_type",
      "type": "string",
      "description": "The type of attachment: 'image', 'video', 'file', or 'audio'.",
      "required": true,
      "example": "image"
    },
    {
      "name": "attachment_url",
      "type": "string",
      "description": "The URL or path to the attachment file.",
      "required": true,
      "example": "https://example.com/image.jpg"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messages",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "recipient": {
        "id": "1234567890"
      },
      "message": {
        "attachment": {
          "type": "image",
          "payload": {
            "url": "https://example.com/image.jpg"
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "recipient_id": "1234567890",
      "message_id": "mid.1457764197618:41d102a3e1ae206a38"
    }
  }
}
