{
  "name": "messenger_profile_set_get_started",
  "description": "Configure the Get Started button payload that triggers when new users first interact with your bot.",
  "endpoint": "/me/messenger_profile",
  "method": "POST",
  "resource_group": "messenger_profile",
  "parameters": [
    {
      "name": "payload",
      "type": "string",
      "description": "The postback payload string sent when the user taps Get Started (max 1000 characters).",
      "required": true,
      "example": "get_started_clicked"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messenger_profile",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "get_started": {
        "payload": "get_started_clicked"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": { "result": "success" }
  },
  "auth_scopes": ["pages_messaging"],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
