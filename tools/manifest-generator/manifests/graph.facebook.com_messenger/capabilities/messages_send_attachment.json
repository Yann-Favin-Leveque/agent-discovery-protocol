{
  "name": "messages_send_attachment",
  "description": "Send an image, video, audio, or file attachment to a Messenger user via URL.",
  "endpoint": "/me/messages",
  "method": "POST",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "recipient_id",
      "type": "string",
      "description": "The PSID of the Messenger recipient.",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "attachment_type",
      "type": "string",
      "description": "The type of attachment: image, video, audio, or file.",
      "required": true,
      "example": "image"
    },
    {
      "name": "attachment_url",
      "type": "string",
      "description": "The URL of the attachment to send.",
      "required": true,
      "example": "https://example.com/image.jpg"
    },
    {
      "name": "is_reusable",
      "type": "boolean",
      "description": "Set to true to make the attachment reusable via attachment_id in future messages.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messages",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "messaging_type": "RESPONSE",
      "recipient": { "id": "1234567890" },
      "message": {
        "attachment": {
          "type": "image",
          "payload": {
            "url": "https://example.com/image.jpg",
            "is_reusable": true
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "recipient_id": "1234567890",
      "message_id": "mid.1457764197618:41d102a3e1ae206a38",
      "attachment_id": "1745504518999123"
    }
  },
  "auth_scopes": ["pages_messaging"],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
