{
  "name": "messages_send_quick_replies",
  "description": "Send a message with quick reply buttons that allow users to tap predefined responses instead of typing.",
  "endpoint": "/me/messages",
  "method": "POST",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "recipient_id",
      "type": "string",
      "description": "The PSID of the Messenger recipient.",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "message_text",
      "type": "string",
      "description": "The text content of the message.",
      "required": true,
      "example": "What is your favorite color?"
    },
    {
      "name": "quick_replies",
      "type": "array",
      "description": "Array of quick reply objects (max 13). Each has content_type, title, and payload.",
      "required": true,
      "example": [
        { "content_type": "text", "title": "Red", "payload": "red" },
        { "content_type": "text", "title": "Blue", "payload": "blue" }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/messages",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "messaging_type": "RESPONSE",
      "recipient": { "id": "1234567890" },
      "message": {
        "text": "What is your favorite color?",
        "quick_replies": [
          { "content_type": "text", "title": "Red", "payload": "red", "image_url": "https://example.com/red.png" },
          { "content_type": "text", "title": "Blue", "payload": "blue" }
        ]
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "recipient_id": "1234567890",
      "message_id": "mid.1457764197618:41d102a3e1ae206a38"
    }
  },
  "auth_scopes": ["pages_messaging"],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
