{
  "name": "attachment_upload",
  "description": "Upload a reusable attachment (image, video, audio, file) to Facebook servers for later use in messages.",
  "endpoint": "/me/message_attachments",
  "method": "POST",
  "resource_group": "attachments",
  "parameters": [
    {
      "name": "attachment_type",
      "type": "string",
      "description": "The type of attachment: image, video, audio, or file.",
      "required": true,
      "example": "image"
    },
    {
      "name": "attachment_url",
      "type": "string",
      "description": "The URL of the attachment to upload.",
      "required": true,
      "example": "https://example.com/image.jpg"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://graph.facebook.com/v18.0/me/message_attachments",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "message": {
        "attachment": {
          "type": "image",
          "payload": {
            "url": "https://example.com/image.jpg",
            "is_reusable": true
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "attachment_id": "1745504518999123"
    }
  },
  "auth_scopes": ["pages_messaging"],
  "rate_limits": {
    "requests_per_minute": 250
  }
}
