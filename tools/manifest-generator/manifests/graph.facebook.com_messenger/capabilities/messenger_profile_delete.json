{
  "name": "messenger_profile_delete",
  "description": "Delete specific Messenger Profile properties such as persistent_menu, get_started, greeting, or whitelisted_domains.",
  "endpoint": "/me/messenger_profile",
  "method": "DELETE",
  "resource_group": "messenger_profile",
  "parameters": [
    {
      "name": "fields",
      "type": "array",
      "description": "Array of profile property names to delete.",
      "required": true,
      "example": ["persistent_menu", "greeting"]
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://graph.facebook.com/v18.0/me/messenger_profile",
    "headers": {
      "Authorization": "Bearer {page_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "fields": ["persistent_menu", "greeting"]
    }
  },
  "response_example": {
    "status": 200,
    "body": { "result": "success" }
  },
  "auth_scopes": ["pages_messaging"],
  "rate_limits": {
    "requests_per_minute": 10
  }
}
