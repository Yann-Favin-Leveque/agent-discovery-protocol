{
  "name": "tasks_list",
  "description": "Get tasks from a list.",
  "resource_group": "tasks",
  "endpoint": "/api/v2/list/{list_id}/task",
  "method": "GET",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "List ID"
    },
    {
      "name": "archived",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Include archived tasks"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Page number (0-indexed)"
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Sort field (id, created, updated, due_date)"
    },
    {
      "name": "reverse",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Reverse sort order"
    },
    {
      "name": "subtasks",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Include subtasks"
    },
    {
      "name": "statuses[]",
      "type": "array",
      "required": false,
      "location": "query",
      "description": "Filter by status names"
    },
    {
      "name": "assignees[]",
      "type": "array",
      "required": false,
      "location": "query",
      "description": "Filter by assignee IDs"
    },
    {
      "name": "due_date_gt",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Due date greater than (unix ms)"
    },
    {
      "name": "due_date_lt",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Due date less than (unix ms)"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}