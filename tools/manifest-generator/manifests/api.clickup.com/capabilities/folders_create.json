{
  "name": "folders_create",
  "description": "Create a folder in a space.",
  "resource_group": "folders",
  "endpoint": "/api/v2/space/{space_id}/folder",
  "method": "POST",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Space ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Folder name",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
