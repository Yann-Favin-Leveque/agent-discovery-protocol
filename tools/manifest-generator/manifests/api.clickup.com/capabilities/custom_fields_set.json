{
  "name": "custom_fields_set",
  "description": "Set a custom field value on a task.",
  "resource_group": "custom_fields",
  "endpoint": "/api/v2/task/{task_id}/field/{field_id}",
  "method": "POST",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID"
    },
    {
      "name": "field_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Custom field ID"
    },
    {
      "name": "value",
      "type": "any",
      "required": true,
      "location": "body",
      "description": "Field value"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}