{
  "name": "goals_create",
  "description": "Create a goal.",
  "resource_group": "goals",
  "endpoint": "/api/v2/team/{team_id}/goal",
  "method": "POST",
  "parameters": [
    {
      "name": "team_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Team/workspace ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Goal name",
      "in": "body"
    },
    {
      "name": "due_date",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Due date",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Description",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
