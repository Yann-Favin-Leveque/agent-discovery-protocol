{
  "name": "spaces_create",
  "description": "Create a space.",
  "resource_group": "spaces",
  "endpoint": "/api/v2/team/{team_id}/space",
  "method": "POST",
  "parameters": [
    {
      "name": "team_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Team/workspace ID"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Space name"
    },
    {
      "name": "multiple_assignees",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Allow multiple assignees"
    },
    {
      "name": "features",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Enabled features"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}