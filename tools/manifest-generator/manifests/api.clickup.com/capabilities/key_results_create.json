  "endpoint": "/api/v2/goal/{goal_id}/key_result",
  "method": "POST",
  "parameters": [
    {
      "name": "goal_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Goal ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Key result name",
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Type: number, currency, boolean, percentage, automatic",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
