{
  "name": "tasks_filtered_list",
  "description": "Get filtered tasks across a workspace.",
  "resource_group": "tasks",
  "endpoint": "/api/v2/team/{team_id}/task",
  "method": "GET",
  "parameters": [
    {
      "name": "team_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Team/workspace ID",
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Page number",
      "in": "query"
    },
    {
      "name": "assignees[]",
      "type": "array",
      "required": false,
      "location": "query",
      "description": "Filter by assignee IDs",
      "in": "query"
    },
    {
      "name": "statuses[]",
      "type": "array",
      "required": false,
      "location": "query",
      "description": "Filter by status names",
      "in": "query"
    },
    {
      "name": "project_ids[]",
      "type": "array",
      "required": false,
      "location": "query",
      "description": "Filter by space IDs",
      "in": "query"
    },
    {
      "name": "list_ids[]",
      "type": "array",
      "required": false,
      "location": "query",
      "description": "Filter by list IDs",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
