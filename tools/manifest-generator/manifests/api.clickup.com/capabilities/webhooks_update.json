{
  "name": "webhooks_update",
  "description": "Update a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/api/v2/webhook/{webhook_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Webhook ID",
      "in": "path"
    },
    {
      "name": "endpoint",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New URL",
      "in": "body"
    },
    {
      "name": "events",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "New events",
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "active or inactive",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
