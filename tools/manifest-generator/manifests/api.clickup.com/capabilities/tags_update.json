{
  "name": "tags_update",
  "description": "Update a space tag.",
  "resource_group": "tags",
  "endpoint": "/api/v2/space/{space_id}/tag/{tag_name}",
  "method": "PUT",
  "parameters": [
    {
      "name": "space_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Space ID"
    },
    {
      "name": "tag_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Current tag name"
    },
    {
      "name": "new_name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "New tag name"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}