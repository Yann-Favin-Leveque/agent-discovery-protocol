{
  "name": "time_entries_create",
  "description": "Create a time entry.",
  "resource_group": "time_tracking",
  "endpoint": "/api/v2/team/{team_id}/time_entries",
  "method": "POST",
  "parameters": [
    {
      "name": "team_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Team/workspace ID",
      "in": "path"
    },
    {
      "name": "tid",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Task ID",
      "in": "body"
    },
    {
      "name": "start",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Start time (unix ms)",
      "in": "body"
    },
    {
      "name": "duration",
      "type": "integer",
      "required": true,
      "location": "body",
      "description": "Duration in milliseconds",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
