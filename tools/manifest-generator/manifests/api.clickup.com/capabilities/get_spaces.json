{
  "name": "get_spaces",
  "description": "Retrieve all spaces in a ClickUp workspace (team). Spaces are the top-level organizational unit containing folders and lists. Returns space names, IDs, enabled features (due dates, time tracking, priorities, etc.), and their statuses. You need the team/workspace ID to call this endpoint.",
  "endpoint": "/api/v2/team/{team_id}/space",
  "method": "GET",
  "parameters": [
    {
      "name": "team_id",
      "type": "string",
      "description": "The ID of the workspace/team to list spaces for.",
      "required": true,
      "example": "1234567"
    },
    {
      "name": "archived",
      "type": "boolean",
      "description": "If true, include archived spaces.",
      "required": false,
      "example": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clickup.com/api/v2/team/1234567/space?archived=false",
    "headers": {
      "Authorization": "pk_12345678_ABCDEFGHIJKLMNOP"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "spaces": [
        {
          "id": "789012",
          "name": "Engineering",
          "private": false,
          "color": "#4194f6",
          "avatar": null,
          "admin_can_manage": false,
          "statuses": [
            { "id": "s1", "status": "to do", "type": "open", "orderindex": 0, "color": "#d3d3d3" },
            { "id": "s2", "status": "in progress", "type": "custom", "orderindex": 1, "color": "#4194f6" },
            { "id": "s3", "status": "review", "type": "custom", "orderindex": 2, "color": "#a142f4" },
            { "id": "s4", "status": "complete", "type": "closed", "orderindex": 3, "color": "#6bc950" }
          ],
          "features": {
            "due_dates": { "enabled": true },
            "time_tracking": { "enabled": true },
            "priorities": { "enabled": true },
            "custom_fields": { "enabled": true },
            "tags": { "enabled": true }
          },
          "multiple_assignees": true,
          "archived": false
        },
        {
          "id": "789013",
          "name": "Marketing",
          "private": false,
          "color": "#f4a142",
          "avatar": null,
          "admin_can_manage": false,
          "statuses": [
            { "id": "s5", "status": "open", "type": "open", "orderindex": 0, "color": "#d3d3d3" },
            { "id": "s6", "status": "closed", "type": "closed", "orderindex": 1, "color": "#6bc950" }
          ],
          "features": {
            "due_dates": { "enabled": true },
            "time_tracking": { "enabled": false },
            "priorities": { "enabled": true },
            "custom_fields": { "enabled": false },
            "tags": { "enabled": true }
          },
          "multiple_assignees": true,
          "archived": false
        }
      ]
    }
  }
}
