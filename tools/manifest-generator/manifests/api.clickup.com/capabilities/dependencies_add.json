{
  "name": "dependencies_add",
  "description": "Add a dependency to a task.",
  "resource_group": "dependencies",
  "endpoint": "/api/v2/task/{task_id}/dependency",
  "method": "POST",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID"
    },
    {
      "name": "depends_on",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Task ID this depends on"
    },
    {
      "name": "dependency_of",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Task ID that depends on this"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}