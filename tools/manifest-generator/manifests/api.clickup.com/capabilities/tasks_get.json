{
  "name": "tasks_get",
  "description": "Get a task by ID.",
  "resource_group": "tasks",
  "endpoint": "/api/v2/task/{task_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID"
    },
    {
      "name": "custom_task_ids",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Use custom task IDs"
    },
    {
      "name": "include_subtasks",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Include subtasks"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}