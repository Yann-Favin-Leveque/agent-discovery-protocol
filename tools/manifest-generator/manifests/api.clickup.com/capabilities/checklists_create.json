{
  "name": "checklists_create",
  "description": "Create a checklist on a task.",
  "resource_group": "checklists",
  "endpoint": "/api/v2/task/{task_id}/checklist",
  "method": "POST",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Checklist name",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
