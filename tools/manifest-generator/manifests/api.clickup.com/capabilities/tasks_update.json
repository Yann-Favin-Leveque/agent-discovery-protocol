{
  "name": "tasks_update",
  "description": "Update a task.",
  "resource_group": "tasks",
  "endpoint": "/api/v2/task/{task_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New name"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New description"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New status"
    },
    {
      "name": "priority",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "New priority"
    },
    {
      "name": "due_date",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "New due date"
    },
    {
      "name": "assignees",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Assignees to add/remove"
    },
    {
      "name": "archived",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Archive/unarchive task"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}