{
  "name": "dependencies_delete",
  "description": "Remove a dependency.",
  "resource_group": "dependencies",
  "endpoint": "/api/v2/task/{task_id}/dependency",
  "method": "DELETE",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID"
    },
    {
      "name": "depends_on",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Dependency task ID"
    },
    {
      "name": "dependency_of",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Dependent task ID"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}