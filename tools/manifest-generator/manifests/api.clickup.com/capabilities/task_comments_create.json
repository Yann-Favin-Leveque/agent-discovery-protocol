{
  "name": "task_comments_create",
  "description": "Create a comment on a task.",
  "resource_group": "comments",
  "endpoint": "/api/v2/task/{task_id}/comment",
  "method": "POST",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID",
      "in": "path"
    },
    {
      "name": "comment_text",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Comment text",
      "in": "body"
    },
    {
      "name": "assignee",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "User ID to assign comment to",
      "in": "body"
    },
    {
      "name": "notify_all",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Notify all assignees",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ],
  "request_example": {
    "comment_text": "This looks good!",
    "notify_all": true
  }
}
