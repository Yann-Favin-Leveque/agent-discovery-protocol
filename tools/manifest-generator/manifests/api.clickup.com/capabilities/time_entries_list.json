{
  "name": "time_entries_list",
  "description": "Get time entries in a workspace.",
  "resource_group": "time_tracking",
  "endpoint": "/api/v2/team/{team_id}/time_entries",
  "method": "GET",
  "parameters": [
    {
      "name": "team_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Team/workspace ID",
      "in": "path"
    },
    {
      "name": "start_date",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Start date (unix ms)",
      "in": "query"
    },
    {
      "name": "end_date",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "End date (unix ms)",
      "in": "query"
    },
    {
      "name": "assignee",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "User ID",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "default"
  ]
}
