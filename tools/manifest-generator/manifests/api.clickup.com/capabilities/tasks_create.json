{
  "name": "tasks_create",
  "description": "Create a new task in a list.",
  "resource_group": "tasks",
  "endpoint": "/api/v2/list/{list_id}/task",
  "method": "POST",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "List ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Task name",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Task description",
      "in": "body"
    },
    {
      "name": "assignees",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "Array of assignee user IDs",
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Task status",
      "in": "body"
    },
    {
      "name": "priority",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Priority (1=urgent, 2=high, 3=normal, 4=low)",
      "in": "body"
    },
    {
      "name": "due_date",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Due date in unix milliseconds",
      "in": "body"
    },
    {
      "name": "tags",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "Array of tag names",
      "in": "body"
    },
    {
      "name": "parent",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Parent task ID for subtask",
      "in": "body"
    },
    {
      "name": "custom_fields",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "Custom field values",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "default"
  ],
  "request_example": {
    "name": "New Task",
    "description": "Task description",
    "assignees": [
      123
    ],
    "priority": 2,
    "status": "Open"
  }
}
