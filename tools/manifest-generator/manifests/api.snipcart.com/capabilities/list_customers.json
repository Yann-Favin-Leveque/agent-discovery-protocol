{
  "name": "list_customers",
  "description": "Retrieve a paginated list of customers who have placed orders through Snipcart. Supports filtering by status and date range, and searching by name or email. Returns customer profiles with order statistics and total spend.",
  "endpoint": "/customers",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of customers to return per page (default 20).",
      "required": false,
      "example": 20
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of customers to skip for pagination.",
      "required": false,
      "example": 0
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by customer status: 'Confirmed' or 'Unconfirmed'.",
      "required": false,
      "example": "Confirmed"
    },
    {
      "name": "from",
      "type": "string",
      "description": "Start date filter for customer creation (ISO 8601 format).",
      "required": false,
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "to",
      "type": "string",
      "description": "End date filter for customer creation (ISO 8601 format).",
      "required": false,
      "example": "2024-12-31T23:59:59Z"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/customers?status=Confirmed&limit=20&offset=0",
    "headers": {
      "Authorization": "Basic {base64_encoded_api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "totalItems": 312,
      "offset": 0,
      "limit": 20,
      "items": [
        {
          "id": "cust-uuid-123",
          "email": "bob@example.com",
          "billingAddressName": "Bob Norman",
          "billingAddressAddress1": "123 Main St",
          "billingAddressCity": "Austin",
          "billingAddressProvince": "TX",
          "billingAddressCountry": "US",
          "billingAddressPostalCode": "78701",
          "status": "Confirmed",
          "statistics": {
            "ordersCount": 5,
            "ordersAmount": 1098.50
          },
          "creationDate": "2024-01-02T08:59:11Z",
          "shippingAddressName": "Bob Norman",
          "shippingAddressAddress1": "123 Main St",
          "shippingAddressCity": "Austin",
          "shippingAddressProvince": "TX",
          "shippingAddressCountry": "US",
          "shippingAddressPostalCode": "78701"
        }
      ]
    }
  }
}
