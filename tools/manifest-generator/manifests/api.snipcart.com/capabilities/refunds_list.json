{
  "name": "refunds_list",
  "description": "Retrieve all refunds for an order.",
  "resource_group": "refunds",
  "endpoint": "/orders/{token}/refunds",
  "method": "GET",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "description": "Order token.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/orders/order-uuid/refunds",
    "headers": {
      "Authorization": "Basic {api_key_base64}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "refund-uuid",
        "amount": 15,
        "comment": "Partial refund"
      }
    ]
  }
}
