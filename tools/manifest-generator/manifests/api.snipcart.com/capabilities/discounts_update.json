{
  "name": "discounts_update",
  "description": "Update an existing discount.",
  "resource_group": "discounts",
  "endpoint": "/discounts/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Discount GUID.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name.",
      "in": "body"
    },
    {
      "name": "rate",
      "type": "number",
      "required": false,
      "description": "Updated rate.",
      "in": "body"
    },
    {
      "name": "maxNumberOfUsages",
      "type": "integer",
      "required": false,
      "description": "Updated usage limit.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://app.snipcart.com/api/discounts/disc-uuid",
    "headers": {
      "Authorization": "Basic {api_key_base64}",
      "Content-Type": "application/json"
    },
    "body": {
      "rate": 25
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "disc-uuid",
      "rate": 25
    }
  }
}
