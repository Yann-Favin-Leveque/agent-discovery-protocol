{
  "name": "abandoned_carts_get",
  "description": "Retrieve a specific abandoned cart by token.",
  "resource_group": "carts",
  "endpoint": "/carts/abandoned/{token}",
  "method": "GET",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "description": "Abandoned cart token."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/carts/abandoned/cart-uuid",
    "headers": {
      "Authorization": "Basic {api_key_base64}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "token": "cart-uuid",
      "email": "customer@example.com",
      "total": 45.0,
      "items": [
        {
          "name": "Product A",
          "price": 45.0,
          "quantity": 1
        }
      ]
    }
  }
}