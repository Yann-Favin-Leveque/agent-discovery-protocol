{
  "name": "list_subscriptions",
  "description": "Retrieve a paginated list of active subscriptions managed through Snipcart. Returns subscription details including plan name, recurring amount, billing interval, current status, next billing date, and associated customer information.",
  "endpoint": "/subscriptions",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of subscriptions to return per page (default 20).",
      "required": false,
      "example": 20
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of subscriptions to skip for pagination.",
      "required": false,
      "example": 0
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by subscription status: 'Active', 'Paused', or 'Cancelled'.",
      "required": false,
      "example": "Active"
    },
    {
      "name": "userDefinedPlanName",
      "type": "string",
      "description": "Filter subscriptions by the plan name defined in the product HTML attributes.",
      "required": false,
      "example": "monthly-premium"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/subscriptions?status=Active&limit=20&offset=0",
    "headers": {
      "Authorization": "Basic {base64_encoded_api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "totalItems": 28,
      "offset": 0,
      "limit": 20,
      "items": [
        {
          "id": "sub-uuid-123",
          "name": "Monthly Premium Plan",
          "userDefinedPlanName": "monthly-premium",
          "status": "Active",
          "amount": 29.99,
          "currency": "usd",
          "quantity": 1,
          "interval": "Month",
          "intervalCount": 1,
          "cancelledOn": null,
          "nextBillingDate": "2024-02-10T11:50:00Z",
          "upcomingPaymentDate": "2024-02-10T11:50:00Z",
          "firstInvoiceReceivedOn": "2024-01-10T11:50:00Z",
          "customer": {
            "email": "bob@example.com",
            "billingAddressName": "Bob Norman"
          },
          "initialOrderToken": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "creationDate": "2024-01-10T11:50:00Z"
        }
      ]
    }
  }
}
