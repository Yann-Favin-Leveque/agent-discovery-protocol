{
  "name": "list_orders",
  "description": "Retrieve a paginated list of orders placed through Snipcart. Supports filtering by status, date range, invoice number, and placement source. Returns order summaries including totals, item count, and customer info.",
  "endpoint": "/orders",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of orders to return per page (default 20).",
      "required": false,
      "example": 20
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of orders to skip for pagination.",
      "required": false,
      "example": 0
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by order status: 'InProgress', 'Processed', 'Disputed', 'Shipped', 'Delivered', 'Pending', or 'Cancelled'.",
      "required": false,
      "example": "Processed"
    },
    {
      "name": "invoiceNumber",
      "type": "string",
      "description": "Filter by exact invoice number.",
      "required": false,
      "example": "SNIP-1001"
    },
    {
      "name": "from",
      "type": "string",
      "description": "Start date filter for order placement (ISO 8601 format).",
      "required": false,
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "to",
      "type": "string",
      "description": "End date filter for order placement (ISO 8601 format).",
      "required": false,
      "example": "2024-12-31T23:59:59Z"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/orders?status=Processed&limit=20&offset=0",
    "headers": {
      "Authorization": "Basic {base64_encoded_api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "totalItems": 145,
      "offset": 0,
      "limit": 20,
      "items": [
        {
          "token": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "invoiceNumber": "SNIP-1001",
          "creationDate": "2024-01-10T11:50:00Z",
          "modificationDate": "2024-01-10T12:00:00Z",
          "status": "Processed",
          "paymentStatus": "Paid",
          "email": "bob@example.com",
          "cardHolderName": "Bob Norman",
          "subtotal": 398.00,
          "totalPrice": 409.94,
          "shippingFees": 0,
          "taxesTotal": 11.94,
          "currency": "usd",
          "numberOfItemsInOrder": 2,
          "billingAddress": {
            "fullName": "Bob Norman",
            "address1": "123 Main St",
            "city": "Austin",
            "province": "TX",
            "country": "US",
            "postalCode": "78701"
          }
        }
      ]
    }
  }
}
