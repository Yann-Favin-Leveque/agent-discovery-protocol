{
  "name": "customers_orders_list",
  "description": "Retrieve all orders for a specific customer.",
  "resource_group": "customers",
  "endpoint": "/customers/{id}/orders",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Customer GUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/customers/cust-uuid/orders",
    "headers": {
      "Authorization": "Basic {api_key_base64}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "token": "order-uuid",
        "status": "Processed",
        "invoiceNumber": "SNIP-0001",
        "total": 30.0
      }
    ]
  }
}