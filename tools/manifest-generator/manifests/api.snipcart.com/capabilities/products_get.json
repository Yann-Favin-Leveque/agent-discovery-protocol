{
  "name": "products_get",
  "description": "Retrieve a specific product by ID.",
  "resource_group": "products",
  "endpoint": "/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Product ID or user-defined ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/products/PROD-001",
    "headers": {
      "Authorization": "Basic {api_key_base64}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "userDefinedId": "PROD-001",
      "name": "Product A",
      "price": 30
    }
  }
}
