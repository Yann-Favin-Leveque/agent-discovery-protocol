{
  "name": "customers_get",
  "description": "Retrieve a specific customer by ID.",
  "resource_group": "customers",
  "endpoint": "/customers/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Customer GUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/customers/cust-uuid",
    "headers": {
      "Authorization": "Basic {api_key_base64}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cust-uuid",
      "email": "customer@example.com",
      "billingAddressName": "John Doe"
    }
  }
}
