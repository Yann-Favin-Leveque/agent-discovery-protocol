{
  "name": "orders_list",
  "description": "Retrieve all completed orders with pagination and filtering.",
  "resource_group": "orders",
  "endpoint": "/orders",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Results to skip. Default 0.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results to fetch. Default 20.",
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter: InProgress, Processed, Disputed, Shipped, Delivered, Pending, Cancelled.",
      "in": "query"
    },
    {
      "name": "invoiceNumber",
      "type": "string",
      "required": false,
      "description": "Filter by invoice number.",
      "in": "query"
    },
    {
      "name": "from",
      "type": "string",
      "required": false,
      "description": "Orders placed after this date.",
      "in": "query"
    },
    {
      "name": "to",
      "type": "string",
      "required": false,
      "description": "Orders placed before this date.",
      "in": "query"
    },
    {
      "name": "placedBy",
      "type": "string",
      "required": false,
      "description": "Filter by purchaser name.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.snipcart.com/api/orders?limit=10&status=Processed",
    "headers": {
      "Authorization": "Basic {api_key_base64}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "totalItems": 10,
      "offset": 0,
      "limit": 10,
      "items": [
        {
          "token": "d16e2f60-39f1-4a4c-b1c3-8a2e166d3f70",
          "status": "Processed",
          "invoiceNumber": "SNIP-0001",
          "email": "customer@example.com",
          "creationDate": "2024-01-10T20:36:26.46Z"
        }
      ]
    }
  }
}
