{
  "name": "create_subscription",
  "description": "Create a recurring subscription for a buyer against a pre-defined billing plan. The billing plan must be created first via the Plans API. Subscriptions handle automatic recurring payments, trial periods, setup fees, and subscription lifecycle management. The buyer must approve the subscription before it becomes active.",
  "endpoint": "/v1/billing/subscriptions",
  "method": "POST",
  "parameters": [
    {
      "name": "plan_id",
      "type": "string",
      "description": "The ID of the billing plan to subscribe to. Plans must be created beforehand via the Plans API.",
      "required": true,
      "example": "P-5ML4271244454362XLNWWI"
    },
    {
      "name": "start_time",
      "type": "string",
      "description": "The date and time when the subscription starts in ISO 8601 format. Must be in the future.",
      "required": false,
      "example": "2024-03-01T00:00:00Z"
    },
    {
      "name": "subscriber",
      "type": "object",
      "description": "Information about the subscriber including name, email, and shipping address.",
      "required": false,
      "example": {
        "name": {
          "given_name": "John",
          "surname": "Doe"
        },
        "email_address": "john@example.com",
        "shipping_address": {
          "name": {
            "full_name": "John Doe"
          },
          "address": {
            "address_line_1": "123 Main St",
            "admin_area_2": "San Jose",
            "admin_area_1": "CA",
            "postal_code": "95131",
            "country_code": "US"
          }
        }
      }
    },
    {
      "name": "application_context",
      "type": "object",
      "description": "Customize the subscription approval experience with return URLs, brand name, and payment preferences.",
      "required": false,
      "example": {
        "brand_name": "Acme SaaS",
        "locale": "en-US",
        "shipping_preference": "SET_PROVIDED_ADDRESS",
        "user_action": "SUBSCRIBE_NOW",
        "payment_method": {
          "payer_selected": "PAYPAL",
          "payee_preferred": "IMMEDIATE_PAYMENT_REQUIRED"
        },
        "return_url": "https://example.com/subscription/success",
        "cancel_url": "https://example.com/subscription/cancel"
      }
    },
    {
      "name": "quantity",
      "type": "string",
      "description": "The quantity of the product in the subscription, if the plan supports quantity-based pricing.",
      "required": false,
      "example": "1"
    },
    {
      "name": "custom_id",
      "type": "string",
      "description": "Your own tracking ID for this subscription. Maximum 127 characters.",
      "required": false,
      "example": "sub_acme_pro_john"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v1/billing/subscriptions",
    "headers": {
      "Authorization": "Bearer A21AAF...",
      "Content-Type": "application/json",
      "PayPal-Request-Id": "sub-request-id-202"
    },
    "body": {
      "plan_id": "P-5ML4271244454362XLNWWI",
      "start_time": "2024-03-01T00:00:00Z",
      "subscriber": {
        "name": {
          "given_name": "John",
          "surname": "Doe"
        },
        "email_address": "john@example.com"
      },
      "application_context": {
        "brand_name": "Acme SaaS",
        "user_action": "SUBSCRIBE_NOW",
        "payment_method": {
          "payer_selected": "PAYPAL",
          "payee_preferred": "IMMEDIATE_PAYMENT_REQUIRED"
        },
        "return_url": "https://example.com/subscription/success",
        "cancel_url": "https://example.com/subscription/cancel"
      },
      "custom_id": "sub_acme_pro_john"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "I-BW452GLLEP1G",
      "status": "APPROVAL_PENDING",
      "status_update_time": "2024-02-01T12:00:00Z",
      "plan_id": "P-5ML4271244454362XLNWWI",
      "start_time": "2024-03-01T00:00:00Z",
      "quantity": "1",
      "create_time": "2024-02-01T12:00:00Z",
      "links": [
        {
          "href": "https://www.paypal.com/webapps/billing/subscriptions?ba_token=BA-2M539689YA3312455",
          "rel": "approve",
          "method": "GET"
        },
        {
          "href": "https://api-m.paypal.com/v1/billing/subscriptions/I-BW452GLLEP1G",
          "rel": "edit",
          "method": "PATCH"
        },
        {
          "href": "https://api-m.paypal.com/v1/billing/subscriptions/I-BW452GLLEP1G",
          "rel": "self",
          "method": "GET"
        }
      ]
    }
  }
}
