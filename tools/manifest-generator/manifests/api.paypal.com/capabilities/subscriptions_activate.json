{
  "name": "subscriptions_activate",
  "description": "Activate a suspended subscription.",
  "endpoint": "/v1/billing/subscriptions/{id}/activate",
  "method": "POST",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID",
      "required": true,
      "example": "SUB_ID"
    },
    {
      "name": "reason",
      "type": "string",
      "description": "Reason for activation",
      "required": true,
      "example": "Customer reactivation"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v1/billing/subscriptions/{id}/activate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}