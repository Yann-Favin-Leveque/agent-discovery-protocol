{
  "name": "subscriptions_suspend",
  "description": "Suspend an active subscription.",
  "endpoint": "/v1/billing/subscriptions/{id}/suspend",
  "method": "POST",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID",
      "required": true,
      "example": "SUB_ID",
      "in": "path"
    },
    {
      "name": "reason",
      "type": "string",
      "description": "Reason for suspension",
      "required": true,
      "example": "Customer request",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v1/billing/subscriptions/{id}/suspend",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
