{
  "name": "invoices_generate_qr_code",
  "description": "Generate a QR code for an invoice.",
  "endpoint": "/v2/invoicing/invoices/{invoice_id}/generate-qr-code",
  "method": "POST",
  "resource_group": "invoicing",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "INV2-ID"
    },
    {
      "name": "width",
      "type": "integer",
      "description": "QR code width in pixels",
      "required": false,
      "example": 400
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v2/invoicing/invoices/{invoice_id}/generate-qr-code",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}