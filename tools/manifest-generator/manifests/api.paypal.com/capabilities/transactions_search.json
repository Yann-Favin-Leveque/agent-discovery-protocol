{
  "name": "transactions_search",
  "description": "Search and list transactions with filters for date range, status, and more.",
  "endpoint": "/v1/reporting/transactions",
  "method": "GET",
  "resource_group": "reporting",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "description": "Start date in ISO 8601",
      "required": true,
      "example": "2025-01-01T00:00:00Z"
    },
    {
      "name": "end_date",
      "type": "string",
      "description": "End date in ISO 8601",
      "required": true,
      "example": "2025-01-31T23:59:59Z"
    },
    {
      "name": "transaction_status",
      "type": "string",
      "description": "Transaction status filter",
      "required": false,
      "example": "S"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-m.paypal.com/v1/reporting/transactions",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}