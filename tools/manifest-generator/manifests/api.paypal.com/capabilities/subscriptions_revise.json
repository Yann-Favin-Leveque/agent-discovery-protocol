{
  "name": "subscriptions_revise",
  "description": "Revise a subscription to change quantity or plan.",
  "endpoint": "/v1/billing/subscriptions/{id}/revise",
  "method": "POST",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID",
      "required": true,
      "example": "SUB_ID",
      "in": "path"
    },
    {
      "name": "plan_id",
      "type": "string",
      "description": "New plan ID to switch to",
      "required": false,
      "example": "NEW_PLAN_ID",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v1/billing/subscriptions/{id}/revise",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
