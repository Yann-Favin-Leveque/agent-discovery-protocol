{
  "name": "invoices_delete_refund",
  "description": "Delete an external refund record from an invoice.",
  "endpoint": "/v2/invoicing/invoices/{invoice_id}/refunds/{transaction_id}",
  "method": "DELETE",
  "resource_group": "invoicing",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "INV2-ID",
      "in": "path"
    },
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Transaction ID",
      "required": true,
      "example": "TXN_ID",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api-m.paypal.com/v2/invoicing/invoices/{invoice_id}/refunds/{transaction_id}",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
