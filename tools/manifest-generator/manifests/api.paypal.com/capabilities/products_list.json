{
  "name": "products_list",
  "description": "List catalog products.",
  "endpoint": "/v1/catalogs/products",
  "method": "GET",
  "resource_group": "products",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Items per page",
      "required": false,
      "example": 10,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-m.paypal.com/v1/catalogs/products",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "products": [
        {
          "id": "PROD_ID",
          "name": "Premium Plan"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
