{
  "name": "invoices_search",
  "description": "Search for invoices matching specific criteria.",
  "endpoint": "/v2/invoicing/search-invoices",
  "method": "POST",
  "resource_group": "invoicing",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Recipient email to search for",
      "required": false,
      "example": "buyer@example.com",
      "in": "body"
    },
    {
      "name": "status",
      "type": "array",
      "description": "Invoice statuses to filter",
      "required": false,
      "example": [
        "SENT",
        "PAID"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v2/invoicing/search-invoices",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
