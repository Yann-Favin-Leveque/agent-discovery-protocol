{
  "name": "create_order",
  "description": "Create a new payment order with PayPal. An order represents a payment intent with one or more purchase units (line items). After creation, the buyer must approve the order (via PayPal checkout or hosted fields), then you capture it to finalize the payment. Supports multiple currencies, shipping, tax, and item-level details.",
  "endpoint": "/v2/checkout/orders",
  "method": "POST",
  "parameters": [
    {
      "name": "intent",
      "type": "string",
      "description": "The intent of the payment. 'CAPTURE' to immediately capture after buyer approval. 'AUTHORIZE' to place a hold and capture later.",
      "required": true,
      "example": "CAPTURE"
    },
    {
      "name": "purchase_units",
      "type": "object[]",
      "description": "Array of purchase units. Each unit represents a payment to a payee with an amount, items, and shipping details.",
      "required": true,
      "example": [
        {
          "reference_id": "PUHF",
          "amount": {
            "currency_code": "USD",
            "value": "100.00",
            "breakdown": {
              "item_total": {
                "currency_code": "USD",
                "value": "90.00"
              },
              "shipping": {
                "currency_code": "USD",
                "value": "10.00"
              }
            }
          },
          "items": [
            {
              "name": "T-Shirt",
              "unit_amount": {
                "currency_code": "USD",
                "value": "45.00"
              },
              "quantity": "2",
              "description": "Premium cotton t-shirt",
              "category": "PHYSICAL_GOODS"
            }
          ],
          "shipping": {
            "name": {
              "full_name": "John Doe"
            },
            "address": {
              "address_line_1": "123 Main St",
              "admin_area_2": "San Jose",
              "admin_area_1": "CA",
              "postal_code": "95131",
              "country_code": "US"
            }
          }
        }
      ]
    },
    {
      "name": "payment_source",
      "type": "object",
      "description": "The payment source for the order. Can be 'paypal' for PayPal wallet, 'card' for direct card payment, or other payment methods.",
      "required": false,
      "example": {
        "paypal": {
          "experience_context": {
            "return_url": "https://example.com/return",
            "cancel_url": "https://example.com/cancel",
            "brand_name": "Acme Store",
            "user_action": "PAY_NOW"
          }
        }
      }
    },
    {
      "name": "application_context",
      "type": "object",
      "description": "Customize the buyer's checkout experience with return URLs, brand name, and landing page preference.",
      "required": false,
      "example": {
        "return_url": "https://example.com/return",
        "cancel_url": "https://example.com/cancel",
        "brand_name": "Acme Store",
        "landing_page": "LOGIN",
        "user_action": "PAY_NOW"
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v2/checkout/orders",
    "headers": {
      "Authorization": "Bearer A21AAF...",
      "Content-Type": "application/json",
      "PayPal-Request-Id": "unique-request-id-123"
    },
    "body": {
      "intent": "CAPTURE",
      "purchase_units": [
        {
          "reference_id": "PUHF",
          "amount": {
            "currency_code": "USD",
            "value": "100.00",
            "breakdown": {
              "item_total": {
                "currency_code": "USD",
                "value": "90.00"
              },
              "shipping": {
                "currency_code": "USD",
                "value": "10.00"
              }
            }
          },
          "items": [
            {
              "name": "T-Shirt",
              "unit_amount": {
                "currency_code": "USD",
                "value": "45.00"
              },
              "quantity": "2",
              "description": "Premium cotton t-shirt",
              "category": "PHYSICAL_GOODS"
            }
          ]
        }
      ],
      "payment_source": {
        "paypal": {
          "experience_context": {
            "return_url": "https://example.com/return",
            "cancel_url": "https://example.com/cancel",
            "brand_name": "Acme Store",
            "user_action": "PAY_NOW"
          }
        }
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "5O190127TN364715T",
      "status": "PAYER_ACTION_REQUIRED",
      "links": [
        {
          "href": "https://api-m.paypal.com/v2/checkout/orders/5O190127TN364715T",
          "rel": "self",
          "method": "GET"
        },
        {
          "href": "https://www.paypal.com/checkoutnow?token=5O190127TN364715T",
          "rel": "payer-action",
          "method": "GET"
        },
        {
          "href": "https://api-m.paypal.com/v2/checkout/orders/5O190127TN364715T/capture",
          "rel": "capture",
          "method": "POST"
        }
      ]
    }
  }
}
