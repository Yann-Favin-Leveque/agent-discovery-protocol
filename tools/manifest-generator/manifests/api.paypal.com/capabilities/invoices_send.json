{
  "name": "invoices_send",
  "description": "Send or schedule an invoice to a customer.",
  "endpoint": "/v2/invoicing/invoices/{invoice_id}/send",
  "method": "POST",
  "resource_group": "invoicing",
  "parameters": [
    {
      "name": "invoice_id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "INV2-ID",
      "in": "path"
    },
    {
      "name": "send_to_invoicer",
      "type": "boolean",
      "description": "Send copy to invoicer",
      "required": false,
      "example": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v2/invoicing/invoices/{invoice_id}/send",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
