{
  "name": "payouts_get",
  "description": "Show status of a batch payout by ID.",
  "endpoint": "/v1/payments/payouts/{payout_batch_id}",
  "method": "GET",
  "resource_group": "payouts",
  "parameters": [
    {
      "name": "payout_batch_id",
      "type": "string",
      "description": "Payout batch ID",
      "required": true,
      "example": "PAYOUT_BATCH_ID",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-m.paypal.com/v1/payments/payouts/{payout_batch_id}",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "batch_header": {
        "payout_batch_id": "PAYOUT_BATCH_ID",
        "batch_status": "SUCCESS"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
