{
  "name": "balances_get",
  "description": "List all account balances at a given date/time.",
  "endpoint": "/v1/reporting/balances",
  "method": "GET",
  "resource_group": "reporting",
  "parameters": [
    {
      "name": "as_of_time",
      "type": "string",
      "description": "Date/time for balance snapshot in ISO 8601",
      "required": false,
      "example": "2025-01-31T23:59:59Z",
      "in": "query"
    },
    {
      "name": "currency_code",
      "type": "string",
      "description": "Currency code filter",
      "required": false,
      "example": "USD",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-m.paypal.com/v1/reporting/balances",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
