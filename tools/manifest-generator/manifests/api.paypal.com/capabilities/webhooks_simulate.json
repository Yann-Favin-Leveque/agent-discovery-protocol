{
  "name": "webhooks_simulate",
  "description": "Simulate a webhook event with a sample payload.",
  "endpoint": "/v1/notifications/simulate-event",
  "method": "POST",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "event_type",
      "type": "string",
      "description": "Event type to simulate",
      "required": true,
      "example": "PAYMENT.CAPTURE.COMPLETED"
    },
    {
      "name": "webhook_id",
      "type": "string",
      "description": "Webhook ID to send to",
      "required": false,
      "example": "WH_ID"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v1/notifications/simulate-event",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}