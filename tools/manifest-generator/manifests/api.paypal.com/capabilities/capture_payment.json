{
  "name": "capture_payment",
  "description": "Capture an approved PayPal order to finalize the payment and transfer funds. The order must have been approved by the buyer first (status: APPROVED). You can capture the full amount or specify a partial amount. After capture, the order status changes to COMPLETED and funds are settled to the seller's account.",
  "endpoint": "/v2/checkout/orders/{order_id}/capture",
  "method": "POST",
  "parameters": [
    {
      "name": "order_id",
      "type": "string",
      "description": "The ID of the order to capture (path parameter). This is the order ID returned from the create_order call.",
      "required": true,
      "example": "5O190127TN364715T"
    },
    {
      "name": "payment_source",
      "type": "object",
      "description": "The payment source for the capture. Usually not needed if the buyer already approved via PayPal.",
      "required": false,
      "example": null
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v2/checkout/orders/5O190127TN364715T/capture",
    "headers": {
      "Authorization": "Bearer A21AAF...",
      "Content-Type": "application/json",
      "PayPal-Request-Id": "capture-request-id-456"
    },
    "body": {}
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "5O190127TN364715T",
      "status": "COMPLETED",
      "purchase_units": [
        {
          "reference_id": "PUHF",
          "payments": {
            "captures": [
              {
                "id": "3C679366HH908993F",
                "status": "COMPLETED",
                "amount": {
                  "currency_code": "USD",
                  "value": "100.00"
                },
                "final_capture": true,
                "seller_protection": {
                  "status": "ELIGIBLE",
                  "dispute_categories": ["ITEM_NOT_RECEIVED", "UNAUTHORIZED_TRANSACTION"]
                },
                "create_time": "2024-02-01T12:00:00Z",
                "update_time": "2024-02-01T12:00:00Z"
              }
            ]
          }
        }
      ],
      "payer": {
        "name": {
          "given_name": "John",
          "surname": "Doe"
        },
        "email_address": "john@example.com",
        "payer_id": "QYR5Z8XDVJNXQ"
      }
    }
  }
}
