{
  "name": "orders_get",
  "description": "Show details for an order by ID, including status, purchase units, and payment source.",
  "endpoint": "/v2/checkout/orders/{id}",
  "method": "GET",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Order ID",
      "required": true,
      "example": "ORDER_ID",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-m.paypal.com/v2/checkout/orders/{id}",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ORDER_ID",
      "status": "APPROVED",
      "purchase_units": [
        {
          "amount": {
            "currency_code": "USD",
            "value": "100.00"
          }
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
