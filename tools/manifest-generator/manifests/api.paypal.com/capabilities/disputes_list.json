{
  "name": "disputes_list",
  "description": "List disputes with a summary of details.",
  "endpoint": "/v1/customer/disputes",
  "method": "GET",
  "resource_group": "disputes",
  "parameters": [
    {
      "name": "start_time",
      "type": "string",
      "description": "Start date for filter",
      "required": false,
      "example": "2025-01-01T00:00:00Z"
    },
    {
      "name": "dispute_state",
      "type": "string",
      "description": "Filter by state (OPEN, WAITING, CLOSED)",
      "required": false,
      "example": "OPEN"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-m.paypal.com/v1/customer/disputes",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}