{
  "name": "subscriptions_transactions_list",
  "description": "List transactions for a subscription.",
  "endpoint": "/v1/billing/subscriptions/{id}/transactions",
  "method": "GET",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscription ID",
      "required": true,
      "example": "SUB_ID",
      "in": "path"
    },
    {
      "name": "start_time",
      "type": "string",
      "description": "Start date in ISO 8601",
      "required": true,
      "example": "2025-01-01T00:00:00Z",
      "in": "query"
    },
    {
      "name": "end_time",
      "type": "string",
      "description": "End date in ISO 8601",
      "required": true,
      "example": "2025-12-31T23:59:59Z",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-m.paypal.com/v1/billing/subscriptions/{id}/transactions",
    "headers": {
      "Authorization": "Bearer {access_token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
