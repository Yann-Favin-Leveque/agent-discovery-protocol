{
  "name": "disputes_escalate",
  "description": "Escalate a dispute to a PayPal claim.",
  "endpoint": "/v1/customer/disputes/{id}/escalate",
  "method": "POST",
  "resource_group": "disputes",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Dispute ID",
      "required": true,
      "example": "DISPUTE_ID",
      "in": "path"
    },
    {
      "name": "note",
      "type": "string",
      "description": "Escalation note",
      "required": true,
      "example": "Unresolved issue",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-m.paypal.com/v1/customer/disputes/{id}/escalate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
