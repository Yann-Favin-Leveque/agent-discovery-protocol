{
  "name": "generate_embeddings",
  "description": "Generate dense vector embeddings for text inputs using Mistral's embedding models. These embeddings can be used for semantic search, document clustering, classification, and building retrieval-augmented generation systems.",
  "endpoint": "/v1/embeddings",
  "method": "POST",
  "parameters": [
    {
      "name": "model",
      "type": "string",
      "description": "The embedding model ID to use.",
      "required": true,
      "example": "mistral-embed"
    },
    {
      "name": "input",
      "type": "array",
      "description": "Array of text strings to generate embeddings for.",
      "required": true,
      "example": ["What is machine learning?", "Deep learning is a subset of ML."]
    },
    {
      "name": "encoding_format",
      "type": "string",
      "description": "Output encoding format: 'float' or 'base64'.",
      "required": false,
      "example": "float"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mistral.ai/v1/embeddings",
    "headers": {
      "Authorization": "Bearer your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "mistral-embed",
      "input": ["What is machine learning?"]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "emb-abc123",
      "object": "list",
      "data": [
        {
          "object": "embedding",
          "embedding": [0.123, -0.456, 0.789, "...(1024 dimensions)"],
          "index": 0
        }
      ],
      "model": "mistral-embed",
      "usage": {
        "prompt_tokens": 8,
        "total_tokens": 8
      }
    }
  }
}
