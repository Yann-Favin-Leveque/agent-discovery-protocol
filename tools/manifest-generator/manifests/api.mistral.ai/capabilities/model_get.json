{
  "name": "model_get",
  "description": "Retrieve information about a specific Mistral model by its ID.",
  "resource_group": "models",
  "endpoint": "/v1/models/{model_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "model_id",
      "type": "string",
      "required": true,
      "description": "Model ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mistral.ai/v1/models/mistral-large-latest",
    "headers": {
      "Authorization": "Bearer mk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "mistral-large-latest",
      "object": "model",
      "created": 1709164800,
      "owned_by": "mistralai"
    }
  }
}
