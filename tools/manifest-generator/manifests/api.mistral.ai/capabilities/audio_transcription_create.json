{
  "name": "audio_transcription_create",
  "description": "Convert audio to text using Mistral's speech recognition model. Supports streaming via SSE.",
  "resource_group": "audio",
  "endpoint": "/v1/audio/transcriptions",
  "method": "POST",
  "parameters": [
    {
      "name": "file",
      "type": "file",
      "required": true,
      "description": "Audio file to transcribe.",
      "in": "body"
    },
    {
      "name": "model",
      "type": "string",
      "required": true,
      "description": "Transcription model ID.",
      "in": "body"
    },
    {
      "name": "language",
      "type": "string",
      "required": false,
      "description": "Language code.",
      "in": "body"
    },
    {
      "name": "response_format",
      "type": "string",
      "required": false,
      "description": "Output format.",
      "in": "body"
    },
    {
      "name": "temperature",
      "type": "number",
      "required": false,
      "description": "Sampling temperature.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mistral.ai/v1/audio/transcriptions",
    "headers": {
      "Authorization": "Bearer mk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    },
    "body": "multipart/form-data: file=@audio.mp3&model=mistral-audio-latest"
  },
  "response_example": {
    "status": 200,
    "body": {
      "text": "Hello, this is a test recording."
    }
  }
}
