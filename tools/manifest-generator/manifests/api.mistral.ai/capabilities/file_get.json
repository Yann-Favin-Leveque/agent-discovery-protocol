{
  "name": "file_get",
  "description": "Retrieve metadata about a specific uploaded file.",
  "resource_group": "files",
  "endpoint": "/v1/files/{file_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "required": true,
      "description": "File ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mistral.ai/v1/files/file-abc123",
    "headers": {
      "Authorization": "Bearer mk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "file-abc123",
      "object": "file",
      "bytes": 175234,
      "filename": "data.jsonl"
    }
  }
}
