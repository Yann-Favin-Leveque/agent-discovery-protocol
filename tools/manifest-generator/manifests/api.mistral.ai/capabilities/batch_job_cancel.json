{
  "name": "batch_job_cancel",
  "description": "Cancel an in-progress batch job.",
  "resource_group": "batch",
  "endpoint": "/v1/batch/jobs/{job_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "job_id",
      "type": "string",
      "required": true,
      "description": "Batch job ID to cancel.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mistral.ai/v1/batch/jobs/batch-abc123/cancel",
    "headers": {
      "Authorization": "Bearer mk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "batch-abc123",
      "status": "cancelled"
    }
  }
}
