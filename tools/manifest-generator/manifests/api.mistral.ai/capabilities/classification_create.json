{
  "name": "classification_create",
  "description": "Classify text into categories using Mistral's classification models.",
  "resource_group": "classifiers",
  "endpoint": "/v1/classifications",
  "method": "POST",
  "parameters": [
    {"name": "model", "type": "string", "required": false, "description": "Classification model ID."},
    {"name": "input", "type": "string or array", "required": true, "description": "Text or texts to classify."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mistral.ai/v1/classifications",
    "headers": {"Authorization": "Bearer mk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx", "Content-Type": "application/json"},
    "body": {"input": "This product is amazing!"}
  },
  "response_example": {"status": 200, "body": {"id": "cls-abc123", "results": [{"categories": {"positive": true, "negative": false}}]}}
}
