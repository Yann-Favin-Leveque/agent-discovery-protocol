{
  "name": "send_password_reset",
  "description": "Send a password reset email to the specified email address. Contains a link that redirects the user to reset their password.",
  "endpoint": "/auth/v1/recover",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "The email address to send the password reset to.",
      "required": true,
      "example": "user@example.com",
      "in": "body"
    },
    {
      "name": "redirect_to",
      "type": "string",
      "description": "URL to redirect to after password reset.",
      "required": false,
      "example": "https://example.com/reset-password",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-project.supabase.co/auth/v1/recover",
    "headers": {
      "apikey": "{anon_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "redirect_to": "https://example.com/reset-password"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
