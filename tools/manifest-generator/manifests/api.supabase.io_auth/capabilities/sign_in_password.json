{
  "name": "sign_in_password",
  "description": "Sign in an existing user with email/password or phone/password. Returns a session with JWT access token and refresh token.",
  "endpoint": "/auth/v1/token?grant_type=password",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "User email address. Required if phone is not provided.",
      "required": false,
      "example": "user@example.com",
      "in": "body"
    },
    {
      "name": "password",
      "type": "string",
      "description": "User password.",
      "required": true,
      "example": "securePassword123",
      "in": "body"
    },
    {
      "name": "phone",
      "type": "string",
      "description": "User phone number. Required if email is not provided.",
      "required": false,
      "example": "+1234567890",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-project.supabase.co/auth/v1/token?grant_type=password",
    "headers": {
      "apikey": "{anon_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "password": "securePassword123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "access_token": "eyJhbGciOiJIUzI1NiIs...",
      "token_type": "bearer",
      "expires_in": 3600,
      "refresh_token": "abc123-refresh",
      "user": {
        "id": "uuid-1234",
        "email": "user@example.com",
        "email_confirmed_at": "2024-01-15T10:05:00Z",
        "last_sign_in_at": "2024-01-15T10:00:00Z"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
