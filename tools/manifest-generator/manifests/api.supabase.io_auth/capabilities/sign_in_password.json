{
  "name": "sign_in_password",
  "description": "Sign in an existing user with their email and password. Returns a session containing a JWT access token (short-lived) and a refresh token (long-lived, single-use). The access token should be included in subsequent API requests as a Bearer token.",
  "endpoint": "/token?grant_type=password",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "password",
      "type": "string",
      "description": "The user's password.",
      "required": true,
      "example": "securepassword123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-project.supabase.co/auth/v1/token?grant_type=password",
    "headers": {
      "apikey": "YOUR_SUPABASE_ANON_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "password": "securepassword123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
      "token_type": "bearer",
      "expires_in": 3600,
      "expires_at": 1709319000,
      "refresh_token": "v1.MjAyNi0wMy0wMVQxMjowMDowMC...",
      "user": {
        "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "email": "user@example.com",
        "email_confirmed_at": "2026-03-01T12:00:00.000Z",
        "role": "authenticated"
      }
    }
  }
}
