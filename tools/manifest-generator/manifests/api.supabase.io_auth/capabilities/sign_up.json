{
  "name": "sign_up",
  "description": "Create a new user account with email and password. Returns the user object with a confirmation status and, if email confirmation is disabled, a full session with access and refresh tokens. Custom user metadata can be provided at signup time.",
  "endpoint": "/signup",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "password",
      "type": "string",
      "description": "The user's password. Minimum 6 characters by default.",
      "required": true,
      "example": "securepassword123"
    },
    {
      "name": "data",
      "type": "object",
      "description": "Custom user metadata to store with the user profile.",
      "required": false,
      "example": { "first_name": "Jane", "age": 30 }
    },
    {
      "name": "gotrue_meta_security",
      "type": "object",
      "description": "Security metadata including captcha_token for bot protection.",
      "required": false,
      "example": { "captcha_token": "token_value" }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-project.supabase.co/auth/v1/signup",
    "headers": {
      "apikey": "YOUR_SUPABASE_ANON_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "password": "securepassword123",
      "data": { "first_name": "Jane" }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "aud": "authenticated",
      "role": "authenticated",
      "email": "user@example.com",
      "email_confirmed_at": null,
      "confirmation_sent_at": "2026-03-01T12:00:00.000Z",
      "created_at": "2026-03-01T12:00:00.000Z",
      "updated_at": "2026-03-01T12:00:00.000Z",
      "user_metadata": { "first_name": "Jane" },
      "app_metadata": { "provider": "email" }
    }
  }
}
