{
  "name": "get_user",
  "description": "Retrieve the currently authenticated user's profile using their JWT access token. Returns email, metadata, and identity providers.",
  "endpoint": "/auth/v1/user",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {
      "name": "Authorization",
      "type": "string",
      "description": "Bearer token (JWT access token) in the Authorization header.",
      "required": true,
      "example": "Bearer eyJhbGciOiJIUzI1NiIs..."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://your-project.supabase.co/auth/v1/user",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer eyJhbGciOiJIUzI1NiIs..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "uuid-1234",
      "aud": "authenticated",
      "role": "authenticated",
      "email": "user@example.com",
      "email_confirmed_at": "2024-01-15T10:05:00Z",
      "phone": "",
      "last_sign_in_at": "2024-01-15T10:00:00Z",
      "app_metadata": {"provider": "email", "providers": ["email"]},
      "user_metadata": {"first_name": "John"},
      "identities": [
        {
          "id": "uuid-1234",
          "user_id": "uuid-1234",
          "identity_data": {"email": "user@example.com"},
          "provider": "email",
          "created_at": "2024-01-15T10:00:00Z"
        }
      ],
      "created_at": "2024-01-15T10:00:00Z",
      "updated_at": "2024-01-15T10:05:00Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 150
  }
}