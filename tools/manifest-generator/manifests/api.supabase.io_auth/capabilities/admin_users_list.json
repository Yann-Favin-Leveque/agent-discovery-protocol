{
  "name": "admin_users_list",
  "description": "List all users in the project. Requires service_role key. Returns paginated user list with profiles and metadata.",
  "endpoint": "/auth/v1/admin/users",
  "method": "GET",
  "resource_group": "admin",
  "parameters": [
    {
      "name": "Authorization",
      "type": "string",
      "description": "Bearer token with service_role key.",
      "required": true,
      "example": "Bearer {service_role_key}"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for pagination.",
      "required": false,
      "example": 1
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Number of users per page.",
      "required": false,
      "example": 50
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://your-project.supabase.co/auth/v1/admin/users?page=1&per_page=50",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer {service_role_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "aud": "authenticated",
      "users": [
        {
          "id": "uuid-1234",
          "email": "user@example.com",
          "email_confirmed_at": "2024-01-15T10:05:00Z",
          "created_at": "2024-01-15T10:00:00Z",
          "last_sign_in_at": "2024-01-20T08:00:00Z",
          "user_metadata": {"first_name": "John"}
        }
      ]
    }
  },
  "auth_scopes": ["service_role"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}