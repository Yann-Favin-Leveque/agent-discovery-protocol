{
  "name": "admin_user_get",
  "description": "Retrieve a specific user by their ID. Requires service_role key. Returns full user profile with metadata and identities.",
  "endpoint": "/auth/v1/admin/users/{user_id}",
  "method": "GET",
  "resource_group": "admin",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "The user's UUID.",
      "required": true,
      "example": "uuid-1234",
      "in": "path"
    },
    {
      "name": "Authorization",
      "type": "string",
      "description": "Bearer token with service_role key.",
      "required": true,
      "example": "Bearer {service_role_key}",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://your-project.supabase.co/auth/v1/admin/users/uuid-1234",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer {service_role_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "uuid-1234",
      "email": "user@example.com",
      "email_confirmed_at": "2024-01-15T10:05:00Z",
      "phone": "",
      "created_at": "2024-01-15T10:00:00Z",
      "last_sign_in_at": "2024-01-20T08:00:00Z",
      "app_metadata": {
        "provider": "email"
      },
      "user_metadata": {
        "first_name": "John"
      },
      "identities": []
    }
  },
  "auth_scopes": [
    "service_role"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
