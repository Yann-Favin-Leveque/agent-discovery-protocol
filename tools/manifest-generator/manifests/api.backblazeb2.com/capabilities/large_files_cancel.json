{
  "name": "large_files_cancel",
  "description": "Cancel a large file upload and delete all uploaded parts.",
  "resource_group": "large_files",
  "endpoint": "/b2api/v3/b2_cancel_large_file",
  "method": "POST",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "Large file ID.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_cancel_large_file",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "fileId": "largefile123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "fileId": "largefile123"
    }
  }
}
