{
  "name": "buckets_update",
  "description": "Update a bucket's settings.",
  "resource_group": "buckets",
  "endpoint": "/b2api/v3/b2_update_bucket",
  "method": "POST",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "description": "Your account ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "bucketId",
      "type": "string",
      "description": "The bucket ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "bucketType",
      "type": "string",
      "description": "Updated type.",
      "required": false,
      "in": "body"
    },
    {
      "name": "bucketInfo",
      "type": "object",
      "description": "Updated info.",
      "required": false,
      "in": "body"
    },
    {
      "name": "corsRules",
      "type": "array",
      "description": "Updated CORS rules.",
      "required": false,
      "in": "body"
    },
    {
      "name": "lifecycleRules",
      "type": "array",
      "description": "Updated lifecycle rules.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_update_bucket",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "accountId": "abc123",
      "bucketId": "bucket123",
      "bucketType": "allPublic"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "bucketId": "bucket123",
      "bucketType": "allPublic"
    }
  }
}
