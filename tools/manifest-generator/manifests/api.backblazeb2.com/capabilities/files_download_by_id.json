{
  "name": "files_download_by_id",
  "description": "Download a file by its file ID.",
  "resource_group": "files",
  "endpoint": "/b2api/v3/b2_download_file_by_id",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "{downloadUrl}/b2api/v3/b2_download_file_by_id?fileId=file123",
    "headers": {
      "Authorization": "{authorizationToken}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "<binary file content>"
  }
}