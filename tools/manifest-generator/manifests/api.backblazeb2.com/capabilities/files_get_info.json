{
  "name": "files_get_info",
  "description": "Get info about a specific file version.",
  "resource_group": "files",
  "endpoint": "/b2api/v3/b2_get_file_info",
  "method": "POST",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_get_file_info",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "fileId": "file123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "fileId": "file123",
      "fileName": "test/file.txt",
      "contentLength": 1234,
      "contentType": "text/plain"
    }
  }
}
