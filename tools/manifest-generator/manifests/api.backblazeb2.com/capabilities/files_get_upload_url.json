{
  "name": "files_get_upload_url",
  "description": "Get a URL and token for uploading files to a bucket.",
  "resource_group": "files",
  "endpoint": "/b2api/v3/b2_get_upload_url",
  "method": "POST",
  "parameters": [
    {
      "name": "bucketId",
      "type": "string",
      "description": "The bucket ID.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_get_upload_url",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "bucketId": "bucket123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uploadUrl": "https://pod-000-1015-05.backblaze.com/b2api/v3/b2_upload_file/bucket123/...",
      "authorizationToken": "upload-token-123"
    }
  }
}
