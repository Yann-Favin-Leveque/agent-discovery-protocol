{
  "name": "files_delete_version",
  "description": "Delete a specific version of a file.",
  "resource_group": "files",
  "endpoint": "/b2api/v3/b2_delete_file_version",
  "method": "POST",
  "parameters": [
    {
      "name": "fileName",
      "type": "string",
      "description": "The file name.",
      "required": true,
      "in": "body"
    },
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_delete_file_version",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "fileName": "test/file.txt",
      "fileId": "file123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "fileId": "file123",
      "fileName": "test/file.txt"
    }
  }
}
