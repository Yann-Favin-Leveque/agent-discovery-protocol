{
  "name": "keys_delete",
  "description": "Delete an application key.",
  "resource_group": "keys",
  "endpoint": "/b2api/v3/b2_delete_key",
  "method": "POST",
  "parameters": [
    {
      "name": "applicationKeyId",
      "type": "string",
      "description": "The key ID to delete.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_delete_key",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "applicationKeyId": "key123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "keyId": "key123"
    }
  }
}