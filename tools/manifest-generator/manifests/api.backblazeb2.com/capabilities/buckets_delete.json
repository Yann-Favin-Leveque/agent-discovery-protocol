{
  "name": "buckets_delete",
  "description": "Delete an empty bucket.",
  "resource_group": "buckets",
  "endpoint": "/b2api/v3/b2_delete_bucket",
  "method": "POST",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "description": "Your account ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "bucketId",
      "type": "string",
      "description": "The bucket ID.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_delete_bucket",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "accountId": "abc123",
      "bucketId": "bucket123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "bucketId": "bucket123"
    }
  }
}
