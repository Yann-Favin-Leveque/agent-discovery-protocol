{
  "name": "keys_list",
  "description": "List all application keys.",
  "resource_group": "keys",
  "endpoint": "/b2api/v3/b2_list_keys",
  "method": "POST",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "description": "Account ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "maxKeyCount",
      "type": "integer",
      "description": "Max keys to return.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_list_keys",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "accountId": "abc123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "keys": [
        {
          "keyId": "key123",
          "keyName": "my-app-key"
        }
      ]
    }
  }
}
