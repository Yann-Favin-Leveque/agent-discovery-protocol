{
  "name": "large_files_get_upload_part_url",
  "description": "Get a URL for uploading a part of a large file.",
  "resource_group": "large_files",
  "endpoint": "/b2api/v3/b2_get_upload_part_url",
  "method": "POST",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "Large file ID from start_large_file.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_get_upload_part_url",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "fileId": "largefile123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uploadUrl": "https://...",
      "authorizationToken": "part-token"
    }
  }
}
