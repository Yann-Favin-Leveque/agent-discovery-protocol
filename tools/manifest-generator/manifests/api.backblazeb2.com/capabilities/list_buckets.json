{
  "name": "list_buckets",
  "description": "List all storage buckets in your Backblaze B2 account, including their IDs, names, types, and lifecycle rules. Optionally filter by bucket name or ID.",
  "endpoint": "/b2api/v3/b2_list_buckets",
  "method": "POST",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "description": "Your Backblaze B2 account ID.",
      "required": true,
      "example": "010203040506"
    },
    {
      "name": "bucketId",
      "type": "string",
      "description": "Optional. If specified, only return information about this specific bucket.",
      "required": false,
      "example": "4a48fe8875c6214145260818"
    },
    {
      "name": "bucketName",
      "type": "string",
      "description": "Optional. If specified, only return the bucket with this name.",
      "required": false,
      "example": "my-app-backups-2026"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.backblazeb2.com/b2api/v3/b2_list_buckets",
    "headers": {
      "Authorization": "your-account-authorization-token",
      "Content-Type": "application/json"
    },
    "body": {
      "accountId": "010203040506"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "buckets": [
        {
          "accountId": "010203040506",
          "bucketId": "4a48fe8875c6214145260818",
          "bucketName": "my-app-backups-2026",
          "bucketType": "allPrivate",
          "lifecycleRules": [],
          "revision": 1,
          "options": []
        },
        {
          "accountId": "010203040506",
          "bucketId": "5b59gf9986d7325256371929",
          "bucketName": "public-assets",
          "bucketType": "allPublic",
          "lifecycleRules": [],
          "revision": 3,
          "options": []
        }
      ]
    }
  }
}
