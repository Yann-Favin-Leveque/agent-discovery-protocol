{
  "name": "files_download_by_name",
  "description": "Download a file by its name and bucket.",
  "resource_group": "files",
  "endpoint": "/file/{bucketName}/{fileName}",
  "method": "GET",
  "parameters": [
    {
      "name": "bucketName",
      "type": "string",
      "description": "The bucket name.",
      "required": true
    },
    {
      "name": "fileName",
      "type": "string",
      "description": "The file name.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "{downloadUrl}/file/my-bucket/test/file.txt",
    "headers": {
      "Authorization": "{authorizationToken}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "<binary file content>"
  }
}