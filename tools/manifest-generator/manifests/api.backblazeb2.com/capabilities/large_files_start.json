{
  "name": "large_files_start",
  "description": "Start a large file upload session.",
  "resource_group": "large_files",
  "endpoint": "/b2api/v3/b2_start_large_file",
  "method": "POST",
  "parameters": [
    {
      "name": "bucketId",
      "type": "string",
      "description": "The bucket ID.",
      "required": true
    },
    {
      "name": "fileName",
      "type": "string",
      "description": "File name.",
      "required": true
    },
    {
      "name": "contentType",
      "type": "string",
      "description": "MIME type.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "{apiUrl}/b2api/v3/b2_start_large_file",
    "headers": {
      "Authorization": "{authorizationToken}",
      "Content-Type": "application/json"
    },
    "body": {
      "bucketId": "bucket123",
      "fileName": "large-file.zip",
      "contentType": "application/zip"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "fileId": "largefile123"
    }
  }
}