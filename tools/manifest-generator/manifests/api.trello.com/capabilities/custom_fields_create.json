{
  "name": "custom_fields_create",
  "description": "Create a custom field on a board.",
  "resource_group": "custom_fields",
  "endpoint": "/customFields",
  "method": "POST",
  "parameters": [
    {
      "name": "idModel",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Board ID"
    },
    {
      "name": "modelType",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Must be 'board'"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Field name"
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Field type: checkbox, date, list, number, text"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}