{
  "name": "cards_actions_list",
  "description": "List actions/activity on a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/actions",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card",
      "in": "path"
    },
    {
      "name": "filter",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter by action type",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
