{
  "name": "search",
  "description": "Search for boards, cards, members, and organizations.",
  "resource_group": "search",
  "endpoint": "/search",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Search query"
    },
    {
      "name": "modelTypes",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated types: actions,boards,cards,members,organizations"
    },
    {
      "name": "board_fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Board fields to include"
    },
    {
      "name": "cards_limit",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Max cards to return"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}