{
  "name": "cards_attachments_create",
  "description": "Add an attachment to a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/attachments",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Attachment name",
      "in": "body"
    },
    {
      "name": "url",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "URL to attach",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
