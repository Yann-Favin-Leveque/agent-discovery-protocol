{
  "name": "lists_update",
  "description": "Update a list.",
  "resource_group": "lists",
  "endpoint": "/lists/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the list"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New list name"
    },
    {
      "name": "closed",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Archive/unarchive"
    },
    {
      "name": "pos",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New position"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}