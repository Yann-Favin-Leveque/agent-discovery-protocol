{
  "name": "lists_update",
  "description": "Update a list.",
  "resource_group": "lists",
  "endpoint": "/lists/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the list",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New list name",
      "in": "body"
    },
    {
      "name": "closed",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Archive/unarchive",
      "in": "body"
    },
    {
      "name": "pos",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New position",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
