{
  "name": "boards_lists_filter",
  "description": "Get filtered lists on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/lists/{filter}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board"
    },
    {
      "name": "filter",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Filter: all, closed, none, open"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}