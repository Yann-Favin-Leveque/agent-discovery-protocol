{
  "name": "boards_update",
  "description": "Update a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New name",
      "in": "body"
    },
    {
      "name": "desc",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New description",
      "in": "body"
    },
    {
      "name": "closed",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Archive/unarchive board",
      "in": "body"
    },
    {
      "name": "prefs/permissionLevel",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Permission level",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
