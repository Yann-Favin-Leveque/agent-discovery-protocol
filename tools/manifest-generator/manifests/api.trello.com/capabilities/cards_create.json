{
  "name": "cards_create",
  "description": "Create a new card.",
  "resource_group": "cards",
  "endpoint": "/cards",
  "method": "POST",
  "parameters": [
    {
      "name": "idList",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "ID of the list to create the card in",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Card name",
      "in": "body"
    },
    {
      "name": "desc",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Card description",
      "in": "body"
    },
    {
      "name": "pos",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Position: top, bottom, or number",
      "in": "body"
    },
    {
      "name": "due",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Due date",
      "in": "body"
    },
    {
      "name": "idMembers",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated member IDs",
      "in": "body"
    },
    {
      "name": "idLabels",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated label IDs",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "request_example": {
    "idList": "list-id",
    "name": "New Task",
    "desc": "Task description"
  }
}
