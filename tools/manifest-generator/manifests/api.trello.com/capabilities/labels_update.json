{
  "name": "labels_update",
  "description": "Update a label.",
  "resource_group": "labels",
  "endpoint": "/labels/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Label ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New name",
      "in": "body"
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New color",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
