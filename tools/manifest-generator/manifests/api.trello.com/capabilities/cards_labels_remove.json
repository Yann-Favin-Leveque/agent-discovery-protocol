{
  "name": "cards_labels_remove",
  "description": "Remove a label from a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/labels/{color}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card"
    },
    {
      "name": "color",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Label color to remove"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}