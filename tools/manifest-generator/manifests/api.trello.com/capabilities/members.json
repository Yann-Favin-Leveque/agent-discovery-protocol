{
  "name": "members",
  "description": "Manage members — upload new boardbackground for member, create star for board, create a new custom board background. Supports standard CRUD operations through the REST API.",
  "endpoint": "/members/{id}/boardBackgrounds",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The ID or username of the member",
      "required": true,
      "example": "abc_123"
    },
    {
      "name": "file",
      "type": "string",
      "description": "The file parameter.",
      "required": true,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.trello.com/1/members/{id}/boardBackgrounds",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "id": "abc_123",
      "file": "example_value"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "id": "abc_123",
        "file": "example_value"
      }
    }
  }
}
