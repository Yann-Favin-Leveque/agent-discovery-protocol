{
  "name": "boards_members_invite",
  "description": "Invite a member to a board by email.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/members",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Email address to invite",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
