{
  "name": "boards_cards_list",
  "description": "List all cards on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/cards",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Card fields to include"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}