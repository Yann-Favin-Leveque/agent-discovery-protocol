{
  "name": "boards_lists_list",
  "description": "List all lists on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/lists",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "filter",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter: all, closed, none, open",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
