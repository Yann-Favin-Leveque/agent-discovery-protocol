{
  "name": "lists_create",
  "description": "Create a new list.",
  "resource_group": "lists",
  "endpoint": "/lists",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "List name",
      "in": "body"
    },
    {
      "name": "idBoard",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Board ID",
      "in": "body"
    },
    {
      "name": "pos",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Position",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
