{
  "name": "boards_lists_create",
  "description": "Create a new list on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/lists",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "List name"
    },
    {
      "name": "pos",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Position: top, bottom, or positive number"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}