{
  "name": "lists_field_get",
  "description": "Get a specific field of a list.",
  "resource_group": "lists",
  "endpoint": "/lists/{id}/{field}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the list",
      "in": "path"
    },
    {
      "name": "field",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Field name",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
