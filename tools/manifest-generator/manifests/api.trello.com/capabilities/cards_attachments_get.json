{
  "name": "cards_attachments_get",
  "description": "Get a specific attachment on a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/attachments/{idAttachment}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card"
    },
    {
      "name": "idAttachment",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Attachment ID"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}