{
  "name": "boards_create",
  "description": "Create a new board.",
  "resource_group": "boards",
  "endpoint": "/boards/",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Board name",
      "in": "body"
    },
    {
      "name": "defaultLabels",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Create default labels",
      "in": "body"
    },
    {
      "name": "defaultLists",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Create default lists",
      "in": "body"
    },
    {
      "name": "desc",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Board description",
      "in": "body"
    },
    {
      "name": "idOrganization",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Organization ID",
      "in": "body"
    },
    {
      "name": "prefs_permissionLevel",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Permission level (private, org, public)",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "request_example": {
    "name": "My Board",
    "defaultLists": true
  }
}
