{
  "name": "labels",
  "description": "Manage labels — create a label, update a label, update a field on a label. Supports standard CRUD operations through the REST API.",
  "endpoint": "/labels",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Name for the label",
      "required": true,
      "example": "Example"
    },
    {
      "name": "color",
      "type": "string",
      "description": "The color for the label.",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "idBoard",
      "type": "string",
      "description": "The ID of the Board to create the Label on.",
      "required": true,
      "example": "abc_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.trello.com/1/labels",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "name": "Example",
      "color": "example_value",
      "idBoard": "abc_123"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "name": "Example",
        "color": "example_value",
        "idBoard": "abc_123"
      }
    }
  }
}
