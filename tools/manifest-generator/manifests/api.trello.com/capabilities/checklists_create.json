{
  "name": "checklists_create",
  "description": "Create a new checklist.",
  "resource_group": "checklists",
  "endpoint": "/checklists",
  "method": "POST",
  "parameters": [
    {
      "name": "idCard",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Card ID",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Checklist name",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
