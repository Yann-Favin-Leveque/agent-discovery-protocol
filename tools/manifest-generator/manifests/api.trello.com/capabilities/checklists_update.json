  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Checklist ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New name",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
