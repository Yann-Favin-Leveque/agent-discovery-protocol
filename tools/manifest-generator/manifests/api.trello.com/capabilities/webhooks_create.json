{
  "name": "webhooks_create",
  "description": "Create a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/tokens/{token}/webhooks",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "API token",
      "in": "path"
    },
    {
      "name": "callbackURL",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Callback URL",
      "in": "body"
    },
    {
      "name": "idModel",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Model ID to watch",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Webhook description",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
