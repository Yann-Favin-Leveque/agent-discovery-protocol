{
  "name": "boards_members_add",
  "description": "Add an existing member to a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/members/{idMember}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "idMember",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Member ID",
      "in": "path"
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Member type: admin, normal, observer",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
