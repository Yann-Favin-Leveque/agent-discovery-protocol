{
  "name": "cards_field_get",
  "description": "Get a specific field of a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/{field}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card"
    },
    {
      "name": "field",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The field name"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}