{
  "name": "cards_custom_field_items_update",
  "description": "Update a custom field value on a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/customFieldItems/{idCustomField}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card"
    },
    {
      "name": "idCustomField",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Custom field ID"
    },
    {
      "name": "value",
      "type": "object",
      "required": true,
      "location": "body",
      "description": "New value for the custom field"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}