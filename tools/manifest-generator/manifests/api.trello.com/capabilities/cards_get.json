{
  "name": "cards_get",
  "description": "Get a card by ID.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Card fields to include"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}