{
  "name": "boards_cards_filter",
  "description": "Get filtered cards on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/cards/{filter}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "filter",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Filter: all, closed, none, open, visible",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
