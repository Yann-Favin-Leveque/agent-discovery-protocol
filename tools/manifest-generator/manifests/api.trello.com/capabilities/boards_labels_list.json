{
  "name": "boards_labels_list",
  "description": "List labels on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/labels",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Max labels to return",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
