{
  "name": "cards_checklists_create",
  "description": "Add a checklist to a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/checklists",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Checklist name",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
