{
  "name": "cards_stickers_create",
  "description": "Add a sticker to a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}/stickers",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card",
      "in": "path"
    },
    {
      "name": "image",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Sticker image identifier",
      "in": "body"
    },
    {
      "name": "top",
      "type": "number",
      "required": true,
      "location": "query",
      "description": "Top position",
      "in": "body"
    },
    {
      "name": "left",
      "type": "number",
      "required": true,
      "location": "query",
      "description": "Left position",
      "in": "body"
    },
    {
      "name": "zIndex",
      "type": "integer",
      "required": true,
      "location": "query",
      "description": "Z-index",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
