{
  "name": "lists_move_all_cards",
  "description": "Move all cards in a list to another list.",
  "resource_group": "lists",
  "endpoint": "/lists/{id}/moveAllCards",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the list"
    },
    {
      "name": "idBoard",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Destination board ID"
    },
    {
      "name": "idList",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Destination list ID"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}