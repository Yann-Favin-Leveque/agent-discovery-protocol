{
  "name": "cards_update",
  "description": "Update a card.",
  "resource_group": "cards",
  "endpoint": "/cards/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the card",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New name",
      "in": "body"
    },
    {
      "name": "desc",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New description",
      "in": "body"
    },
    {
      "name": "closed",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Archive/unarchive card",
      "in": "body"
    },
    {
      "name": "idList",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Move to list",
      "in": "body"
    },
    {
      "name": "due",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Due date",
      "in": "body"
    },
    {
      "name": "dueComplete",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Mark due complete",
      "in": "body"
    },
    {
      "name": "pos",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "New position",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
