{
  "name": "boards_actions_list",
  "description": "List actions/activity on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/actions",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "filter",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter actions by type",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Max actions to return (max 1000)",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
