{
  "name": "checklists_checkitems_create",
  "description": "Create a checkitem on a checklist.",
  "resource_group": "checklists",
  "endpoint": "/checklists/{id}/checkItems",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Checklist ID"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Checkitem name"
    },
    {
      "name": "checked",
      "type": "boolean",
      "required": false,
      "location": "query",
      "description": "Initial checked state"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}