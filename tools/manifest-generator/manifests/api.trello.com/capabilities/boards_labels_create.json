{
  "name": "boards_labels_create",
  "description": "Create a new label on a board.",
  "resource_group": "boards",
  "endpoint": "/boards/{id}/labels",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the board",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Label name",
      "in": "body"
    },
    {
      "name": "color",
      "type": "string",
      "required": true,
      "location": "query",
      "description": "Label color",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
