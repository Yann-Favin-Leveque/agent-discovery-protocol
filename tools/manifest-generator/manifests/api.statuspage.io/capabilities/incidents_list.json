{
  "name": "incidents_list",
  "description": "List all incidents on a status page including their current status, affected components, impact, and the full history of incident updates. Supports search via query parameter.",
  "resource_group": "incidents",
  "endpoint": "/v1/pages/{page_id}/incidents",
  "method": "GET",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "description": "The unique identifier of the status page.",
      "in": "path"
    },
    {
      "name": "q",
      "type": "string",
      "required": false,
      "description": "Search query to filter incidents by name or content.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.statuspage.io/v1/pages/pg1a2b3c4d5e6/incidents",
    "headers": {
      "Authorization": "OAuth your-api-key-here"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "inc1a2b3c4d5e6",
        "name": "API Latency Issues",
        "status": "investigating",
        "impact": "minor",
        "created_at": "2026-03-01T10:00:00Z",
        "updated_at": "2026-03-01T10:30:00Z",
        "resolved_at": null,
        "shortlink": "https://stspg.io/abc123",
        "incident_updates": [
          {
            "id": "upd1a2b3c4d5e6",
            "status": "investigating",
            "body": "We are investigating increased API latency.",
            "created_at": "2026-03-01T10:00:00Z"
          }
        ],
        "components": [
          {
            "id": "cmp1a2b3c4d5e6",
            "name": "API Gateway",
            "status": "degraded_performance"
          }
        ]
      }
    ]
  }
}
