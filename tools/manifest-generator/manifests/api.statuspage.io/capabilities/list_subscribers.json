{
  "name": "list_subscribers",
  "description": "List all subscribers to a status page. Subscribers receive notifications about incidents and scheduled maintenance events. Returns subscriber details including email, phone number (for SMS subscribers), webhook URL, and subscription preferences.",
  "endpoint": "/v1/pages/{page_id}/subscribers",
  "method": "GET",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "description": "The ID of the status page."
    },
    {
      "name": "q",
      "type": "string",
      "required": false,
      "description": "Search query to filter subscribers by email or phone."
    },
    {
      "name": "type",
      "type": "string",
      "required": false,
      "description": "Filter by subscriber type: 'email', 'sms', 'webhook', or 'slack'."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of results per page (default 100)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.statuspage.io/v1/pages/pg1a2b3c4d5e6/subscribers?type=email&per_page=50",
    "headers": {
      "Authorization": "OAuth your-api-key-here"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "sub1a2b3c4d5e",
        "created_at": "2025-03-10T08:00:00Z",
        "mode": "email",
        "email": "ops-team@acmecorp.com",
        "phone_number": null,
        "phone_country": null,
        "endpoint": null,
        "page_access_user": null,
        "skip_confirmation_notification": false,
        "quarantined_at": null,
        "purge_at": null,
        "component_ids": []
      },
      {
        "id": "sub2b3c4d5e6f",
        "created_at": "2025-06-22T14:30:00Z",
        "mode": "webhook",
        "email": null,
        "phone_number": null,
        "phone_country": null,
