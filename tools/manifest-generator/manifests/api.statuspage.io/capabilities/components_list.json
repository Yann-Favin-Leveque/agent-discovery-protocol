{
  "name": "components_list",
  "description": "List all components on a status page. Components represent individual services or systems whose operational status is tracked independently. Returns component IDs, names, descriptions, current status, and position order.",
  "resource_group": "components",
  "endpoint": "/v1/pages/{page_id}/components",
  "method": "GET",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "description": "The unique identifier of the status page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.statuspage.io/v1/pages/pg1a2b3c4d5e6/components",
    "headers": {
      "Authorization": "OAuth your-api-key-here"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "cmp1a2b3c4d5e6",
        "page_id": "pg1a2b3c4d5e6",
        "name": "API Gateway",
        "description": "Main API entry point",
        "status": "operational",
        "position": 1,
        "showcase": true,
        "only_show_if_degraded": false,
        "created_at": "2025-01-15T10:00:00Z",
        "updated_at": "2026-02-28T08:30:00Z"
      }
    ]
  }
}
