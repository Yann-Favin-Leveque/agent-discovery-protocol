{
  "name": "update_component_status",
  "description": "Update the operational status of a specific component on a status page. Valid statuses are: 'operational', 'degraded_performance', 'partial_outage', 'major_outage', and 'under_maintenance'. Changing a component's status may trigger subscriber notifications depending on page configuration.",
  "endpoint": "/v1/pages/{page_id}/components/{component_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "description": "The ID of the status page."
    },
    {
      "name": "component_id",
      "type": "string",
      "required": true,
      "description": "The ID of the component to update."
    },
    {
      "name": "component.status",
      "type": "string",
      "required": true,
      "description": "New status: 'operational', 'degraded_performance', 'partial_outage', 'major_outage', or 'under_maintenance'."
    },
    {
      "name": "component.description",
      "type": "string",
      "required": false,
      "description": "Updated description for the component."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.statuspage.io/v1/pages/pg1a2b3c4d5e6/components/cmp3c4d5e6f",
    "headers": {
      "Authorization": "OAuth your-api-key-here",
      "Content-Type": "application/json"
    },
    "body": {
      "component": {
        "status": "partial_outage"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cmp3c4d5e6f",
      "page_id": "pg1a2b3c4d5e6",
      "group_id": null,
      "created_at": "2025-01-15T10:07:00Z",
      "updated_at": "2026-02-28T12:00:00Z",
      "name": "Database",
      "description": "Primary database cluster",
      "position": 3,
      "status": "partial_outage",
      "showcase": true,
      "only_show_if_degraded": false
    }
  }
}
