{
  "name": "incidents_list_scheduled",
  "description": "List only scheduled maintenance incidents on a status page. Scheduled incidents represent planned outages or maintenance periods.",
  "resource_group": "incidents",
  "endpoint": "/v1/pages/{page_id}/incidents/scheduled",
  "method": "GET",
  "parameters": [
    {
      "name": "page_id",
      "type": "string",
      "required": true,
      "description": "The unique identifier of the status page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.statuspage.io/v1/pages/pg1a2b3c4d5e6/incidents/scheduled",
    "headers": {
      "Authorization": "OAuth your-api-key-here"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "inc2b3c4d5e6f7",
        "name": "Database Maintenance Window",
        "status": "scheduled",
        "impact": "maintenance",
        "scheduled_for": "2026-03-05T02:00:00Z",
        "scheduled_until": "2026-03-05T06:00:00Z",
        "created_at": "2026-03-01T10:00:00Z"
      }
    ]
  }
}
