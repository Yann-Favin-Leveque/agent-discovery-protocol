{
  "name": "objects_create",
  "description": "Create a new custom object in the workspace.",
  "resource_group": "objects",
  "endpoint": "/objects",
  "method": "POST",
  "parameters": [
    {
      "name": "api_slug",
      "type": "string",
      "required": true,
      "description": "URL-safe slug"
    },
    {
      "name": "singular_noun",
      "type": "string",
      "required": true,
      "description": "Singular display name"
    },
    {
      "name": "plural_noun",
      "type": "string",
      "required": true,
      "description": "Plural display name"
    }
  ],
  "request_example": {
    "api_slug": "tickets",
    "singular_noun": "Ticket",
    "plural_noun": "Tickets"
  },
  "response_example": {
    "data": {
      "id": {
        "object_id": "obj_456"
      }
    }
  },
  "auth_scopes": []
}
