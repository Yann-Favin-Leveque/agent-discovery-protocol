{
  "name": "attributes_create",
  "description": "Create a new attribute on either an object or a list.",
  "resource_group": "attributes",
  "endpoint": "/attributes",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Attribute title"
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "Attribute type (text, number, select, etc.)"
    },
    {
      "name": "object_id",
      "type": "string",
      "required": false,
      "description": "Object to add attribute to"
    },
    {
      "name": "list_id",
      "type": "string",
      "required": false,
      "description": "List to add attribute to"
    }
  ],
  "request_example": {
    "title": "Priority",
    "type": "select",
    "object_id": "obj_123"
  },
  "response_example": {
    "data": {
      "id": {
        "attribute_id": "attr_456"
      }
    }
  },
  "auth_scopes": []
}
