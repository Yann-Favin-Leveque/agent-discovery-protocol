{
  "name": "create_record",
  "description": "Create a new record in any Attio object with specified attribute values.",
  "endpoint": "/objects/{object_slug}/records",
  "method": "POST",
  "parameters": [
    {"name": "object_slug", "type": "string", "description": "Object slug.", "required": true, "example": "people"},
    {"name": "data", "type": "object", "description": "Record data with attribute values.", "required": true, "example": {"values": {"name": [{"first_name": "Jane", "last_name": "Smith"}], "email_addresses": [{"email_address": "jane@example.com"}]}}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.attio.com/v2/objects/people/records",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"data": {"values": {"name": [{"first_name": "Jane", "last_name": "Smith"}], "email_addresses": [{"email_address": "jane@example.com"}]}}}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"id": {"record_id": "rec_new456"}, "values": {"name": [{"first_name": "Jane", "last_name": "Smith"}], "email_addresses": [{"email_address": "jane@example.com"}]}, "created_at": "2024-01-20T10:00:00Z"}}
  }
}
