{
  "name": "records_list",
  "description": "List records from any object with optional filtering and sorting.",
  "resource_group": "records",
  "endpoint": "/objects/{object_id}/records",
  "method": "GET",
  "parameters": [
    {
      "name": "object_id",
      "type": "string",
      "required": true,
      "description": "Object ID or slug",
      "location": "path"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max records to return"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Pagination offset"
    }
  ],
  "request_example": {},
  "response_example": {
    "data": [
      {
        "id": {
          "record_id": "rec_123"
        },
        "values": {}
      }
    ]
  },
  "auth_scopes": []
}
