{
  "name": "notes_create",
  "description": "Create a new note attached to a record.",
  "resource_group": "notes",
  "endpoint": "/notes",
  "method": "POST",
  "parameters": [
    {
      "name": "parent_object",
      "type": "string",
      "required": true,
      "description": "Parent object slug",
      "in": "body"
    },
    {
      "name": "parent_record_id",
      "type": "string",
      "required": true,
      "description": "Parent record ID",
      "in": "body"
    },
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Note title",
      "in": "body"
    },
    {
      "name": "content",
      "type": "string",
      "required": false,
      "description": "Note content in markdown",
      "in": "body"
    }
  ],
  "request_example": {
    "parent_object": "people",
    "parent_record_id": "rec_123",
    "title": "Meeting Notes",
    "content": "Discussed Q4 goals"
  },
  "response_example": {
    "data": {
      "id": {
        "note_id": "note_123"
      }
    }
  },
  "auth_scopes": []
}
