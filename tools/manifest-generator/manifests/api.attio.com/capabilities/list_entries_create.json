{
  "name": "list_entries_create",
  "description": "Add a record to a list as a new list entry.",
  "resource_group": "list_entries",
  "endpoint": "/lists/{list_id}/entries",
  "method": "POST",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "required": true,
      "description": "List ID",
      "location": "path"
    },
    {
      "name": "parent_record_id",
      "type": "string",
      "required": true,
      "description": "Parent record ID"
    },
    {
      "name": "data",
      "type": "object",
      "required": false,
      "description": "Entry attribute values"
    }
  ],
  "request_example": {
    "parent_record_id": "rec_123"
  },
  "response_example": {
    "data": {
      "id": {
        "entry_id": "entry_456"
      }
    }
  },
  "auth_scopes": []
}
