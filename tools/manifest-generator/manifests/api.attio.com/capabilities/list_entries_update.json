{
  "name": "list_entries_update",
  "description": "Update a list entry attribute values.",
  "resource_group": "list_entries",
  "endpoint": "/lists/{list_id}/entries/{entry_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "required": true,
      "description": "List ID",
      "location": "path"
    },
    {
      "name": "entry_id",
      "type": "string",
      "required": true,
      "description": "Entry ID",
      "location": "path"
    },
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Updated values"
    }
  ],
  "request_example": {
    "data": {
      "values": {
        "stage": [
          {
            "status": "Won"
          }
        ]
      }
    }
  },
  "response_example": {
    "data": {
      "id": {
        "entry_id": "entry_456"
      }
    }
  },
  "auth_scopes": []
}
