{
  "name": "records_create",
  "description": "Create a new record in any object.",
  "resource_group": "records",
  "endpoint": "/objects/{object_id}/records",
  "method": "POST",
  "parameters": [
    {
      "name": "object_id",
      "type": "string",
      "required": true,
      "description": "Object ID or slug",
      "location": "path"
    },
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Record data with attribute values"
    }
  ],
  "request_example": {
    "data": {
      "values": {
        "name": [
          {
            "first_name": "John",
            "last_name": "Smith"
          }
        ]
      }
    }
  },
  "response_example": {
    "data": {
      "id": {
        "record_id": "rec_123"
      }
    }
  },
  "auth_scopes": []
}
