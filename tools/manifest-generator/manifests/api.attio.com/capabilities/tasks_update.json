{
  "name": "tasks_update",
  "description": "Update an existing task.",
  "resource_group": "tasks",
  "endpoint": "/tasks/{task_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "description": "Task ID",
      "location": "path"
    },
    {
      "name": "content",
      "type": "string",
      "required": false,
      "description": "Updated content"
    },
    {
      "name": "is_completed",
      "type": "boolean",
      "required": false,
      "description": "Mark completed"
    }
  ],
  "request_example": {
    "is_completed": true
  },
  "response_example": {
    "data": {
      "id": {
        "task_id": "task_456"
      }
    }
  },
  "auth_scopes": []
}
