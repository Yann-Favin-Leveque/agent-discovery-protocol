{
  "name": "records_update",
  "description": "Update a record by ID. Multiselect values are appended.",
  "resource_group": "records",
  "endpoint": "/objects/{object_id}/records/{record_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "object_id",
      "type": "string",
      "required": true,
      "description": "Object ID or slug",
      "location": "path"
    },
    {
      "name": "record_id",
      "type": "string",
      "required": true,
      "description": "Record ID",
      "location": "path"
    },
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Updated attribute values"
    }
  ],
  "request_example": {
    "data": {
      "values": {
        "name": [
          {
            "first_name": "Jane"
          }
        ]
      }
    }
  },
  "response_example": {
    "data": {
      "id": {
        "record_id": "rec_123"
      }
    }
  },
  "auth_scopes": []
}
