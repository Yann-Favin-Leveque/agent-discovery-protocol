{
  "name": "objects_update",
  "description": "Update a single object.",
  "resource_group": "objects",
  "endpoint": "/objects/{object_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "object_id",
      "type": "string",
      "required": true,
      "description": "Object ID or slug",
      "location": "path"
    },
    {
      "name": "singular_noun",
      "type": "string",
      "required": false,
      "description": "Updated singular name"
    }
  ],
  "request_example": {
    "singular_noun": "Support Ticket"
  },
  "response_example": {
    "data": {
      "id": {
        "object_id": "obj_456"
      }
    }
  },
  "auth_scopes": []
}
