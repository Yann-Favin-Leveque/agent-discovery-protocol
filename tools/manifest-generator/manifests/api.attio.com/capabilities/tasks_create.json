{
  "name": "tasks_create",
  "description": "Create a new task.",
  "resource_group": "tasks",
  "endpoint": "/tasks",
  "method": "POST",
  "parameters": [
    {
      "name": "content",
      "type": "string",
      "required": true,
      "description": "Task content",
      "in": "body"
    },
    {
      "name": "deadline_at",
      "type": "string",
      "required": false,
      "description": "Deadline date",
      "in": "body"
    },
    {
      "name": "assignees",
      "type": "array",
      "required": false,
      "description": "Workspace member IDs",
      "in": "body"
    },
    {
      "name": "linked_records",
      "type": "array",
      "required": false,
      "description": "Records to link",
      "in": "body"
    }
  ],
  "request_example": {
    "content": "Follow up with client",
    "deadline_at": "2025-03-15"
  },
  "response_example": {
    "data": {
      "id": {
        "task_id": "task_456"
      }
    }
  },
  "auth_scopes": []
}
