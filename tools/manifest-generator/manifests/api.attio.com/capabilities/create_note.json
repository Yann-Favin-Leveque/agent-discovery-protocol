{
  "name": "create_note",
  "description": "Create a note attached to a record in Attio.",
  "endpoint": "/notes",
  "method": "POST",
  "parameters": [
    {"name": "data", "type": "object", "description": "Note data with title, content, and parent record.", "required": true, "example": {"title": "Meeting Notes", "content": "Discussed Q1 objectives and pricing.", "parent_object": "people", "parent_record_id": "rec_abc123"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.attio.com/v2/notes",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"data": {"title": "Meeting Notes", "content": "Discussed Q1 objectives and pricing.", "parent_object": "people", "parent_record_id": "rec_abc123"}}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"id": "note_abc", "title": "Meeting Notes", "content": "Discussed Q1 objectives and pricing.", "created_at": "2024-01-20T10:00:00Z"}}
  }
}
