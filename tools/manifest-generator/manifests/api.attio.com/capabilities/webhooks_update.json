{
  "name": "webhooks_update",
  "description": "Update a webhook and its subscriptions.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks/{webhook_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "required": true,
      "description": "Webhook ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "target_url",
      "type": "string",
      "required": false,
      "description": "Updated URL",
      "in": "body"
    }
  ],
  "request_example": {
    "target_url": "https://example.com/new-hook"
  },
  "response_example": {
    "data": {
      "id": {
        "webhook_id": "whk_456"
      }
    }
  },
  "auth_scopes": []
}
