{
  "name": "comments_create",
  "description": "Create a new comment on a thread, record, or entry.",
  "resource_group": "comments",
  "endpoint": "/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "content",
      "type": "string",
      "required": true,
      "description": "Comment content"
    },
    {
      "name": "thread_id",
      "type": "string",
      "required": false,
      "description": "Thread ID to reply to"
    },
    {
      "name": "record_id",
      "type": "string",
      "required": false,
      "description": "Record ID"
    }
  ],
  "request_example": {
    "content": "Great progress!",
    "record_id": "rec_123"
  },
  "response_example": {
    "data": {
      "id": {
        "comment_id": "cmt_123"
      }
    }
  },
  "auth_scopes": []
}
