{
  "name": "records_upsert",
  "description": "Create or update a record using a unique attribute to find matches.",
  "resource_group": "records",
  "endpoint": "/objects/{object_id}/records",
  "method": "PUT",
  "parameters": [
    {
      "name": "object_id",
      "type": "string",
      "required": true,
      "description": "Object ID or slug",
      "location": "path"
    },
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Record data with matching and attribute values"
    }
  ],
  "request_example": {
    "data": {
      "values": {
        "email_addresses": [
          {
            "email_address": "john@example.com"
          }
        ]
      }
    }
  },
  "response_example": {
    "data": {
      "id": {
        "record_id": "rec_123"
      }
    }
  },
  "auth_scopes": []
}
