{
  "name": "list_records",
  "description": "List records from any Attio object (people, companies, deals, or custom objects) with optional filtering.",
  "endpoint": "/objects/{object_slug}/records/query",
  "method": "POST",
  "parameters": [
    {"name": "object_slug", "type": "string", "description": "Object slug (e.g., 'people', 'companies', or custom object slug).", "required": true, "example": "people"},
    {"name": "filter", "type": "object", "description": "Filter criteria for records.", "required": false, "example": {}},
    {"name": "limit", "type": "number", "description": "Maximum number of records to return.", "required": false, "example": 25},
    {"name": "offset", "type": "number", "description": "Pagination offset.", "required": false, "example": 0}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.attio.com/v2/objects/people/records/query",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"limit": 25, "offset": 0}
  },
  "response_example": {
    "status": 200,
    "body": {"data": [{"id": {"record_id": "rec_abc123"}, "values": {"name": [{"first_name": "John", "last_name": "Doe"}], "email_addresses": [{"email_address": "john@example.com"}]}}]}
  }
}
