{
  "name": "useragent_parse",
  "description": "Parse a user-agent string from the request header to extract browser, device, and OS details.",
  "endpoint": "/v3/user-agent",
  "method": "GET",
  "resource_group": "user_agent",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "description": "Your API key.",
      "required": true,
      "example": "YOUR_API_KEY",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ipgeolocation.io/v3/user-agent?apiKey=YOUR_API_KEY",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64)",
      "name": "Chrome",
      "version": "120.0",
      "operatingSystem": {
        "name": "Windows",
        "version": "10"
      },
      "device": {
        "name": "Desktop",
        "type": "PC"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
