{
  "name": "timezone_lookup",
  "description": "Get current date, time, and timezone for a location by timezone name, IP, coordinates, or airport code.",
  "endpoint": "/v3/timezone",
  "method": "GET",
  "resource_group": "timezone",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "description": "Your API key.",
      "required": true,
      "example": "YOUR_API_KEY",
      "in": "query"
    },
    {
      "name": "tz",
      "type": "string",
      "description": "IANA timezone name.",
      "required": false,
      "example": "America/New_York",
      "in": "query"
    },
    {
      "name": "ip",
      "type": "string",
      "description": "IP address.",
      "required": false,
      "example": "8.8.8.8",
      "in": "query"
    },
    {
      "name": "lat",
      "type": "number",
      "description": "Latitude.",
      "required": false,
      "example": 40.7128,
      "in": "query"
    },
    {
      "name": "long",
      "type": "number",
      "description": "Longitude.",
      "required": false,
      "example": -74.006,
      "in": "query"
    },
    {
      "name": "location",
      "type": "string",
      "description": "City/address string.",
      "required": false,
      "example": "London, UK",
      "in": "query"
    },
    {
      "name": "iata_code",
      "type": "string",
      "description": "IATA airport code.",
      "required": false,
      "example": "JFK",
      "in": "query"
    },
    {
      "name": "lang",
      "type": "string",
      "description": "Response language.",
      "required": false,
      "example": "en",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ipgeolocation.io/v3/timezone?apiKey=YOUR_API_KEY&tz=America/New_York",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "timezone": "America/New_York",
      "timezone_offset": -5,
      "date": "2024-03-15",
      "time_24": "14:30:00",
      "date_time": "2024-03-15 14:30:00",
      "is_dst": false
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
