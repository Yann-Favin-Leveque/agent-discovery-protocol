{
  "name": "timezone_convert",
  "description": "Convert time between two locations using timezone names, coordinates, or airport codes.",
  "endpoint": "/v3/timezone/convert",
  "method": "GET",
  "resource_group": "timezone",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "description": "Your API key.",
      "required": true,
      "example": "YOUR_API_KEY",
      "in": "query"
    },
    {
      "name": "tz_from",
      "type": "string",
      "description": "Source timezone.",
      "required": false,
      "example": "America/New_York",
      "in": "query"
    },
    {
      "name": "tz_to",
      "type": "string",
      "description": "Destination timezone.",
      "required": false,
      "example": "Europe/London",
      "in": "query"
    },
    {
      "name": "time",
      "type": "string",
      "description": "Time to convert (yyyy-MM-dd HH:mm).",
      "required": false,
      "example": "2024-03-15 14:30",
      "in": "query"
    },
    {
      "name": "lat_from",
      "type": "number",
      "description": "Source latitude.",
      "required": false,
      "example": 40.7128,
      "in": "query"
    },
    {
      "name": "long_from",
      "type": "number",
      "description": "Source longitude.",
      "required": false,
      "example": -74.006,
      "in": "query"
    },
    {
      "name": "lat_to",
      "type": "number",
      "description": "Destination latitude.",
      "required": false,
      "example": 51.5074,
      "in": "query"
    },
    {
      "name": "long_to",
      "type": "number",
      "description": "Destination longitude.",
      "required": false,
      "example": -0.1278,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ipgeolocation.io/v3/timezone/convert?apiKey=YOUR_API_KEY&tz_from=America/New_York&tz_to=Europe/London&time=2024-03-15 14:30",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "original": {
        "timezone": "America/New_York",
        "date_time": "2024-03-15 14:30:00"
      },
      "converted": {
        "timezone": "Europe/London",
        "date_time": "2024-03-15 18:30:00"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
