{
  "name": "topics_delete",
  "description": "Remove an existing topic.",
  "resource_group": "topics",
  "endpoint": "/topics/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Topic ID.",
      "required": true,
      "example": "topic-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/topics/topic-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}