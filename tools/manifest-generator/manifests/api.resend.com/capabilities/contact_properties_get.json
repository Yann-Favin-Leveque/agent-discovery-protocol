{
  "name": "contact_properties_get",
  "description": "Retrieve a single contact property by ID.",
  "resource_group": "contact_properties",
  "endpoint": "/contact-properties/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Property ID.",
      "required": true,
      "example": "prop-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/contact-properties/prop-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "prop-123",
      "name": "company",
      "type": "string"
    }
  }
}