{
  "name": "contacts_segments_remove",
  "description": "Remove a contact from a segment.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{contact_id}/segments/{segment_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID.",
      "required": true,
      "example": "con-123"
    },
    {
      "name": "segment_id",
      "type": "string",
      "description": "Segment ID.",
      "required": true,
      "example": "seg-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/contacts/con-123/segments/seg-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}