{
  "name": "topics_get",
  "description": "Retrieve a single topic by ID.",
  "resource_group": "topics",
  "endpoint": "/topics/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Topic ID.",
      "required": true,
      "example": "topic-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/topics/topic-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "topic-123",
      "name": "Product Updates"
    }
  }
}
