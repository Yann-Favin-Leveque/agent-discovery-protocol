{
  "name": "templates_delete",
  "description": "Remove an existing template.",
  "resource_group": "templates",
  "endpoint": "/templates/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "tmpl-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/templates/tmpl-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}