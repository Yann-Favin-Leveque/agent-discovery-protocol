{
  "name": "broadcasts_update",
  "description": "Update an existing broadcast.",
  "resource_group": "broadcasts",
  "endpoint": "/broadcasts/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Broadcast ID.",
      "required": true,
      "example": "bc-123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Updated subject.",
      "required": false,
      "in": "body"
    },
    {
      "name": "html",
      "type": "string",
      "description": "Updated HTML content.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.resend.com/broadcasts/bc-123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "subject": "Updated Newsletter"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "bc-123"
    }
  }
}
