{
  "name": "contacts_update",
  "description": "Update a contact by ID or email.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Contact ID or email.",
      "required": true,
      "example": "con-123",
      "in": "path"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Updated first name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "description": "Updated last name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "unsubscribed",
      "type": "boolean",
      "description": "Subscription status.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.resend.com/contacts/con-123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "first_name": "Jane"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "con-123"
    }
  }
}
