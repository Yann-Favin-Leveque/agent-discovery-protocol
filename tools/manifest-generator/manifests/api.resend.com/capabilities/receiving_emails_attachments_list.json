{
  "name": "receiving_emails_attachments_list",
  "description": "Retrieve attachments for a received email.",
  "resource_group": "receiving",
  "endpoint": "/emails/receiving/{email_id}/attachments",
  "method": "GET",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The ID of the received email.",
      "required": true,
      "example": "rec-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails/receiving/rec-123/attachments",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "att-456",
          "filename": "doc.pdf"
        }
      ]
    }
  }
}
