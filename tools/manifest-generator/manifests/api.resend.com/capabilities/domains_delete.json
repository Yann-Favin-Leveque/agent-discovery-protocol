{
  "name": "domains_delete",
  "description": "Remove an existing domain.",
  "resource_group": "domains",
  "endpoint": "/domains/{domain_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "domain_id",
      "type": "string",
      "description": "The domain ID.",
      "required": true,
      "example": "dom-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/domains/dom-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}