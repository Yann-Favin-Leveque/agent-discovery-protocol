{
  "name": "contacts_delete",
  "description": "Remove a contact by ID or email.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Contact ID or email.",
      "required": true,
      "example": "con-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/contacts/con-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}