{
  "name": "emails_batch",
  "description": "Send up to 100 emails in a single batch request.",
  "resource_group": "emails",
  "endpoint": "/emails/batch",
  "method": "POST",
  "parameters": [
    {
      "name": "emails",
      "type": "array",
      "description": "Array of email objects to send (max 100).",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/emails/batch",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": [
      {
        "from": "user@example.com",
        "to": "a@example.com",
        "subject": "Hello",
        "html": "<p>Hi</p>"
      }
    ]
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "ae2014de"
        }
      ]
    }
  }
}
