{
  "name": "segments_create",
  "description": "Create a new contact segment.",
  "resource_group": "segments",
  "endpoint": "/segments",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Segment name.",
      "required": true,
      "example": "Active Users",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/segments",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Active Users"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "seg-123"
    }
  }
}
