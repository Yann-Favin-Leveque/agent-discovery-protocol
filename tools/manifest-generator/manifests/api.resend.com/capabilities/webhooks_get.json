{
  "name": "webhooks_get",
  "description": "Retrieve a single webhook by ID.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks/{webhook_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "example": "wh-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/webhooks/wh-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "wh-123",
      "endpoint": "https://example.com/webhook",
      "events": [
        "email.sent"
      ]
    }
  }
}
