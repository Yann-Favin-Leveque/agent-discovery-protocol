{
  "name": "contacts_list",
  "description": "Retrieve a list of contacts with optional segment filtering.",
  "resource_group": "contacts",
  "endpoint": "/contacts",
  "method": "GET",
  "parameters": [
    {
      "name": "segment_id",
      "type": "string",
      "description": "Filter by segment ID.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/contacts",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "con-123",
          "email": "user@example.com",
          "first_name": "John"
        }
      ]
    }
  }
}
