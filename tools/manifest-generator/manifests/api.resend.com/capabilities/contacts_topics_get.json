{
  "name": "contacts_topics_get",
  "description": "Retrieve topic subscriptions for a contact.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{contact_id}/topics",
  "method": "GET",
  "parameters": [
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID.",
      "required": true,
      "example": "con-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/contacts/con-123/topics",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "topic-123",
          "name": "Newsletter",
          "subscribed": true
        }
      ]
    }
  }
}
