{
  "name": "segments_delete",
  "description": "Remove an existing segment.",
  "resource_group": "segments",
  "endpoint": "/segments/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Segment ID.",
      "required": true,
      "example": "seg-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/segments/seg-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}