{
  "name": "emails_list",
  "description": "Retrieve a paginated list of sent emails.",
  "resource_group": "emails",
  "endpoint": "/emails",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "number",
      "description": "Number of emails to return.",
      "required": false,
      "example": 10
    },
    {
      "name": "after",
      "type": "string",
      "description": "Cursor for pagination (after this ID).",
      "required": false
    },
    {
      "name": "before",
      "type": "string",
      "description": "Cursor for pagination (before this ID).",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails?limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "ae2014de",
          "from": "user@example.com",
          "to": [
            "recipient@example.com"
          ],
          "subject": "Hello",
          "created_at": "2024-01-01T00:00:00Z"
        }
      ]
    }
  }
}