{
  "name": "receiving_emails_attachments_get",
  "description": "Retrieve a single attachment from a received email.",
  "resource_group": "receiving",
  "endpoint": "/emails/receiving/{email_id}/attachments/{attachment_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The received email ID.",
      "required": true,
      "example": "rec-123"
    },
    {
      "name": "attachment_id",
      "type": "string",
      "description": "The attachment ID.",
      "required": true,
      "example": "att-456"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails/receiving/rec-123/attachments/att-456",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "att-456",
      "filename": "doc.pdf",
      "content": "base64-data"
    }
  }
}