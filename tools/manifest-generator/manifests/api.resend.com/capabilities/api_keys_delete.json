{
  "name": "api_keys_delete",
  "description": "Remove an existing API key.",
  "resource_group": "api_keys",
  "endpoint": "/api-keys/{api_key_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "api_key_id",
      "type": "string",
      "description": "The API key ID.",
      "required": true,
      "example": "key-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/api-keys/key-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
