{
  "name": "emails_send",
  "description": "Send an email to one or more recipients with HTML, text, attachments, and scheduling support.",
  "resource_group": "emails",
  "endpoint": "/emails",
  "method": "POST",
  "parameters": [
    {
      "name": "from",
      "type": "string",
      "description": "Sender email address.",
      "required": true,
      "example": "onboarding@resend.dev"
    },
    {
      "name": "to",
      "type": "string",
      "description": "Recipient email address(es). Max 50.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Email subject line.",
      "required": true,
      "example": "Hello World"
    },
    {
      "name": "html",
      "type": "string",
      "description": "HTML body of the email.",
      "required": false,
      "example": "<p>Hello</p>"
    },
    {
      "name": "text",
      "type": "string",
      "description": "Plain text body of the email.",
      "required": false
    },
    {
      "name": "cc",
      "type": "string",
      "description": "CC recipients.",
      "required": false
    },
    {
      "name": "bcc",
      "type": "string",
      "description": "BCC recipients.",
      "required": false
    },
    {
      "name": "reply_to",
      "type": "string",
      "description": "Reply-to address.",
      "required": false
    },
    {
      "name": "scheduled_at",
      "type": "string",
      "description": "ISO 8601 date to schedule sending.",
      "required": false
    },
    {
      "name": "tags",
      "type": "array",
      "description": "Tags for categorization.",
      "required": false
    },
    {
      "name": "attachments",
      "type": "array",
      "description": "File attachments.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/emails",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "from": "onboarding@resend.dev",
      "to": "user@example.com",
      "subject": "Hello",
      "html": "<p>Hello</p>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ae2014de-c168-4c61-8267-70d2662a1ce8"
    }
  }
}