{
  "name": "templates_publish",
  "description": "Publish a template to make it available for sending.",
  "resource_group": "templates",
  "endpoint": "/templates/{id}/publish",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "tmpl-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/templates/tmpl-123/publish",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tmpl-123"
    }
  }
}
