{
  "name": "contacts_segments_add",
  "description": "Add a contact to a segment.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{contact_id}/segments/{segment_id}",
  "method": "POST",
  "parameters": [
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID.",
      "required": true,
      "example": "con-123",
      "in": "path"
    },
    {
      "name": "segment_id",
      "type": "string",
      "description": "Segment ID.",
      "required": true,
      "example": "seg-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/contacts/con-123/segments/seg-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
