{
  "name": "contacts_segments_list",
  "description": "List segments a contact belongs to.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{contact_id}/segments",
  "method": "GET",
  "parameters": [
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID.",
      "required": true,
      "example": "con-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/contacts/con-123/segments",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "seg-123",
          "name": "Newsletter"
        }
      ]
    }
  }
}
