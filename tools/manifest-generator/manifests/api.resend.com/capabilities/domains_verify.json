{
  "name": "domains_verify",
  "description": "Verify an existing domain's DNS records.",
  "resource_group": "domains",
  "endpoint": "/domains/{domain_id}/verify",
  "method": "POST",
  "parameters": [
    {
      "name": "domain_id",
      "type": "string",
      "description": "The domain ID.",
      "required": true,
      "example": "dom-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/domains/dom-123/verify",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dom-123",
      "status": "pending"
    }
  }
}
