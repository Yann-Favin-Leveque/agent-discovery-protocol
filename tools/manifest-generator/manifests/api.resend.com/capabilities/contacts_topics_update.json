{
  "name": "contacts_topics_update",
  "description": "Update topic subscriptions for a contact.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{contact_id}/topics",
  "method": "PATCH",
  "parameters": [
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID.",
      "required": true,
      "example": "con-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.resend.com/contacts/con-123/topics",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "topics": [
        {
          "id": "topic-123",
          "subscribed": false
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
