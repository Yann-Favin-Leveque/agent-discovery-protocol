{
  "name": "emails_attachments_get",
  "description": "Retrieve a single attachment from a sent email.",
  "resource_group": "emails",
  "endpoint": "/emails/{email_id}/attachments/{attachment_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The ID of the email.",
      "required": true,
      "example": "ae2014de",
      "in": "path"
    },
    {
      "name": "attachment_id",
      "type": "string",
      "description": "The ID of the attachment.",
      "required": true,
      "example": "att-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails/ae2014de/attachments/att-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "att-123",
      "filename": "file.pdf",
      "content_type": "application/pdf",
      "content": "base64-data"
    }
  }
}
