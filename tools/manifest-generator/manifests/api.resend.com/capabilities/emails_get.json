{
  "name": "emails_get",
  "description": "Retrieve a single email by its ID.",
  "resource_group": "emails",
  "endpoint": "/emails/{email_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The ID of the email.",
      "required": true,
      "example": "ae2014de-c168-4c61-8267-70d2662a1ce8"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails/ae2014de-c168-4c61-8267-70d2662a1ce8",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ae2014de",
      "from": "user@example.com",
      "to": [
        "recipient@example.com"
      ],
      "subject": "Hello",
      "created_at": "2024-01-01T00:00:00Z"
    }
  }
}