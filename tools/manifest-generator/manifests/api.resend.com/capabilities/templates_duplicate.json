{
  "name": "templates_duplicate",
  "description": "Duplicate an existing template.",
  "resource_group": "templates",
  "endpoint": "/templates/{id}/duplicate",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "tmpl-123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/templates/tmpl-123/duplicate",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "tmpl-456"
    }
  }
}