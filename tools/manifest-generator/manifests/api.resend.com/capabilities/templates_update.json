{
  "name": "templates_update",
  "description": "Update an existing template.",
  "resource_group": "templates",
  "endpoint": "/templates/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "tmpl-123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "html",
      "type": "string",
      "description": "Updated HTML.",
      "required": false,
      "in": "body"
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Updated subject.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.resend.com/templates/tmpl-123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Template"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tmpl-123"
    }
  }
}
