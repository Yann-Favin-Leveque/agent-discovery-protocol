{
  "name": "webhooks_delete",
  "description": "Remove an existing webhook.",
  "resource_group": "webhooks",
  "endpoint": "/webhooks/{webhook_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "example": "wh-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/webhooks/wh-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}
