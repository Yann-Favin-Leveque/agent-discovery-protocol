{
  "name": "contact_properties_update",
  "description": "Update an existing contact property.",
  "resource_group": "contact_properties",
  "endpoint": "/contact-properties/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Property ID.",
      "required": true,
      "example": "prop-123"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.resend.com/contact-properties/prop-123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "organization"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "prop-123"
    }
  }
}