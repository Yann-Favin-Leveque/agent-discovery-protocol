{
  "name": "emails_cancel",
  "description": "Cancel the scheduled sending of an email.",
  "resource_group": "emails",
  "endpoint": "/emails/{email_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The ID of the scheduled email.",
      "required": true,
      "example": "ae2014de"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/emails/ae2014de/cancel",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ae2014de"
    }
  }
}