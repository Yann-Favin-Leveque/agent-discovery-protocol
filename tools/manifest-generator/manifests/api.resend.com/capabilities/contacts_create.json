{
  "name": "contacts_create",
  "description": "Create a new contact.",
  "resource_group": "contacts",
  "endpoint": "/contacts",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Contact email address.",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "First name.",
      "required": false,
      "example": "John"
    },
    {
      "name": "last_name",
      "type": "string",
      "description": "Last name.",
      "required": false,
      "example": "Doe"
    },
    {
      "name": "unsubscribed",
      "type": "boolean",
      "description": "Whether the contact is unsubscribed.",
      "required": false,
      "example": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/contacts",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "first_name": "John"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "con-123"
    }
  }
}