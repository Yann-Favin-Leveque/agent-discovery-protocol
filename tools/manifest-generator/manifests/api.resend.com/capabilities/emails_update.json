{
  "name": "emails_update",
  "description": "Update a scheduled email's send time.",
  "resource_group": "emails",
  "endpoint": "/emails/{email_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The ID of the email.",
      "required": true,
      "example": "ae2014de"
    },
    {
      "name": "scheduled_at",
      "type": "string",
      "description": "New scheduled time in ISO 8601.",
      "required": false,
      "example": "2024-12-01T12:00:00Z"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.resend.com/emails/ae2014de",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "scheduled_at": "2024-12-01T12:00:00Z"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ae2014de"
    }
  }
}