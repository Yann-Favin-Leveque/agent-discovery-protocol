{
  "name": "contact_properties_create",
  "description": "Create a new custom contact property.",
  "resource_group": "contact_properties",
  "endpoint": "/contact-properties",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Property name.",
      "required": true,
      "example": "company",
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Property type.",
      "required": true,
      "example": "string",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/contact-properties",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "company",
      "type": "string"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "prop-123"
    }
  }
}
