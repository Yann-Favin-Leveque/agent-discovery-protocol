{
  "name": "contacts_get",
  "description": "Retrieve a single contact by ID or email.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Contact ID or email.",
      "required": true,
      "example": "con-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/contacts/con-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "con-123",
      "email": "user@example.com",
      "first_name": "John"
    }
  }
}