{
  "name": "topics_update",
  "description": "Update an existing topic.",
  "resource_group": "topics",
  "endpoint": "/topics/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Topic ID.",
      "required": true,
      "example": "topic-123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.resend.com/topics/topic-123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Topic"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "topic-123"
    }
  }
}
