{
  "name": "templates_get",
  "description": "Retrieve a single template by ID or alias.",
  "resource_group": "templates",
  "endpoint": "/templates/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Template ID or alias.",
      "required": true,
      "example": "tmpl-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/templates/tmpl-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tmpl-123",
      "name": "Welcome Email",
      "html": "<p>Welcome</p>",
      "subject": "Welcome!"
    }
  }
}