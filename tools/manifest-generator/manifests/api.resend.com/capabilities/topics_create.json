{
  "name": "topics_create",
  "description": "Create a new subscription topic.",
  "resource_group": "topics",
  "endpoint": "/topics",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Topic name.",
      "required": true,
      "example": "Product Updates"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/topics",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Product Updates"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "topic-123"
    }
  }
}