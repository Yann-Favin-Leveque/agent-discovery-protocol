{
  "name": "broadcasts_delete",
  "description": "Remove a draft broadcast.",
  "resource_group": "broadcasts",
  "endpoint": "/broadcasts/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Broadcast ID.",
      "required": true,
      "example": "bc-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.resend.com/broadcasts/bc-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}
