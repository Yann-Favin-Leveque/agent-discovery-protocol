{
  "name": "emails_attachments_list",
  "description": "Retrieve attachments for a sent email.",
  "resource_group": "emails",
  "endpoint": "/emails/{email_id}/attachments",
  "method": "GET",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The ID of the email.",
      "required": true,
      "example": "ae2014de"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails/ae2014de/attachments",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "att-123",
          "filename": "file.pdf",
          "content_type": "application/pdf"
        }
      ]
    }
  }
}