{
  "name": "broadcasts_get",
  "description": "Retrieve a single broadcast by ID.",
  "resource_group": "broadcasts",
  "endpoint": "/broadcasts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Broadcast ID.",
      "required": true,
      "example": "bc-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/broadcasts/bc-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "bc-123",
      "name": "Newsletter",
      "status": "draft"
    }
  }
}