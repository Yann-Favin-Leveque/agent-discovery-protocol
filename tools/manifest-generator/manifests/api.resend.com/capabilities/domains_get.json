{
  "name": "domains_get",
  "description": "Retrieve a single domain by ID.",
  "resource_group": "domains",
  "endpoint": "/domains/{domain_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "domain_id",
      "type": "string",
      "description": "The domain ID.",
      "required": true,
      "example": "dom-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/domains/dom-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "dom-123",
      "name": "example.com",
      "status": "verified",
      "records": []
    }
  }
}