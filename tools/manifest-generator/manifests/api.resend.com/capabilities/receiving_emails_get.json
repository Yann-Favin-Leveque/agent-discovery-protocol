{
  "name": "receiving_emails_get",
  "description": "Retrieve a single received email by ID.",
  "resource_group": "receiving",
  "endpoint": "/emails/receiving/{email_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "email_id",
      "type": "string",
      "description": "The ID of the received email.",
      "required": true,
      "example": "rec-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails/receiving/rec-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rec-123",
      "from": "sender@example.com",
      "subject": "Incoming",
      "html": "<p>Content</p>"
    }
  }
}
