{
  "name": "broadcasts_send",
  "description": "Send or schedule a broadcast for delivery.",
  "resource_group": "broadcasts",
  "endpoint": "/broadcasts/{id}/send",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Broadcast ID.",
      "required": true,
      "example": "bc-123",
      "in": "path"
    },
    {
      "name": "scheduled_at",
      "type": "string",
      "description": "Schedule time in ISO 8601.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.resend.com/broadcasts/bc-123/send",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "bc-123"
    }
  }
}
