{
  "name": "receiving_emails_list",
  "description": "Retrieve a list of received emails.",
  "resource_group": "receiving",
  "endpoint": "/emails/receiving",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "number",
      "description": "Number of emails to return.",
      "required": false,
      "example": 10
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.resend.com/emails/receiving?limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "rec-123",
          "from": "sender@example.com",
          "subject": "Incoming"
        }
      ]
    }
  }
}