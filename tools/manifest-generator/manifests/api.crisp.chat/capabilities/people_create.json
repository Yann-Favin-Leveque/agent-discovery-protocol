{
  "name": "people_create",
  "description": "Create a new contact profile in your Crisp people database.",
  "endpoint": "/v1/website/{website_id}/people",
  "method": "POST",
  "resource_group": "people",
  "parameters": [
    {
      "name": "website_id",
      "type": "string",
      "description": "The unique website identifier.",
      "required": true,
      "example": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc",
      "in": "path"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Email address for the new contact.",
      "required": true,
      "example": "jane@example.com",
      "in": "body"
    },
    {
      "name": "person",
      "type": "object",
      "description": "Person details including nickname, description, etc.",
      "required": false,
      "example": {
        "nickname": "Jane Smith"
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.crisp.chat/v1/website/8c842203-7ed8-4e29-a608-7cf78a7d2fcc/people",
    "headers": {
      "Authorization": "Basic base64(identifier:key)",
      "Content-Type": "application/json",
      "X-Crisp-Tier": "plugin"
    },
    "body": {
      "email": "jane@example.com",
      "person": {
        "nickname": "Jane Smith"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "people_id": "c7b72a68-be91-4e29-b6a0-efbb3b72ed1b"
      }
    }
  },
  "auth_scopes": [
    "website:people:profiles"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
