{
  "name": "conversation_state_update",
  "description": "Change the state of a conversation to pending, unresolved, or resolved.",
  "endpoint": "/v1/website/{website_id}/conversation/{session_id}/state",
  "method": "PATCH",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "website_id",
      "type": "string",
      "description": "The unique website identifier.",
      "required": true,
      "example": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc"
    },
    {
      "name": "session_id",
      "type": "string",
      "description": "The conversation session identifier.",
      "required": true,
      "example": "session_19e5240f-0a8d-461e-a661-a3123f3e"
    },
    {
      "name": "state",
      "type": "string",
      "description": "New conversation state: 'pending', 'unresolved', or 'resolved'.",
      "required": true,
      "example": "resolved"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.crisp.chat/v1/website/8c842203-7ed8-4e29-a608-7cf78a7d2fcc/conversation/session_19e5240f-0a8d-461e-a661-a3123f3e/state",
    "headers": {
      "Authorization": "Basic base64(identifier:key)",
      "Content-Type": "application/json",
      "X-Crisp-Tier": "plugin"
    },
    "body": {
      "state": "resolved"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {}
    }
  },
  "auth_scopes": ["website:conversation:sessions"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
