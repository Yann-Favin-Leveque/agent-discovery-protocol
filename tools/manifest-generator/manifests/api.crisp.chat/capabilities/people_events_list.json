{
  "name": "people_events_list",
  "description": "List tracked events for a specific people profile with pagination.",
  "endpoint": "/v1/website/{website_id}/people/{people_id}/events/{page_number}",
  "method": "GET",
  "resource_group": "people",
  "parameters": [
    {
      "name": "website_id",
      "type": "string",
      "description": "The unique website identifier.",
      "required": true,
      "example": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc"
    },
    {
      "name": "people_id",
      "type": "string",
      "description": "The unique people profile identifier.",
      "required": true,
      "example": "c7b72a68-be91-4e29-b6a0-efbb3b72ed1b"
    },
    {
      "name": "page_number",
      "type": "integer",
      "description": "Page number for pagination.",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.crisp.chat/v1/website/8c842203-7ed8-4e29-a608-7cf78a7d2fcc/people/c7b72a68-be91-4e29-b6a0-efbb3b72ed1b/events/1",
    "headers": {
      "Authorization": "Basic base64(identifier:key)",
      "X-Crisp-Tier": "plugin"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "text": "Signed up for trial",
          "data": {"plan": "trial"},
          "color": "blue",
          "timestamp": 1693560000
        }
      ]
    }
  },
  "auth_scopes": ["website:people:events"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
