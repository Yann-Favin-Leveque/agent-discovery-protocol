{
  "name": "people_conversations_list",
  "description": "List all conversations associated with a specific people profile.",
  "endpoint": "/v1/website/{website_id}/people/{people_id}/conversations/{page_number}",
  "method": "GET",
  "resource_group": "people",
  "parameters": [
    {
      "name": "website_id",
      "type": "string",
      "description": "The unique website identifier.",
      "required": true,
      "example": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc"
    },
    {
      "name": "people_id",
      "type": "string",
      "description": "The unique people profile identifier.",
      "required": true,
      "example": "c7b72a68-be91-4e29-b6a0-efbb3b72ed1b"
    },
    {
      "name": "page_number",
      "type": "integer",
      "description": "Page number for pagination.",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.crisp.chat/v1/website/8c842203-7ed8-4e29-a608-7cf78a7d2fcc/people/c7b72a68-be91-4e29-b6a0-efbb3b72ed1b/conversations/1",
    "headers": {
      "Authorization": "Basic base64(identifier:key)",
      "X-Crisp-Tier": "plugin"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "session_id": "session_19e5240f-0a8d-461e-a661-a3123f3e",
          "state": "resolved",
          "created_at": "2024-09-01T10:00:00.000Z"
        }
      ]
    }
  },
  "auth_scopes": ["website:people:profiles"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
