{
  "name": "messages_list",
  "description": "Retrieve the full message history for a specific conversation.",
  "endpoint": "/v1/website/{website_id}/conversation/{session_id}/messages",
  "method": "GET",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "website_id",
      "type": "string",
      "description": "The unique website identifier.",
      "required": true,
      "example": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc"
    },
    {
      "name": "session_id",
      "type": "string",
      "description": "The conversation session identifier.",
      "required": true,
      "example": "session_19e5240f-0a8d-461e-a661-a3123f3e"
    },
    {
      "name": "timestamp_before",
      "type": "integer",
      "description": "Load messages before this Unix timestamp (for pagination).",
      "required": false,
      "example": 1693560000
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.crisp.chat/v1/website/8c842203-7ed8-4e29-a608-7cf78a7d2fcc/conversation/session_19e5240f-0a8d-461e-a661-a3123f3e/messages",
    "headers": {
      "Authorization": "Basic base64(identifier:key)",
      "X-Crisp-Tier": "plugin"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "fingerprint": 163435890009,
          "type": "text",
          "from": "user",
          "origin": "chat",
          "content": "Hi, I need help with my order.",
          "timestamp": 1693560000,
          "user": {
            "nickname": "John Doe"
          }
        }
      ]
    }
  },
  "auth_scopes": ["website:conversation:messages"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
