{
  "name": "conversations_get",
  "description": "Retrieve details of a specific conversation including metadata, state, and participants.",
  "endpoint": "/v1/website/{website_id}/conversation/{session_id}",
  "method": "GET",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "website_id",
      "type": "string",
      "description": "The unique website identifier.",
      "required": true,
      "example": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc",
      "in": "path"
    },
    {
      "name": "session_id",
      "type": "string",
      "description": "The conversation session identifier.",
      "required": true,
      "example": "session_19e5240f-0a8d-461e-a661-a3123f3e",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.crisp.chat/v1/website/8c842203-7ed8-4e29-a608-7cf78a7d2fcc/conversation/session_19e5240f-0a8d-461e-a661-a3123f3e",
    "headers": {
      "Authorization": "Basic base64(identifier:key)",
      "X-Crisp-Tier": "plugin"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "session_id": "session_19e5240f-0a8d-461e-a661-a3123f3e",
        "website_id": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc",
        "state": "unresolved",
        "is_verified": false,
        "created_at": "2024-09-01T10:00:00.000Z",
        "meta": {
          "nickname": "John Doe",
          "email": "john@example.com"
        }
      }
    }
  },
  "auth_scopes": [
    "website:conversation:sessions"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
