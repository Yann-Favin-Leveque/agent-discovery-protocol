{
  "name": "people_data_get",
  "description": "Retrieve custom data fields associated with a people profile.",
  "endpoint": "/v1/website/{website_id}/people/{people_id}/data",
  "method": "GET",
  "resource_group": "people",
  "parameters": [
    {
      "name": "website_id",
      "type": "string",
      "description": "The unique website identifier.",
      "required": true,
      "example": "8c842203-7ed8-4e29-a608-7cf78a7d2fcc",
      "in": "path"
    },
    {
      "name": "people_id",
      "type": "string",
      "description": "The unique people profile identifier.",
      "required": true,
      "example": "c7b72a68-be91-4e29-b6a0-efbb3b72ed1b",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.crisp.chat/v1/website/8c842203-7ed8-4e29-a608-7cf78a7d2fcc/people/c7b72a68-be91-4e29-b6a0-efbb3b72ed1b/data",
    "headers": {
      "Authorization": "Basic base64(identifier:key)",
      "X-Crisp-Tier": "plugin"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "plan": "enterprise",
        "company": "Acme Corp",
        "signup_date": "2024-01-15"
      }
    }
  },
  "auth_scopes": [
    "website:people:profiles"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
