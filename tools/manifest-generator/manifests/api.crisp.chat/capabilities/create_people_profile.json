{
  "name": "create_people_profile",
  "description": "Create a new contact profile in your Crisp people database. Useful for importing contacts or pre-populating visitor information.",
  "endpoint": "/website/{website_id}/people",
  "method": "POST",
  "parameters": [
    { "name": "website_id", "type": "string", "description": "The unique identifier for your Crisp website.", "required": true, "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890" },
    { "name": "email", "type": "string", "description": "The contact's email address.", "required": true, "example": "john@example.com" },
    { "name": "person", "type": "object", "description": "Contact details including nickname and optional metadata.", "required": false, "example": { "nickname": "John Doe" } }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.crisp.chat/v1/website/a1b2c3d4-e5f6-7890-abcd-ef1234567890/people",
    "headers": {
      "Authorization": "Basic {base64_credentials}",
      "Content-Type": "application/json",
      "X-Crisp-Tier": "plugin"
    },
    "body": {
      "email": "john@example.com",
      "person": {
        "nickname": "John Doe"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "error": false,
      "reason": "created",
      "data": {
        "people_id": "people_abc123"
      }
    }
  }
}
