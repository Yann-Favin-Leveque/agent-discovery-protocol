{
  "name": "send_chat_action",
  "resource_group": "chats",
  "description": "Send a chat action indicator (typing, uploading, etc).",
  "endpoint": "/bot{token}/sendChatAction",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Chat ID",
      "example": "123456789",
      "in": "body"
    },
    {
      "name": "action",
      "type": "string",
      "required": true,
      "description": "Action (typing, upload_photo, upload_document, etc)",
      "example": "typing",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/sendChatAction",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789",
      "action": "typing"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": true
    }
  }
}
