{
  "name": "send_video",
  "resource_group": "messages",
  "description": "Send a video to a chat.",
  "endpoint": "/bot{token}/sendVideo",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Target chat ID",
      "example": "123456789",
      "in": "body"
    },
    {
      "name": "video",
      "type": "string",
      "required": true,
      "description": "Video URL or file_id",
      "example": "https://example.com/video.mp4",
      "in": "body"
    },
    {
      "name": "caption",
      "type": "string",
      "required": false,
      "description": "Video caption",
      "example": "Demo video",
      "in": "body"
    },
    {
      "name": "duration",
      "type": "integer",
      "required": false,
      "description": "Duration in seconds",
      "example": 120,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/sendVideo",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789",
      "video": "https://example.com/video.mp4"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "message_id": 103
      }
    }
  }
}
