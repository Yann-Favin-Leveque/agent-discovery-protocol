{
  "name": "delete_webhook",
  "resource_group": "updates",
  "description": "Remove webhook integration.",
  "endpoint": "/bot{token}/deleteWebhook",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "drop_pending_updates",
      "type": "boolean",
      "required": false,
      "description": "Drop pending updates",
      "example": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/deleteWebhook",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": true
    }
  }
}
