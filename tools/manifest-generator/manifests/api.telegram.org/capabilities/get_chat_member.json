{
  "name": "get_chat_member",
  "resource_group": "chats",
  "description": "Get information about a chat member.",
  "endpoint": "/bot{token}/getChatMember",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Chat ID",
      "example": "-1001234567890",
      "in": "body"
    },
    {
      "name": "user_id",
      "type": "integer",
      "required": true,
      "description": "User ID",
      "example": 111222333,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/getChatMember",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "-1001234567890",
      "user_id": 111222333
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "user": {
          "id": 111222333,
          "first_name": "John"
        },
        "status": "member"
      }
    }
  }
}
