{
  "name": "send_message",
  "resource_group": "messages",
  "description": "Send a text message to a chat with optional formatting and keyboards.",
  "endpoint": "/bot{token}/sendMessage",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Target chat ID or @username",
      "example": "123456789",
      "in": "body"
    },
    {
      "name": "text",
      "type": "string",
      "required": true,
      "description": "Message text (1-4096 chars)",
      "example": "Hello from bot!",
      "in": "body"
    },
    {
      "name": "parse_mode",
      "type": "string",
      "required": false,
      "description": "Formatting (MarkdownV2, HTML)",
      "example": "HTML",
      "in": "body"
    },
    {
      "name": "reply_to_message_id",
      "type": "integer",
      "required": false,
      "description": "Message ID to reply to",
      "example": 42,
      "in": "body"
    },
    {
      "name": "disable_web_page_preview",
      "type": "boolean",
      "required": false,
      "description": "Disable link previews",
      "example": false,
      "in": "body"
    },
    {
      "name": "disable_notification",
      "type": "boolean",
      "required": false,
      "description": "Send silently",
      "example": false,
      "in": "body"
    },
    {
      "name": "reply_markup",
      "type": "object",
      "required": false,
      "description": "Inline/reply keyboard markup",
      "example": {
        "inline_keyboard": [
          [
            {
              "text": "Click me",
              "callback_data": "btn1"
            }
          ]
        ]
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/sendMessage",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789",
      "text": "<b>Hello</b> from bot!",
      "parse_mode": "HTML"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "message_id": 100,
        "from": {
          "id": 123456789,
          "is_bot": true
        },
        "chat": {
          "id": 123456789,
          "type": "private"
        },
        "date": 1710500000,
        "text": "Hello from bot!"
      }
    }
  }
}
