{
  "name": "sendLocation",
  "resource_group": "messages",
  "description": "Send a location point on the map.",
  "endpoint": "/bot{token}/sendLocation",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Target chat ID",
      "example": "123456789"
    },
    {
      "name": "latitude",
      "type": "number",
      "required": true,
      "description": "Latitude",
      "example": 40.7128
    },
    {
      "name": "longitude",
      "type": "number",
      "required": true,
      "description": "Longitude",
      "example": -74.006
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/sendLocation",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789",
      "latitude": 40.7128,
      "longitude": -74.006
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "message_id": 104,
        "location": {
          "latitude": 40.7128,
          "longitude": -74.006
        }
      }
    }
  }
}