{
  "name": "send_document",
  "resource_group": "messages",
  "description": "Send a document or file to a chat.",
  "endpoint": "/bot{token}/sendDocument",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Target chat ID",
      "example": "123456789",
      "in": "body"
    },
    {
      "name": "document",
      "type": "string",
      "required": true,
      "description": "Document URL or file_id",
      "example": "https://example.com/report.pdf",
      "in": "body"
    },
    {
      "name": "caption",
      "type": "string",
      "required": false,
      "description": "Document caption",
      "example": "Monthly report",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/sendDocument",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789",
      "document": "https://example.com/report.pdf"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "message_id": 102,
        "document": {
          "file_id": "BQACAgIAAxkBAAI",
          "file_name": "report.pdf"
        }
      }
    }
  }
}
