{
  "name": "delete_message",
  "resource_group": "messages",
  "description": "Delete a message from a chat.",
  "endpoint": "/bot{token}/deleteMessage",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Chat ID",
      "example": "123456789",
      "in": "body"
    },
    {
      "name": "message_id",
      "type": "integer",
      "required": true,
      "description": "Message ID",
      "example": 100,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/deleteMessage",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789",
      "message_id": 100
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": true
    }
  }
}
