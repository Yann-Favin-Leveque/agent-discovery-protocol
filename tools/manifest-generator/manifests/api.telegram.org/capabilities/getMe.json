{
  "name": "getMe",
  "resource_group": "bot",
  "description": "Get basic information about the bot.",
  "endpoint": "/bot{token}/getMe",
  "method": "GET",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token from BotFather",
      "example": "123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/getMe"
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "id": 123456789,
        "is_bot": true,
        "first_name": "My Bot",
        "username": "my_bot"
      }
    }
  }
}