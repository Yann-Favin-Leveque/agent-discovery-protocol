{
  "name": "get_chat",
  "description": "Get chat information. Agents can retrieve chat details, member counts, and chat metadata.",
  "endpoint": "/bot{token}/getChat",
  "method": "POST",
  "parameters": [
    {
      "name": "chat_id",
      "type": "integer",
      "description": "Unique identifier for the target chat. Can be a user ID, group ID, or channel ID.",
      "required": true,
      "example": 123456789
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot{token}/getChat",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": 123456789
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "id": 123456789,
        "type": "private",
        "title": null,
        "username": "john_doe",
        "first_name": "John",
        "last_name": "Doe",
        "is_forum": false,
        "photo": {
          "small_file_id": "AgADAgADr...",
          "small_file_unique_id": "AQADr...",
          "big_file_id": "AgADAgADr...",
          "big_file_unique_id": "AQADr..."
        },
        "active_usernames": ["john_doe"],
        "emoji_status_custom_emoji_id": null,
        "bio": "I like bots",
        "has_private_forwards": false,
        "has_restricted_voice_and_video_messages": false
      }
    }
  }
}
