{
  "name": "get_chat",
  "resource_group": "chats",
  "description": "Get information about a chat.",
  "endpoint": "/bot{token}/getChat",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Chat ID or @username",
      "example": "123456789",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/getChat",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "id": 123456789,
        "type": "private",
        "first_name": "John"
      }
    }
  }
}
