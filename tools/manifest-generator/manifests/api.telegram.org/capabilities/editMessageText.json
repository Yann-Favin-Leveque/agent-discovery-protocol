{
  "name": "editMessageText",
  "resource_group": "messages",
  "description": "Edit the text of a previously sent message.",
  "endpoint": "/bot{token}/editMessageText",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": false,
      "description": "Chat ID",
      "example": "123456789"
    },
    {
      "name": "message_id",
      "type": "integer",
      "required": false,
      "description": "Message ID to edit",
      "example": 100
    },
    {
      "name": "text",
      "type": "string",
      "required": true,
      "description": "New text",
      "example": "Updated text"
    },
    {
      "name": "parse_mode",
      "type": "string",
      "required": false,
      "description": "Formatting",
      "example": "HTML"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/editMessageText",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "123456789",
      "message_id": 100,
      "text": "Updated text"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "message_id": 100,
        "text": "Updated text",
        "edit_date": 1710500100
      }
    }
  }
}