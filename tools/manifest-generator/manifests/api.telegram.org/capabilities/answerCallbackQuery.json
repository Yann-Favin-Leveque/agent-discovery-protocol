{
  "name": "answerCallbackQuery",
  "resource_group": "callbacks",
  "description": "Answer a callback query from an inline keyboard button press.",
  "endpoint": "/bot{token}/answerCallbackQuery",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "callback_query_id",
      "type": "string",
      "required": true,
      "description": "Callback query ID",
      "example": "4382bfdwdsb323b2d9"
    },
    {
      "name": "text",
      "type": "string",
      "required": false,
      "description": "Notification text",
      "example": "Acknowledged!"
    },
    {
      "name": "show_alert",
      "type": "boolean",
      "required": false,
      "description": "Show alert popup",
      "example": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/answerCallbackQuery",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "callback_query_id": "4382bfdwdsb323b2d9",
      "text": "Acknowledged!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": true
    }
  }
}