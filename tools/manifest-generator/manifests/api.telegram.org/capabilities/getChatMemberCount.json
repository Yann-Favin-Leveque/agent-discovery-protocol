{
  "name": "getChatMemberCount",
  "resource_group": "chats",
  "description": "Get the number of members in a chat.",
  "endpoint": "/bot{token}/getChatMemberCount",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "chat_id",
      "type": "string",
      "required": true,
      "description": "Chat ID",
      "example": "-1001234567890"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/getChatMemberCount",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "chat_id": "-1001234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": 150
    }
  }
}