{
  "name": "get_updates",
  "resource_group": "updates",
  "description": "Receive incoming updates using long polling.",
  "endpoint": "/bot{token}/getUpdates",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Update offset",
      "example": 100,
      "in": "body"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max updates (1-100)",
      "example": 10,
      "in": "body"
    },
    {
      "name": "timeout",
      "type": "integer",
      "required": false,
      "description": "Long polling timeout seconds",
      "example": 30,
      "in": "body"
    },
    {
      "name": "allowed_updates",
      "type": "array",
      "required": false,
      "description": "Update types to receive",
      "example": [
        "message",
        "callback_query"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/getUpdates",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "offset": 100,
      "limit": 10,
      "timeout": 30
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": [
        {
          "update_id": 100,
          "message": {
            "message_id": 50,
            "from": {
              "id": 111
            },
            "chat": {
              "id": 111,
              "type": "private"
            },
            "text": "/start"
          }
        }
      ]
    }
  }
}
