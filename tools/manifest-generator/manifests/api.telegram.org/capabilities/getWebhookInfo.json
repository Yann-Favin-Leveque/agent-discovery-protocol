{
  "name": "getWebhookInfo",
  "resource_group": "updates",
  "description": "Get current webhook status.",
  "endpoint": "/bot{token}/getWebhookInfo",
  "method": "GET",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Bot token",
      "example": "123456:ABC-DEF"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.telegram.org/bot123456:ABC-DEF/getWebhookInfo"
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true,
      "result": {
        "url": "https://example.com/webhook",
        "pending_update_count": 0
      }
    }
  }
}