{
  "name": "deploys_rollback",
  "description": "Rollback a service to a previous deployment by specifying the deploy ID to revert to.",
  "resource_group": "deploys",
  "endpoint": "/v1/services/{serviceId}/rollback",
  "method": "POST",
  "parameters": [
    {"name": "serviceId", "type": "string", "required": true, "description": "The service ID."},
    {"name": "deployId", "type": "string", "required": true, "description": "The deploy ID to rollback to."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/rollback",
    "body": {"deployId": "dep-k1l2m3n4o5"}
  },
  "response_example": {
    "id": "dep-newrollback123",
    "status": "created",
    "trigger": "api"
  }
}
