{
  "name": "envvars_delete",
  "description": "Delete a single environment variable from a service.",
  "resource_group": "environment_variables",
  "endpoint": "/v1/services/{serviceId}/env-vars/{envVarKey}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "The service ID.",
      "in": "path"
    },
    {
      "name": "envVarKey",
      "type": "string",
      "required": true,
      "description": "The environment variable key to delete.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/env-vars/OLD_VAR"
  },
  "response_example": null
}
