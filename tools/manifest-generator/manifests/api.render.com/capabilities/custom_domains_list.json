{
  "name": "custom_domains_list",
  "description": "List custom domains attached to a service with filtering by name, type, and verification status.",
  "resource_group": "custom_domains",
  "endpoint": "/v1/services/{serviceId}/custom-domains",
  "method": "GET",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "The service ID.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter by domain name.",
      "in": "query"
    },
    {
      "name": "domainType",
      "type": "string",
      "required": false,
      "description": "Filter by domain type.",
      "in": "query"
    },
    {
      "name": "verificationStatus",
      "type": "string",
      "required": false,
      "description": "Filter by verification status.",
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Cursor for pagination.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/custom-domains"
  },
  "response_example": [
    {
      "customDomain": {
        "id": "cdm-abc123",
        "name": "api.example.com",
        "domainType": "apex",
        "verificationStatus": "verified"
      },
      "cursor": "cdm-cursor-1"
    }
  ]
}
