{
  "name": "custom_domains_verify",
  "description": "Verify DNS configuration for a custom domain. Checks that DNS records point correctly to Render.",
  "resource_group": "custom_domains",
  "endpoint": "/v1/services/{serviceId}/custom-domains/{customDomainIdOrName}/verify",
  "method": "POST",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "The service ID.",
      "in": "path"
    },
    {
      "name": "customDomainIdOrName",
      "type": "string",
      "required": true,
      "description": "The custom domain ID or domain name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/custom-domains/api.example.com/verify"
  },
  "response_example": {
    "id": "cdm-abc123",
    "name": "api.example.com",
    "verificationStatus": "verified"
  }
}
