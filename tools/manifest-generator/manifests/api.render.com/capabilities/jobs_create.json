{
  "name": "jobs_create",
  "description": "Create and run a one-off job for a service with a custom start command.",
  "resource_group": "jobs",
  "endpoint": "/v1/services/{serviceId}/jobs",
  "method": "POST",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "The service ID to run the job on.",
      "in": "path"
    },
    {
      "name": "startCommand",
      "type": "string",
      "required": true,
      "description": "The command to execute.",
      "in": "body"
    },
    {
      "name": "planId",
      "type": "string",
      "required": false,
      "description": "Plan to use for the job.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/jobs",
    "body": {
      "startCommand": "npm run db:migrate"
    }
  },
  "response_example": {
    "id": "job-abc123",
    "serviceId": "srv-a1b2c3d4e5",
    "startCommand": "npm run db:migrate",
    "status": "pending",
    "createdAt": "2026-01-20T14:00:00Z"
  }
}
