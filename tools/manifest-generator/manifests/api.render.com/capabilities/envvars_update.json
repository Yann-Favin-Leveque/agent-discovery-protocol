{
  "name": "envvars_update",
  "description": "Add or update a single environment variable for a service.",
  "resource_group": "environment_variables",
  "endpoint": "/v1/services/{serviceId}/env-vars/{envVarKey}",
  "method": "PUT",
  "parameters": [
    {"name": "serviceId", "type": "string", "required": true, "description": "The service ID."},
    {"name": "envVarKey", "type": "string", "required": true, "description": "The environment variable key."},
    {"name": "value", "type": "string", "required": true, "description": "The value for the environment variable."}
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/env-vars/NODE_ENV",
    "body": {"value": "production"}
  },
  "response_example": {
    "key": "NODE_ENV",
    "value": "production"
  }
}
