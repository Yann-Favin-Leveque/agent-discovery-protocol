{
  "name": "disks_get",
  "description": "Retrieve details about a specific persistent disk.",
  "resource_group": "disks",
  "endpoint": "/v1/disks/{diskId}",
  "method": "GET",
  "parameters": [
    {
      "name": "diskId",
      "type": "string",
      "required": true,
      "description": "The disk ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/disks/dsk-abc123"
  },
  "response_example": {
    "id": "dsk-abc123",
    "name": "data-disk",
    "sizeGB": 10,
    "mountPath": "/data",
    "serviceId": "srv-a1b2c3d4e5"
  }
}
