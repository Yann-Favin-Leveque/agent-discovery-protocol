{
  "name": "services_scale",
  "description": "Set the fixed number of instances for a service.",
  "resource_group": "services",
  "endpoint": "/v1/services/{serviceId}/scale",
  "method": "POST",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "The service ID to scale.",
      "in": "path"
    },
    {
      "name": "numInstances",
      "type": "integer",
      "required": true,
      "description": "Number of instances to scale to.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/scale",
    "body": {
      "numInstances": 3
    }
  },
  "response_example": null
}
