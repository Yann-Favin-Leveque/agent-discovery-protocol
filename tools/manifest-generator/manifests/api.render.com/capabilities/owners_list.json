{
  "name": "owners_list",
  "description": "List accessible workspaces (owners) with optional filtering by name or email.",
  "resource_group": "workspaces",
  "endpoint": "/v1/owners",
  "method": "GET",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter by workspace name.",
      "in": "query"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by email.",
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Cursor for pagination.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/owners"
  },
  "response_example": [
    {
      "owner": {
        "id": "own-abc123",
        "name": "My Team",
        "email": "team@example.com",
        "type": "team"
      },
      "cursor": "own-cursor-1"
    }
  ]
}
