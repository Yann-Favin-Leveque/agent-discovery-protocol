{
  "name": "owners_get",
  "description": "Retrieve workspace details by ID.",
  "resource_group": "workspaces",
  "endpoint": "/v1/owners/{ownerId}",
  "method": "GET",
  "parameters": [
    {"name": "ownerId", "type": "string", "required": true, "description": "The workspace/owner ID."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/owners/own-abc123"
  },
  "response_example": {
    "id": "own-abc123",
    "name": "My Team",
    "email": "team@example.com",
    "type": "team"
  }
}
