{
  "name": "blueprints_list",
  "description": "List blueprints (render.yaml infrastructure-as-code configurations) for your workspaces.",
  "resource_group": "blueprints",
  "endpoint": "/v1/blueprints",
  "method": "GET",
  "parameters": [
    {
      "name": "ownerId",
      "type": "string",
      "required": false,
      "description": "Filter by workspace/owner ID.",
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Cursor for pagination.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/blueprints"
  },
  "response_example": [
    {
      "blueprint": {
        "id": "bpr-abc123",
        "name": "my-infra",
        "autoSync": true,
        "repo": "https://github.com/my-org/infra"
      },
      "cursor": "bpr-cursor-1"
    }
  ]
}
