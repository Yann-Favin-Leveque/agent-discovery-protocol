{
  "name": "blueprints_get",
  "description": "Retrieve a specific blueprint by ID.",
  "resource_group": "blueprints",
  "endpoint": "/v1/blueprints/{blueprintId}",
  "method": "GET",
  "parameters": [
    {"name": "blueprintId", "type": "string", "required": true, "description": "The blueprint ID."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/blueprints/bpr-abc123"
  },
  "response_example": {
    "id": "bpr-abc123",
    "name": "my-infra",
    "autoSync": true,
    "repo": "https://github.com/my-org/infra",
    "branch": "main",
    "path": "render.yaml"
  }
}
