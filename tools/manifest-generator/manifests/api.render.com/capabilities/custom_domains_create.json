{
  "name": "custom_domains_create",
  "description": "Attach a custom domain to a service.",
  "resource_group": "custom_domains",
  "endpoint": "/v1/services/{serviceId}/custom-domains",
  "method": "POST",
  "parameters": [
    {"name": "serviceId", "type": "string", "required": true, "description": "The service ID."},
    {"name": "name", "type": "string", "required": true, "description": "The domain name to attach (e.g., api.example.com)."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/custom-domains",
    "body": {"name": "api.example.com"}
  },
  "response_example": {
    "id": "cdm-abc123",
    "name": "api.example.com",
    "domainType": "apex",
    "verificationStatus": "unverified",
    "createdAt": "2026-01-20T14:00:00Z"
  }
}
