{
  "name": "events_list",
  "description": "List events for a service including deploys, scaling events, restarts, and more.",
  "resource_group": "events",
  "endpoint": "/v1/services/{serviceId}/events",
  "method": "GET",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "The service ID.",
      "in": "path"
    },
    {
      "name": "eventType",
      "type": "string",
      "required": false,
      "description": "Filter by event type.",
      "in": "query"
    },
    {
      "name": "startTime",
      "type": "string",
      "required": false,
      "description": "Filter events after this ISO 8601 timestamp.",
      "in": "query"
    },
    {
      "name": "endTime",
      "type": "string",
      "required": false,
      "description": "Filter events before this ISO 8601 timestamp.",
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Cursor for pagination.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results to return.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/events?limit=10"
  },
  "response_example": [
    {
      "event": {
        "id": "evt-abc123",
        "type": "deploy",
        "timestamp": "2026-01-20T14:30:00Z",
        "details": {
          "deployId": "dep-k1l2m3n4o5",
          "status": "live"
        }
      },
      "cursor": "evt-cursor-1"
    }
  ]
}
