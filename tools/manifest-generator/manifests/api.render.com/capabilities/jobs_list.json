{
  "name": "jobs_list",
  "description": "List one-off jobs for a service with filtering by status and timestamps.",
  "resource_group": "jobs",
  "endpoint": "/v1/services/{serviceId}/jobs",
  "method": "GET",
  "parameters": [
    {"name": "serviceId", "type": "string", "required": true, "description": "The service ID."},
    {"name": "status", "type": "string", "required": false, "description": "Filter by job status: pending, running, succeeded, failed."},
    {"name": "cursor", "type": "string", "required": false, "description": "Cursor for pagination."},
    {"name": "limit", "type": "integer", "required": false, "description": "Max results to return."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/jobs?status=running"
  },
  "response_example": [
    {"job": {"id": "job-abc123", "serviceId": "srv-a1b2c3d4e5", "startCommand": "npm run migrate", "status": "succeeded", "createdAt": "2026-01-20T14:00:00Z"}, "cursor": "job-cursor-1"}
  ]
}
