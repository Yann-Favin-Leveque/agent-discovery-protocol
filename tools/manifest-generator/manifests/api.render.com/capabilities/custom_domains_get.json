{
  "name": "custom_domains_get",
  "description": "Get details about a specific custom domain including verification status and DNS records.",
  "resource_group": "custom_domains",
  "endpoint": "/v1/services/{serviceId}/custom-domains/{customDomainIdOrName}",
  "method": "GET",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "The service ID.",
      "in": "path"
    },
    {
      "name": "customDomainIdOrName",
      "type": "string",
      "required": true,
      "description": "The custom domain ID or domain name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/custom-domains/api.example.com"
  },
  "response_example": {
    "id": "cdm-abc123",
    "name": "api.example.com",
    "domainType": "apex",
    "verificationStatus": "verified"
  }
}
