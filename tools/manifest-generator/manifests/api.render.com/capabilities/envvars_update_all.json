{
  "name": "envvars_update_all",
  "description": "Replace all environment variables for a service with a new set. This overwrites all existing variables.",
  "resource_group": "environment_variables",
  "endpoint": "/v1/services/{serviceId}/env-vars",
  "method": "PUT",
  "parameters": [
    {"name": "serviceId", "type": "string", "required": true, "description": "The service ID."},
    {"name": "envVars", "type": "array", "required": true, "description": "Array of {key, value} environment variable objects to set."}
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/env-vars",
    "body": [
      {"key": "NODE_ENV", "value": "production"},
      {"key": "PORT", "value": "3000"}
    ]
  },
  "response_example": [
    {"envVar": {"key": "NODE_ENV", "value": "production"}},
    {"envVar": {"key": "PORT", "value": "3000"}}
  ]
}
