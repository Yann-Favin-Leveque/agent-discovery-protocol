{
  "name": "envvars_get",
  "description": "Retrieve a specific environment variable by key name.",
  "resource_group": "environment_variables",
  "endpoint": "/v1/services/{serviceId}/env-vars/{envVarKey}",
  "method": "GET",
  "parameters": [
    {"name": "serviceId", "type": "string", "required": true, "description": "The service ID."},
    {"name": "envVarKey", "type": "string", "required": true, "description": "The environment variable key name."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.render.com/v1/services/srv-a1b2c3d4e5/env-vars/NODE_ENV"
  },
  "response_example": {
    "key": "NODE_ENV",
    "value": "production"
  }
}
