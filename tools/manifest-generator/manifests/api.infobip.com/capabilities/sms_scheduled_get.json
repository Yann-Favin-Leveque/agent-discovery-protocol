{
  "name": "sms_scheduled_get",
  "description": "Retrieve the status of a previously scheduled SMS message batch by its bulk ID.",
  "endpoint": "/sms/1/bulks",
  "method": "GET",
  "resource_group": "sms",
  "parameters": [
    {
      "name": "bulkId",
      "type": "string",
      "required": true,
      "description": "The bulk ID of the scheduled message batch.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.infobip.com/sms/1/bulks?bulkId=2034072219640523072",
    "headers": {
      "Authorization": "App {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "bulkId": "2034072219640523072",
      "sendAt": "2024-01-20T12:00:00.000+0000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
