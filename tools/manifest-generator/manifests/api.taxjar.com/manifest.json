{
  "spec_version": "1.0",
  "name": "TaxJar",
  "description": "US sales tax calculation, reporting, and filing API. Calculate tax rates, manage order and refund transactions, handle customers and nexus addresses, validate addresses and VAT numbers.",
  "base_url": "https://api.taxjar.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://app.taxjar.com/api_sign_up"
  },
  "capabilities": [
    {
      "name": "categories_list",
      "description": "List all product tax categories with tax codes.",
      "detail_url": "/capabilities/categories_list",
      "resource_group": "categories"
    },
    {
      "name": "taxes_calculate",
      "description": "Calculate sales tax for an order based on origin/destination and line items.",
      "detail_url": "/capabilities/taxes_calculate",
      "resource_group": "taxes"
    },
    {
      "name": "rates_get",
      "description": "Get tax rates for a specific location by zip code.",
      "detail_url": "/capabilities/rates_get",
      "resource_group": "rates"
    },
    {
      "name": "orders_list",
      "description": "List existing order transactions.",
      "detail_url": "/capabilities/orders_list",
      "resource_group": "orders"
    },
    {
      "name": "orders_get",
      "description": "Retrieve a specific order transaction by ID.",
      "detail_url": "/capabilities/orders_get",
      "resource_group": "orders"
    },
    {
      "name": "orders_create",
      "description": "Create a new order transaction for reporting.",
      "detail_url": "/capabilities/orders_create",
      "resource_group": "orders"
    },
    {
      "name": "orders_update",
      "description": "Update an existing order transaction.",
      "detail_url": "/capabilities/orders_update",
      "resource_group": "orders"
    },
    {
      "name": "orders_delete",
      "description": "Delete an order transaction.",
      "detail_url": "/capabilities/orders_delete",
      "resource_group": "orders"
    },
    {
      "name": "refunds_list",
      "description": "List existing refund transactions.",
      "detail_url": "/capabilities/refunds_list",
      "resource_group": "refunds"
    },
    {
      "name": "refunds_get",
      "description": "Retrieve a specific refund transaction.",
      "detail_url": "/capabilities/refunds_get",
      "resource_group": "refunds"
    },
    {
      "name": "refunds_create",
      "description": "Create a refund transaction for reporting.",
      "detail_url": "/capabilities/refunds_create",
      "resource_group": "refunds"
    },
    {
      "name": "refunds_update",
      "description": "Update an existing refund transaction.",
      "detail_url": "/capabilities/refunds_update",
      "resource_group": "refunds"
    },
    {
      "name": "refunds_delete",
      "description": "Delete a refund transaction.",
      "detail_url": "/capabilities/refunds_delete",
      "resource_group": "refunds"
    },
    {
      "name": "customers_list",
      "description": "List all customers.",
      "detail_url": "/capabilities/customers_list",
      "resource_group": "customers"
    },
    {
      "name": "customers_get",
      "description": "Retrieve a customer by ID.",
      "detail_url": "/capabilities/customers_get",
      "resource_group": "customers"
    },
    {
      "name": "customers_create",
      "description": "Create a new customer with exemption details.",
      "detail_url": "/capabilities/customers_create",
      "resource_group": "customers"
    },
    {
      "name": "customers_update",
      "description": "Update an existing customer.",
      "detail_url": "/capabilities/customers_update",
      "resource_group": "customers"
    },
    {
      "name": "customers_delete",
      "description": "Delete a customer.",
      "detail_url": "/capabilities/customers_delete",
      "resource_group": "customers"
    },
    {
      "name": "nexus_list",
      "description": "List nexus regions for the account.",
      "detail_url": "/capabilities/nexus_list",
      "resource_group": "nexus"
    },
    {
      "name": "addresses_validate",
      "description": "Validate a US address using USPS database.",
      "detail_url": "/capabilities/addresses_validate",
      "resource_group": "validations"
    },
    {
      "name": "validations_validate",
      "description": "Validate a VAT identification number (EU/UK/AU/etc.).",
      "detail_url": "/capabilities/validations_validate",
      "resource_group": "validations"
    },
    {
      "name": "summary_rates_list",
      "description": "Get summarized tax rates for all regions where you have nexus.",
      "detail_url": "/capabilities/summary_rates_list",
      "resource_group": "summary_rates"
    }
  ]
}