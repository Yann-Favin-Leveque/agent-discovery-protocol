{
  "name": "orders_get",
  "description": "Retrieve a specific order transaction by ID.",
  "endpoint": "/v2/transactions/orders/{transaction_id}",
  "method": "GET",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Order transaction ID.",
      "required": true,
      "example": "321"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.taxjar.com/v2/transactions/orders/321",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "transaction_id": "321",
        "user_id": 123,
        "transaction_date": "2024-01-15",
        "to_country": "US",
        "to_zip": "90002",
        "to_state": "CA",
        "amount": "15.00",
        "shipping": "1.50",
        "sales_tax": "1.36"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}