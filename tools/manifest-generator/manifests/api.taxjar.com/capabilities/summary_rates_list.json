          "minimum_rate": {
            "label": "State Tax",
            "rate": 0.0625
          },
          "average_rate": {
            "label": "Tax",
            "rate": 0.0868
          }
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}