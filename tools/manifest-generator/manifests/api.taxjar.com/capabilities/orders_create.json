{
  "name": "orders_create",
  "description": "Create a new order transaction for reporting.",
  "endpoint": "/v2/transactions/orders",
  "method": "POST",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Unique order transaction ID.",
      "required": true,
      "example": "321"
    },
    {
      "name": "transaction_date",
      "type": "string",
      "description": "Transaction date.",
      "required": true,
      "example": "2024/01/15"
    },
    {
      "name": "to_country",
      "type": "string",
      "description": "Destination country.",
      "required": true,
      "example": "US"
    },
    {
      "name": "to_zip",
      "type": "string",
      "description": "Destination zip.",
      "required": true,
      "example": "90002"
    },
    {
      "name": "to_state",
      "type": "string",
      "description": "Destination state.",
      "required": true,
      "example": "CA"
    },
    {
      "name": "amount",
      "type": "number",
      "description": "Order amount.",
      "required": true,
      "example": 15.0
    },
    {
      "name": "shipping",
      "type": "number",
      "description": "Shipping amount.",
      "required": true,
      "example": 1.5
    },
    {
      "name": "sales_tax",
      "type": "number",
      "description": "Sales tax collected.",
      "required": true,
      "example": 1.36
    },
    {
      "name": "line_items",
      "type": "array",
      "description": "Array of line items.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.taxjar.com/v2/transactions/orders",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "transaction_id": "321",
      "transaction_date": "2024/01/15",
      "to_country": "US",
      "to_zip": "90002",
      "to_state": "CA",
      "amount": 15.0,
      "shipping": 1.5,
      "sales_tax": 1.36,
      "line_items": [
        {
          "id": "1",
          "quantity": 1,
          "product_identifier": "12-34243-0",
          "description": "Widget",
          "unit_price": 15.0,
          "sales_tax": 1.36
        }
      ]
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "order": {
        "transaction_id": "321",
        "transaction_date": "2024-01-15",
        "amount": "15.00",
        "shipping": "1.50",
        "sales_tax": "1.36"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}