{
  "name": "customers_delete",
  "description": "Delete a customer.",
  "endpoint": "/v2/customers/{customer_id}",
  "method": "DELETE",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "Customer ID.",
      "required": true,
      "example": "CUST-001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.taxjar.com/v2/customers/CUST-001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer": {
        "customer_id": "CUST-001"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
