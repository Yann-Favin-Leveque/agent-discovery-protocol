{
  "name": "refunds_get",
  "description": "Retrieve a specific refund transaction.",
  "endpoint": "/v2/transactions/refunds/{transaction_id}",
  "method": "GET",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Refund transaction ID.",
      "required": true,
      "example": "321-refund"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.taxjar.com/v2/transactions/refunds/321-refund",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refund": {
        "transaction_id": "321-refund",
        "transaction_reference_id": "321",
        "transaction_date": "2024-01-20",
        "amount": "-15.00",
        "shipping": "-1.50",
        "sales_tax": "-1.36"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}