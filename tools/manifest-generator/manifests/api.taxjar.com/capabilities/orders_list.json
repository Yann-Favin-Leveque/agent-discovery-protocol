{
  "name": "orders_list",
  "description": "List existing order transactions.",
  "endpoint": "/v2/transactions/orders",
  "method": "GET",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "transaction_date",
      "type": "string",
      "description": "Filter by transaction date (YYYY/MM/DD).",
      "required": false
    },
    {
      "name": "from_transaction_date",
      "type": "string",
      "description": "Start date filter.",
      "required": false,
      "example": "2024/01/01"
    },
    {
      "name": "to_transaction_date",
      "type": "string",
      "description": "End date filter.",
      "required": false,
      "example": "2024/01/31"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.taxjar.com/v2/transactions/orders?from_transaction_date=2024/01/01&to_transaction_date=2024/01/31",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "orders": [
        "321",
        "654",
        "987"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}