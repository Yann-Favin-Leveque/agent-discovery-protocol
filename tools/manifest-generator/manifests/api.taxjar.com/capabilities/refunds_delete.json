{
  "name": "refunds_delete",
  "description": "Delete a refund transaction.",
  "endpoint": "/v2/transactions/refunds/{transaction_id}",
  "method": "DELETE",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Refund transaction ID.",
      "required": true,
      "example": "321-refund",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.taxjar.com/v2/transactions/refunds/321-refund",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refund": {
        "transaction_id": "321-refund"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
