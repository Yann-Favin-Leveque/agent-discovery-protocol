{
  "name": "orders_update",
  "description": "Update an existing order transaction.",
  "endpoint": "/v2/transactions/orders/{transaction_id}",
  "method": "PUT",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Order transaction ID.",
      "required": true,
      "example": "321",
      "in": "path"
    },
    {
      "name": "amount",
      "type": "number",
      "description": "Updated amount.",
      "required": false,
      "in": "body"
    },
    {
      "name": "shipping",
      "type": "number",
      "description": "Updated shipping.",
      "required": false,
      "in": "body"
    },
    {
      "name": "sales_tax",
      "type": "number",
      "description": "Updated sales tax.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.taxjar.com/v2/transactions/orders/321",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "transaction_id": "321",
      "amount": 20,
      "shipping": 2,
      "sales_tax": 1.82
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "transaction_id": "321",
        "amount": "20.00",
        "shipping": "2.00",
        "sales_tax": "1.82"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
