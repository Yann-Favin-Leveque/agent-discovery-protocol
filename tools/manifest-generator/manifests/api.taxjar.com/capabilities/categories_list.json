{
  "name": "categories_list",
  "description": "List all product tax categories with tax codes.",
  "endpoint": "/v2/categories",
  "method": "GET",
  "resource_group": "categories",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.taxjar.com/v2/categories",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "categories": [
        {
          "name": "Clothing",
          "product_tax_code": "20010",
          "description": "All human wearing apparel suitable for general use."
        },
        {
          "name": "Food & Groceries",
          "product_tax_code": "40030",
          "description": "Food for home consumption."
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}