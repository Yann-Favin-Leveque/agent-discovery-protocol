{
  "name": "refunds_list",
  "description": "List existing refund transactions.",
  "endpoint": "/v2/transactions/refunds",
  "method": "GET",
  "resource_group": "refunds",
  "parameters": [
    {
      "name": "from_transaction_date",
      "type": "string",
      "description": "Start date filter.",
      "required": false,
      "example": "2024/01/01",
      "in": "query"
    },
    {
      "name": "to_transaction_date",
      "type": "string",
      "description": "End date filter.",
      "required": false,
      "example": "2024/01/31",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.taxjar.com/v2/transactions/refunds?from_transaction_date=2024/01/01&to_transaction_date=2024/01/31",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "refunds": [
        "321-refund",
        "654-refund"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
