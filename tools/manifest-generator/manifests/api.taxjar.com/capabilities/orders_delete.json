{
  "name": "orders_delete",
  "description": "Delete an order transaction.",
  "endpoint": "/v2/transactions/orders/{transaction_id}",
  "method": "DELETE",
  "resource_group": "orders",
  "parameters": [
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Order transaction ID.",
      "required": true,
      "example": "321",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.taxjar.com/v2/transactions/orders/321",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "transaction_id": "321"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
