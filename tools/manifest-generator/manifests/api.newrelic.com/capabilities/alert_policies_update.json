{
  "name": "alert_policies_update",
  "description": "Update an existing alert policy.",
  "resource_group": "alerts",
  "endpoint": "/v2/alerts_policies/{policy_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "policy_id",
      "type": "integer",
      "required": true,
      "description": "Policy ID",
      "location": "path"
    },
    {
      "name": "policy",
      "type": "object",
      "required": true,
      "description": "Updated policy"
    }
  ],
  "request_example": {
    "policy": {
      "name": "Updated Policy",
      "incident_preference": "PER_CONDITION"
    }
  },
  "response_example": {
    "policy": {
      "id": 2
    }
  },
  "auth_scopes": []
}
