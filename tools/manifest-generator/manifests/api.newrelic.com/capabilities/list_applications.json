{
  "name": "list_applications",
  "description": "List all monitored applications in the New Relic account. Returns application names, IDs, language, health status, and summary metrics including response time, throughput, and error rate. Supports filtering by name and pagination.",
  "endpoint": "/v2/applications.json",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[name]",
      "type": "string",
      "required": false,
      "description": "Filter applications by name (exact or partial match)."
    },
    {
      "name": "filter[host]",
      "type": "string",
      "required": false,
      "description": "Filter applications by host name."
    },
    {
      "name": "filter[ids]",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of application IDs to filter by."
    },
    {
      "name": "filter[language]",
      "type": "string",
      "required": false,
      "description": "Filter by application language (e.g. 'java', 'python', 'nodejs')."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination (starts at 1)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.newrelic.com/v2/applications.json?filter[name]=my-app",
    "headers": {
      "Api-Key": "NRAK-XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "applications": [
        {
          "id": 12345678,
          "name": "my-app-production",
          "language": "nodejs",
          "health_status": "green",
          "reporting": true,
          "last_reported_at": "2026-02-28T15:30:00+00:00",
          "application_summary": {
            "response_time": 45.2,
            "throughput": 1250.0,
            "error_rate": 0.12,
            "apdex_target": 0.5,
            "apdex_score": 0.95,
            "host_count": 3,
            "instance_count": 6
          },
          "settings": {
            "app_apdex_threshold": 0.5,
            "end_user_apdex_threshold": 7.0,
            "enable_real_user_monitoring": true
          },
          "links": {
            "application_instances": [98765, 98766, 98767],
            "servers": [],
            "application_hosts": [11111, 22222, 33333]
          }
        }
      ]
    }
  }
}
