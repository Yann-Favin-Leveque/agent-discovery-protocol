{
  "name": "applications_update",
  "description": "Update application settings like Apdex threshold and server-side config.",
  "resource_group": "applications",
  "endpoint": "/v2/applications/{application_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "application_id",
      "type": "integer",
      "required": true,
      "description": "Application ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "application",
      "type": "object",
      "required": true,
      "description": "Application settings to update",
      "in": "body"
    }
  ],
  "request_example": {
    "application": {
      "name": "My App v2",
      "settings": {
        "app_apdex_threshold": 0.7
      }
    }
  },
  "response_example": {
    "application": {
      "id": 12345,
      "name": "My App v2"
    }
  },
  "auth_scopes": []
}
