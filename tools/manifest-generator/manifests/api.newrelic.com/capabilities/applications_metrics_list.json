{
  "name": "applications_metrics_list",
  "description": "List available metric names for an application.",
  "resource_group": "applications",
  "endpoint": "/v2/applications/{application_id}/metrics.json",
  "method": "GET",
  "parameters": [
    {
      "name": "application_id",
      "type": "integer",
      "required": true,
      "description": "Application ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Filter metric names",
      "location": "query",
      "in": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "metrics": [
      {
        "name": "HttpDispatcher",
        "values": [
          "average_response_time",
          "calls_per_minute"
        ]
      }
    ]
  },
  "auth_scopes": []
}
