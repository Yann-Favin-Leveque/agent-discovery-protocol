{
  "name": "get_synthetics_monitors",
  "description": "List all synthetic monitors configured in New Relic Synthetics. Synthetic monitors periodically check the availability and performance of endpoints from multiple geographic locations. Returns monitor name, type, status, frequency, locations, and the URI being monitored.",
  "endpoint": "/v3/monitors",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Number of monitors to skip for pagination (default 0)."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Maximum number of monitors to return (default 20, max 100)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.newrelic.com/v3/monitors?limit=50",
    "headers": {
      "Api-Key": "NRAK-XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "monitors": [
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "name": "Production Homepage",
          "type": "SIMPLE",
          "frequency": 5,
          "uri": "https://www.example.com",
          "locations": ["AWS_US_EAST_1", "AWS_EU_WEST_1", "AWS_AP_SOUTHEAST_1"],
          "status": "ENABLED",
          "slaThreshold": 7.0,
          "options": {},
          "modifiedAt": "2026-02-20T10:00:00+00:00",
          "createdAt": "2025-06-15T08:30:00+00:00"
        },
        {
          "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
          "name": "API Health Check",
          "type": "SIMPLE",
          "frequency": 1,
          "uri": "https://api.example.com/health",
          "locations": ["AWS_US_EAST_1", "AWS_US_WEST_2"],
          "status": "ENABLED",
          "slaThreshold": 7.0,
          "options": {},
          "modifiedAt": "2026-02-25T14:20:00+00:00",
          "createdAt": "2025-09-01T12:00:00+00:00"
        }
      ],
      "count": 2
    }
  }
}
