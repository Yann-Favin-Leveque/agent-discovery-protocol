{
  "name": "list_alert_policies",
  "description": "List all alert policies configured in the New Relic account. Returns policy names, IDs, incident preference settings, and creation/update timestamps. Supports filtering by name and pagination.",
  "endpoint": "/v2/alerts_policies.json",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[name]",
      "type": "string",
      "required": false,
      "description": "Filter alert policies by exact name match."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination (starts at 1)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.newrelic.com/v2/alerts_policies.json",
    "headers": {
      "Api-Key": "NRAK-XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "policies": [
        {
          "id": 555001,
          "incident_preference": "PER_POLICY",
          "name": "Production Critical Alerts",
          "created_at": 1704067200,
          "updated_at": 1709251200
        },
        {
          "id": 555002,
          "incident_preference": "PER_CONDITION",
          "name": "Staging Warnings",
          "created_at": 1704153600,
          "updated_at": 1708646400
        },
        {
          "id": 555003,
          "incident_preference": "PER_CONDITION_AND_TARGET",
          "name": "Infrastructure Monitoring",
          "created_at": 1706745600,
          "updated_at": 1709337600
        }
      ]
    }
  }
}
