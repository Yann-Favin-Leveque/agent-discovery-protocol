{
  "name": "create_cart",
  "description": "Create a new shopping cart for a customer session, optionally pre-populated with line items and a region. The cart ID is used for all subsequent cart operations and checkout.",
  "endpoint": "/store/carts",
  "method": "POST",
  "parameters": [
    {
      "name": "region_id",
      "type": "string",
      "description": "The region ID to associate with the cart, determining currency and tax rules.",
      "required": false,
      "example": "reg_01H..."
    },
    {
      "name": "items",
      "type": "array",
      "description": "Array of line items to add to the cart, each with variant_id and quantity.",
      "required": false,
      "example": [
        {
          "variant_id": "variant_01H...",
          "quantity": 1
        }
      ]
    },
    {
      "name": "country_code",
      "type": "string",
      "description": "ISO 2-letter country code to auto-select the region.",
      "required": false,
      "example": "us"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.medusajs.com/store/carts",
    "headers": {
      "x-publishable-api-key": "YOUR_PUBLISHABLE_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "region_id": "reg_01H...",
      "items": [
        {
          "variant_id": "variant_01H...",
          "quantity": 1
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "cart": {
        "id": "cart_01H...",
        "region_id": "reg_01H...",
        "items": [
          {
            "id": "item_01H...",
            "variant_id": "variant_01H...",
            "title": "Medusa T-Shirt",
            "quantity": 1,
            "unit_price": 2000,
            "subtotal": 2000
          }
        ],
        "subtotal": 2000,
        "total": 2000,
        "created_at": "2024-01-15T10:00:00.000Z"
      }
    }
  }
}
