{
  "name": "carts_get",
  "description": "Retrieve cart details.",
  "resource_group": "carts",
  "endpoint": "/store/carts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Cart ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/carts/cart_01",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "cart": {
        "id": "cart_01",
        "items": [],
        "subtotal": 0,
        "total": 0
      }
    }
  }
}
