{
  "name": "products_get",
  "description": "Retrieve full product details.",
  "resource_group": "products",
  "endpoint": "/store/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Product ID.",
      "example": "prod_01"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/products/prod_01",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "product": {
        "id": "prod_01",
        "title": "Medusa T-Shirt",
        "description": "A great t-shirt",
        "variants": [
          {
            "id": "var_01",
            "title": "S / Black"
          }
        ],
        "images": [
          {
            "url": "https://example.com/image.jpg"
          }
        ]
      }
    }
  }
}