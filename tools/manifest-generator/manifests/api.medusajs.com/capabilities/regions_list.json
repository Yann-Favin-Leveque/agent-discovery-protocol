{
  "name": "regions_list",
  "description": "Retrieve available regions with currencies and tax rates.",
  "resource_group": "regions",
  "endpoint": "/store/regions",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/regions",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "regions": [
        {
          "id": "reg_01",
          "name": "NA",
          "currency_code": "usd",
          "tax_rate": 0
        }
      ]
    }
  }
}