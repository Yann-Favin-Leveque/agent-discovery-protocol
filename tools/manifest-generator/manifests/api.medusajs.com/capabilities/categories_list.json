{
  "name": "categories_list",
  "description": "Retrieve product categories.",
  "resource_group": "categories",
  "endpoint": "/store/product-categories",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Results to skip."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/product-categories",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "product_categories": [
        {
          "id": "pcat_01",
          "name": "Shirts",
          "handle": "shirts"
        }
      ]
    }
  }
}