{
  "name": "collections_list",
  "description": "Retrieve product collections.",
  "resource_group": "collections",
  "endpoint": "/store/collections",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Results to skip.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/collections",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collections": [
        {
          "id": "col_01",
          "title": "Summer Collection",
          "handle": "summer"
        }
      ]
    }
  }
}
