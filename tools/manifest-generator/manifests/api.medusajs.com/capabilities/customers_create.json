{
  "name": "customers_create",
  "description": "Create a new customer account.",
  "resource_group": "customers",
  "endpoint": "/store/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "first_name",
      "type": "string",
      "required": true,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": true,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email address.",
      "example": "customer@example.com",
      "in": "body"
    },
    {
      "name": "password",
      "type": "string",
      "required": true,
      "description": "Account password.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.medusajs.com/store/customers",
    "headers": {
      "x-publishable-api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "first_name": "John",
      "last_name": "Doe",
      "email": "john@example.com",
      "password": "supersecure"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer": {
        "id": "cus_01",
        "email": "john@example.com",
        "first_name": "John",
        "last_name": "Doe"
      }
    }
  }
}
