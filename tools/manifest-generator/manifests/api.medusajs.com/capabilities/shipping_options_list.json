{
  "name": "shipping_options_list",
  "description": "List available shipping options.",
  "resource_group": "shipping",
  "endpoint": "/store/shipping-options",
  "method": "GET",
  "parameters": [
    {
      "name": "cart_id",
      "type": "string",
      "required": false,
      "description": "Cart ID to get applicable shipping options.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/shipping-options?cart_id=cart_01",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "shipping_options": [
        {
          "id": "so_01",
          "name": "Standard Shipping",
          "amount": 800
        }
      ]
    }
  }
}
