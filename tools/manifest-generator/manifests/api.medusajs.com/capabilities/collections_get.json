{
  "name": "collections_get",
  "description": "Retrieve a specific collection.",
  "resource_group": "collections",
  "endpoint": "/store/collections/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Collection ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/collections/col_01",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collection": {
        "id": "col_01",
        "title": "Summer Collection"
      }
    }
  }
}