{
  "name": "carts_line_items_add",
  "description": "Add line items to a cart.",
  "resource_group": "carts",
  "endpoint": "/store/carts/{id}/line-items",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Cart ID.",
      "in": "path"
    },
    {
      "name": "variant_id",
      "type": "string",
      "required": true,
      "description": "Product variant ID.",
      "example": "var_01",
      "in": "body"
    },
    {
      "name": "quantity",
      "type": "integer",
      "required": true,
      "description": "Quantity to add.",
      "example": 1,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.medusajs.com/store/carts/cart_01/line-items",
    "headers": {
      "x-publishable-api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "variant_id": "var_01",
      "quantity": 1
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "cart": {
        "id": "cart_01",
        "items": [
          {
            "id": "item_01",
            "variant_id": "var_01",
            "quantity": 1,
            "unit_price": 2000
          }
        ]
      }
    }
  }
}
