{
  "name": "get_product",
  "description": "Retrieve full details for a specific product including all variants, options, images, and metadata. Use the product handle or ID to look up a single product.",
  "endpoint": "/store/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The unique product ID.",
      "required": true,
      "example": "prod_01H..."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/products/prod_01H...",
    "headers": {
      "x-publishable-api-key": "YOUR_PUBLISHABLE_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "product": {
        "id": "prod_01H...",
        "title": "Medusa T-Shirt",
        "description": "A comfortable cotton t-shirt with the Medusa logo.",
        "handle": "medusa-t-shirt",
        "status": "published",
        "thumbnail": "https://example.com/thumb.jpg",
        "images": [
          {
            "id": "img_01H...",
            "url": "https://example.com/image.jpg"
          }
        ],
        "options": [
          {
            "id": "opt_01H...",
            "title": "Size",
            "values": ["S", "M", "L", "XL"]
          }
        ],
        "variants": [
          {
            "id": "variant_01H...",
            "title": "S / Black",
            "sku": "TSHIRT-S-BLK",
            "prices": [
              {
                "amount": 2000,
                "currency_code": "usd"
              }
            ],
            "inventory_quantity": 50
          }
        ],
        "collection_id": "col_01H...",
        "created_at": "2024-01-15T10:00:00.000Z"
      }
    }
  }
}
