{
  "name": "carts_line_items_delete",
  "description": "Remove a line item from a cart.",
  "resource_group": "carts",
  "endpoint": "/store/carts/{id}/line-items/{line_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Cart ID.",
      "in": "path"
    },
    {
      "name": "line_id",
      "type": "string",
      "required": true,
      "description": "Line item ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.medusajs.com/store/carts/cart_01/line-items/item_01",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "cart": {
        "id": "cart_01",
        "items": []
      }
    }
  }
}
