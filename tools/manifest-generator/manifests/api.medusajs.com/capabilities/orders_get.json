{
  "name": "orders_get",
  "description": "Retrieve an order by ID.",
  "resource_group": "orders",
  "endpoint": "/store/orders/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Order ID.",
      "example": "order_01",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/orders/order_01",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "order": {
        "id": "order_01",
        "status": "completed",
        "items": [
          {
            "title": "Medusa T-Shirt",
            "quantity": 1,
            "unit_price": 2000
          }
        ],
        "total": 2000
      }
    }
  }
}
