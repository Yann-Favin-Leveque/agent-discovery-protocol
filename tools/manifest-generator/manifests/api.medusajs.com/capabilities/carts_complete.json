{
  "name": "carts_complete",
  "description": "Complete checkout and create an order.",
  "resource_group": "carts",
  "endpoint": "/store/carts/{id}/complete",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Cart ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.medusajs.com/store/carts/cart_01/complete",
    "headers": {
      "x-publishable-api-key": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "order",
      "data": {
        "id": "order_01",
        "status": "pending",
        "total": 2000
      }
    }
  }
}