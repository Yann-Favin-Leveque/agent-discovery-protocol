{
  "name": "orders_list",
  "description": "List orders for the authenticated customer.",
  "resource_group": "orders",
  "endpoint": "/store/orders",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Results to skip.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/orders",
    "headers": {
      "x-publishable-api-key": "{api_key}",
      "Authorization": "Bearer {customer_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "orders": [
        {
          "id": "order_01",
          "status": "completed",
          "total": 2000
        }
      ]
    }
  }
}
