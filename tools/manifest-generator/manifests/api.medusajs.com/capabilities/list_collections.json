{
  "name": "list_collections",
  "description": "Retrieve product collections available in the store for organized browsing and category-based navigation. Collections group related products together for merchandising.",
  "endpoint": "/store/collections",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of collections to return. Defaults to 10.",
      "required": false,
      "example": 10
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of collections to skip for pagination.",
      "required": false,
      "example": 0
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/collections?limit=10&offset=0",
    "headers": {
      "x-publishable-api-key": "YOUR_PUBLISHABLE_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "collections": [
        {
          "id": "col_01H...",
          "title": "Summer Collection",
          "handle": "summer-collection",
          "created_at": "2024-01-10T08:00:00.000Z",
          "updated_at": "2024-01-10T08:00:00.000Z"
        },
        {
          "id": "col_02H...",
          "title": "New Arrivals",
          "handle": "new-arrivals",
          "created_at": "2024-01-12T08:00:00.000Z",
          "updated_at": "2024-01-12T08:00:00.000Z"
        }
      ],
      "count": 2,
      "offset": 0,
      "limit": 10
    }
  }
}
