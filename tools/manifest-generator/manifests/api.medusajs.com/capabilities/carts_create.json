{
  "name": "carts_create",
  "description": "Create a new shopping cart.",
  "resource_group": "carts",
  "endpoint": "/store/carts",
  "method": "POST",
  "parameters": [
    {
      "name": "region_id",
      "type": "string",
      "required": false,
      "description": "Region ID for pricing.",
      "in": "body"
    },
    {
      "name": "items",
      "type": "array",
      "required": false,
      "description": "Initial line items with variant_id and quantity.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.medusajs.com/store/carts",
    "headers": {
      "x-publishable-api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "region_id": "reg_01"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "cart": {
        "id": "cart_01",
        "region_id": "reg_01",
        "items": [],
        "total": 0
      }
    }
  }
}
