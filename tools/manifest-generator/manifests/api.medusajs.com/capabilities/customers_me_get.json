{
  "name": "customers_me_get",
  "description": "Retrieve the authenticated customer profile.",
  "resource_group": "customers",
  "endpoint": "/store/customers/me",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.medusajs.com/store/customers/me",
    "headers": {
      "x-publishable-api-key": "{api_key}",
      "Authorization": "Bearer {customer_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "customer": {
        "id": "cus_01",
        "email": "john@example.com",
        "first_name": "John",
        "last_name": "Doe"
      }
    }
  }
}