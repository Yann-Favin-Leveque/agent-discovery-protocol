{
  "name": "contacts_find",
  "description": "Find a contact by email address.",
  "endpoint": "/api/v1/contacts/find",
  "method": "GET",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Email address to search for.",
      "required": true,
      "example": "user@example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.loops.so/api/v1/contacts/find?email=user@example.com",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "contact_abc123",
        "email": "user@example.com",
        "firstName": "John",
        "lastName": "Doe",
        "subscribed": true
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}