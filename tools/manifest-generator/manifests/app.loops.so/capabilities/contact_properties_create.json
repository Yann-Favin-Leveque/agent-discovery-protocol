{
  "name": "contact_properties_create",
  "description": "Create a new custom contact property.",
  "endpoint": "/api/v1/contact-properties",
  "method": "POST",
  "resource_group": "contact_properties",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Property key name.",
      "required": true,
      "example": "plan_type",
      "in": "body"
    },
    {
      "name": "label",
      "type": "string",
      "description": "Display label.",
      "required": true,
      "example": "Plan Type",
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Property type: string, number, boolean, date.",
      "required": true,
      "example": "string",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://app.loops.so/api/v1/contact-properties",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "key": "plan_type",
      "label": "Plan Type",
      "type": "string"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
