{
  "name": "contacts_delete",
  "description": "Delete a contact from Loops by email or user ID.",
  "endpoint": "/api/v1/contacts",
  "method": "DELETE",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Email of the contact to delete.",
      "required": false,
      "example": "user@example.com"
    },
    {
      "name": "userId",
      "type": "string",
      "description": "User ID of the contact to delete.",
      "required": false
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://app.loops.so/api/v1/contacts",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "message": "Contact deleted."
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}