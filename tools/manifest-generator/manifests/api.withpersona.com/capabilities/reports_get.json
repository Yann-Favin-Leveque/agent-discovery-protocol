{
  "name": "reports_get",
  "description": "Retrieve a specific report by ID including its status and results.",
  "resource_group": "reports",
  "endpoint": "/reports/{report_id}",
  "method": "GET",
  "parameters": [
    {"name": "report_id", "type": "string", "description": "The report ID.", "required": true, "example": "rep_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://withpersona.com/api/v1/reports/rep_abc123",
    "headers": {"Authorization": "Bearer {api_key}", "Persona-Version": "2023-01-05"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"type": "report", "id": "rep_abc123", "attributes": {"status": "ready", "created-at": "2024-01-15T10:30:00.000Z", "completed-at": "2024-01-15T10:35:00.000Z"}}}
  },
  "rate_limits": {"requests_per_minute": 300}
}