{
  "name": "accounts_update",
  "description": "Update fields on an existing Persona account.",
  "resource_group": "accounts",
  "endpoint": "/accounts/{account_id}",
  "method": "PATCH",
  "parameters": [
    {"name": "account_id", "type": "string", "description": "The account ID.", "required": true, "example": "act_abc123"},
    {"name": "reference-id", "type": "string", "description": "Updated reference ID.", "required": false},
    {"name": "tags", "type": "array", "description": "Tags to assign to the account.", "required": false}
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://withpersona.com/api/v1/accounts/act_abc123",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json", "Persona-Version": "2023-01-05"},
    "body": {"data": {"attributes": {"reference-id": "updated_ref_123"}}}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"type": "account", "id": "act_abc123", "attributes": {"reference-id": "updated_ref_123"}}}
  },
  "rate_limits": {"requests_per_minute": 300}
}