{
  "name": "reports_list",
  "description": "List all reports with optional filtering by status, account, and pagination.",
  "resource_group": "reports",
  "endpoint": "/reports",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[account-id]",
      "type": "string",
      "description": "Filter by account ID.",
      "required": false,
      "in": "query"
    },
    {
      "name": "filter[status]",
      "type": "string",
      "description": "Filter by status (pending, ready, errored).",
      "required": false,
      "in": "query"
    },
    {
      "name": "page[after]",
      "type": "string",
      "description": "Cursor for pagination.",
      "required": false,
      "in": "query"
    },
    {
      "name": "page[size]",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://withpersona.com/api/v1/reports?filter[status]=ready&page[size]=25",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Persona-Version": "2023-01-05"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "report",
          "id": "rep_abc123",
          "attributes": {
            "status": "ready",
            "created-at": "2024-01-15T10:30:00.000Z"
          }
        }
      ]
    }
  },
  "rate_limits": {
    "requests_per_minute": 300
  }
}
