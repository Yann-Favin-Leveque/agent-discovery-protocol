{
  "name": "accounts_list",
  "description": "List all accounts with optional filtering by reference ID and pagination.",
  "resource_group": "accounts",
  "endpoint": "/accounts",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[reference-id]",
      "type": "string",
      "description": "Filter by reference ID.",
      "required": false,
      "example": "user_12345",
      "in": "query"
    },
    {
      "name": "page[after]",
      "type": "string",
      "description": "Cursor for pagination.",
      "required": false,
      "in": "query"
    },
    {
      "name": "page[size]",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 25,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://withpersona.com/api/v1/accounts?page[size]=25",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Persona-Version": "2023-01-05"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "account",
          "id": "act_abc123",
          "attributes": {
            "reference-id": "user_12345",
            "name-first": "Jane",
            "name-last": "Doe"
          }
        }
      ]
    }
  },
  "rate_limits": {
    "requests_per_minute": 300
  }
}
