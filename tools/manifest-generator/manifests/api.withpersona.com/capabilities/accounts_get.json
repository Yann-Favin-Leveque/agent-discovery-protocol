{
  "name": "accounts_get",
  "description": "Retrieve a specific account by ID, including linked inquiries and verification summary.",
  "resource_group": "accounts",
  "endpoint": "/accounts/{account_id}",
  "method": "GET",
  "parameters": [
    {"name": "account_id", "type": "string", "description": "The account ID.", "required": true, "example": "act_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://withpersona.com/api/v1/accounts/act_abc123",
    "headers": {"Authorization": "Bearer {api_key}", "Persona-Version": "2023-01-05"}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"type": "account", "id": "act_abc123", "attributes": {"reference-id": "user_12345", "name-first": "Jane", "name-last": "Doe", "created-at": "2024-01-15T10:30:00.000Z"}}}
  },
  "rate_limits": {"requests_per_minute": 300}
}