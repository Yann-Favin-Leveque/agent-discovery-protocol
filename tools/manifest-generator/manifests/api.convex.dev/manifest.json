{
  "spec_version": "1.0",
  "name": "Convex",
  "description": "Convex is a reactive backend-as-a-service platform. Use this HTTP API to run queries, mutations, and actions against your Convex deployment.",
  "base_url": "https://api.convex.dev",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Convex",
    "setup_url": "https://dashboard.convex.dev"
  },
  "capabilities": [
    {
      "name": "functions_query",
      "resource_group": "functions",
      "description": "Execute a read-only query function.",
      "detail_url": "/capabilities/functions_query"
    },
    {
      "name": "functions_mutation",
      "resource_group": "functions",
      "description": "Execute a mutation function.",
      "detail_url": "/capabilities/functions_mutation"
    },
    {
      "name": "functions_action",
      "resource_group": "functions",
      "description": "Execute an action function.",
      "detail_url": "/capabilities/functions_action"
    },
    {
      "name": "functions_run",
      "resource_group": "functions",
      "description": "Call any function type with path in the URL.",
      "detail_url": "/capabilities/functions_run"
    }
  ]
}