{
  "name": "teammates_get",
  "description": "Retrieve a specific teammate by ID.",
  "endpoint": "/teammates/{teammate_id}",
  "method": "GET",
  "resource_group": "teammates",
  "parameters": [
    {"name": "teammate_id", "type": "string", "description": "The teammate ID.", "required": true, "example": "tea_123"}
  ],
  "request_example": {"method": "GET", "url": "https://api2.frontapp.com/teammates/tea_123", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": {"id": "tea_123", "email": "alice@company.com", "first_name": "Alice", "last_name": "Agent", "is_admin": true}},
  "auth_scopes": ["shared:teammates.read"],
  "rate_limits": {"requests_per_minute": 120}
}
