{
  "name": "comments_list",
  "description": "List all internal comments on a conversation.",
  "endpoint": "/conversations/{conversation_id}/comments",
  "method": "GET",
  "resource_group": "comments",
  "parameters": [
    {
      "name": "conversation_id",
      "type": "string",
      "description": "The conversation ID.",
      "required": true,
      "example": "cnv_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.frontapp.com/conversations/cnv_abc123/comments",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "_results": [
        {
          "id": "com_111",
          "body": "Internal note: customer is VIP.",
          "author": {
            "id": "tea_123"
          },
          "posted_at": 1693560000
        }
      ]
    }
  },
  "auth_scopes": [
    "shared:comments.read"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
