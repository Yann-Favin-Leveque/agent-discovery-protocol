{
  "name": "conversations_get",
  "description": "Retrieve a specific conversation by its ID with full details.",
  "endpoint": "/conversations/{conversation_id}",
  "method": "GET",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "conversation_id",
      "type": "string",
      "description": "The conversation ID.",
      "required": true,
      "example": "cnv_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.frontapp.com/conversations/cnv_abc123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "cnv_abc123",
      "subject": "Billing question",
      "status": "assigned",
      "assignee": {
        "id": "tea_123"
      },
      "recipient": {
        "handle": "john@example.com"
      },
      "created_at": 1693560000,
      "last_message": {
        "body": "I have a question about my invoice."
      }
    }
  },
  "auth_scopes": [
    "shared:conversations.read"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
