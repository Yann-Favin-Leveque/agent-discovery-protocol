{
  "name": "tags_create",
  "description": "Create a new tag in the workspace.",
  "endpoint": "/tags",
  "method": "POST",
  "resource_group": "tags",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Tag name.",
      "required": true,
      "example": "urgent",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Tag description.",
      "required": false,
      "example": "Urgent issues",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api2.frontapp.com/tags",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "urgent"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "tag_3",
      "name": "urgent"
    }
  },
  "auth_scopes": [
    "shared:tags.write"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
