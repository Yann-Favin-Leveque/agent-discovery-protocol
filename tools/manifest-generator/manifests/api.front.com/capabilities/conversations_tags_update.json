{
  "name": "conversations_tags_update",
  "description": "Add or replace tags on a conversation for categorization and filtering.",
  "endpoint": "/conversations/{conversation_id}/tags",
  "method": "PUT",
  "resource_group": "conversations",
  "parameters": [
    {"name": "conversation_id", "type": "string", "description": "The conversation ID.", "required": true, "example": "cnv_abc123"},
    {"name": "tag_ids", "type": "array", "description": "Array of tag IDs to apply.", "required": true, "example": ["tag_1", "tag_2"]}
  ],
  "request_example": {"method": "PUT", "url": "https://api2.frontapp.com/conversations/cnv_abc123/tags", "headers": {"Authorization": "Bearer {token}", "Content-Type": "application/json"}, "body": {"tag_ids": ["tag_1", "tag_2"]}},
  "response_example": {"status": 204, "body": {}},
  "auth_scopes": ["shared:conversations.write"],
  "rate_limits": {"requests_per_minute": 120}
}
