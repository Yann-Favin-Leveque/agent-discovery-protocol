{
  "name": "accounts_list",
  "description": "List all company/customer accounts in the workspace.",
  "endpoint": "/accounts",
  "method": "GET",
  "resource_group": "accounts",
  "parameters": [
    {"name": "limit", "type": "integer", "description": "Max results.", "required": false, "example": 50}
  ],
  "request_example": {"method": "GET", "url": "https://api2.frontapp.com/accounts?limit=50", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": {"_results": [{"id": "acc_123", "name": "Acme Corp", "domains": ["acme.com"], "description": "Enterprise customer"}]}},
  "auth_scopes": ["shared:accounts.read"],
  "rate_limits": {"requests_per_minute": 120}
}
