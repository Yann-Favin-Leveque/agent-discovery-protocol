{
  "name": "contacts_get",
  "description": "Retrieve a specific contact by ID with all their details and handles.",
  "endpoint": "/contacts/{contact_id}",
  "method": "GET",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "contact_id",
      "type": "string",
      "description": "The contact ID.",
      "required": true,
      "example": "crd_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.frontapp.com/contacts/crd_123",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "crd_123",
      "name": "John Doe",
      "description": "VIP customer",
      "handles": [
        {
          "handle": "john@example.com",
          "source": "email"
        }
      ],
      "groups": [],
      "custom_fields": {}
    }
  },
  "auth_scopes": [
    "shared:contacts.read"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
