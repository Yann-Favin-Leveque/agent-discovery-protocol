{
  "name": "conversations_update",
  "description": "Update a conversation's status or other properties.",
  "endpoint": "/conversations/{conversation_id}",
  "method": "PATCH",
  "resource_group": "conversations",
  "parameters": [
    {
      "name": "conversation_id",
      "type": "string",
      "description": "The conversation ID.",
      "required": true,
      "example": "cnv_abc123",
      "in": "path"
    },
    {
      "name": "status",
      "type": "string",
      "description": "New status (assigned, unassigned, archived, trashed).",
      "required": false,
      "example": "archived",
      "in": "body"
    },
    {
      "name": "assignee_id",
      "type": "string",
      "description": "Teammate ID to assign.",
      "required": false,
      "example": "tea_123",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api2.frontapp.com/conversations/cnv_abc123",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "status": "archived"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "shared:conversations.write"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
