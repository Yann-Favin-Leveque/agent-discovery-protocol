{
  "name": "contacts_update",
  "description": "Update a contact's name, description, or custom fields.",
  "endpoint": "/contacts/{contact_id}",
  "method": "PATCH",
  "resource_group": "contacts",
  "parameters": [
    {
      "name": "contact_id",
      "type": "string",
      "description": "The contact ID.",
      "required": true,
      "example": "crd_123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "John D.",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false,
      "example": "Enterprise customer",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api2.frontapp.com/contacts/crd_123",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "John D.",
      "description": "Enterprise customer"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "shared:contacts.write"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
