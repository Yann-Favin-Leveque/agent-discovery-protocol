{
  "name": "messages_get",
  "description": "Retrieve a specific message by its ID.",
  "endpoint": "/messages/{message_id}",
  "method": "GET",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "message_id",
      "type": "string",
      "description": "The message ID.",
      "required": true,
      "example": "msg_111",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api2.frontapp.com/messages/msg_111",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "msg_111",
      "body": "Hello, I need help.",
      "type": "email",
      "is_inbound": true,
      "created_at": 1693560000,
      "attachments": []
    }
  },
  "auth_scopes": [
    "shared:messages.read"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
