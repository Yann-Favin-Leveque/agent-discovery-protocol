{
  "name": "conversations_assignee_update",
  "description": "Assign or reassign a conversation to a specific teammate. Pass null to unassign.",
  "endpoint": "/conversations/{conversation_id}/assignee",
  "method": "PUT",
  "resource_group": "conversations",
  "parameters": [
    {"name": "conversation_id", "type": "string", "description": "The conversation ID.", "required": true, "example": "cnv_abc123"},
    {"name": "assignee_id", "type": "string", "description": "Teammate ID to assign, or null to unassign.", "required": true, "example": "tea_123"}
  ],
  "request_example": {"method": "PUT", "url": "https://api2.frontapp.com/conversations/cnv_abc123/assignee", "headers": {"Authorization": "Bearer {token}", "Content-Type": "application/json"}, "body": {"assignee_id": "tea_123"}},
  "response_example": {"status": 204, "body": {}},
  "auth_scopes": ["shared:conversations.write"],
  "rate_limits": {"requests_per_minute": 120}
}
