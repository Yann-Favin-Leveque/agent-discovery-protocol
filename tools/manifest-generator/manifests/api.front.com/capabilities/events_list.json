{
  "name": "events_list",
  "description": "List recent events in the workspace (messages, assignments, tags, etc.).",
  "endpoint": "/events",
  "method": "GET",
  "resource_group": "events",
  "parameters": [
    {"name": "page_token", "type": "string", "description": "Pagination token.", "required": false, "example": "abc"},
    {"name": "limit", "type": "integer", "description": "Max results.", "required": false, "example": 50}
  ],
  "request_example": {"method": "GET", "url": "https://api2.frontapp.com/events?limit=50", "headers": {"Authorization": "Bearer {token}"}, "body": {}},
  "response_example": {"status": 200, "body": {"_results": [{"id": "evt_123", "type": "assign", "emitted_at": 1693560000, "source": {"_meta": {"type": "teammate"}, "data": {"id": "tea_123"}}}]}},
  "auth_scopes": ["shared:events.read"],
  "rate_limits": {"requests_per_minute": 120}
}
