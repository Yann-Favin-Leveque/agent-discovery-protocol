{
  "name": "comments_create",
  "description": "Add an internal comment to a conversation.",
  "endpoint": "/conversations/{conversation_id}/comments",
  "method": "POST",
  "resource_group": "comments",
  "parameters": [
    {"name": "conversation_id", "type": "string", "description": "The conversation ID.", "required": true, "example": "cnv_abc123"},
    {"name": "body", "type": "string", "description": "Comment body text.", "required": true, "example": "Please escalate this to engineering."}
  ],
  "request_example": {"method": "POST", "url": "https://api2.frontapp.com/conversations/cnv_abc123/comments", "headers": {"Authorization": "Bearer {token}", "Content-Type": "application/json"}, "body": {"body": "Please escalate this to engineering."}},
  "response_example": {"status": 201, "body": {"id": "com_222", "body": "Please escalate this to engineering.", "posted_at": 1693560000}},
  "auth_scopes": ["shared:comments.write"],
  "rate_limits": {"requests_per_minute": 120}
}
