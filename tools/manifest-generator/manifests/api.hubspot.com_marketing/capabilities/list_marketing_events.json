{
  "name": "list_marketing_events",
  "description": "Retrieve all marketing events in your HubSpot account. Returns event names, dates, attendance counts, and associated contacts.",
  "endpoint": "/marketing/v3/marketing-events",
  "method": "GET",
  "parameters": [
    { "name": "limit", "type": "integer", "description": "Maximum number of events to return. Default 10, max 100.", "required": false, "example": 20 },
    { "name": "after", "type": "string", "description": "Cursor token for pagination. Returned in previous response.", "required": false, "example": "NTI1Cg%3D%3D" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubspot.com/marketing/v3/marketing-events?limit=20",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/json"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "12345",
          "eventName": "Product Launch Webinar 2024",
          "eventType": "WEBINAR",
          "startDateTime": "2024-03-15T14:00:00Z",
          "endDateTime": "2024-03-15T15:30:00Z",
          "eventOrganizer": "Marketing Team"
        }
      ],
      "paging": {
        "next": {
          "after": "NTI1Cg%3D%3D",
          "link": "https://api.hubspot.com/marketing/v3/marketing-events?after=NTI1Cg%3D%3D"
        }
      }
    }
  }
}
