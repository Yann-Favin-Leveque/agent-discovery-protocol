{
  "name": "get_form_submissions",
  "description": "Retrieve all submissions for a specific form. Returns submitted field values, timestamps, and contact associations.",
  "endpoint": "/form-integrations/v1/submissions/forms/{formId}",
  "method": "GET",
  "parameters": [
    { "name": "formId", "type": "string", "description": "The unique identifier of the form.", "required": true, "example": "form_abc123" },
    { "name": "limit", "type": "integer", "description": "Maximum number of submissions to return. Default 20, max 50.", "required": false, "example": 20 },
    { "name": "after", "type": "string", "description": "Cursor token for pagination.", "required": false, "example": "" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubspot.com/form-integrations/v1/submissions/forms/form_abc123?limit=20",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/json"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "submittedAt": 1700000000000,
          "values": [
            { "name": "email", "value": "john@example.com" },
            { "name": "firstname", "value": "John" }
          ],
          "pageUrl": "https://example.com/signup"
        }
      ],
      "paging": {
        "next": {
          "after": "abc123"
        }
      }
    }
  }
}
