{
  "name": "marketing_events_delete",
  "description": "Delete a marketing event by its external event ID.",
  "endpoint": "/marketing/v3/marketing-events/events/{externalEventId}",
  "method": "DELETE",
  "resource_group": "marketing_events",
  "parameters": [
    {
      "name": "externalEventId",
      "type": "string",
      "description": "The external event identifier to delete.",
      "required": true,
      "example": "ext_event_001"
    },
    {
      "name": "externalAccountId",
      "type": "string",
      "description": "The external account identifier.",
      "required": true,
      "example": "acct_001"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.hubspot.com/marketing/v3/marketing-events/events/ext_event_001?externalAccountId=acct_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": ["marketing-events"],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
