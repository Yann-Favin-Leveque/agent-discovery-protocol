{
  "name": "forms_update",
  "description": "Update an existing form's fields, configuration, or submission settings.",
  "endpoint": "/marketing/v3/forms/{formId}",
  "method": "PATCH",
  "resource_group": "forms",
  "parameters": [
    {
      "name": "formId",
      "type": "string",
      "description": "The form ID to update.",
      "required": true,
      "example": "form_abc123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated form name.",
      "required": false,
      "example": "Newsletter Signup - Updated",
      "in": "body"
    },
    {
      "name": "fieldGroups",
      "type": "array",
      "description": "Updated field groups.",
      "required": false,
      "example": [],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.hubspot.com/marketing/v3/forms/form_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Newsletter Signup - Updated"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "form_abc123",
      "name": "Newsletter Signup - Updated",
      "updatedAt": "2024-01-20T10:00:00Z"
    }
  },
  "auth_scopes": [
    "forms"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
