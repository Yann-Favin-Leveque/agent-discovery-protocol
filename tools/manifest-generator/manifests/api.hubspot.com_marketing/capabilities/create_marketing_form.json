{
  "name": "create_marketing_form",
  "description": "Create a new form in HubSpot to capture leads. Define form fields, submission behavior, and notification settings.",
  "endpoint": "/marketing/v3/forms",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "The internal name of the form.", "required": true, "example": "Newsletter Signup" },
    { "name": "formType", "type": "string", "description": "The type of form. One of: hubspot, embedded, standalone, popup.", "required": true, "example": "hubspot" },
    { "name": "fieldGroups", "type": "array", "description": "Groups of form fields. Each group contains an array of field definitions.", "required": true, "example": [{ "groupType": "default_group", "richTextType": "text", "fields": [{ "name": "email", "label": "Email", "type": "string", "fieldType": "text", "required": true }] }] },
    { "name": "configuration", "type": "object", "description": "Form configuration including language, lifecycle stage, and redirect URL.", "required": false, "example": { "language": "en", "createNewContactForNewEmail": true } }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hubspot.com/marketing/v3/forms",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Newsletter Signup",
      "formType": "hubspot",
      "fieldGroups": [
        {
          "groupType": "default_group",
          "richTextType": "text",
          "fields": [
            { "name": "email", "label": "Email", "type": "string", "fieldType": "text", "required": true },
            { "name": "firstname", "label": "First Name", "type": "string", "fieldType": "text", "required": false }
          ]
        }
      ],
      "configuration": {
        "language": "en",
        "createNewContactForNewEmail": true
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "form_abc123",
      "name": "Newsletter Signup",
      "formType": "hubspot",
      "createdAt": "2024-01-15T10:00:00Z",
      "updatedAt": "2024-01-15T10:00:00Z"
    }
  }
}
