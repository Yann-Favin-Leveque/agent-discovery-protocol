{
  "name": "forms_list",
  "description": "List all forms in your HubSpot account with pagination.",
  "endpoint": "/marketing/v3/forms",
  "method": "GET",
  "resource_group": "forms",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of forms to return (default 20, max 100).",
      "required": false,
      "example": 20
    },
    {
      "name": "after",
      "type": "string",
      "description": "Cursor token for pagination.",
      "required": false,
      "example": ""
    },
    {
      "name": "formTypes",
      "type": "string",
      "description": "Comma-separated form types to filter: hubspot, captured, flow, blog_comment.",
      "required": false,
      "example": "hubspot"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubspot.com/marketing/v3/forms?limit=20&formTypes=hubspot",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": "form_abc123",
          "name": "Newsletter Signup",
          "formType": "hubspot",
          "createdAt": "2024-01-15T10:00:00Z",
          "updatedAt": "2024-01-15T10:00:00Z"
        }
      ],
      "paging": {
        "next": { "after": "abc123" }
      }
    }
  },
  "auth_scopes": ["forms"],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
