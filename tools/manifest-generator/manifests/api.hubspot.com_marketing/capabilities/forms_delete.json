{
  "name": "forms_delete",
  "description": "Archive (soft-delete) a form by its ID.",
  "endpoint": "/marketing/v3/forms/{formId}",
  "method": "DELETE",
  "resource_group": "forms",
  "parameters": [
    {
      "name": "formId",
      "type": "string",
      "description": "The form ID to delete.",
      "required": true,
      "example": "form_abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.hubspot.com/marketing/v3/forms/form_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": ["forms"],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
