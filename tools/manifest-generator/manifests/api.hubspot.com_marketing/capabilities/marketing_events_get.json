{
  "name": "marketing_events_get",
  "description": "Retrieve details of a specific marketing event by its external event ID.",
  "endpoint": "/marketing/v3/marketing-events/events/{externalEventId}",
  "method": "GET",
  "resource_group": "marketing_events",
  "parameters": [
    {
      "name": "externalEventId",
      "type": "string",
      "description": "The external event identifier.",
      "required": true,
      "example": "ext_event_001"
    },
    {
      "name": "externalAccountId",
      "type": "string",
      "description": "The external account identifier.",
      "required": true,
      "example": "acct_001"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hubspot.com/marketing/v3/marketing-events/events/ext_event_001?externalAccountId=acct_001",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "12345",
      "eventName": "Product Launch Webinar 2024",
      "eventType": "WEBINAR",
      "startDateTime": "2024-03-15T14:00:00Z",
      "endDateTime": "2024-03-15T15:30:00Z",
      "eventOrganizer": "Marketing Team"
    }
  },
  "auth_scopes": ["marketing-events"],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
