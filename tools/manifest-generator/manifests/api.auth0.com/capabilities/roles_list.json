{
  "name": "roles_list",
  "description": "List all roles defined in your Auth0 tenant with their names, descriptions, and IDs.",
  "endpoint": "/api/v2/roles",
  "method": "GET",
  "resource_group": "roles",
  "parameters": [
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 0},
    {"name": "per_page", "type": "integer", "description": "Results per page.", "required": false, "example": 50},
    {"name": "name_filter", "type": "string", "description": "Filter by role name.", "required": false, "example": "admin"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/roles",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": "rol_abc123", "name": "admin", "description": "Administrator role"}]
  },
  "auth_scopes": ["read:roles"],
  "rate_limits": {"requests_per_minute": 50}
}
