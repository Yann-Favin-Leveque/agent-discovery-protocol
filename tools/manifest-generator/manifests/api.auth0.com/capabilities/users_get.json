{
  "name": "users_get",
  "description": "Retrieve a single user's full profile by their Auth0 user ID including identities, metadata, and login history.",
  "endpoint": "/api/v2/users/{id}",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The user_id of the user.",
      "required": true,
      "example": "auth0|507f1f77bcf86cd799439011",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/users/auth0%7C507f1f77bcf86cd799439011",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user_id": "auth0|507f1f77bcf86cd799439011",
      "email": "john@example.com",
      "name": "John Doe",
      "identities": [
        {
          "connection": "Username-Password-Authentication",
          "provider": "auth0",
          "isSocial": false
        }
      ],
      "logins_count": 42,
      "last_login": "2024-06-14T08:00:00.000Z"
    }
  },
  "auth_scopes": [
    "read:users"
  ],
  "rate_limits": {
    "requests_per_minute": 50
  }
}
