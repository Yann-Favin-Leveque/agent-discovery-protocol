{
  "name": "tenant_get",
  "description": "Retrieve tenant settings including friendly name, support information, and session configuration.",
  "endpoint": "/api/v2/tenants/settings",
  "method": "GET",
  "resource_group": "tenants",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/tenants/settings",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"friendly_name": "My Company", "support_email": "support@example.com", "support_url": "https://support.example.com", "session_lifetime": 168, "idle_session_lifetime": 72}
  },
  "auth_scopes": ["read:tenant_settings"],
  "rate_limits": {"requests_per_minute": 50}
}
