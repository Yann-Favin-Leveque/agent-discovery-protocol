{
  "name": "roles_delete",
  "description": "Delete a role by its ID. Users who had this role will lose its permissions.",
  "endpoint": "/api/v2/roles/{id}",
  "method": "DELETE",
  "resource_group": "roles",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The role ID.",
      "required": true,
      "example": "rol_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/roles/rol_abc123",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "delete:roles"
  ],
  "rate_limits": {
    "requests_per_minute": 50
  }
}
