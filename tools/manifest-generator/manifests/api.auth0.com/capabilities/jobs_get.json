{
  "name": "jobs_get",
  "description": "Check the status of a background job (user export, user import, verification email).",
  "endpoint": "/api/v2/jobs/{id}",
  "method": "GET",
  "resource_group": "jobs",
  "parameters": [
    {"name": "id", "type": "string", "description": "The job ID.", "required": true, "example": "job_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/jobs/job_abc123",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "job_abc123", "type": "users_export", "status": "completed", "location": "https://auth0.s3.amazonaws.com/export.json"}
  },
  "auth_scopes": ["create:users"],
  "rate_limits": {"requests_per_minute": 50}
}
