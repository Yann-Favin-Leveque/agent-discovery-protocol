{
  "name": "connections_get",
  "description": "Retrieve details of a specific connection by its ID.",
  "endpoint": "/api/v2/connections/{id}",
  "method": "GET",
  "resource_group": "connections",
  "parameters": [
    {"name": "id", "type": "string", "description": "The connection ID.", "required": true, "example": "con_abc123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/connections/con_abc123",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "con_abc123", "name": "Username-Password-Authentication", "strategy": "auth0", "options": {"passwordPolicy": "good"}, "enabled_clients": ["client123"]}
  },
  "auth_scopes": ["read:connections"],
  "rate_limits": {"requests_per_minute": 50}
}
