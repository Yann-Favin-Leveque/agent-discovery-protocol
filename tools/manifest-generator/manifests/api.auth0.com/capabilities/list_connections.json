{
  "name": "list_connections",
  "description": "List all configured identity provider connections in your Auth0 tenant. Includes database connections, social providers (Google, Facebook, GitHub), and enterprise connections (SAML, OIDC, AD/LDAP).",
  "endpoint": "/connections",
  "method": "GET",
  "parameters": [
    {
      "name": "strategy",
      "type": "string",
      "description": "Filter by connection strategy (e.g., 'auth0', 'google-oauth2', 'github', 'samlp', 'waad').",
      "required": false,
      "example": "auth0"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Filter by connection name.",
      "required": false,
      "example": "Username-Password-Authentication"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page index (zero-based).",
      "required": false,
      "example": 0
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Number of results per page (max 100). Default is 50.",
      "required": false,
      "example": 25
    },
    {
      "name": "include_totals",
      "type": "boolean",
      "description": "Whether to include total count in the response.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/connections?per_page=25&include_totals=true",
    "headers": {
      "Authorization": "Bearer YOUR_MANAGEMENT_API_TOKEN"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "connections": [
        {
          "id": "con_abc123",
          "name": "Username-Password-Authentication",
          "strategy": "auth0",
          "enabled_clients": ["client_abc", "client_def"],
          "is_domain_connection": false,
          "realms": ["Username-Password-Authentication"]
        },
        {
          "id": "con_def456",
          "name": "google-oauth2",
          "strategy": "google-oauth2",
          "enabled_clients": ["client_abc"],
          "is_domain_connection": false
        }
      ],
      "start": 0,
      "limit": 25,
      "total": 2
    }
  }
}
