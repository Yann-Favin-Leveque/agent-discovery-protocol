{
  "name": "organizations_list",
  "description": "List all organizations in your Auth0 tenant for B2B multi-tenant scenarios.",
  "endpoint": "/api/v2/organizations",
  "method": "GET",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 50,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/organizations",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "org_abc123",
        "name": "acme-corp",
        "display_name": "Acme Corporation"
      }
    ]
  },
  "auth_scopes": [
    "read:organizations"
  ],
  "rate_limits": {
    "requests_per_minute": 50
  }
}
