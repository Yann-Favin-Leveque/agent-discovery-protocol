{
  "name": "users_create",
  "description": "Create a new user in a specific Auth0 database connection with email, password, and optional profile metadata.",
  "endpoint": "/api/v2/users",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "User email address.",
      "required": true,
      "example": "john@example.com",
      "in": "body"
    },
    {
      "name": "password",
      "type": "string",
      "description": "User password meeting the connection policy.",
      "required": true,
      "example": "S3cur3P@ss!",
      "in": "body"
    },
    {
      "name": "connection",
      "type": "string",
      "description": "Database connection name.",
      "required": true,
      "example": "Username-Password-Authentication",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Full name.",
      "required": false,
      "example": "John Doe",
      "in": "body"
    },
    {
      "name": "user_metadata",
      "type": "object",
      "description": "Custom user-accessible metadata.",
      "required": false,
      "example": {
        "preferred_language": "en"
      },
      "in": "body"
    },
    {
      "name": "app_metadata",
      "type": "object",
      "description": "Application metadata.",
      "required": false,
      "example": {
        "plan": "premium"
      },
      "in": "body"
    },
    {
      "name": "email_verified",
      "type": "boolean",
      "description": "Whether the email is pre-verified.",
      "required": false,
      "example": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/users",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "john@example.com",
      "password": "S3cur3P@ss!",
      "connection": "Username-Password-Authentication",
      "name": "John Doe"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "user_id": "auth0|507f1f77bcf86cd799439011",
      "email": "john@example.com",
      "name": "John Doe",
      "created_at": "2024-06-15T10:00:00.000Z"
    }
  },
  "auth_scopes": [
    "create:users"
  ],
  "rate_limits": {
    "requests_per_minute": 50
  }
}
