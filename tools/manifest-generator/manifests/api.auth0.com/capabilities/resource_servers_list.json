{
  "name": "resource_servers_list",
  "description": "List all API resource servers (audiences) registered in your Auth0 tenant.",
  "endpoint": "/api/v2/resource-servers",
  "method": "GET",
  "resource_group": "resource_servers",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 0,
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 50,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/resource-servers",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "rs_abc123",
        "name": "My API",
        "identifier": "https://api.example.com",
        "scopes": [
          {
            "value": "read:data",
            "description": "Read data"
          }
        ]
      }
    ]
  },
  "auth_scopes": [
    "read:resource_servers"
  ],
  "rate_limits": {
    "requests_per_minute": 50
  }
}
