{
  "name": "users_get_roles",
  "description": "List all roles assigned to a specific user.",
  "endpoint": "/api/v2/users/{id}/roles",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {"name": "id", "type": "string", "description": "The user_id.", "required": true, "example": "auth0|507f1f77bcf86cd799439011"},
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 0},
    {"name": "per_page", "type": "integer", "description": "Results per page.", "required": false, "example": 50}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/users/auth0%7C507f1f77bcf86cd799439011/roles",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": "rol_abc123", "name": "admin", "description": "Administrator role"}]
  },
  "auth_scopes": ["read:users"],
  "rate_limits": {"requests_per_minute": 50}
}
