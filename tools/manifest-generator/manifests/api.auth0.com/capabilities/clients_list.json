{
  "name": "clients_list",
  "description": "List all applications (clients) registered in your Auth0 tenant.",
  "endpoint": "/api/v2/clients",
  "method": "GET",
  "resource_group": "clients",
  "parameters": [
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 0},
    {"name": "per_page", "type": "integer", "description": "Results per page.", "required": false, "example": 50},
    {"name": "app_type", "type": "string", "description": "Filter by app type (spa, regular_web, non_interactive, native).", "required": false, "example": "spa"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/clients",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"client_id": "abc123", "name": "My App", "app_type": "spa", "callbacks": ["https://myapp.com/callback"]}]
  },
  "auth_scopes": ["read:clients"],
  "rate_limits": {"requests_per_minute": 50}
}
