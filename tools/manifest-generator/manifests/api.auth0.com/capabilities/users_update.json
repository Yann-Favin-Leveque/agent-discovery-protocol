{
  "name": "users_update",
  "description": "Update a user's profile attributes including email, name, password, blocked status, and custom metadata.",
  "endpoint": "/api/v2/users/{id}",
  "method": "PATCH",
  "resource_group": "users",
  "parameters": [
    {"name": "id", "type": "string", "description": "The user_id of the user.", "required": true, "example": "auth0|507f1f77bcf86cd799439011"},
    {"name": "email", "type": "string", "description": "Updated email.", "required": false, "example": "newemail@example.com"},
    {"name": "name", "type": "string", "description": "Updated name.", "required": false, "example": "John Smith"},
    {"name": "password", "type": "string", "description": "New password.", "required": false, "example": "NewP@ss!"},
    {"name": "blocked", "type": "boolean", "description": "Block or unblock the user.", "required": false, "example": false},
    {"name": "user_metadata", "type": "object", "description": "Updated user metadata.", "required": false, "example": {}},
    {"name": "app_metadata", "type": "object", "description": "Updated app metadata.", "required": false, "example": {"plan": "enterprise"}}
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/users/auth0%7C507f1f77bcf86cd799439011",
    "headers": {"Authorization": "Bearer {token}", "Content-Type": "application/json"},
    "body": {"name": "John Smith", "app_metadata": {"plan": "enterprise"}}
  },
  "response_example": {
    "status": 200,
    "body": {"user_id": "auth0|507f1f77bcf86cd799439011", "name": "John Smith", "updated_at": "2024-06-15T11:00:00.000Z"}
  },
  "auth_scopes": ["update:users"],
  "rate_limits": {"requests_per_minute": 50}
}
