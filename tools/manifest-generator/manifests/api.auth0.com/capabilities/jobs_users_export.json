{
  "name": "jobs_users_export",
  "description": "Create a job to export all users from a connection to a file for bulk processing.",
  "endpoint": "/api/v2/jobs/users-exports",
  "method": "POST",
  "resource_group": "jobs",
  "parameters": [
    {"name": "connection_id", "type": "string", "description": "Connection ID to export users from.", "required": true, "example": "con_abc123"},
    {"name": "format", "type": "string", "description": "Export format: csv or json.", "required": false, "example": "json"},
    {"name": "fields", "type": "array", "description": "Fields to include in export.", "required": false, "example": [{"name": "email"}, {"name": "name"}]}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/jobs/users-exports",
    "headers": {"Authorization": "Bearer {token}", "Content-Type": "application/json"},
    "body": {"connection_id": "con_abc123", "format": "json"}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "job_abc123", "type": "users_export", "status": "pending", "created_at": "2024-06-15T10:00:00.000Z"}
  },
  "auth_scopes": ["create:users", "read:users"],
  "rate_limits": {"requests_per_minute": 10}
}
