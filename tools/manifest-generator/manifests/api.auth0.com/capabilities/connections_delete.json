{
  "name": "connections_delete",
  "description": "Delete a connection and all its users from your Auth0 tenant.",
  "endpoint": "/api/v2/connections/{id}",
  "method": "DELETE",
  "resource_group": "connections",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The connection ID.",
      "required": true,
      "example": "con_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/connections/con_abc123",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "delete:connections"
  ],
  "rate_limits": {
    "requests_per_minute": 50
  }
}
