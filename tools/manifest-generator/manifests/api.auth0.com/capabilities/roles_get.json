{
  "name": "roles_get",
  "description": "Retrieve a specific role by its ID.",
  "endpoint": "/api/v2/roles/{id}",
  "method": "GET",
  "resource_group": "roles",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The role ID.",
      "required": true,
      "example": "rol_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/roles/rol_abc123",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rol_abc123",
      "name": "admin",
      "description": "Administrator role"
    }
  },
  "auth_scopes": [
    "read:roles"
  ],
  "rate_limits": {
    "requests_per_minute": 50
  }
}
