{
  "name": "connections_list",
  "description": "List all configured identity provider connections (database, social, enterprise) in your Auth0 tenant.",
  "endpoint": "/api/v2/connections",
  "method": "GET",
  "resource_group": "connections",
  "parameters": [
    {"name": "strategy", "type": "string", "description": "Filter by strategy (auth0, google-oauth2, samlp, etc.).", "required": false, "example": "auth0"},
    {"name": "name", "type": "string", "description": "Filter by connection name.", "required": false, "example": "Username-Password-Authentication"},
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 0},
    {"name": "per_page", "type": "integer", "description": "Results per page.", "required": false, "example": 50}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/connections",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": "con_abc123", "name": "Username-Password-Authentication", "strategy": "auth0", "enabled_clients": ["client123"]}]
  },
  "auth_scopes": ["read:connections"],
  "rate_limits": {"requests_per_minute": 50}
}
