{
  "name": "get_user",
  "description": "Retrieve a single user's full profile by their Auth0 user ID. Returns the user's email, name, identity providers, roles, metadata, login count, and timestamps for creation and last login.",
  "endpoint": "/users/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The Auth0 user ID (e.g., 'auth0|507f1f77bcf86cd799439011').",
      "required": true,
      "example": "auth0|507f1f77bcf86cd799439011"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields to include or exclude.",
      "required": false,
      "example": "email,name,user_metadata"
    },
    {
      "name": "include_fields",
      "type": "boolean",
      "description": "If true, only the specified fields are returned. If false, the specified fields are excluded.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/users/auth0%7C507f1f77bcf86cd799439011",
    "headers": {
      "Authorization": "Bearer YOUR_MANAGEMENT_API_TOKEN"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "user_id": "auth0|507f1f77bcf86cd799439011",
      "email": "john@example.com",
      "email_verified": true,
      "name": "John Doe",
      "picture": "https://s.gravatar.com/avatar/...",
      "created_at": "2025-01-15T10:30:00.000Z",
      "updated_at": "2026-02-28T14:20:00.000Z",
      "last_login": "2026-02-28T14:20:00.000Z",
      "logins_count": 42,
      "identities": [
        {
          "connection": "Username-Password-Authentication",
          "provider": "auth0",
          "user_id": "507f1f77bcf86cd799439011",
          "isSocial": false
        }
      ],
      "user_metadata": {},
      "app_metadata": {}
    }
  }
}
