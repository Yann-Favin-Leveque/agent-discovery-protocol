{
  "name": "logs_get",
  "description": "Retrieve a single log event by its ID.",
  "endpoint": "/api/v2/logs/{id}",
  "method": "GET",
  "resource_group": "logs",
  "parameters": [
    {"name": "id", "type": "string", "description": "The log event ID.", "required": true, "example": "90020241015000000000000001"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/logs/90020241015000000000000001",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"log_id": "90020241015000000000000001", "date": "2024-06-15T10:00:00.000Z", "type": "s", "description": "Successful login", "ip": "203.0.113.1", "user_id": "auth0|507f1f77bcf86cd799439011", "details": {}}
  },
  "auth_scopes": ["read:logs"],
  "rate_limits": {"requests_per_minute": 50}
}
