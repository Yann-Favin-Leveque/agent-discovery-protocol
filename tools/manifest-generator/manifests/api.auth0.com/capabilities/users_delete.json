{
  "name": "users_delete",
  "description": "Permanently delete a user from your Auth0 tenant.",
  "endpoint": "/api/v2/users/{id}",
  "method": "DELETE",
  "resource_group": "users",
  "parameters": [
    {"name": "id", "type": "string", "description": "The user_id of the user to delete.", "required": true, "example": "auth0|507f1f77bcf86cd799439011"}
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://YOUR_DOMAIN.auth0.com/api/v2/users/auth0%7C507f1f77bcf86cd799439011",
    "headers": {"Authorization": "Bearer {token}"}
  },
  "response_example": {"status": 204, "body": {}},
  "auth_scopes": ["delete:users"],
  "rate_limits": {"requests_per_minute": 50}
}
