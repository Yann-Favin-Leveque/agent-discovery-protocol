{
  "name": "list_sources",
  "description": "Retrieve all configured data sources in the workspace with their connection status and settings.",
  "endpoint": "/v1beta/workspaces/{workspace}/sources",
  "method": "GET",
  "parameters": [
    { "name": "workspace", "type": "string", "required": true, "description": "The workspace slug" },
    { "name": "page_size", "type": "number", "required": false, "description": "Number of sources per page" },
    { "name": "page_token", "type": "string", "required": false, "description": "Pagination token for next page" }
  ],
  "request_example": {
    "url": "/v1beta/workspaces/my-workspace/sources?page_size=10"
  },
  "response_example": {
    "sources": [
      {
        "name": "workspaces/my-workspace/sources/javascript",
        "catalog_name": "catalog/sources/javascript",
        "write_keys": ["write_key_abc123"],
        "enabled": true
      }
    ],
    "next_page_token": ""
  }
}
