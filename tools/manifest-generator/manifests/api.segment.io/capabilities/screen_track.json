{
  "name": "screen_track",
  "description": "Record a mobile screen view with name and properties.",
  "resource_group": "tracking",
  "endpoint": "/v1/screen",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": false,
      "description": "User ID"
    },
    {
      "name": "anonymousId",
      "type": "string",
      "required": false,
      "description": "Anonymous ID"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Screen name"
    },
    {
      "name": "properties",
      "type": "object",
      "required": false,
      "description": "Screen properties"
    }
  ],
  "request_example": {
    "userId": "user_123",
    "name": "Dashboard",
    "properties": {
      "section": "overview"
    }
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
