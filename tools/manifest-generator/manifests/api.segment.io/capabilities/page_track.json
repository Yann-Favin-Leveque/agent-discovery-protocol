{
  "name": "page_track",
  "description": "Record a page view with name, category, and properties.",
  "resource_group": "tracking",
  "endpoint": "/v1/page",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": false,
      "description": "User ID"
    },
    {
      "name": "anonymousId",
      "type": "string",
      "required": false,
      "description": "Anonymous ID"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Page name"
    },
    {
      "name": "category",
      "type": "string",
      "required": false,
      "description": "Page category"
    },
    {
      "name": "properties",
      "type": "object",
      "required": false,
      "description": "Page properties"
    }
  ],
  "request_example": {
    "userId": "user_123",
    "name": "Pricing",
    "category": "Marketing",
    "properties": {
      "url": "https://example.com/pricing"
    }
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
