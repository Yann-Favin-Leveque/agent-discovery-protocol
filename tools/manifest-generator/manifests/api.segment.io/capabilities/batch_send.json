{
  "name": "batch_send",
  "description": "Send multiple tracking calls in a single batch request.",
  "resource_group": "tracking",
  "endpoint": "/v1/batch",
  "method": "POST",
  "parameters": [
    {
      "name": "batch",
      "type": "array",
      "required": true,
      "description": "Array of identify, track, page, screen, group, or alias calls"
    }
  ],
  "request_example": {
    "batch": [
      {
        "type": "identify",
        "userId": "user_123",
        "traits": {
          "email": "john@example.com"
        }
      },
      {
        "type": "track",
        "userId": "user_123",
        "event": "Login"
      }
    ]
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
