{
  "name": "list_destinations",
  "description": "Retrieve all configured destinations where event data is routed, with their enabled status and configuration.",
  "endpoint": "/v1beta/workspaces/{workspace}/sources/{source}/destinations",
  "method": "GET",
  "parameters": [
    { "name": "workspace", "type": "string", "required": true, "description": "The workspace slug" },
    { "name": "source", "type": "string", "required": true, "description": "The source slug" },
    { "name": "page_size", "type": "number", "required": false, "description": "Number of destinations per page" }
  ],
  "request_example": {
    "url": "/v1beta/workspaces/my-workspace/sources/javascript/destinations?page_size=10"
  },
  "response_example": {
    "destinations": [
      {
        "name": "workspaces/my-workspace/sources/javascript/destinations/google-analytics",
        "enabled": true,
        "connection_mode": "cloud",
        "config": []
      }
    ],
    "next_page_token": ""
  }
}
