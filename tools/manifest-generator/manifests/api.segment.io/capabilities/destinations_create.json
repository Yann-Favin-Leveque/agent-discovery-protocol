{
  "name": "destinations_create",
  "description": "Create a new destination connection.",
  "resource_group": "destinations",
  "endpoint": "/destinations",
  "method": "POST",
  "parameters": [
    {
      "name": "sourceId",
      "type": "string",
      "required": true,
      "description": "Source to connect from",
      "in": "body"
    },
    {
      "name": "metadataId",
      "type": "string",
      "required": true,
      "description": "Destination catalog metadata ID",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Destination name",
      "in": "body"
    },
    {
      "name": "settings",
      "type": "object",
      "required": false,
      "description": "Destination settings",
      "in": "body"
    },
    {
      "name": "enabled",
      "type": "boolean",
      "required": false,
      "description": "Whether destination is enabled",
      "in": "body"
    }
  ],
  "request_example": {
    "sourceId": "src_123",
    "metadataId": "meta_ga",
    "name": "GA4",
    "enabled": true
  },
  "response_example": {
    "data": {
      "destination": {
        "id": "dst_456"
      }
    }
  },
  "auth_scopes": []
}
