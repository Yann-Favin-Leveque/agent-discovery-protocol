{
  "name": "group_user",
  "description": "Associate a user with a group such as a company or organization, with group-level traits.",
  "endpoint": "/v1/group",
  "method": "POST",
  "parameters": [
    { "name": "userId", "type": "string", "required": true, "description": "Unique identifier for the user" },
    { "name": "groupId", "type": "string", "required": true, "description": "Unique identifier for the group" },
    { "name": "traits", "type": "object", "required": false, "description": "Dictionary of group traits (name, industry, size, etc.)" }
  ],
  "request_example": {
    "userId": "user_123",
    "groupId": "group_456",
    "traits": {
      "name": "Acme Inc",
      "industry": "Technology",
      "employees": 250
    }
  },
  "response_example": {
    "success": true
  }
}
