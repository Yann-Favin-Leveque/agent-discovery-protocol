{
  "name": "users_identify",
  "description": "Associate a user with traits like email, name, and custom attributes.",
  "resource_group": "tracking",
  "endpoint": "/v1/identify",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": false,
      "description": "User ID",
      "in": "body"
    },
    {
      "name": "anonymousId",
      "type": "string",
      "required": false,
      "description": "Anonymous ID",
      "in": "body"
    },
    {
      "name": "traits",
      "type": "object",
      "required": false,
      "description": "User traits (email, name, plan, etc.)",
      "in": "body"
    },
    {
      "name": "context",
      "type": "object",
      "required": false,
      "description": "Context object",
      "in": "body"
    },
    {
      "name": "timestamp",
      "type": "string",
      "required": false,
      "description": "ISO 8601 timestamp",
      "in": "body"
    }
  ],
  "request_example": {
    "userId": "user_123",
    "traits": {
      "email": "john@example.com",
      "name": "John Smith",
      "plan": "pro"
    }
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
