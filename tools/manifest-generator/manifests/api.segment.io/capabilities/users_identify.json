{
  "name": "users_identify",
  "description": "Associate a user with traits like email, name, and custom attributes.",
  "resource_group": "tracking",
  "endpoint": "/v1/identify",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": false,
      "description": "User ID"
    },
    {
      "name": "anonymousId",
      "type": "string",
      "required": false,
      "description": "Anonymous ID"
    },
    {
      "name": "traits",
      "type": "object",
      "required": false,
      "description": "User traits (email, name, plan, etc.)"
    },
    {
      "name": "context",
      "type": "object",
      "required": false,
      "description": "Context object"
    },
    {
      "name": "timestamp",
      "type": "string",
      "required": false,
      "description": "ISO 8601 timestamp"
    }
  ],
  "request_example": {
    "userId": "user_123",
    "traits": {
      "email": "john@example.com",
      "name": "John Smith",
      "plan": "pro"
    }
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
