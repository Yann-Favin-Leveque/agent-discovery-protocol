{
  "name": "users_group",
  "description": "Associate a user with a group such as a company or organization.",
  "resource_group": "tracking",
  "endpoint": "/v1/group",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "required": true,
      "description": "User ID",
      "in": "body"
    },
    {
      "name": "groupId",
      "type": "string",
      "required": true,
      "description": "Group ID",
      "in": "body"
    },
    {
      "name": "traits",
      "type": "object",
      "required": false,
      "description": "Group traits",
      "in": "body"
    },
    {
      "name": "context",
      "type": "object",
      "required": false,
      "description": "Context object",
      "in": "body"
    }
  ],
  "request_example": {
    "userId": "user_123",
    "groupId": "company_456",
    "traits": {
      "name": "Acme Corp",
      "industry": "Technology"
    }
  },
  "response_example": {
    "success": true
  },
  "auth_scopes": []
}
