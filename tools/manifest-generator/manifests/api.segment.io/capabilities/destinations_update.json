{
  "name": "destinations_update",
  "description": "Update an existing destination.",
  "resource_group": "destinations",
  "endpoint": "/destinations/{destination_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "destination_id",
      "type": "string",
      "required": true,
      "description": "Destination ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name",
      "in": "body"
    },
    {
      "name": "enabled",
      "type": "boolean",
      "required": false,
      "description": "Enable or disable",
      "in": "body"
    },
    {
      "name": "settings",
      "type": "object",
      "required": false,
      "description": "Updated settings",
      "in": "body"
    }
  ],
  "request_example": {
    "enabled": false
  },
  "response_example": {
    "data": {
      "destination": {
        "id": "dst_456"
      }
    }
  },
  "auth_scopes": []
}
