{
  "name": "sources_create",
  "description": "Create a new data source.",
  "resource_group": "sources",
  "endpoint": "/sources",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Source name",
      "in": "body"
    },
    {
      "name": "slug",
      "type": "string",
      "required": true,
      "description": "Source catalog slug",
      "in": "body"
    },
    {
      "name": "enabled",
      "type": "boolean",
      "required": false,
      "description": "Whether source is enabled",
      "in": "body"
    }
  ],
  "request_example": {
    "name": "Mobile App",
    "slug": "ios",
    "enabled": true
  },
  "response_example": {
    "data": {
      "source": {
        "id": "src_456"
      }
    }
  },
  "auth_scopes": []
}
