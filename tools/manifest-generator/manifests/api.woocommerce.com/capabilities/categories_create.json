{
  "name": "categories_create",
  "description": "Create a new product category.",
  "resource_group": "categories",
  "endpoint": "/products/categories",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Category name.",
      "example": "New Category"
    },
    {
      "name": "parent",
      "type": "integer",
      "required": false,
      "description": "Parent category ID."
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Category description."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{store}/wp-json/wc/v3/products/categories",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "New Category"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 10,
      "name": "New Category",
      "slug": "new-category"
    }
  }
}