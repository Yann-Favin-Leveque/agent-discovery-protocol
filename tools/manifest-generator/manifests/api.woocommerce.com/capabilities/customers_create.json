{
  "name": "customers_create",
  "description": "Create a new customer.",
  "resource_group": "customers",
  "endpoint": "/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Customer email.",
      "example": "john@example.com",
      "in": "body"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "billing",
      "type": "object",
      "required": false,
      "description": "Billing address.",
      "in": "body"
    },
    {
      "name": "shipping",
      "type": "object",
      "required": false,
      "description": "Shipping address.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{store}/wp-json/wc/v3/customers",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "john@example.com",
      "first_name": "John",
      "last_name": "Doe"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2,
      "email": "john@example.com",
      "first_name": "John"
    }
  }
}
