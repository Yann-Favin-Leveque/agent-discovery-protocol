{
  "name": "products_update",
  "description": "Update an existing product.",
  "resource_group": "products",
  "endpoint": "/products/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Product ID.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name.",
      "in": "body"
    },
    {
      "name": "regular_price",
      "type": "string",
      "required": false,
      "description": "Updated price.",
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Updated status.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://{store}/wp-json/wc/v3/products/794",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "regular_price": "24.99"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 794,
      "name": "Premium Quality",
      "price": "24.99"
    }
  }
}
