{
  "name": "coupons_list",
  "description": "Retrieve all discount coupons.",
  "resource_group": "coupons",
  "endpoint": "/coupons",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Items per page."
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "description": "Search by coupon code."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/coupons",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 719,
        "code": "summer10",
        "discount_type": "percent",
        "amount": "10.00",
        "usage_count": 5
      }
    ]
  }
}