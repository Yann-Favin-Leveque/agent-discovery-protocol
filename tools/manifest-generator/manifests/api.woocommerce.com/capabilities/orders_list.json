{
  "name": "orders_list",
  "description": "Retrieve a paginated list of orders.",
  "resource_group": "orders",
  "endpoint": "/orders",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Items per page.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Current page.",
      "in": "query"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter: pending, processing, on-hold, completed, cancelled, refunded, failed, any.",
      "in": "query"
    },
    {
      "name": "customer",
      "type": "integer",
      "required": false,
      "description": "Filter by customer ID.",
      "in": "query"
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Orders after this date (ISO 8601).",
      "in": "query"
    },
    {
      "name": "before",
      "type": "string",
      "required": false,
      "description": "Orders before this date.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/orders?status=processing",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 727,
        "status": "processing",
        "total": "49.00",
        "customer_id": 1,
        "line_items": [
          {
            "id": 315,
            "name": "Product A",
            "quantity": 1,
            "total": "49.00"
          }
        ]
      }
    ]
  }
}
