{
  "name": "categories_list",
  "description": "Retrieve all product categories.",
  "resource_group": "categories",
  "endpoint": "/products/categories",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Items per page."
    },
    {
      "name": "parent",
      "type": "integer",
      "required": false,
      "description": "Filter by parent category ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/products/categories",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 9,
        "name": "Clothing",
        "slug": "clothing",
        "parent": 0,
        "count": 12
      }
    ]
  }
}