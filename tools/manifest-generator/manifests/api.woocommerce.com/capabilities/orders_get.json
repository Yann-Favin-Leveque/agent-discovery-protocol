{
  "name": "orders_get",
  "description": "Retrieve a specific order by ID.",
  "resource_group": "orders",
  "endpoint": "/orders/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Order ID.",
      "example": 727,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/orders/727",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 727,
      "status": "processing",
      "total": "49.00",
      "billing": {
        "first_name": "John",
        "last_name": "Doe",
        "email": "john@example.com"
      },
      "line_items": [
        {
          "name": "Product A",
          "quantity": 1,
          "total": "49.00"
        }
      ]
    }
  }
}
