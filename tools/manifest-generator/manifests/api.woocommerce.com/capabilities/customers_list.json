{
  "name": "customers_list",
  "description": "Retrieve a paginated list of customers.",
  "resource_group": "customers",
  "endpoint": "/customers",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Items per page."
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "description": "Search by name or email."
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by email."
    },
    {
      "name": "role",
      "type": "string",
      "required": false,
      "description": "Filter by role."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/customers",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "email": "john@example.com",
        "first_name": "John",
        "last_name": "Doe"
      }
    ]
  }
}