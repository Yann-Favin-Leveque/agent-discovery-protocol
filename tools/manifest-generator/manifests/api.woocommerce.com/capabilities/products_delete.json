{
  "name": "products_delete",
  "description": "Delete a product by ID.",
  "resource_group": "products",
  "endpoint": "/products/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Product ID.",
      "in": "path"
    },
    {
      "name": "force",
      "type": "boolean",
      "required": false,
      "description": "True to permanently delete (bypass trash).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://{store}/wp-json/wc/v3/products/794?force=true",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 794,
      "name": "Premium Quality"
    }
  }
}
