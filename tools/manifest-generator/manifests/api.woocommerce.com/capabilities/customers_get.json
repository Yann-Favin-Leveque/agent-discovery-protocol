{
  "name": "customers_get",
  "description": "Retrieve a specific customer by ID.",
  "resource_group": "customers",
  "endpoint": "/customers/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Customer ID.",
      "example": 1,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/customers/1",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "email": "john@example.com",
      "first_name": "John",
      "last_name": "Doe",
      "billing": {
        "address_1": "123 Main St",
        "city": "Portland"
      }
    }
  }
}
