{
  "name": "reports_top_sellers",
  "description": "Retrieve best-selling products report.",
  "resource_group": "reports",
  "endpoint": "/reports/top_sellers",
  "method": "GET",
  "parameters": [
    {
      "name": "date_min",
      "type": "string",
      "required": false,
      "description": "Start date (YYYY-MM-DD).",
      "in": "query"
    },
    {
      "name": "date_max",
      "type": "string",
      "required": false,
      "description": "End date (YYYY-MM-DD).",
      "in": "query"
    },
    {
      "name": "period",
      "type": "string",
      "required": false,
      "description": "Report period.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/reports/top_sellers?period=month",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "title": "Premium Quality",
        "product_id": 794,
        "quantity": 25
      }
    ]
  }
}
