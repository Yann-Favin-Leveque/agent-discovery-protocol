{
  "name": "products_get",
  "description": "Retrieve a single product by ID.",
  "resource_group": "products",
  "endpoint": "/products/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Product ID.",
      "example": 794
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{store}/wp-json/wc/v3/products/794",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 794,
      "name": "Premium Quality",
      "price": "21.99",
      "description": "<p>Great product</p>",
      "sku": "PQ-001"
    }
  }
}