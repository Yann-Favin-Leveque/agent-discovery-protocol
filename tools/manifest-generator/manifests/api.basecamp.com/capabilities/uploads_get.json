{
  "name": "uploads_get",
  "resource_group": "uploads",
  "description": "Retrieve a specific upload by ID.",
  "endpoint": "/{account_id}/buckets/{project_id}/uploads/{upload_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "upload_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Upload ID",
      "example": 1069479700
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/uploads/1069479700.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479700,
      "title": "design-mockup.png",
      "description": "Homepage mockup",
      "download_url": "https://3.basecamp.com/download/..."
    }
  }
}