{
  "name": "people_list_project",
  "resource_group": "people",
  "description": "List all people on a specific project.",
  "endpoint": "/{account_id}/projects/{project_id}/people.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/projects/2085958499/people.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1049715914,
        "name": "Victor Cooper",
        "email_address": "victor@example.com"
      }
    ]
  }
}