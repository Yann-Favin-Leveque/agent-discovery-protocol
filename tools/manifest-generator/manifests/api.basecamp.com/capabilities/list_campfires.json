{
  "name": "list_campfires",
  "description": "Retrieve all campfires (chat channels) available in a Basecamp account. Campfires enable real-time team communication and discussions separate from project-specific messages.",
  "endpoint": "/{account_id}/chats.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The unique identifier for the Basecamp account. Required in the URL path.",
      "required": true,
      "example": "3619386"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/3619386/chats.json",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "User-Agent": "MyApp (your-email@example.com)"
    }
  },
