{
  "name": "comments_update",
  "resource_group": "comments",
  "description": "Update a comment's content.",
  "endpoint": "/{account_id}/buckets/{project_id}/comments/{comment_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "comment_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Comment ID",
      "example": 1069479400
    },
    {
      "name": "content",
      "type": "string",
      "required": true,
      "description": "Updated content",
      "example": "<p>Updated comment</p>"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/comments/1069479400.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "content": "<p>Updated comment</p>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479400,
      "content": "<p>Updated comment</p>"
    }
  }
}