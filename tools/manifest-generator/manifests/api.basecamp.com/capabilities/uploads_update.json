{
  "name": "uploads_update",
  "resource_group": "uploads",
  "description": "Update an upload's description or filename.",
  "endpoint": "/{account_id}/buckets/{project_id}/uploads/{upload_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "upload_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Upload ID",
      "example": 1069479700
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Updated description",
      "example": "<p>Updated description</p>",
      "in": "body"
    },
    {
      "name": "base_name",
      "type": "string",
      "required": false,
      "description": "Updated filename",
      "example": "renamed-file",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/uploads/1069479700.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "description": "<p>Updated description</p>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479700,
      "description": "<p>Updated description</p>"
    }
  }
}
