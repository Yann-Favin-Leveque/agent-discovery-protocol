{
  "name": "schedule_entries_get",
  "resource_group": "schedule_entries",
  "description": "Retrieve a specific schedule entry.",
  "endpoint": "/{account_id}/buckets/{project_id}/schedule_entries/{entry_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "entry_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Schedule entry ID",
      "example": 1069479600
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/schedule_entries/1069479600.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479600,
      "summary": "Team standup",
      "starts_at": "2025-03-15T09:00:00Z",
      "ends_at": "2025-03-15T09:15:00Z"
    }
  }
}