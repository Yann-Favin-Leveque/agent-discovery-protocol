{
  "name": "people_list",
  "resource_group": "people",
  "description": "List all people (team members) in a Basecamp account.",
  "endpoint": "/{account_id}/people.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/people.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1049715914,
        "name": "Victor Cooper",
        "email_address": "victor@example.com",
        "admin": true,
        "avatar_url": "https://example.com/avatar.png"
      }
    ]
  }
}