{
  "name": "projects_list",
  "resource_group": "projects",
  "description": "List all projects in the Basecamp account, including active and archived projects.",
  "endpoint": "/{account_id}/projects.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by status (archived or trashed)",
      "example": "archived",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/projects.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 2085958499,
        "status": "active",
        "name": "The Leto Laptop",
        "description": "A project about laptops",
        "created_at": "2025-01-15T10:00:00Z",
        "updated_at": "2025-03-10T14:30:00Z",
        "bookmark_url": "https://3.basecampapi.com/9999999/my/bookmarks/123.json"
      }
    ]
  }
}
