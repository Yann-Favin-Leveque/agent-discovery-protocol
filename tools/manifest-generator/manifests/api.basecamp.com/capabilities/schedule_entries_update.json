{
  "name": "schedule_entries_update",
  "resource_group": "schedule_entries",
  "description": "Update a schedule entry.",
  "endpoint": "/{account_id}/buckets/{project_id}/schedule_entries/{entry_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "entry_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Entry ID",
      "example": 1069479600
    },
    {
      "name": "summary",
      "type": "string",
      "required": false,
      "description": "Updated title",
      "example": "Updated standup",
      "in": "body"
    },
    {
      "name": "starts_at",
      "type": "string",
      "required": false,
      "description": "Updated start",
      "example": "2025-03-15T09:30:00Z",
      "in": "body"
    },
    {
      "name": "ends_at",
      "type": "string",
      "required": false,
      "description": "Updated end",
      "example": "2025-03-15T09:45:00Z",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/schedule_entries/1069479600.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "summary": "Updated standup"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479600,
      "summary": "Updated standup"
    }
  }
}
