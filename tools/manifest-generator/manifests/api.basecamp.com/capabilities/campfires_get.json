{
  "name": "campfires_get",
  "resource_group": "campfires",
  "description": "Retrieve a specific campfire by ID.",
  "endpoint": "/{account_id}/chats/{campfire_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "campfire_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Campfire ID",
      "example": 1069479500
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/chats/1069479500.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479500,
      "title": "Campfire"
    }
  }
}