{
  "name": "people_get",
  "resource_group": "people",
  "description": "Retrieve a specific person by their ID.",
  "endpoint": "/{account_id}/people/{person_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "person_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Person ID",
      "example": 1049715914
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/people/1049715914.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1049715914,
      "name": "Victor Cooper",
      "email_address": "victor@example.com",
      "admin": true
    }
  }
}