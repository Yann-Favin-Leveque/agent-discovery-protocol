{
  "name": "comments_list",
  "resource_group": "comments",
  "description": "List all comments on a recording (message, todo, etc).",
  "endpoint": "/{account_id}/buckets/{project_id}/recordings/{recording_id}/comments.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "recording_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Recording ID (message, todo, etc.)",
      "example": 1069479300
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/recordings/1069479300/comments.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479400,
        "content": "<p>Great work!</p>",
        "created_at": "2025-03-10T12:00:00Z",
        "creator": {
          "id": 1049715914,
          "name": "Victor Cooper"
        }
      }
    ]
  }
}