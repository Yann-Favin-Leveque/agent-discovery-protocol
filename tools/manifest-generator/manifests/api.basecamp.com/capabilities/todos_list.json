{
  "name": "todos_list",
  "resource_group": "todos",
  "description": "List all todos in a todolist.",
  "endpoint": "/{account_id}/buckets/{project_id}/todolists/{todolist_id}/todos.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todolist_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todolist ID",
      "example": 1069479338
    },
    {
      "name": "completed",
      "type": "boolean",
      "required": false,
      "description": "Filter by completion status",
      "example": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todolists/1069479338/todos.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479099,
        "content": "Design homepage",
        "description": "",
        "completed": false,
        "due_on": "2025-03-20",
        "assignees": [
          {
            "id": 1049715914,
            "name": "Victor Cooper"
          }
        ]
      }
    ]
  }
}