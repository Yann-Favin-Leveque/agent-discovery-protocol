{
  "name": "people_update_access",
  "resource_group": "people",
  "description": "Grant or revoke project access for people.",
  "endpoint": "/{account_id}/projects/{project_id}/people/users.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "grant",
      "type": "array",
      "required": false,
      "description": "Person IDs to grant access",
      "example": [
        1049715914
      ],
      "in": "body"
    },
    {
      "name": "revoke",
      "type": "array",
      "required": false,
      "description": "Person IDs to revoke access",
      "example": [],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/projects/2085958499/people/users.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "grant": [
        1049715914
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "granted": [
        {
          "id": 1049715914,
          "name": "Victor Cooper"
        }
      ],
      "revoked": []
    }
  }
}
