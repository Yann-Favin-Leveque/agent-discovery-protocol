{
  "name": "people_my_profile",
  "resource_group": "people",
  "description": "Retrieve the authenticated user's profile.",
  "endpoint": "/{account_id}/my/profile.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/my/profile.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1049715914,
      "name": "Victor Cooper",
      "email_address": "victor@example.com"
    }
  }
}