{
  "name": "todos_update",
  "resource_group": "todos",
  "description": "Update a todo's content, assignees, or due date.",
  "endpoint": "/{account_id}/buckets/{project_id}/todos/{todo_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todo_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todo ID",
      "example": 1069479099
    },
    {
      "name": "content",
      "type": "string",
      "required": true,
      "description": "Updated content",
      "example": "Updated task name"
    },
    {
      "name": "due_on",
      "type": "string",
      "required": false,
      "description": "Updated due date",
      "example": "2025-04-01"
    },
    {
      "name": "assignee_ids",
      "type": "array",
      "required": false,
      "description": "Updated assignee IDs",
      "example": [
        1049715914
      ]
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todos/1069479099.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "content": "Updated task name",
      "due_on": "2025-04-01"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479099,
      "content": "Updated task name",
      "due_on": "2025-04-01"
    }
  }
}