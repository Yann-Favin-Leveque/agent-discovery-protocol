{
  "name": "messages_update",
  "resource_group": "messages",
  "description": "Update a message's subject or content.",
  "endpoint": "/{account_id}/buckets/{project_id}/messages/{message_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "message_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Message ID",
      "example": 1069479300
    },
    {
      "name": "subject",
      "type": "string",
      "required": false,
      "description": "Updated subject",
      "example": "Updated Sprint Update",
      "in": "body"
    },
    {
      "name": "content",
      "type": "string",
      "required": false,
      "description": "Updated content",
      "example": "<p>Updated content</p>",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/messages/1069479300.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "subject": "Updated Sprint Update"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479300,
      "subject": "Updated Sprint Update"
    }
  }
}
