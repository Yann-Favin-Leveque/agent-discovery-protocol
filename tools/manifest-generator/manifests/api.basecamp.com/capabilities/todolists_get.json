{
  "name": "todolists_get",
  "resource_group": "todolists",
  "description": "Retrieve a specific todolist by ID.",
  "endpoint": "/{account_id}/buckets/{project_id}/todolists/{todolist_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todolist_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todolist ID",
      "example": 1069479338
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todolists/1069479338.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479338,
      "title": "Launch checklist",
      "description": "Tasks for launch",
      "completed_ratio": "2/5"
    }
  }
}