{
  "name": "webhooks_list",
  "resource_group": "webhooks",
  "description": "List all webhooks for a project.",
  "endpoint": "/{account_id}/buckets/{project_id}/webhooks.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/webhooks.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 999,
        "active": true,
        "payload_url": "https://example.com/webhook",
        "types": [
          "Comment",
          "Todo"
        ]
      }
    ]
  }
}