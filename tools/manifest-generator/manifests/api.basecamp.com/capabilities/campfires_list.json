{
  "name": "campfires_list",
  "resource_group": "campfires",
  "description": "List all campfires (chat rooms) in the account.",
  "endpoint": "/{account_id}/chats.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/chats.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479500,
        "title": "Campfire",
        "created_at": "2025-01-01T00:00:00Z"
      }
    ]
  }
}