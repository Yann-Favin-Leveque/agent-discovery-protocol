{
  "name": "todos_reposition",
  "resource_group": "todos",
  "description": "Change the position of a todo within its list.",
  "endpoint": "/{account_id}/buckets/{project_id}/todos/{todo_id}/position.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todo_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todo ID",
      "example": 1069479099
    },
    {
      "name": "position",
      "type": "integer",
      "required": true,
      "description": "New position (1-based)",
      "example": 1
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todos/1069479099/position.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "position": 1
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}