{
  "name": "todos_complete",
  "resource_group": "todos",
  "description": "Mark a todo as complete.",
  "endpoint": "/{account_id}/buckets/{project_id}/todos/{todo_id}/completion.json",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todo_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todo ID",
      "example": 1069479099
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todos/1069479099/completion.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}