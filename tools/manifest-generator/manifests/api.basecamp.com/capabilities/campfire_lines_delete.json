{
  "name": "campfire_lines_delete",
  "resource_group": "campfires",
  "description": "Delete a campfire line (message).",
  "endpoint": "/{account_id}/buckets/{project_id}/chats/{campfire_id}/lines/{line_id}.json",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "campfire_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Campfire ID",
      "example": 1069479500
    },
    {
      "name": "line_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Line ID",
      "example": 1069479510
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/chats/1069479500/lines/1069479510.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}