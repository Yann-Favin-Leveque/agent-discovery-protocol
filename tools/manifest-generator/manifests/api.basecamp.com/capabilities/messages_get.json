{
  "name": "messages_get",
  "resource_group": "messages",
  "description": "Retrieve a specific message by ID.",
  "endpoint": "/{account_id}/buckets/{project_id}/messages/{message_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "message_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Message ID",
      "example": 1069479300
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/messages/1069479300.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479300,
      "subject": "Welcome!",
      "content": "<p>Hello team!</p>"
    }
  }
}