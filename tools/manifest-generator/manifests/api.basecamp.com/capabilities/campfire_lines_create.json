{
  "name": "campfire_lines_create",
  "resource_group": "campfires",
  "description": "Post a new message (line) to a campfire.",
  "endpoint": "/{account_id}/buckets/{project_id}/chats/{campfire_id}/lines.json",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "campfire_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Campfire ID",
      "example": 1069479500
    },
    {
      "name": "content",
      "type": "string",
      "required": true,
      "description": "Plain text message",
      "example": "Good morning everyone!",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/chats/1069479500/lines.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "content": "Good morning everyone!"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 1069479511,
      "content": "Good morning everyone!"
    }
  }
}
