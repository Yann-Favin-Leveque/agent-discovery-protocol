{
  "name": "projects_get",
  "resource_group": "projects",
  "description": "Retrieve a specific project by its ID.",
  "endpoint": "/{account_id}/projects/{project_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/projects/2085958499.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 2085958499,
      "status": "active",
      "name": "The Leto Laptop",
      "description": "Project description",
      "dock": [
        {
          "id": 123,
          "title": "Message Board",
          "name": "message_board",
          "enabled": true
        },
        {
          "id": 456,
          "title": "To-dos",
          "name": "todoset",
          "enabled": true
        }
      ]
    }
  }
}