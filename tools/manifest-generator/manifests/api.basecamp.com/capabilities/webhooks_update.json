{
  "name": "webhooks_update",
  "resource_group": "webhooks",
  "description": "Update a webhook's URL, types, or active status.",
  "endpoint": "/{account_id}/buckets/{project_id}/webhooks/{webhook_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "webhook_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Webhook ID",
      "example": 999
    },
    {
      "name": "payload_url",
      "type": "string",
      "required": true,
      "description": "Updated URL",
      "example": "https://example.com/new-webhook"
    },
    {
      "name": "active",
      "type": "boolean",
      "required": false,
      "description": "Toggle active state",
      "example": true
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/webhooks/999.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "payload_url": "https://example.com/new-webhook",
      "active": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 999,
      "active": true,
      "payload_url": "https://example.com/new-webhook"
    }
  }
}