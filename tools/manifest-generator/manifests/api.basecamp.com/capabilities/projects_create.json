{
  "name": "projects_create",
  "resource_group": "projects",
  "description": "Create a new project in the Basecamp account.",
  "endpoint": "/{account_id}/projects.json",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Project name",
      "example": "New Marketing Campaign",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Project description",
      "example": "Q2 2025 campaign planning",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://3.basecampapi.com/9999999/projects.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "name": "New Marketing Campaign",
      "description": "Q2 2025 campaign planning"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2085958500,
      "status": "active",
      "name": "New Marketing Campaign",
      "description": "Q2 2025 campaign planning"
    }
  }
}
