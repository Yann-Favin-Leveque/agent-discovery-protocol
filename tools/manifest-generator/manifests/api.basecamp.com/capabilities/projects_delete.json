{
  "name": "projects_delete",
  "resource_group": "projects",
  "description": "Trash a project (deleted after 30 days).",
  "endpoint": "/{account_id}/projects/{project_id}.json",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://3.basecampapi.com/9999999/projects/2085958499.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}