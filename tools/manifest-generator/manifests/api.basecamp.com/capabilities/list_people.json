{
  "name": "list_people",
  "description": "Retrieve all team members in a Basecamp account. Returns user information including names, email addresses, roles, and availability status. Use this to find team members for assigning tasks or sending messages.",
  "endpoint": "/{account_id}/people.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The unique identifier for the Basecamp account. Required in the URL path.",
      "required": true,
      "example": "3619386"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/3619386/people.json",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "User-Agent": "MyApp (your-email@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 10000001,
        "name": "Alice Johnson",
        "email_address": "alice@example.com",
        "personable_type": "User",
        "title": "Project Manager",
