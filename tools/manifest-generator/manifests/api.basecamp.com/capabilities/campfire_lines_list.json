{
  "name": "campfire_lines_list",
  "resource_group": "campfires",
  "description": "List all lines (messages) in a campfire.",
  "endpoint": "/{account_id}/buckets/{project_id}/chats/{campfire_id}/lines.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "campfire_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Campfire ID",
      "example": 1069479500
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/chats/1069479500/lines.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479510,
        "content": "Hello team!",
        "created_at": "2025-03-10T10:00:00Z",
        "creator": {
          "id": 1049715914,
          "name": "Victor Cooper"
        }
      }
    ]
  }
}