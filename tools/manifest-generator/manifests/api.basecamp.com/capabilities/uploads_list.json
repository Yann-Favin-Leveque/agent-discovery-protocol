{
  "name": "uploads_list",
  "resource_group": "uploads",
  "description": "List all uploads in a project vault.",
  "endpoint": "/{account_id}/buckets/{project_id}/vaults/{vault_id}/uploads.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "vault_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Vault ID",
      "example": 5555555
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/vaults/5555555/uploads.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479700,
        "title": "design-mockup.png",
        "description": "Homepage mockup",
        "content_type": "image/png",
        "byte_size": 245678
      }
    ]
  }
}