{
  "name": "webhooks_delete",
  "resource_group": "webhooks",
  "description": "Delete a webhook.",
  "endpoint": "/{account_id}/buckets/{project_id}/webhooks/{webhook_id}.json",
  "method": "DELETE",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "webhook_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Webhook ID",
      "example": 999
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/webhooks/999.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}