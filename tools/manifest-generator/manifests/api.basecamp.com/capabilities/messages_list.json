{
  "name": "messages_list",
  "resource_group": "messages",
  "description": "List all messages on a project's message board.",
  "endpoint": "/{account_id}/buckets/{project_id}/message_boards/{board_id}/messages.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "board_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Message board ID",
      "example": 7654321
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/message_boards/7654321/messages.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479300,
        "subject": "Welcome!",
        "content": "<p>Hello team!</p>",
        "status": "active",
        "created_at": "2025-03-10T10:00:00Z",
        "creator": {
          "id": 1049715914,
          "name": "Victor Cooper"
        }
      }
    ]
  }
}