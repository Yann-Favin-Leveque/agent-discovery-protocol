{
  "name": "schedule_entries_list",
  "resource_group": "schedule_entries",
  "description": "List all schedule entries in a project schedule.",
  "endpoint": "/{account_id}/buckets/{project_id}/schedules/{schedule_id}/entries.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "schedule_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Schedule ID",
      "example": 8888888
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by status",
      "example": "archived"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/schedules/8888888/entries.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479600,
        "summary": "Team standup",
        "starts_at": "2025-03-15T09:00:00Z",
        "ends_at": "2025-03-15T09:15:00Z",
        "all_day": false
      }
    ]
  }
}