{
  "name": "todolists_update",
  "resource_group": "todolists",
  "description": "Update a todolist's name or description.",
  "endpoint": "/{account_id}/buckets/{project_id}/todolists/{todolist_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todolist_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todolist ID",
      "example": 1069479338
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Updated name",
      "example": "Updated Sprint Tasks",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Updated description",
      "example": "<p>Updated</p>",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todolists/1069479338.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "name": "Updated Sprint Tasks"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479338,
      "title": "Updated Sprint Tasks"
    }
  }
}
