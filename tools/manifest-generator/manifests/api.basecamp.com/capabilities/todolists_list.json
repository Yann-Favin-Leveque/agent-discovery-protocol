{
  "name": "todolists_list",
  "resource_group": "todolists",
  "description": "List all todolists in a todoset.",
  "endpoint": "/{account_id}/buckets/{project_id}/todosets/{todoset_id}/todolists.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todoset_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todoset ID",
      "example": 1234567
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by status",
      "example": "archived",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todosets/1234567/todolists.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1069479338,
        "title": "Launch checklist",
        "completed_ratio": "2/5",
        "description": "Tasks for launch",
        "app_url": "https://3.basecamp.com/9999999/buckets/2085958499/todolists/1069479338"
      }
    ]
  }
}
