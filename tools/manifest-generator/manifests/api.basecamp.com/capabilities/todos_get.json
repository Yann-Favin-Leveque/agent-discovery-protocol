{
  "name": "todos_get",
  "resource_group": "todos",
  "description": "Retrieve a specific todo by ID.",
  "endpoint": "/{account_id}/buckets/{project_id}/todos/{todo_id}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "todo_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Todo ID",
      "example": 1069479099
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://3.basecampapi.com/9999999/buckets/2085958499/todos/1069479099.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "User-Agent": "MyApp (user@example.com)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1069479099,
      "content": "Design homepage",
      "completed": false,
      "due_on": "2025-03-20"
    }
  }
}