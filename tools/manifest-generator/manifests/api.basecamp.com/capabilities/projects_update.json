{
  "name": "projects_update",
  "resource_group": "projects",
  "description": "Update a project's name or description.",
  "endpoint": "/{account_id}/projects/{project_id}.json",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Basecamp account ID",
      "example": 9999999
    },
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Project ID",
      "example": 2085958499
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Updated project name",
      "example": "Updated Campaign"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Updated description",
      "example": "Updated description"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://3.basecampapi.com/9999999/projects/2085958499.json",
    "headers": {
      "Authorization": "Bearer BC3_TOKEN",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (user@example.com)"
    },
    "body": {
      "name": "Updated Campaign",
      "description": "Updated description"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 2085958499,
      "name": "Updated Campaign"
    }
  }
}