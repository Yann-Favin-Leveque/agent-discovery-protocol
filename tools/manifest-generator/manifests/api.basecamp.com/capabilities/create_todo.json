{
  "name": "create_todo",
  "description": "Create a new todo item in a specific todolist. Todos can be assigned to team members, have due dates, and may be marked as completed. Use this to add actionable tasks to your project workflow.",
  "endpoint": "/{account_id}/buckets/{project_id}/todolists/{todolist_id}/todos.json",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The unique identifier for the Basecamp account.",
      "required": true,
      "example": "3619386"
    },
    {
      "name": "project_id",
      "type": "string",
      "description": "The unique identifier for the project (bucket).",
      "required": true,
      "example": "1028178134"
    },
    {
      "name": "todolist_id",
      "type": "string",
      "description": "The unique identifier for the todolist containing this todo.",
      "required": true,
      "example": "9007199254740993"
    },
    {
      "name": "content",
      "type": "string",
      "description": "The title or description of the todo item.",
      "required": true,
      "example": "Design homepage mockup"
    },
    {
      "name": "assignee_ids",
      "type": "array",
      "description": "Optional array of person IDs to assign this todo to.",
      "required": false,
      "example": "[10000001, 10000002]"
    },
    {
      "name": "due_on",
      "type": "string",
      "description": "Optional due date in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-03-15"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://3.basecampapi.com/3619386/buckets/1028178134/todolists/9007199254740993/todos.json",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "User-Agent": "MyApp (your-email@example.com)"
    },
    "body": {
      "content": "Design homepage mockup",
      "assignee_ids": [10000001],
      "due_on": "2024-03-15"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 1087626407,
      "status": "active",
      "created_at": "2024-03-01T15:30:00Z",
      "updated_at": "2024-03-01T15:30:00Z",
      "content": "Design homepage mockup",
      "completed": false,
      "due_on": "2024-03-15",
      "assignees": [
        {
          "id": 10000001,
          "name": "Alice Johnson",
          "email_address": "alice@example.com"
        }
      ],
      "position": 1,
      "bucket": {
        "id": 1028178134,
        "name": "Website Redesign",
        "type": "Project"
      },
      "todolist": {
        "id": 9007199254740993,
        "name": "Sprint Planning"
      },
      "creator": {
        "id": 10000001,
        "name": "Alice Johnson",
        "email_address": "alice@example.com"
      }
    }
  }
}
