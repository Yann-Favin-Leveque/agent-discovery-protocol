{
  "name": "redis_pipeline",
  "resource_group": "redis",
  "description": "Execute multiple Redis commands in a single batch (non-atomic).",
  "endpoint": "/pipeline",
  "method": "POST",
  "parameters": [
    {
      "name": "commands",
      "type": "array",
      "required": true,
      "in": "body",
      "description": "2D JSON array of commands."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{endpoint}.upstash.io/pipeline",
    "headers": {
      "Authorization": "Bearer {rest_token}",
      "Content-Type": "application/json"
    },
    "body": [
      [
        "SET",
        "foo",
        "bar"
      ],
      [
        "GET",
        "foo"
      ]
    ]
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "result": "OK"
      },
      {
        "result": "bar"
      }
    ]
  }
}