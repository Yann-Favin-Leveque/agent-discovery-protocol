{
  "name": "databases_delete",
  "resource_group": "databases",
  "description": "Delete a Redis database by ID. Irreversible.",
  "endpoint": "/v2/redis/database/{database_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "database_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.upstash.com/v2/redis/database/db-abc123",
    "headers": {
      "Authorization": "Basic base64(email:api_key)"
    }
  },
  "response_example": {
    "status": 200,
    "body": "OK"
  }
}