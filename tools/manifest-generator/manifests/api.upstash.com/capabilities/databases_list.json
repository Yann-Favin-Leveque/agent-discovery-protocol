{
  "name": "databases_list",
  "resource_group": "databases",
  "description": "List all Redis databases in your Upstash account.",
  "endpoint": "/v2/redis/databases",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.upstash.com/v2/redis/databases",
    "headers": {
      "Authorization": "Basic base64(email:api_key)"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "database_id": "db-abc123",
        "database_name": "my-redis",
        "endpoint": "us1-merry-cat-32748.upstash.io",
        "region": "us-east-1",
        "state": "active"
      }
    ]
  }
}