{
  "name": "databases_reset_password",
  "resource_group": "databases",
  "description": "Reset the password of a Redis database.",
  "endpoint": "/v2/redis/reset-password/{database_id}",
  "method": "POST",
  "parameters": [
    {
      "name": "database_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.upstash.com/v2/redis/reset-password/db-abc123",
    "headers": {
      "Authorization": "Basic base64(email:api_key)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "password": "new-password-here",
      "rest_token": "new-rest-token"
    }
  }
}