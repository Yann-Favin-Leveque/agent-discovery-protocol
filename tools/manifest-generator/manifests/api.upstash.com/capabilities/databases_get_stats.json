{
  "name": "databases_get_stats",
  "resource_group": "databases",
  "description": "Get usage statistics for a Redis database.",
  "endpoint": "/v2/redis/stats/{database_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "database_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.upstash.com/v2/redis/stats/db-abc123",
    "headers": {
      "Authorization": "Basic base64(email:api_key)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "connection_count": 5,
      "commands_per_second": 120,
      "key_count": 1500
    }
  }
}