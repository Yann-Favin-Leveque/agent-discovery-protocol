{
  "name": "manage_redis_databases",
  "description": "Create, list, get details, and delete serverless Redis databases. Use this to provision new Redis instances or manage existing ones in your Upstash account.",
  "endpoint": "/v2/redis/database",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "Name for the new database.", "required": true, "example": "my-cache" },
    { "name": "region", "type": "string", "description": "The region for the database (e.g., us-east-1, eu-west-1).", "required": true, "example": "us-east-1" },
    { "name": "tls", "type": "boolean", "description": "Enable TLS encryption.", "required": false, "example": true }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.upstash.com/v2/redis/database",
    "headers": { "Authorization": "Basic {base64(email:api_key)}", "Content-Type": "application/json" },
    "body": { "name": "my-cache", "region": "us-east-1", "tls": true }
  },
  "response_example": {
    "status": 200,
    "body": {
      "database_id": "db-123abc",
      "database_name": "my-cache",
      "endpoint": "us1-abc-12345.upstash.io",
      "port": 6379,
      "password": "xxxxxxxxxxxx",
      "rest_token": "AXxxxxxxxxxxxx",
      "read_only_rest_token": "AnXxxxxxxxxxxx"
    }
  }
}
