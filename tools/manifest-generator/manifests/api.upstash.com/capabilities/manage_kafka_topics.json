{
  "name": "manage_kafka_topics",
  "description": "Create, list, and manage Kafka topics in your Upstash Kafka cluster. Topics are the fundamental unit of data organization in Kafka.",
  "endpoint": "/v2/kafka/topic",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "Name for the topic.", "required": true, "example": "events" },
    { "name": "cluster_id", "type": "string", "description": "The Kafka cluster ID.", "required": true, "example": "cluster-123" },
    { "name": "partitions", "type": "number", "description": "Number of partitions.", "required": true, "example": 3 },
    { "name": "retention_time", "type": "number", "description": "Message retention time in milliseconds.", "required": false, "example": 86400000 }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.upstash.com/v2/kafka/topic",
    "headers": { "Authorization": "Basic {base64(email:api_key)}", "Content-Type": "application/json" },
    "body": { "name": "events", "cluster_id": "cluster-123", "partitions": 3, "retention_time": 86400000 }
  },
  "response_example": {
    "status": 200,
    "body": {
      "topic_id": "topic-456",
      "topic_name": "events",
      "partitions": 3,
      "cluster_id": "cluster-123"
    }
  }
}
