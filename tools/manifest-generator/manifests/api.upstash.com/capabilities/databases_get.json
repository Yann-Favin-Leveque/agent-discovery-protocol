{
  "name": "databases_get",
  "resource_group": "databases",
  "description": "Get details of a specific Redis database by ID.",
  "endpoint": "/v2/redis/database/{database_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "database_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.upstash.com/v2/redis/database/db-abc123",
    "headers": {
      "Authorization": "Basic base64(email:api_key)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "database_id": "db-abc123",
      "database_name": "my-redis",
      "endpoint": "us1-merry-cat-32748.upstash.io",
      "port": 32748,
      "state": "active",
      "tls": true
    }
  }
}