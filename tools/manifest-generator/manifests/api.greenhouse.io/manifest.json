{
  "spec_version": "1.0",
  "name": "Greenhouse Harvest API",
  "description": "Greenhouse is an applicant tracking system (ATS) for managing recruiting and hiring workflows. The Harvest API provides programmatic access to candidates, job postings, applications, interviews, scorecards, offers, and organizational data. Use it to automate recruiting pipelines, sync candidate data, manage interview scheduling, and track hiring metrics.",
  "base_url": "https://harvest.greenhouse.io",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Basic",
    "setup_url": "https://app.greenhouse.io/configure/dev_center/credentials"
  },
