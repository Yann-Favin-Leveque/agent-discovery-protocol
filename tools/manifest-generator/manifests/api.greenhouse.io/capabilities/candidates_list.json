{
  "name": "candidates_list",
  "resource_group": "Candidates",
  "endpoint": "/v1/candidates",
  "method": "GET",
  "description": "List all candidates with filtering by date, job, email, or external ID.",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page (1-500).",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "created_after",
      "type": "string",
      "required": false,
      "description": "ISO-8601 date filter.",
      "in": "query"
    },
    {
      "name": "updated_after",
      "type": "string",
      "required": false,
      "description": "ISO-8601 date filter.",
      "in": "query"
    },
    {
      "name": "job_id",
      "type": "integer",
      "required": false,
      "description": "Filter by job.",
      "in": "query"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by email.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/candidates?per_page=50",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 17681532,
        "first_name": "John",
        "last_name": "Doe",
        "emails": [
          {
            "value": "john@example.com",
            "type": "personal"
          }
        ]
      }
    ]
  }
}
