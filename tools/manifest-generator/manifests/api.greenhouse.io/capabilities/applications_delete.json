{
  "name": "applications_delete",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}",
  "method": "DELETE",
  "description": "Delete a candidate application.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID.",
      "in": "path"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID performing the action (header).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Application deleted"
    }
  }
}
