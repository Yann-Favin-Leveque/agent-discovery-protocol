{
  "name": "users_list",
  "resource_group": "Users",
  "endpoint": "/v1/users",
  "method": "GET",
  "description": "List all Greenhouse users.",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Filter by email.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/users",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 100,
        "first_name": "Sarah",
        "last_name": "Connor",
        "email": "sarah@co.com"
      }
    ]
  }
}
