{
  "name": "applications_move",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}/move",
  "method": "POST",
  "description": "Move an application to a specific stage within the same job.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID."
    },
    {
      "name": "from_stage_id",
      "type": "integer",
      "required": true,
      "description": "Current stage."
    },
    {
      "name": "to_stage_id",
      "type": "integer",
      "required": true,
      "description": "Target stage."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/move",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "from_stage_id": 7834,
      "to_stage_id": 7836
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 29483021,
      "current_stage": {
        "id": 7836,
        "name": "Offer"
      }
    }
  }
}