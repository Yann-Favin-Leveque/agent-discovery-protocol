  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Job ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/jobs/45021/approval_flows",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 600,
        "sequential": true
      }
    ]
  }
}
