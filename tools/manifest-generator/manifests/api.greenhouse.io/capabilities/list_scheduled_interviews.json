{
  "name": "list_scheduled_interviews",
  "description": "List all scheduled interviews across the organization. Returns interview details including the application and candidate, interview date/time, duration, interviewers, location, and associated interview kit. Can filter by creation date to retrieve only recently scheduled interviews.",
  "endpoint": "/v1/scheduled_interviews",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of interviews per page. Default: 100. Max: 500."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "created_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter interviews created after this timestamp."
    },
    {
      "name": "updated_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter interviews updated after this timestamp."
    },
    {
      "name": "starts_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter interviews starting after this timestamp."
    },
    {
      "name": "starts_before",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter interviews starting before this timestamp."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/scheduled_interviews?per_page=2&starts_after=2024-11-01T00:00:00Z",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6cGFzc3dvcmQ="
    }
  },
