{
  "name": "jobs_stages_list",
  "resource_group": "Job Stages",
  "endpoint": "/v1/jobs/{id}/stages",
  "method": "GET",
  "description": "List all pipeline stages for a job.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Job ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/jobs/45021/stages",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 7830,
        "name": "Application Review"
      },
      {
        "id": 7834,
        "name": "Technical Interview"
      },
      {
        "id": 7836,
        "name": "Offer"
      }
    ]
  }
}
