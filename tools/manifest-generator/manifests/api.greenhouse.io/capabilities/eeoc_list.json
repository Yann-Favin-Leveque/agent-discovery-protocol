{
  "name": "eeoc_list",
  "resource_group": "EEOC",
  "endpoint": "/v1/eeoc",
  "method": "GET",
  "description": "List all EEOC data entries.",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/eeoc",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "application_id": 29483021,
        "race": {
          "description": "Two or More Races"
        }
      }
    ]
  }
}
