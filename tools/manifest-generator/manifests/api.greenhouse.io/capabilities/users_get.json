{
  "name": "users_get",
  "resource_group": "Users",
  "endpoint": "/v1/users/{id}",
  "method": "GET",
  "description": "Retrieve a specific user.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "User ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/users/100",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 100,
      "first_name": "Sarah",
      "last_name": "Connor"
    }
  }
}
