{
  "name": "candidates_get",
  "resource_group": "Candidates",
  "endpoint": "/v1/candidates/{id}",
  "method": "GET",
  "description": "Retrieve full details for a specific candidate.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Candidate ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/candidates/17681532",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 17681532,
      "first_name": "John",
      "last_name": "Doe",
      "company": "Acme",
      "emails": [
        {
          "value": "john@example.com"
        }
      ],
      "applications": [
        {
          "id": 29483021
        }
      ]
    }
  }
}
