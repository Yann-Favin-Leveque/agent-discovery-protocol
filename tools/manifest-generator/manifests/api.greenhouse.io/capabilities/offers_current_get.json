{
  "name": "offers_current_get",
  "resource_group": "Offers",
  "endpoint": "/v1/applications/{id}/offers/current_offer",
  "method": "GET",
  "description": "Retrieve the current offer for an application.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/offers/current_offer",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 9000,
      "status": "accepted"
    }
  }
}
