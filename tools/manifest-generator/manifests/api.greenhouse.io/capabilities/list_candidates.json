{
  "name": "list_candidates",
  "description": "List all candidates in the Greenhouse ATS with pagination. Can filter by creation date to retrieve only recently added candidates. Returns candidate names, email addresses, phone numbers, application IDs, and timestamps. Results are ordered by candidate ID.",
  "endpoint": "/v1/candidates",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of candidates per page. Default: 100. Max: 500."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "created_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter candidates created after this timestamp (e.g., '2024-01-01T00:00:00Z')."
    },
    {
      "name": "created_before",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter candidates created before this timestamp."
    },
    {
      "name": "updated_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter candidates updated after this timestamp."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/candidates?per_page=2&created_after=2024-10-01T00:00:00Z",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6cGFzc3dvcmQ="
    }
  },
