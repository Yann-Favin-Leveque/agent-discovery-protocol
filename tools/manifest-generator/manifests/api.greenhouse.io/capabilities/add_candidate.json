{
  "name": "add_candidate",
  "description": "Create a new candidate record in Greenhouse and optionally attach them to one or more job applications. Requires at least first name and last name. Can include email addresses, phone numbers, social media profiles, tags, and an initial application with a job ID. The On-Behalf-Of header specifying a Greenhouse user ID is required.",
  "endpoint": "/v1/candidates",
  "method": "POST",
  "parameters": [
    {
      "name": "first_name",
      "type": "string",
      "required": true,
      "description": "The candidate's first name."
    },
    {
      "name": "last_name",
      "type": "string",
      "required": true,
      "description": "The candidate's last name."
    },
    {
      "name": "company",
      "type": "string",
      "required": false,
      "description": "The candidate's current company."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "The candidate's current job title."
    },
    {
      "name": "phone_numbers",
      "type": "array",
      "required": false,
      "description": "Array of phone number objects with 'value' (string) and 'type' ('mobile', 'home', 'work', 'other') fields."
    },
    {
      "name": "email_addresses",
      "type": "array",
      "required": false,
      "description": "Array of email objects with 'value' (string) and 'type' ('personal', 'work', 'other') fields."
    },
    {
      "name": "website_addresses",
      "type": "array",
      "required": false,
      "description": "Array of website objects with 'value' (URL string) and 'type' ('personal', 'company', 'portfolio', 'other') fields."
    },
    {
      "name": "social_media_addresses",
      "type": "array",
      "required": false,
      "description": "Array of social media objects with 'value' (URL string) fields."
    },
    {
      "name": "tags",
      "type": "array",
      "required": false,
      "description": "Array of tag strings to categorize the candidate (e.g., ['engineering', 'senior', 'referral'])."
    },
    {
      "name": "applications",
      "type": "array",
      "required": false,
      "description": "Array of application objects. Each must contain 'job_id' (integer). Can also include 'source_id', 'referrer', and 'initial_stage_id'."
    }
  ],
  "request_example": {
