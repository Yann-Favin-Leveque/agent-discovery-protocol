{
  "name": "custom_fields_get",
  "resource_group": "Custom Fields",
  "endpoint": "/v1/custom_fields/{id}",
  "method": "GET",
  "description": "Retrieve a specific custom field.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Custom field ID."
    }
  ],
  "request_example": {
