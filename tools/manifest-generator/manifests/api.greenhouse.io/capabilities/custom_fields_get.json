    "url": "https://harvest.greenhouse.io/v1/custom_fields/50",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 50,
      "name": "Salary Expectation",
      "field_type": "short_text"
    }
  }
}