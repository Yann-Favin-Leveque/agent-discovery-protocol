{
  "name": "offices_create",
  "resource_group": "Offices",
  "endpoint": "/v1/offices",
  "method": "POST",
  "description": "Create a new office.",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Office name.",
      "in": "body"
    },
    {
      "name": "location",
      "type": "string",
      "required": false,
      "description": "Location.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/offices",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "London"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 3,
      "name": "London"
    }
  }
}
