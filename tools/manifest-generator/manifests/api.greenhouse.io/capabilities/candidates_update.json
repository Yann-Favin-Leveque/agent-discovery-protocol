{
  "name": "candidates_update",
  "resource_group": "Candidates",
  "endpoint": "/v1/candidates/{id}",
  "method": "PATCH",
  "description": "Update a candidate's information.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Candidate ID.",
      "in": "path"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "company",
      "type": "string",
      "required": false,
      "description": "Company.",
      "in": "body"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Title.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://harvest.greenhouse.io/v1/candidates/17681532",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "company": "NewCo"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 17681532,
      "company": "NewCo"
    }
  }
}
