{
  "name": "applications_hire",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}/hire",
  "method": "POST",
  "description": "Mark an application as hired with optional start date.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID."
    },
    {
      "name": "start_date",
      "type": "string",
      "required": false,
      "description": "Start date YYYY-MM-DD."
    },
    {
      "name": "opening_id",
      "type": "integer",
      "required": false,
      "description": "Opening to fill."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/hire",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "start_date": "2025-01-15"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 29483021,
      "status": "hired"
    }
  }
}