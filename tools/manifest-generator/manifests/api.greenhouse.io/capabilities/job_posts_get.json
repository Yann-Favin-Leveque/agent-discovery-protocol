{
  "name": "job_posts_get",
  "resource_group": "Job Posts",
  "endpoint": "/v1/job_posts/{id}",
  "method": "GET",
  "description": "Retrieve a specific job post.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Job post ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/job_posts/56001",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 56001,
      "title": "Software Engineer",
      "active": true
    }
  }
}
