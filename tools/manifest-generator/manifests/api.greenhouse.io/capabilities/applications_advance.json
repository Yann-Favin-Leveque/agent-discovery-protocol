{
  "name": "applications_advance",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}/advance",
  "method": "POST",
  "description": "Advance an application to the next stage in the hiring pipeline.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID."
    },
    {
      "name": "from_stage_id",
      "type": "integer",
      "required": true,
      "description": "Current stage ID."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/advance",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "from_stage_id": 7834
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 29483021,
      "current_stage": {
        "id": 7835,
        "name": "Onsite Interview"
      }
    }
  }
}