{
  "name": "job_posts_list",
  "resource_group": "Job Posts",
  "endpoint": "/v1/job_posts",
  "method": "GET",
  "description": "List all job posts.",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    },
    {
      "name": "internal",
      "type": "boolean",
      "required": false,
      "description": "Filter internal."
    },
    {
      "name": "full_content",
      "type": "boolean",
      "required": false,
      "description": "Include HTML."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/job_posts",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 56001,
        "title": "Software Engineer",
        "active": true
      }
    ]
  }
}