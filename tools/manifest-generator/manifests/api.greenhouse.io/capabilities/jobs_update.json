{
  "name": "jobs_update",
  "resource_group": "Jobs",
  "endpoint": "/v1/jobs/{id}",
  "method": "PATCH",
  "description": "Update a job's properties.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Job ID."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "New title."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://harvest.greenhouse.io/v1/jobs/45021",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Staff Software Engineer"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 45021,
      "name": "Staff Software Engineer"
    }
  }
}