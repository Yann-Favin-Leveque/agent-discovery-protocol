{
  "name": "users_disable",
  "resource_group": "Users",
  "endpoint": "/v2/users/{id}/disable",
  "method": "PATCH",
  "description": "Disable a user account.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "User ID.",
      "in": "path"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://harvest.greenhouse.io/v2/users/200/disable",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 200,
      "disabled": true
    }
  }
}
