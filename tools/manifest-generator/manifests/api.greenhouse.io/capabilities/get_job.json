{
  "name": "get_job",
  "description": "Retrieve full details for a specific job posting by its ID. Returns comprehensive information including the hiring team (managers, recruiters, coordinators), departments, offices, openings with their statuses, and custom fields.",
  "endpoint": "/v1/jobs/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "The job's unique Greenhouse ID (e.g., 45021)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/jobs/45021",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6cGFzc3dvcmQ="
    }
  },
