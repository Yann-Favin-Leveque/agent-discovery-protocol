{
  "name": "applications_reject",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}/reject",
  "method": "POST",
  "description": "Reject an application with optional reason and email notification.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID.",
      "in": "path"
    },
    {
      "name": "rejection_reason_id",
      "type": "integer",
      "required": false,
      "description": "Rejection reason ID.",
      "in": "body"
    },
    {
      "name": "notes",
      "type": "string",
      "required": false,
      "description": "Internal notes.",
      "in": "body"
    },
    {
      "name": "rejection_email",
      "type": "object",
      "required": false,
      "description": "Email config with send_email_at and email_template_id.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/reject",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "rejection_reason_id": 5
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 29483021,
      "status": "rejected"
    }
  }
}
