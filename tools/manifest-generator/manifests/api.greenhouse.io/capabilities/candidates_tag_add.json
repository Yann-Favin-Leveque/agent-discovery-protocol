{
  "name": "candidates_tag_add",
  "resource_group": "Candidates",
  "endpoint": "/v1/candidates/{candidate_id}/tags/{tag_id}",
  "method": "PUT",
  "description": "Add a tag to a candidate.",
  "parameters": [
    {
      "name": "candidate_id",
      "type": "integer",
      "required": true,
      "description": "Candidate ID.",
      "in": "path"
    },
    {
      "name": "tag_id",
      "type": "integer",
      "required": true,
      "description": "Tag ID.",
      "in": "path"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://harvest.greenhouse.io/v1/candidates/17681532/tags/1",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "name": "Strong Hire"
    }
  }
}
