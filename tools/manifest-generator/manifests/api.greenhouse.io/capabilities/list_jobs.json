{
  "name": "list_jobs",
  "description": "List job postings in Greenhouse with optional filtering by status (open, closed, draft) and department. Returns job titles, departments, offices, opening counts, and hiring team information. Results are paginated and ordered by job ID.",
  "endpoint": "/v1/jobs",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by job status: 'open', 'closed', or 'draft'. If omitted, returns all jobs."
    },
    {
      "name": "department_id",
      "type": "integer",
      "required": false,
      "description": "Filter by department ID to return only jobs in a specific department."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of jobs per page. Default: 100. Max: 500."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "created_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter jobs created after this timestamp."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/jobs?status=open&per_page=3",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6cGFzc3dvcmQ="
    }
  },
