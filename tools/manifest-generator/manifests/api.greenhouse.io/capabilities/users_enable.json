{
  "name": "users_enable",
  "resource_group": "Users",
  "endpoint": "/v2/users/{id}/enable",
  "method": "PATCH",
  "description": "Re-enable a disabled user account.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "User ID."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://harvest.greenhouse.io/v2/users/200/enable",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 200,
      "disabled": false
    }
  }
}