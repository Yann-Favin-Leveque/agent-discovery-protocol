{
  "name": "scheduled_interviews_delete",
  "resource_group": "Scheduled Interviews",
  "endpoint": "/v1/scheduled_interviews/{id}",
  "method": "DELETE",
  "description": "Delete a scheduled interview.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Interview ID.",
      "in": "path"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://harvest.greenhouse.io/v1/scheduled_interviews/5000",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Deleted"
    }
  }
}
