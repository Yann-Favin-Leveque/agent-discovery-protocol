{
  "name": "list_applications",
  "description": "List job applications in Greenhouse with optional filtering by job ID and application status. Returns application details including current hiring stage, rejection reason (if applicable), source, credited referrer, and associated candidate and job information.",
  "endpoint": "/v1/applications",
  "method": "GET",
  "parameters": [
    {
      "name": "job_id",
      "type": "integer",
      "required": false,
      "description": "Filter applications by job ID to see only applications for a specific role."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by application status: 'active', 'rejected', or 'hired'."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of applications per page. Default: 100. Max: 500."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "created_after",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date/time to filter applications created after this timestamp."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/applications?job_id=45021&status=active&per_page=3",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6cGFzc3dvcmQ="
    }
  },
