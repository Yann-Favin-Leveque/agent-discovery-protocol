{
  "name": "applications_attachment_create",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}/attachments",
  "method": "POST",
  "description": "Attach a file to an application (resume, cover letter, etc.).",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID.",
      "in": "path"
    },
    {
      "name": "filename",
      "type": "string",
      "required": true,
      "description": "File name.",
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "Type: resume, cover_letter, other, take_home_test, offer_letter.",
      "in": "body"
    },
    {
      "name": "url",
      "type": "string",
      "required": false,
      "description": "URL to file.",
      "in": "body"
    },
    {
      "name": "content",
      "type": "string",
      "required": false,
      "description": "Base64-encoded content.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/attachments",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "filename": "resume.pdf",
      "type": "resume",
      "url": "https://example.com/resume.pdf"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "filename": "resume.pdf",
      "type": "resume"
    }
  }
}
