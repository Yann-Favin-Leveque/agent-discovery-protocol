{
  "name": "candidates_education_create",
  "resource_group": "Candidates",
  "endpoint": "/v1/candidates/{id}/educations",
  "method": "POST",
  "description": "Add education history to a candidate.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Candidate ID.",
      "in": "path"
    },
    {
      "name": "school_id",
      "type": "integer",
      "required": false,
      "description": "School ID.",
      "in": "body"
    },
    {
      "name": "degree_id",
      "type": "integer",
      "required": false,
      "description": "Degree ID.",
      "in": "body"
    },
    {
      "name": "discipline_id",
      "type": "integer",
      "required": false,
      "description": "Discipline ID.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/candidates/17681532/educations",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "school_id": 100,
      "degree_id": 5
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 300,
      "school_name": "MIT",
      "degree": "Bachelor's"
    }
  }
}
