{
  "name": "jobs_hiring_team_get",
  "resource_group": "Jobs",
  "endpoint": "/v1/jobs/{id}/hiring_team",
  "method": "GET",
  "description": "Retrieve the hiring team for a job.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Job ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/jobs/45021/hiring_team",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hiring_managers": [
        {
          "id": 100,
          "first_name": "Sarah",
          "last_name": "Connor"
        }
      ],
      "recruiters": [
        {
          "id": 101
        }
      ]
    }
  }
}
