{
  "name": "users_create",
  "resource_group": "Users",
  "endpoint": "/v1/users",
  "method": "POST",
  "description": "Create a new Greenhouse user.",
  "parameters": [
    {
      "name": "first_name",
      "type": "string",
      "required": true,
      "description": "First name."
    },
    {
      "name": "last_name",
      "type": "string",
      "required": true,
      "description": "Last name."
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/users",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "first_name": "Alex",
      "last_name": "Kim",
      "email": "alex@co.com"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 200,
      "first_name": "Alex"
    }
  }
}