{
  "name": "candidates_anonymize",
  "resource_group": "Candidates",
  "endpoint": "/v1/candidates/{id}/anonymize",
  "method": "PUT",
  "description": "Anonymize a candidate's personal data for GDPR compliance.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Candidate ID."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://harvest.greenhouse.io/v1/candidates/17681532/anonymize",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 17681532,
      "first_name": "Anonymized"
    }
  }
}