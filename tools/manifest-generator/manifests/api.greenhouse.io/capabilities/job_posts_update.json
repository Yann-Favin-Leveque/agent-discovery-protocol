{
  "name": "job_posts_update",
  "resource_group": "Job Posts",
  "endpoint": "/v1/job_posts/{id}",
  "method": "PATCH",
  "description": "Update a job post.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Job post ID.",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Title.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://harvest.greenhouse.io/v1/job_posts/56001",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Senior Software Engineer"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 56001,
      "title": "Senior Software Engineer"
    }
  }
}
