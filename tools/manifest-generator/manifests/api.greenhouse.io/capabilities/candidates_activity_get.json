{
  "name": "candidates_activity_get",
  "resource_group": "Activity Feed",
  "endpoint": "/v1/candidates/{id}/activity_feed",
  "method": "GET",
  "description": "Retrieve a candidate's activity feed including interviews, notes, and emails.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Candidate ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/candidates/12345/activity_feed",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "notes": [
        {
          "id": 1,
          "body": "Great interview"
        }
      ],
      "emails": [
        {
          "id": 2,
          "subject": "Follow up"
        }
      ],
      "activities": [
        {
          "id": 3,
          "body": "Advanced"
        }
      ]
    }
  }
}
