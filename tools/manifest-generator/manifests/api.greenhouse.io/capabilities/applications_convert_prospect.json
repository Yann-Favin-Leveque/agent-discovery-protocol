{
  "name": "applications_convert_prospect",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}/convert_prospect",
  "method": "PATCH",
  "description": "Convert a prospect application to a candidate application.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID.",
      "in": "path"
    },
    {
      "name": "job_id",
      "type": "integer",
      "required": true,
      "description": "Target job ID.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/convert_prospect",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "job_id": 45021
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 29483021,
      "prospect": false
    }
  }
}
