{
  "name": "jobs_get",
  "resource_group": "Jobs",
  "endpoint": "/v1/jobs/{id}",
  "method": "GET",
  "description": "Retrieve full details for a specific job.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Job ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/jobs/45021",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 45021,
      "name": "Software Engineer",
      "status": "open",
      "departments": [
        {
          "id": 1,
          "name": "Engineering"
        }
      ],
      "offices": [
        {
          "id": 1,
          "name": "San Francisco"
        }
      ]
    }
  }
}
