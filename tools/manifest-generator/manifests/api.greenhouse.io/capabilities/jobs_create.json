{
  "name": "jobs_create",
  "resource_group": "Jobs",
  "endpoint": "/v1/jobs",
  "method": "POST",
  "description": "Create a new job posting.",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Job title.",
      "in": "body"
    },
    {
      "name": "department_id",
      "type": "integer",
      "required": false,
      "description": "Department ID.",
      "in": "body"
    },
    {
      "name": "office_ids",
      "type": "array",
      "required": false,
      "description": "Office IDs.",
      "in": "body"
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header).",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/jobs",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Data Engineer",
      "department_id": 1
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 45050,
      "name": "Data Engineer",
      "status": "draft"
    }
  }
}
