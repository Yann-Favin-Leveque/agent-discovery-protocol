{
  "name": "scorecards_get",
  "resource_group": "Scorecards",
  "endpoint": "/v1/scorecards/{id}",
  "method": "GET",
  "description": "Retrieve a specific scorecard.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Scorecard ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/scorecards/8000",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 8000,
      "overall_recommendation": "strong_yes",
      "attributes": [
        {
          "name": "Technical Skills",
          "rating": "4"
        }
      ]
    }
  }
}
