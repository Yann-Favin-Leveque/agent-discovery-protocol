{
  "name": "applications_get",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}",
  "method": "GET",
  "description": "Retrieve full details for a specific application by ID.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 29483021,
      "candidate_id": 17681532,
      "status": "active",
      "current_stage": {
        "id": 7834,
        "name": "Technical Interview"
      }
    }
  }
}
