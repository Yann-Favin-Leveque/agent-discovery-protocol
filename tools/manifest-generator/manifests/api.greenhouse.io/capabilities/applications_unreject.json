{
  "name": "applications_unreject",
  "resource_group": "Applications",
  "endpoint": "/v1/applications/{id}/unreject",
  "method": "POST",
  "description": "Unreject a previously rejected application.",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Application ID."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/applications/29483021/unreject",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 29483021,
      "status": "active"
    }
  }
}