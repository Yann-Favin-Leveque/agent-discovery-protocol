{
  "name": "tags_create",
  "resource_group": "Tags",
  "endpoint": "/v1/tags",
  "method": "POST",
  "description": "Create a new candidate tag.",
  "parameters": [
    {
      "name": "tag",
      "type": "string",
      "required": true,
      "description": "Tag name."
    },
    {
      "name": "On-Behalf-Of",
      "type": "integer",
      "required": true,
      "description": "User ID (header)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://harvest.greenhouse.io/v1/tags",
    "headers": {
      "Authorization": "Basic dXNlcm5hbWU6",
      "On-Behalf-Of": "4321",
      "Content-Type": "application/json"
    },
    "body": {
      "tag": "Priority"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 4,
      "name": "Priority"
    }
  }
}