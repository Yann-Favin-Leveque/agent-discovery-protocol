{
  "name": "get_user_profile",
  "description": "Retrieve the profile details of a specific user by their user ID. Returns their full name, email, profile picture URL, enrolled courses, roles, and custom profile fields.",
  "endpoint": "/webservice/rest/server.php",
  "method": "GET",
  "parameters": [
    { "name": "wstoken", "type": "string", "description": "The web service authentication token.", "required": true, "example": "abc123def456" },
    { "name": "wsfunction", "type": "string", "description": "Must be 'core_user_get_users_by_field'.", "required": true, "example": "core_user_get_users_by_field" },
    { "name": "moodlewsrestformat", "type": "string", "description": "Response format. Use 'json'.", "required": true, "example": "json" },
    { "name": "field", "type": "string", "description": "The field to search by: id, username, email.", "required": true, "example": "id" },
    { "name": "values[0]", "type": "string", "description": "The value to search for in the specified field.", "required": true, "example": "2" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.moodle.com/webservice/rest/server.php?wstoken={api_key}&wsfunction=core_user_get_users_by_field&moodlewsrestformat=json&field=id&values[0]=2",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 2,
        "username": "janesmith",
        "firstname": "Jane",
        "lastname": "Smith",
        "fullname": "Jane Smith",
        "email": "jane.smith@university.edu",
        "profileimageurl": "https://moodle.example.com/pluginfile.php/5/user/icon/f1",
        "city": "New York",
        "country": "US",
        "lang": "en"
      }
    ]
  }
}
