{
  "name": "messages_get",
  "description": "Retrieve messages for a conversation between two users.",
  "endpoint": "/webservice/rest/server.php?wsfunction=core_message_get_messages",
  "method": "POST",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "wstoken",
      "type": "string",
      "description": "Web service authentication token",
      "required": true,
      "example": "abc123token",
      "in": "body"
    },
    {
      "name": "useridto",
      "type": "integer",
      "description": "Recipient user ID",
      "required": true,
      "example": 42,
      "in": "body"
    },
    {
      "name": "useridfrom",
      "type": "integer",
      "description": "Sender user ID (0 for all senders)",
      "required": false,
      "example": 0,
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Message type (notifications, conversations, both)",
      "required": false,
      "example": "both",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{moodle_url}/webservice/rest/server.php?wstoken={token}&wsfunction=core_message_get_messages&moodlewsrestformat=json",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "useridto": 42,
      "useridfrom": 0,
      "type": "both"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "messages": [
        {
          "id": 100,
          "useridfrom": 2,
          "text": "Welcome to the course!",
          "timecreated": 1706745600
        }
      ]
    }
  },
  "auth_scopes": [
    "core_message_get_messages"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
