{
  "name": "enroll_user",
  "description": "Enroll one or more users into a course with a specified role. Common roles include student (roleid 5), teacher (roleid 3), and non-editing teacher (roleid 4). Requires appropriate enrollment permissions.",
  "endpoint": "/webservice/rest/server.php",
  "method": "POST",
  "parameters": [
    { "name": "wstoken", "type": "string", "description": "The web service authentication token.", "required": true, "example": "abc123def456" },
    { "name": "wsfunction", "type": "string", "description": "Must be 'enrol_manual_enrol_users'.", "required": true, "example": "enrol_manual_enrol_users" },
    { "name": "moodlewsrestformat", "type": "string", "description": "Response format. Use 'json'.", "required": true, "example": "json" },
    { "name": "enrolments[0][roleid]", "type": "integer", "description": "The role to assign: 3=teacher, 4=non-editing teacher, 5=student.", "required": true, "example": 5 },
    { "name": "enrolments[0][userid]", "type": "integer", "description": "The ID of the user to enroll.", "required": true, "example": 2 },
    { "name": "enrolments[0][courseid]", "type": "integer", "description": "The ID of the course to enroll into.", "required": true, "example": 5 }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.moodle.com/webservice/rest/server.php",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": "wstoken={api_key}&wsfunction=enrol_manual_enrol_users&moodlewsrestformat=json&enrolments[0][roleid]=5&enrolments[0][userid]=2&enrolments[0][courseid]=5"
  },
  "response_example": {
    "status": 200,
    "body": null
  }
}
