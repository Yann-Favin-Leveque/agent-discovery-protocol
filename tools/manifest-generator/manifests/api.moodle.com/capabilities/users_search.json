{
  "name": "users_search",
  "description": "Search for users matching specific criteria with filtering and pagination.",
  "endpoint": "/webservice/rest/server.php?wsfunction=core_user_get_users",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    { "name": "wstoken", "type": "string", "description": "Web service authentication token", "required": true, "example": "abc123token" },
    { "name": "criteria[0][key]", "type": "string", "description": "Search field (firstname, lastname, email, username, etc.)", "required": true, "example": "email" },
    { "name": "criteria[0][value]", "type": "string", "description": "Search value (supports % wildcard)", "required": true, "example": "%@example.com" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{moodle_url}/webservice/rest/server.php?wstoken={token}&wsfunction=core_user_get_users&moodlewsrestformat=json",
    "headers": { "Content-Type": "application/x-www-form-urlencoded" },
    "body": { "criteria[0][key]": "email", "criteria[0][value]": "%@example.com" }
  },
  "response_example": {
    "status": 200,
    "body": { "users": [{ "id": 42, "username": "jdoe", "firstname": "John", "lastname": "Doe" }], "warnings": [] }
  },
  "auth_scopes": ["core_user_get_users"],
  "rate_limits": { "requests_per_minute": 120 }
}
