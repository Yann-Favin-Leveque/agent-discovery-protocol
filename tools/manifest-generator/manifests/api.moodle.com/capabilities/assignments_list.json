{
  "name": "assignments_list",
  "description": "Retrieve all assignments for one or more courses including due dates and grading settings.",
  "endpoint": "/webservice/rest/server.php?wsfunction=mod_assign_get_assignments",
  "method": "POST",
  "resource_group": "assignments",
  "parameters": [
    {
      "name": "wstoken",
      "type": "string",
      "description": "Web service authentication token",
      "required": true,
      "example": "abc123token",
      "in": "body"
    },
    {
      "name": "courseids[0]",
      "type": "integer",
      "description": "Course ID to get assignments for",
      "required": true,
      "example": 5,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{moodle_url}/webservice/rest/server.php?wstoken={token}&wsfunction=mod_assign_get_assignments&moodlewsrestformat=json",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "courseids[0]": 5
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "courses": [
        {
          "id": 5,
          "assignments": [
            {
              "id": 1,
              "name": "Lab Report 1",
              "duedate": 1706745600,
              "grade": 100
            }
          ]
        }
      ]
    }
  },
  "auth_scopes": [
    "mod_assign_get_assignments"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
