{
  "name": "courses_delete",
  "description": "Delete one or more courses from the Moodle site.",
  "endpoint": "/webservice/rest/server.php?wsfunction=core_course_delete_courses",
  "method": "POST",
  "resource_group": "courses",
  "parameters": [
    {
      "name": "wstoken",
      "type": "string",
      "description": "Web service authentication token",
      "required": true,
      "example": "abc123token",
      "in": "body"
    },
    {
      "name": "courseids[0]",
      "type": "integer",
      "description": "Course ID to delete",
      "required": true,
      "example": 5,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{moodle_url}/webservice/rest/server.php?wstoken={token}&wsfunction=core_course_delete_courses&moodlewsrestformat=json",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "courseids[0]": 5
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "warnings": []
    }
  },
  "auth_scopes": [
    "core_course_delete_courses"
  ],
  "rate_limits": {
    "requests_per_minute": 30
  }
}
