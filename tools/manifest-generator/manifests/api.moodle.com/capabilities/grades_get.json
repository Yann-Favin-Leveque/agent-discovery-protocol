{
  "name": "grades_get",
  "description": "Retrieve grade items and final grades for a user in a specific course.",
  "endpoint": "/webservice/rest/server.php?wsfunction=core_grades_get_grades",
  "method": "POST",
  "resource_group": "grades",
  "parameters": [
    { "name": "wstoken", "type": "string", "description": "Web service authentication token", "required": true, "example": "abc123token" },
    { "name": "courseid", "type": "integer", "description": "The course ID", "required": true, "example": 5 },
    { "name": "userids[0]", "type": "integer", "description": "User ID to get grades for", "required": false, "example": 42 }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{moodle_url}/webservice/rest/server.php?wstoken={token}&wsfunction=core_grades_get_grades&moodlewsrestformat=json",
    "headers": { "Content-Type": "application/x-www-form-urlencoded" },
    "body": { "courseid": 5, "userids[0]": 42 }
  },
  "response_example": {
    "status": 200,
    "body": { "items": [{ "id": 1, "itemname": "Final Exam", "grades": [{ "userid": 42, "grade": "85.00" }] }] }
  },
  "auth_scopes": ["core_grades_get_grades"],
  "rate_limits": { "requests_per_minute": 120 }
}
