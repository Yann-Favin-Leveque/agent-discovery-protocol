{
  "name": "get_grades",
  "description": "Retrieve grade items and final grades for a user in a specific course. Returns individual grade items (assignments, quizzes), their scores, percentages, and the overall course grade.",
  "endpoint": "/webservice/rest/server.php",
  "method": "GET",
  "parameters": [
    { "name": "wstoken", "type": "string", "description": "The web service authentication token.", "required": true, "example": "abc123def456" },
    { "name": "wsfunction", "type": "string", "description": "Must be 'gradereport_user_get_grade_items'.", "required": true, "example": "gradereport_user_get_grade_items" },
    { "name": "moodlewsrestformat", "type": "string", "description": "Response format. Use 'json'.", "required": true, "example": "json" },
    { "name": "courseid", "type": "integer", "description": "The ID of the course to get grades for.", "required": true, "example": 5 },
    { "name": "userid", "type": "integer", "description": "The ID of the user to get grades for. Omit to get grades for the authenticated user.", "required": false, "example": 2 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.moodle.com/webservice/rest/server.php?wstoken={api_key}&wsfunction=gradereport_user_get_grade_items&moodlewsrestformat=json&courseid=5&userid=2",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "usergrades": [
        {
          "courseid": 5,
          "userid": 2,
          "userfullname": "Jane Smith",
          "maxdepth": 1,
          "gradeitems": [
            {
              "id": 1,
              "itemname": "Assignment 1: Hello World",
              "itemtype": "mod",
              "itemmodule": "assign",
              "graderaw": 95,
              "grademax": 100,
              "percentageformatted": "95.00 %"
            },
            {
              "id": 2,
              "itemname": "Course total",
              "itemtype": "course",
              "graderaw": 95,
              "grademax": 100,
              "percentageformatted": "95.00 %"
            }
          ]
        }
      ]
    }
  }
}
