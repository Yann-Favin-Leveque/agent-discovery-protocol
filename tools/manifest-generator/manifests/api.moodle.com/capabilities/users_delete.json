{
  "name": "users_delete",
  "description": "Delete one or more users from the Moodle database.",
  "endpoint": "/webservice/rest/server.php?wsfunction=core_user_delete_users",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    { "name": "wstoken", "type": "string", "description": "Web service authentication token", "required": true, "example": "abc123token" },
    { "name": "userids[0]", "type": "integer", "description": "User ID to delete", "required": true, "example": 42 }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{moodle_url}/webservice/rest/server.php?wstoken={token}&wsfunction=core_user_delete_users&moodlewsrestformat=json",
    "headers": { "Content-Type": "application/x-www-form-urlencoded" },
    "body": { "userids[0]": 42 }
  },
  "response_example": {
    "status": 200,
    "body": null
  },
  "auth_scopes": ["core_user_delete_users"],
  "rate_limits": { "requests_per_minute": 30 }
}
