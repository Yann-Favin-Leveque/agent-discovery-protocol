{
  "name": "products_list_devices",
  "description": "List devices in a product fleet.",
  "resource_group": "products",
  "endpoint": "/v1/products/{productIdOrSlug}/devices",
  "method": "GET",
  "parameters": [
    {
      "name": "productIdOrSlug",
      "type": "string",
      "description": "Product ID or slug.",
      "required": true
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false
    },
    {
      "name": "perPage",
      "type": "integer",
      "description": "Results per page.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/products/my-product/devices",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "devices": [
        {
          "id": "abc123",
          "name": "device-1",
          "online": true
        }
      ]
    }
  }
}