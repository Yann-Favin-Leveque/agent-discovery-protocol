{
  "name": "sims_list",
  "description": "List all SIM cards.",
  "resource_group": "sims",
  "endpoint": "/v1/sims",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page.",
      "required": false,
      "in": "query"
    },
    {
      "name": "perPage",
      "type": "integer",
      "description": "Per page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/sims",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sims": [
        {
          "_id": "sim_1",
          "iccid": "89014103211118510720",
          "status": "active"
        }
      ]
    }
  }
}
