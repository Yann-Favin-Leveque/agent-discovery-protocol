{
  "name": "sims_get",
  "description": "Get SIM card details.",
  "resource_group": "sims",
  "endpoint": "/v1/sims/{iccid}",
  "method": "GET",
  "parameters": [
    {
      "name": "iccid",
      "type": "string",
      "description": "SIM ICCID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/sims/89014103211118510720",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "sim_1",
      "iccid": "89014103211118510720",
      "status": "active"
    }
  }
}