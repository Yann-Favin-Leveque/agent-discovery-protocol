{
  "name": "access_tokens_list",
  "description": "Get current access token details.",
  "resource_group": "auth",
  "endpoint": "/v1/access_tokens/current",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/access_tokens/current",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "token": "abc...",
      "expires_at": "2024-12-31T23:59:59Z"
    }
  }
}