{
  "name": "devices_signal",
  "description": "Make device LED shout rainbows.",
  "resource_group": "devices",
  "endpoint": "/v1/devices/{deviceId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "signal",
      "type": "boolean",
      "description": "Enable/disable signal mode.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.particle.io/v1/devices/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "signal": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "signaling": true
    }
  }
}
