{
  "name": "devices_get",
  "description": "Get device details.",
  "resource_group": "devices",
  "endpoint": "/v1/devices/{deviceId}",
  "method": "GET",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/devices/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "name": "my-device",
      "connected": true,
      "variables": {
        "temp": "double",
        "humidity": "double"
      },
      "functions": [
        "toggle",
        "setMode"
      ],
      "firmware_version": "2.3.1"
    }
  }
}