{
  "name": "devices_delete",
  "description": "Unclaim a device.",
  "resource_group": "devices",
  "endpoint": "/v1/devices/{deviceId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.particle.io/v1/devices/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}
