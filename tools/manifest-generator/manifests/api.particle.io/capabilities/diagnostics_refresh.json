{
  "name": "diagnostics_refresh",
  "description": "Request fresh diagnostics.",
  "resource_group": "diagnostics",
  "endpoint": "/v1/diagnostics/{deviceId}/update",
  "method": "POST",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.particle.io/v1/diagnostics/abc123/update",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ok": true
    }
  }
}