{
  "name": "sims_get_data_usage",
  "description": "Get data usage for a SIM.",
  "resource_group": "sims",
  "endpoint": "/v1/sims/{iccid}/data_usage",
  "method": "GET",
  "parameters": [
    {
      "name": "iccid",
      "type": "string",
      "description": "SIM ICCID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/sims/89014103211118510720/data_usage",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "usage_by_day": [
        {
          "date": "2024-06-01",
          "mbs_used": 0.5
        }
      ]
    }
  }
}
