{
  "name": "devices_update",
  "description": "Update device name, notes, or settings.",
  "resource_group": "devices",
  "endpoint": "/v1/devices/{deviceId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "New device name.",
      "required": false
    },
    {
      "name": "notes",
      "type": "string",
      "description": "Device notes.",
      "required": false
    },
    {
      "name": "signal",
      "type": "boolean",
      "description": "Enable signal mode.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.particle.io/v1/devices/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "living-room-sensor"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "name": "living-room-sensor"
    }
  }
}