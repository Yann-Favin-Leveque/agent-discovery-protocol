{
  "name": "devices_create",
  "description": "Claim a device.",
  "resource_group": "devices",
  "endpoint": "/v1/devices",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Device ID to claim.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.particle.io/v1/devices",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "abc123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "connected": false
    }
  }
}