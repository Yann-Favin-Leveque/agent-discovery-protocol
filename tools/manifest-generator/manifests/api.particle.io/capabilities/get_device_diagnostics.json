{
  "name": "get_device_diagnostics",
  "description": "Retrieve the most recent diagnostic vitals from a device, including signal strength, round-trip time, memory usage, and battery state. Helpful for troubleshooting connectivity issues or monitoring device health over time.",
  "endpoint": "/v1/diagnostics/{deviceId}/last",
  "method": "GET",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "The unique ID of the device to get diagnostics for.",
      "required": true,
      "example": "0123456789abcdef01234567"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/diagnostics/0123456789abcdef01234567/last",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "diagnostics": {
        "updatedAt": "2025-12-01T18:30:00.000Z",
        "deviceID": "0123456789abcdef01234567",
        "payload": {
          "device": {
            "system": {
              "uptime": 86400,
              "memory": {
                "used": 32768,
                "total": 65536
              }
            },
            "network": {
              "signal": {
                "strength": -65,
                "quality": 80
              }
            }
          }
        }
      }
    }
  }
}
