{
  "name": "diagnostics_get_last",
  "description": "Get latest diagnostics.",
  "resource_group": "diagnostics",
  "endpoint": "/v1/diagnostics/{deviceId}/last",
  "method": "GET",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/diagnostics/abc123/last",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "diagnostics": {
        "signalStrength": -65,
        "freeMemory": 45000,
        "uptime": 86400
      }
    }
  }
}
