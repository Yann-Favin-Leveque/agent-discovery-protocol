{
  "name": "devices_get_variable",
  "description": "Read a variable from a device.",
  "resource_group": "devices",
  "endpoint": "/v1/devices/{deviceId}/{varName}",
  "method": "GET",
  "parameters": [
    {
      "name": "deviceId",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "varName",
      "type": "string",
      "description": "Variable name.",
      "required": true,
      "example": "temp",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.particle.io/v1/devices/abc123/temp",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "temp",
      "result": 22.5,
      "coreInfo": {
        "connected": true
      }
    }
  }
}
