{
  "name": "sip_trunk_delete",
  "description": "Delete a SIP trunk (inbound or outbound) by its trunk ID.",
  "endpoint": "/twirp/livekit.SIP/DeleteSIPTrunk",
  "method": "POST",
  "resource_group": "sip",
  "parameters": [
    {
      "name": "sip_trunk_id",
      "type": "string",
      "required": true,
      "description": "The SIP trunk ID to delete."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-livekit-host.livekit.cloud/twirp/livekit.SIP/DeleteSIPTrunk",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "sip_trunk_id": "ST_inbound_01"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": ["sipAdmin"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
