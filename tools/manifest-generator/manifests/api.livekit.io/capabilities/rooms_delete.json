{
  "name": "rooms_delete",
  "description": "Delete a room and immediately disconnect all participants currently in it.",
  "endpoint": "/twirp/livekit.RoomService/DeleteRoom",
  "method": "POST",
  "resource_group": "rooms",
  "parameters": [
    {
      "name": "room",
      "type": "string",
      "required": true,
      "description": "Name of the room to delete."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://your-livekit-host.livekit.cloud/twirp/livekit.RoomService/DeleteRoom",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    },
    "body": {
      "room": "interview-room-42"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": ["roomCreate"],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
