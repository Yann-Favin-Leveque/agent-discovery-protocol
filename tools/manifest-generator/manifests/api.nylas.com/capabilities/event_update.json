{
  "name": "event_update",
  "description": "Update an existing calendar event.",
  "resource_group": "event",
  "endpoint": "/v3/grants/{grant_id}/events/{event_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "event_id",
      "type": "string",
      "description": "Event ID (path parameter).",
      "required": true,
      "example": "evt_abc",
      "in": "path"
    },
    {
      "name": "calendar_id",
      "type": "string",
      "description": "Calendar ID (required query parameter).",
      "required": true,
      "example": "cal_abc",
      "in": "body"
    },
    {
      "name": "title",
      "type": "string",
      "description": "Updated title.",
      "required": false,
      "in": "body"
    },
    {
      "name": "when",
      "type": "object",
      "description": "Updated time.",
      "required": false,
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false,
      "in": "body"
    },
    {
      "name": "location",
      "type": "string",
      "description": "Updated location.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.us.nylas.com/v3/grants/me/events/evt_abc?calendar_id=cal_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Updated Meeting"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "evt_abc",
        "title": "Updated Meeting"
      }
    }
  }
}
