{
  "name": "thread_list",
  "description": "List email threads with optional filtering.",
  "resource_group": "thread",
  "endpoint": "/v3/grants/{grant_id}/threads",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "example": 50
    },
    {
      "name": "page_token",
      "type": "string",
      "description": "Pagination token.",
      "required": false
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Filter by subject.",
      "required": false
    },
    {
      "name": "unread",
      "type": "boolean",
      "description": "Filter by unread.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/threads?limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "thread_abc",
          "subject": "Re: Hello",
          "latest_message_date": 1704067200,
          "unread": true,
          "message_ids": [
            "msg_1",
            "msg_2"
          ]
        }
      ]
    }
  }
}