{
  "name": "message_delete",
  "description": "Delete or trash a specific message.",
  "resource_group": "message",
  "endpoint": "/v3/grants/{grant_id}/messages/{message_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "message_id",
      "type": "string",
      "description": "Message ID (path parameter).",
      "required": true,
      "example": "msg_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.us.nylas.com/v3/grants/me/messages/msg_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
