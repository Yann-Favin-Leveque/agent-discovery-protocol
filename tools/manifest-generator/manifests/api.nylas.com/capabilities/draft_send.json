{
  "name": "draft_send",
  "description": "Send an existing draft as an email.",
  "resource_group": "draft",
  "endpoint": "/v3/grants/{grant_id}/drafts/{draft_id}",
  "method": "POST",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me"
    },
    {
      "name": "draft_id",
      "type": "string",
      "description": "Draft ID (path parameter).",
      "required": true,
      "example": "draft_abc"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.us.nylas.com/v3/grants/me/drafts/draft_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "msg_sent",
        "thread_id": "thread_abc"
      }
    }
  }
}