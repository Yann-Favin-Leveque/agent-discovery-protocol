{
  "name": "webhook_delete",
  "description": "Delete a webhook subscription.",
  "resource_group": "webhook",
  "endpoint": "/v3/webhooks/{webhook_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "Webhook ID (path parameter).",
      "required": true,
      "example": "wh_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.us.nylas.com/v3/webhooks/wh_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
