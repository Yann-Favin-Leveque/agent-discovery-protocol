{
  "name": "grant_get",
  "description": "Retrieve a specific grant by ID or email.",
  "resource_group": "grant",
  "endpoint": "/v3/grants/{grant_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID or email (path parameter).",
      "required": true,
      "example": "grant_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/grant_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "grant_abc",
        "email": "user@gmail.com",
        "provider": "google",
        "grant_status": "valid",
        "scope": [
          "Mail.Read",
          "Calendars.ReadWrite"
        ]
      }
    }
  }
}