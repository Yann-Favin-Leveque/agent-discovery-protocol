{
  "name": "folder_delete",
  "description": "Delete a folder/label.",
  "resource_group": "folder",
  "endpoint": "/v3/grants/{grant_id}/folders/{folder_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me"
    },
    {
      "name": "folder_id",
      "type": "string",
      "description": "Folder ID (path parameter).",
      "required": true,
      "example": "folder_abc"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.us.nylas.com/v3/grants/me/folders/folder_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}