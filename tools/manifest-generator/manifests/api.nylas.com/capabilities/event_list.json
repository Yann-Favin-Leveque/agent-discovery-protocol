{
  "name": "event_list",
  "description": "List calendar events with required calendar_id and optional time range filtering.",
  "resource_group": "event",
  "endpoint": "/v3/grants/{grant_id}/events",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "calendar_id",
      "type": "string",
      "description": "Calendar ID (required query parameter).",
      "required": true,
      "example": "cal_abc",
      "in": "query"
    },
    {
      "name": "start",
      "type": "integer",
      "description": "Start time (Unix timestamp).",
      "required": false,
      "example": 1704067200,
      "in": "query"
    },
    {
      "name": "end",
      "type": "integer",
      "description": "End time (Unix timestamp).",
      "required": false,
      "example": 1704153600,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "example": 50,
      "in": "query"
    },
    {
      "name": "page_token",
      "type": "string",
      "description": "Pagination token.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/events?calendar_id=cal_abc&limit=10",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "evt_abc",
          "title": "Team Meeting",
          "when": {
            "start_time": 1704067200,
            "end_time": 1704070800
          },
          "participants": [
            {
              "email": "jane@example.com",
              "status": "yes"
            }
          ]
        }
      ]
    }
  }
}
