{
  "name": "calendar_update",
  "description": "Update a calendar.",
  "resource_group": "calendar",
  "endpoint": "/v3/grants/{grant_id}/calendars/{calendar_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "calendar_id",
      "type": "string",
      "description": "Calendar ID (path parameter).",
      "required": true,
      "example": "cal_abc",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "example": "Updated Calendar",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.us.nylas.com/v3/grants/me/calendars/cal_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Calendar"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "cal_abc",
        "name": "Work Calendar"
      }
    }
  }
}
