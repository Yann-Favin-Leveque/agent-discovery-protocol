{
  "name": "webhook_list",
  "description": "List all webhook subscriptions for the application.",
  "resource_group": "webhook",
  "endpoint": "/v3/webhooks",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/webhooks",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
