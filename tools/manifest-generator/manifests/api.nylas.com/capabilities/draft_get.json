{
  "name": "draft_get",
  "description": "Retrieve a specific draft by ID.",
  "resource_group": "draft",
  "endpoint": "/v3/grants/{grant_id}/drafts/{draft_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "draft_id",
      "type": "string",
      "description": "Draft ID (path parameter).",
      "required": true,
      "example": "draft_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/drafts/draft_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "draft_abc",
        "subject": "Draft email",
        "body": "<p>Draft content</p>"
      }
    }
  }
}
