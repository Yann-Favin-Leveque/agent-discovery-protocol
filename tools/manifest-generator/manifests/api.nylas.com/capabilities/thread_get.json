{
  "name": "thread_get",
  "description": "Retrieve a specific email thread with all messages.",
  "resource_group": "thread",
  "endpoint": "/v3/grants/{grant_id}/threads/{thread_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me"
    },
    {
      "name": "thread_id",
      "type": "string",
      "description": "Thread ID (path parameter).",
      "required": true,
      "example": "thread_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/threads/thread_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "thread_abc",
        "subject": "Re: Hello",
        "message_ids": [
          "msg_1",
          "msg_2"
        ]
      }
    }
  }
}