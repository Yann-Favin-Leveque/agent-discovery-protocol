{
  "name": "event_delete",
  "description": "Delete a calendar event.",
  "resource_group": "event",
  "endpoint": "/v3/grants/{grant_id}/events/{event_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "event_id",
      "type": "string",
      "description": "Event ID (path parameter).",
      "required": true,
      "example": "evt_abc",
      "in": "path"
    },
    {
      "name": "calendar_id",
      "type": "string",
      "description": "Calendar ID (required query parameter).",
      "required": true,
      "example": "cal_abc",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.us.nylas.com/v3/grants/me/events/evt_abc?calendar_id=cal_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
