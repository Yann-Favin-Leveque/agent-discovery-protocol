{
  "name": "contact_delete",
  "description": "Delete a contact.",
  "resource_group": "contact",
  "endpoint": "/v3/grants/{grant_id}/contacts/{contact_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me"
    },
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID (path parameter).",
      "required": true,
      "example": "contact_abc"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.us.nylas.com/v3/grants/me/contacts/contact_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}