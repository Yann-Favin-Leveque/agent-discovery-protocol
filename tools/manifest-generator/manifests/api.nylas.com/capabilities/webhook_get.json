{
  "name": "webhook_get",
  "description": "Retrieve a specific webhook subscription.",
  "resource_group": "webhook",
  "endpoint": "/v3/webhooks/{webhook_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "Webhook ID (path parameter).",
      "required": true,
      "example": "wh_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/webhooks/wh_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "wh_abc",
        "webhook_url": "https://example.com/webhook",
        "triggers": [
          "message.created"
        ],
        "status": "active"
      }
    }
  }
}