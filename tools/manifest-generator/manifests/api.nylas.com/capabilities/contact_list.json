{
  "name": "contact_list",
  "description": "List contacts for a grant.",
  "resource_group": "contact",
  "endpoint": "/v3/grants/{grant_id}/contacts",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "example": 50,
      "in": "query"
    },
    {
      "name": "page_token",
      "type": "string",
      "description": "Pagination token.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/contacts",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "contact_abc",
        "given_name": "Jane",
        "surname": "Doe"
      }
    }
  }
}
