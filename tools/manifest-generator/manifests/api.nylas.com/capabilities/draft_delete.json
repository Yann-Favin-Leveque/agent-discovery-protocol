{
  "name": "draft_delete",
  "description": "Delete a draft.",
  "resource_group": "draft",
  "endpoint": "/v3/grants/{grant_id}/drafts/{draft_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "draft_id",
      "type": "string",
      "description": "Draft ID (path parameter).",
      "required": true,
      "example": "draft_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.us.nylas.com/v3/grants/me/drafts/draft_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
