{
  "name": "folder_list",
  "description": "List all folders/labels for a grant.",
  "resource_group": "folder",
  "endpoint": "/v3/grants/{grant_id}/folders",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/folders",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "folder_abc",
        "name": "My Folder"
      }
    }
  }
}