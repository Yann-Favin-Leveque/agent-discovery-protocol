{
  "name": "contact_update",
  "description": "Update a contact.",
  "resource_group": "contact",
  "endpoint": "/v3/grants/{grant_id}/contacts/{contact_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID (path parameter).",
      "required": true,
      "example": "contact_abc",
      "in": "path"
    },
    {
      "name": "given_name",
      "type": "string",
      "description": "First name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "surname",
      "type": "string",
      "description": "Last name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.us.nylas.com/v3/grants/me/contacts/contact_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "given_name": "Janet"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "contact_abc",
        "given_name": "Jane",
        "surname": "Doe"
      }
    }
  }
}
