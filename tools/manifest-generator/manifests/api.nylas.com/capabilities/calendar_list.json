{
  "name": "calendar_list",
  "description": "List all calendars for a grant.",
  "resource_group": "calendar",
  "endpoint": "/v3/grants/{grant_id}/calendars",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/calendars",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "cal_abc",
        "name": "Work Calendar"
      }
    }
  }
}
