{
  "name": "calendar_delete",
  "description": "Delete a calendar.",
  "resource_group": "calendar",
  "endpoint": "/v3/grants/{grant_id}/calendars/{calendar_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me"
    },
    {
      "name": "calendar_id",
      "type": "string",
      "description": "Calendar ID (path parameter).",
      "required": true,
      "example": "cal_abc"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.us.nylas.com/v3/grants/me/calendars/cal_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}