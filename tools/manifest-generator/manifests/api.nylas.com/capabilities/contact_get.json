{
  "name": "contact_get",
  "description": "Retrieve a specific contact by ID.",
  "resource_group": "contact",
  "endpoint": "/v3/grants/{grant_id}/contacts/{contact_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "contact_id",
      "type": "string",
      "description": "Contact ID (path parameter).",
      "required": true,
      "example": "contact_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/contacts/contact_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "contact_abc",
        "given_name": "Jane",
        "surname": "Doe"
      }
    }
  }
}
