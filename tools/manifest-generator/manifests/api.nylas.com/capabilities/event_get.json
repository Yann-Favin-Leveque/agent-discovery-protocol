{
  "name": "event_get",
  "description": "Retrieve a specific calendar event by ID.",
  "resource_group": "event",
  "endpoint": "/v3/grants/{grant_id}/events/{event_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "event_id",
      "type": "string",
      "description": "Event ID (path parameter).",
      "required": true,
      "example": "evt_abc",
      "in": "path"
    },
    {
      "name": "calendar_id",
      "type": "string",
      "description": "Calendar ID (required query parameter).",
      "required": true,
      "example": "cal_abc",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.us.nylas.com/v3/grants/me/events/evt_abc?calendar_id=cal_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "evt_abc",
        "title": "Team Meeting",
        "description": "Weekly sync",
        "when": {
          "start_time": 1704067200,
          "end_time": 1704070800
        }
      }
    }
  }
}
