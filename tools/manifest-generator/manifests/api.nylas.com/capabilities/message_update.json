{
  "name": "message_update",
  "description": "Update message attributes such as unread status, starred, or folder.",
  "resource_group": "message",
  "endpoint": "/v3/grants/{grant_id}/messages/{message_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "grant_id",
      "type": "string",
      "description": "Grant ID (path parameter).",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "message_id",
      "type": "string",
      "description": "Message ID (path parameter).",
      "required": true,
      "example": "msg_abc",
      "in": "path"
    },
    {
      "name": "unread",
      "type": "boolean",
      "description": "Mark as unread or read.",
      "required": false,
      "example": false,
      "in": "body"
    },
    {
      "name": "starred",
      "type": "boolean",
      "description": "Star or unstar.",
      "required": false,
      "in": "body"
    },
    {
      "name": "folders",
      "type": "array",
      "description": "Folder IDs to move to.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.us.nylas.com/v3/grants/me/messages/msg_abc",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "unread": false
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "msg_abc",
        "unread": false
      }
    }
  }
}
