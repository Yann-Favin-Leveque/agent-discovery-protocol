{
  "name": "embedded_edit_url",
  "description": "Retrieve the edit URL for an embedded template draft to display in an iFrame.",
  "endpoint": "/v3/embedded/edit_url/{template_id}",
  "method": "POST",
  "resource_group": "embedded",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "c26b8a16",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hellosign.com/v3/embedded/edit_url/c26b8a16",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "embedded": {
        "edit_url": "https://app.hellosign.com/editor/embeddedEdit?template_id=c26b8a16",
        "expires_at": 1700000000
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
