{
  "name": "account_get",
  "description": "Retrieve the currently authenticated account details including quotas and callback URL.",
  "endpoint": "/v3/account",
  "method": "GET",
  "resource_group": "account",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/account",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "account": {
        "account_id": "abc123",
        "email_address": "user@example.com",
        "is_paid_hs": true,
        "quotas": {
          "templates_left": 5,
          "api_signature_requests_left": 100
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}