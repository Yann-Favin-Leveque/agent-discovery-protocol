{
  "name": "template_get",
  "description": "Retrieve details of a specific template including signer roles and fields.",
  "endpoint": "/v3/template/{template_id}",
  "method": "GET",
  "resource_group": "template",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "c26b8a16"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/template/c26b8a16",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "template": {
        "template_id": "c26b8a16",
        "title": "NDA Template",
        "signer_roles": [
          {
            "name": "Client",
            "order": 0
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}