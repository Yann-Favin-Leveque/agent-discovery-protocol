{
  "name": "embedded_sign_url",
  "description": "Retrieve the sign URL for an embedded signature to display in an iFrame.",
  "endpoint": "/v3/embedded/sign_url/{signature_id}",
  "method": "GET",
  "resource_group": "embedded",
  "parameters": [
    {
      "name": "signature_id",
      "type": "string",
      "description": "Signature ID.",
      "required": true,
      "example": "78caf2a1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/embedded/sign_url/78caf2a1",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "embedded": {
        "sign_url": "https://app.hellosign.com/editor/embeddedSign?signature_id=78caf2a1",
        "expires_at": 1700000000
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}