{
  "name": "report_create",
  "description": "Generate a report of signature requests and/or templates within a date range.",
  "endpoint": "/v3/report/create",
  "method": "POST",
  "resource_group": "report",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "description": "Start date (MM/DD/YYYY).",
      "required": true,
      "example": "01/01/2024",
      "in": "body"
    },
    {
      "name": "end_date",
      "type": "string",
      "description": "End date (MM/DD/YYYY).",
      "required": true,
      "example": "12/31/2024",
      "in": "body"
    },
    {
      "name": "report_type",
      "type": "array",
      "description": "Report types: user_activity, document_status.",
      "required": true,
      "example": [
        "user_activity"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hellosign.com/v3/report/create",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "start_date": "01/01/2024",
      "end_date": "12/31/2024",
      "report_type": [
        "user_activity"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
