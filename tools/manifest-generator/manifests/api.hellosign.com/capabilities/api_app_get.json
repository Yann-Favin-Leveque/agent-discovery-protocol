{
  "name": "api_app_get",
  "description": "Retrieve details of a specific API app by client ID.",
  "endpoint": "/v3/api_app/{client_id}",
  "method": "GET",
  "resource_group": "api_app",
  "parameters": [
    {
      "name": "client_id",
      "type": "string",
      "description": "Client ID.",
      "required": true,
      "example": "b6b8e7de"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/api_app/b6b8e7de",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "api_app": {
        "client_id": "b6b8e7de",
        "name": "My App"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}