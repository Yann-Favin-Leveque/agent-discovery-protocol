{
  "name": "get_signature_request",
  "description": "Retrieve the details and current status of a specific signature request by its ID. Returns information about all signers, their signing status (awaiting_signature, signed, declined), timestamps, and whether the request is complete. Use this to check if a document has been signed by all parties.",
  "endpoint": "/v3/signature_request/{signature_request_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "signature_request_id",
      "type": "string",
      "required": true,
      "description": "The unique identifier of the signature request to retrieve."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/signature_request/fa5c8a0b0f492d768749333ad6fcc214c111e967",
    "headers": {
      "Authorization": "Basic YXBpX2tleV9oZXJlOg=="
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "signature_request": {
        "signature_request_id": "fa5c8a0b0f492d768749333ad6fcc214c111e967",
        "title": "Employment Agreement",
        "is_complete": true,
        "has_error": false,
        "requester_email_address": "admin@example.com",
        "signing_url": null,
        "details_url": "https://app.hellosign.com/home/manage?guid=fa5c8a0b0f492d768749333ad6fcc214c111e967",
        "files_url": "https://api.hellosign.com/v3/signature_request/files/fa5c8a0b0f492d768749333ad6fcc214c111e967",
        "signatures": [
          {
            "signature_id": "78caf2a1d01cd39cea2bc1cbb340dac3",
            "signer_email_address": "jane@example.com",
            "signer_name": "Jane Doe",
            "order": 0,
            "status_code": "signed",
            "signed_at": 1705316400
          },
          {
            "signature_id": "a9b3e2f14c8d7a5e6b0f1c2d3e4a5b6c",
            "signer_email_address": "bob@example.com",
            "signer_name": "Bob Smith",
            "order": 1,
            "status_code": "signed",
            "signed_at": 1705320000
          }
        ],
        "created_at": 1705312800
      }
    }
  }
}
