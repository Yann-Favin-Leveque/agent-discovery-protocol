{
  "name": "template_update",
  "description": "Update an existing template name, subject, or message.",
  "endpoint": "/v3/template/{template_id}",
  "method": "PUT",
  "resource_group": "template",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "c26b8a16"
    },
    {
      "name": "subject",
      "type": "string",
      "description": "New subject.",
      "required": false,
      "example": "Updated NDA"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.hellosign.com/v3/template/c26b8a16",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "subject": "Updated NDA"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "template": {
        "template_id": "c26b8a16"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}