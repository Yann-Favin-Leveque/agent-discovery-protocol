{
  "name": "template_list",
  "description": "List all templates available to your account.",
  "endpoint": "/v3/template/list",
  "method": "GET",
  "resource_group": "template",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 20,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/template/list?page=1",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list_info": {
        "num_pages": 3,
        "page": 1
      },
      "templates": [
        {
          "template_id": "c26b8a16",
          "title": "NDA Template"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
