{
  "name": "template_add_user",
  "description": "Give another account access to use a template.",
  "endpoint": "/v3/template/add_user/{template_id}",
  "method": "POST",
  "resource_group": "template",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "c26b8a16"
    },
    {
      "name": "email_address",
      "type": "string",
      "description": "Email of user to add.",
      "required": true,
      "example": "colleague@example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hellosign.com/v3/template/add_user/c26b8a16",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "colleague@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "template": {
        "template_id": "c26b8a16"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}