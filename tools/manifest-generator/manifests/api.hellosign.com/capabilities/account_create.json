{
  "name": "account_create",
  "description": "Create a new Dropbox Sign account that must be confirmed via email.",
  "endpoint": "/v3/account/create",
  "method": "POST",
  "resource_group": "account",
  "parameters": [
    {
      "name": "email_address",
      "type": "string",
      "description": "Email for the new account.",
      "required": true,
      "example": "newuser@example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hellosign.com/v3/account/create",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "newuser@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "account": {
        "account_id": "def456",
        "email_address": "newuser@example.com"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
