{
  "name": "api_app_update",
  "description": "Update an existing API app settings.",
  "endpoint": "/v3/api_app/{client_id}",
  "method": "PUT",
  "resource_group": "api_app",
  "parameters": [
    {
      "name": "client_id",
      "type": "string",
      "description": "Client ID.",
      "required": true,
      "example": "b6b8e7de"
    },
    {
      "name": "name",
      "type": "string",
      "description": "New name.",
      "required": false,
      "example": "Updated App"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.hellosign.com/v3/api_app/b6b8e7de",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated App"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "api_app": {
        "client_id": "b6b8e7de",
        "name": "Updated App"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}