{
  "name": "team_update",
  "description": "Update your team name.",
  "endpoint": "/v3/team",
  "method": "PUT",
  "resource_group": "team",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "New team name.",
      "required": true,
      "example": "New Name",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.hellosign.com/v3/team",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "New Name"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "team": {
        "name": "New Name"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
