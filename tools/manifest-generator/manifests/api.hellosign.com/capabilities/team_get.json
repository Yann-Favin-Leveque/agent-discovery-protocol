{
  "name": "team_get",
  "description": "Retrieve information about your team including name and members.",
  "endpoint": "/v3/team",
  "method": "GET",
  "resource_group": "team",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/team",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "team": {
        "name": "My Team",
        "accounts": [
          {
            "account_id": "abc123",
            "email_address": "user@example.com",
            "role": "admin"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}