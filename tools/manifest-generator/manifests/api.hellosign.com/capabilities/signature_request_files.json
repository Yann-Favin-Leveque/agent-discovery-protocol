{
  "name": "signature_request_files",
  "description": "Download files associated with a signature request as PDF or ZIP.",
  "endpoint": "/v3/signature_request/files/{signature_request_id}",
  "method": "GET",
  "resource_group": "signature_request",
  "parameters": [
    {
      "name": "signature_request_id",
      "type": "string",
      "description": "ID of the signature request.",
      "required": true,
      "example": "fa5c8a0b"
    },
    {
      "name": "file_type",
      "type": "string",
      "description": "File format: pdf or zip.",
      "required": false,
      "example": "pdf"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/signature_request/files/fa5c8a0b?file_type=pdf",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "(binary PDF content)"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}