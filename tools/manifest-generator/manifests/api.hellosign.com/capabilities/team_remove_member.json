{
  "name": "team_remove_member",
  "description": "Remove a member from your team.",
  "endpoint": "/v3/team/remove_member",
  "method": "PUT",
  "resource_group": "team",
  "parameters": [
    {
      "name": "email_address",
      "type": "string",
      "description": "Email of member.",
      "required": false,
      "example": "member@example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.hellosign.com/v3/team/remove_member",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "member@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "team": {
        "name": "My Team"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
