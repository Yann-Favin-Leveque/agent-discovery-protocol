{
  "name": "team_create",
  "description": "Create a new team for your Dropbox Sign account.",
  "endpoint": "/v3/team/create",
  "method": "POST",
  "resource_group": "team",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Team name.",
      "required": true,
      "example": "Engineering",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hellosign.com/v3/team/create",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Engineering"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "team": {
        "name": "Engineering"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
