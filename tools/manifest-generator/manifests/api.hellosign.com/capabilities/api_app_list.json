{
  "name": "api_app_list",
  "description": "List all API apps associated with your account.",
  "endpoint": "/v3/api_app/list",
  "method": "GET",
  "resource_group": "api_app",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/api_app/list?page=1",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list_info": {
        "num_pages": 1,
        "page": 1
      },
      "api_apps": [
        {
          "client_id": "b6b8e7de",
          "name": "My App"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}