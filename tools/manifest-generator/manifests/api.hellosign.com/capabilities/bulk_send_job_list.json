{
  "name": "bulk_send_job_list",
  "description": "List all bulk send jobs for your account.",
  "endpoint": "/v3/bulk_send_job/list",
  "method": "GET",
  "resource_group": "bulk_send_job",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.hellosign.com/v3/bulk_send_job/list?page=1",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list_info": {
        "num_pages": 2,
        "page": 1
      },
      "bulk_send_jobs": [
        {
          "bulk_send_job_id": "6e683bc0",
          "total": 10
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
