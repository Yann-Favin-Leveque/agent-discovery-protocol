{
  "name": "signature_request_cancel",
  "description": "Cancel an incomplete signature request.",
  "endpoint": "/v3/signature_request/cancel/{signature_request_id}",
  "method": "POST",
  "resource_group": "signature_request",
  "parameters": [
    {
      "name": "signature_request_id",
      "type": "string",
      "description": "ID of the request to cancel.",
      "required": true,
      "example": "fa5c8a0b0f492d768749333ad6fcc214c111e967",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.hellosign.com/v3/signature_request/cancel/fa5c8a0b0f492d768749333ad6fcc214c111e967",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
