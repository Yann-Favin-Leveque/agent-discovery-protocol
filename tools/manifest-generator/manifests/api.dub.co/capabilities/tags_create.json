{
  "name": "tags_create",
  "description": "Create a new tag for organizing short links.",
  "endpoint": "/tags",
  "method": "POST",
  "resource_group": "tags",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "The tag name (1-50 chars).",
      "required": true,
      "example": "marketing",
      "in": "body"
    },
    {
      "name": "color",
      "type": "string",
      "description": "Tag color: red, yellow, green, blue, purple, brown, gray, pink.",
      "required": false,
      "example": "blue",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dub.co/tags",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "marketing",
      "color": "blue"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "tag_abc123",
      "name": "marketing",
      "color": "blue"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
