{
  "name": "tags_delete",
  "description": "Delete an existing tag from the workspace.",
  "endpoint": "/tags/{id}",
  "method": "DELETE",
  "resource_group": "tags",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The tag ID.",
      "required": true,
      "example": "tag_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dub.co/tags/tag_abc123",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tag_abc123"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
