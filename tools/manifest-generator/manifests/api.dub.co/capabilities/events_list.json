{
  "name": "events_list",
  "description": "Retrieve a list of click, lead, or sale events with detailed filtering by link, geography, device, and UTM parameters.",
  "endpoint": "/events",
  "method": "GET",
  "resource_group": "events",
  "parameters": [
    {
      "name": "event",
      "type": "string",
      "description": "Event type: clicks, leads, or sales.",
      "required": false,
      "example": "clicks",
      "in": "query"
    },
    {
      "name": "domain",
      "type": "string",
      "description": "Filter by domain.",
      "required": false,
      "in": "query"
    },
    {
      "name": "linkId",
      "type": "string",
      "description": "Filter by link ID.",
      "required": false,
      "in": "query"
    },
    {
      "name": "interval",
      "type": "string",
      "description": "Time interval: 24h, 7d, 30d, 90d, 1y, all.",
      "required": false,
      "example": "7d",
      "in": "query"
    },
    {
      "name": "country",
      "type": "string",
      "description": "Filter by 2-letter country code.",
      "required": false,
      "in": "query"
    },
    {
      "name": "page",
      "type": "number",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "number",
      "description": "Results per page (max 1000).",
      "required": false,
      "example": 100,
      "in": "query"
    },
    {
      "name": "sortOrder",
      "type": "string",
      "description": "Sort direction: asc or desc.",
      "required": false,
      "example": "desc",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dub.co/events?event=clicks&interval=7d&limit=100",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "event": "click",
        "timestamp": "2024-01-15T10:30:00.000Z",
        "click": {
          "id": "cl_abc123",
          "country": "US",
          "device": "Desktop",
          "browser": "Chrome"
        },
        "link": {
          "id": "clux0rgak0001",
          "domain": "dub.sh",
          "key": "my-link"
        }
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
