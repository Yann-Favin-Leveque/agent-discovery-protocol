{
  "name": "tags_update",
  "description": "Update an existing tag's name or color.",
  "endpoint": "/tags/{id}",
  "method": "PATCH",
  "resource_group": "tags",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The tag ID.",
      "required": true,
      "example": "tag_abc123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "New tag name.",
      "required": false,
      "example": "sales",
      "in": "body"
    },
    {
      "name": "color",
      "type": "string",
      "description": "New tag color.",
      "required": false,
      "example": "green",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.dub.co/tags/tag_abc123",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "sales",
      "color": "green"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tag_abc123",
      "name": "sales",
      "color": "green"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
