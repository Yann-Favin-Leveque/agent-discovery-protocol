{
  "name": "domains_delete",
  "description": "Remove a custom domain from the workspace.",
  "endpoint": "/domains/{slug}",
  "method": "DELETE",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "slug",
      "type": "string",
      "description": "The domain slug to delete.",
      "required": true,
      "example": "links.acme.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dub.co/domains/links.acme.com",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "slug": "links.acme.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
