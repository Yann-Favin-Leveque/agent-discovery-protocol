{
  "name": "tags_list",
  "description": "Retrieve a list of all tags in the workspace with optional search and pagination.",
  "endpoint": "/tags",
  "method": "GET",
  "resource_group": "tags",
  "parameters": [
    {
      "name": "sortBy",
      "type": "string",
      "description": "Sort field: name or createdAt.",
      "required": false,
      "example": "name"
    },
    {
      "name": "sortOrder",
      "type": "string",
      "description": "Sort direction: asc or desc.",
      "required": false,
      "example": "asc"
    },
    {
      "name": "search",
      "type": "string",
      "description": "Filter tags by search term.",
      "required": false
    },
    {
      "name": "page",
      "type": "number",
      "description": "Page number.",
      "required": false,
      "example": 1
    },
    {
      "name": "pageSize",
      "type": "number",
      "description": "Items per page (1-100).",
      "required": false,
      "example": 100
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.dub.co/tags",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "tag_abc123",
        "name": "marketing",
        "color": "blue"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}