{
  "name": "links_delete",
  "description": "Delete an existing short link by its link ID or external ID.",
  "endpoint": "/links/{linkId}",
  "method": "DELETE",
  "resource_group": "links",
  "parameters": [
    {
      "name": "linkId",
      "type": "string",
      "description": "The link ID or externalId prefixed with ext_.",
      "required": true,
      "example": "clux0rgak0001..."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.dub.co/links/clux0rgak0001",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "clux0rgak0001..."
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}