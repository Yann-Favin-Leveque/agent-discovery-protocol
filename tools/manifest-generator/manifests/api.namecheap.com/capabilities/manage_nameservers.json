{
  "name": "manage_nameservers",
  "description": "Get and set custom nameservers for a domain. Use this to point your domain to different DNS providers like Cloudflare, AWS Route53, etc.",
  "endpoint": "/xml.response",
  "method": "GET",
  "parameters": [
    { "name": "Command", "type": "string", "description": "Use 'namecheap.domains.dns.getList' to get or 'namecheap.domains.dns.setCustom' to set.", "required": true, "example": "namecheap.domains.dns.setCustom" },
    { "name": "SLD", "type": "string", "description": "Second-level domain.", "required": true, "example": "example" },
    { "name": "TLD", "type": "string", "description": "Top-level domain.", "required": true, "example": "com" },
    { "name": "NameServers", "type": "string", "description": "Comma-separated list of nameservers.", "required": true, "example": "ns1.cloudflare.com,ns2.cloudflare.com" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?ApiUser=myuser&ApiKey=abc123&UserName=myuser&ClientIp=1.2.3.4&Command=namecheap.domains.dns.setCustom&SLD=example&TLD=com&NameServers=ns1.cloudflare.com,ns2.cloudflare.com",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse><DomainDNSSetCustomResult Domain=\"example.com\" Updated=\"true\" /></CommandResponse></ApiResponse>"
  }
}
