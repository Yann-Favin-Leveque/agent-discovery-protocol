{
  "name": "domains_create",
  "description": "Register a new domain name with your Namecheap account.",
  "endpoint": "/xml.response?Command=namecheap.domains.create",
  "method": "GET",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser",
      "in": "query"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here",
      "in": "query"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser",
      "in": "query"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1",
      "in": "query"
    },
    {
      "name": "DomainName",
      "type": "string",
      "description": "Domain to register",
      "required": true,
      "example": "mynewdomain.com",
      "in": "query"
    },
    {
      "name": "Years",
      "type": "integer",
      "description": "Registration period in years",
      "required": true,
      "example": 1,
      "in": "query"
    },
    {
      "name": "RegistrantFirstName",
      "type": "string",
      "description": "Registrant first name",
      "required": true,
      "example": "John",
      "in": "query"
    },
    {
      "name": "RegistrantLastName",
      "type": "string",
      "description": "Registrant last name",
      "required": true,
      "example": "Doe",
      "in": "query"
    },
    {
      "name": "RegistrantEmailAddress",
      "type": "string",
      "description": "Registrant email",
      "required": true,
      "example": "john@example.com",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.domains.create&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}
