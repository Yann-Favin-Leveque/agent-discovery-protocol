{
  "name": "whoisguard_renew",
  "description": "Renew a WhoisGuard privacy protection subscription.",
  "endpoint": "/xml.response?Command=namecheap.whoisguard.renew",
  "method": "GET",
  "resource_group": "whoisguard",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1"
    },
    {
      "name": "WhoisguardID",
      "type": "integer",
      "description": "WhoisGuard subscription ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "Years",
      "type": "integer",
      "description": "Number of years to renew",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.whoisguard.renew&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}