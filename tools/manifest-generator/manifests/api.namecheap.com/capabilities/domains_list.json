{
  "name": "domains_list",
  "description": "List all domains in your Namecheap account with optional filtering and pagination.",
  "endpoint": "/xml.response?Command=namecheap.domains.getList",
  "method": "GET",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1"
    },
    {
      "name": "ListType",
      "type": "string",
      "description": "Filter type (ALL, EXPIRING, EXPIRED)",
      "required": false,
      "example": "ALL"
    },
    {
      "name": "Page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": 1
    },
    {
      "name": "PageSize",
      "type": "integer",
      "description": "Results per page (10-100)",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.domains.getList&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}