{
  "name": "dns_set_hosts",
  "description": "Set DNS host records for a domain. Replaces all existing records.",
  "endpoint": "/xml.response?Command=namecheap.domains.dns.setHosts",
  "method": "GET",
  "resource_group": "dns",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1"
    },
    {
      "name": "SLD",
      "type": "string",
      "description": "Second-level domain",
      "required": true,
      "example": "example"
    },
    {
      "name": "TLD",
      "type": "string",
      "description": "Top-level domain",
      "required": true,
      "example": "com"
    },
    {
      "name": "HostName1",
      "type": "string",
      "description": "First host name",
      "required": true,
      "example": "@"
    },
    {
      "name": "RecordType1",
      "type": "string",
      "description": "Record type (A, CNAME, MX, TXT)",
      "required": true,
      "example": "A"
    },
    {
      "name": "Address1",
      "type": "string",
      "description": "Record value",
      "required": true,
      "example": "192.0.2.1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.domains.dns.setHosts&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}