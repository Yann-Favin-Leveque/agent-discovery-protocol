{
  "name": "ssl_activate",
  "description": "Activate a purchased SSL certificate by submitting a CSR.",
  "endpoint": "/xml.response?Command=namecheap.ssl.activate",
  "method": "GET",
  "resource_group": "ssl",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser",
      "in": "query"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here",
      "in": "query"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser",
      "in": "query"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1",
      "in": "query"
    },
    {
      "name": "CertificateID",
      "type": "integer",
      "description": "SSL certificate ID",
      "required": true,
      "example": 12345,
      "in": "query"
    },
    {
      "name": "CSR",
      "type": "string",
      "description": "Certificate Signing Request",
      "required": true,
      "example": "-----BEGIN CERTIFICATE REQUEST-----...",
      "in": "query"
    },
    {
      "name": "AdminEmailAddress",
      "type": "string",
      "description": "Admin email for domain validation",
      "required": true,
      "example": "admin@example.com",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.ssl.activate&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}
