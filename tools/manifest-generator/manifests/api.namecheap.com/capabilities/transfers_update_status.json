{
  "name": "transfers_update_status",
  "description": "Update the status of a domain transfer.",
  "endpoint": "/xml.response?Command=namecheap.domains.transfer.updateStatus",
  "method": "GET",
  "resource_group": "transfers",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1"
    },
    {
      "name": "TransferID",
      "type": "integer",
      "description": "Transfer ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "Resubmit",
      "type": "boolean",
      "description": "Whether to resubmit the transfer",
      "required": true,
      "example": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.domains.transfer.updateStatus&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}