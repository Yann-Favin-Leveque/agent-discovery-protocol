{
  "name": "domains_set_contacts",
  "description": "Set contact information for a domain.",
  "endpoint": "/xml.response?Command=namecheap.domains.setContacts",
  "method": "GET",
  "resource_group": "domains",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1"
    },
    {
      "name": "DomainName",
      "type": "string",
      "description": "Domain name",
      "required": true,
      "example": "example.com"
    },
    {
      "name": "RegistrantFirstName",
      "type": "string",
      "description": "Registrant first name",
      "required": true,
      "example": "John"
    },
    {
      "name": "RegistrantLastName",
      "type": "string",
      "description": "Registrant last name",
      "required": true,
      "example": "Doe"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.domains.setContacts&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}