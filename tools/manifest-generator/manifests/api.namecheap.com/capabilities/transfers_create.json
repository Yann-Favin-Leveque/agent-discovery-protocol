{
  "name": "transfers_create",
  "description": "Transfer a domain from another registrar to Namecheap.",
  "endpoint": "/xml.response?Command=namecheap.domains.transfer.create",
  "method": "GET",
  "resource_group": "transfers",
  "parameters": [
    {
      "name": "ApiUser",
      "type": "string",
      "description": "API user account ID",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ApiKey",
      "type": "string",
      "description": "API key from Namecheap account",
      "required": true,
      "example": "api_key_here"
    },
    {
      "name": "UserName",
      "type": "string",
      "description": "Namecheap username",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "ClientIp",
      "type": "string",
      "description": "Whitelisted IP address of the client",
      "required": true,
      "example": "203.0.113.1"
    },
    {
      "name": "DomainName",
      "type": "string",
      "description": "Domain to transfer",
      "required": true,
      "example": "example.com"
    },
    {
      "name": "Years",
      "type": "integer",
      "description": "Years to add",
      "required": true,
      "example": 1
    },
    {
      "name": "EPPCode",
      "type": "string",
      "description": "Auth/EPP code from current registrar",
      "required": true,
      "example": "abc123epp"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.namecheap.com/xml.response?Command=namecheap.domains.transfer.create&ApiUser=myuser&ApiKey=api_key&UserName=myuser&ClientIp=203.0.113.1",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "<ApiResponse Status=\"OK\"><CommandResponse>...</CommandResponse></ApiResponse>"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 20
  }
}