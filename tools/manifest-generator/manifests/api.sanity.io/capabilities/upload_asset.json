{
  "name": "upload_asset",
  "description": "Upload images and files to the Sanity asset pipeline. Uploaded assets get an ID and URL that can be referenced from documents.",
  "endpoint": "/v2021-10-21/assets/images/{dataset}",
  "method": "POST",
  "parameters": [
    { "name": "dataset", "type": "string", "description": "The dataset name.", "required": true, "example": "production" },
    { "name": "filename", "type": "string", "description": "Original filename.", "required": false, "example": "hero.jpg" },
    { "name": "label", "type": "string", "description": "Label for the asset.", "required": false, "example": "Hero Image" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{project_id}.api.sanity.io/v2021-10-21/assets/images/production?filename=hero.jpg",
    "headers": { "Authorization": "Bearer {api_token}", "Content-Type": "image/jpeg" },
    "body": "<binary image data>"
  },
  "response_example": {
    "status": 200,
    "body": {
      "document": {
        "_id": "image-abc123-1920x1080-jpg",
        "_type": "sanity.imageAsset",
        "url": "https://cdn.sanity.io/images/project_id/production/abc123-1920x1080.jpg",
        "metadata": { "dimensions": { "width": 1920, "height": 1080 } }
      }
    }
  }
}
