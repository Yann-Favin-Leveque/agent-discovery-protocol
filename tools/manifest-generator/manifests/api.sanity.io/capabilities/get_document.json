{
  "name": "get_document",
  "description": "Retrieve one or more documents by their IDs. Returns the full document including all fields and metadata.",
  "endpoint": "/v2021-10-21/data/doc/{dataset}/{ids}",
  "method": "GET",
  "parameters": [
    { "name": "dataset", "type": "string", "description": "The dataset name.", "required": true, "example": "production" },
    { "name": "ids", "type": "string", "description": "Comma-separated document IDs.", "required": true, "example": "doc_xyz789" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{project_id}.api.sanity.io/v2021-10-21/data/doc/production/doc_xyz789",
    "headers": { "Authorization": "Bearer {api_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "documents": [
        { "_id": "doc_xyz789", "_type": "post", "_rev": "rev_abc", "title": "Hello World", "body": "Post content...", "_createdAt": "2024-01-15T10:00:00Z" }
      ]
    }
  }
}
