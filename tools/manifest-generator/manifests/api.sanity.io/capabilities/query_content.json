{
  "name": "query_content",
  "description": "Query content using GROQ (Graph-Relational Object Queries). GROQ is Sanity's powerful query language that lets you filter, project, and join content in expressive ways.",
  "endpoint": "/v2021-10-21/data/query/{dataset}",
  "method": "GET",
  "parameters": [
    { "name": "dataset", "type": "string", "description": "The dataset name.", "required": true, "example": "production" },
    { "name": "query", "type": "string", "description": "GROQ query string.", "required": true, "example": "*[_type == 'post']{title, slug, _createdAt}" },
    { "name": "$param", "type": "string", "description": "Query parameters (prefixed with $).", "required": false, "example": "\"my-post\"" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{project_id}.api.sanity.io/v2021-10-21/data/query/production?query=*[_type == 'post']{title, slug, _createdAt}",
    "headers": { "Authorization": "Bearer {api_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ms": 15,
      "query": "*[_type == 'post']{title, slug, _createdAt}",
      "result": [
        { "title": "Hello World", "slug": { "current": "hello-world" }, "_createdAt": "2024-01-15T10:00:00Z" }
      ]
    }
  }
}
