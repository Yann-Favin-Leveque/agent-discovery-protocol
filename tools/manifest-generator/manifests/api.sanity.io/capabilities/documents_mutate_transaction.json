{
  "name": "documents_mutate_transaction",
  "description": "Execute multiple mutations atomically in a single transaction. All succeed or all fail.",
  "endpoint": "/v{apiVersion}/data/mutate/{dataset}",
  "method": "POST",
  "resource_group": "mutations",
  "parameters": [
    {
      "name": "apiVersion",
      "type": "string",
      "description": "API version date string",
      "required": true,
      "example": "2024-01-01"
    },
    {
      "name": "dataset",
      "type": "string",
      "description": "Dataset name",
      "required": true,
      "example": "production"
    },
    {
      "name": "transactionId",
      "type": "string",
      "description": "Custom transaction ID for idempotency",
      "required": false,
      "example": "my-txn-123"
    },
    {
      "name": "dryRun",
      "type": "boolean",
      "description": "Test mutations without persisting",
      "required": false,
      "example": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{projectId}.api.sanity.io/v2024-01-01/data/mutate/production?returnIds=true",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "mutations": [
        {
          "create": {
            "_type": "post",
            "title": "Post A"
          }
        },
        {
          "create": {
            "_type": "post",
            "title": "Post B"
          }
        },
        {
          "patch": {
            "id": "config-1",
            "set": {
              "postCount": 42
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "transactionId": "txn-abc",
      "results": [
        {
          "id": "id1",
          "operation": "create"
        },
        {
          "id": "id2",
          "operation": "create"
        },
        {
          "id": "config-1",
          "operation": "update"
        }
      ]
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}