{
  "name": "documents_patch",
  "description": "Patch (partially update) an existing document using set, unset, inc, dec, or diffMatchPatch operations.",
  "endpoint": "/v{apiVersion}/data/mutate/{dataset}",
  "method": "POST",
  "resource_group": "mutations",
  "parameters": [
    {
      "name": "apiVersion",
      "type": "string",
      "description": "API version date string",
      "required": true,
      "example": "2024-01-01",
      "in": "path"
    },
    {
      "name": "dataset",
      "type": "string",
      "description": "Dataset name",
      "required": true,
      "example": "production",
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "Document ID to patch",
      "required": true,
      "example": "post-123",
      "in": "body"
    },
    {
      "name": "ifRevisionID",
      "type": "string",
      "description": "Only apply if document has this revision",
      "required": false,
      "example": "abc123",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{projectId}.api.sanity.io/v2024-01-01/data/mutate/production",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "mutations": [
        {
          "patch": {
            "id": "post-123",
            "set": {
              "title": "Updated Title"
            },
            "inc": {
              "viewCount": 1
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "transactionId": "jkl012",
      "results": [
        {
          "id": "post-123",
          "operation": "update"
        }
      ]
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 120
  }
}
