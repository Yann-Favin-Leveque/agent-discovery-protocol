{
  "name": "create_customer",
  "description": "Create a customer in the Braintree vault to securely store their payment methods for future charges. A vaulted customer can have multiple payment methods (credit cards, PayPal accounts, Venmo) and a designated default payment method. This is essential for recurring billing, one-click checkout, and returning customer experiences.",
  "endpoint": "/graphql",
  "method": "POST",
  "note": "Braintree uses a GraphQL API. The legacy REST API endpoint is POST /merchants/{merchant_id}/customers.",
  "parameters": [
    {
      "name": "first_name",
      "type": "string",
      "description": "Customer's first name.",
      "required": false,
      "example": "John"
    },
    {
      "name": "last_name",
      "type": "string",
      "description": "Customer's last name.",
      "required": false,
      "example": "Doe"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Customer's email address.",
      "required": false,
      "example": "john@example.com"
    },
    {
      "name": "phone",
      "type": "string",
      "description": "Customer's phone number.",
      "required": false,
      "example": "+1-555-123-4567"
    },
    {
      "name": "company",
      "type": "string",
      "description": "Customer's company name.",
      "required": false,
      "example": "Acme Inc"
    },
    {
      "name": "id",
      "type": "string",
      "description": "Your own customer ID. If not provided, Braintree generates one. Must be unique.",
      "required": false,
      "example": "cust_12345"
    },
    {
      "name": "payment_method_nonce",
      "type": "string",
      "description": "A nonce from the client SDK to vault as this customer's first payment method.",
      "required": false,
      "example": "tokencc_bf_f6bp8m_8q9jzs_7js5xy_b3xmg9_94g"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://payments.braintree-api.com/graphql",
    "headers": {
      "Authorization": "Basic cHVibGljX2tleTpwcml2YXRlX2tleQ==",
      "Content-Type": "application/json",
      "Braintree-Version": "2024-01-01"
    },
    "body": {
      "query": "mutation CreateCustomer($input: CreateCustomerInput!) { createCustomer(input: $input) { customer { id firstName lastName email } } }",
      "variables": {
        "input": {
          "customer": {
            "firstName": "John",
            "lastName": "Doe",
            "email": "john@example.com",
            "company": "Acme Inc",
            "phone": "+1-555-123-4567"
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "createCustomer": {
          "customer": {
            "id": "cust_12345",
            "firstName": "John",
            "lastName": "Doe",
            "email": "john@example.com",
            "company": "Acme Inc",
            "createdAt": "2024-02-01T12:00:00Z"
          }
        }
      },
      "extensions": {
        "requestId": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
      }
    }
  }
}
