{
  "name": "disputes_accept",
  "description": "Accept a dispute (chargeback), conceding the disputed amount to the customer.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "disputes",
  "parameters": [
    {"name": "disputeId", "type": "string", "description": "ID of the dispute to accept.", "required": true, "example": "ZGlzcHV0ZV8xMjM0NQ"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://payments.braintree-api.com/graphql",
    "headers": {"Authorization": "Basic {base64(public_key:private_key)}", "Content-Type": "application/json", "Braintree-Version": "2024-08-01"},
    "body": {"query": "mutation AcceptDispute($input: AcceptDisputeInput!) { acceptDispute(input: $input) { clientMutationId } }", "variables": {"input": {"disputeId": "ZGlzcHV0ZV8xMjM0NQ"}}}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"acceptDispute": {"clientMutationId": null}}}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 300}
}
