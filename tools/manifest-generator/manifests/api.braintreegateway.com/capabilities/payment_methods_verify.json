{
  "name": "payment_methods_verify",
  "description": "Verify a vaulted payment method by running a verification transaction to confirm it is valid.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "payment_methods",
  "parameters": [
    {
      "name": "paymentMethodId",
      "type": "string",
      "description": "ID of the payment method to verify.",
      "required": true,
      "example": "cGF5bWVudG1ldGhvZF8x",
      "in": "body"
    },
    {
      "name": "merchantAccountId",
      "type": "string",
      "description": "Merchant account for verification.",
      "required": false,
      "example": "my_merchant",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://payments.braintree-api.com/graphql",
    "headers": {
      "Authorization": "Basic {base64(public_key:private_key)}",
      "Content-Type": "application/json",
      "Braintree-Version": "2024-08-01"
    },
    "body": {
      "query": "mutation VerifyPaymentMethod($input: VerifyPaymentMethodInput!) { verifyPaymentMethod(input: $input) { verification { id status } } }",
      "variables": {
        "input": {
          "paymentMethodId": "cGF5bWVudG1ldGhvZF8x"
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "verifyPaymentMethod": {
          "verification": {
            "id": "dmVyaWZpY2F0aW9uXzE",
            "status": "VERIFIED"
          }
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
