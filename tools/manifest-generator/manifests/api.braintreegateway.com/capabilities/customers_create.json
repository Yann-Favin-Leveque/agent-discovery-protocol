{
  "name": "customers_create",
  "description": "Create a customer in the Braintree vault to store their payment methods for future charges.",
  "endpoint": "/graphql",
  "method": "POST",
  "resource_group": "customers",
  "parameters": [
    {"name": "firstName", "type": "string", "description": "Customer first name.", "required": false, "example": "John"},
    {"name": "lastName", "type": "string", "description": "Customer last name.", "required": false, "example": "Doe"},
    {"name": "email", "type": "string", "description": "Customer email.", "required": false, "example": "john@example.com"},
    {"name": "company", "type": "string", "description": "Customer company.", "required": false, "example": "Acme Inc"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://payments.braintree-api.com/graphql",
    "headers": {"Authorization": "Basic {base64(public_key:private_key)}", "Content-Type": "application/json", "Braintree-Version": "2024-08-01"},
    "body": {"query": "mutation CreateCustomer($input: CreateCustomerInput!) { createCustomer(input: $input) { customer { id firstName lastName email } } }", "variables": {"input": {"customer": {"firstName": "John", "lastName": "Doe", "email": "john@example.com"}}}}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"createCustomer": {"customer": {"id": "Y3VzdG9tZXJfMTIz", "firstName": "John", "lastName": "Doe", "email": "john@example.com"}}}}
  },
  "auth_scopes": [],
  "rate_limits": {"requests_per_minute": 300}
}
