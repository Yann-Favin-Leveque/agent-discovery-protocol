{
  "name": "users_add_properties",
  "description": "Set or update custom properties on a user profile for segmentation and analysis.",
  "endpoint": "/api/add_user_properties",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Your Heap environment ID.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "identity",
      "type": "string",
      "description": "User identity.",
      "required": true,
      "example": "john@example.com"
    },
    {
      "name": "properties",
      "type": "object",
      "description": "Custom properties to set on the user.",
      "required": true,
      "example": { "plan": "enterprise", "company": "Acme Corp", "role": "admin" }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://heapanalytics.com/api/add_user_properties",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "app_id": "123456789",
      "identity": "john@example.com",
      "properties": { "plan": "enterprise", "company": "Acme Corp", "role": "admin" }
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
