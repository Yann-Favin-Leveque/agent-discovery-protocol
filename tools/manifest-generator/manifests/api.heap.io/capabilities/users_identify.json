{
  "name": "users_identify",
  "description": "Assign a unique identity to a user server-side, merging anonymous and identified sessions.",
  "endpoint": "/api/identify",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Your Heap environment ID.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "identity",
      "type": "string",
      "description": "Unique user identifier (e.g., email, username). Must be under 255 characters.",
      "required": true,
      "example": "john@example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://heapanalytics.com/api/identify",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "app_id": "123456789",
      "identity": "john@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
