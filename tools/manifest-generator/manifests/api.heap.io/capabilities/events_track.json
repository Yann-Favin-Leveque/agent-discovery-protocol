{
  "name": "events_track",
  "description": "Send a custom server-side track event for a specific user to Heap analytics.",
  "endpoint": "/api/track",
  "method": "POST",
  "resource_group": "events",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Your Heap environment ID.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "identity",
      "type": "string",
      "description": "User identity (email or user ID).",
      "required": true,
      "example": "john@example.com"
    },
    {
      "name": "event",
      "type": "string",
      "description": "Event name.",
      "required": true,
      "example": "Complete Purchase"
    },
    {
      "name": "properties",
      "type": "object",
      "description": "Custom event properties.",
      "required": false,
      "example": { "plan": "enterprise", "amount": 99.99 }
    },
    {
      "name": "timestamp",
      "type": "string",
      "description": "ISO 8601 timestamp. Defaults to current time.",
      "required": false,
      "example": "2024-01-20T10:00:00Z"
    },
    {
      "name": "idempotency_key",
      "type": "string",
      "description": "Optional key to prevent duplicate events.",
      "required": false,
      "example": "evt_unique_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://heapanalytics.com/api/track",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "app_id": "123456789",
      "identity": "john@example.com",
      "event": "Complete Purchase",
      "properties": { "plan": "enterprise", "amount": 99.99 }
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
