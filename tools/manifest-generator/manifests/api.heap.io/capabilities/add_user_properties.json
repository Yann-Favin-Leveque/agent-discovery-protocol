{
  "name": "add_user_properties",
  "description": "Set or update custom properties on a user profile in Heap.",
  "endpoint": "/add_user_properties",
  "method": "POST",
  "parameters": [
    {"name": "app_id", "type": "string", "description": "Heap environment ID.", "required": true, "example": "123456789"},
    {"name": "identity", "type": "string", "description": "User identity.", "required": true, "example": "john@example.com"},
    {"name": "properties", "type": "object", "description": "Properties to set on the user.", "required": true, "example": {"plan": "enterprise", "company": "Acme Corp", "role": "admin"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://heapanalytics.com/api/add_user_properties",
    "headers": {"Content-Type": "application/json"},
    "body": {"app_id": "123456789", "identity": "john@example.com", "properties": {"plan": "enterprise", "company": "Acme Corp", "role": "admin"}}
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
