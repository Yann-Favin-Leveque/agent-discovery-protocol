{
  "name": "query_users",
  "description": "Query user data from Heap using the Connect API to analyze user segments and properties.",
  "endpoint": "/partner/v1/users",
  "method": "GET",
  "parameters": [
    {"name": "email", "type": "string", "description": "Filter by user email.", "required": false, "example": "john@example.com"},
    {"name": "user_id", "type": "string", "description": "Filter by user ID.", "required": false, "example": "user_123"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://heapanalytics.com/api/partner/v1/users?email=john@example.com",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"users": [{"identity": "john@example.com", "properties": {"plan": "enterprise", "company": "Acme Corp"}, "sessions_count": 42, "first_seen": "2024-01-01T00:00:00Z", "last_seen": "2024-01-20T10:00:00Z"}]}
  }
}
