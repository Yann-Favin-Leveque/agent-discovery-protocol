{
  "name": "users_delete",
  "description": "Delete users from your Heap workspace. Requires an auth token for authorization.",
  "endpoint": "/api/delete_users",
  "method": "POST",
  "resource_group": "users",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Your Heap environment ID.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "user_ids",
      "type": "array",
      "description": "Array of user identities to delete.",
      "required": true,
      "example": ["john@example.com", "jane@example.com"]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://heapanalytics.com/api/delete_users",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "app_id": "123456789",
      "user_ids": ["john@example.com", "jane@example.com"]
    }
  },
  "response_example": {
    "status": 200,
    "body": { "success": true }
  },
  "auth_scopes": ["delete"],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
