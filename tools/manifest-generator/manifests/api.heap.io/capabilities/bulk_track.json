{
  "name": "bulk_track",
  "description": "Send multiple events in a single batch request for efficient server-side tracking.",
  "endpoint": "/track",
  "method": "POST",
  "parameters": [
    {"name": "app_id", "type": "string", "description": "Heap environment ID.", "required": true, "example": "123456789"},
    {"name": "events", "type": "array", "description": "Array of event objects with identity and properties.", "required": true, "example": [{"identity": "user1@example.com", "event": "page_view", "properties": {"page": "/pricing"}}, {"identity": "user2@example.com", "event": "sign_up"}]}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://heapanalytics.com/api/track",
    "headers": {"Content-Type": "application/json"},
    "body": {"app_id": "123456789", "events": [{"identity": "user1@example.com", "event": "page_view", "properties": {"page": "/pricing"}}, {"identity": "user2@example.com", "event": "sign_up"}]}
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}
