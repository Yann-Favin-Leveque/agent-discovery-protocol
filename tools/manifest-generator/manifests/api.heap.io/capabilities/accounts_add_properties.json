{
  "name": "accounts_add_properties",
  "description": "Set properties on an account for B2B analytics grouping.",
  "endpoint": "/api/add_account_properties",
  "method": "POST",
  "resource_group": "accounts",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Your Heap environment ID.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "account_id",
      "type": "string",
      "description": "Unique account identifier.",
      "required": true,
      "example": "acme-corp"
    },
    {
      "name": "properties",
      "type": "object",
      "description": "Properties to set on the account.",
      "required": true,
      "example": { "name": "Acme Corp", "plan": "enterprise", "employee_count": 500 }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://heapanalytics.com/api/add_account_properties",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "app_id": "123456789",
      "account_id": "acme-corp",
      "properties": { "name": "Acme Corp", "plan": "enterprise", "employee_count": 500 }
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
