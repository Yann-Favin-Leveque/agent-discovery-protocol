{
  "name": "tracking_categories_list",
  "description": "Retrieve all tracking categories and options.",
  "resource_group": "tracking",
  "endpoint": "/TrackingCategories",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "accounting.settings.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/TrackingCategories",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TrackingCategories": [
        {
          "Name": "Region",
          "Options": [
            {
              "Name": "North"
            },
            {
              "Name": "South"
            }
          ]
        }
      ]
    }
  }
}