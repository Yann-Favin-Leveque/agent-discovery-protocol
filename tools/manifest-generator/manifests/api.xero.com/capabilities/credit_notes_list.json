{
  "name": "credit_notes_list",
  "description": "Retrieve all credit notes.",
  "resource_group": "credit_notes",
  "endpoint": "/CreditNotes",
  "method": "GET",
  "parameters": [
    {
      "name": "where",
      "type": "string",
      "required": false,
      "description": "Filter."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page."
    }
  ],
  "auth_scopes": [
    "accounting.transactions.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/CreditNotes",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "CreditNotes": [
        {
          "CreditNoteID": "cn-abc",
          "Total": 200.0,
          "Status": "AUTHORISED"
        }
      ]
    }
  }
}