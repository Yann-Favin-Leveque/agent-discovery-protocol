{
  "name": "contacts_get",
  "description": "Retrieve a specific contact by ID.",
  "resource_group": "contacts",
  "endpoint": "/Contacts/{ContactID}",
  "method": "GET",
  "parameters": [
    {
      "name": "ContactID",
      "type": "string",
      "required": true,
      "description": "The contact UUID."
    }
  ],
  "auth_scopes": [
    "accounting.contacts.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Contacts/contact-abc",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Contacts": [
        {
          "ContactID": "contact-abc",
          "Name": "Acme Corp"
        }
      ]
    }
  }
}