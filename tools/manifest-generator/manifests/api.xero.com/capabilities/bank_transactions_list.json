{
  "name": "bank_transactions_list",
  "description": "Retrieve bank transactions (spent/received money).",
  "resource_group": "bank_transactions",
  "endpoint": "/BankTransactions",
  "method": "GET",
  "parameters": [
    {
      "name": "where",
      "type": "string",
      "required": false,
      "description": "Filter.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "accounting.transactions.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/BankTransactions?page=1",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "BankTransactions": [
        {
          "BankTransactionID": "bt-abc",
          "Type": "SPEND",
          "Total": 250,
          "Date": "2024-08-15"
        }
      ]
    }
  }
}
