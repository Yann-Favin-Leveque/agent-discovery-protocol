{
  "name": "currencies_list",
  "description": "Retrieve all currencies used by the organization.",
  "resource_group": "currencies",
  "endpoint": "/Currencies",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "accounting.settings.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Currencies",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Currencies": [
        {
          "Code": "USD",
          "Description": "US Dollar"
        },
        {
          "Code": "EUR",
          "Description": "Euro"
        }
      ]
    }
  }
}