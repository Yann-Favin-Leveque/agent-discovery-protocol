{
  "name": "reports_balance_sheet",
  "description": "Generate a Balance Sheet report.",
  "resource_group": "reports",
  "endpoint": "/Reports/BalanceSheet",
  "method": "GET",
  "parameters": [
    {
      "name": "date",
      "type": "string",
      "required": false,
      "description": "Date YYYY-MM-DD."
    }
  ],
  "auth_scopes": [
    "accounting.reports.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Reports/BalanceSheet?date=2024-08-15",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Reports": [
        {
          "ReportName": "Balance Sheet"
        }
      ]
    }
  }
}