{
  "name": "items_list",
  "description": "Retrieve all items (products/services).",
  "resource_group": "items",
  "endpoint": "/Items",
  "method": "GET",
  "parameters": [
    {
      "name": "where",
      "type": "string",
      "required": false,
      "description": "Filter."
    }
  ],
  "auth_scopes": [
    "accounting.settings.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Items",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Items": [
        {
          "ItemID": "item-abc",
          "Code": "CONSULT",
          "Name": "Consulting",
          "SalesDetails": {
            "UnitPrice": 150.0
          }
        }
      ]
    }
  }
}