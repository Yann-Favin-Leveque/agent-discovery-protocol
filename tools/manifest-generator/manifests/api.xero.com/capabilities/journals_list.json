{
  "name": "journals_list",
  "description": "Retrieve journal entries.",
  "resource_group": "journals",
  "endpoint": "/Journals",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Offset for pagination."
    }
  ],
  "auth_scopes": [
    "accounting.journals.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Journals?offset=0",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Journals": [
        {
          "JournalID": "jnl-abc",
          "JournalDate": "2024-08-15",
          "JournalNumber": 1001
        }
      ]
    }
  }
}