{
  "name": "manual_journals_list",
  "description": "Retrieve all manual journal entries.",
  "resource_group": "manual_journals",
  "endpoint": "/ManualJournals",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "accounting.transactions.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/ManualJournals",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ManualJournals": [
        {
          "ManualJournalID": "mj-abc",
          "Narration": "Month-end adjustment",
          "Status": "POSTED"
        }
      ]
    }
  }
}
