{
  "name": "tax_rates_list",
  "description": "Retrieve all tax rates.",
  "resource_group": "tax_rates",
  "endpoint": "/TaxRates",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "accounting.settings.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/TaxRates",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TaxRates": [
        {
          "Name": "Sales Tax",
          "TaxType": "OUTPUT",
          "EffectiveRate": 10.0
        }
      ]
    }
  }
}