{
  "name": "accounts_list",
  "description": "Retrieve the chart of accounts.",
  "resource_group": "accounts",
  "endpoint": "/Accounts",
  "method": "GET",
  "parameters": [
    {
      "name": "where",
      "type": "string",
      "required": false,
      "description": "Filter."
    }
  ],
  "auth_scopes": [
    "accounting.settings.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Accounts",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Accounts": [
        {
          "AccountID": "acc-abc",
          "Code": "200",
          "Name": "Sales",
          "Type": "REVENUE"
        }
      ]
    }
  }
}