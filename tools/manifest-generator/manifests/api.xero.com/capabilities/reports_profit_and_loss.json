{
  "name": "reports_profit_and_loss",
  "description": "Generate a Profit and Loss report.",
  "resource_group": "reports",
  "endpoint": "/Reports/ProfitAndLoss",
  "method": "GET",
  "parameters": [
    {
      "name": "fromDate",
      "type": "string",
      "required": false,
      "description": "Start date YYYY-MM-DD.",
      "in": "query"
    },
    {
      "name": "toDate",
      "type": "string",
      "required": false,
      "description": "End date YYYY-MM-DD.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "accounting.reports.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Reports/ProfitAndLoss?fromDate=2024-01-01&toDate=2024-08-15",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Reports": [
        {
          "ReportName": "Profit and Loss",
          "Rows": [
            {
              "RowType": "Section",
              "Title": "Income"
            }
          ]
        }
      ]
    }
  }
}
