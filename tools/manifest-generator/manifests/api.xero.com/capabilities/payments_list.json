{
  "name": "payments_list",
  "description": "Retrieve all payments.",
  "resource_group": "payments",
  "endpoint": "/Payments",
  "method": "GET",
  "parameters": [
    {
      "name": "where",
      "type": "string",
      "required": false,
      "description": "Filter expression."
    }
  ],
  "auth_scopes": [
    "accounting.transactions.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/Payments",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Payments": [
        {
          "PaymentID": "pay-abc",
          "Amount": 1500.0,
          "Date": "2024-08-15",
          "Status": "AUTHORISED"
        }
      ]
    }
  }
}