{
  "name": "contacts_update",
  "description": "Update an existing contact.",
  "resource_group": "contacts",
  "endpoint": "/Contacts/{ContactID}",
  "method": "POST",
  "parameters": [
    {
      "name": "ContactID",
      "type": "string",
      "required": true,
      "description": "The contact UUID.",
      "in": "path"
    },
    {
      "name": "Contact",
      "type": "object",
      "required": true,
      "description": "Fields to update.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "accounting.contacts"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.xero.com/api.xro/2.0/Contacts/contact-abc",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID",
      "Content-Type": "application/json"
    },
    "body": {
      "EmailAddress": "new@acme.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Contacts": [
        {
          "ContactID": "contact-abc",
          "EmailAddress": "new@acme.com"
        }
      ]
    }
  }
}
