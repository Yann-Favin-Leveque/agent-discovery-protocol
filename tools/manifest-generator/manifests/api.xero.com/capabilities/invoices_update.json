{
  "name": "invoices_update",
  "description": "Update an existing invoice.",
  "resource_group": "invoices",
  "endpoint": "/Invoices/{InvoiceID}",
  "method": "POST",
  "parameters": [
    {
      "name": "InvoiceID",
      "type": "string",
      "required": true,
      "description": "The invoice UUID.",
      "in": "path"
    },
    {
      "name": "Invoice",
      "type": "object",
      "required": true,
      "description": "Fields to update.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "accounting.transactions"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.xero.com/api.xro/2.0/Invoices/abc-123",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID",
      "Content-Type": "application/json"
    },
    "body": {
      "Status": "AUTHORISED"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Invoices": [
        {
          "InvoiceID": "abc-123",
          "Status": "AUTHORISED"
        }
      ]
    }
  }
}
