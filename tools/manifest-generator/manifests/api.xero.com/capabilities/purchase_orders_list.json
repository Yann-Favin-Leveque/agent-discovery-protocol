{
  "name": "purchase_orders_list",
  "description": "Retrieve all purchase orders.",
  "resource_group": "purchase_orders",
  "endpoint": "/PurchaseOrders",
  "method": "GET",
  "parameters": [
    {
      "name": "Status",
      "type": "string",
      "required": false,
      "description": "Filter by status."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page."
    }
  ],
  "auth_scopes": [
    "accounting.transactions.read"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.xero.com/api.xro/2.0/PurchaseOrders?Status=AUTHORISED",
    "headers": {
      "Authorization": "Bearer ACCESS_TOKEN",
      "xero-tenant-id": "TENANT_ID"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "PurchaseOrders": [
        {
          "PurchaseOrderID": "po-abc",
          "Total": 5000.0,
          "Status": "AUTHORISED"
        }
      ]
    }
  }
}