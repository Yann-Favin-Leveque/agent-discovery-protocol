{
  "name": "data_sources_create",
  "description": "Create a new data source for importing billing data.",
  "endpoint": "/v1/data_sources",
  "method": "POST",
  "resource_group": "data_sources",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Name of the data source.",
      "required": true,
      "example": "Stripe Production"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.chartmogul.com/v1/data_sources",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Stripe Production"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "uuid": "ds_93b06efd-30f0-2153-890f-709a64cf8292",
      "name": "Stripe Production",
      "system": "Custom",
      "status": "idle",
      "created_at": "2024-01-01T00:00:00.000Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}