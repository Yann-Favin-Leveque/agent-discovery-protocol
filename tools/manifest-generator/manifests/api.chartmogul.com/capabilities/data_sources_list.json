{
  "name": "data_sources_list",
  "description": "Retrieve a list of all data sources.",
  "endpoint": "/v1/data_sources",
  "method": "GET",
  "resource_group": "data_sources",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Filter by source name.",
      "required": false
    },
    {
      "name": "system",
      "type": "string",
      "description": "Filter by system type (Stripe, Recurly, Custom).",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chartmogul.com/v1/data_sources",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data_sources": [
        {
          "uuid": "ds_93b06efd",
          "name": "Stripe Production",
          "system": "Stripe",
          "status": "idle"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}