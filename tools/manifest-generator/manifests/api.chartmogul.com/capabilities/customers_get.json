{
  "name": "customers_get",
  "description": "Retrieve a specific customer by UUID.",
  "endpoint": "/v1/customers/{customer_uuid}",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "customer_uuid",
      "type": "string",
      "description": "The customer UUID.",
      "required": true,
      "example": "cus_93b06efd-30f0-2153-890f-709a64cf8292",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chartmogul.com/v1/customers/cus_93b06efd",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uuid": "cus_93b06efd",
      "external_id": "cus_123",
      "name": "Acme Corp",
      "email": "billing@acme.com",
      "status": "Active",
      "mrr": 9900,
      "arr": 118800,
      "country": "US"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
