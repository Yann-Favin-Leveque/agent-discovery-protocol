{
  "name": "metrics_asp",
  "description": "Retrieve Average Sale Price (ASP) metrics.",
  "endpoint": "/v1/metrics/asp",
  "method": "GET",
  "resource_group": "metrics",
  "parameters": [
    {
      "name": "start-date",
      "type": "string",
      "description": "Start date (ISO-8601).",
      "required": true,
      "example": "2024-01-01",
      "in": "query"
    },
    {
      "name": "end-date",
      "type": "string",
      "description": "End date (ISO-8601).",
      "required": true,
      "example": "2024-12-31",
      "in": "query"
    },
    {
      "name": "interval",
      "type": "string",
      "description": "Grouping interval.",
      "required": false,
      "example": "month",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chartmogul.com/v1/metrics/asp?start-date=2024-01-01&end-date=2024-12-31",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entries": [
        {
          "date": "2024-01-31",
          "asp": 12000
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
