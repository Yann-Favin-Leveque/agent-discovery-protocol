{
  "name": "subscriptions_list",
  "description": "List all subscriptions for a customer.",
  "endpoint": "/v1/customers/{customer_uuid}/subscriptions",
  "method": "GET",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "customer_uuid",
      "type": "string",
      "description": "The customer UUID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 200,
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "description": "Pagination cursor.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chartmogul.com/v1/customers/cus_93b06efd/subscriptions",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entries": [
        {
          "uuid": "sub_93b06efd",
          "external_id": "sub_001",
