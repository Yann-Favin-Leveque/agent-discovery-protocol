{
  "name": "metrics_mrr",
  "description": "Retrieve Monthly Recurring Revenue (MRR) metrics for a date range.",
  "endpoint": "/v1/metrics/mrr",
  "method": "GET",
  "resource_group": "metrics",
  "parameters": [
    {
      "name": "start-date",
      "type": "string",
      "description": "Start date (ISO-8601, e.g. 2024-01-01).",
      "required": true,
      "example": "2024-01-01",
      "in": "query"
    },
    {
      "name": "end-date",
      "type": "string",
      "description": "End date (ISO-8601).",
      "required": true,
      "example": "2024-12-31",
      "in": "query"
    },
    {
      "name": "interval",
      "type": "string",
      "description": "Grouping interval: day, week, month, quarter, year.",
      "required": false,
      "example": "month",
      "in": "query"
    },
    {
      "name": "geo",
      "type": "string",
      "description": "Filter by country codes (comma-separated).",
      "required": false,
      "in": "query"
    },
    {
      "name": "plans",
      "type": "string",
      "description": "Filter by plan names or UUIDs (comma-separated).",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chartmogul.com/v1/metrics/mrr?start-date=2024-01-01&end-date=2024-12-31&interval=month",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entries": [
        {
          "date": "2024-01-31",
          "mrr": 950000,
          "mrr-new-business": 50000,
          "mrr-expansion": 10000,
          "mrr-contraction": -5000,
          "mrr-churn": -15000,
          "mrr-reactivation": 5000
        }
      ],
      "summary": {
        "current": 950000,
        "previous": 900000,
        "percentage-change": 5.6
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
