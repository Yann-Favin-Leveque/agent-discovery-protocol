{
  "name": "metrics_arr",
  "description": "Retrieve Annualized Run Rate (ARR) metrics for a date range.",
  "endpoint": "/v1/metrics/arr",
  "method": "GET",
  "resource_group": "metrics",
  "parameters": [
    {
      "name": "start-date",
      "type": "string",
      "description": "Start date (ISO-8601).",
      "required": true,
      "example": "2024-01-01"
    },
    {
      "name": "end-date",
      "type": "string",
      "description": "End date (ISO-8601).",
      "required": true,
      "example": "2024-12-31"
    },
    {
      "name": "interval",
      "type": "string",
      "description": "Grouping interval: day, week, month, quarter, year.",
      "required": false,
      "example": "month"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chartmogul.com/v1/metrics/arr?start-date=2024-01-01&end-date=2024-12-31&interval=month",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entries": [
        {
          "date": "2024-01-31",
          "arr": 11400000
        }
      ],
      "summary": {
        "current": 11400000,
        "previous": 10800000,
        "percentage-change": 5.6
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}