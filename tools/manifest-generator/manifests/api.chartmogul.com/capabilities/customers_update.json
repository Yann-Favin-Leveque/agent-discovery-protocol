{
  "name": "customers_update",
  "description": "Update customer attributes like name, email, company, or location.",
  "endpoint": "/v1/customers/{customer_uuid}",
  "method": "PATCH",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "customer_uuid",
      "type": "string",
      "description": "The customer UUID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated customer name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "description": "Updated email.",
      "required": false,
      "in": "body"
    },
    {
      "name": "company",
      "type": "string",
      "description": "Updated company name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "country",
      "type": "string",
      "description": "Updated country code.",
      "required": false,
      "in": "body"
    },
    {
      "name": "city",
      "type": "string",
      "description": "Updated city.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.chartmogul.com/v1/customers/cus_93b06efd",
    "headers": {
      "Authorization": "Basic {base64_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Acme Corporation",
      "city": "San Francisco"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uuid": "cus_93b06efd",
      "name": "Acme Corporation",
      "city": "San Francisco"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
