{
  "name": "metrics_all",
  "description": "Retrieve all key SaaS metrics (MRR, ARR, ARPA, ASP, customer count, churn, LTV) in a single request.",
  "endpoint": "/v1/metrics/all",
  "method": "GET",
  "resource_group": "metrics",
  "parameters": [
    {
      "name": "start-date",
      "type": "string",
      "description": "Start date (ISO-8601).",
      "required": true,
      "example": "2024-01-01"
    },
    {
      "name": "end-date",
      "type": "string",
      "description": "End date (ISO-8601).",
      "required": true,
      "example": "2024-12-31"
    },
    {
      "name": "interval",
      "type": "string",
      "description": "Grouping interval: day, week, month, quarter, year.",
      "required": false,
      "example": "month"
    },
    {
      "name": "geo",
      "type": "string",
      "description": "Filter by country codes.",
      "required": false
    },
    {
      "name": "plans",
      "type": "string",
      "description": "Filter by plans.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.chartmogul.com/v1/metrics/all?start-date=2024-01-01&end-date=2024-12-31&interval=month",
    "headers": {
      "Authorization": "Basic {base64_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entries": [
        {
          "date": "2024-01-31",
          "mrr": 950000,
          "arr": 11400000,
          "arpa": 9500,
          "asp": 12000,
          "customers": 150,
          "customer-churn-rate": 2.5,
          "mrr-churn-rate": 1.8,
          "ltv": 285000
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}