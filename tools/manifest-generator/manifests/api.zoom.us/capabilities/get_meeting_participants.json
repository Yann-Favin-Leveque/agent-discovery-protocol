{
  "name": "get_meeting_participants",
  "description": "Get a list of participants who joined a past meeting. Returns participant names, emails, join times, leave times, duration spent in the meeting, and client version information.",
  "endpoint": "/past_meetings/{meetingId}/participants",
  "method": "GET",
  "parameters": [
    {
      "name": "meetingId",
      "type": "string",
      "description": "The meeting ID (numeric or UUID) of a past meeting.",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Number of participants to return per page (1-300, default 30).",
      "required": false,
      "example": 30
    },
    {
      "name": "next_page_token",
      "type": "string",
      "description": "Pagination token from previous response for retrieving next page of results.",
      "required": false,
      "example": "IUlQa3SnfLVYYEk5yzDOjQ7W0zv8ZpXHmQKwwgxowmU="
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.zoom.us/v2/past_meetings/123456789/participants?page_size=30",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "page_count": 1,
      "page_number": 1,
      "page_size": 30,
      "total_records": 2,
      "next_page_token": "IUlQa3SnfLVYYEk5yzDOjQ7W0zv8ZpXHmQKwwgxowmU=",
      "participants": [
        {
          "id": "participant123",
          "name": "John Smith",
          "email": "john.smith@company.com",
          "user_id": "user123",
          "join_time": "2026-03-15T10:05:30Z",
          "leave_time": "2026-03-15T10:45:30Z",
          "duration": 40,
          "client_version": "5.14.5",
          "status": "left"
        },
        {
          "id": "participant124",
          "name": "Jane Doe",
          "email": "jane.doe@company.com",
          "user_id": "user124",
          "join_time": "2026-03-15T10:08:00Z",
          "leave_time": "2026-03-15T10:50:00Z",
          "duration": 42,
          "client_version": "5.14.5",
          "status": "left"
        }
      ]
    }
  }
}
