{
  "name": "get_meeting",
  "description": "Get detailed information about a specific meeting including topic, description, start time, duration, timezone, settings, join URL, and password. Optionally retrieve meeting statistics.",
  "endpoint": "/meetings/{meetingId}",
  "method": "GET",
  "parameters": [
    {
      "name": "meetingId",
      "type": "string",
      "description": "The meeting ID (numeric or UUID).",
      "required": true,
      "example": "123456789"
    },
    {
      "name": "occurrence_id",
      "type": "string",
      "description": "Occurrence ID for a recurring meeting instance.",
      "required": false,
      "example": "1614556800000"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.zoom.us/v2/meetings/123456789",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uuid": "gH5sRpzfQrOo58gH5sRpzf==",
      "id": 123456789,
      "host_id": "aBcDeF1234",
      "host_email": "user@company.com",
      "topic": "Q1 Planning Meeting",
      "type": 2,
      "description": "Quarterly planning and goal setting session",
      "start_time": "2026-03-15T10:00:00",
      "duration": 60,
      "timezone": "America/New_York",
      "created_at": "2026-03-01T12:00:00Z",
      "start_url": "https://us06web.zoom.us/s/123456789?zak=xxx",
      "join_url": "https://us06web.zoom.us/j/123456789?pwd=Meeting123",
      "password": "Meeting123",
      "pstn_password": "123456",
      "h323_password": "123456",
      "settings": {
        "host_video": true,
        "participant_video": true,
        "join_before_host": false,
        "waiting_room": true,
        "mute_upon_entry": true,
        "meeting_authentication": false,
        "encryption_type": "enhanced",
        "allow_multiple_devices": true
      }
    }
  }
}
