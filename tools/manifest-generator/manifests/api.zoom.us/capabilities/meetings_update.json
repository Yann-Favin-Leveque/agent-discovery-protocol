{
  "name": "meetings_update",
  "description": "Update an existing meeting's details such as topic, start time, duration, timezone, and settings. Useful for rescheduling or changing meeting configuration.",
  "endpoint": "/meetings/{meetingId}",
  "method": "PATCH",
  "resource_group": "meetings",
  "parameters": [
    {
      "name": "meetingId",
      "type": "integer",
      "description": "The meeting ID to update.",
      "required": true,
      "example": 1234567890,
      "in": "path"
    },
    {
      "name": "occurrence_id",
      "type": "string",
      "description": "Occurrence ID for updating a specific recurring meeting instance.",
      "required": false,
      "example": "",
      "in": "body"
    },
    {
      "name": "topic",
      "type": "string",
      "description": "Updated meeting topic.",
      "required": false,
      "example": "Updated Team Sync",
      "in": "body"
    },
    {
      "name": "start_time",
      "type": "string",
      "description": "Updated start time in ISO 8601 format.",
      "required": false,
      "example": "2024-01-16T10:00:00Z",
      "in": "body"
    },
    {
      "name": "duration",
      "type": "integer",
      "description": "Updated duration in minutes.",
      "required": false,
      "example": 45,
      "in": "body"
    },
    {
      "name": "settings",
      "type": "object",
      "description": "Updated meeting settings object.",
      "required": false,
      "example": {
        "waiting_room": false
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.zoom.us/v2/meetings/1234567890",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "topic": "Updated Team Sync",
      "start_time": "2024-01-16T10:00:00Z",
      "duration": 45
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "meeting:write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
