{
  "name": "list_meetings",
  "description": "Retrieve all scheduled meetings for a user. Supports pagination with page size and cursor options. Returns meeting IDs, topics, start times, durations, types, and status for each meeting.",
  "endpoint": "/users/{userId}/meetings",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user ID or email address of the meeting host. Use 'me' to refer to the authenticated user.",
      "required": true,
      "example": "me"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Meeting type to filter: 'scheduled', 'live', 'upcoming', or 'all'.",
      "required": false,
      "example": "upcoming"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Number of meetings to return per page (1-300, default 30).",
      "required": false,
      "example": 30
    },
    {
      "name": "next_page_token",
      "type": "string",
      "description": "Pagination token from previous response for retrieving next page of results.",
      "required": false,
      "example": "IUlQa3SnfLVYYEk5yzDOjQ7W0zv8ZpXHmQKwwgxowmU="
    },
    {
      "name": "from",
      "type": "string",
      "description": "Start date for filtering meetings (YYYY-MM-DD format).",
      "required": false,
      "example": "2026-03-01"
    },
    {
      "name": "to",
      "type": "string",
      "description": "End date for filtering meetings (YYYY-MM-DD format).",
      "required": false,
      "example": "2026-03-31"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.zoom.us/v2/users/me/meetings?type=upcoming&page_size=30",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_records": 2,
      "page_count": 1,
      "page_number": 1,
      "page_size": 30,
      "next_page_token": "IUlQa3SnfLVYYEk5yzDOjQ7W0zv8ZpXHmQKwwgxowmU=",
      "meetings": [
        {
          "uuid": "gH5sRpzfQrOo58gH5sRpzf==",
          "id": 123456789,
          "host_id": "aBcDeF1234",
          "topic": "Q1 Planning Meeting",
          "type": 2,
          "start_time": "2026-03-15T10:00:00",
          "duration": 60,
          "timezone": "America/New_York",
          "created_at": "2026-03-01T12:00:00Z",
          "join_url": "https://us06web.zoom.us/j/123456789"
        },
        {
          "uuid": "sRpzfQrOo58gH5sRpzfQr==",
          "id": 987654321,
          "host_id": "aBcDeF1234",
          "topic": "Team Sync",
          "type": 2,
          "start_time": "2026-03-20T14:00:00",
          "duration": 30,
          "timezone": "America/New_York",
          "created_at": "2026-03-01T13:00:00Z",
          "join_url": "https://us06web.zoom.us/j/987654321"
        }
      ]
    }
  }
}
