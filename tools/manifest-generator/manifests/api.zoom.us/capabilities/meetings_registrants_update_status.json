{
  "name": "meetings_registrants_update_status",
  "description": "Approve, deny, or cancel registration for meeting registrants. Supports batch updates for multiple registrants.",
  "endpoint": "/meetings/{meetingId}/registrants/status",
  "method": "PUT",
  "resource_group": "meetings",
  "parameters": [
    {
      "name": "meetingId",
      "type": "integer",
      "description": "The meeting ID.",
      "required": true,
      "example": 1234567890
    },
    {
      "name": "action",
      "type": "string",
      "description": "The registration status action: approve, deny, or cancel.",
      "required": true,
      "example": "approve"
    },
    {
      "name": "registrants",
      "type": "array",
      "description": "Array of registrant objects with id and email to update.",
      "required": true,
      "example": [{"id": "reg123", "email": "jane@example.com"}]
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.zoom.us/v2/meetings/1234567890/registrants/status",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "action": "approve",
      "registrants": [{"id": "reg123", "email": "jane@example.com"}]
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": ["meeting:write"],
  "rate_limits": {
    "requests_per_minute": 100
  }
}