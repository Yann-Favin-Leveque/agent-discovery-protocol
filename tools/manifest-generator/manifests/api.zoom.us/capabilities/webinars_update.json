{
  "name": "webinars_update",
  "description": "Update an existing webinar's details including topic, schedule, duration, and settings.",
  "endpoint": "/webinars/{webinarId}",
  "method": "PATCH",
  "resource_group": "webinars",
  "parameters": [
    {
      "name": "webinarId",
      "type": "integer",
      "description": "The webinar ID to update.",
      "required": true,
      "example": 9876543210,
      "in": "path"
    },
    {
      "name": "topic",
      "type": "string",
      "description": "Updated webinar topic.",
      "required": false,
      "example": "Updated Product Launch",
      "in": "body"
    },
    {
      "name": "start_time",
      "type": "string",
      "description": "Updated start time in ISO 8601.",
      "required": false,
      "example": "2024-02-02T14:00:00Z",
      "in": "body"
    },
    {
      "name": "duration",
      "type": "integer",
      "description": "Updated duration in minutes.",
      "required": false,
      "example": 120,
      "in": "body"
    },
    {
      "name": "settings",
      "type": "object",
      "description": "Updated webinar settings.",
      "required": false,
      "example": {
        "auto_recording": "none"
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.zoom.us/v2/webinars/9876543210",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "topic": "Updated Product Launch",
      "duration": 120
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "webinar:write"
  ],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
