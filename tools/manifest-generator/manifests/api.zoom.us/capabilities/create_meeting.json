{
  "name": "create_meeting",
  "description": "Schedule a new Zoom meeting for a user. Specify the meeting topic, description, start time, duration, timezone, and optional settings like password protection, waiting room, and participant restrictions. Returns the newly created meeting ID and join URL.",
  "endpoint": "/users/{userId}/meetings",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user ID or email address of the meeting host. Use 'me' to refer to the authenticated user.",
      "required": true,
      "example": "me"
    },
    {
      "name": "topic",
      "type": "string",
      "description": "Meeting topic or title.",
      "required": true,
      "example": "Q1 Planning Meeting"
    },
    {
      "name": "type",
      "type": "integer",
      "description": "Meeting type: 1 (Instant), 2 (Scheduled), 3 (Recurring), 8 (Recurring No Fixed Time).",
      "required": true,
      "example": 2
    },
    {
      "name": "start_time",
      "type": "string",
      "description": "Meeting start time in ISO 8601 format (YYYY-MM-DDTHH:mm:ss).",
      "required": false,
      "example": "2026-03-15T10:00:00"
    },
    {
      "name": "duration",
      "type": "integer",
      "description": "Meeting duration in minutes.",
      "required": false,
      "example": 60
    },
    {
      "name": "timezone",
      "type": "string",
      "description": "Timezone for the meeting in IANA timezone format.",
      "required": false,
      "example": "America/New_York"
    },
    {
      "name": "password",
      "type": "string",
      "description": "Meeting password (6-15 alphanumeric characters).",
      "required": false,
      "example": "Meeting123"
    },
    {
      "name": "settings",
      "type": "object",
      "description": "Optional meeting settings object (waiting_room, join_before_host, host_video, participant_video, mute_upon_entry, etc.).",
      "required": false,
      "example": {
        "waiting_room": true,
        "join_before_host": false,
        "host_video": true,
        "participant_video": true,
        "mute_upon_entry": true
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.zoom.us/v2/users/me/meetings",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "topic": "Q1 Planning Meeting",
      "type": 2,
      "start_time": "2026-03-15T10:00:00",
      "duration": 60,
      "timezone": "America/New_York",
      "password": "Meeting123",
      "settings": {
        "waiting_room": true,
        "join_before_host": false,
        "host_video": true,
        "participant_video": true,
        "mute_upon_entry": true
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "uuid": "gH5sRpzfQrOo58gH5sRpzf==",
      "id": 123456789,
      "host_id": "aBcDeF1234",
      "topic": "Q1 Planning Meeting",
      "type": 2,
      "start_time": "2026-03-15T10:00:00",
      "duration": 60,
      "timezone": "America/New_York",
      "created_at": "2026-03-01T12:00:00Z",
      "join_url": "https://us06web.zoom.us/j/123456789?pwd=Meeting123"
    }
  }
}
