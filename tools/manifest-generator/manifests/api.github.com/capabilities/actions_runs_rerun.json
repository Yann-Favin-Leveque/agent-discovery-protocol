{
  "name": "actions_runs_rerun",
  "description": "Re-run a workflow run.",
  "resource_group": "actions",
  "endpoint": "/repos/{owner}/{repo}/actions/runs/{run_id}/rerun",
  "method": "POST",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner."
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name."
    },
    {
      "name": "run_id",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "The workflow run ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.github.com/repos/octocat/my-project/actions/runs/100/rerun",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 201,
    "body": null
  }
}