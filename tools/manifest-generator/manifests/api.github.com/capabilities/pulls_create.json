{
  "name": "pulls_create",
  "description": "Create a new pull request.",
  "resource_group": "pull_requests",
  "endpoint": "/repos/{owner}/{repo}/pulls",
  "method": "POST",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner.",
      "in": "path"
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name.",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "PR title.",
      "in": "body"
    },
    {
      "name": "head",
      "type": "string",
      "required": true,
      "description": "Source branch (or user:branch for cross-repo).",
      "in": "body"
    },
    {
      "name": "base",
      "type": "string",
      "required": true,
      "description": "Target branch to merge into.",
      "in": "body"
    },
    {
      "name": "body",
      "type": "string",
      "required": false,
      "description": "PR description (Markdown).",
      "in": "body"
    },
    {
      "name": "draft",
      "type": "boolean",
      "required": false,
      "description": "Create as draft PR. Default false.",
      "in": "body"
    },
    {
      "name": "maintainer_can_modify",
      "type": "boolean",
      "required": false,
      "description": "Allow maintainers to push to head branch.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.github.com/repos/octocat/my-project/pulls",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    },
    "body": {
      "title": "Add dark mode support",
      "head": "feature/dark-mode",
      "base": "main",
      "body": "## Summary\\nImplements dark mode theme.\\n\\n## Changes\\n- Added CSS variables\\n- Theme toggle component",
      "draft": false
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "number": 101,
      "title": "Add dark mode support",
      "state": "open",
      "html_url": "https://github.com/octocat/my-project/pull/101"
    }
  }
}
