{
  "name": "actions_workflows_list",
  "description": "List all workflows in a repository.",
  "resource_group": "actions",
  "endpoint": "/repos/{owner}/{repo}/actions/workflows",
  "method": "GET",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner."
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/repos/octocat/my-project/actions/workflows",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 2,
      "workflows": [
        {
          "id": 1,
          "name": "CI",
          "path": ".github/workflows/ci.yml",
          "state": "active",
          "created_at": "2026-01-01T00:00:00Z"
        }
      ]
    }
  }
}