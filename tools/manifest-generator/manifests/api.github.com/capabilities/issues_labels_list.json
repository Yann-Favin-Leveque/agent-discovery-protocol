{
  "name": "issues_labels_list",
  "description": "List labels for a repository.",
  "resource_group": "issues",
  "endpoint": "/repos/{owner}/{repo}/labels",
  "method": "GET",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner.",
      "in": "path"
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name.",
      "in": "path"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/repos/octocat/my-project/labels",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "name": "bug",
        "color": "d73a4a",
        "description": "Something is broken"
      },
      {
        "id": 2,
        "name": "enhancement",
        "color": "a2eeef",
        "description": "New feature or improvement"
      }
    ]
  }
}
