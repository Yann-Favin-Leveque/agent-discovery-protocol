{
  "name": "orgs_get",
  "description": "Get detailed information about an organization.",
  "resource_group": "organizations",
  "endpoint": "/orgs/{org}",
  "method": "GET",
  "parameters": [
    {
      "name": "org",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Organization name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/orgs/my-org",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "login": "my-org",
      "id": 100,
      "name": "My Organization",
      "description": "We build cool stuff",
      "public_repos": 25,
      "total_private_repos": 10,
      "members_count": 15
    }
  }
}
