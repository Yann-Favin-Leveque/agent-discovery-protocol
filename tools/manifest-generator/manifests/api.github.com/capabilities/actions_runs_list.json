{
  "name": "actions_runs_list",
  "description": "List workflow runs for a repository with optional filtering by workflow, branch, or status.",
  "resource_group": "actions",
  "endpoint": "/repos/{owner}/{repo}/actions/runs",
  "method": "GET",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner."
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter: completed, action_required, cancelled, failure, neutral, skipped, stale, success, timed_out, in_progress, queued, requested, waiting, pending."
    },
    {
      "name": "branch",
      "type": "string",
      "required": false,
      "description": "Filter by branch name."
    },
    {
      "name": "event",
      "type": "string",
      "required": false,
      "description": "Filter by event type (push, pull_request, etc.)."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/repos/octocat/my-project/actions/runs?status=failure&per_page=5",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 3,
      "workflow_runs": [
        {
          "id": 100,
          "name": "CI",
          "status": "completed",
          "conclusion": "failure",
          "head_branch": "main",
          "event": "push",
          "created_at": "2026-02-28T10:00:00Z",
          "html_url": "https://github.com/octocat/my-project/actions/runs/100"
        }
      ]
    }
  }
}