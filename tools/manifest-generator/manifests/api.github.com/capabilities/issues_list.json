{
  "name": "issues_list",
  "description": "List issues for a repository with optional filtering by state, labels, assignee, and milestone.",
  "resource_group": "issues",
  "endpoint": "/repos/{owner}/{repo}/issues",
  "method": "GET",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner.",
      "in": "path"
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name.",
      "in": "path"
    },
    {
      "name": "state",
      "type": "string",
      "required": false,
      "description": "Filter: open, closed, all. Default open.",
      "in": "query"
    },
    {
      "name": "labels",
      "type": "string",
      "required": false,
      "description": "Comma-separated label names.",
      "in": "query"
    },
    {
      "name": "assignee",
      "type": "string",
      "required": false,
      "description": "Filter by assignee username, 'none', or '*'.",
      "in": "query"
    },
    {
      "name": "milestone",
      "type": "string",
      "required": false,
      "description": "Milestone number, 'none', or '*'.",
      "in": "query"
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort by: created, updated, comments. Default created.",
      "in": "query"
    },
    {
      "name": "direction",
      "type": "string",
      "required": false,
      "description": "asc or desc.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page (max 100).",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/repos/octocat/my-project/issues?state=open&labels=bug&per_page=10",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 1,
        "number": 42,
        "title": "Login page crashes on mobile",
        "state": "open",
        "labels": [
          {
            "name": "bug",
            "color": "d73a4a"
          }
        ],
        "assignee": {
          "login": "octocat"
        },
        "created_at": "2026-02-28T10:00:00Z",
        "comments": 3
      }
    ]
  }
}
