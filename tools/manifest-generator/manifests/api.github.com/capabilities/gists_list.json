{
  "name": "gists_list",
  "description": "List gists for the authenticated user.",
  "resource_group": "gists",
  "endpoint": "/gists",
  "method": "GET",
  "parameters": [
    {
      "name": "since",
      "type": "string",
      "required": false,
      "description": "Only gists updated after this time (ISO 8601)."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/gists?per_page=10",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "aa5a315d61ae9438b18d",
        "description": "Hello World example",
        "public": true,
        "files": {
          "hello.py": {
            "filename": "hello.py",
            "language": "Python",
            "size": 28
          }
        },
        "created_at": "2026-02-28T10:00:00Z"
      }
    ]
  }
}