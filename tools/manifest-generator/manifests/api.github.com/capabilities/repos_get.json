{
  "name": "repos_get",
  "description": "Get detailed information about a specific repository.",
  "resource_group": "repositories",
  "endpoint": "/repos/{owner}/{repo}",
  "method": "GET",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner (user or org)."
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/repos/octocat/my-project",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 123456,
      "name": "my-project",
      "full_name": "octocat/my-project",
      "private": false,
      "description": "A sample project",
      "default_branch": "main",
      "stargazers_count": 42,
      "forks_count": 5,
      "open_issues_count": 3,
      "language": "TypeScript",
      "license": {
        "key": "mit",
        "name": "MIT License"
      }
    }
  }
}