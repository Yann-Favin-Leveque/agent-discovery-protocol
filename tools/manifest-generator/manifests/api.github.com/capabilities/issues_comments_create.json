{
  "name": "issues_comments_create",
  "description": "Create a comment on an issue.",
  "resource_group": "issues",
  "endpoint": "/repos/{owner}/{repo}/issues/{issue_number}/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner."
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name."
    },
    {
      "name": "issue_number",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "The issue number."
    },
    {
      "name": "body",
      "type": "string",
      "required": true,
      "description": "Comment body (Markdown)."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.github.com/repos/octocat/my-project/issues/42/comments",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    },
    "body": {
      "body": "Fixed in commit abc123. Closing this issue."
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 1002,
      "body": "Fixed in commit abc123. Closing this issue.",
      "user": {
        "login": "octocat"
      },
      "created_at": "2026-03-01T09:00:00Z"
    }
  }
}