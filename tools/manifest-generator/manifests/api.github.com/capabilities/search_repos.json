{
  "name": "search_repos",
  "description": "Search for repositories by keywords, language, stars, and other criteria.",
  "resource_group": "search",
  "endpoint": "/search/repositories",
  "method": "GET",
  "parameters": [
    {
      "name": "q",
      "type": "string",
      "required": true,
      "description": "Search query using GitHub search syntax (e.g., 'machine learning language:python stars:>1000')."
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort by: stars, forks, help-wanted-issues, updated. Default: best match."
    },
    {
      "name": "order",
      "type": "string",
      "required": false,
      "description": "asc or desc. Default desc."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page (max 100)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/search/repositories?q=machine+learning+language:python+stars:>1000&sort=stars&per_page=5",
    "headers": {
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 5432,
      "items": [
        {
          "full_name": "tensorflow/tensorflow",
          "description": "Open Source ML Framework",
          "stargazers_count": 180000,
          "language": "Python",
          "html_url": "https://github.com/tensorflow/tensorflow"
        }
      ]
    }
  }
}