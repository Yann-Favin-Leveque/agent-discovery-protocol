{
  "name": "credentials",
  "description": "Manage credentials — revoke a list of credentials. Supports standard CRUD operations through the REST API.",
  "endpoint": "/credentials/revoke",
  "method": "POST",
  "parameters": [
    {
      "name": "credentials",
      "type": "string[]",
      "description": "A list of credentials to be revoked, up to 1000 per request.",
      "required": true,
      "example": [
        "value1"
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.github.com/credentials/revoke",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "credentials": [
        "value1"
      ]
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "credentials": [
          "value1"
        ]
      }
    }
  }
}
