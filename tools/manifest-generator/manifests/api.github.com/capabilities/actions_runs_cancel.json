{
  "name": "actions_runs_cancel",
  "description": "Cancel a workflow run that is in progress or queued.",
  "resource_group": "actions",
  "endpoint": "/repos/{owner}/{repo}/actions/runs/{run_id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner.",
      "in": "path"
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name.",
      "in": "path"
    },
    {
      "name": "run_id",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "The workflow run ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.github.com/repos/octocat/my-project/actions/runs/100/cancel",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 202,
    "body": null
  }
}
