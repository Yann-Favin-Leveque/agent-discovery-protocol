{
  "name": "users_get",
  "description": "Get a user's public profile by username.",
  "resource_group": "users",
  "endpoint": "/users/{username}",
  "method": "GET",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The GitHub username.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/users/octocat",
    "headers": {
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "login": "octocat",
      "id": 1,
      "name": "The Octocat",
      "bio": "A sample user",
      "public_repos": 42,
      "followers": 1000
    }
  }
}
