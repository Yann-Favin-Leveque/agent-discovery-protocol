{
  "name": "search_issues",
  "description": "Search for issues and pull requests across all repositories.",
  "resource_group": "search",
  "endpoint": "/search/issues",
  "method": "GET",
  "parameters": [
    {
      "name": "q",
      "type": "string",
      "required": true,
      "description": "Search query (e.g., 'bug label:bug state:open repo:octocat/my-project').",
      "in": "query"
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort by: comments, reactions, interactions, created, updated.",
      "in": "query"
    },
    {
      "name": "order",
      "type": "string",
      "required": false,
      "description": "asc or desc.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.github.com/search/issues?q=memory+leak+label:bug+state:open&sort=created&per_page=10",
    "headers": {
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 234,
      "items": [
        {
          "number": 42,
          "title": "Memory leak in parser",
          "state": "open",
          "repository_url": "https://api.github.com/repos/octocat/my-project",
          "html_url": "https://github.com/octocat/my-project/issues/42"
        }
      ]
    }
  }
}
