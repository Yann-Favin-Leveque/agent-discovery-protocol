{
  "name": "repos_delete",
  "description": "Delete a repository. Requires admin access. This action is irreversible.",
  "resource_group": "repositories",
  "endpoint": "/repos/{owner}/{repo}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository owner.",
      "in": "path"
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Repository name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.github.com/repos/octocat/old-project",
    "headers": {
      "Authorization": "Bearer ghp_xxxxxxxxxxxx",
      "Accept": "application/vnd.github+json"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
