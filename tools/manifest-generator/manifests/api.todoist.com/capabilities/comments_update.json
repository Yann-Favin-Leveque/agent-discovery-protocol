{
  "name": "comments_update",
  "description": "Update a comment.",
  "resource_group": "comments",
  "endpoint": "/rest/v2/comments/{id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Comment ID",
      "in": "path"
    },
    {
      "name": "content",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "New content",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ]
}
