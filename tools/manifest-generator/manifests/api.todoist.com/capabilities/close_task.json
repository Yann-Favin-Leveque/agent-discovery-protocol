{
  "name": "close_task",
  "description": "Mark a task as complete. Returns a 204 No Content response on success.",
  "endpoint": "/rest/v2/tasks/{id}/close",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The task ID to mark as complete (required in URL path).",
      "required": true,
      "example": "4017903321"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.todoist.com/rest/v2/tasks/4017903321/close",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
