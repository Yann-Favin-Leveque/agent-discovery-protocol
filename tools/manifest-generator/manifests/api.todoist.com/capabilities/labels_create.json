{
  "name": "labels_create",
  "description": "Create a personal label.",
  "resource_group": "labels",
  "endpoint": "/rest/v2/labels",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Label name"
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Label color"
    },
    {
      "name": "order",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Label order"
    },
    {
      "name": "is_favorite",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Favorite status"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ],
  "request_example": {
    "name": "urgent",
    "color": "red"
  }
}