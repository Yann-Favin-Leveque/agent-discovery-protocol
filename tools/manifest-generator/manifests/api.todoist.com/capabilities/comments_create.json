{
  "name": "comments_create",
  "description": "Create a comment on a task or project.",
  "resource_group": "comments",
  "endpoint": "/rest/v2/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Task ID",
      "in": "body"
    },
    {
      "name": "project_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Project ID",
      "in": "body"
    },
    {
      "name": "content",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Comment content in Markdown",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ],
  "request_example": {
    "task_id": "456",
    "content": "Remember to check the expiry dates"
  }
}
