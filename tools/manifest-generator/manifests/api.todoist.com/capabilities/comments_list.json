{
  "name": "comments_list",
  "description": "Get comments on a task or project.",
  "resource_group": "comments",
  "endpoint": "/rest/v2/comments",
  "method": "GET",
  "parameters": [
    {
      "name": "task_id",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Task ID (required if no project_id)"
    },
    {
      "name": "project_id",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Project ID (required if no task_id)"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ]
}