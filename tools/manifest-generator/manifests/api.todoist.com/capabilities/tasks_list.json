{
  "name": "tasks_list",
  "description": "Get active tasks with optional filters.",
  "resource_group": "tasks",
  "endpoint": "/rest/v2/tasks",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter by project ID"
    },
    {
      "name": "section_id",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter by section ID"
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter by label name"
    },
    {
      "name": "filter",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Todoist filter query string"
    },
    {
      "name": "ids",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Comma-separated task IDs"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ],
  "response_example": [
    {
      "id": "456",
      "content": "Buy groceries",
      "project_id": "123",
      "priority": 2
    }
  ]
}