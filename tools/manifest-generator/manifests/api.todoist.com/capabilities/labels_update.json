{
  "name": "labels_update",
  "description": "Update a label.",
  "resource_group": "labels",
  "endpoint": "/rest/v2/labels/{id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Label ID"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New name"
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New color"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ]
}