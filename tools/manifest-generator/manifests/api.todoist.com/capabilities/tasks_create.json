{
  "name": "tasks_create",
  "description": "Create a new task.",
  "resource_group": "tasks",
  "endpoint": "/rest/v2/tasks",
  "method": "POST",
  "parameters": [
    {
      "name": "content",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Task content/title"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Task description in Markdown"
    },
    {
      "name": "project_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Project to add task to"
    },
    {
      "name": "section_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Section to add task to"
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Parent task ID for subtasks"
    },
    {
      "name": "order",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Task order"
    },
    {
      "name": "labels",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "Array of label names"
    },
    {
      "name": "priority",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Priority (1=normal, 2, 3, 4=urgent)"
    },
    {
      "name": "due_string",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Natural language due date (e.g., 'tomorrow', 'next Monday')"
    },
    {
      "name": "due_date",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Due date in YYYY-MM-DD format"
    },
    {
      "name": "due_datetime",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Due datetime in RFC3339 format"
    },
    {
      "name": "due_lang",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Language for due_string parsing"
    },
    {
      "name": "assignee_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "User ID to assign task to"
    },
    {
      "name": "duration",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Task duration in minutes"
    },
    {
      "name": "duration_unit",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Duration unit: minute or day"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ],
  "request_example": {
    "content": "Buy groceries",
    "due_string": "tomorrow at 5pm",
    "priority": 3,
    "labels": [
      "errands"
    ]
  }
}