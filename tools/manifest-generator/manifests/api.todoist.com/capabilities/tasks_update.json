{
  "name": "tasks_update",
  "description": "Update a task.",
  "resource_group": "tasks",
  "endpoint": "/rest/v2/tasks/{id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Task ID"
    },
    {
      "name": "content",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New content"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New description"
    },
    {
      "name": "labels",
      "type": "array",
      "required": false,
      "location": "body",
      "description": "Labels"
    },
    {
      "name": "priority",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Priority"
    },
    {
      "name": "due_string",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Due date string"
    },
    {
      "name": "due_date",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Due date"
    },
    {
      "name": "assignee_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Assignee ID"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ]
}