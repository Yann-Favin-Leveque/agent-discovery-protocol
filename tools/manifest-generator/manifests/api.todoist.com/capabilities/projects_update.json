{
  "name": "projects_update",
  "description": "Update a project.",
  "resource_group": "projects",
  "endpoint": "/rest/v2/projects/{id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Project ID",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New name",
      "in": "body"
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New color",
      "in": "body"
    },
    {
      "name": "is_favorite",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Favorite status",
      "in": "body"
    },
    {
      "name": "view_style",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "View style",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ]
}
