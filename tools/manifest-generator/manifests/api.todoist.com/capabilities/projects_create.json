{
  "name": "projects_create",
  "description": "Create a new project.",
  "resource_group": "projects",
  "endpoint": "/rest/v2/projects",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Project name",
      "in": "body"
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Parent project ID for sub-projects",
      "in": "body"
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "Project color (e.g., berry_red, blue, green)",
      "in": "body"
    },
    {
      "name": "is_favorite",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Mark as favorite",
      "in": "body"
    },
    {
      "name": "view_style",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "View style: list or board",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ],
  "request_example": {
    "name": "Work",
    "color": "blue",
    "view_style": "board"
  }
}
