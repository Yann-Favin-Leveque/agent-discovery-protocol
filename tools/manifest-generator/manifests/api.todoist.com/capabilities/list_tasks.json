{
  "name": "list_tasks",
  "description": "Retrieve all tasks or filter by project, label, or status. Returns task metadata including ID, content, due date, priority, and assigned project.",
  "endpoint": "/rest/v2/tasks",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "integer",
      "description": "Filter tasks by project ID.",
      "required": false,
      "example": "2203306141"
    },
    {
      "name": "label_id",
      "type": "integer",
      "description": "Filter tasks by label ID.",
      "required": false,
      "example": "2158662141"
    },
    {
      "name": "filter",
      "type": "string",
      "description": "Use Todoist query language to filter tasks (e.g., 'priority > 2' or 'today').",
      "required": false,
      "example": "priority > 2 & today"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.todoist.com/rest/v2/tasks?project_id=2203306141",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "4017903321",
        "project_id": "2203306141",
        "content": "Buy groceries",
        "description": "Milk, eggs, bread",
        "due": {
          "date": "2026-03-15",
          "is_recurring": false,
          "datetime": "2026-03-15T18:00:00Z",
          "string": "Mar 15"
        },
        "priority": 2,
        "order": 1,
        "labels": ["shopping"],
        "is_completed": false
      },
      {
        "id": "4017903322",
        "project_id": "2203306141",
        "content": "Call client",
        "description": "Follow up on proposal",
        "due": {
          "date": "2026-03-10",
          "is_recurring": false,
          "datetime": "2026-03-10T14:00:00Z",
          "string": "Mar 10"
        },
        "priority": 4,
        "order": 2,
        "labels": ["work"],
        "is_completed": false
      }
    ]
  }
}
