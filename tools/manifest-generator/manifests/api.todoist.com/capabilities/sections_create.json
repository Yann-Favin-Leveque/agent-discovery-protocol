  "resource_group": "sections",
  "endpoint": "/rest/v2/sections",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Section name"
    },
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Project ID"
    },
    {
      "name": "order",
      "type": "integer",
      "required": false,
      "location": "body",
      "description": "Section order"
    }
  ],
  "auth_scopes": [
    "task:add",
    "data:read",
    "data:read_write",
    "data:delete"
  ],
  "request_example": {
    "name": "In Progress",
    "project_id": "123"
  }
}