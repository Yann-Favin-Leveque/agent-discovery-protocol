{
  "spec_version": "1.0",
  "name": "Todoist",
  "description": "Todoist is a task and project management tool. The REST API v2 provides full CRUD for projects, sections, tasks, comments, and labels. Supports natural language due dates, priorities, assignees, and shared labels.",
  "base_url": "https://api.todoist.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://todoist.com/app/settings/integrations/developer"
  },
  "capabilities": [
    {
      "name": "projects_list",
      "description": "Get all projects.",
      "resource_group": "projects",
      "detail_url": "/capabilities/projects_list"
    },
    {
      "name": "projects_create",
      "description": "Create a new project.",
      "resource_group": "projects",
      "detail_url": "/capabilities/projects_create"
    },
    {
      "name": "projects_get",
      "description": "Get a project by ID.",
      "resource_group": "projects",
      "detail_url": "/capabilities/projects_get"
    },
    {
      "name": "projects_update",
      "description": "Update a project.",
      "resource_group": "projects",
      "detail_url": "/capabilities/projects_update"
    },
    {
