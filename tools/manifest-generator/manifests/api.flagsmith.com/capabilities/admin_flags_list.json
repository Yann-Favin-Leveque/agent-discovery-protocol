{
  "name": "admin_flags_list",
  "description": "List all feature flags in a project. Requires the Admin API token.",
  "resource_group": "admin_flags",
  "endpoint": "/projects/{project_id}/features/",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "integer",
      "description": "Project ID.",
      "required": true,
      "example": 1,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.flagsmith.com/api/v1/projects/1/features/",
    "headers": {
      "Authorization": "Token {admin_api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 101,
        "name": "new_checkout",
        "type": "FLAG",
        "default_enabled": true,
        "initial_value": null
      },
      {
        "id": 102,
        "name": "header_color",
        "type": "CONFIG",
        "default_enabled": true,
        "initial_value": "#2d7ff9"
      }
    ]
  },
  "rate_limits": {
    "requests_per_minute": 500
  }
}
