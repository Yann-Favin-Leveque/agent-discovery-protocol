{
  "name": "events_batch",
  "description": "Send multiple events in a single batch request.",
  "resource_group": "capture",
  "endpoint": "/batch",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Project API key"
    },
    {
      "name": "batch",
      "type": "array",
      "required": true,
      "description": "Array of event objects"
    }
  ],
  "request_example": {
    "api_key": "phc_xxx",
    "batch": [
      {
        "event": "page_view",
        "properties": {
          "distinct_id": "user_123"
        },
        "timestamp": "2025-01-01T00:00:00Z"
      }
    ]
  },
  "response_example": {
    "status": 1
  },
  "auth_scopes": []
}
