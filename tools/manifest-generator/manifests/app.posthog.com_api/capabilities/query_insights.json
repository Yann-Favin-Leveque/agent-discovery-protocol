{
  "name": "query_insights",
  "description": "Query analytics insights including trends, funnels, retention, and paths analysis.",
  "endpoint": "/projects/{project_id}/insights/",
  "method": "GET",
  "parameters": [
    {"name": "project_id", "type": "number", "description": "Project ID.", "required": true, "example": 1},
    {"name": "short_id", "type": "string", "description": "Short ID of a saved insight.", "required": false, "example": "abc123"},
    {"name": "limit", "type": "number", "description": "Max results.", "required": false, "example": 10}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://app.posthog.com/api/projects/1/insights/?limit=10",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"count": 5, "results": [{"id": 101, "short_id": "abc123", "name": "Weekly Active Users", "filters": {"insight": "TRENDS", "events": [{"id": "$pageview"}]}, "result": [{"data": [100, 120, 150, 180]}]}]}
  }
}
