{
  "name": "events_list",
  "description": "Retrieve recent events with filtering by event type and properties.",
  "resource_group": "events",
  "endpoint": "/projects/{project_id}/events",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID",
      "location": "path"
    },
    {
      "name": "event",
      "type": "string",
      "required": false,
      "description": "Filter by event name",
      "location": "query"
    },
    {
      "name": "after",
      "type": "string",
      "required": false,
      "description": "Retrieve events after this timestamp",
      "location": "query"
    },
    {
      "name": "before",
      "type": "string",
      "required": false,
      "description": "Retrieve events before this timestamp",
      "location": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max events to return",
      "location": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "results": [
      {
        "id": "evt_123",
        "event": "page_view",
        "properties": {
          "distinct_id": "user_123"
        }
      }
    ]
  },
  "auth_scopes": []
}
