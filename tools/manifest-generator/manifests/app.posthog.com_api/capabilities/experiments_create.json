{
  "name": "experiments_create",
  "description": "Create a new A/B test experiment with variants.",
  "resource_group": "experiments",
  "endpoint": "/projects/{project_id}/experiments",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Experiment name",
      "in": "body"
    },
    {
      "name": "feature_flag_key",
      "type": "string",
      "required": true,
      "description": "Associated feature flag key",
      "in": "body"
    },
    {
      "name": "parameters",
      "type": "object",
      "required": false,
      "description": "Experiment parameters",
      "in": "body"
    }
  ],
  "request_example": {
    "name": "Button Color Test",
    "feature_flag_key": "button-color"
  },
  "response_example": {
    "id": 2,
    "name": "Button Color Test"
  },
  "auth_scopes": []
}
