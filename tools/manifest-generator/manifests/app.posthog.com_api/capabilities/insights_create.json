{
  "name": "insights_create",
  "description": "Create a new insight with filters for trends, funnels, retention, or paths.",
  "resource_group": "insights",
  "endpoint": "/projects/{project_id}/insights",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID",
      "location": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Insight name"
    },
    {
      "name": "filters",
      "type": "object",
      "required": true,
      "description": "Insight filter configuration"
    },
    {
      "name": "saved",
      "type": "boolean",
      "required": false,
      "description": "Whether to save the insight"
    }
  ],
  "request_example": {
    "name": "DAU",
    "filters": {
      "insight": "TRENDS",
      "events": [
        {
          "id": "$pageview"
        }
      ],
      "date_from": "-7d"
    }
  },
  "response_example": {
    "id": 1,
    "name": "DAU",
    "result": []
  },
  "auth_scopes": []
}
