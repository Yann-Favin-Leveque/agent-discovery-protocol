{
  "name": "feature_flags_evaluate",
  "description": "Evaluate feature flags for a specific user via the decide endpoint.",
  "resource_group": "feature_flags",
  "endpoint": "/decide",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Project API key"
    },
    {
      "name": "distinct_id",
      "type": "string",
      "required": true,
      "description": "User identifier"
    },
    {
      "name": "person_properties",
      "type": "object",
      "required": false,
      "description": "User properties for flag evaluation"
    }
  ],
  "request_example": {
    "api_key": "phc_xxx",
    "distinct_id": "user_123"
  },
  "response_example": {
    "featureFlags": {
      "beta-feature": true
    },
    "featureFlagPayloads": {}
  },
  "auth_scopes": []
}
