{
  "name": "actions_create",
  "description": "Create a new action to group and name events.",
  "resource_group": "actions",
  "endpoint": "/projects/{project_id}/actions",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID",
      "location": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Action name"
    },
    {
      "name": "steps",
      "type": "array",
      "required": true,
      "description": "Event matching steps"
    }
  ],
  "request_example": {
    "name": "Signup",
    "steps": [
      {
        "event": "user_signed_up"
      }
    ]
  },
  "response_example": {
    "id": 2,
    "name": "Signup"
  },
  "auth_scopes": []
}
