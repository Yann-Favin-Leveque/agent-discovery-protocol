{
  "name": "events_capture",
  "description": "Capture a custom analytics event with properties and user identification.",
  "resource_group": "capture",
  "endpoint": "/i/v0/e",
  "method": "POST",
  "parameters": [
    {
      "name": "api_key",
      "type": "string",
      "required": true,
      "description": "Project API key",
      "in": "body"
    },
    {
      "name": "event",
      "type": "string",
      "required": true,
      "description": "Event name",
      "in": "body"
    },
    {
      "name": "properties",
      "type": "object",
      "required": false,
      "description": "Event properties including distinct_id",
      "in": "body"
    },
    {
      "name": "timestamp",
      "type": "string",
      "required": false,
      "description": "ISO 8601 timestamp",
      "in": "body"
    }
  ],
  "request_example": {
    "api_key": "phc_xxx",
    "event": "page_view",
    "properties": {
      "distinct_id": "user_123",
      "$current_url": "https://example.com"
    }
  },
  "response_example": {
    "status": 1
  },
  "auth_scopes": []
}
