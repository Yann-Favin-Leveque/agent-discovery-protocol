{
  "name": "annotations_create",
  "description": "Create a new annotation to mark important dates on charts.",
  "resource_group": "annotations",
  "endpoint": "/projects/{project_id}/annotations",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID",
      "location": "path"
    },
    {
      "name": "content",
      "type": "string",
      "required": true,
      "description": "Annotation text"
    },
    {
      "name": "date_marker",
      "type": "string",
      "required": true,
      "description": "Date for the annotation"
    },
    {
      "name": "scope",
      "type": "string",
      "required": false,
      "description": "Scope: project or organization"
    }
  ],
  "request_example": {
    "content": "v2.0 Launch",
    "date_marker": "2025-03-01",
    "scope": "project"
  },
  "response_example": {
    "id": 2,
    "content": "v2.0 Launch"
  },
  "auth_scopes": []
}
