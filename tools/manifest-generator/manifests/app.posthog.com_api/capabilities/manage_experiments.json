{
  "name": "manage_experiments",
  "description": "Create and manage A/B test experiments with variant configuration and goal metrics.",
  "endpoint": "/projects/{project_id}/experiments/",
  "method": "POST",
  "parameters": [
    {"name": "project_id", "type": "number", "description": "Project ID.", "required": true, "example": 1},
    {"name": "name", "type": "string", "description": "Experiment name.", "required": true, "example": "Pricing Page Test"},
    {"name": "feature_flag_key", "type": "string", "description": "Feature flag key for the experiment.", "required": true, "example": "pricing-page-test"},
    {"name": "parameters", "type": "object", "description": "Experiment parameters with variants.", "required": true, "example": {"feature_flag_variants": [{"key": "control", "rollout_percentage": 50}, {"key": "test", "rollout_percentage": 50}]}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://app.posthog.com/api/projects/1/experiments/",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"name": "Pricing Page Test", "feature_flag_key": "pricing-page-test", "parameters": {"feature_flag_variants": [{"key": "control", "rollout_percentage": 50}, {"key": "test", "rollout_percentage": 50}]}}
  },
  "response_example": {
    "status": 201,
    "body": {"id": 15, "name": "Pricing Page Test", "feature_flag_key": "pricing-page-test", "start_date": null, "end_date": null, "created_at": "2024-01-20T10:00:00Z"}
  }
}
