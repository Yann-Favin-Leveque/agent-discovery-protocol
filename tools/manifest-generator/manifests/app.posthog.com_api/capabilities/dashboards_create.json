{
  "name": "dashboards_create",
  "description": "Create a new dashboard.",
  "resource_group": "dashboards",
  "endpoint": "/projects/{project_id}/dashboards",
  "method": "POST",
  "parameters": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID",
      "location": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Dashboard name"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "Dashboard description"
    }
  ],
  "request_example": {
    "name": "Product Dashboard"
  },
  "response_example": {
    "id": 2,
    "name": "Product Dashboard"
  },
  "auth_scopes": []
}
