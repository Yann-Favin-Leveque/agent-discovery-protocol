{
  "name": "settings_sendAs_delete",
  "description": "Deletes the specified send-as alias.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/sendAs/{sendAsEmail}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "sendAsEmail",
      "type": "string",
      "description": "The alias email.",
      "required": true,
      "example": "alias@example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/sendAs/alias@example.com",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.sharing"
  ]
}