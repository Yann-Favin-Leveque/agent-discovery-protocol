{
  "name": "settings_sendAs_verify",
  "description": "Sends a verification email to the specified send-as alias address.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/sendAs/{sendAsEmail}/verify",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "sendAsEmail",
      "type": "string",
      "description": "The alias email to verify.",
      "required": true,
      "example": "alias@example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/sendAs/alias@example.com/verify",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.sharing"
  ]
}