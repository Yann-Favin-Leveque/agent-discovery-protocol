{
  "name": "users_getProfile",
  "description": "Gets the current user's Gmail profile including email address, message and thread counts.",
  "resource_group": "users",
  "endpoint": "/gmail/v1/users/{userId}/profile",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address. Use 'me' for the authenticated user.",
      "required": true,
      "example": "me"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/profile",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "emailAddress": "user@gmail.com",
      "messagesTotal": 1234,
      "threadsTotal": 567,
      "historyId": "12345"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.readonly"
  ]
}