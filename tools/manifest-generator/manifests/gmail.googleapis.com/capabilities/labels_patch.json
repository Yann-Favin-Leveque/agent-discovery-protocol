{
  "name": "labels_patch",
  "description": "Patches the specified label with partial updates.",
  "resource_group": "labels",
  "endpoint": "/gmail/v1/users/{userId}/labels/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the label.",
      "required": true,
      "example": "Label_1"
    },
    {
      "name": "name",
      "type": "string",
      "description": "New display name.",
      "required": false,
      "example": "Updated Label"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/labels/Label_1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Label"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "Label_1",
      "name": "Updated Label",
      "type": "user"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.labels"
  ]
}