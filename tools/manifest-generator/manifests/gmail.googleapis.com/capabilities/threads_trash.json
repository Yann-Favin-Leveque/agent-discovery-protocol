{
  "name": "threads_trash",
  "description": "Moves the specified thread to the trash.",
  "resource_group": "threads",
  "endpoint": "/gmail/v1/users/{userId}/threads/{id}/trash",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the thread.",
      "required": true,
      "example": "18e2abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/threads/18e2abc123/trash",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "18e2abc123",
      "historyId": "12345"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.modify"
  ]
}
