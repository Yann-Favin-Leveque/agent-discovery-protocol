{
  "name": "settings_delegates_list",
  "description": "Lists the delegates for the specified account.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/delegates",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/delegates",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "delegates": [
        {
          "delegateEmail": "delegate@example.com",
          "verificationStatus": "accepted"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.basic"
  ]
}