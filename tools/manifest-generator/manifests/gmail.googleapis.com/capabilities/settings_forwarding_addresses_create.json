{
  "name": "settings_forwarding_addresses_create",
  "description": "Creates a forwarding address. If verification is required, a confirmation email will be sent.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/forwardingAddresses",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "forwardingEmail",
      "type": "string",
      "description": "Email address to forward to.",
      "required": true,
      "example": "forward@example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/forwardingAddresses",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "forwardingEmail": "forward@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "forwardingEmail": "forward@example.com",
      "verificationStatus": "pending"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.sharing"
  ]
}
