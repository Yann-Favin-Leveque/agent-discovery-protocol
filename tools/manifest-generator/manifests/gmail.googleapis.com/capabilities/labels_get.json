{
  "name": "labels_get",
  "description": "Gets the specified label by ID.",
  "resource_group": "labels",
  "endpoint": "/gmail/v1/users/{userId}/labels/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the label.",
      "required": true,
      "example": "Label_1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/labels/Label_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "Label_1",
      "name": "My Label",
      "type": "user",
      "messagesTotal": 42,
      "messagesUnread": 5
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.labels"
  ]
}