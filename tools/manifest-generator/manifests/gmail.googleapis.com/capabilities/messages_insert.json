{
  "name": "messages_insert",
  "description": "Directly inserts a message into the mailbox bypassing most scanning and classification.",
  "resource_group": "messages",
  "endpoint": "/gmail/v1/users/{userId}/messages",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "raw",
      "type": "string",
      "description": "The email in base64url encoded RFC 2822 format.",
      "required": true
    },
    {
      "name": "internalDateSource",
      "type": "string",
      "description": "Source for internal date: dateHeader or receivedTime.",
      "required": false,
      "example": "dateHeader"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/messages?internalDateSource=dateHeader",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "raw": "base64url-encoded-email"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "18e2abc789",
      "threadId": "18e2abc789",
      "labelIds": [
        "INBOX"
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.insert"
  ]
}