{
  "name": "drafts_delete",
  "description": "Immediately and permanently deletes the specified draft.",
  "resource_group": "drafts",
  "endpoint": "/gmail/v1/users/{userId}/drafts/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the draft.",
      "required": true,
      "example": "r123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/drafts/r123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.compose"
  ]
}