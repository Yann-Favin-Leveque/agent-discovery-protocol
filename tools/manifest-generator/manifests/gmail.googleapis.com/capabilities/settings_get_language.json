{
  "name": "settings_get_language",
  "description": "Gets language settings for the specified account.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/language",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/language",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "displayLanguage": "en"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.basic"
  ]
}
