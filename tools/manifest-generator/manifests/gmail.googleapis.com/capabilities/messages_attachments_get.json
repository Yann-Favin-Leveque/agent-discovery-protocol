{
  "name": "messages_attachments_get",
  "description": "Gets the specified message attachment by its ID.",
  "resource_group": "messages",
  "endpoint": "/gmail/v1/users/{userId}/messages/{messageId}/attachments/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "messageId",
      "type": "string",
      "description": "The ID of the parent message.",
      "required": true,
      "example": "18e2abc123",
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the attachment.",
      "required": true,
      "example": "ANGjdJ8",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/messages/18e2abc123/attachments/ANGjdJ8",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "attachmentId": "ANGjdJ8",
      "size": 12345,
      "data": "base64url-encoded-data"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.readonly"
  ]
}
