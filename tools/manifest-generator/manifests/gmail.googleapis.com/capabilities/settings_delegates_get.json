{
  "name": "settings_delegates_get",
  "description": "Gets the specified delegate.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/delegates/{delegateEmail}",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "delegateEmail",
      "type": "string",
      "description": "The delegate email.",
      "required": true,
      "example": "delegate@example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/delegates/delegate@example.com",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "delegateEmail": "delegate@example.com",
      "verificationStatus": "accepted"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.basic"
  ]
}
