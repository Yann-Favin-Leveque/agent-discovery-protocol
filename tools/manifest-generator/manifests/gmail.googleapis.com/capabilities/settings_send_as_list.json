{
  "name": "settings_send_as_list",
  "description": "Lists the send-as aliases for the specified account.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/sendAs",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/sendAs",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sendAs": [
        {
          "sendAsEmail": "user@gmail.com",
          "displayName": "John Doe",
          "isDefault": true
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.basic"
  ]
}
