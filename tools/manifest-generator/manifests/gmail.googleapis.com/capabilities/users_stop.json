{
  "name": "users_stop",
  "description": "Stops receiving push notifications for the given user mailbox.",
  "resource_group": "users",
  "endpoint": "/gmail/v1/users/{userId}/stop",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/stop",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.modify"
  ]
}
