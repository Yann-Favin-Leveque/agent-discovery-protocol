{
  "name": "settings_delegates_delete",
  "description": "Removes the specified delegate and revokes access.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/delegates/{delegateEmail}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "delegateEmail",
      "type": "string",
      "description": "The delegate email.",
      "required": true,
      "example": "delegate@example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/delegates/delegate@example.com",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.sharing"
  ]
}