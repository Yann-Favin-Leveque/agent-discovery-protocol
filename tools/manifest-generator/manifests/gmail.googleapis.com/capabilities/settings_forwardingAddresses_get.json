{
  "name": "settings_forwardingAddresses_get",
  "description": "Gets the specified forwarding address.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/forwardingAddresses/{forwardingEmail}",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "forwardingEmail",
      "type": "string",
      "description": "The forwarding email address.",
      "required": true,
      "example": "forward@example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/forwardingAddresses/forward@example.com",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "forwardingEmail": "forward@example.com",
      "verificationStatus": "accepted"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.basic"
  ]
}