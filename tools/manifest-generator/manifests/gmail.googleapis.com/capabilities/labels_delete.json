{
  "name": "labels_delete",
  "description": "Immediately and permanently deletes the specified label.",
  "resource_group": "labels",
  "endpoint": "/gmail/v1/users/{userId}/labels/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the label to delete.",
      "required": true,
      "example": "Label_1"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/labels/Label_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.labels"
  ]
}