{
  "name": "labels_list",
  "description": "Lists all labels in the user's mailbox.",
  "resource_group": "labels",
  "endpoint": "/gmail/v1/users/{userId}/labels",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/labels",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "labels": [
        {
          "id": "INBOX",
          "name": "INBOX",
          "type": "system"
        },
        {
          "id": "Label_1",
          "name": "My Label",
          "type": "user"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.labels"
  ]
}
