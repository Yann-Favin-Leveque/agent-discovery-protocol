{
  "name": "threads_delete",
  "description": "Immediately and permanently deletes the specified thread.",
  "resource_group": "threads",
  "endpoint": "/gmail/v1/users/{userId}/threads/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the thread.",
      "required": true,
      "example": "18e2abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/threads/18e2abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://mail.google.com/"
  ]
}