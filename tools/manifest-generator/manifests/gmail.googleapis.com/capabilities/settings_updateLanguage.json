{
  "name": "settings_updateLanguage",
  "description": "Updates language settings for the specified account.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/language",
  "method": "PUT",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "displayLanguage",
      "type": "string",
      "description": "Language to display Gmail in (RFC 3066).",
      "required": true,
      "example": "en"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/language",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "displayLanguage": "en"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "displayLanguage": "en"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.basic"
  ]
}