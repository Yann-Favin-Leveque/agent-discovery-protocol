{
  "name": "settings_updateAutoForwarding",
  "description": "Updates the auto-forwarding setting for the specified account.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/autoForwarding",
  "method": "PUT",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "enabled",
      "type": "boolean",
      "description": "Whether auto-forwarding is enabled.",
      "required": true,
      "example": true
    },
    {
      "name": "emailAddress",
      "type": "string",
      "description": "Email address to forward messages to.",
      "required": false,
      "example": "forward@example.com"
    },
    {
      "name": "disposition",
      "type": "string",
      "description": "Action after forwarding: leaveInInbox, archive, trash, markRead.",
      "required": false,
      "example": "leaveInInbox"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/autoForwarding",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "enabled": true,
      "emailAddress": "forward@example.com",
      "disposition": "leaveInInbox"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "enabled": true,
      "emailAddress": "forward@example.com",
      "disposition": "leaveInInbox"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.sharing"
  ]
}