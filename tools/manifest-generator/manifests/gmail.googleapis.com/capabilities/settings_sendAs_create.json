{
  "name": "settings_sendAs_create",
  "description": "Creates a custom 'from' send-as alias.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/sendAs",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "sendAsEmail",
      "type": "string",
      "description": "The alias email address.",
      "required": true,
      "example": "alias@example.com"
    },
    {
      "name": "displayName",
      "type": "string",
      "description": "Display name for the alias.",
      "required": false,
      "example": "My Alias"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/sendAs",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "sendAsEmail": "alias@example.com",
      "displayName": "My Alias"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sendAsEmail": "alias@example.com",
      "displayName": "My Alias",
      "verificationStatus": "pending"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.sharing"
  ]
}