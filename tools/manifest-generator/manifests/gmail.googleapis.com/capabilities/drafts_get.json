{
  "name": "drafts_get",
  "description": "Gets the specified draft including the message content.",
  "resource_group": "drafts",
  "endpoint": "/gmail/v1/users/{userId}/drafts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the draft.",
      "required": true,
      "example": "r123"
    },
    {
      "name": "format",
      "type": "string",
      "description": "Format: minimal, full, raw, metadata.",
      "required": false,
      "example": "full"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/drafts/r123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "r123",
      "message": {
        "id": "18e2abc123",
        "snippet": "Draft content..."
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.readonly"
  ]
}