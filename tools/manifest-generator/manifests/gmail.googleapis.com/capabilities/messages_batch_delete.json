{
  "name": "messages_batch_delete",
  "description": "Permanently deletes many messages by message ID.",
  "resource_group": "messages",
  "endpoint": "/gmail/v1/users/{userId}/messages/batchDelete",
  "method": "POST",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "ids",
      "type": "array",
      "description": "The list of message IDs to delete.",
      "required": true,
      "example": [
        "18e2abc123",
        "18e2abc456"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/messages/batchDelete",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "ids": [
        "18e2abc123",
        "18e2abc456"
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://mail.google.com/"
  ]
}
