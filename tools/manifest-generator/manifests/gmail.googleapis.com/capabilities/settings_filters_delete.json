{
  "name": "settings_filters_delete",
  "description": "Deletes a message filter by ID.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/filters/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The filter ID.",
      "required": true,
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/filters/abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.basic"
  ]
}