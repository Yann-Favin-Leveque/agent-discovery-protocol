{
  "name": "messages_delete",
  "description": "Immediately and permanently deletes the specified message. Cannot be undone.",
  "resource_group": "messages",
  "endpoint": "/gmail/v1/users/{userId}/messages/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "The ID of the message to delete.",
      "required": true,
      "example": "18e2abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/messages/18e2abc123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://mail.google.com/"
  ]
}
