{
  "name": "settings_forwarding_addresses_delete",
  "description": "Deletes the specified forwarding address.",
  "resource_group": "settings",
  "endpoint": "/gmail/v1/users/{userId}/settings/forwardingAddresses/{forwardingEmail}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "userId",
      "type": "string",
      "description": "The user's email address.",
      "required": true,
      "example": "me",
      "in": "path"
    },
    {
      "name": "forwardingEmail",
      "type": "string",
      "description": "The forwarding email address.",
      "required": true,
      "example": "forward@example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://gmail.googleapis.com/gmail/v1/users/me/settings/forwardingAddresses/forward@example.com",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/gmail.settings.sharing"
  ]
}
