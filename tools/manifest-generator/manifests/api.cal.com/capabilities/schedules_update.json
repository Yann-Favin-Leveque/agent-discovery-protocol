{
  "name": "schedules_update",
  "resource_group": "schedules",
  "description": "Update an existing schedule.",
  "endpoint": "/v2/schedules/{scheduleId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "scheduleId",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Schedule ID",
      "example": 1
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name",
      "example": "Updated Hours",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.cal.com/v2/schedules/1",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "Content-Type": "application/json",
      "cal-api-version": "2024-08-13"
    },
    "body": {
      "name": "Updated Hours"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 1,
        "name": "Updated Hours"
      }
    }
  }
}
