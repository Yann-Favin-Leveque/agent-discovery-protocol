    "url": "https://api.cal.com/v2/calendars",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "credentialId": 1,
          "integration": "google_calendar",
          "email": "user@gmail.com"
        }
      ]
    }
  }
}