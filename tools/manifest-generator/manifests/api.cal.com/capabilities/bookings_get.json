{
  "name": "bookings_get",
  "resource_group": "bookings",
  "description": "Retrieve a specific booking by its unique identifier.",
  "endpoint": "/v2/bookings/{bookingUid}",
  "method": "GET",
  "parameters": [
    {
      "name": "bookingUid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Unique booking identifier",
      "example": "bk_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/bookings/bk_abc123",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 123456,
        "uid": "bk_abc123",
        "title": "30 Minute Meeting",
        "status": "accepted",
        "start": "2025-03-15T10:00:00Z",
        "end": "2025-03-15T10:30:00Z"
      }
    }
  }
}