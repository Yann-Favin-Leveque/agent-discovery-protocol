{
  "name": "teams_update",
  "resource_group": "teams",
  "description": "Update a team's settings.",
  "endpoint": "/v2/teams/{teamId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "teamId",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Team ID",
      "example": 1
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Updated name",
      "example": "Product Team"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.cal.com/v2/teams/1",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "Content-Type": "application/json",
      "cal-api-version": "2024-08-13"
    },
    "body": {
      "name": "Product Team"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 1,
        "name": "Product Team"
      }
    }
  }
}