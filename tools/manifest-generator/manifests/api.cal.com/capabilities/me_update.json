{
  "name": "me_update",
  "resource_group": "profile",
  "description": "Update the authenticated user's profile information.",
  "endpoint": "/v2/me",
  "method": "PATCH",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Display name",
      "example": "John Smith"
    },
    {
      "name": "timeZone",
      "type": "string",
      "required": false,
      "description": "Timezone",
      "example": "Europe/London"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.cal.com/v2/me",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "Content-Type": "application/json",
      "cal-api-version": "2024-08-13"
    },
    "body": {
      "name": "John Smith"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 12345,
        "name": "John Smith"
      }
    }
  }
}