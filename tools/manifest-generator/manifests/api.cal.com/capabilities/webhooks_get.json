{
  "name": "webhooks_get",
  "resource_group": "webhooks",
  "description": "Retrieve a specific webhook by its ID.",
  "endpoint": "/v2/webhooks/{webhookId}",
  "method": "GET",
  "parameters": [
    {
      "name": "webhookId",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Webhook ID",
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/webhooks/1",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 1,
        "subscriberUrl": "https://example.com/webhook",
        "active": true
      }
    }
  }
}