{
  "name": "list_event_types",
  "description": "Retrieve all event types configured for the authenticated Cal.com user. Event types define the meetings people can book with you, including duration, title, description, locations, and booking limits. Each event type has a unique slug used in the booking URL.",
  "endpoint": "/v2/event-types",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/event-types",
    "headers": {
      "Authorization": "Bearer cal_live_abcdef1234567890"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "id": 12345,
          "title": "30 Minute Meeting",
          "slug": "30min",
          "description": "A quick 30-minute call to discuss your project.",
          "length": 30,
          "locations": [
            { "type": "integrations:google:meet" }
          ],
          "hidden": false,
          "requiresConfirmation": false,
          "minimumBookingNotice": 120,
          "beforeEventBuffer": 5,
          "afterEventBuffer": 5,
          "schedulingType": null,
          "periodType": "UNLIMITED",
          "slotInterval": null,
          "bookingLimits": null
        },
        {
          "id": 12346,
          "title": "60 Minute Consultation",
          "slug": "60min-consultation",
          "description": "In-depth consultation for new clients.",
          "length": 60,
          "locations": [
            { "type": "integrations:zoom" }
          ],
          "hidden": false,
          "requiresConfirmation": true,
          "minimumBookingNotice": 1440,
          "beforeEventBuffer": 10,
          "afterEventBuffer": 10,
          "schedulingType": null,
          "periodType": "UNLIMITED",
          "slotInterval": null,
          "bookingLimits": null
        }
      ]
    }
  }
}
