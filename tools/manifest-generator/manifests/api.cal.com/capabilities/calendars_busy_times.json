{
  "name": "calendars_busy_times",
  "resource_group": "calendars",
  "description": "Get busy time ranges from connected calendars.",
  "endpoint": "/v2/calendars/busy-times",
  "method": "GET",
  "parameters": [
    {
      "name": "dateFrom",
      "type": "string",
      "required": true,
      "description": "Start date",
      "example": "2025-03-15"
    },
    {
      "name": "dateTo",
      "type": "string",
      "required": true,
      "description": "End date",
      "example": "2025-03-22"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/calendars/busy-times?dateFrom=2025-03-15&dateTo=2025-03-22",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "start": "2025-03-15T10:00:00Z",
          "end": "2025-03-15T11:00:00Z"
        }
      ]
    }
  }
}