{
  "name": "event_types_get",
  "resource_group": "event_types",
  "description": "Retrieve a specific event type by its ID.",
  "endpoint": "/v2/event-types/{eventTypeId}",
  "method": "GET",
  "parameters": [
    {
      "name": "eventTypeId",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Event type ID",
      "example": 789
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/event-types/789",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 789,
        "slug": "30-minute-meeting",
        "title": "30 Minute Meeting",
        "length": 30,
        "locations": [
          {
            "type": "integrations:google:meet"
          }
        ]
      }
    }
  }
}