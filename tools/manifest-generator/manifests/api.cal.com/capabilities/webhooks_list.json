{
  "name": "webhooks_list",
  "resource_group": "webhooks",
  "description": "Retrieve all webhook subscriptions.",
  "endpoint": "/v2/webhooks",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/webhooks",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": [
        {
          "id": 1,
          "subscriberUrl": "https://example.com/webhook",
          "triggers": [
            "BOOKING_CREATED"
          ],
          "active": true
        }
      ]
    }
  }
}