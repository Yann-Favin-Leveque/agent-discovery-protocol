{
  "name": "bookings_confirm",
  "resource_group": "bookings",
  "description": "Confirm a pending booking that requires manual confirmation.",
  "endpoint": "/v2/bookings/{bookingUid}/confirm",
  "method": "POST",
  "parameters": [
    {
      "name": "bookingUid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Unique booking identifier",
      "example": "bk_abc123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cal.com/v2/bookings/bk_abc123/confirm",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "uid": "bk_abc123",
        "status": "accepted"
      }
    }
  }
}