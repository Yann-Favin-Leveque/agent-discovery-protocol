{
  "name": "me_get",
  "resource_group": "profile",
  "description": "Retrieve the authenticated user's profile information.",
  "endpoint": "/v2/me",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/me",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 12345,
        "username": "johndoe",
        "name": "John Doe",
        "email": "john@example.com",
        "timeZone": "America/New_York"
      }
    }
  }
}