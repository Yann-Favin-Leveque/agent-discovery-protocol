{
  "name": "webhooks_update",
  "resource_group": "webhooks",
  "description": "Update a webhook subscription.",
  "endpoint": "/v2/webhooks/{webhookId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "webhookId",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Webhook ID",
      "example": 1
    },
    {
      "name": "active",
      "type": "boolean",
      "required": false,
      "description": "Toggle active state",
      "example": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.cal.com/v2/webhooks/1",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "Content-Type": "application/json",
      "cal-api-version": "2024-08-13"
    },
    "body": {
      "active": false
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 1,
        "active": false
      }
    }
  }
}
