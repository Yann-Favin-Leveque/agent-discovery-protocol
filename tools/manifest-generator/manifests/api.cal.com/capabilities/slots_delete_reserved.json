{
  "name": "slots_delete_reserved",
  "resource_group": "slots",
  "description": "Release a previously reserved time slot.",
  "endpoint": "/v2/slots/reserved/{slotUid}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "slotUid",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Reserved slot UID",
      "example": "slot-uid-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cal.com/v2/slots/reserved/slot-uid-123",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success"
    }
  }
}