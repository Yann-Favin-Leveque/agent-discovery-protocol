{
  "name": "schedules_get",
  "resource_group": "schedules",
  "description": "Retrieve a specific schedule by its ID.",
  "endpoint": "/v2/schedules/{scheduleId}",
  "method": "GET",
  "parameters": [
    {
      "name": "scheduleId",
      "type": "integer",
      "required": true,
      "in": "path",
      "description": "Schedule ID",
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cal.com/v2/schedules/1",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "cal-api-version": "2024-08-13"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "success",
      "data": {
        "id": 1,
        "name": "Working Hours",
        "timeZone": "America/New_York",
        "isDefault": true
      }
    }
  }
}