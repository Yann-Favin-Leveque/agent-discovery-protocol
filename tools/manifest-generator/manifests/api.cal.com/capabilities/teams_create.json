{
  "name": "teams_create",
  "resource_group": "teams",
  "description": "Create a new team.",
  "endpoint": "/v2/teams",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Team name",
      "example": "Engineering",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cal.com/v2/teams",
    "headers": {
      "Authorization": "Bearer cal_live_xxxx",
      "Content-Type": "application/json",
      "cal-api-version": "2024-08-13"
    },
    "body": {
      "name": "Engineering"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "status": "success",
      "data": {
        "id": 2,
        "name": "Engineering"
      }
    }
  }
}
