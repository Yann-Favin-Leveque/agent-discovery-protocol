{
  "name": "list_files",
  "description": "Retrieve a paginated list of all uploaded files with their metadata including size, type, URL, and upload date.",
  "endpoint": "/v6/listFiles",
  "method": "POST",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of files to return per request. Default is 500, maximum is 500.",
      "required": false,
      "example": 100
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of files to skip for pagination.",
      "required": false,
      "example": 0
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uploadthing.com/v6/listFiles",
    "headers": {
      "x-uploadthing-api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "limit": 100,
      "offset": 0
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hasMore": true,
      "files": [
        {
          "key": "f1a2b3c4d5e6",
          "name": "document.pdf",
          "size": 102400,
          "url": "https://utfs.io/f/f1a2b3c4d5e6",
          "customId": null,
          "status": "uploaded",
          "uploadedAt": "2024-01-15T10:30:00.000Z"
        }
      ]
    }
  }
}
