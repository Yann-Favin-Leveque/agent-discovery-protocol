{
  "name": "files_get_usage",
  "resource_group": "usage",
  "description": "Get current storage usage and limits for your UploadThing app.",
  "endpoint": "/v6/getUsageInfo",
  "method": "POST",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://api.uploadthing.com/v6/getUsageInfo",
    "headers": {
      "x-uploadthing-api-key": "sk_live_xxxxx",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "totalBytes": 1073741824,
      "totalReadable": "1 GB",
      "appTotalBytes": 524288000,
      "appTotalReadable": "500 MB",
      "filesUploaded": 250,
      "limitBytes": 5368709120,
      "limitReadable": "5 GB"
    }
  }
}