{
  "name": "rename_files",
  "description": "Rename one or more uploaded files. Updates the file name metadata without changing the file key or URL.",
  "endpoint": "/v6/renameFiles",
  "method": "POST",
  "parameters": [
    {
      "name": "updates",
      "type": "array",
      "description": "Array of objects with fileKey and newName to rename multiple files at once.",
      "required": true,
      "example": [{ "fileKey": "f1a2b3c4d5e6", "newName": "report-final.pdf" }]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uploadthing.com/v6/renameFiles",
    "headers": {
      "x-uploadthing-api-key": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "updates": [
        { "fileKey": "f1a2b3c4d5e6", "newName": "report-final.pdf" }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}
