{
  "name": "files_upload",
  "resource_group": "files",
  "description": "Upload files directly from your server. Generates presigned URLs and uploads to storage.",
  "endpoint": "/v6/uploadFiles",
  "method": "POST",
  "parameters": [
    {
      "name": "files",
      "type": "array",
      "required": true,
      "description": "Array of file objects to upload.",
      "in": "body"
    },
    {
      "name": "metadata",
      "type": "object",
      "required": false,
      "description": "Custom metadata to attach.",
      "in": "body"
    },
    {
      "name": "contentDisposition",
      "type": "string",
      "required": false,
      "description": "Content disposition: inline or attachment. Default inline.",
      "in": "body"
    },
    {
      "name": "acl",
      "type": "string",
      "required": false,
      "description": "Access control: public-read or private.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uploadthing.com/v6/uploadFiles",
    "headers": {
      "x-uploadthing-api-key": "sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "files": [
        {
          "name": "photo.jpg",
          "size": 245000,
          "type": "image/jpeg"
        }
      ],
      "metadata": {
        "userId": "user123"
      },
      "acl": "public-read"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "key": "abc123-photo.jpg",
          "url": "https://utfs.io/f/abc123-photo.jpg",
          "name": "photo.jpg",
          "size": 245000,
          "type": "image/jpeg",
          "customId": null
        }
      ]
    }
  }
}
