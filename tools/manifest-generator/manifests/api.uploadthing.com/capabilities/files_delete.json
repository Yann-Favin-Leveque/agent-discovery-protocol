{
  "name": "files_delete",
  "resource_group": "files",
  "description": "Delete one or more files by file key or custom ID.",
  "endpoint": "/v6/deleteFile",
  "method": "POST",
  "parameters": [
    {
      "name": "fileKeys",
      "type": "array",
      "required": false,
      "description": "Array of file keys to delete."
    },
    {
      "name": "customIds",
      "type": "array",
      "required": false,
      "description": "Array of custom IDs to delete."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uploadthing.com/v6/deleteFile",
    "headers": {
      "x-uploadthing-api-key": "sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "fileKeys": [
        "abc123-photo.jpg"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "deletedCount": 1
    }
  }
}