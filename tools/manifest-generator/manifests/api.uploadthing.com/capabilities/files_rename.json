{
  "name": "files_rename",
  "resource_group": "files",
  "description": "Rename one or more uploaded files.",
  "endpoint": "/v6/renameFiles",
  "method": "POST",
  "parameters": [
    {
      "name": "updates",
      "type": "array",
      "required": true,
      "description": "Array of objects with fileKey (or customId) and newName.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.uploadthing.com/v6/renameFiles",
    "headers": {
      "x-uploadthing-api-key": "sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "updates": [
        {
          "fileKey": "abc123-photo.jpg",
          "newName": "hero-image.jpg"
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}
