{
  "spec_version": "1.0",
  "name": "Cloudflare DNS",
  "description": "Cloudflare DNS API for managing DNS records, DNSSEC, DNS analytics, and DNS settings for your zones. Part of the Cloudflare API.",
  "base_url": "https://api.cloudflare.com/client/v4",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://dash.cloudflare.com/profile/api-tokens"
  },
  "capabilities": [
    {
      "name": "dns_records_list",
      "resource_group": "dns_records",
      "description": "List DNS records for a zone.",
      "detail_url": "/capabilities/dns_records_list"
    },
    {
      "name": "dns_records_create",
      "resource_group": "dns_records",
      "description": "Create a DNS record.",
      "detail_url": "/capabilities/dns_records_create"
    },
    {
      "name": "dns_records_get",
      "resource_group": "dns_records",
      "description": "Get a DNS record.",
      "detail_url": "/capabilities/dns_records_get"
    },
    {
      "name": "dns_records_update",
      "resource_group": "dns_records",
      "description": "Update a DNS record.",
      "detail_url": "/capabilities/dns_records_update"
    },
    {
      "name": "dns_records_patch",
      "resource_group": "dns_records",
      "description": "Patch a DNS record.",
      "detail_url": "/capabilities/dns_records_patch"
    },
    {
      "name": "dns_records_delete",
      "resource_group": "dns_records",
      "description": "Delete a DNS record.",
      "detail_url": "/capabilities/dns_records_delete"
    },
    {
      "name": "dns_records_export",
      "resource_group": "dns_records",
      "description": "Export DNS records as BIND config.",
      "detail_url": "/capabilities/dns_records_export"
    },
    {
      "name": "dns_records_import",
      "resource_group": "dns_records",
      "description": "Import DNS records from BIND config.",
      "detail_url": "/capabilities/dns_records_import"
    },
    {
      "name": "dns_records_batch",
      "resource_group": "dns_records",
      "description": "Batch create/update/delete DNS records.",
      "detail_url": "/capabilities/dns_records_batch"
    },
    {
      "name": "dns_records_scan_trigger",
      "resource_group": "dns_records",
      "description": "Trigger an async DNS record scan.",
      "detail_url": "/capabilities/dns_records_scan_trigger"
    },
    {
      "name": "dnssec_get",
      "resource_group": "dnssec",
      "description": "Get DNSSEC status.",
      "detail_url": "/capabilities/dnssec_get"
    },
    {
      "name": "dnssec_update",
      "resource_group": "dnssec",
      "description": "Enable or disable DNSSEC.",
      "detail_url": "/capabilities/dnssec_update"
    },
    {
      "name": "dns_analytics_report",
      "resource_group": "dns_analytics",
      "description": "Get DNS analytics report.",
      "detail_url": "/capabilities/dns_analytics_report"
    },
    {
      "name": "dns_analytics_by_time",
      "resource_group": "dns_analytics",
      "description": "Get DNS analytics grouped by time.",
      "detail_url": "/capabilities/dns_analytics_by_time"
    },
    {
      "name": "dns_settings_zone_get",
      "resource_group": "dns_settings",
      "description": "Get DNS settings for a zone.",
      "detail_url": "/capabilities/dns_settings_zone_get"
    },
    {
      "name": "dns_settings_zone_update",
      "resource_group": "dns_settings",
      "description": "Update DNS settings for a zone.",
      "detail_url": "/capabilities/dns_settings_zone_update"
    }
  ]
}