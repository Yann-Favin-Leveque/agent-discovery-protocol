{
  "name": "dns_analytics_by_time",
  "resource_group": "dns_analytics",
  "description": "Get DNS analytics grouped by time interval.",
  "endpoint": "/zones/{zone_id}/dns_analytics/report/bytime",
  "method": "GET",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Zone identifier."
    },
    {
      "name": "since",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "Start date."
    },
    {
      "name": "until",
      "type": "string",
      "required": false,
      "in": "query",
      "description": "End date."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/zone123/dns_analytics/report/bytime",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "data": []
      }
    }
  }
}