{
  "name": "dnssec_get",
  "resource_group": "dnssec",
  "description": "Get DNSSEC status and configuration for a zone.",
  "endpoint": "/zones/{zone_id}/dnssec",
  "method": "GET",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Zone identifier."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/zone123/dnssec",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "status": "active",
        "algorithm": "ecdsap256sha256"
      }
    }
  }
}