{
  "name": "applications",
  "description": "Manage applications — create application, get  applications, get application by id. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{accountId}/resource-library/applications",
  "method": "POST",
  "parameters": [
    {
      "name": "accountId",
      "type": "string",
      "description": "Account ID.",
      "required": true,
      "example": "023e105f4ecef8ad9ca31a8372d0c353"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{accountId}/resource-library/applications",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "accountId": "023e105f4ecef8ad9ca31a8372d0c353"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "accountId": "023e105f4ecef8ad9ca31a8372d0c353"
      }
    }
  }
}
