{
  "name": "dns_settings_zone_get",
  "resource_group": "dns_settings",
  "description": "Get DNS settings for a zone.",
  "endpoint": "/zones/{zone_id}/dns_settings",
  "method": "GET",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Zone identifier."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/zone123/dns_settings",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "flatten_all_cnames": false
      }
    }
  }
}