{
  "name": "access_applications",
  "description": "Manage access applications — add an access application, revoke application tokens, update an access application. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{account_id}/access/apps",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The account_id parameter.",
      "required": true,
      "example": "abc_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/access/apps",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "account_id": "abc_123"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "account_id": "abc_123"
      }
    }
  }
}
