{
  "name": "access_application_scoped_policies",
  "description": "Manage access application scoped policies — create an access application policy, update an access application policy, convert an access application policy to a reusable policy. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{account_id}/access/apps/{app_id}/policies",
  "method": "POST",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "The application ID.",
      "required": true,
      "example": "abc_123"
    },
    {
      "name": "account_id",
      "type": "string",
      "description": "The account_id parameter.",
      "required": true,
      "example": "abc_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/access/apps/{app_id}/policies",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "app_id": "abc_123",
      "account_id": "abc_123"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "app_id": "abc_123",
        "account_id": "abc_123"
      }
    }
  }
}
