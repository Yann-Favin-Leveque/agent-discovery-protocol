{
  "name": "custom_pages_for_an_account",
  "description": "Manage custom pages for an account — update a custom page, list custom pages, get a custom page. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{account_identifier}/custom_pages/{identifier}",
  "method": "PUT",
  "parameters": [
    {
      "name": "identifier",
      "type": "string",
      "description": "The identifier parameter.",
      "required": true,
      "example": "abc_123"
    },
    {
      "name": "account_identifier",
      "type": "string",
      "description": "The account_identifier parameter.",
      "required": true,
      "example": "abc_123"
    },
    {
      "name": "state",
      "type": "string",
      "description": "The state field.",
      "required": true,
      "example": "example_value"
    },
    {
      "name": "url",
      "type": "string",
      "description": "The url field.",
      "required": true,
      "example": "https://example.com"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_identifier}/custom_pages/{identifier}",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "identifier": "abc_123",
      "account_identifier": "abc_123",
      "state": "example_value",
      "url": "https://example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "identifier": "abc_123",
        "account_identifier": "abc_123",
        "state": "example_value",
        "url": "https://example.com"
      }
    }
  }
}
