{
  "name": "dns_records_export",
  "resource_group": "dns_records",
  "description": "Export all DNS records as BIND config format.",
  "endpoint": "/zones/{zone_id}/dns_records/export",
  "method": "GET",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Zone identifier."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/zone123/dns_records/export",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": ";; BIND zone file for example.com\nexample.com. 3600 IN A 198.51.100.4"
  }
}