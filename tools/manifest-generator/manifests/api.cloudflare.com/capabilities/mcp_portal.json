{
  "name": "mcp_portal",
  "description": "Manage mcp portal — create a new mcp portal, update a mcp portal, list mcp portals. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{account_id}/access/ai-controls/mcp/portals",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The account_id parameter.",
      "required": true,
      "example": "a86a8f5c339544d7bdc89926de14fb8c"
    },
    {
      "name": "description",
      "type": "string",
      "description": "The description field.",
      "required": false,
      "example": "This is my custom MCP Portal"
    },
    {
      "name": "hostname",
      "type": "string",
      "description": "The hostname field.",
      "required": true,
      "example": "exmaple.com"
    },
    {
      "name": "id",
      "type": "string",
      "description": "portal id",
      "required": true,
      "example": "my-mcp-portal"
    },
    {
      "name": "name",
      "type": "string",
      "description": "The name field.",
      "required": true,
      "example": "My MCP Portal"
    },
    {
      "name": "secure_web_gateway",
      "type": "boolean",
      "description": "Route outbound MCP traffic through Zero Trust Secure Web Gateway",
      "required": false,
      "example": false
    },
    {
      "name": "servers",
      "type": "object[]",
      "description": "The servers field.",
      "required": false,
      "example": []
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/access/ai-controls/mcp/portals",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "account_id": "a86a8f5c339544d7bdc89926de14fb8c",
      "hostname": "exmaple.com",
      "id": "my-mcp-portal",
      "name": "My MCP Portal"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "account_id": "a86a8f5c339544d7bdc89926de14fb8c",
        "hostname": "exmaple.com",
        "id": "my-mcp-portal",
        "name": "My MCP Portal"
      }
    }
  }
}
