{
  "name": "mcp_portal_servers",
  "description": "Manage mcp portal servers — create a new mcp server, sync mcp server capabilities, update a mcp server. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{account_id}/access/ai-controls/mcp/servers",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The account_id parameter.",
      "required": true,
      "example": "a86a8f5c339544d7bdc89926de14fb8c"
    },
    {
      "name": "auth_credentials",
      "type": "string",
      "description": "The auth_credentials field.",
      "required": false,
      "example": "example_value"
    },
    {
      "name": "auth_type",
      "type": "string",
      "description": "The auth_type field.",
      "required": true,
      "example": "unauthenticated"
    },
    {
      "name": "description",
      "type": "string",
      "description": "The description field.",
      "required": false,
      "example": "This is one remote mcp server"
    },
    {
      "name": "hostname",
      "type": "string",
      "description": "The hostname field.",
      "required": true,
      "example": "https://exmaple.com/mcp"
    },
    {
      "name": "id",
      "type": "string",
      "description": "server id",
      "required": true,
      "example": "my-mcp-server"
    },
    {
      "name": "name",
      "type": "string",
      "description": "The name field.",
      "required": true,
      "example": "My MCP Server"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/access/ai-controls/mcp/servers",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "account_id": "a86a8f5c339544d7bdc89926de14fb8c",
      "auth_type": "unauthenticated",
      "hostname": "https://exmaple.com/mcp",
      "id": "my-mcp-server",
      "name": "My MCP Server"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "account_id": "a86a8f5c339544d7bdc89926de14fb8c",
        "auth_type": "unauthenticated",
        "hostname": "https://exmaple.com/mcp",
        "id": "my-mcp-server",
        "name": "My MCP Server"
      }
    }
  }
}
