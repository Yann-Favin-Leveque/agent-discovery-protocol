{
  "name": "dns_records_delete",
  "resource_group": "dns_records",
  "description": "Delete a DNS record.",
  "endpoint": "/zones/{zone_id}/dns_records/{dns_record_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Zone identifier."
    },
    {
      "name": "dns_record_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "DNS record identifier."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cloudflare.com/client/v4/zones/zone123/dns_records/rec-123",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "id": "rec-123"
      }
    }
  }
}