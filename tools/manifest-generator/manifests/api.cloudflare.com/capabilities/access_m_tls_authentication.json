{
  "name": "access_m_tls_authentication",
  "description": "Manage access m tls authentication — add an mtls certificate, update an mtls certificate's hostname settings, update an mtls certificate. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{account_id}/access/certificates",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The account_id parameter.",
      "required": true,
      "example": "abc_123"
    },
    {
      "name": "associated_hostnames",
      "type": "string",
      "description": "The associated_hostnames field.",
      "required": false,
      "example": "Example"
    },
    {
      "name": "certificate",
      "type": "string",
      "description": "The certificate content.",
      "required": true,
      "example": "-----BEGIN CERTIFICATE-----\nMIIGAjCCA+qgAwIBAgIJAI7kymlF7CWT...N4RI7KKB7nikiuUf8vhULKy5IX10\nDrUtmu/B\n-----END CERTIFICATE-----"
    },
    {
      "name": "name",
      "type": "string",
      "description": "The name field.",
      "required": true,
      "example": "Example"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/access/certificates",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "account_id": "abc_123",
      "certificate": "-----BEGIN CERTIFICATE-----\nMIIGAjCCA+qgAwIBAgIJAI7kymlF7CWT...N4RI7KKB7nikiuUf8vhULKy5IX10\nDrUtmu/B\n-----END CERTIFICATE-----",
      "name": "Example"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "account_id": "abc_123",
        "certificate": "-----BEGIN CERTIFICATE-----\nMIIGAjCCA+qgAwIBAgIJAI7kymlF7CWT...N4RI7KKB7nikiuUf8vhULKy5IX10\nDrUtmu/B\n-----END CERTIFICATE-----",
        "name": "Example"
      }
    }
  }
}
