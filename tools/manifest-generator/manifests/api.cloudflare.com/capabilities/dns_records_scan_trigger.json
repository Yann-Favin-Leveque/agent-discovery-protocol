{
  "name": "dns_records_scan_trigger",
  "resource_group": "dns_records",
  "description": "Trigger an async scan for common DNS records.",
  "endpoint": "/zones/{zone_id}/dns_records/scan/trigger",
  "method": "POST",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Zone identifier."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/zones/zone123/dns_records/scan/trigger",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}