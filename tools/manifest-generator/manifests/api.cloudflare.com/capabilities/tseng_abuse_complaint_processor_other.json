{
  "name": "tseng_abuse_complaint_processor_other",
  "description": "Manage tseng abuse complaint processor other — request review on mitigations, submit an abuse report, list abuse reports. Supports standard CRUD operations through the REST API.",
  "endpoint": "/accounts/{account_id}/abuse-reports/{report_id}/mitigations/appeal",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "Cloudflare Account ID",
      "required": true,
      "example": "023e105f4ecef8ad9ca31a8372d0c353"
    },
    {
      "name": "report_id",
      "type": "string",
      "description": "Abuse Report ID",
      "required": true,
      "example": "abc_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/abuse-reports/{report_id}/mitigations/appeal",
    "headers": {
      "Content-Type": "application/json",
      "X-Auth-Email": "{api_key}"
    },
    "body": {
      "account_id": "023e105f4ecef8ad9ca31a8372d0c353",
      "report_id": "abc_123"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "account_id": "023e105f4ecef8ad9ca31a8372d0c353",
        "report_id": "abc_123"
      }
    }
  }
}
