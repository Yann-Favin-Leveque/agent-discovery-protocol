{
  "name": "account_unmute",
  "resource_group": "accounts",
  "description": "Unmute a given account.",
  "endpoint": "/api/v1/accounts/{id}/unmute",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Account ID.",
      "required": true,
      "in": "path",
      "example": "12345"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://mastodon.social/api/v1/accounts/12345/unmute",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "12345",
      "muting": false
    }
  },
  "auth_scopes": [
    "write:mutes"
  ]
}