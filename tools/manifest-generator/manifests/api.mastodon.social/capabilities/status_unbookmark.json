{
  "name": "status_unbookmark",
  "resource_group": "statuses",
  "description": "Remove a status from your bookmarks.",
  "endpoint": "/api/v1/statuses/{id}/unbookmark",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Status ID.",
      "required": true,
      "in": "path",
      "example": "109876543210"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://mastodon.social/api/v1/statuses/109876543210/unbookmark",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "109876543210",
      "bookmarked": false
    }
  },
  "auth_scopes": [
    "write:bookmarks"
  ]
}