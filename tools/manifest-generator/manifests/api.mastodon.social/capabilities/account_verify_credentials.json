{
  "name": "account_verify_credentials",
  "resource_group": "accounts",
  "description": "Verify the access token and get the authenticated account.",
  "endpoint": "/api/v1/accounts/verify_credentials",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/accounts/verify_credentials",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "12345",
      "username": "myuser",
      "display_name": "My User",
      "note": "<p>My bio</p>",
      "followers_count": 500,
      "following_count": 200,
      "statuses_count": 1200
    }
  },
  "auth_scopes": [
    "read:accounts"
  ]
}