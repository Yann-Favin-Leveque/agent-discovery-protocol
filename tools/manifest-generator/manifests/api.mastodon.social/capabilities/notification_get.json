{
  "name": "notification_get",
  "resource_group": "notifications",
  "description": "View a single notification.",
  "endpoint": "/api/v1/notifications/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Notification ID.",
      "required": true,
      "in": "path",
      "example": "1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/notifications/1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "1",
      "type": "mention",
      "account": {
        "username": "user1"
      }
    }
  },
  "auth_scopes": [
    "read:notifications"
  ]
}