{
  "name": "status_history_get",
  "resource_group": "statuses",
  "description": "View the edit history of a status.",
  "endpoint": "/api/v1/statuses/{id}/history",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Status ID.",
      "required": true,
      "in": "path",
      "example": "109876543210"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/statuses/109876543210/history",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "content": "<p>Original</p>",
        "created_at": "2024-03-01T15:30:00.000Z"
      },
      {
        "content": "<p>Edited</p>",
        "created_at": "2024-03-01T16:00:00.000Z"
      }
    ]
  },
  "auth_scopes": [
    "read:statuses"
  ]
}