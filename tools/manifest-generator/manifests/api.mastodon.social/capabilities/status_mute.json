{
  "name": "status_mute",
  "resource_group": "statuses",
  "description": "Mute notifications for a conversation thread.",
  "endpoint": "/api/v1/statuses/{id}/mute",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Status ID.",
      "required": true,
      "in": "path",
      "example": "109876543210"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://mastodon.social/api/v1/statuses/109876543210/mute",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "109876543210",
      "muted": true
    }
  },
  "auth_scopes": [
    "write:mutes"
  ]
}