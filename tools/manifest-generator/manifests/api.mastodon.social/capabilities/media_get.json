{
  "name": "media_get",
  "resource_group": "media",
  "description": "Get a media attachment to check processing status.",
  "endpoint": "/api/v1/media/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Media attachment ID.",
      "required": true,
      "in": "path",
      "example": "12345"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/media/12345",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "12345",
      "type": "image",
      "url": "https://files.mastodon.social/media/..."
    }
  },
  "auth_scopes": [
    "write:media"
  ]
}