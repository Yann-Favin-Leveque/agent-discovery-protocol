{
  "name": "timeline_public_get",
  "resource_group": "timelines",
  "description": "Fetch the public (local or federated) timeline.",
  "endpoint": "/api/v1/timelines/public",
  "method": "GET",
  "parameters": [
    {
      "name": "local",
      "type": "boolean",
      "description": "Show only local statuses.",
      "required": false,
      "in": "query",
      "example": false
    },
    {
      "name": "remote",
      "type": "boolean",
      "description": "Show only remote statuses.",
      "required": false,
      "in": "query",
      "example": false
    },
    {
      "name": "only_media",
      "type": "boolean",
      "description": "Only statuses with media.",
      "required": false,
      "in": "query",
      "example": false
    },
    {
      "name": "max_id",
      "type": "string",
      "description": "Upper bound.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results (default 20, max 40).",
      "required": false,
      "in": "query",
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/timelines/public?local=true&limit=20",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "109876543210",
        "content": "<p>Public status</p>"
      }
    ]
  },
  "auth_scopes": [
    "read:statuses"
  ]
}