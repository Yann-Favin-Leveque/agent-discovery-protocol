{
  "name": "get_status",
  "description": "Retrieve a single status by its ID. Returns the full status object including content, author details, media attachments, engagement counts, and thread context information.",
  "endpoint": "/api/v1/statuses/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The unique identifier of the status to retrieve.",
      "required": true,
      "example": "110234567890123456"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/statuses/110234567890123456",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "110234567890123456",
      "created_at": "2024-03-01T18:30:00.000Z",
      "content": "<p>Hello Fediverse! Excited to share this update.</p>",
      "visibility": "public",
      "sensitive": false,
      "spoiler_text": "",
      "url": "https://mastodon.social/@myaccount/110234567890123456",
      "account": {
        "id": "109876543210000000",
        "username": "myaccount",
        "display_name": "My Account",
        "avatar": "https://files.mastodon.social/accounts/avatars/original/avatar.png"
      },
      "reblogs_count": 5,
      "favourites_count": 12,
      "replies_count": 3,
      "favourited": false,
      "reblogged": false,
      "bookmarked": false,
      "media_attachments": [],
      "tags": [],
      "application": {
        "name": "AgentDiscovery",
        "website": null
      }
    }
  }
}
