{
  "name": "status_delete",
  "resource_group": "statuses",
  "description": "Delete one of your own statuses.",
  "endpoint": "/api/v1/statuses/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Status ID.",
      "required": true,
      "in": "path",
      "example": "109876543210"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://mastodon.social/api/v1/statuses/109876543210",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "109876543210",
      "text": "Hello Mastodon!"
    }
  },
  "auth_scopes": [
    "write:statuses"
  ]
}