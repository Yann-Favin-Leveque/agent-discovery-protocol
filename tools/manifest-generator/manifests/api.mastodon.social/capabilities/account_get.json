{
  "name": "account_get",
  "resource_group": "accounts",
  "description": "Retrieve profile info for a specific account.",
  "endpoint": "/api/v1/accounts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Account ID.",
      "required": true,
      "in": "path",
      "example": "12345"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/accounts/12345",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "12345",
      "username": "user1",
      "display_name": "User One",
      "followers_count": 500,
      "following_count": 200
    }
  },
  "auth_scopes": [
    "read:accounts"
  ]
}