{
  "name": "account_update_credentials",
  "resource_group": "accounts",
  "description": "Update display name, bio, avatar, and preferences.",
  "endpoint": "/api/v1/accounts/update_credentials",
  "method": "PATCH",
  "parameters": [
    {
      "name": "display_name",
      "type": "string",
      "description": "Display name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "note",
      "type": "string",
      "description": "Account bio.",
      "required": false,
      "in": "body"
    },
    {
      "name": "locked",
      "type": "boolean",
      "description": "Require manual follow approval.",
      "required": false,
      "in": "body"
    },
    {
      "name": "bot",
      "type": "boolean",
      "description": "Bot flag.",
      "required": false,
      "in": "body"
    },
    {
      "name": "discoverable",
      "type": "boolean",
      "description": "Show in directory.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://mastodon.social/api/v1/accounts/update_credentials",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "display_name": "New Name",
      "note": "Updated bio"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "12345",
      "display_name": "New Name",
      "note": "<p>Updated bio</p>"
    }
  },
  "auth_scopes": [
    "write:accounts"
  ]
}