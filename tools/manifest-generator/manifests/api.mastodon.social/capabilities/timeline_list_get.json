{
  "name": "timeline_list_get",
  "resource_group": "timelines",
  "description": "Fetch statuses from a specific list timeline.",
  "endpoint": "/api/v1/timelines/list/{list_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "list_id",
      "type": "string",
      "description": "List ID.",
      "required": true,
      "in": "path",
      "example": "12345"
    },
    {
      "name": "max_id",
      "type": "string",
      "description": "Upper bound.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "in": "query",
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/timelines/list/12345?limit=20",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "109876543210",
        "content": "<p>List status</p>"
      }
    ]
  },
  "auth_scopes": [
    "read:lists"
  ]
}