{
  "name": "get_account",
  "description": "Retrieve profile information for the authenticated user or a specified account by ID. Returns display name, username, bio, avatar, header image, follower and following counts, and account metadata fields.",
  "endpoint": "/api/v1/accounts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The account ID to look up. Use /api/v1/accounts/verify_credentials for the authenticated user.",
      "required": true,
      "example": "109876543210000000"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mastodon.social/api/v1/accounts/109876543210000000",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "109876543210000000",
      "username": "myaccount",
      "acct": "myaccount",
      "display_name": "My Account",
      "note": "<p>Software developer and open source enthusiast.</p>",
      "url": "https://mastodon.social/@myaccount",
      "avatar": "https://files.mastodon.social/accounts/avatars/original/avatar.png",
      "header": "https://files.mastodon.social/accounts/headers/original/header.png",
      "followers_count": 1542,
      "following_count": 387,
      "statuses_count": 2891,
      "created_at": "2022-11-15T00:00:00.000Z",
      "fields": [
        {
          "name": "Website",
          "value": "<a href=\"https://example.com\">example.com</a>"
        },
        {
          "name": "GitHub",
          "value": "<a href=\"https://github.com/myaccount\">github.com/myaccount</a>"
        }
      ]
    }
  }
}
