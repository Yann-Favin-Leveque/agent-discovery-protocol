{
  "name": "collections_add_photo",
  "description": "Add a photo to a collection. Requires write_collections scope.",
  "resource_group": "collections",
  "endpoint": "/collections/{id}/add",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The collection's unique identifier.",
      "in": "path"
    },
    {
      "name": "photo_id",
      "type": "string",
      "required": true,
      "description": "The photo's unique identifier to add.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "write_collections"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.unsplash.com/collections/296/add",
    "headers": {
      "Authorization": "Bearer USER_ACCESS_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "photo_id": "eOLpJytrbsQ"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "photo": {
        "id": "eOLpJytrbsQ"
      },
      "collection": {
        "id": 296,
        "title": "Nature Landscapes"
      }
    }
  }
}
