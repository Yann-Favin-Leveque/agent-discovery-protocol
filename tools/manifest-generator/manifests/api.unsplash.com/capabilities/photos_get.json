{
  "name": "photos_get",
  "description": "Retrieve detailed information about a specific photo by its ID, including EXIF data, location, download links at multiple resolutions, and photographer information.",
  "resource_group": "photos",
  "endpoint": "/photos/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The photo's unique identifier.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/photos/eOLpJytrbsQ",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "eOLpJytrbsQ",
