{
  "name": "users_get_profile",
  "description": "Fetch public profile information for a specific Unsplash user by username.",
  "resource_group": "users",
  "endpoint": "/users/{username}",
  "method": "GET",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "required": true,
      "description": "The user's username.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/users/danielmirlea",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pXhwzz1JtQU",
      "username": "danielmirlea",
      "name": "Daniel Mirlea",
      "bio": "Landscape photographer based in Switzerland",
      "location": "Zurich, Switzerland",
      "total_photos": 234,
      "total_collections": 12,
      "total_likes": 567,
      "portfolio_url": "https://danielmirlea.com",
      "profile_image": {
        "small": "https://images.unsplash.com/profile-pXhwzz1JtQU?w=32",
        "medium": "https://images.unsplash.com/profile-pXhwzz1JtQU?w=64"
      }
    }
  }
}
