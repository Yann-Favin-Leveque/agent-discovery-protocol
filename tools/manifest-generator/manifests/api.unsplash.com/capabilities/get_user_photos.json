{
  "name": "get_user_photos",
  "description": "Retrieve photos uploaded by a specific Unsplash user, identified by their username. Returns paginated results ordered by most recent. Each photo includes URLs for multiple sizes, dimensions, descriptions, and metadata.",
  "endpoint": "/users/{username}/photos",
  "method": "GET",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "required": true,
      "description": "The user's Unsplash username (e.g., 'anniespratt', 'danielmirlea')."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of photos per page. Default: 10. Max: 30."
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "description": "Sort order: 'latest' (default), 'oldest', 'popular', or 'views'."
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "description": "Filter by orientation: 'landscape', 'portrait', or 'squarish'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/users/anniespratt/photos?page=1&per_page=2&order_by=latest",
    "headers": {
      "Authorization": "Client-ID your_access_key_here"
    }
  },
