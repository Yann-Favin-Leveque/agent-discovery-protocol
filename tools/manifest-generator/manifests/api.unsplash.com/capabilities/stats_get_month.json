{
  "name": "stats_get_month",
  "description": "Retrieve platform-wide statistics for Unsplash for the current month.",
  "resource_group": "stats",
  "endpoint": "/stats/month",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/stats/month",
    "headers": { "Authorization": "Client-ID YOUR_ACCESS_KEY" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "downloads": 245000000,
      "views": 2100000000,
      "likes": 35000000,
      "new_photos": 120000,
      "new_photographers": 8500
    }
  }
}