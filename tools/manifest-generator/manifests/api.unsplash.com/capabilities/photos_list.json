{
  "name": "photos_list",
  "description": "Fetch a paginated list of editorial photos curated by Unsplash. Returns abbreviated photo objects with URLs for multiple image sizes.",
  "resource_group": "photos",
  "endpoint": "/photos",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of items per page. Default: 10. Max: 30.",
      "in": "query"
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "description": "Sort order: 'latest', 'oldest', or 'popular'. Default: 'latest'.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/photos?page=1&per_page=5&order_by=latest",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "eOLpJytrbsQ",
        "slug": "golden-sunset-mountains",
        "created_at": "2024-08-15T18:22:03Z",
        "width": 5472,
        "height": 3648,
        "color": "#f57c2e",
        "description": "Golden sunset over mountain range",
        "urls": {
          "raw": "https://images.unsplash.com/photo-eOLpJytrbsQ",
          "full": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=2000",
          "regular": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=1080",
          "small": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=400",
          "thumb": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=200"
        },
        "user": {
          "id": "pXhwzz1JtQU",
          "username": "danielmirlea",
          "name": "Daniel Mirlea"
        }
      }
    ]
  }
}
