{
  "name": "topics_get",
  "description": "Fetch specific topic details by ID or slug.",
  "resource_group": "topics",
  "endpoint": "/topics/{id_or_slug}",
  "method": "GET",
  "parameters": [
    {
      "name": "id_or_slug",
      "type": "string",
      "required": true,
      "description": "The topic's ID or URL slug.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/topics/wallpapers",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "bo8jQKTaE0Y",
      "slug": "wallpapers",
      "title": "Wallpapers",
      "description": "From epic drone shots to scenic snaps...",
      "total_photos": 12540,
      "status": "open",
      "owners": [
        {
          "username": "unsplash",
          "name": "Unsplash"
        }
      ]
    }
  }
}
