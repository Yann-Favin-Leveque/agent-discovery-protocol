{
  "name": "search_photos",
  "description": "Search for photos on Unsplash by keyword query. Returns paginated results with URLs for multiple image sizes (raw, full, regular, small, thumb). Supports filtering by orientation (landscape, portrait, squarish) and dominant color. Results include photographer info, download links, and photo metadata like dimensions and description.",
  "endpoint": "/search/photos",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "The search query. For example: 'mountain sunset', 'office workspace', 'abstract texture'."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of results per page. Default: 10. Max: 30."
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "description": "Filter by orientation: 'landscape', 'portrait', or 'squarish'."
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "description": "Filter by dominant color: 'black_and_white', 'black', 'white', 'yellow', 'orange', 'red', 'purple', 'magenta', 'green', 'teal', 'blue'."
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "description": "Sort order: 'relevant' (default) or 'latest'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/search/photos?query=mountain%20sunset&per_page=2&orientation=landscape",
    "headers": {
      "Authorization": "Client-ID your_access_key_here"
    }
  },
