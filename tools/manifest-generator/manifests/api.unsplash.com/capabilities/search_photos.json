{
  "name": "search_photos",
  "description": "Search for photos by keyword query with filtering by orientation, color, collections, and content filter. Returns paginated results with URLs for multiple image sizes.",
  "resource_group": "search",
  "endpoint": "/search/photos",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "The search query keyword. E.g. 'mountain sunset', 'office workspace'.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of results per page. Default: 10. Max: 30.",
      "in": "query"
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "description": "Sort order: 'relevant' (default) or 'latest'.",
      "in": "query"
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "description": "Filter by orientation: 'landscape', 'portrait', or 'squarish'.",
      "in": "query"
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "description": "Filter by dominant color: 'black_and_white', 'black', 'white', 'yellow', 'orange', 'red', 'purple', 'magenta', 'green', 'teal', 'blue'.",
      "in": "query"
    },
    {
      "name": "collections",
      "type": "string",
      "required": false,
      "description": "Comma-separated collection IDs to narrow results.",
      "in": "query"
    },
    {
      "name": "content_filter",
      "type": "string",
      "required": false,
      "description": "Content safety filter: 'low' (default) or 'high'.",
      "in": "query"
    },
    {
      "name": "lang",
      "type": "string",
      "required": false,
      "description": "ISO 639-1 language code for search query (beta).",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/search/photos?query=mountain%20sunset&per_page=2&orientation=landscape",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total": 8432,
      "total_pages": 4216,
      "results": [
        {
          "id": "eOLpJytrbsQ",
          "description": "Golden sunset casting warm light over a mountain range",
          "urls": {
            "regular": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=1080",
            "small": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=400"
          },
          "user": {
            "username": "danielmirlea",
            "name": "Daniel Mirlea"
          }
        }
      ]
    }
  }
}
