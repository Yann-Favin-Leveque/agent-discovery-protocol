{
  "name": "get_random_photo",
  "description": "Get one or more random photos from Unsplash. Optionally filter by search query, collection ID, topic, featured status, or orientation. When count > 1, returns an array of photos. Useful for generating varied visual content without repeating the same images.",
  "endpoint": "/photos/random",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": false,
      "description": "Filter random photos by search term (e.g., 'nature', 'technology')."
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "description": "Filter by orientation: 'landscape', 'portrait', or 'squarish'."
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Number of random photos to return. Default: 1. Max: 30. When count > 1, response is an array."
    },
    {
      "name": "collections",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of collection IDs to filter from."
    },
    {
      "name": "topics",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of topic IDs to filter from."
    },
    {
      "name": "featured",
      "type": "boolean",
      "required": false,
      "description": "If true, only return photos curated by the Unsplash editorial team."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/photos/random?query=technology&orientation=landscape&count=2",
    "headers": {
      "Authorization": "Client-ID your_access_key_here"
    }
  },
