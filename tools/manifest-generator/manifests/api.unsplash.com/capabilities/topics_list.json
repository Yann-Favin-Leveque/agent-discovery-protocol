{
  "name": "topics_list",
  "description": "Retrieve available editorial topics curated by Unsplash editors.",
  "resource_group": "topics",
  "endpoint": "/topics",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number. Default: 1.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Items per page. Default: 10. Max: 30.",
      "in": "query"
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "description": "Sort order: 'featured' (default) or 'latest'.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/topics?per_page=5&order_by=featured",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "bo8jQKTaE0Y",
        "slug": "wallpapers",
        "title": "Wallpapers",
        "description": "From epic drone shots to scenic snaps...",
        "total_photos": 12540,
        "status": "open"
      }
    ]
  }
}
