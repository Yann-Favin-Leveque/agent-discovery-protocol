{
  "name": "collections_list",
  "description": "Retrieve a paginated list of all public photo collections on Unsplash.",
  "resource_group": "collections",
  "endpoint": "/collections",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of items per page. Default: 10. Max: 30.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/collections?page=1&per_page=10",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 296,
        "title": "Nature Landscapes",
        "description": "Beautiful landscapes from around the world",
        "total_photos": 87,
        "cover_photo": {
          "id": "abc123",
          "urls": {
            "small": "https://images.unsplash.com/photo-abc123?w=400"
          }
        },
        "user": {
          "username": "naturelover",
          "name": "Nature Lover"
        }
      }
    ]
  }
}
