{
  "name": "photos_track_download",
  "description": "Track a photo download event. Required by the Unsplash API Terms to be called when a photo is downloaded or used. Returns the actual download URL.",
  "resource_group": "photos",
  "endpoint": "/photos/{id}/download",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The photo's unique identifier.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/photos/eOLpJytrbsQ/download",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "url": "https://images.unsplash.com/photo-eOLpJytrbsQ?ixlib=rb-4.0.3&dl=eOLpJytrbsQ.jpg"
    }
  }
}
