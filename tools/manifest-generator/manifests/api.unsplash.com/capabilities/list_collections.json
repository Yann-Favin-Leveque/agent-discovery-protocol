{
  "name": "list_collections",
  "description": "List featured photo collections curated by Unsplash editors. Each collection is a group of thematically related photos. Returns collection titles, descriptions, cover photos, total photo counts, and curator information. Useful for browsing curated sets of high-quality images.",
  "endpoint": "/collections",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of collections per page. Default: 10. Max: 30."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/collections?page=1&per_page=3",
    "headers": {
      "Authorization": "Client-ID your_access_key_here"
    }
  },
