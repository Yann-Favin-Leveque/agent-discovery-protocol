{
  "name": "collections_get",
  "description": "Fetch detailed information about a specific photo collection by its ID.",
  "resource_group": "collections",
  "endpoint": "/collections/{id}",
  "method": "GET",
  "parameters": [
    { "name": "id", "type": "string", "required": true, "description": "The collection's unique identifier." }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/collections/296",
    "headers": { "Authorization": "Client-ID YOUR_ACCESS_KEY" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 296,
      "title": "Nature Landscapes",
      "description": "Beautiful landscapes from around the world",
      "published_at": "2024-01-15T10:30:00Z",
      "total_photos": 87,
      "private": false,
      "cover_photo": { "id": "abc123", "urls": { "regular": "https://images.unsplash.com/photo-abc123?w=1080" } },
      "user": { "username": "naturelover", "name": "Nature Lover" }
    }
  }
}