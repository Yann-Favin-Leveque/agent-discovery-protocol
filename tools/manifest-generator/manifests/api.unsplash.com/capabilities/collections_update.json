{
  "name": "collections_update",
  "description": "Update a collection's title, description, or privacy setting. Requires write_collections scope.",
  "resource_group": "collections",
  "endpoint": "/collections/{id}",
  "method": "PUT",
  "parameters": [
    { "name": "id", "type": "string", "required": true, "description": "The collection's unique identifier." },
    { "name": "title", "type": "string", "required": false, "description": "New title for the collection." },
    { "name": "description", "type": "string", "required": false, "description": "New description for the collection." },
    { "name": "private", "type": "boolean", "required": false, "description": "Whether the collection is private." }
  ],
  "auth_scopes": ["write_collections"],
  "request_example": {
    "method": "PUT",
    "url": "https://api.unsplash.com/collections/500",
    "headers": { "Authorization": "Bearer USER_ACCESS_TOKEN", "Content-Type": "application/json" },
    "body": { "title": "Updated Travel Photos", "description": "Updated description" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": 500, "title": "Updated Travel Photos", "description": "Updated description" }
  }
}