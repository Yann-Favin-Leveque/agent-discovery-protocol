{
  "name": "collections_get_related",
  "description": "Retrieve collections related to a specific collection.",
  "resource_group": "collections",
  "endpoint": "/collections/{id}/related",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The collection's unique identifier.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/collections/296/related",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 301,
        "title": "Mountain Views",
        "total_photos": 45
      },
      {
        "id": 415,
        "title": "Wilderness",
        "total_photos": 62
      }
    ]
  }
}
