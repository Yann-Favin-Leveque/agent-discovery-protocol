{
  "name": "photos_update",
  "description": "Update a photo's metadata including description, tags, location, and EXIF data. Requires write_photos scope.",
  "resource_group": "photos",
  "endpoint": "/photos/{id}",
  "method": "PUT",
  "parameters": [
    { "name": "id", "type": "string", "required": true, "description": "The photo's unique identifier." },
    { "name": "description", "type": "string", "required": false, "description": "Updated description for the photo." },
    { "name": "show_on_profile", "type": "boolean", "required": false, "description": "Whether to show the photo on the photographer's profile." },
    { "name": "tags", "type": "array", "required": false, "description": "Array of tag objects to assign to the photo." },
    { "name": "location[latitude]", "type": "number", "required": false, "description": "Latitude of the photo's location." },
    { "name": "location[longitude]", "type": "number", "required": false, "description": "Longitude of the photo's location." },
    { "name": "location[name]", "type": "string", "required": false, "description": "Name of the photo's location." },
    { "name": "location[city]", "type": "string", "required": false, "description": "City of the photo's location." },
    { "name": "location[country]", "type": "string", "required": false, "description": "Country of the photo's location." }
  ],
  "auth_scopes": ["write_photos"],
  "request_example": {
    "method": "PUT",
    "url": "https://api.unsplash.com/photos/eOLpJytrbsQ",
    "headers": { "Authorization": "Bearer USER_ACCESS_TOKEN", "Content-Type": "application/json" },
    "body": { "description": "Stunning sunset over Swiss Alps", "location": { "name": "Swiss Alps", "city": "Zermatt", "country": "Switzerland" } }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "eOLpJytrbsQ", "description": "Stunning sunset over Swiss Alps", "location": { "name": "Swiss Alps", "city": "Zermatt", "country": "Switzerland" } }
  }
}