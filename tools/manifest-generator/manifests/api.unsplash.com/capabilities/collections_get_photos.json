{
  "name": "collections_get_photos",
  "description": "Retrieve photos contained in a specific collection.",
  "resource_group": "collections",
  "endpoint": "/collections/{id}/photos",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The collection's unique identifier.",
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of items per page. Default: 10. Max: 30.",
      "in": "query"
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "description": "Filter by orientation: 'landscape', 'portrait', or 'squarish'.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/collections/296/photos?page=1&per_page=10",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "eOLpJytrbsQ",
        "description": "Mountain sunset",
        "urls": {
          "regular": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=1080"
        },
        "user": {
          "username": "danielmirlea",
          "name": "Daniel Mirlea"
        }
      }
    ]
  }
}
