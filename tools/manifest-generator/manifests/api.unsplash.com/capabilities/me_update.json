{
  "name": "me_update",
  "description": "Update the authenticated user's profile details.",
  "resource_group": "current_user",
  "endpoint": "/me",
  "method": "PUT",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "required": false,
      "description": "New username.",
      "in": "body"
    },
    {
      "name": "first_name",
      "type": "string",
      "required": false,
      "description": "First name.",
      "in": "body"
    },
    {
      "name": "last_name",
      "type": "string",
      "required": false,
      "description": "Last name.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Email address.",
      "in": "body"
    },
    {
      "name": "url",
      "type": "string",
      "required": false,
      "description": "Portfolio/personal URL.",
      "in": "body"
    },
    {
      "name": "location",
      "type": "string",
      "required": false,
      "description": "Location.",
      "in": "body"
    },
    {
      "name": "bio",
      "type": "string",
      "required": false,
      "description": "Bio/about text.",
      "in": "body"
    },
    {
      "name": "instagram_username",
      "type": "string",
      "required": false,
      "description": "Instagram username.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "write_user"
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.unsplash.com/me",
    "headers": {
      "Authorization": "Bearer USER_ACCESS_TOKEN",
      "Content-Type": "application/json"
    },
    "body": {
      "bio": "Landscape and travel photographer",
      "location": "Zurich, Switzerland"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "pXhwzz1JtQU",
      "username": "danielmirlea",
      "bio": "Landscape and travel photographer",
      "location": "Zurich, Switzerland"
    }
  }
}
