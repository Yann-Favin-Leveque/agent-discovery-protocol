{
  "name": "photos_get_random",
  "description": "Get one or more random photos, optionally filtered by search query, collection, topic, orientation, or username. Useful for generating varied visual content.",
  "resource_group": "photos",
  "endpoint": "/photos/random",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": false,
      "description": "Filter by search query keyword.",
      "in": "query"
    },
    {
      "name": "collections",
      "type": "string",
      "required": false,
      "description": "Comma-separated collection IDs to filter by.",
      "in": "query"
    },
    {
      "name": "topics",
      "type": "string",
      "required": false,
      "description": "Comma-separated topic IDs to filter by.",
      "in": "query"
    },
    {
      "name": "username",
      "type": "string",
      "required": false,
      "description": "Filter by a specific photographer's username.",
      "in": "query"
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "description": "Filter by orientation: 'landscape', 'portrait', or 'squarish'.",
      "in": "query"
    },
    {
      "name": "content_filter",
      "type": "string",
      "required": false,
      "description": "Content safety filter: 'low' (default) or 'high'.",
      "in": "query"
    },
    {
      "name": "count",
      "type": "integer",
      "required": false,
      "description": "Number of random photos to return. Default: 1. Max: 30.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/photos/random?query=nature&orientation=landscape&count=3",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "abc123",
        "width": 4000,
        "height": 2667,
        "description": "Mountain lake at dawn",
        "urls": {
          "regular": "https://images.unsplash.com/photo-abc123?w=1080",
          "small": "https://images.unsplash.com/photo-abc123?w=400"
        },
        "user": {
          "username": "naturephotog",
          "name": "Nature Photographer"
        }
      }
    ]
  }
}
