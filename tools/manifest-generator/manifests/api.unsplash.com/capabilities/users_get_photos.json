{
  "name": "users_get_photos",
  "description": "Retrieve photos uploaded by a specific Unsplash user.",
  "resource_group": "users",
  "endpoint": "/users/{username}/photos",
  "method": "GET",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "required": true,
      "description": "The user's username.",
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number. Default: 1.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Items per page. Default: 10. Max: 30.",
      "in": "query"
    },
    {
      "name": "order_by",
      "type": "string",
      "required": false,
      "description": "Sort: 'latest', 'oldest', 'popular', 'views', 'downloads'.",
      "in": "query"
    },
    {
      "name": "orientation",
      "type": "string",
      "required": false,
      "description": "Filter: 'landscape', 'portrait', or 'squarish'.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/users/danielmirlea/photos?per_page=5&order_by=popular",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "eOLpJytrbsQ",
        "description": "Mountain sunset",
        "urls": {
          "regular": "https://images.unsplash.com/photo-eOLpJytrbsQ?w=1080"
        }
      }
    ]
  }
}
