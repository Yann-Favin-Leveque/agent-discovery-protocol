{
  "name": "search_collections",
  "description": "Search for photo collections by keyword query. Returns matching collections with their titles, descriptions, cover photos, total photo counts, and curator information. Use this to find thematically organized sets of photos.",
  "endpoint": "/search/collections",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "The search query for collections (e.g., 'workspace', 'food photography', 'travel')."
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of results per page. Default: 10. Max: 30."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/search/collections?query=workspace&per_page=2",
    "headers": {
      "Authorization": "Client-ID your_access_key_here"
    }
  },
