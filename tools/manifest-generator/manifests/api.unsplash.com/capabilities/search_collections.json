{
  "name": "search_collections",
  "description": "Search for photo collections by keyword query. Returns matching collections with their titles, descriptions, cover photos, and total photo counts.",
  "resource_group": "search",
  "endpoint": "/search/collections",
  "method": "GET",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "The search query keyword.",
      "in": "query"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Default: 1.",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of results per page. Default: 10. Max: 30.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.unsplash.com/search/collections?query=nature&per_page=5",
    "headers": {
      "Authorization": "Client-ID YOUR_ACCESS_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total": 512,
      "total_pages": 103,
      "results": [
        {
          "id": 296,
          "title": "Nature Landscapes",
          "description": "Beautiful landscapes from around the world",
          "total_photos": 87,
          "cover_photo": {
            "id": "abc123",
            "urls": {
              "small": "https://images.unsplash.com/photo-abc123?w=400"
            }
          },
          "user": {
            "username": "naturelover",
            "name": "Nature Lover"
          }
        }
      ]
    }
  }
}
