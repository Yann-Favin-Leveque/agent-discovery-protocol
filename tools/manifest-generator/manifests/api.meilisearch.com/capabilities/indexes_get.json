{
  "name": "indexes_get",
  "description": "Get information about a specific index by its UID.",
  "endpoint": "/indexes/{indexUid}",
  "method": "GET",
  "resource_group": "indexes",
  "parameters": [
    {
      "name": "indexUid",
      "type": "string",
      "description": "UID of the index.",
      "required": true,
      "example": "movies"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.meilisearch.com/indexes/movies",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uid": "movies",
      "primaryKey": "id",
      "createdAt": "2024-01-01T00:00:00Z",
      "updatedAt": "2024-01-01T00:00:00Z"
    }
  },
  "auth_scopes": [
    "indexes.get"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}