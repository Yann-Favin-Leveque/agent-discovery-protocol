{
  "name": "tasks_delete",
  "description": "Delete finished tasks (succeeded, failed, or canceled) matching the given filters.",
  "endpoint": "/tasks",
  "method": "DELETE",
  "resource_group": "tasks",
  "parameters": [
    {
      "name": "uids",
      "type": "string",
      "description": "Comma-separated task UIDs to delete.",
      "required": false,
      "example": "1,2"
    },
    {
      "name": "statuses",
      "type": "string",
      "description": "Delete tasks with these statuses.",
      "required": false,
      "example": "succeeded,failed"
    },
    {
      "name": "types",
      "type": "string",
      "description": "Delete tasks of these types.",
      "required": false,
      "example": "documentAdditionOrUpdate"
    },
    {
      "name": "indexUids",
      "type": "string",
      "description": "Delete tasks for these indexes.",
      "required": false,
      "example": "movies"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.meilisearch.com/tasks?statuses=succeeded",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "taskUid": 13,
      "status": "enqueued",
      "type": "taskDeletion",
      "enqueuedAt": "2024-01-01T00:00:00Z"
    }
  },
  "auth_scopes": [
    "tasks.delete"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}