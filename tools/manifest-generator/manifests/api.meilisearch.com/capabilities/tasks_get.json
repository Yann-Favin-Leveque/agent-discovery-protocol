{
  "name": "tasks_get",
  "description": "Get the status and details of a single task by its UID.",
  "endpoint": "/tasks/{taskUid}",
  "method": "GET",
  "resource_group": "tasks",
  "parameters": [
    {
      "name": "taskUid",
      "type": "integer",
      "description": "UID of the task.",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.meilisearch.com/tasks/1",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "uid": 1,
      "indexUid": "movies",
      "status": "succeeded",
      "type": "documentAdditionOrUpdate",
      "details": {
        "receivedDocuments": 100,
        "indexedDocuments": 100
      },
      "duration": "PT0.5S",
      "enqueuedAt": "2024-01-01T00:00:00Z",
      "startedAt": "2024-01-01T00:00:01Z",
      "finishedAt": "2024-01-01T00:00:01Z"
    }
  },
  "auth_scopes": [
    "tasks.get"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}