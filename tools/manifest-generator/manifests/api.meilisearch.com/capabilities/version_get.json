{
  "name": "version_get",
  "description": "Get the version of the Meilisearch instance, including commit SHA and build date.",
  "endpoint": "/version",
  "method": "GET",
  "resource_group": "system",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.meilisearch.com/version",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "commitSha": "abc123",
      "commitDate": "2024-01-01",
      "pkgVersion": "1.6.0"
    }
  },
  "auth_scopes": [
    "version"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}