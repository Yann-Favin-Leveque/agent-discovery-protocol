{
  "name": "indexes_list",
  "description": "List all indexes in the Meilisearch instance with pagination.",
  "endpoint": "/indexes",
  "method": "GET",
  "resource_group": "indexes",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of indexes to skip.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of indexes to return.",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.meilisearch.com/indexes?offset=0&limit=20",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "uid": "movies",
          "primaryKey": "id",
          "createdAt": "2024-01-01T00:00:00Z",
          "updatedAt": "2024-01-01T00:00:00Z"
        }
      ],
      "offset": 0,
      "limit": 20,
      "total": 1
    }
  },
  "auth_scopes": [
    "indexes.get"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}