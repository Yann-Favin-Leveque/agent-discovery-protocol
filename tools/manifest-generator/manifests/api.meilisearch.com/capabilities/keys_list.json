{
  "name": "keys_list",
  "description": "List all API keys with pagination.",
  "endpoint": "/keys",
  "method": "GET",
  "resource_group": "keys",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of keys to skip.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of keys to return.",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.meilisearch.com/keys?limit=20",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "uid": "abc-123",
          "name": "Default Search API Key",
          "description": "Search-only key",
          "key": "abc123...",
          "actions": [
            "search"
          ],
          "indexes": [
            "*"
          ],
          "expiresAt": null,
          "createdAt": "2024-01-01T00:00:00Z",
          "updatedAt": "2024-01-01T00:00:00Z"
        }
      ],
      "offset": 0,
      "limit": 20,
      "total": 2
    }
  },
  "auth_scopes": [
    "keys.get"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}