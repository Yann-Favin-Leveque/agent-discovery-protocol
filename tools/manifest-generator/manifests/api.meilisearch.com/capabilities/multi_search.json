{
  "name": "multi_search",
  "description": "Execute multiple search queries across one or more indexes in a single HTTP request. Supports federated search to merge results.",
  "endpoint": "/multi-search",
  "method": "POST",
  "resource_group": "search",
  "parameters": [
    {
      "name": "queries",
      "type": "array",
      "description": "Array of search query objects, each with an indexUid and search parameters.",
      "required": true,
      "example": [
        {
          "indexUid": "movies",
          "q": "matrix"
        },
        {
          "indexUid": "books",
          "q": "matrix"
        }
      ],
      "in": "body"
    },
    {
      "name": "federation",
      "type": "object",
      "description": "Federation options to merge results across queries (optional).",
      "required": false,
      "example": {
        "limit": 20
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.meilisearch.com/multi-search",
    "headers": {
      "Authorization": "Bearer MASTER_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "queries": [
        {
          "indexUid": "movies",
          "q": "matrix",
          "limit": 5
        },
        {
          "indexUid": "books",
          "q": "matrix",
          "limit": 5
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "indexUid": "movies",
          "hits": [
            {
              "id": 1,
              "title": "The Matrix"
            }
          ],
          "query": "matrix",
          "processingTimeMs": 1,
          "estimatedTotalHits": 1
        },
        {
          "indexUid": "books",
          "hits": [
            {
              "id": 10,
              "title": "The Matrix Comics"
            }
          ],
          "query": "matrix",
          "processingTimeMs": 1,
          "estimatedTotalHits": 1
        }
      ]
    }
  },
  "auth_scopes": [
    "search"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
