{
  "name": "multi_search",
  "description": "Execute multiple search queries across different Meilisearch indexes in a single HTTP request. Each query can target a different index with its own search parameters. Perfect for building federated search UIs, autocomplete with multiple sources, or aggregated dashboards.",
  "endpoint": "/multi-search",
  "method": "POST",
  "parameters": [
    {
      "name": "queries",
      "type": "array",
      "description": "Array of search query objects. Each must have 'indexUid' and can include any search parameters like 'q', 'filter', 'limit', etc.",
      "required": true,
      "example": [
        {"indexUid": "movies", "q": "inception", "limit": 3},
        {"indexUid": "books", "q": "inception", "limit": 2}
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.meilisearch.com/multi-search",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "queries": [
        {
          "indexUid": "movies",
          "q": "inception",
          "limit": 3,
          "attributesToRetrieve": ["title", "rating"]
        },
        {
          "indexUid": "books",
          "q": "inception",
          "limit": 2,
          "attributesToRetrieve": ["title", "author"]
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "indexUid": "movies",
          "hits": [
            {"title": "Inception", "rating": 4.8}
          ],
          "query": "inception",
          "processingTimeMs": 2,
          "limit": 3,
          "offset": 0,
          "estimatedTotalHits": 1
        },
        {
          "indexUid": "books",
          "hits": [
            {"title": "Inception: The Shooting Script", "author": "Christopher Nolan"}
          ],
          "query": "inception",
          "processingTimeMs": 1,
          "limit": 2,
          "offset": 0,
          "estimatedTotalHits": 1
        }
      ]
    }
  }
}
