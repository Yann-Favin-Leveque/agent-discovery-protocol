{
  "name": "dumps_create",
  "description": "Create a database dump. The dump is a snapshot of the entire Meilisearch data that can be used for backup or migration. Returns an asynchronous task.",
  "endpoint": "/dumps",
  "method": "POST",
  "resource_group": "system",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://api.meilisearch.com/dumps",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "taskUid": 20,
      "status": "enqueued",
      "type": "dumpCreation",
      "enqueuedAt": "2024-01-01T00:00:00Z"
    }
  },
  "auth_scopes": [
    "dumps.create"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}