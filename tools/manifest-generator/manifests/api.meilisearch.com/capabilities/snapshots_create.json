{
  "name": "snapshots_create",
  "description": "Create a snapshot of the Meilisearch database for backup. Returns an asynchronous task.",
  "endpoint": "/snapshots",
  "method": "POST",
  "resource_group": "system",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://api.meilisearch.com/snapshots",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "taskUid": 21,
      "status": "enqueued",
      "type": "snapshotCreation",
      "enqueuedAt": "2024-01-01T00:00:00Z"
    }
  },
  "auth_scopes": [
    "snapshots.create"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}