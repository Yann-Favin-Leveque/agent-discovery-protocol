{
  "name": "documents_add_or_replace",
  "description": "Add new documents or replace existing ones (matched by primary key). Returns an asynchronous task.",
  "endpoint": "/indexes/{indexUid}/documents",
  "method": "POST",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "indexUid",
      "type": "string",
      "description": "UID of the index.",
      "required": true,
      "example": "movies"
    },
    {
      "name": "primaryKey",
      "type": "string",
      "description": "Primary key for the documents (query param, optional if already set).",
      "required": false,
      "example": "id"
    },
    {
      "name": "documents",
      "type": "array",
      "description": "Array of document objects to add or replace.",
      "required": true,
      "example": [
        {
          "id": 1,
          "title": "The Matrix"
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.meilisearch.com/indexes/movies/documents",
    "headers": {
      "Authorization": "Bearer MASTER_KEY",
      "Content-Type": "application/json"
    },
    "body": [
      {
        "id": 1,
        "title": "The Matrix",
        "genre": "action"
      }
    ]
  },
  "response_example": {
    "status": 202,
    "body": {
      "taskUid": 4,
      "indexUid": "movies",
      "status": "enqueued",
      "type": "documentAdditionOrUpdate",
      "enqueuedAt": "2024-01-01T00:00:00Z"
    }
  },
  "auth_scopes": [
    "documents.add"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}