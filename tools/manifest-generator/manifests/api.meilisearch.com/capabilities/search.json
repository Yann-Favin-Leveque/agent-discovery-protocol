{
  "name": "search",
  "description": "Perform a full-text search query on an index with support for filters, facets, sorting, highlighting, geo-search, and pagination.",
  "endpoint": "/indexes/{indexUid}/search",
  "method": "POST",
  "resource_group": "search",
  "parameters": [
    {
      "name": "indexUid",
      "type": "string",
      "description": "UID of the index to search.",
      "required": true,
      "example": "movies"
    },
    {
      "name": "q",
      "type": "string",
      "description": "Search query string.",
      "required": false,
      "example": "matrix"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Number of results to skip.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of results to return (max 1000).",
      "required": false,
      "example": 20
    },
    {
      "name": "hitsPerPage",
      "type": "integer",
      "description": "Number of results per page (for page-based pagination).",
      "required": false,
      "example": 20
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number (1-indexed, for page-based pagination).",
      "required": false,
      "example": 1
    },
    {
      "name": "filter",
      "type": "string",
      "description": "Filter expression (e.g., \"genre = 'action' AND year > 2000\").",
      "required": false,
      "example": "genre = 'action'"
    },
    {
      "name": "facets",
      "type": "array",
      "description": "Array of attributes to use as facets.",
      "required": false,
      "example": [
        "genre",
        "year"
      ]
    },
    {
      "name": "attributesToRetrieve",
      "type": "array",
      "description": "Attributes to include in results.",
      "required": false,
      "example": [
        "id",
        "title",
        "genre"
      ]
    },
    {
      "name": "attributesToCrop",
      "type": "array",
      "description": "Attributes to crop in results.",
      "required": false,
      "example": [
        "overview"
      ]
    },
    {
      "name": "cropLength",
      "type": "integer",
      "description": "Maximum length of cropped values.",
      "required": false,
      "example": 200
    },
    {
      "name": "attributesToHighlight",
      "type": "array",
      "description": "Attributes to highlight search matches in.",
      "required": false,
      "example": [
        "title",
        "overview"
      ]
    },
    {
      "name": "highlightPreTag",
      "type": "string",
      "description": "HTML tag to insert before highlighted text.",
      "required": false,
      "example": "<em>"
    },
    {
      "name": "highlightPostTag",
      "type": "string",
      "description": "HTML tag to insert after highlighted text.",
      "required": false,
      "example": "</em>"
    },
    {
      "name": "showMatchesPosition",
      "type": "boolean",
      "description": "Whether to include match position info.",
      "required": false,
      "example": false
    },
    {
      "name": "sort",
      "type": "array",
      "description": "Attributes and direction to sort results by.",
      "required": false,
      "example": [
        "year:desc"
      ]
    },
    {
      "name": "matchingStrategy",
      "type": "string",
      "description": "Strategy for matching query words: 'last', 'all', or 'frequency'.",
      "required": false,
      "example": "last"
    },
    {
      "name": "showRankingScore",
      "type": "boolean",
      "description": "Whether to include ranking score in results.",
      "required": false,
      "example": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.meilisearch.com/indexes/movies/search",
    "headers": {
      "Authorization": "Bearer MASTER_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "q": "matrix",
      "limit": 10,
      "filter": "genre = 'action'",
      "facets": [
        "genre",
        "year"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hits": [
        {
          "id": 1,
          "title": "The Matrix",
          "genre": "action",
          "_rankingScore": 0.99
        }
      ],
      "offset": 0,
      "limit": 10,
      "estimatedTotalHits": 1,
      "processingTimeMs": 2,
      "query": "matrix",
      "facetDistribution": {
        "genre": {
          "action": 1
        }
      }
    }
  },
  "auth_scopes": [
    "search"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}