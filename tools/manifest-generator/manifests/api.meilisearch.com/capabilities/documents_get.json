{
  "name": "documents_get",
  "description": "Retrieve a single document from an index by its document ID.",
  "endpoint": "/indexes/{indexUid}/documents/{documentId}",
  "method": "GET",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "indexUid",
      "type": "string",
      "description": "UID of the index.",
      "required": true,
      "example": "movies"
    },
    {
      "name": "documentId",
      "type": "string",
      "description": "ID of the document to retrieve.",
      "required": true,
      "example": "1"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields to display.",
      "required": false,
      "example": "id,title"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.meilisearch.com/indexes/movies/documents/1",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "title": "The Matrix",
      "genre": "action",
      "year": 1999
    }
  },
  "auth_scopes": [
    "documents.get"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}