{
  "name": "keys_delete",
  "description": "Delete an API key by its UID or key value.",
  "endpoint": "/keys/{keyUidOrKey}",
  "method": "DELETE",
  "resource_group": "keys",
  "parameters": [
    {
      "name": "keyUidOrKey",
      "type": "string",
      "description": "UID or key value of the API key to delete.",
      "required": true,
      "example": "abc-123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.meilisearch.com/keys/abc-123",
    "headers": {
      "Authorization": "Bearer MASTER_KEY"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "keys.delete"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}