{
  "name": "search_courses",
  "description": "Search the Udemy course catalog by keyword, category, subcategory, or topic. Returns a paginated list of matching courses with titles, prices, ratings, and instructor information. Supports filtering by price, rating, duration, and language.",
  "endpoint": "/api-2.0/courses/",
  "method": "GET",
  "parameters": [
    {
      "name": "search",
      "type": "string",
      "description": "The search keyword or phrase to find courses.",
      "required": false,
      "example": "python machine learning"
    },
    {
      "name": "category",
      "type": "string",
      "description": "Filter by course category name (e.g. 'Development', 'Business').",
      "required": false,
      "example": "Development"
    },
    {
      "name": "subcategory",
      "type": "string",
      "description": "Filter by subcategory name (e.g. 'Web Development', 'Data Science').",
      "required": false,
      "example": "Data Science"
    },
    {
      "name": "price",
      "type": "string",
      "description": "Filter by price: 'price-free' or 'price-paid'.",
      "required": false,
      "example": "price-paid"
    },
    {
      "name": "language",
      "type": "string",
      "description": "Filter by course language code (e.g. 'en', 'es', 'fr').",
      "required": false,
      "example": "en"
    },
    {
      "name": "ordering",
      "type": "string",
      "description": "Sort order: 'relevance', 'most-reviewed', 'highest-rated', 'newest', 'price-low-to-high', 'price-high-to-low'.",
      "required": false,
      "example": "highest-rated"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for pagination (starts at 1).",
      "required": false,
      "example": 1
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Number of results per page (max 100, default 20).",
      "required": false,
      "example": 20
    },
    {
      "name": "fields[course]",
      "type": "string",
      "description": "Comma-separated list of course fields to include in the response (e.g. 'title,url,price,avg_rating').",
      "required": false,
      "example": "title,url,price,avg_rating,num_reviews,num_subscribers,image_480x270"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.udemy.com/api-2.0/courses/?search=python+machine+learning&page_size=5&ordering=highest-rated&fields[course]=title,url,price,avg_rating,num_reviews",
    "headers": {
      "Authorization": "Basic {base64_encoded_client_id:client_secret}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1250,
      "next": "https://www.udemy.com/api-2.0/courses/?page=2&search=python+machine+learning",
      "previous": null,
      "results": [
        {
          "id": 950390,
          "title": "Python for Data Science and Machine Learning Bootcamp",
          "url": "/course/python-for-data-science-and-machine-learning-bootcamp/",
          "price": "$12.99",
          "avg_rating": 4.6,
          "num_reviews": 125000
        }
      ]
    }
  }
}
