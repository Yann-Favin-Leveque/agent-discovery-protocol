{
  "name": "courses_curriculum_list",
  "description": "Retrieve the public curriculum structure of a course including sections, lectures, and content types.",
  "endpoint": "/api-2.0/courses/{course_id}/public-curriculum-items/",
  "method": "GET",
  "resource_group": "courses",
  "parameters": [
    {
      "name": "course_id",
      "type": "integer",
      "description": "The numeric course ID",
      "required": true,
      "example": "1234",
      "in": "path"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": "1",
      "in": "query"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Number of items per page",
      "required": false,
      "example": "50",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.udemy.com/api-2.0/courses/1234/public-curriculum-items/?page_size=50",
    "headers": {
      "Authorization": "Basic {base64_client_id:client_secret}",
      "Accept": "application/json, text/plain, */*"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 185,
      "results": [
        {
          "_class": "chapter",
          "title": "Introduction",
          "sort_order": 1
        },
        {
          "_class": "lecture",
          "title": "Welcome",
          "sort_order": 2,
          "content_summary": "01:30"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
