{
  "name": "transformations_create",
  "resource_group": "transformations",
  "description": "Create a named transformation.",
  "endpoint": "/v1_1/{cloud_name}/transformations",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Transformation name.",
      "in": "body"
    },
    {
      "name": "transformation",
      "type": "string",
      "required": true,
      "description": "Transformation string (e.g. w_200,h_200,c_fill).",
      "in": "body"
    },
    {
      "name": "allowed_for_strict",
      "type": "boolean",
      "required": false,
      "description": "Allow in strict transformations.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudinary.com/v1_1/mycloud/transformations",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "t_thumbnail",
      "transformation": "w_200,h_200,c_fill"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "created"
    }
  }
}
