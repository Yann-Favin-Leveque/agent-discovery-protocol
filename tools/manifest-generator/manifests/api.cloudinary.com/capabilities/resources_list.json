{
  "name": "resources_list",
  "resource_group": "resources",
  "description": "List assets in your Cloudinary account by resource type with pagination.",
  "endpoint": "/v1_1/{cloud_name}/resources/{resource_type}",
  "method": "GET",
  "parameters": [
    {
      "name": "resource_type",
      "type": "string",
      "required": true,
      "description": "Resource type: image, raw, video.",
      "in": "path"
    },
    {
      "name": "type",
      "type": "string",
      "required": false,
      "description": "Sub-type: upload, private, authenticated, fetch."
    },
    {
      "name": "prefix",
      "type": "string",
      "required": false,
      "description": "Filter by public ID prefix (folder)."
    },
    {
      "name": "max_results",
      "type": "integer",
      "required": false,
      "description": "Max results. Default 10, max 500."
    },
    {
      "name": "next_cursor",
      "type": "string",
      "required": false,
      "description": "Pagination cursor."
    },
    {
      "name": "tags",
      "type": "boolean",
      "required": false,
      "description": "Include tags in response."
    },
    {
      "name": "context",
      "type": "boolean",
      "required": false,
      "description": "Include context metadata."
    },
    {
      "name": "moderations",
      "type": "boolean",
      "required": false,
      "description": "Include moderation status."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudinary.com/v1_1/mycloud/resources/image?max_results=20&prefix=products/",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resources": [
        {
          "public_id": "products/my-photo",
          "format": "jpg",
          "version": 1702656000,
          "resource_type": "image",
          "type": "upload",
          "created_at": "2024-01-15T10:30:00Z",
          "bytes": 245000,
          "width": 1200,
          "height": 800,
          "secure_url": "https://res.cloudinary.com/mycloud/image/upload/products/my-photo.jpg"
        }
      ],
      "next_cursor": "abc123"
    }
  }
}