{
  "name": "upload_presets_update",
  "resource_group": "upload_presets",
  "description": "Update an existing upload preset.",
  "endpoint": "/v1_1/{cloud_name}/upload_presets/{name}",
  "method": "PUT",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Preset name.",
      "in": "path"
    },
    {
      "name": "folder",
      "type": "string",
      "required": false,
      "description": "Updated folder."
    },
    {
      "name": "tags",
      "type": "string",
      "required": false,
      "description": "Updated tags."
    },
    {
      "name": "transformation",
      "type": "string",
      "required": false,
      "description": "Updated transformation."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.cloudinary.com/v1_1/mycloud/upload_presets/product_upload",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "folder": "products/new",
      "tags": "product,featured"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "updated"
    }
  }
}