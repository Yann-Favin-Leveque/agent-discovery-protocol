{
  "name": "folders_list_sub",
  "resource_group": "folders",
  "description": "List subfolders within a given folder path.",
  "endpoint": "/v1_1/{cloud_name}/folders/{folder_path}",
  "method": "GET",
  "parameters": [
    {
      "name": "folder_path",
      "type": "string",
      "required": true,
      "description": "Parent folder path.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudinary.com/v1_1/mycloud/folders/products",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "folders": [
        {
          "name": "electronics",
          "path": "products/electronics"
        },
        {
          "name": "clothing",
          "path": "products/clothing"
        }
      ]
    }
  }
}