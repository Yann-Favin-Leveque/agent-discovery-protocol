{
  "name": "metadata_fields_list",
  "resource_group": "metadata",
  "description": "List all structured metadata field definitions.",
  "endpoint": "/v1_1/{cloud_name}/metadata_fields",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudinary.com/v1_1/mycloud/metadata_fields",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "metadata_fields": [
        {
          "external_id": "caption",
          "label": "Caption",
          "type": "string",
          "mandatory": false
        }
      ]
    }
  }
}