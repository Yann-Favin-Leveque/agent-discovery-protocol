{
  "name": "folders_rename",
  "resource_group": "folders",
  "description": "Rename a folder.",
  "endpoint": "/v1_1/{cloud_name}/folders/{folder_path}",
  "method": "PUT",
  "parameters": [
    {
      "name": "folder_path",
      "type": "string",
      "required": true,
      "description": "Current folder path.",
      "in": "path"
    },
    {
      "name": "to_folder",
      "type": "string",
      "required": true,
      "description": "New folder path."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.cloudinary.com/v1_1/mycloud/folders/products/old-name",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "to_folder": "products/new-name"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "from": "products/old-name",
      "to": "products/new-name"
    }
  }
}