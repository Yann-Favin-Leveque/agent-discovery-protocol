{
  "name": "upload_presets_list",
  "resource_group": "upload_presets",
  "description": "List all upload presets.",
  "endpoint": "/v1_1/{cloud_name}/upload_presets",
  "method": "GET",
  "parameters": [
    {
      "name": "max_results",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "next_cursor",
      "type": "string",
      "required": false,
      "description": "Pagination cursor.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudinary.com/v1_1/mycloud/upload_presets",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "presets": [
        {
          "name": "product_upload",
          "unsigned": false,
          "settings": {
            "folder": "products",
            "tags": "product"
          }
        }
      ]
    }
  }
}
