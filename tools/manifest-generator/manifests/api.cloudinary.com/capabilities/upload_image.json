{
  "name": "upload_image",
  "resource_group": "upload",
  "description": "Upload an image to Cloudinary from a URL, file, or base64 string with optional transformations.",
  "endpoint": "/v1_1/{cloud_name}/image/upload",
  "method": "POST",
  "parameters": [
    {
      "name": "file",
      "type": "string",
      "required": true,
      "description": "File to upload: URL, base64 data URI, or file path."
    },
    {
      "name": "public_id",
      "type": "string",
      "required": false,
      "description": "Custom public ID for the asset."
    },
    {
      "name": "folder",
      "type": "string",
      "required": false,
      "description": "Folder path."
    },
    {
      "name": "tags",
      "type": "string",
      "required": false,
      "description": "Comma-separated tags."
    },
    {
      "name": "transformation",
      "type": "string",
      "required": false,
      "description": "Incoming transformation to apply on upload."
    },
    {
      "name": "eager",
      "type": "string",
      "required": false,
      "description": "Eager transformations to generate on upload."
    },
    {
      "name": "resource_type",
      "type": "string",
      "required": false,
      "description": "Type: image, raw, video, auto. Default image."
    },
    {
      "name": "upload_preset",
      "type": "string",
      "required": false,
      "description": "Upload preset name."
    },
    {
      "name": "overwrite",
      "type": "boolean",
      "required": false,
      "description": "Overwrite if public_id exists. Default true."
    },
    {
      "name": "type",
      "type": "string",
      "required": false,
      "description": "Delivery type: upload, private, authenticated."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudinary.com/v1_1/mycloud/image/upload",
    "headers": {
      "Content-Type": "multipart/form-data"
    },
    "body": {
      "file": "https://example.com/photo.jpg",
      "public_id": "my-photo",
      "folder": "products",
      "tags": "product,featured"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "public_id": "products/my-photo",
      "version": 1702656000,
      "signature": "abc123",
      "width": 1200,
      "height": 800,
      "format": "jpg",
      "resource_type": "image",
      "created_at": "2024-01-15T10:30:00Z",
      "bytes": 245000,
      "url": "https://res.cloudinary.com/mycloud/image/upload/v1702656000/products/my-photo.jpg",
      "secure_url": "https://res.cloudinary.com/mycloud/image/upload/v1702656000/products/my-photo.jpg"
    }
  }
}