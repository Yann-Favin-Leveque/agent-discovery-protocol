{
  "name": "folders_delete",
  "resource_group": "folders",
  "description": "Delete an empty folder.",
  "endpoint": "/v1_1/{cloud_name}/folders/{folder_path}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "folder_path",
      "type": "string",
      "required": true,
      "description": "Folder path to delete.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cloudinary.com/v1_1/mycloud/folders/products/old-category",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": [
        "products/old-category"
      ]
    }
  }
}