{
  "name": "folders_list_root",
  "resource_group": "folders",
  "description": "List all root folders in your media library.",
  "endpoint": "/v1_1/{cloud_name}/folders",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudinary.com/v1_1/mycloud/folders",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "folders": [
        {
          "name": "products",
          "path": "products"
        },
        {
          "name": "banners",
          "path": "banners"
        }
      ]
    }
  }
}