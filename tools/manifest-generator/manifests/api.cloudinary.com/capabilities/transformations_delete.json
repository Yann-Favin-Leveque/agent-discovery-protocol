{
  "name": "transformations_delete",
  "resource_group": "transformations",
  "description": "Delete a stored transformation.",
  "endpoint": "/v1_1/{cloud_name}/transformations",
  "method": "DELETE",
  "parameters": [
    {
      "name": "transformation",
      "type": "string",
      "required": true,
      "description": "Transformation name or string to delete."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cloudinary.com/v1_1/mycloud/transformations?transformation=t_thumbnail",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "deleted"
    }
  }
}