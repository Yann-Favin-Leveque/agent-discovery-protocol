{
  "name": "upload_presets_get",
  "resource_group": "upload_presets",
  "description": "Retrieve details of a specific upload preset.",
  "endpoint": "/v1_1/{cloud_name}/upload_presets/{name}",
  "method": "GET",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Preset name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudinary.com/v1_1/mycloud/upload_presets/product_upload",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "product_upload",
      "unsigned": false,
      "settings": {
        "folder": "products",
        "tags": "product",
        "transformation": "w_1200,q_auto"
      }
    }
  }
}