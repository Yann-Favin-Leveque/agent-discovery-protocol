{
  "name": "metadata_fields_update",
  "resource_group": "metadata",
  "description": "Update a metadata field definition.",
  "endpoint": "/v1_1/{cloud_name}/metadata_fields/{field_external_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "field_external_id",
      "type": "string",
      "required": true,
      "description": "Field external ID.",
      "in": "path"
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "description": "Updated label."
    },
    {
      "name": "mandatory",
      "type": "boolean",
      "required": false,
      "description": "Updated mandatory flag."
    },
    {
      "name": "default_value",
      "type": "string",
      "required": false,
      "description": "Updated default value."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.cloudinary.com/v1_1/mycloud/metadata_fields/category",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)",
      "Content-Type": "application/json"
    },
    "body": {
      "label": "Product Category",
      "mandatory": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "external_id": "category",
      "label": "Product Category",
      "mandatory": true
    }
  }
}