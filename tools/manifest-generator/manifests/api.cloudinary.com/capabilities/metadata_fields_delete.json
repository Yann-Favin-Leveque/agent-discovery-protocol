{
  "name": "metadata_fields_delete",
  "resource_group": "metadata",
  "description": "Delete a metadata field definition.",
  "endpoint": "/v1_1/{cloud_name}/metadata_fields/{field_external_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "field_external_id",
      "type": "string",
      "required": true,
      "description": "Field external ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cloudinary.com/v1_1/mycloud/metadata_fields/category",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "deleted"
    }
  }
}