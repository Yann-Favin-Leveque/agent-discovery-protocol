{
  "name": "folders_create",
  "resource_group": "folders",
  "description": "Create a new folder in your media library.",
  "endpoint": "/v1_1/{cloud_name}/folders/{folder_path}",
  "method": "POST",
  "parameters": [
    {
      "name": "folder_path",
      "type": "string",
      "required": true,
      "description": "Full folder path to create.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudinary.com/v1_1/mycloud/folders/products/new-category",
    "headers": {
      "Authorization": "Basic base64(api_key:api_secret)",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "path": "products/new-category",
      "name": "new-category"
    }
  }
}