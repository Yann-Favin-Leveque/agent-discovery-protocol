{
  "name": "files_modify_labels",
  "description": "Modify the set of labels applied to a file.",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/{fileId}/modifyLabels",
  "method": "POST",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "labelModifications",
      "type": "array",
      "description": "Array of label modification requests.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/modifyLabels",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "labelModifications": [
        {
          "labelId": "label123",
          "fieldModifications": []
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "modifiedLabels": []
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
