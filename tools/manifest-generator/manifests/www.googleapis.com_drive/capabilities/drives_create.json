{
  "name": "drives_create",
  "description": "Create a new shared drive.",
  "resource_group": "drives",
  "endpoint": "/drive/v3/drives",
  "method": "POST",
  "parameters": [
    {
      "name": "requestId",
      "type": "string",
      "description": "Unique request ID for idempotency.",
      "required": true,
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Name of the shared drive.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.googleapis.com/drive/v3/drives?requestId=req123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Team Drive"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "drive123",
      "name": "Team Drive"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
