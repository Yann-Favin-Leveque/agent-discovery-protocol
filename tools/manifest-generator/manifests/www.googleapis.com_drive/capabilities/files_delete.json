{
  "name": "files_delete",
  "description": "Permanently delete a file (bypasses trash).",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/{fileId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "supportsAllDrives",
      "type": "boolean",
      "description": "Support shared drives.",
      "required": false
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://www.googleapis.com/drive/v3/files/1abc",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}