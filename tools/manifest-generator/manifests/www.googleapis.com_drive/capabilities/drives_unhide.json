{
  "name": "drives_unhide",
  "description": "Restore a shared drive to the default view.",
  "resource_group": "drives",
  "endpoint": "/drive/v3/drives/{driveId}/unhide",
  "method": "POST",
  "parameters": [
    {
      "name": "driveId",
      "type": "string",
      "description": "The shared drive ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.googleapis.com/drive/v3/drives/drive123/unhide",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "drive123",
      "hidden": false
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}