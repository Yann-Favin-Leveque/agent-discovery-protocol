{
  "name": "replies_update",
  "description": "Update a reply to a comment.",
  "resource_group": "replies",
  "endpoint": "/drive/v3/files/{fileId}/comments/{commentId}/replies/{replyId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "commentId",
      "type": "string",
      "description": "The comment ID.",
      "required": true
    },
    {
      "name": "replyId",
      "type": "string",
      "description": "The reply ID.",
      "required": true
    },
    {
      "name": "content",
      "type": "string",
      "description": "Updated reply text.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/comments/comment1/replies/reply1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "content": "Updated reply"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "reply1",
      "content": "Updated reply"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}