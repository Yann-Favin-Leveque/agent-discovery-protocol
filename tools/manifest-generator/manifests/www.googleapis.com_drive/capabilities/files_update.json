{
  "name": "files_update",
  "description": "Update a file's metadata and/or content.",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/{fileId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Updated description.",
      "required": false,
      "in": "body"
    },
    {
      "name": "mimeType",
      "type": "string",
      "description": "Updated MIME type.",
      "required": false,
      "in": "body"
    },
    {
      "name": "addParents",
      "type": "string",
      "description": "Comma-separated parent IDs to add.",
      "required": false,
      "in": "body"
    },
    {
      "name": "removeParents",
      "type": "string",
      "description": "Comma-separated parent IDs to remove.",
      "required": false,
      "in": "body"
    },
    {
      "name": "trashed",
      "type": "boolean",
      "description": "Move to trash.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://www.googleapis.com/drive/v3/files/1abc",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Renamed File"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "1abc",
      "name": "Renamed File"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
