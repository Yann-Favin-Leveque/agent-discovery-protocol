{
  "name": "revisions_list",
  "description": "List a file's revisions.",
  "resource_group": "revisions",
  "endpoint": "/drive/v3/files/{fileId}/revisions",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "pageSize",
      "type": "integer",
      "description": "Max results.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/revisions",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "revisions": [
        {
          "id": "rev1",
          "modifiedTime": "2024-01-15T12:00:00Z"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}