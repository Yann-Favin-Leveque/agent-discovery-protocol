{
  "name": "files_list_labels",
  "description": "List the labels on a file.",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/{fileId}/listLabels",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "maxResults",
      "type": "integer",
      "description": "Max labels to return.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/listLabels",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "labels": []
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
