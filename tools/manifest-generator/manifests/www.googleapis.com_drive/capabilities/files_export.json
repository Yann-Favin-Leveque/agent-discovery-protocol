{
  "name": "files_export",
  "description": "Export a Google Workspace document to the requested MIME type.",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/{fileId}/export",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "mimeType",
      "type": "string",
      "description": "Target MIME type for export.",
      "required": true,
      "example": "application/pdf"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/export?mimeType=application/pdf",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "<binary content>"
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}