{
  "name": "revisions_get",
  "description": "Get a specific revision's metadata or content.",
  "resource_group": "revisions",
  "endpoint": "/drive/v3/files/{fileId}/revisions/{revisionId}",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "revisionId",
      "type": "string",
      "description": "The revision ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/revisions/rev1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "rev1",
      "modifiedTime": "2024-01-15T12:00:00Z"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}