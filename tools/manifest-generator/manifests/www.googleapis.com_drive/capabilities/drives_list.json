{
  "name": "drives_list",
  "description": "List all shared drives.",
  "resource_group": "drives",
  "endpoint": "/drive/v3/drives",
  "method": "GET",
  "parameters": [
    {
      "name": "pageSize",
      "type": "integer",
      "description": "Max results per page.",
      "required": false
    },
    {
      "name": "pageToken",
      "type": "string",
      "description": "Pagination token.",
      "required": false
    },
    {
      "name": "q",
      "type": "string",
      "description": "Search query.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/drives",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "drives": [
        {
          "id": "drive123",
          "name": "Team Drive"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}