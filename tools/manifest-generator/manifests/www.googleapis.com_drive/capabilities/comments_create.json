{
  "name": "comments_create",
  "description": "Create a comment on a file.",
  "resource_group": "comments",
  "endpoint": "/drive/v3/files/{fileId}/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "content",
      "type": "string",
      "description": "The comment text.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/comments?fields=*",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "content": "Great document!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "comment1",
      "content": "Great document!"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
