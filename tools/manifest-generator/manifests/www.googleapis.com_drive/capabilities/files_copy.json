{
  "name": "files_copy",
  "description": "Create a copy of a file.",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/{fileId}/copy",
  "method": "POST",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID to copy.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "Name for the copy.",
      "required": false
    },
    {
      "name": "parents",
      "type": "array",
      "description": "Parent folder IDs for the copy.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/copy",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Copy of doc.pdf"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "1xyz",
      "name": "Copy of doc.pdf"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}