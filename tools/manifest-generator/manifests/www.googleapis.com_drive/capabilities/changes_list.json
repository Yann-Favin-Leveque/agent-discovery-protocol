{
  "name": "changes_list",
  "description": "List changes to files and shared drives.",
  "resource_group": "changes",
  "endpoint": "/drive/v3/changes",
  "method": "GET",
  "parameters": [
    {
      "name": "pageToken",
      "type": "string",
      "description": "Token from previous list or getStartPageToken.",
      "required": true
    },
    {
      "name": "pageSize",
      "type": "integer",
      "description": "Max results.",
      "required": false
    },
    {
      "name": "spaces",
      "type": "string",
      "description": "Spaces to query.",
      "required": false
    },
    {
      "name": "includeRemoved",
      "type": "boolean",
      "description": "Include removed items.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/changes?pageToken=12345",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "changes": [
        {
          "changeType": "file",
          "fileId": "1abc",
          "removed": false
        }
      ],
      "newStartPageToken": "12346"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}