{
  "name": "about_get",
  "description": "Get information about the user, the user's Drive, and system capabilities.",
  "resource_group": "about",
  "endpoint": "/drive/v3/about",
  "method": "GET",
  "parameters": [
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated list of fields to include.",
      "required": true,
      "example": "user,storageQuota"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/about?fields=user,storageQuota",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "displayName": "John Doe",
        "emailAddress": "john@example.com"
      },
      "storageQuota": {
        "limit": "16106127360",
        "usage": "1234567890"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}