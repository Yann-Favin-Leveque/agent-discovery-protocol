{
  "name": "operations",
  "description": "Manage operations — gets the latest state of a long-running operation. clients can use this method to poll the operation result at intervals as recommended by the api service. Supports standard CRUD operations through the REST API.",
  "endpoint": "/operations/{name}",
  "method": "GET",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "The name of the operation resource.",
      "required": true,
      "example": "Example"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/operations/{name}",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "name": "Example"
      }
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.appdata",
    "https://www.googleapis.com/auth/drive.apps.readonly",
    "https://www.googleapis.com/auth/drive.file",
    "https://www.googleapis.com/auth/drive.meet.readonly"
  ]
}
