{
  "name": "operations_get",
  "description": "Get the latest state of a long-running operation.",
  "resource_group": "operations",
  "endpoint": "/drive/v3/operations/{operationId}",
  "method": "GET",
  "parameters": [
    {
      "name": "operationId",
      "type": "string",
      "description": "The operation name/ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/operations/op123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "op123",
      "done": true
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
