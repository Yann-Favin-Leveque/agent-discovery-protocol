{
  "name": "apps_get",
  "description": "Get a specific installed app.",
  "resource_group": "apps",
  "endpoint": "/drive/v3/apps/{appId}",
  "method": "GET",
  "parameters": [
    {
      "name": "appId",
      "type": "string",
      "description": "The app ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/apps/app1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "app1",
      "name": "Google Docs"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive.apps.readonly"
  ]
}
