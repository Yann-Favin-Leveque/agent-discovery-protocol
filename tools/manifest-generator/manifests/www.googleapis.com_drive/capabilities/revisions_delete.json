{
  "name": "revisions_delete",
  "description": "Permanently delete a file revision.",
  "resource_group": "revisions",
  "endpoint": "/drive/v3/files/{fileId}/revisions/{revisionId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "revisionId",
      "type": "string",
      "description": "The revision ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/revisions/rev1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
