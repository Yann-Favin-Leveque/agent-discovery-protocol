{
  "name": "permissions_list",
  "description": "List all permissions for a file.",
  "resource_group": "permissions",
  "endpoint": "/drive/v3/files/{fileId}/permissions",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Fields to include.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/permissions",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "permissions": [
        {
          "id": "perm123",
          "role": "reader",
          "type": "user"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
