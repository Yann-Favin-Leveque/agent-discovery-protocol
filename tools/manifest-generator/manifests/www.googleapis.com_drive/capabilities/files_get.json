{
  "name": "files_get",
  "description": "Get a file's metadata by ID.",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/{fileId}",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Fields to include.",
      "required": false
    },
    {
      "name": "acknowledgeAbuse",
      "type": "boolean",
      "description": "Acknowledge risk of downloading known malware.",
      "required": false
    },
    {
      "name": "supportsAllDrives",
      "type": "boolean",
      "description": "Support shared drives.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc?fields=id,name,size,mimeType",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "1abc",
      "name": "doc.pdf",
      "size": "1234567",
      "mimeType": "application/pdf"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}