{
  "name": "comments_get",
  "description": "Get a specific comment on a file.",
  "resource_group": "comments",
  "endpoint": "/drive/v3/files/{fileId}/comments/{commentId}",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "commentId",
      "type": "string",
      "description": "The comment ID.",
      "required": true
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Fields to include.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/comments/comment1?fields=*",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "comment1",
      "content": "Great document!"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}