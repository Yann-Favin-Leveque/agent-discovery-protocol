{
  "name": "channels_stop",
  "description": "Stop watching resources through a channel.",
  "resource_group": "channels",
  "endpoint": "/drive/v3/channels/stop",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Channel ID to stop.",
      "required": true,
      "in": "body"
    },
    {
      "name": "resourceId",
      "type": "string",
      "description": "Resource ID from the watch response.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.googleapis.com/drive/v3/channels/stop",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "channel-1",
      "resourceId": "res123"
    }
  },
  "response_example": {
    "status": 204
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
