{
  "name": "files_generate_ids",
  "description": "Generate a set of file IDs for future uploads.",
  "resource_group": "files",
  "endpoint": "/drive/v3/files/generateIds",
  "method": "GET",
  "parameters": [
    {
      "name": "count",
      "type": "integer",
      "description": "Number of IDs to generate (max 1000).",
      "required": false,
      "example": 10,
      "in": "query"
    },
    {
      "name": "space",
      "type": "string",
      "description": "Space: drive or appDataFolder.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/generateIds?count=5",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "ids": [
        "id1",
        "id2",
        "id3",
        "id4",
        "id5"
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
