{
  "name": "changes_watch",
  "description": "Subscribe to push notifications for changes.",
  "resource_group": "changes",
  "endpoint": "/drive/v3/changes/watch",
  "method": "POST",
  "parameters": [
    {
      "name": "pageToken",
      "type": "string",
      "description": "Start page token.",
      "required": true
    },
    {
      "name": "id",
      "type": "string",
      "description": "Unique channel ID.",
      "required": true
    },
    {
      "name": "type",
      "type": "string",
      "description": "Channel type: web_hook.",
      "required": true
    },
    {
      "name": "address",
      "type": "string",
      "description": "Webhook URL.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://www.googleapis.com/drive/v3/changes/watch?pageToken=12345",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "channel-1",
      "type": "web_hook",
      "address": "https://example.com/webhook"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "kind": "api#channel",
      "id": "channel-1"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}