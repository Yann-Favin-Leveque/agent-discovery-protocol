{
  "name": "permissions_delete",
  "description": "Delete a permission from a file.",
  "resource_group": "permissions",
  "endpoint": "/drive/v3/files/{fileId}/permissions/{permissionId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "permissionId",
      "type": "string",
      "description": "The permission ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/permissions/perm123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}