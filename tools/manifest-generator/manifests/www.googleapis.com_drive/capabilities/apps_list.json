{
  "name": "apps_list",
  "description": "List a user's installed apps.",
  "resource_group": "apps",
  "endpoint": "/drive/v3/apps",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/apps",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "app1",
          "name": "Google Docs"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive.apps.readonly"
  ]
}