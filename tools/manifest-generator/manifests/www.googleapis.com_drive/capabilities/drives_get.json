{
  "name": "drives_get",
  "description": "Get a specific shared drive.",
  "resource_group": "drives",
  "endpoint": "/drive/v3/drives/{driveId}",
  "method": "GET",
  "parameters": [
    {
      "name": "driveId",
      "type": "string",
      "description": "The shared drive ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/drives/drive123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "drive123",
      "name": "Team Drive"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
