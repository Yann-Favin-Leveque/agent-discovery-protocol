{
  "name": "replies_list",
  "description": "List all replies to a comment.",
  "resource_group": "replies",
  "endpoint": "/drive/v3/files/{fileId}/comments/{commentId}/replies",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "commentId",
      "type": "string",
      "description": "The comment ID.",
      "required": true
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Fields to include.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/comments/comment1/replies?fields=*",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "replies": [
        {
          "id": "reply1",
          "content": "Thanks!"
        }
      ]
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}