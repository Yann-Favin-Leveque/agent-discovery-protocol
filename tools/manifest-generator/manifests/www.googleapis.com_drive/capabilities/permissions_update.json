{
  "name": "permissions_update",
  "description": "Update a permission for a file.",
  "resource_group": "permissions",
  "endpoint": "/drive/v3/files/{fileId}/permissions/{permissionId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "permissionId",
      "type": "string",
      "description": "The permission ID.",
      "required": true
    },
    {
      "name": "role",
      "type": "string",
      "description": "Updated role.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/permissions/perm123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "role": "writer"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "perm123",
      "role": "writer"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}