{
  "name": "drives_delete",
  "description": "Permanently delete a shared drive (must be empty).",
  "resource_group": "drives",
  "endpoint": "/drive/v3/drives/{driveId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "driveId",
      "type": "string",
      "description": "The shared drive ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://www.googleapis.com/drive/v3/drives/drive123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}