{
  "name": "comments_update",
  "description": "Update a comment on a file.",
  "resource_group": "comments",
  "endpoint": "/drive/v3/files/{fileId}/comments/{commentId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "commentId",
      "type": "string",
      "description": "The comment ID.",
      "required": true
    },
    {
      "name": "content",
      "type": "string",
      "description": "Updated comment text.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/comments/comment1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "content": "Updated comment"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "comment1",
      "content": "Updated comment"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}