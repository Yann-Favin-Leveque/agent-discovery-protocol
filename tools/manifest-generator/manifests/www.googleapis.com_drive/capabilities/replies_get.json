{
  "name": "replies_get",
  "description": "Get a specific reply to a comment.",
  "resource_group": "replies",
  "endpoint": "/drive/v3/files/{fileId}/comments/{commentId}/replies/{replyId}",
  "method": "GET",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "commentId",
      "type": "string",
      "description": "The comment ID.",
      "required": true
    },
    {
      "name": "replyId",
      "type": "string",
      "description": "The reply ID.",
      "required": true
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Fields to include.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/comments/comment1/replies/reply1?fields=*",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "reply1",
      "content": "Thanks!"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}