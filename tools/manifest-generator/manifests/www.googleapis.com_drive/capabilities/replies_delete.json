{
  "name": "replies_delete",
  "description": "Delete a reply to a comment.",
  "resource_group": "replies",
  "endpoint": "/drive/v3/files/{fileId}/comments/{commentId}/replies/{replyId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "fileId",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "commentId",
      "type": "string",
      "description": "The comment ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "replyId",
      "type": "string",
      "description": "The reply ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://www.googleapis.com/drive/v3/files/1abc/comments/comment1/replies/reply1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
