{
  "name": "drives_update",
  "description": "Update a shared drive's metadata.",
  "resource_group": "drives",
  "endpoint": "/drive/v3/drives/{driveId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "driveId",
      "type": "string",
      "description": "The shared drive ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://www.googleapis.com/drive/v3/drives/drive123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Renamed Drive"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "drive123",
      "name": "Renamed Drive"
    }
  },
  "auth_scopes": [
    "https://www.googleapis.com/auth/drive"
  ]
}
