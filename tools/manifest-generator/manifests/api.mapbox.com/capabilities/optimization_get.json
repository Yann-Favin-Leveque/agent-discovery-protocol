{
  "name": "optimization_get",
  "description": "Retrieve the solution for a previously submitted optimization problem.",
  "endpoint": "/optimized-trips/v2/{id}",
  "method": "GET",
  "resource_group": "optimization",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Optimization problem ID.",
      "required": true,
      "example": "opt_abc123"
    },
    {
      "name": "access_token",
      "type": "string",
      "description": "Access token.",
      "required": true,
      "example": "pk.xxx"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mapbox.com/optimized-trips/v2/opt_abc123?access_token=pk.xxx",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "opt_abc123",
      "status": "complete",
      "routes": [
        {
          "vehicle": 0,
          "stops": [
            {
              "location": 0
            },
            {
              "location": 1
            }
          ],
          "distance": 3500,
          "duration": 600
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}