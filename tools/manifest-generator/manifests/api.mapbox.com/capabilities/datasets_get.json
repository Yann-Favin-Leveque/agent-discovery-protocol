{
  "name": "datasets_get",
  "description": "Retrieve information about a specific dataset.",
  "endpoint": "/datasets/v1/{username}/{dataset_id}",
  "method": "GET",
  "resource_group": "datasets",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "description": "Username.",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "dataset_id",
      "type": "string",
      "description": "Dataset ID.",
      "required": true,
      "example": "ds_abc"
    },
    {
      "name": "access_token",
      "type": "string",
      "description": "Access token.",
      "required": true,
      "example": "sk.xxx"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mapbox.com/datasets/v1/myuser/ds_abc?access_token=sk.xxx",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ds_abc",
      "name": "Store Locations",
      "features": 150
    }
  },
  "auth_scopes": [
    "datasets:read"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}