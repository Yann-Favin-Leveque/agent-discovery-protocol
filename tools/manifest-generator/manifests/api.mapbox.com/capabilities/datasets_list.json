{
  "name": "datasets_list",
  "description": "List all datasets for a user account.",
  "endpoint": "/datasets/v1/{username}",
  "method": "GET",
  "resource_group": "datasets",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "description": "Mapbox username.",
      "required": true,
      "example": "myuser"
    },
    {
      "name": "access_token",
      "type": "string",
      "description": "Access token.",
      "required": true,
      "example": "sk.xxx"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mapbox.com/datasets/v1/myuser?access_token=sk.xxx",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "ds_abc",
        "name": "My Dataset",
        "description": "Store locations",
        "features": 150
      }
    ]
  },
  "auth_scopes": [
    "datasets:list"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}