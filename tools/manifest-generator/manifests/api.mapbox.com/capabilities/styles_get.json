{
  "name": "styles_get",
  "description": "Retrieve a specific map style document.",
  "endpoint": "/styles/v1/{username}/{style_id}",
  "method": "GET",
  "resource_group": "styles",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "description": "Mapbox username.",
      "required": true,
      "example": "mapbox",
      "in": "path"
    },
    {
      "name": "style_id",
      "type": "string",
      "description": "Style ID.",
      "required": true,
      "example": "streets-v12",
      "in": "path"
    },
    {
      "name": "access_token",
      "type": "string",
      "description": "Access token.",
      "required": true,
      "example": "pk.xxx",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mapbox.com/styles/v1/mapbox/streets-v12?access_token=pk.xxx",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "version": 8,
      "name": "Streets",
      "sources": {},
      "layers": []
    }
  },
  "auth_scopes": [
    "styles:read"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
