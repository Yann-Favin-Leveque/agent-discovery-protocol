{
  "name": "styles_list",
  "description": "List all map styles for a user account.",
  "endpoint": "/styles/v1/{username}",
  "method": "GET",
  "resource_group": "styles",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "description": "Mapbox username.",
      "required": true,
      "example": "mapbox"
    },
    {
      "name": "access_token",
      "type": "string",
      "description": "Access token.",
      "required": true,
      "example": "pk.xxx"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mapbox.com/styles/v1/mapbox?access_token=pk.xxx",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "version": 8,
        "name": "Streets",
        "id": "streets-v12",
        "created": "2024-01-01",
        "modified": "2024-03-01"
      }
    ]
  },
  "auth_scopes": [
    "styles:list"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}