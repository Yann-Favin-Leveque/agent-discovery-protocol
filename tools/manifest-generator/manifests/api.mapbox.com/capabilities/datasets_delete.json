{
  "name": "datasets_delete",
  "description": "Delete a dataset.",
  "endpoint": "/datasets/v1/{username}/{dataset_id}",
  "method": "DELETE",
  "resource_group": "datasets",
  "parameters": [
    {
      "name": "username",
      "type": "string",
      "description": "Username.",
      "required": true,
      "example": "myuser",
      "in": "path"
    },
    {
      "name": "dataset_id",
      "type": "string",
      "description": "Dataset ID.",
      "required": true,
      "example": "ds_abc",
      "in": "path"
    },
    {
      "name": "access_token",
      "type": "string",
      "description": "Access token.",
      "required": true,
      "example": "sk.xxx",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mapbox.com/datasets/v1/myuser/ds_abc?access_token=sk.xxx",
    "headers": {}
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [
    "datasets:write"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
