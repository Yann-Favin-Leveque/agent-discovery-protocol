{
  "name": "lists_get",
  "description": "Retrieve a single contact list by ID.",
  "resource_group": "lists",
  "endpoint": "/v3/marketing/lists/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "List ID.",
      "required": true,
      "example": "list-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/marketing/lists/list-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "list-123",
      "name": "Newsletter",
      "contact_count": 500
    }
  }
}
