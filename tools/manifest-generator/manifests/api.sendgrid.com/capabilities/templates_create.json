{
  "name": "templates_create",
  "description": "Create a new email template.",
  "resource_group": "templates",
  "endpoint": "/v3/templates",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Template name.",
      "required": true,
      "example": "Welcome Email"
    },
    {
      "name": "generation",
      "type": "string",
      "description": "Template generation: legacy or dynamic.",
      "required": false,
      "example": "dynamic"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.sendgrid.com/v3/templates",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Welcome Email",
      "generation": "dynamic"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "d-abc123",
      "name": "Welcome Email",
      "generation": "dynamic"
    }
  }
}