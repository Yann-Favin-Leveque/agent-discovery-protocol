{
  "name": "lists_create",
  "description": "Create a new contact list.",
  "resource_group": "lists",
  "endpoint": "/v3/marketing/lists",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "List name.",
      "required": true,
      "example": "Newsletter Subscribers",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.sendgrid.com/v3/marketing/lists",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Newsletter Subscribers"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "list-123",
      "name": "Newsletter Subscribers",
      "contact_count": 0
    }
  }
}
