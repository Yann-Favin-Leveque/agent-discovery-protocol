      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": [
        {
          "id": "abc123",
          "email": "user@example.com",
          "first_name": "John"
        }
      ],
      "contact_count": 100
    }
  }
}