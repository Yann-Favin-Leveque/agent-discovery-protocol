{
  "name": "contacts_get",
  "description": "Retrieve a single contact by ID.",
  "resource_group": "contacts",
  "endpoint": "/v3/marketing/contacts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Contact ID.",
      "required": true,
      "example": "abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/marketing/contacts/abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "email": "user@example.com",
      "first_name": "John"
    }
  }
}