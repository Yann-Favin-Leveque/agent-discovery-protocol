{
  "name": "senders_create",
  "description": "Create a new verified sender identity.",
  "resource_group": "senders",
  "endpoint": "/v3/verified_senders",
  "method": "POST",
  "parameters": [
    {
      "name": "from_email",
      "type": "string",
      "description": "Sender email.",
      "required": true,
      "example": "sender@example.com"
    },
    {
      "name": "from_name",
      "type": "string",
      "description": "Sender name.",
      "required": true,
      "example": "My App"
    },
    {
      "name": "reply_to",
      "type": "string",
      "description": "Reply-to email.",
      "required": true,
      "example": "reply@example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.sendgrid.com/v3/verified_senders",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "from_email": "sender@example.com",
      "from_name": "My App",
      "reply_to": "reply@example.com"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 123,
      "from_email": "sender@example.com"
    }
  }
}