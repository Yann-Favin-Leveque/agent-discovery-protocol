{
  "name": "templates_get",
  "description": "Retrieve a single template by ID.",
  "resource_group": "templates",
  "endpoint": "/v3/templates/{template_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "d-abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/templates/d-abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "d-abc123",
      "name": "Welcome Email",
      "versions": []
    }
  }
}