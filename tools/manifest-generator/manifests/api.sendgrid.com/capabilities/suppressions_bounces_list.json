{
  "name": "suppressions_bounces_list",
  "description": "Retrieve all email addresses on the bounce list.",
  "resource_group": "suppressions",
  "endpoint": "/v3/suppression/bounces",
  "method": "GET",
  "parameters": [
    {
      "name": "start_time",
      "type": "number",
      "description": "Start of date range (Unix timestamp).",
      "required": false,
      "in": "query"
    },
    {
      "name": "end_time",
      "type": "number",
      "description": "End of date range (Unix timestamp).",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/suppression/bounces",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "email": "bounce@example.com",
        "created": 1234567890,
        "reason": "550 User unknown",
        "status": "5.1.1"
      }
    ]
  }
}
