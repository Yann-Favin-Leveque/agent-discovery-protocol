{
  "name": "lists_update",
  "description": "Update a contact list name.",
  "resource_group": "lists",
  "endpoint": "/v3/marketing/lists/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "List ID.",
      "required": true,
      "example": "list-123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": true,
      "example": "Updated List",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.sendgrid.com/v3/marketing/lists/list-123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated List"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "list-123",
      "name": "Updated List"
    }
  }
}
