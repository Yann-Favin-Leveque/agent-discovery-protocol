{
  "name": "templates_list",
  "description": "Retrieve all email templates.",
  "resource_group": "templates",
  "endpoint": "/v3/templates",
  "method": "GET",
  "parameters": [
    {
      "name": "generations",
      "type": "string",
      "description": "Filter by generation: legacy or dynamic.",
      "required": false,
      "example": "dynamic"
    },
    {
      "name": "page_size",
      "type": "number",
      "description": "Number of templates per page.",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/templates?generations=dynamic",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": [
        {
          "id": "d-abc123",
          "name": "Welcome Email",
          "generation": "dynamic"
        }
      ]
    }
  }
}