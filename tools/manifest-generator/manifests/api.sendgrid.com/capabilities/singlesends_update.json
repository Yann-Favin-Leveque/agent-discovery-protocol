{
  "name": "singlesends_update",
  "description": "Update a Single Send.",
  "resource_group": "singlesends",
  "endpoint": "/v3/marketing/singlesends/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Single Send ID.",
      "required": true,
      "example": "ss-123"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.sendgrid.com/v3/marketing/singlesends/ss-123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Campaign"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ss-123"
    }
  }
}