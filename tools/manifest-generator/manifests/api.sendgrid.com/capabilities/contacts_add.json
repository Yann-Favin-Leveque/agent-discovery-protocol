{
  "name": "contacts_add",
  "description": "Add or update contacts in Marketing Contacts. Supports up to 30,000 contacts per request.",
  "resource_group": "contacts",
  "endpoint": "/v3/marketing/contacts",
  "method": "PUT",
  "parameters": [
    {
      "name": "contacts",
      "type": "array",
      "description": "Array of contact objects.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.sendgrid.com/v3/marketing/contacts",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "contacts": [
        {
          "email": "user@example.com",
          "first_name": "John"
        }
      ]
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "job_id": "abc123"
    }
  }
}
