{
  "name": "singlesends_get",
  "description": "Retrieve a Single Send by ID.",
  "resource_group": "singlesends",
  "endpoint": "/v3/marketing/singlesends/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Single Send ID.",
      "required": true,
      "example": "ss-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/marketing/singlesends/ss-123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ss-123",
      "name": "March Newsletter",
      "status": "draft"
    }
  }
}
