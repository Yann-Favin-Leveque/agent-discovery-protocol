{
  "name": "templates_update",
  "description": "Update a template name.",
  "resource_group": "templates",
  "endpoint": "/v3/templates/{template_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "description": "Template ID.",
      "required": true,
      "example": "d-abc123"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": true,
      "example": "Updated Template"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.sendgrid.com/v3/templates/d-abc123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Template"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "d-abc123",
      "name": "Updated Template"
    }
  }
}