{
  "name": "suppressions_bounces_delete",
  "description": "Remove an email address from the bounce list.",
  "resource_group": "suppressions",
  "endpoint": "/v3/suppression/bounces/{email}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Email to remove.",
      "required": true,
      "example": "bounce@example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sendgrid.com/v3/suppression/bounces/bounce@example.com",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
