{
  "name": "contacts_delete",
  "description": "Delete one or more contacts by ID.",
  "resource_group": "contacts",
  "endpoint": "/v3/marketing/contacts",
  "method": "DELETE",
  "parameters": [
    {
      "name": "ids",
      "type": "string",
      "description": "Comma-separated list of contact IDs.",
      "required": true,
      "example": "abc123,def456"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.sendgrid.com/v3/marketing/contacts?ids=abc123,def456",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "job_id": "del123"
    }
  }
}