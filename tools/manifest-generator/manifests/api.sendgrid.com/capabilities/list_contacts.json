{
  "name": "list_contacts",
  "description": "Retrieve a paginated list of all contacts from your Marketing Contacts database. Returns contact details including email addresses, names, custom fields, metadata, and status. Use pagination to handle large contact lists efficiently.",
  "endpoint": "/v3/marketing/contacts",
  "method": "GET",
  "parameters": [
    {
      "name": "page_size",
      "type": "integer",
      "description": "Number of contacts to return per page. Maximum 500. Default is 100.",
      "required": false,
      "example": 100
    },
    {
      "name": "page_token",
      "type": "string",
      "description": "Token for pagination. Use the token from the previous response's '_metadata.next' field to fetch the next page of results.",
      "required": false,
      "example": "MTIzNDU2Nzg5MA=="
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/marketing/contacts?page_size=50",
    "headers": {
      "Authorization": "Bearer SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": [
        {
          "id": "abc123def456",
          "email": "john@example.com",
          "first_name": "John",
          "last_name": "Doe",
          "phone_number": "+1234567890",
          "created_at": "2024-01-15T10:30:00Z",
          "updated_at": "2024-02-01T15:45:00Z",
          "custom_fields": {
            "company": "Acme Corp",
            "subscription_tier": "premium"
          },
          "alternate_emails": []
        },
        {
          "id": "xyz789abc123",
          "email": "jane@example.com",
          "first_name": "Jane",
          "last_name": "Smith",
          "phone_number": "+0987654321",
          "created_at": "2024-01-20T09:15:00Z",
          "updated_at": "2024-02-03T12:30:00Z",
          "custom_fields": {
            "company": "Tech Startup",
            "subscription_tier": "standard"
          },
          "alternate_emails": []
        }
      ],
      "_metadata": {
        "prev": null,
        "self": "/v3/marketing/contacts?page_size=50",
        "next": "MTIzNDU2Nzg5MA=="
      }
    }
  }
}
