{
  "name": "lists_list",
  "description": "Retrieve all contact lists.",
  "resource_group": "lists",
  "endpoint": "/v3/marketing/lists",
  "method": "GET",
  "parameters": [
    {
      "name": "page_size",
      "type": "number",
      "description": "Number of lists per page.",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/marketing/lists",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": [
        {
          "id": "list-123",
          "name": "Newsletter",
          "contact_count": 500
        }
      ]
    }
  }
}