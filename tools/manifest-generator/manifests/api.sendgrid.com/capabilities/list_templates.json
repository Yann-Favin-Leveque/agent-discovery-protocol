{
  "name": "list_templates",
  "description": "Retrieve all email templates in your account. Discover available templates, get template IDs, versions, and metadata. Useful for building reusable email layouts and finding templates for programmatic sending.",
  "endpoint": "/v3/templates",
  "method": "GET",
  "parameters": [
    {
      "name": "generations",
      "type": "string",
      "description": "Filter templates by generation type. Use 'dynamic' for Dynamic Templates or 'legacy' for legacy templates. Default returns all.",
      "required": false,
      "example": "dynamic"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Number of templates to return per page. Maximum 200. Default is 50.",
      "required": false,
      "example": 50
    },
    {
      "name": "page_token",
      "type": "string",
      "description": "Token for pagination. Use the token from the previous response to fetch the next page.",
      "required": false,
      "example": "MTIzNDU2Nzg5MA=="
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.sendgrid.com/v3/templates?generations=dynamic&page_size=50",
    "headers": {
      "Authorization": "Bearer SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
  },
