{
  "spec_version": "1.0",
  "name": "SendGrid",
  "description": "Cloud-based email delivery platform for transactional and marketing emails with templates, contact management, and analytics.",
  "base_url": "https://api.sendgrid.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://app.sendgrid.com/settings/api_keys"
  },
  "capabilities": [
    {
      "name": "mail_send",
      "description": "Send an email to one or more recipients with personalization, templates, attachments, and scheduling.",
      "detail_url": "/capabilities/mail_send",
      "resource_group": "mail"
    },
    {
      "name": "contacts_list",
      "description": "Retrieve all contacts from Marketing Contacts.",
      "detail_url": "/capabilities/contacts_list",
      "resource_group": "contacts"
    },
    {
      "name": "contacts_add",
      "description": "Add or update contacts in Marketing Contacts.",
      "detail_url": "/capabilities/contacts_add",
      "resource_group": "contacts"
    },
    {
      "name": "contacts_search",
      "description": "Search contacts using SGQL query syntax.",
      "detail_url": "/capabilities/contacts_search",
      "resource_group": "contacts"
    },
    {
      "name": "contacts_get",
      "description": "Retrieve a single contact by ID.",
      "detail_url": "/capabilities/contacts_get",
      "resource_group": "contacts"
    },
    {
      "name": "contacts_delete",
      "description": "Delete one or more contacts by ID.",
      "detail_url": "/capabilities/contacts_delete",
      "resource_group": "contacts"
    },
    {
      "name": "contacts_count",
      "description": "Get the total number of contacts.",
      "detail_url": "/capabilities/contacts_count",
      "resource_group": "contacts"
    },
    {
      "name": "lists_list",
      "description": "Retrieve all contact lists.",
      "detail_url": "/capabilities/lists_list",
      "resource_group": "lists"
    },
    {
      "name": "lists_create",
      "description": "Create a new contact list.",
      "detail_url": "/capabilities/lists_create",
      "resource_group": "lists"
    },
    {
      "name": "lists_get",
      "description": "Retrieve a single contact list by ID.",
      "detail_url": "/capabilities/lists_get",
      "resource_group": "lists"
    },
    {
      "name": "lists_update",
      "description": "Update a contact list name.",
      "detail_url": "/capabilities/lists_update",
      "resource_group": "lists"
    },
    {
      "name": "lists_delete",
      "description": "Delete a contact list.",
      "detail_url": "/capabilities/lists_delete",
      "resource_group": "lists"
    },
    {
      "name": "singlesends_list",
      "description": "Retrieve all Single Sends (marketing campaigns).",
      "detail_url": "/capabilities/singlesends_list",
      "resource_group": "singlesends"
    },
    {
      "name": "singlesends_create",
      "description": "Create a new Single Send campaign.",
      "detail_url": "/capabilities/singlesends_create",
      "resource_group": "singlesends"
    },
    {
      "name": "singlesends_get",
      "description": "Retrieve a Single Send by ID.",
      "detail_url": "/capabilities/singlesends_get",
      "resource_group": "singlesends"
    },
    {
      "name": "singlesends_update",
      "description": "Update a Single Send.",
      "detail_url": "/capabilities/singlesends_update",
      "resource_group": "singlesends"
    },
    {
      "name": "singlesends_delete",
      "description": "Delete a Single Send.",
      "detail_url": "/capabilities/singlesends_delete",
      "resource_group": "singlesends"
    },
    {
      "name": "singlesends_schedule",
      "description": "Schedule a Single Send for delivery.",
      "detail_url": "/capabilities/singlesends_schedule",
      "resource_group": "singlesends"
    },
    {
      "name": "templates_list",
      "description": "Retrieve all email templates.",
      "detail_url": "/capabilities/templates_list",
      "resource_group": "templates"
    },
    {
      "name": "templates_create",
      "description": "Create a new email template.",
      "detail_url": "/capabilities/templates_create",
      "resource_group": "templates"
    },
    {
      "name": "templates_get",
      "description": "Retrieve a single template by ID.",
      "detail_url": "/capabilities/templates_get",
      "resource_group": "templates"
    },
    {
      "name": "templates_update",
      "description": "Update a template name.",
      "detail_url": "/capabilities/templates_update",
      "resource_group": "templates"
    },
    {
      "name": "templates_delete",
      "description": "Delete a template.",
      "detail_url": "/capabilities/templates_delete",
      "resource_group": "templates"
    },
    {
      "name": "stats_global",
      "description": "Retrieve global email statistics for a date range.",
      "detail_url": "/capabilities/stats_global",
      "resource_group": "stats"
    },
    {
      "name": "suppressions_bounces_list",
      "description": "Retrieve all email addresses on the bounce list.",
      "detail_url": "/capabilities/suppressions_bounces_list",
      "resource_group": "suppressions"
    },
    {
      "name": "suppressions_bounces_delete",
      "description": "Remove an email address from the bounce list.",
      "detail_url": "/capabilities/suppressions_bounces_delete",
      "resource_group": "suppressions"
    },
    {
      "name": "suppressions_blocks_list",
      "description": "Retrieve all blocked email addresses.",
      "detail_url": "/capabilities/suppressions_blocks_list",
      "resource_group": "suppressions"
    },
    {
      "name": "suppressions_unsubscribes_list",
      "description": "Retrieve all global unsubscribes.",
      "detail_url": "/capabilities/suppressions_unsubscribes_list",
      "resource_group": "suppressions"
    },
    {
      "name": "senders_list",
      "description": "Retrieve all verified sender identities.",
      "detail_url": "/capabilities/senders_list",
      "resource_group": "senders"
    },
    {
      "name": "senders_create",
      "description": "Create a new verified sender identity.",
      "detail_url": "/capabilities/senders_create",
      "resource_group": "senders"
    },
    {
      "name": "api_keys_list",
      "description": "Retrieve all API keys.",
      "detail_url": "/capabilities/api_keys_list",
      "resource_group": "api_keys"
    },
    {
      "name": "api_keys_create",
      "description": "Create a new API key.",
      "detail_url": "/capabilities/api_keys_create",
      "resource_group": "api_keys"
    },
    {
      "name": "api_keys_delete",
      "description": "Delete an API key.",
      "detail_url": "/capabilities/api_keys_delete",
      "resource_group": "api_keys"
    }
  ]
}