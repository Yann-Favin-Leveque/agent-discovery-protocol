{
  "name": "body_fat_log_get",
  "description": "Retrieve body fat percentage log entries for a date or range.",
  "resource_group": "body",
  "endpoint": "/1/user/-/body/log/fat/date/{date}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "Date YYYY-MM-DD or {start}/{end}.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "weight"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/body/log/fat/date/2025-01-15.json",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "fat": [
        {
          "logId": 5678,
          "date": "2025-01-15",
          "fat": 18.3
        }
      ]
    }
  }
}