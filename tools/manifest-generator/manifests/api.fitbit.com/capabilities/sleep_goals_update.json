{
  "name": "sleep_goals_update",
  "description": "Update the user's sleep goal to a new target minutes of sleep per night.",
  "resource_group": "sleep",
  "endpoint": "/1.2/user/-/sleep/goal.json",
  "method": "POST",
  "parameters": [
    { "name": "minDuration", "type": "integer", "required": true, "description": "Target sleep duration in minutes." }
  ],
  "auth_scopes": ["sleep"],
  "request_example": {
    "method": "POST",
    "url": "https://api.fitbit.com/1.2/user/-/sleep/goal.json",
    "headers": { "Authorization": "Bearer eyJhbGciOiJIUzI1NiJ9...", "Content-Type": "application/x-www-form-urlencoded" },
    "body": { "minDuration": 480 }
  },
  "response_example": {
    "status": 200,
    "body": { "goal": { "minDuration": 480, "updatedOn": "2025-01-15" } }
  }
}
