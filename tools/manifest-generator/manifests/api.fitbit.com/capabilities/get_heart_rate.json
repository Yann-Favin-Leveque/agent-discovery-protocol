{
  "name": "get_heart_rate",
  "description": "Retrieve heart rate time series data for the authenticated user. Returns resting heart rate and time spent in each heart rate zone (Out of Range, Fat Burn, Cardio, Peak) for a specific date or date range. Each zone includes min/max BPM thresholds, minutes spent, and calories burned. Use period values like '1d', '7d', '30d', '1w', '1m' for date ranges.",
  "endpoint": "/1/user/-/activities/heart/date/{date}/{period}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "The start date in YYYY-MM-DD format or 'today'."
    },
    {
      "name": "period",
      "type": "string",
      "required": true,
      "description": "The time period to retrieve. One of: '1d', '7d', '30d', '1w', '1m'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/activities/heart/date/2025-01-15/1d.json",
    "headers": {
      "Authorization": "Bearer eyJhbGciOiJIUzI1NiJ9..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "activities-heart": [
        {
          "dateTime": "2025-01-15",
          "value": {
            "restingHeartRate": 62,
            "heartRateZones": [
              {
                "name": "Out of Range",
                "min": 30,
                "max": 97,
                "minutes": 1200,
                "caloriesBurned": 1024.5
              },
              {
                "name": "Fat Burn",
                "min": 97,
                "max": 136,
                "minutes": 45,
                "caloriesBurned": 312.8
              },
              {
                "name": "Cardio",
                "min": 136,
                "max": 170,
                "minutes": 22,
                "caloriesBurned": 198.3
              },
              {
                "name": "Peak",
                "min": 170,
                "max": 220,
                "minutes": 5,
                "caloriesBurned": 62.1
              }
            ]
          }
        }
      ]
    }
  }
}
