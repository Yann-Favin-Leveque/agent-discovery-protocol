{
  "name": "nutrition_water_log_create",
  "description": "Log water intake.",
  "resource_group": "nutrition",
  "endpoint": "/1/user/-/foods/log/water.json",
  "method": "POST",
  "parameters": [
    {
      "name": "amount",
      "type": "number",
      "required": true,
      "description": "Water amount in ml."
    },
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "Date YYYY-MM-DD."
    }
  ],
  "auth_scopes": [
    "nutrition"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.fitbit.com/1/user/-/foods/log/water.json",
    "headers": {
      "Authorization": "Bearer TOKEN",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "amount": 500,
      "date": "2025-01-15"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "waterLog": {
        "logId": 3002,
        "amount": 500
      }
    }
  }
}