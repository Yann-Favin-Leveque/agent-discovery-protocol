{
  "name": "nutrition_water_log_get",
  "description": "Retrieve water intake log for a date.",
  "resource_group": "nutrition",
  "endpoint": "/1/user/-/foods/log/water/date/{date}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "Date YYYY-MM-DD.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "nutrition"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/foods/log/water/date/2025-01-15.json",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "water": [
        {
          "logId": 3001,
          "amount": 500
        }
      ],
      "summary": {
        "water": 2000
      }
    }
  }
}