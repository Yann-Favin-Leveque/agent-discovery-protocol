{
  "name": "activity_goals_get",
  "description": "Retrieve a user's current daily or weekly activity goals including targets for steps, distance, calories out, active minutes, and floors.",
  "resource_group": "activity",
  "endpoint": "/1/user/-/activities/goals/{period}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "period",
      "type": "string",
      "required": true,
      "description": "The goal period: 'daily' or 'weekly'.",
      "in": "path"
    }
  ],
  "auth_scopes": ["activity"],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/activities/goals/daily.json",
    "headers": { "Authorization": "Bearer eyJhbGciOiJIUzI1NiJ9..." }
  },
  "response_example": {
    "status": 200,
    "body": {
      "goals": {
        "steps": 10000,
        "caloriesOut": 2500,
        "distance": 8.05,
        "floors": 10,
        "activeMinutes": 30
      }
    }
  }
}
