{
  "name": "body_weight_log_get",
  "description": "Retrieve body weight log entries for a specific date or date range.",
  "resource_group": "body",
  "endpoint": "/1/user/-/body/log/weight/date/{date}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "Date in YYYY-MM-DD or {start}/{end} format.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "weight"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/body/log/weight/date/2025-01-15.json",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "weight": [
        {
          "logId": 1234,
          "date": "2025-01-15",
          "weight": 75.5,
          "bmi": 24.2
        }
      ]
    }
  }
}