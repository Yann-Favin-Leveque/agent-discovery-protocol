{
  "name": "activity_goals_update",
  "description": "Update a user's daily or weekly activity goals. Provide one or more goal values to update.",
  "resource_group": "activity",
  "endpoint": "/1/user/-/activities/goals/{period}.json",
  "method": "POST",
  "parameters": [
    { "name": "period", "type": "string", "required": true, "description": "The goal period: 'daily' or 'weekly'.", "in": "path" },
    { "name": "steps", "type": "integer", "required": false, "description": "Step goal." },
    { "name": "distance", "type": "number", "required": false, "description": "Distance goal." },
    { "name": "caloriesOut", "type": "integer", "required": false, "description": "Calories out goal." },
    { "name": "floors", "type": "integer", "required": false, "description": "Floors goal." },
    { "name": "activeMinutes", "type": "integer", "required": false, "description": "Active minutes goal." }
  ],
  "auth_scopes": ["activity"],
  "request_example": {
    "method": "POST",
    "url": "https://api.fitbit.com/1/user/-/activities/goals/daily.json",
    "headers": { "Authorization": "Bearer eyJhbGciOiJIUzI1NiJ9...", "Content-Type": "application/x-www-form-urlencoded" },
    "body": { "steps": 12000 }
  },
  "response_example": {
    "status": 200,
    "body": { "goals": { "steps": 12000, "caloriesOut": 2500, "distance": 8.05, "floors": 10, "activeMinutes": 30 } }
  }
}
