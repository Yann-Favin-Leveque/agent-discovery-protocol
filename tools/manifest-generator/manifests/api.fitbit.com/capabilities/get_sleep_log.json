{
  "name": "get_sleep_log",
  "description": "Retrieve the authenticated user's sleep log for a specific date. Returns detailed sleep data including total time asleep, time in bed, sleep efficiency percentage, and a breakdown of sleep stages (deep, light, REM, awake) with durations in minutes. Each sleep entry includes start time, end time, and whether it was the main sleep or a nap.",
  "endpoint": "/1.2/user/-/sleep/date/{date}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "The date to retrieve sleep data for, in YYYY-MM-DD format or 'today'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1.2/user/-/sleep/date/2025-01-15.json",
    "headers": {
      "Authorization": "Bearer eyJhbGciOiJIUzI1NiJ9..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sleep": [
        {
          "logId": 38472916345,
          "dateOfSleep": "2025-01-15",
          "startTime": "2025-01-14T23:12:00.000",
          "endTime": "2025-01-15T07:05:00.000",
          "duration": 28380000,
          "minutesToFallAsleep": 8,
          "minutesAsleep": 436,
          "minutesAwake": 37,
          "minutesAfterWakeup": 2,
          "timeInBed": 473,
          "efficiency": 92,
          "type": "stages",
          "isMainSleep": true,
          "levels": {
            "summary": {
              "deep": { "count": 4, "minutes": 82 },
              "light": { "count": 28, "minutes": 214 },
              "rem": { "count": 6, "minutes": 108 },
              "wake": { "count": 18, "minutes": 37 }
            }
          }
        }
      ],
      "summary": {
        "totalMinutesAsleep": 436,
        "totalSleepRecords": 1,
        "totalTimeInBed": 473
      }
    }
  }
}
