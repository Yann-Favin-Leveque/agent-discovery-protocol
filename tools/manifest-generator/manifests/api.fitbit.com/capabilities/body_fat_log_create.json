{
  "name": "body_fat_log_create",
  "description": "Create a body fat percentage log entry.",
  "resource_group": "body",
  "endpoint": "/1/user/-/body/log/fat.json",
  "method": "POST",
  "parameters": [
    {
      "name": "fat",
      "type": "number",
      "required": true,
      "description": "Body fat percentage.",
      "in": "body"
    },
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "Date YYYY-MM-DD.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "weight"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.fitbit.com/1/user/-/body/log/fat.json",
    "headers": {
      "Authorization": "Bearer TOKEN",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "fat": 18.3,
      "date": "2025-01-15"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "fatLog": {
        "logId": 5678,
        "fat": 18.3
      }
    }
  }
}
