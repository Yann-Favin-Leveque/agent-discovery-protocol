{
  "name": "user_profile_update",
  "description": "Update user profile (name, gender, birthday, height, weight, timezone).",
  "resource_group": "user",
  "endpoint": "/1/user/-/profile.json",
  "method": "POST",
  "parameters": [
    {
      "name": "gender",
      "type": "string",
      "required": false,
      "description": "MALE, FEMALE, or NA.",
      "in": "body"
    },
    {
      "name": "birthday",
      "type": "string",
      "required": false,
      "description": "DOB YYYY-MM-DD.",
      "in": "body"
    },
    {
      "name": "height",
      "type": "number",
      "required": false,
      "description": "Height in cm.",
      "in": "body"
    },
    {
      "name": "weight",
      "type": "number",
      "required": false,
      "description": "Weight in kg.",
      "in": "body"
    },
    {
      "name": "timezone",
      "type": "string",
      "required": false,
      "description": "Timezone string.",
      "in": "body"
    },
    {
      "name": "fullName",
      "type": "string",
      "required": false,
      "description": "Display name.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "profile"
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.fitbit.com/1/user/-/profile.json",
    "headers": {
      "Authorization": "Bearer TOKEN",
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": {
      "height": 170
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "encodedId": "ABC123",
        "height": 170
      }
    }
  }
}
