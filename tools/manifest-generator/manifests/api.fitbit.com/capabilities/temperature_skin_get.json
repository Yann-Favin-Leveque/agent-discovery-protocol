{
  "name": "temperature_skin_get",
  "description": "Retrieve skin temperature variation data (deviation from baseline).",
  "resource_group": "temperature",
  "endpoint": "/1/user/-/temp/skin/date/{date}.json",
  "method": "GET",
  "parameters": [
    {
      "name": "date",
      "type": "string",
      "required": true,
      "description": "Date YYYY-MM-DD or {start}/{end}.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "temperature"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/temp/skin/date/2025-01-15.json",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tempSkin": [
        {
          "dateTime": "2025-01-15",
          "value": {
            "nightlyRelative": 0.12
          }
        }
      ]
    }
  }
}