{
  "name": "devices_list",
  "description": "Retrieve Fitbit devices paired to the account with battery and sync info.",
  "resource_group": "devices",
  "endpoint": "/1/user/-/devices.json",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "settings"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/devices.json",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "ABC123",
        "deviceVersion": "Charge 5",
        "type": "TRACKER",
        "battery": "High",
        "batteryLevel": 85,
        "lastSyncTime": "2025-01-15T08:30:00.000"
      }
    ]
  }
}