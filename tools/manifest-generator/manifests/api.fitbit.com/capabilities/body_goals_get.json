{
  "name": "body_goals_get",
  "description": "Retrieve body weight or fat goals.",
  "resource_group": "body",
  "endpoint": "/1/user/-/body/log/{goal-type}/goal.json",
  "method": "GET",
  "parameters": [
    {
      "name": "goal-type",
      "type": "string",
      "required": true,
      "description": "Goal type: weight or fat.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "weight"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.fitbit.com/1/user/-/body/log/weight/goal.json",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "goal": {
        "goalType": "LOSE",
        "startWeight": 80,
        "weight": 72
      }
    }
  }
}