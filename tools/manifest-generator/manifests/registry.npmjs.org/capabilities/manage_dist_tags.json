{
  "name": "manage_dist_tags",
  "description": "Add, remove, or list distribution tags (like 'latest', 'next', 'beta') for an npm package.",
  "endpoint": "/-/package/{package_name}/dist-tags",
  "method": "GET",
  "parameters": [
    {"name": "package_name", "type": "string", "description": "Package name.", "required": true, "example": "express"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://registry.npmjs.org/-/package/express/dist-tags",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"latest": "4.18.2", "next": "5.0.0-beta.1"}
  }
}
