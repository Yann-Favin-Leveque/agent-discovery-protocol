{
  "name": "downloads_point",
  "description": "Get download count for a package at a specific point.",
  "resource_group": "downloads",
  "endpoint": "/downloads/point/{period}/{package}",
  "method": "GET",
  "parameters": [
    {
      "name": "period",
      "type": "string",
      "required": true,
      "description": "Time period: last-day, last-week, last-month, or YYYY-MM-DD:YYYY-MM-DD.",
      "in": "path"
    },
    {
      "name": "package",
      "type": "string",
      "required": true,
      "description": "Package name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.npmjs.org/downloads/point/last-month/express"
  },
  "response_example": {
    "downloads": 50000000,
    "start": "2025-12-21",
    "end": "2026-01-20",
    "package": "express"
  }
}
