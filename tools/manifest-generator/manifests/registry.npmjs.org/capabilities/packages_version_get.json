{
  "name": "packages_version_get",
  "description": "Get metadata for a specific package version.",
  "resource_group": "packages",
  "endpoint": "/{package}/{version}",
  "method": "GET",
  "parameters": [
    {
      "name": "package",
      "type": "string",
      "required": true,
      "description": "Package name."
    },
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "Semver version or 'latest'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://registry.npmjs.org/express/4.21.0"
  },
  "response_example": {
    "name": "express",
    "version": "4.21.0",
    "description": "Fast web framework",
    "main": "index.js",
    "dependencies": {
      "accepts": "~1.3.8",
      "body-parser": "1.20.2"
    },
    "dist": {
      "tarball": "https://registry.npmjs.org/express/-/express-4.21.0.tgz",
      "shasum": "abc123"
    }
  }
}