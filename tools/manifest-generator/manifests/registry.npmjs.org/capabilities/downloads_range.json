{
  "name": "downloads_range",
  "description": "Get daily download counts over a range.",
  "resource_group": "downloads",
  "endpoint": "/downloads/range/{period}/{package}",
  "method": "GET",
  "parameters": [
    {
      "name": "period",
      "type": "string",
      "required": true,
      "description": "Time period: last-week, last-month, or date range.",
      "in": "path"
    },
    {
      "name": "package",
      "type": "string",
      "required": true,
      "description": "Package name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.npmjs.org/downloads/range/last-week/express"
  },
  "response_example": {
    "downloads": [
      {
        "downloads": 1500000,
        "day": "2026-01-14"
      },
      {
        "downloads": 1600000,
        "day": "2026-01-15"
      }
    ],
    "start": "2026-01-14",
    "end": "2026-01-20",
    "package": "express"
  }
}
