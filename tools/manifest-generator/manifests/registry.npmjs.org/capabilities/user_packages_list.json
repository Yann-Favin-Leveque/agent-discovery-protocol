{
  "name": "user_packages_list",
  "description": "List packages maintained by a user.",
  "resource_group": "user",
  "endpoint": "/-/v1/search",
  "method": "GET",
  "parameters": [
    {
      "name": "maintainer",
      "type": "string",
      "required": true,
      "description": "Username to search packages for.",
      "in": "query"
    },
    {
      "name": "size",
      "type": "integer",
      "required": false,
      "description": "Result count.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://registry.npmjs.org/-/v1/search?text=maintainer:sindresorhus&size=10"
  },
  "response_example": {
    "objects": [
      {
        "package": {
          "name": "got",
          "version": "14.0.0",
          "description": "HTTP request library"
        }
      }
    ],
    "total": 100
  }
}
