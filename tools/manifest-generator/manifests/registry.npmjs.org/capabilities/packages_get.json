{
  "name": "packages_get",
  "description": "Get full metadata for an npm package including all versions.",
  "resource_group": "packages",
  "endpoint": "/{package}",
  "method": "GET",
  "parameters": [
    {
      "name": "package",
      "type": "string",
      "required": true,
      "description": "Package name (e.g., express, @scope/name).",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://registry.npmjs.org/express"
  },
  "response_example": {
    "name": "express",
    "description": "Fast web framework",
    "dist-tags": {
      "latest": "4.21.0"
    },
    "versions": {
      "4.21.0": {
        "name": "express",
        "version": "4.21.0",
        "dependencies": {
          "accepts": "~1.3.8"
        }
      }
    },
    "time": {
      "created": "2010-12-29T19:38:25.450Z",
      "modified": "2026-01-15T00:00:00Z"
    }
  }
}
