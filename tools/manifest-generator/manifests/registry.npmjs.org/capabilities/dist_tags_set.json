{
  "name": "dist_tags_set",
  "description": "Set a distribution tag on a package.",
  "resource_group": "packages",
  "endpoint": "/dist-tags/{package}/{tag}",
  "method": "PUT",
  "parameters": [
    {
      "name": "package",
      "type": "string",
      "required": true,
      "description": "Package name.",
      "in": "path"
    },
    {
      "name": "tag",
      "type": "string",
      "required": true,
      "description": "Tag name (e.g., latest, beta).",
      "in": "path"
    },
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "Version to tag.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://registry.npmjs.org/-/package/express/dist-tags/beta",
    "body": "\"5.0.0-beta.1\""
  },
  "response_example": {
    "ok": true
  }
}
