{
  "name": "search_packages",
  "description": "Search the npm registry for packages matching a query string with optional filters.",
  "endpoint": "/-/v1/search",
  "method": "GET",
  "parameters": [
    {"name": "text", "type": "string", "description": "Search query text.", "required": true, "example": "express"},
    {"name": "size", "type": "number", "description": "Number of results to return (max 250).", "required": false, "example": 20},
    {"name": "from", "type": "number", "description": "Offset for pagination.", "required": false, "example": 0},
    {"name": "quality", "type": "number", "description": "Weight for quality score (0-1).", "required": false, "example": 0.65},
    {"name": "popularity", "type": "number", "description": "Weight for popularity score (0-1).", "required": false, "example": 0.98}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://registry.npmjs.org/-/v1/search?text=express&size=20",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {"total": 5000, "objects": [{"package": {"name": "express", "version": "4.18.2", "description": "Fast, unopinionated, minimalist web framework", "links": {"npm": "https://www.npmjs.com/package/express"}, "publisher": {"username": "dougwilson"}}, "score": {"final": 0.95}}]}
  }
}
