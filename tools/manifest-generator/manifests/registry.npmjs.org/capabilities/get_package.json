{
  "name": "get_package",
  "description": "Get full metadata for an npm package including all versions, maintainers, and repository info.",
  "endpoint": "/{package_name}",
  "method": "GET",
  "parameters": [
    {"name": "package_name", "type": "string", "description": "Full package name (scoped packages use %2f for /).", "required": true, "example": "express"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://registry.npmjs.org/express",
    "headers": {"Accept": "application/json"}
  },
  "response_example": {
    "status": 200,
    "body": {"name": "express", "description": "Fast, unopinionated, minimalist web framework", "dist-tags": {"latest": "4.18.2"}, "versions": {"4.18.2": {"name": "express", "version": "4.18.2", "dependencies": {"accepts": "~1.3.8"}}}, "maintainers": [{"name": "dougwilson", "email": "doug@somethingdoug.com"}]}
  }
}
