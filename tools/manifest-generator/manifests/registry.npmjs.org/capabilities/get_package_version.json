{
  "name": "get_package_version",
  "description": "Get metadata for a specific version of an npm package.",
  "endpoint": "/{package_name}/{version}",
  "method": "GET",
  "parameters": [
    {"name": "package_name", "type": "string", "description": "Package name.", "required": true, "example": "express"},
    {"name": "version", "type": "string", "description": "Specific semver version.", "required": true, "example": "4.18.2"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://registry.npmjs.org/express/4.18.2",
    "headers": {"Accept": "application/json"}
  },
  "response_example": {
    "status": 200,
    "body": {"name": "express", "version": "4.18.2", "description": "Fast, unopinionated, minimalist web framework", "main": "index.js", "dependencies": {"accepts": "~1.3.8", "body-parser": "1.20.1"}, "dist": {"tarball": "https://registry.npmjs.org/express/-/express-4.18.2.tgz", "integrity": "sha512-..."}}
  }
}
