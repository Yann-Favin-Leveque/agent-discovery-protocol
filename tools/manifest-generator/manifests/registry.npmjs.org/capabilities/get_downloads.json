{
  "name": "get_downloads",
  "description": "Get download count statistics for a package over a specific time period.",
  "endpoint": "/downloads/point/{period}/{package_name}",
  "method": "GET",
  "parameters": [
    {"name": "period", "type": "string", "description": "Time period: last-day, last-week, last-month, or date range (YYYY-MM-DD:YYYY-MM-DD).", "required": true, "example": "last-month"},
    {"name": "package_name", "type": "string", "description": "Package name.", "required": true, "example": "express"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.npmjs.org/downloads/point/last-month/express",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {"downloads": 30000000, "start": "2024-01-01", "end": "2024-01-31", "package": "express"}
  }
}
