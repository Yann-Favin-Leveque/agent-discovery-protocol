{
  "name": "directions_geojson",
  "description": "Calculate a route and return the result in GeoJSON format.",
  "endpoint": "/v2/directions/{profile}/geojson",
  "method": "POST",
  "resource_group": "directions",
  "parameters": [
    {
      "name": "profile",
      "type": "string",
      "description": "Routing profile",
      "required": true,
      "example": "foot-walking",
      "in": "path"
    },
    {
      "name": "coordinates",
      "type": "array",
      "description": "Array of [longitude, latitude] coordinate pairs",
      "required": true,
      "example": [
        [
          8.681495,
          49.41461
        ],
        [
          8.687872,
          49.420318
        ]
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.openrouteservice.org/v2/directions/{profile}/geojson",
    "headers": {
      "Authorization": "{api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "coordinates": [
        [
          8.681495,
          49.41461
        ],
        [
          8.687872,
          49.420318
        ]
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "FeatureCollection",
      "features": []
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 40
  }
}
