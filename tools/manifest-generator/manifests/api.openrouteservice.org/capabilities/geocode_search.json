{
  "name": "geocode_search",
  "description": "Convert an address or place name into geographic coordinates (forward geocoding).",
  "endpoint": "/geocode/search",
  "method": "GET",
  "resource_group": "geocoding",
  "parameters": [
    {
      "name": "text",
      "type": "string",
      "description": "Address or place name to search",
      "required": true,
      "example": "Heidelberg, Germany"
    },
    {
      "name": "boundary.country",
      "type": "string",
      "description": "ISO 3166-1 alpha-2/3 country code to restrict results",
      "required": false,
      "example": "DE"
    },
    {
      "name": "size",
      "type": "integer",
      "description": "Maximum number of results",
      "required": false,
      "example": 5
    },
    {
      "name": "focus.point.lon",
      "type": "number",
      "description": "Longitude to bias results toward",
      "required": false,
      "example": 8.681495
    },
    {
      "name": "focus.point.lat",
      "type": "number",
      "description": "Latitude to bias results toward",
      "required": false,
      "example": 49.41461
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.openrouteservice.org/geocode/search",
    "headers": {
      "Authorization": "{api_key}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "FeatureCollection",
      "features": [
        {
          "type": "Feature",
          "geometry": {
            "type": "Point",
            "coordinates": [
              8.6946,
              49.4058
            ]
          },
          "properties": {
            "name": "Heidelberg",
            "country": "Germany"
          }
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 40
  }
}