{
  "name": "document_status_get",
  "description": "Check the translation status of an uploaded document. Returns status, estimated time remaining, and billed characters when done.",
  "resource_group": "documents",
  "endpoint": "/v2/document/{document_id}",
  "method": "POST",
  "parameters": [
    {
      "name": "document_id",
      "type": "string",
      "required": true,
      "description": "Document ID from upload.",
      "in": "path"
    },
    {
      "name": "document_key",
      "type": "string",
      "required": true,
      "description": "Document key from upload.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.deepl.com/v2/document/doc123",
    "headers": {
      "Authorization": "DeepL-Auth-Key your-api-key-here",
      "Content-Type": "application/json"
    },
    "body": {
      "document_key": "key456"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "document_id": "doc123",
      "status": "done",
      "billed_characters": 1500
    }
  }
}
