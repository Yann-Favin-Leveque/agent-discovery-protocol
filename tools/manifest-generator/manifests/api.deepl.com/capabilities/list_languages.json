{
  "name": "list_languages",
  "description": "Retrieve the list of languages supported by the DeepL API for either source or target translation. Returns language codes and names to validate translation pairs before submitting requests.",
  "endpoint": "/v2/languages",
  "method": "GET",
  "parameters": [
    {
      "name": "type",
      "type": "string",
      "description": "Filter by language direction: 'source' or 'target'. Returns both if omitted.",
      "required": false,
      "example": "target"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepl.com/v2/languages?type=target",
    "headers": {
      "Authorization": "DeepL-Auth-Key your-api-key"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "language": "DE",
        "name": "German",
        "supports_formality": true
      },
      {
        "language": "FR",
        "name": "French",
        "supports_formality": true
      },
      {
        "language": "JA",
        "name": "Japanese",
        "supports_formality": true
      },
      {
        "language": "ES",
        "name": "Spanish",
        "supports_formality": true
      }
    ]
  }
}
