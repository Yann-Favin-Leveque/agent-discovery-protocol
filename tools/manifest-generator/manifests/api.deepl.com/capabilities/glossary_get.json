{
  "name": "glossary_get",
  "description": "Retrieve metadata for a specific glossary, omitting the glossary entries.",
  "resource_group": "glossaries",
  "endpoint": "/v2/glossaries/{glossary_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "glossary_id",
      "type": "string",
      "required": true,
      "description": "Glossary ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepl.com/v2/glossaries/gls123",
    "headers": {
      "Authorization": "DeepL-Auth-Key your-api-key-here"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "glossary_id": "gls123",
      "name": "Tech Terms",
      "ready": true,
      "source_lang": "EN",
      "target_lang": "DE",
      "entry_count": 2
    }
  }
}
