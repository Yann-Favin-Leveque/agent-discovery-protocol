{
  "name": "languages_list",
  "description": "Retrieve the list of supported source and target languages with their language codes and formality support.",
  "resource_group": "languages",
  "endpoint": "/v2/languages",
  "method": "GET",
  "parameters": [
    {"name": "type", "type": "string", "required": false, "description": "Filter by type: 'source' or 'target' (default 'source')."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.deepl.com/v2/languages?type=target",
    "headers": {"Authorization": "DeepL-Auth-Key your-api-key-here"}
  },
  "response_example": {
    "status": 200,
    "body": [
      {"language": "DE", "name": "German", "supports_formality": true},
      {"language": "EN-GB", "name": "English (British)", "supports_formality": false},
      {"language": "FR", "name": "French", "supports_formality": true}
    ]
  }
}
