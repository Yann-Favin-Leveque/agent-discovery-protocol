{
  "name": "translate_document",
  "description": "Upload and translate entire documents while preserving their formatting and layout. Supports PDF, DOCX, PPTX, XLSX, HTML, TXT, and other common file formats.",
  "endpoint": "/v2/document",
  "method": "POST",
  "parameters": [
    {
      "name": "file",
      "type": "file",
      "description": "The document file to translate (multipart/form-data upload).",
      "required": true,
      "example": "document.docx"
    },
    {
      "name": "target_lang",
      "type": "string",
      "description": "Target language code for translation.",
      "required": true,
      "example": "FR"
    },
    {
      "name": "source_lang",
      "type": "string",
      "description": "Source language code. Auto-detected if omitted.",
      "required": false,
      "example": "EN"
    },
    {
      "name": "formality",
      "type": "string",
      "description": "Desired formality level: 'default', 'more', 'less', 'prefer_more', 'prefer_less'.",
      "required": false,
      "example": "default"
    },
    {
      "name": "glossary_id",
      "type": "string",
      "description": "ID of a custom glossary for consistent terminology.",
      "required": false,
      "example": "def3a26b-3e84-45b3-84ae-0c0aaf3525f7"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.deepl.com/v2/document",
    "headers": {
      "Authorization": "DeepL-Auth-Key your-api-key",
      "Content-Type": "multipart/form-data"
    },
    "body": {
      "file": "(binary file content)",
      "target_lang": "FR"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "document_id": "4BA7B5244B9F4CE0",
      "document_key": "D2C7B1A3E8F04A56B9E3C4D5F6A7B8C9"
    }
  }
}
