{
  "name": "document_download",
  "description": "Download the translated document after processing is complete. The document is automatically removed after download.",
  "resource_group": "documents",
  "endpoint": "/v2/document/{document_id}/result",
  "method": "POST",
  "parameters": [
    {"name": "document_id", "type": "string", "required": true, "description": "Document ID."},
    {"name": "document_key", "type": "string", "required": true, "description": "Document key."}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.deepl.com/v2/document/doc123/result",
    "headers": {"Authorization": "DeepL-Auth-Key your-api-key-here", "Content-Type": "application/json"},
    "body": {"document_key": "key456"}
  },
  "response_example": {"status": 200, "body": "Binary document content"}
}
