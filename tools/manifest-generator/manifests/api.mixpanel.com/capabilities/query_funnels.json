{
  "name": "query_funnels",
  "description": "Analyze a conversion funnel with multiple steps.",
  "resource_group": "query",
  "endpoint": "/funnels",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "description": "Project ID",
      "location": "query",
      "in": "query"
    },
    {
      "name": "funnel_id",
      "type": "integer",
      "required": true,
      "description": "Funnel ID",
      "location": "query",
      "in": "query"
    },
    {
      "name": "from_date",
      "type": "string",
      "required": true,
      "description": "Start date",
      "location": "query",
      "in": "query"
    },
    {
      "name": "to_date",
      "type": "string",
      "required": true,
      "description": "End date",
      "location": "query",
      "in": "query"
    },
    {
      "name": "length",
      "type": "integer",
      "required": false,
      "description": "Funnel completion window in days",
      "location": "query",
      "in": "query"
    },
    {
      "name": "unit",
      "type": "string",
      "required": false,
      "description": "Time bucket: day, week, month",
      "location": "query",
      "in": "query"
    },
    {
      "name": "on",
      "type": "string",
      "required": false,
      "description": "Property to segment by",
      "location": "query",
      "in": "query"
    },
    {
      "name": "where",
      "type": "string",
      "required": false,
      "description": "Filter expression",
      "location": "query",
      "in": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "data": {
      "steps": [
        {
          "count": 1000,
          "step_conv_ratio": 1
        },
        {
          "count": 500,
          "step_conv_ratio": 0.5
        }
      ]
    }
  },
  "auth_scopes": []
}
