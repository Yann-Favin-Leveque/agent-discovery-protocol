{
  "name": "profiles_delete",
  "description": "Permanently delete a user profile.",
  "resource_group": "ingestion",
  "endpoint": "/engage#profile-delete",
  "method": "POST",
  "parameters": [
    {
      "name": "$distinct_id",
      "type": "string",
      "required": true,
      "description": "User identifier",
      "in": "body"
    },
    {
      "name": "$token",
      "type": "string",
      "required": true,
      "description": "Project token",
      "in": "body"
    },
    {
      "name": "$delete",
      "type": "string",
      "required": true,
      "description": "Empty string to confirm deletion",
      "in": "body"
    }
  ],
  "request_example": {
    "$distinct_id": "user_123",
    "$token": "YOUR_TOKEN",
    "$delete": ""
  },
  "response_example": {
    "status": 1
  },
  "auth_scopes": []
}
