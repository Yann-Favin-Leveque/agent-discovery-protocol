{
  "name": "query_retention",
  "description": "Get user retention data over time periods.",
  "resource_group": "query",
  "endpoint": "/retention",
  "method": "GET",
  "parameters": [
    {
      "name": "project_id",
      "type": "integer",
      "required": true,
      "description": "Project ID",
      "location": "query",
      "in": "query"
    },
    {
      "name": "from_date",
      "type": "string",
      "required": true,
      "description": "Start date",
      "location": "query",
      "in": "query"
    },
    {
      "name": "to_date",
      "type": "string",
      "required": true,
      "description": "End date",
      "location": "query",
      "in": "query"
    },
    {
      "name": "retention_type",
      "type": "string",
      "required": false,
      "description": "birth or compounded",
      "location": "query",
      "in": "query"
    },
    {
      "name": "born_event",
      "type": "string",
      "required": false,
      "description": "Initial qualifying event",
      "location": "query",
      "in": "query"
    },
    {
      "name": "event",
      "type": "string",
      "required": false,
      "description": "Return event to track",
      "location": "query",
      "in": "query"
    },
    {
      "name": "unit",
      "type": "string",
      "required": false,
      "description": "day, week, or month",
      "location": "query",
      "in": "query"
    },
    {
      "name": "interval_count",
      "type": "integer",
      "required": false,
      "description": "Number of buckets",
      "location": "query",
      "in": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "data": {
      "2025-01-01": {
        "counts": [
          100,
          80,
          60
        ],
        "first": 100
      }
    }
  },
  "auth_scopes": []
}
