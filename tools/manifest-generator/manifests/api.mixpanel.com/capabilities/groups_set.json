{
  "name": "groups_set",
  "description": "Set properties on a group profile.",
  "resource_group": "ingestion",
  "endpoint": "/groups#group-set",
  "method": "POST",
  "parameters": [
    {
      "name": "$token",
      "type": "string",
      "required": true,
      "description": "Project token",
      "in": "body"
    },
    {
      "name": "$group_key",
      "type": "string",
      "required": true,
      "description": "Group key",
      "in": "body"
    },
    {
      "name": "$group_id",
      "type": "string",
      "required": true,
      "description": "Group ID",
      "in": "body"
    },
    {
      "name": "$set",
      "type": "object",
      "required": true,
      "description": "Properties to set",
      "in": "body"
    }
  ],
  "request_example": {
    "$token": "YOUR_TOKEN",
    "$group_key": "company",
    "$group_id": "acme",
    "$set": {
      "plan": "enterprise"
    }
  },
  "response_example": {
    "status": 1
  },
  "auth_scopes": []
}
