{
  "name": "profiles_set",
  "description": "Set properties on a user profile, creating it if it does not exist.",
  "resource_group": "ingestion",
  "endpoint": "/engage#profile-set",
  "method": "POST",
  "parameters": [
    {
      "name": "$distinct_id",
      "type": "string",
      "required": true,
      "description": "User identifier"
    },
    {
      "name": "$token",
      "type": "string",
      "required": true,
      "description": "Project token"
    },
    {
      "name": "$set",
      "type": "object",
      "required": true,
      "description": "Properties to set"
    }
  ],
  "request_example": {
    "$distinct_id": "user_123",
    "$token": "YOUR_TOKEN",
    "$set": {
      "name": "John",
      "plan": "pro"
    }
  },
  "response_example": {
    "status": 1
  },
  "auth_scopes": []
}
