{
  "name": "track_event",
  "description": "Track a user event with custom properties for product analytics in Mixpanel.",
  "endpoint": "/track",
  "method": "POST",
  "parameters": [
    {"name": "event", "type": "string", "description": "Event name.", "required": true, "example": "Sign Up"},
    {"name": "properties", "type": "object", "description": "Event properties including distinct_id and token.", "required": true, "example": {"distinct_id": "user_123", "token": "proj_token", "plan": "enterprise", "source": "landing_page"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mixpanel.com/track",
    "headers": {"Content-Type": "application/json", "Accept": "text/plain"},
    "body": [{"event": "Sign Up", "properties": {"distinct_id": "user_123", "token": "proj_token", "plan": "enterprise", "source": "landing_page"}}]
  },
  "response_example": {
    "status": 200,
    "body": 1
  }
}
