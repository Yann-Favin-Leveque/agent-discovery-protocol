{
  "name": "manage_variables",
  "description": "Get, set, or delete environment variables for a service in a specific environment.",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {"name": "query", "type": "string", "description": "GraphQL query or mutation for variable operations.", "required": true, "example": "mutation($input: VariableCollectionUpsertInput!) { variableCollectionUpsert(input: $input) }"},
    {"name": "variables", "type": "object", "description": "Input containing project, environment, service IDs and variable key-value pairs.", "required": true, "example": {"input": {"projectId": "proj_abc", "environmentId": "env_prod", "serviceId": "srv_abc", "variables": {"DATABASE_URL": "postgresql://..."}}}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"query": "mutation($input: VariableCollectionUpsertInput!) { variableCollectionUpsert(input: $input) }", "variables": {"input": {"projectId": "proj_abc", "environmentId": "env_prod", "serviceId": "srv_abc", "variables": {"DATABASE_URL": "postgresql://localhost:5432/mydb"}}}}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"variableCollectionUpsert": true}}
  }
}
