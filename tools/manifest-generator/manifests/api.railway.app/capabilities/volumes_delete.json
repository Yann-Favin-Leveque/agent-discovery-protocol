{
  "name": "volumes_delete",
  "description": "Delete a persistent volume.",
  "resource_group": "volumes",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "volumeId",
      "type": "string",
      "required": true,
      "description": "Volume ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "mutation($id: String!) { volumeDelete(id: $id) }",
      "variables": {
        "id": "vol-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "volumeDelete": true
    }
  }
}
