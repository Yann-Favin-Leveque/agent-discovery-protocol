{
  "name": "deploy_service",
  "description": "Trigger a new deployment for a specific service in a project environment.",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {"name": "query", "type": "string", "description": "GraphQL mutation string.", "required": true, "example": "mutation($serviceId: String!, $environmentId: String!) { serviceInstanceRedeploy(serviceId: $serviceId, environmentId: $environmentId) }"},
    {"name": "variables", "type": "object", "description": "Service ID and environment ID for the deployment.", "required": true, "example": {"serviceId": "srv_abc123", "environmentId": "env_prod"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"query": "mutation($serviceId: String!, $environmentId: String!) { serviceInstanceRedeploy(serviceId: $serviceId, environmentId: $environmentId) }", "variables": {"serviceId": "srv_abc123", "environmentId": "env_prod"}}
  },
  "response_example": {
    "status": 200,
    "body": {"data": {"serviceInstanceRedeploy": true}}
  }
}
