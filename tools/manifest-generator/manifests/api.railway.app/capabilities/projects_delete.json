{
  "name": "projects_delete",
  "description": "Delete a project and all resources.",
  "resource_group": "projects",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "description": "Project ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "mutation($id: String!) { projectDelete(id: $id) }",
      "variables": {
        "id": "proj-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "projectDelete": true
    }
  }
}