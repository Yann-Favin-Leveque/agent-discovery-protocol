{
  "name": "domains_delete",
  "description": "Remove a custom domain.",
  "resource_group": "domains",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "domainId",
      "type": "string",
      "required": true,
      "description": "Domain ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "mutation($id: String!) { customDomainDelete(id: $id) }",
      "variables": {
        "id": "dom-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "customDomainDelete": true
    }
  }
}