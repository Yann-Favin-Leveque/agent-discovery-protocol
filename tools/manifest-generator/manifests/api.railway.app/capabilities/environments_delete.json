{
  "name": "environments_delete",
  "description": "Delete an environment.",
  "resource_group": "environments",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "environmentId",
      "type": "string",
      "required": true,
      "description": "Environment ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "mutation($id: String!) { environmentDelete(id: $id) }",
      "variables": {
        "id": "env-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "environmentDelete": true
    }
  }
}
