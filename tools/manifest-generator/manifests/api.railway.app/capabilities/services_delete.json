{
  "name": "services_delete",
  "description": "Delete a service.",
  "resource_group": "services",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "Service ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "mutation($id: String!) { serviceDelete(id: $id) }",
      "variables": {
        "id": "srv-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "serviceDelete": true
    }
  }
}
