{
  "name": "services_restart",
  "description": "Restart a running service.",
  "resource_group": "services",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "Service ID.",
      "in": "body"
    },
    {
      "name": "environmentId",
      "type": "string",
      "required": true,
      "description": "Environment ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "mutation($sId: String!, $eId: String!) { serviceInstanceRedeploy(serviceId: $sId, environmentId: $eId) }",
      "variables": {
        "sId": "srv-abc",
        "eId": "env-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "serviceInstanceRedeploy": true
    }
  }
}
