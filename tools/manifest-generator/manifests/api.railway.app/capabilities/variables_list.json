{
  "name": "variables_list",
  "description": "List environment variables for a service.",
  "resource_group": "variables",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "description": "Project ID.",
      "in": "body"
    },
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "Service ID.",
      "in": "body"
    },
    {
      "name": "environmentId",
      "type": "string",
      "required": true,
      "description": "Environment ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "query($pId: String!, $sId: String!, $eId: String!) { variables(projectId: $pId, serviceId: $sId, environmentId: $eId) }",
      "variables": {
        "pId": "proj-abc",
        "sId": "srv-abc",
        "eId": "env-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "variables": {
        "DATABASE_URL": "postgresql://host/db",
        "NODE_ENV": "production"
      }
    }
  }
}
