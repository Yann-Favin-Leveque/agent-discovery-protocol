{
  "name": "domains_list",
  "description": "List custom domains for a service.",
  "resource_group": "domains",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "description": "Project ID."
    },
    {
      "name": "serviceId",
      "type": "string",
      "required": true,
      "description": "Service ID."
    },
    {
      "name": "environmentId",
      "type": "string",
      "required": true,
      "description": "Environment ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "query($pId: String!, $sId: String!, $eId: String!) { customDomains(projectId: $pId, serviceId: $sId, environmentId: $eId) { id domain } }",
      "variables": {
        "pId": "proj-abc",
        "sId": "srv-abc",
        "eId": "env-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "customDomains": [
        {
          "id": "dom-abc",
          "domain": "api.example.com"
        }
      ]
    }
  }
}