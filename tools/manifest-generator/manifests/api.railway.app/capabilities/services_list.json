{
  "name": "services_list",
  "description": "List all services in a project.",
  "resource_group": "services",
  "endpoint": "/graphql/v2",
  "method": "POST",
  "parameters": [
    {
      "name": "projectId",
      "type": "string",
      "required": true,
      "description": "Project ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://backboard.railway.app/graphql/v2",
    "body": {
      "query": "query($id: String!) { project(id: $id) { services { edges { node { id name updatedAt } } } } }",
      "variables": {
        "id": "proj-abc"
      }
    }
  },
  "response_example": {
    "data": {
      "project": {
        "services": {
          "edges": [
            {
              "node": {
                "id": "srv-abc",
                "name": "backend"
              }
            }
          ]
        }
      }
    }
  }
}