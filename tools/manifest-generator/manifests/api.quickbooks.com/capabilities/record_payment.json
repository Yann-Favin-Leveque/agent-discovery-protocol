{
  "name": "record_payment",
  "description": "Record a payment received from a customer. Link it to one or more invoices to mark them as paid.",
  "endpoint": "/v3/company/{realmId}/payment",
  "method": "POST",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID (realm ID).",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "CustomerRef",
      "type": "object",
      "description": "Reference to the customer making the payment.",
      "required": true,
      "example": { "value": "1" }
    },
    {
      "name": "TotalAmt",
      "type": "number",
      "description": "The total amount of the payment.",
      "required": true,
      "example": 150.00
    },
    {
      "name": "Line",
      "type": "array",
      "description": "Array of line items linking the payment to specific invoices.",
      "required": false,
      "example": [
        {
          "Amount": 150.00,
          "LinkedTxn": [{ "TxnId": "130", "TxnType": "Invoice" }]
        }
      ]
    },
    {
      "name": "PaymentMethodRef",
      "type": "object",
      "description": "Reference to the payment method (e.g., cash, check, credit card).",
      "required": false,
      "example": { "value": "1" }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/payment",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "body": {
      "CustomerRef": { "value": "1" },
      "TotalAmt": 150.00,
      "Line": [
        {
          "Amount": 150.00,
          "LinkedTxn": [{ "TxnId": "130", "TxnType": "Invoice" }]
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Payment": {
        "Id": "200",
        "TotalAmt": 150.00,
        "CustomerRef": { "value": "1", "name": "Acme Corp" },
        "TxnDate": "2024-01-20",
        "Line": [
          {
            "Amount": 150.00,
            "LinkedTxn": [{ "TxnId": "130", "TxnType": "Invoice" }]
          }
        ]
      }
    }
  }
}
