{
  "name": "refundreceipts_create",
  "description": "Create a refund receipt to record a refund to a customer.",
  "endpoint": "/v3/company/{realmId}/refundreceipt",
  "method": "POST",
  "resource_group": "refundreceipts",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "Line",
      "type": "array",
      "description": "Line items to refund",
      "required": true,
      "example": [
        {
          "Amount": 25.0,
          "DetailType": "SalesItemLineDetail"
        }
      ]
    },
    {
      "name": "DepositToAccountRef",
      "type": "object",
      "description": "Refund source account",
      "required": true,
      "example": {
        "value": "35"
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/refundreceipt?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "DepositToAccountRef": {
        "value": "35"
      },
      "Line": [
        {
          "Amount": 25.0,
          "DetailType": "SalesItemLineDetail",
          "SalesItemLineDetail": {
            "ItemRef": {
              "value": "1"
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "RefundReceipt": {
        "Id": "44",
        "TotalAmt": 25.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}