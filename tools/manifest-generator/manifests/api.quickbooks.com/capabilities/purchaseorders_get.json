{
  "name": "purchaseorders_get",
  "description": "Retrieve a specific purchase order by its ID.",
  "endpoint": "/v3/company/{realmId}/purchaseorder/{purchaseOrderId}",
  "method": "GET",
  "resource_group": "purchaseorders",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "purchaseOrderId",
      "type": "string",
      "description": "Purchase order ID",
      "required": true,
      "example": "22",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/purchaseorder/22?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "PurchaseOrder": {
        "Id": "22",
        "TotalAmt": 500
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
