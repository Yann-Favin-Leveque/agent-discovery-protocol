{
  "name": "transfers_create",
  "description": "Create a funds transfer between two bank accounts.",
  "endpoint": "/v3/company/{realmId}/transfer",
  "method": "POST",
  "resource_group": "transfers",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "FromAccountRef",
      "type": "object",
      "description": "Source account",
      "required": true,
      "example": {
        "value": "35"
      }
    },
    {
      "name": "ToAccountRef",
      "type": "object",
      "description": "Destination account",
      "required": true,
      "example": {
        "value": "36"
      }
    },
    {
      "name": "Amount",
      "type": "number",
      "description": "Transfer amount",
      "required": true,
      "example": 500.0
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/transfer?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "FromAccountRef": {
        "value": "35"
      },
      "ToAccountRef": {
        "value": "36"
      },
      "Amount": 500.0
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Transfer": {
        "Id": "14",
        "Amount": 500.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}