{
  "name": "purchaseorders_create",
  "description": "Create a purchase order to a vendor for goods or services.",
  "endpoint": "/v3/company/{realmId}/purchaseorder",
  "method": "POST",
  "resource_group": "purchaseorders",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "VendorRef",
      "type": "object",
      "description": "Vendor reference",
      "required": true,
      "example": {
        "value": "40"
      }
    },
    {
      "name": "Line",
      "type": "array",
      "description": "Line items",
      "required": true,
      "example": [
        {
          "Amount": 500.0,
          "DetailType": "ItemBasedExpenseLineDetail"
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/purchaseorder?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "VendorRef": {
        "value": "40"
      },
      "Line": [
        {
          "Amount": 500.0,
          "DetailType": "ItemBasedExpenseLineDetail",
          "ItemBasedExpenseLineDetail": {
            "ItemRef": {
              "value": "1"
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "PurchaseOrder": {
        "Id": "22",
        "TotalAmt": 500.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}