{
  "name": "items_update",
  "description": "Update an existing item. Requires SyncToken for concurrency.",
  "endpoint": "/v3/company/{realmId}/item",
  "method": "POST",
  "resource_group": "items",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "Id",
      "type": "string",
      "description": "Item ID",
      "required": true,
      "example": "21"
    },
    {
      "name": "SyncToken",
      "type": "string",
      "description": "Concurrency token",
      "required": true,
      "example": "0"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/item?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "Id": "21",
      "SyncToken": "0",
      "Name": "Updated Service",
      "UnitPrice": 120.0
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Item": {
        "Id": "21",
        "SyncToken": "1",
        "Name": "Updated Service"
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}