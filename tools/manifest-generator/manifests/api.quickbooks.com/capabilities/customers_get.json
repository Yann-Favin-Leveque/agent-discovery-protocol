{
  "name": "customers_get",
  "description": "Retrieve a specific customer by ID with full contact and billing details.",
  "endpoint": "/v3/company/{realmId}/customer/{customerId}",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "customerId",
      "type": "string",
      "description": "The customer ID",
      "required": true,
      "example": "56",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/customer/56?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Customer": {
        "Id": "56",
        "DisplayName": "John Doe",
        "Balance": 150
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
