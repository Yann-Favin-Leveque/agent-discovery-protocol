{
  "name": "invoices_send",
  "description": "Send an existing invoice to the customer via email.",
  "endpoint": "/v3/company/{realmId}/invoice/{invoiceId}/send",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "invoiceId",
      "type": "string",
      "description": "The invoice ID",
      "required": true,
      "example": "130"
    },
    {
      "name": "sendTo",
      "type": "string",
      "description": "Override email address",
      "required": false,
      "example": "customer@example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/invoice/130/send?sendTo=customer@example.com",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/octet-stream"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Invoice": {
        "Id": "130",
        "EmailStatus": "EmailSent"
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}