{
  "name": "vendors_create",
  "description": "Create a new vendor record with contact and payment information.",
  "endpoint": "/v3/company/{realmId}/vendor",
  "method": "POST",
  "resource_group": "vendors",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "DisplayName",
      "type": "string",
      "description": "Vendor display name",
      "required": true,
      "example": "Office Supplies Inc"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/vendor?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "DisplayName": "Office Supplies Inc"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Vendor": {
        "Id": "40",
        "DisplayName": "Office Supplies Inc",
        "Active": true
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}