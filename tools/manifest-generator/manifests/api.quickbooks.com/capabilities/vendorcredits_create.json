{
  "name": "vendorcredits_create",
  "description": "Create a vendor credit to record a credit from a vendor.",
  "endpoint": "/v3/company/{realmId}/vendorcredit",
  "method": "POST",
  "resource_group": "vendorcredits",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "VendorRef",
      "type": "object",
      "description": "Vendor reference",
      "required": true,
      "example": {
        "value": "40"
      }
    },
    {
      "name": "Line",
      "type": "array",
      "description": "Credit line items",
      "required": true,
      "example": [
        {
          "Amount": 50.0,
          "DetailType": "AccountBasedExpenseLineDetail"
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/vendorcredit?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "VendorRef": {
        "value": "40"
      },
      "Line": [
        {
          "Amount": 50.0,
          "DetailType": "AccountBasedExpenseLineDetail",
          "AccountBasedExpenseLineDetail": {
            "AccountRef": {
              "value": "7"
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "VendorCredit": {
        "Id": "51",
        "TotalAmt": 50.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}