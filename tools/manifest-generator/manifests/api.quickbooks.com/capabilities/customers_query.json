{
  "name": "customers_query",
  "description": "Query customers using SQL-like syntax. Filter by name, email, or active status.",
  "endpoint": "/v3/company/{realmId}/query",
  "method": "GET",
  "resource_group": "customers",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "query",
      "type": "string",
      "description": "SQL-like query",
      "required": true,
      "example": "SELECT * FROM Customer WHERE Active = true"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/query?query=SELECT * FROM Customer&minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "QueryResponse": {
        "Customer": [
          {
            "Id": "56",
            "DisplayName": "John Doe"
          }
        ],
        "startPosition": 1,
        "maxResults": 100
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}