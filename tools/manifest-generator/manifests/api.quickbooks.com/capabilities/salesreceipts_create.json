{
  "name": "salesreceipts_create",
  "description": "Create a sales receipt for an immediate payment without an invoice.",
  "endpoint": "/v3/company/{realmId}/salesreceipt",
  "method": "POST",
  "resource_group": "salesreceipts",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "Line",
      "type": "array",
      "description": "Line items",
      "required": true,
      "example": [
        {
          "Amount": 75,
          "DetailType": "SalesItemLineDetail"
        }
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/salesreceipt?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "Line": [
        {
          "Amount": 75,
          "DetailType": "SalesItemLineDetail",
          "SalesItemLineDetail": {
            "ItemRef": {
              "value": "1"
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "SalesReceipt": {
        "Id": "11",
        "TotalAmt": 75
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
