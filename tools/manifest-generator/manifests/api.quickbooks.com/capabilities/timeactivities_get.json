{
  "name": "timeactivities_get",
  "description": "Retrieve a specific time activity by its ID.",
  "endpoint": "/v3/company/{realmId}/timeactivity/{timeActivityId}",
  "method": "GET",
  "resource_group": "timeactivities",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "timeActivityId",
      "type": "string",
      "description": "Time activity ID",
      "required": true,
      "example": "4"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/timeactivity/4?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "TimeActivity": {
        "Id": "4",
        "Hours": 8
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}