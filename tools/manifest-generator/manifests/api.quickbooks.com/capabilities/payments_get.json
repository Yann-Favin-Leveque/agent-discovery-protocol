{
  "name": "payments_get",
  "description": "Retrieve a specific payment by its ID.",
  "endpoint": "/v3/company/{realmId}/payment/{paymentId}",
  "method": "GET",
  "resource_group": "payments",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "paymentId",
      "type": "string",
      "description": "The payment ID",
      "required": true,
      "example": "174",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/payment/174?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Payment": {
        "Id": "174",
        "TotalAmt": 150
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
