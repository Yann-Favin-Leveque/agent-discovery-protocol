{
  "name": "payments_create",
  "description": "Record a payment received from a customer. Link to invoices to mark them paid.",
  "endpoint": "/v3/company/{realmId}/payment",
  "method": "POST",
  "resource_group": "payments",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "CustomerRef",
      "type": "object",
      "description": "Reference to customer",
      "required": true,
      "example": {
        "value": "1"
      }
    },
    {
      "name": "TotalAmt",
      "type": "number",
      "description": "Payment amount",
      "required": true,
      "example": 150.0
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/payment?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "CustomerRef": {
        "value": "1"
      },
      "TotalAmt": 150.0,
      "Line": [
        {
          "Amount": 150.0,
          "LinkedTxn": [
            {
              "TxnId": "130",
              "TxnType": "Invoice"
            }
          ]
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Payment": {
        "Id": "174",
        "TotalAmt": 150.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}