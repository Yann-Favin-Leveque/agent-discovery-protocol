{
  "name": "creditmemos_create",
  "description": "Create a credit memo to refund or credit a customer.",
  "endpoint": "/v3/company/{realmId}/creditmemo",
  "method": "POST",
  "resource_group": "creditmemos",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "CustomerRef",
      "type": "object",
      "description": "Customer reference",
      "required": true,
      "example": {
        "value": "1"
      }
    },
    {
      "name": "Line",
      "type": "array",
      "description": "Line items to credit",
      "required": true,
      "example": [
        {
          "Amount": 50.0,
          "DetailType": "SalesItemLineDetail"
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/creditmemo?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "CustomerRef": {
        "value": "1"
      },
      "Line": [
        {
          "Amount": 50.0,
          "DetailType": "SalesItemLineDetail",
          "SalesItemLineDetail": {
            "ItemRef": {
              "value": "1"
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "CreditMemo": {
        "Id": "101",
        "TotalAmt": 50.0,
        "RemainingCredit": 50.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}