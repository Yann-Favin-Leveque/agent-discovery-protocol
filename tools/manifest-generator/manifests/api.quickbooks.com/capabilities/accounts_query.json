{
  "name": "accounts_query",
  "description": "Query the chart of accounts using SQL-like syntax. Filter by account type, name, or classification.",
  "endpoint": "/v3/company/{realmId}/query",
  "method": "GET",
  "resource_group": "accounts",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "query",
      "type": "string",
      "description": "SQL-like query string",
      "required": true,
      "example": "SELECT * FROM Account WHERE AccountType = 'Bank'"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/query?query=SELECT * FROM Account&minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "QueryResponse": {
        "Account": [
          {
            "Id": "35",
            "Name": "Checking",
            "AccountType": "Bank",
            "CurrentBalance": 1200.0
          }
        ],
        "startPosition": 1,
        "maxResults": 100
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}