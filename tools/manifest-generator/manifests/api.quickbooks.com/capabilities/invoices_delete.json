{
  "name": "invoices_delete",
  "description": "Delete (void) an invoice by ID and SyncToken.",
  "endpoint": "/v3/company/{realmId}/invoice",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "Id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "130",
      "in": "body"
    },
    {
      "name": "SyncToken",
      "type": "string",
      "description": "Concurrency token",
      "required": true,
      "example": "1",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/invoice?operation=delete&minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "Id": "130",
      "SyncToken": "1"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Invoice": {
        "Id": "130",
        "status": "Deleted"
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
