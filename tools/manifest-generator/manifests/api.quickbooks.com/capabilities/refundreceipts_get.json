{
  "name": "refundreceipts_get",
  "description": "Retrieve a specific refund receipt by its ID.",
  "endpoint": "/v3/company/{realmId}/refundreceipt/{refundReceiptId}",
  "method": "GET",
  "resource_group": "refundreceipts",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "refundReceiptId",
      "type": "string",
      "description": "Refund receipt ID",
      "required": true,
      "example": "44"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/refundreceipt/44?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "RefundReceipt": {
        "Id": "44",
        "TotalAmt": 25.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}