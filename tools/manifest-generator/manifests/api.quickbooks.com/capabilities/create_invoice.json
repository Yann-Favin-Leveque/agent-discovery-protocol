{
  "name": "create_invoice",
  "description": "Create a new invoice for a customer with line items, tax, and due date. Supports custom fields, discounts, and multiple currencies.",
  "endpoint": "/v3/company/{realmId}/invoice",
  "method": "POST",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID (also called realm ID). Found in your QuickBooks account settings.",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "CustomerRef",
      "type": "object",
      "description": "Reference to the customer this invoice is for. Must include the customer's QuickBooks ID.",
      "required": true,
      "example": { "value": "1" }
    },
    {
      "name": "Line",
      "type": "array",
      "description": "Array of line items on the invoice. Each line has an amount, description, and item reference.",
      "required": true,
      "example": [
        {
          "Amount": 150.00,
          "DetailType": "SalesItemLineDetail",
          "SalesItemLineDetail": {
            "ItemRef": { "value": "1", "name": "Services" },
            "Qty": 1,
            "UnitPrice": 150.00
          }
        }
      ]
    },
    {
      "name": "DueDate",
      "type": "string",
      "description": "The due date for the invoice in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-02-15"
    },
    {
      "name": "DocNumber",
      "type": "string",
      "description": "Custom invoice number. If omitted, QuickBooks auto-generates one.",
      "required": false,
      "example": "INV-1001"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/invoice",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "body": {
      "CustomerRef": { "value": "1" },
      "Line": [
        {
          "Amount": 150.00,
          "DetailType": "SalesItemLineDetail",
          "SalesItemLineDetail": {
            "ItemRef": { "value": "1", "name": "Services" },
            "Qty": 1,
            "UnitPrice": 150.00
          }
        }
      ],
      "DueDate": "2024-02-15"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Invoice": {
        "Id": "130",
        "DocNumber": "1001",
        "TxnDate": "2024-01-15",
        "DueDate": "2024-02-15",
        "TotalAmt": 150.00,
        "Balance": 150.00,
        "CustomerRef": { "value": "1", "name": "Acme Corp" },
        "Line": [
          {
            "Amount": 150.00,
            "DetailType": "SalesItemLineDetail",
            "SalesItemLineDetail": {
              "ItemRef": { "value": "1", "name": "Services" },
              "Qty": 1,
              "UnitPrice": 150.00
            }
          }
        ]
      }
    }
  }
}
