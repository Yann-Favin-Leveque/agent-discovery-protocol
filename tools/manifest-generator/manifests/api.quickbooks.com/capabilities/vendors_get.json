{
  "name": "vendors_get",
  "description": "Retrieve a specific vendor by ID.",
  "endpoint": "/v3/company/{realmId}/vendor/{vendorId}",
  "method": "GET",
  "resource_group": "vendors",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "vendorId",
      "type": "string",
      "description": "Vendor ID",
      "required": true,
      "example": "40"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/vendor/40?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Vendor": {
        "Id": "40",
        "DisplayName": "Office Supplies Inc",
        "Balance": 200.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}