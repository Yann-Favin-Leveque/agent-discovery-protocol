{
  "name": "accounts_create",
  "description": "Create a new account in the chart of accounts with type, name, and classification.",
  "endpoint": "/v3/company/{realmId}/account",
  "method": "POST",
  "resource_group": "accounts",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "Name",
      "type": "string",
      "description": "Account name",
      "required": true,
      "example": "Business Savings"
    },
    {
      "name": "AccountType",
      "type": "string",
      "description": "Account type (Bank, Expense, Income)",
      "required": true,
      "example": "Bank"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/account?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "Name": "Business Savings",
      "AccountType": "Bank"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Account": {
        "Id": "94",
        "Name": "Business Savings",
        "AccountType": "Bank",
        "Active": true
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}