{
  "name": "items_get",
  "description": "Retrieve a specific item by its ID.",
  "endpoint": "/v3/company/{realmId}/item/{itemId}",
  "method": "GET",
  "resource_group": "items",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "itemId",
      "type": "string",
      "description": "Item ID",
      "required": true,
      "example": "21"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/item/21?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Item": {
        "Id": "21",
        "Name": "Consulting Service",
        "Type": "Service",
        "UnitPrice": 100.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}