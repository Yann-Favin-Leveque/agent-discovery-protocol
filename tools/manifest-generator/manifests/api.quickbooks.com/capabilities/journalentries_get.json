{
  "name": "journalentries_get",
  "description": "Retrieve a specific journal entry by its ID.",
  "endpoint": "/v3/company/{realmId}/journalentry/{journalEntryId}",
  "method": "GET",
  "resource_group": "journalentries",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "journalEntryId",
      "type": "string",
      "description": "Journal entry ID",
      "required": true,
      "example": "167",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/journalentry/167?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "JournalEntry": {
        "Id": "167",
        "TotalAmt": 100
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
