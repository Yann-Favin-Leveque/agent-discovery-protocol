{
  "name": "employees_get",
  "description": "Retrieve a specific employee by ID.",
  "endpoint": "/v3/company/{realmId}/employee/{employeeId}",
  "method": "GET",
  "resource_group": "employees",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "employeeId",
      "type": "string",
      "description": "Employee ID",
      "required": true,
      "example": "55"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/employee/55?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Employee": {
        "Id": "55",
        "GivenName": "Jane",
        "FamilyName": "Smith"
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}