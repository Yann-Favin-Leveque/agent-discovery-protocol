{
  "name": "salesreceipts_get",
  "description": "Retrieve a specific sales receipt by its ID.",
  "endpoint": "/v3/company/{realmId}/salesreceipt/{salesReceiptId}",
  "method": "GET",
  "resource_group": "salesreceipts",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "salesReceiptId",
      "type": "string",
      "description": "Sales receipt ID",
      "required": true,
      "example": "11",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/salesreceipt/11?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "SalesReceipt": {
        "Id": "11",
        "TotalAmt": 75
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
