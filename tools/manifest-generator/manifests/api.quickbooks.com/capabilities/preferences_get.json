{
  "name": "preferences_get",
  "description": "Retrieve the company preferences and feature settings.",
  "endpoint": "/v3/company/{realmId}/preferences",
  "method": "GET",
  "resource_group": "preferences",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/preferences?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Preferences": {
        "AccountingInfoPrefs": {
          "FirstMonthOfFiscalYear": "January"
        }
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}