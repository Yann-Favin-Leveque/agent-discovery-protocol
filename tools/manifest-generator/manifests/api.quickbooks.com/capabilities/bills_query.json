{
  "name": "bills_query",
  "description": "Query bills using SQL-like syntax. Filter by vendor, date, or balance.",
  "endpoint": "/v3/company/{realmId}/query",
  "method": "GET",
  "resource_group": "bills",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "query",
      "type": "string",
      "description": "SQL-like query",
      "required": true,
      "example": "SELECT * FROM Bill WHERE Balance > '0'",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/query?query=SELECT * FROM Bill&minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "QueryResponse": {
        "Bill": [
          {
            "Id": "25",
            "TotalAmt": 200
          }
        ],
        "startPosition": 1,
        "maxResults": 100
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
