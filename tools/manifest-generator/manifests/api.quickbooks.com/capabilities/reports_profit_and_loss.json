{
  "name": "reports_profit_and_loss",
  "description": "Generate a Profit and Loss (income statement) report for a date range.",
  "endpoint": "/v3/company/{realmId}/reports/ProfitAndLoss",
  "method": "GET",
  "resource_group": "reports",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "start_date",
      "type": "string",
      "description": "Start date (YYYY-MM-DD)",
      "required": false,
      "example": "2026-01-01",
      "in": "query"
    },
    {
      "name": "end_date",
      "type": "string",
      "description": "End date (YYYY-MM-DD)",
      "required": false,
      "example": "2026-03-31",
      "in": "query"
    },
    {
      "name": "accounting_method",
      "type": "string",
      "description": "Cash or Accrual",
      "required": false,
      "example": "Accrual",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/reports/ProfitAndLoss?start_date=2026-01-01&end_date=2026-03-31",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Header": {
        "ReportName": "ProfitAndLoss"
      },
      "Rows": {
        "Row": []
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
