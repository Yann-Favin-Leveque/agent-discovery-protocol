{
  "name": "payments_delete",
  "description": "Delete a payment by ID and SyncToken.",
  "endpoint": "/v3/company/{realmId}/payment",
  "method": "POST",
  "resource_group": "payments",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890",
      "in": "path"
    },
    {
      "name": "Id",
      "type": "string",
      "description": "Payment ID",
      "required": true,
      "example": "174",
      "in": "body"
    },
    {
      "name": "SyncToken",
      "type": "string",
      "description": "Concurrency token",
      "required": true,
      "example": "0",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/payment?operation=delete&minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "Id": "174",
      "SyncToken": "0"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Payment": {
        "Id": "174",
        "status": "Deleted"
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
