{
  "name": "invoices_get_pdf",
  "description": "Download the PDF version of an invoice.",
  "endpoint": "/v3/company/{realmId}/invoice/{invoiceId}/pdf",
  "method": "GET",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "invoiceId",
      "type": "string",
      "description": "The invoice ID",
      "required": true,
      "example": "130"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/invoice/130/pdf",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/pdf"
    }
  },
  "response_example": {
    "status": 200,
    "body": "(PDF binary content)"
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}