{
  "name": "query_invoices",
  "description": "Query invoices using SQL-like syntax. Filter by customer, date range, status, and amount. Returns paginated results.",
  "endpoint": "/v3/company/{realmId}/query",
  "method": "GET",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID (realm ID).",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "query",
      "type": "string",
      "description": "SQL-like query string. Supports SELECT, WHERE, ORDER BY, and MAXRESULTS clauses.",
      "required": true,
      "example": "SELECT * FROM Invoice WHERE TotalAmt > '100.00' ORDERBY TxnDate DESC MAXRESULTS 25"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/query?query=SELECT%20*%20FROM%20Invoice%20WHERE%20TotalAmt%20%3E%20%27100.00%27%20MAXRESULTS%2025",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "QueryResponse": {
        "Invoice": [
          {
            "Id": "130",
            "DocNumber": "1001",
            "TxnDate": "2024-01-15",
            "DueDate": "2024-02-15",
            "TotalAmt": 150.00,
            "Balance": 150.00,
            "CustomerRef": { "value": "1", "name": "Acme Corp" }
          }
        ],
        "startPosition": 1,
        "maxResults": 25,
        "totalCount": 1
      }
    }
  }
}
