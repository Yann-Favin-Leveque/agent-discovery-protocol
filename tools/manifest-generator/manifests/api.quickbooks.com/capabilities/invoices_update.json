{
  "name": "invoices_update",
  "description": "Update an existing invoice. Requires full object with SyncToken.",
  "endpoint": "/v3/company/{realmId}/invoice",
  "method": "POST",
  "resource_group": "invoices",
  "parameters": [
    {
      "name": "realmId",
      "type": "string",
      "description": "The QuickBooks company ID",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "Id",
      "type": "string",
      "description": "Invoice ID",
      "required": true,
      "example": "130"
    },
    {
      "name": "SyncToken",
      "type": "string",
      "description": "Concurrency token",
      "required": true,
      "example": "0"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://quickbooks.api.intuit.com/v3/company/1234567890/invoice?minorversion=65",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "Id": "130",
      "SyncToken": "0",
      "DueDate": "2026-05-01",
      "CustomerRef": {
        "value": "1"
      },
      "Line": []
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Invoice": {
        "Id": "130",
        "SyncToken": "1",
        "TotalAmt": 200.0
      }
    }
  },
  "auth_scopes": [
    "com.intuit.quickbooks.accounting"
  ],
  "rate_limits": {
    "requests_per_minute": 500
  }
}