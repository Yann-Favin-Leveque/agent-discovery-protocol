{
  "name": "projects_list",
  "description": "List projects in an organization.",
  "resource_group": "projects",
  "endpoint": "/organizations/{organization_slug}/projects/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Pagination cursor.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/organizations/my-org/projects/"
  },
  "response_example": [
    {
      "id": "proj-abc",
      "slug": "my-project",
      "name": "My Project",
      "platform": "python"
    }
  ]
}
