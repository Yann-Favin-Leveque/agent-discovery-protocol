{
  "name": "issues_list",
  "description": "List issues for a project.",
  "resource_group": "issues",
  "endpoint": "/projects/{organization_slug}/{project_slug}/issues/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "project_slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "path"
    },
    {
      "name": "query",
      "type": "string",
      "required": false,
      "description": "Search query.",
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Pagination.",
      "in": "query"
    },
    {
      "name": "statsPeriod",
      "type": "string",
      "required": false,
      "description": "Stats period: 24h, 14d.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/projects/my-org/my-project/issues/?query=is:unresolved"
  },
  "response_example": [
    {
      "id": "issue-abc",
      "title": "TypeError: Cannot read property",
      "culprit": "app.js",
      "count": "42",
      "status": "unresolved",
      "level": "error"
    }
  ]
}
