{
  "name": "projects_get",
  "description": "Get project details.",
  "resource_group": "projects",
  "endpoint": "/projects/{organization_slug}/{project_slug}/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "project_slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/projects/my-org/my-project/"
  },
  "response_example": {
    "id": "proj-abc",
    "slug": "my-project",
    "name": "My Project",
    "platform": "python"
  }
}
