{
  "name": "releases_get",
  "description": "Get release details.",
  "resource_group": "releases",
  "endpoint": "/organizations/{organization_slug}/releases/{version}/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "Version.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/organizations/my-org/releases/1.0.0/"
  },
  "response_example": {
    "version": "1.0.0",
    "dateCreated": "2026-01-20T00:00:00Z",
    "newGroups": 5
  }
}
