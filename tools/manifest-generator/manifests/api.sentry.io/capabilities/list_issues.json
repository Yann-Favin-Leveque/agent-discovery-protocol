{
  "name": "list_issues",
  "description": "List error issues for a specific project with optional filtering by status, query, and sort order.",
  "endpoint": "/projects/{organization_slug}/{project_slug}/issues/",
  "method": "GET",
  "parameters": [
    {"name": "organization_slug", "type": "string", "description": "Organization slug.", "required": true, "example": "my-org"},
    {"name": "project_slug", "type": "string", "description": "Project slug.", "required": true, "example": "my-app"},
    {"name": "query", "type": "string", "description": "Search query to filter issues.", "required": false, "example": "is:unresolved"},
    {"name": "sort", "type": "string", "description": "Sort order: date, new, priority, freq, user.", "required": false, "example": "date"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/projects/my-org/my-app/issues/?query=is:unresolved&sort=date",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": "789", "title": "TypeError: Cannot read property 'map' of undefined", "culprit": "app/components/List.js", "count": "42", "firstSeen": "2024-01-15T10:00:00Z", "lastSeen": "2024-01-20T15:00:00Z", "status": "unresolved", "level": "error"}]
  }
}
