{
  "name": "issues_update",
  "description": "Update issue (resolve, ignore, assign).",
  "resource_group": "issues",
  "endpoint": "/issues/{issue_id}/",
  "method": "PUT",
  "parameters": [
    {
      "name": "issue_id",
      "type": "string",
      "required": true,
      "description": "Issue ID.",
      "in": "path"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "resolved, unresolved, ignored.",
      "in": "body"
    },
    {
      "name": "assignedTo",
      "type": "string",
      "required": false,
      "description": "User or team.",
      "in": "body"
    },
    {
      "name": "hasSeen",
      "type": "boolean",
      "required": false,
      "description": "Mark as seen.",
      "in": "body"
    },
    {
      "name": "isBookmarked",
      "type": "boolean",
      "required": false,
      "description": "Bookmark.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://sentry.io/api/0/issues/issue-abc/",
    "body": {
      "status": "resolved"
    }
  },
  "response_example": {
    "id": "issue-abc",
    "status": "resolved"
  }
}
