{
  "name": "releases_list",
  "description": "List releases for an organization.",
  "resource_group": "releases",
  "endpoint": "/organizations/{organization_slug}/releases/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug."
    },
    {
      "name": "project",
      "type": "integer",
      "required": false,
      "description": "Project ID."
    },
    {
      "name": "query",
      "type": "string",
      "required": false,
      "description": "Search."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/organizations/my-org/releases/"
  },
  "response_example": [
    {
      "version": "1.0.0",
      "dateCreated": "2026-01-20T14:00:00Z",
      "newGroups": 5
    }
  ]
}