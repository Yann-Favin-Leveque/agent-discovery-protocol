  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/organizations/my-org/teams/"
  },
  "response_example": [
    {
      "id": "team-abc",
      "slug": "backend",
      "name": "Backend Team"
    }
  ]
}