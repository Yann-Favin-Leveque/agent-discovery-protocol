{
  "name": "teams_create",
  "description": "Create a team.",
  "resource_group": "teams",
  "endpoint": "/organizations/{organization_slug}/teams/",
  "method": "POST",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Team name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://sentry.io/api/0/organizations/my-org/teams/",
    "body": {
      "name": "Frontend Team"
    }
  },
  "response_example": {
    "id": "team-new",
    "slug": "frontend-team",
    "name": "Frontend Team"
  }
}