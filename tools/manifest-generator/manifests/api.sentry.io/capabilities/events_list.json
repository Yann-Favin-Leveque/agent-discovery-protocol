{
  "name": "events_list",
  "description": "List events for a project.",
  "resource_group": "events",
  "endpoint": "/projects/{organization_slug}/{project_slug}/events/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "project_slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "path"
    },
    {
      "name": "full",
      "type": "boolean",
      "required": false,
      "description": "Include full details.",
      "in": "query"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "Pagination.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/projects/my-org/my-project/events/"
  },
  "response_example": [
    {
      "eventID": "evt-abc",
      "title": "TypeError",
      "dateCreated": "2026-01-20T14:00:00Z"
    }
