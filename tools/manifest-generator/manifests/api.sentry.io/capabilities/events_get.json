{
  "name": "events_get",
  "description": "Get a specific event.",
  "resource_group": "events",
  "endpoint": "/projects/{organization_slug}/{project_slug}/events/{event_id}/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug."
    },
    {
      "name": "project_slug",
      "type": "string",
      "required": true,
      "description": "Project slug."
    },
    {
      "name": "event_id",
      "type": "string",
      "required": true,
      "description": "Event ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/projects/my-org/my-project/events/evt-abc/"
