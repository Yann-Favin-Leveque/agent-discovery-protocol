{
  "name": "project_keys_list",
  "description": "List client keys (DSN) for a project.",
  "resource_group": "projects",
  "endpoint": "/projects/{organization_slug}/{project_slug}/keys/",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "project_slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://sentry.io/api/0/projects/my-org/my-project/keys/"
  },
  "response_example": [
    {
      "id": "key-abc",
      "name": "Default",
      "dsn": {
        "public": "https://abc@sentry.io/123"
      },
      "isActive": true
    }
  ]
}
