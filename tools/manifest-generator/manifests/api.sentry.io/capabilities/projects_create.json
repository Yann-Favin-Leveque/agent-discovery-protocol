{
  "name": "projects_create",
  "description": "Create a new project.",
  "resource_group": "projects",
  "endpoint": "/teams/{organization_slug}/{team_slug}/projects/",
  "method": "POST",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug."
    },
    {
      "name": "team_slug",
      "type": "string",
      "required": true,
      "description": "Team slug."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Name."
    },
    {
      "name": "platform",
      "type": "string",
      "required": false,
      "description": "Platform."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://sentry.io/api/0/teams/my-org/my-team/projects/",
    "body": {
      "name": "new-project",
      "platform": "python"
    }
  },
  "response_example": {
    "id": "proj-new",
    "slug": "new-project",
    "name": "new-project"
  }
}