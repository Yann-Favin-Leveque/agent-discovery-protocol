{
  "name": "releases_update",
  "description": "Update a release.",
  "resource_group": "releases",
  "endpoint": "/organizations/{organization_slug}/releases/{version}/",
  "method": "PUT",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "Version.",
      "in": "path"
    },
    {
      "name": "ref",
      "type": "string",
      "required": false,
      "description": "Git ref.",
      "in": "body"
    },
    {
      "name": "dateReleased",
      "type": "string",
      "required": false,
      "description": "ISO 8601 date.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://sentry.io/api/0/organizations/my-org/releases/1.0.0/",
    "body": {
      "dateReleased": "2026-01-20T14:00:00Z"
    }
  },
  "response_example": {
    "version": "1.0.0",
    "dateReleased": "2026-01-20T14:00:00Z"
  }
}
