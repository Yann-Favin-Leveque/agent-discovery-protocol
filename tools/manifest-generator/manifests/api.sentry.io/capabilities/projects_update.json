{
  "name": "projects_update",
  "description": "Update a project.",
  "resource_group": "projects",
  "endpoint": "/projects/{organization_slug}/{project_slug}/",
  "method": "PUT",
  "parameters": [
    {
      "name": "organization_slug",
      "type": "string",
      "required": true,
      "description": "Org slug.",
      "in": "path"
    },
    {
      "name": "project_slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "New name.",
      "in": "body"
    },
    {
      "name": "platform",
      "type": "string",
      "required": false,
      "description": "Platform.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://sentry.io/api/0/projects/my-org/my-project/",
    "body": {
      "name": "renamed"
    }
  },
  "response_example": {
    "id": "proj-abc",
    "name": "renamed"
  }
}
