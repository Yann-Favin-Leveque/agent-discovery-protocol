{
  "name": "purchases_list",
  "description": "Retrieve a paginated list of recorded purchases.",
  "resource_group": "purchases",
  "endpoint": "/v4/purchases",
  "method": "GET",
  "parameters": [
    {
      "name": "after",
      "type": "string",
      "description": "Pagination cursor.",
      "required": false,
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Number per page.",
      "required": false,
      "example": 50,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.convertkit.com/v4/purchases",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "purchases": [
        {
          "id": 701,
          "transaction_id": "txn_123",
          "total": 29.99,
          "status": "paid"
        }
      ]
    }
  }
}
