{
  "name": "tags_bulk_create",
  "description": "Create multiple tags in a single batch request.",
  "resource_group": "tags",
  "endpoint": "/v4/bulk/tags",
  "method": "POST",
  "parameters": [
    {
      "name": "tags",
      "type": "array",
      "description": "Array of tag objects with name field.",
      "required": true,
      "example": [
        {
          "name": "tag-a"
        },
        {
          "name": "tag-b"
        }
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/bulk/tags",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "tags": [
        {
          "name": "tag-a"
        },
        {
          "name": "tag-b"
        }
      ]
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "id": "bulk_xyz",
      "status": "processing"
    }
  }
}
