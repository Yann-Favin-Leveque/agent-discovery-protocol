{
  "name": "subscribers_bulk_create",
  "description": "Create multiple subscribers in a single batch request.",
  "resource_group": "subscribers",
  "endpoint": "/v4/bulk/subscribers",
  "method": "POST",
  "parameters": [
    {
      "name": "subscribers",
      "type": "array",
      "description": "Array of subscriber objects, each with email_address and optional first_name/fields.",
      "required": true,
      "example": [
        {
          "email_address": "a@example.com"
        },
        {
          "email_address": "b@example.com",
          "first_name": "Bob"
        }
      ],
      "in": "body"
    },
    {
      "name": "callback_url",
      "type": "string",
      "description": "URL to notify when bulk operation completes.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/bulk/subscribers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "subscribers": [
        {
          "email_address": "a@example.com"
        },
        {
          "email_address": "b@example.com",
          "first_name": "Bob"
        }
      ]
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "id": "bulk_abc123",
      "status": "processing"
    }
  }
}
