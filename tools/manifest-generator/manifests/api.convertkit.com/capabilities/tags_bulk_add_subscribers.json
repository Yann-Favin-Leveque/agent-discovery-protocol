{
  "name": "tags_bulk_add_subscribers",
  "description": "Apply a tag to multiple subscribers in a single batch request.",
  "resource_group": "tags",
  "endpoint": "/v4/bulk/tags/{tag_id}/subscribers",
  "method": "POST",
  "parameters": [
    {
      "name": "tag_id",
      "type": "integer",
      "description": "The ID of the tag.",
      "required": true,
      "example": 101,
      "in": "path"
    },
    {
      "name": "subscribers",
      "type": "array",
      "description": "Array of subscriber IDs or email addresses.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/bulk/tags/101/subscribers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "subscribers": [
        {
          "id": 1001
        },
        {
          "id": 1002
        }
      ]
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "id": "bulk_tag_123",
      "status": "processing"
    }
  }
}
