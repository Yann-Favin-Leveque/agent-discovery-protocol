{
  "name": "subscribers_update",
  "description": "Update an existing subscriber's data by ID.",
  "resource_group": "subscribers",
  "endpoint": "/v4/subscribers/{subscriber_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "subscriber_id",
      "type": "integer",
      "description": "The ID of the subscriber to update.",
      "required": true,
      "example": 1001,
      "in": "path"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "Updated first name.",
      "required": false,
      "example": "Johnny",
      "in": "body"
    },
    {
      "name": "email_address",
      "type": "string",
      "description": "Updated email address.",
      "required": false,
      "in": "body"
    },
    {
      "name": "fields",
      "type": "object",
      "description": "Custom field key-value pairs to update.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.convertkit.com/v4/subscribers/1001",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "first_name": "Johnny"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriber": {
        "id": 1001,
        "email_address": "john@example.com",
        "first_name": "Johnny",
        "state": "active"
      }
    }
  }
}
