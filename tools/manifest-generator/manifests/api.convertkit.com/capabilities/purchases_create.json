{
  "name": "purchases_create",
  "description": "Record a purchase transaction for a subscriber.",
  "resource_group": "purchases",
  "endpoint": "/v4/purchases",
  "method": "POST",
  "parameters": [
    {
      "name": "email_address",
      "type": "string",
      "description": "Email of the purchasing subscriber.",
      "required": true,
      "example": "john@example.com",
      "in": "body"
    },
    {
      "name": "transaction_id",
      "type": "string",
      "description": "Unique transaction identifier.",
      "required": true,
      "example": "txn_456",
      "in": "body"
    },
    {
      "name": "currency",
      "type": "string",
      "description": "ISO 4217 currency code.",
      "required": false,
      "example": "USD",
      "in": "body"
    },
    {
      "name": "total",
      "type": "number",
      "description": "Total purchase amount.",
      "required": true,
      "example": 49.99,
      "in": "body"
    },
    {
      "name": "products",
      "type": "array",
      "description": "Array of product objects with name, pid, and unit_price.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/purchases",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "john@example.com",
      "transaction_id": "txn_456",
      "total": 49.99,
      "products": [
        {
          "name": "Course",
          "pid": "prod_1",
          "unit_price": 49.99
        }
      ]
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "purchase": {
        "id": 702,
        "transaction_id": "txn_456",
        "total": 49.99
      }
    }
  }
}
