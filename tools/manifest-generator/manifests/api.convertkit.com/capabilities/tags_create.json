{
  "name": "tags_create",
  "description": "Create a new tag.",
  "resource_group": "tags",
  "endpoint": "/v4/tags",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "The name of the tag.",
      "required": true,
      "example": "vip-customer",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/tags",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "vip-customer"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "tag": {
        "id": 102,
        "name": "vip-customer",
        "created_at": "2024-06-01T00:00:00Z"
      }
    }
  }
}
