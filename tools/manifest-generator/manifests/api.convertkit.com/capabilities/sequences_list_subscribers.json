{
  "name": "sequences_list_subscribers",
  "description": "Retrieve all subscribers enrolled in a specific sequence.",
  "resource_group": "sequences",
  "endpoint": "/v4/sequences/{sequence_id}/subscribers",
  "method": "GET",
  "parameters": [
    {
      "name": "sequence_id",
      "type": "integer",
      "description": "The ID of the sequence.",
      "required": true,
      "example": 301,
      "in": "path"
    },
    {
      "name": "after",
      "type": "string",
      "description": "Pagination cursor.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.convertkit.com/v4/sequences/301/subscribers",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscribers": [
        {
          "id": 1001,
          "email_address": "john@example.com"
        }
      ],
      "pagination": {
        "has_next_page": false
      }
    }
  }
}
