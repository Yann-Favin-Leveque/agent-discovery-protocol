{
  "name": "custom_fields_create",
  "description": "Create a new custom field for subscriber profiles.",
  "resource_group": "custom_fields",
  "endpoint": "/v4/custom_fields",
  "method": "POST",
  "parameters": [
    {
      "name": "label",
      "type": "string",
      "description": "Display label for the custom field.",
      "required": true,
      "example": "Company",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/custom_fields",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "label": "Company"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "custom_field": {
        "id": 502,
        "label": "Company",
        "key": "company"
      }
    }
  }
}
