{
  "name": "subscribers_unsubscribe",
  "description": "Unsubscribe a subscriber from your list.",
  "resource_group": "subscribers",
  "endpoint": "/v4/subscribers/{subscriber_id}/unsubscribe",
  "method": "POST",
  "parameters": [
    {
      "name": "subscriber_id",
      "type": "integer",
      "description": "The ID of the subscriber to unsubscribe.",
      "required": true,
      "example": 1001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/subscribers/1001/unsubscribe",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriber": {
        "id": 1001,
        "state": "cancelled"
      }
    }
  }
}
