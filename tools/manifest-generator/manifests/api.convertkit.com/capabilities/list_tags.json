{
  "name": "list_tags",
  "description": "Retrieve all tags in your ConvertKit account. Tags are used to segment subscribers by interest, behavior, or source.",
  "endpoint": "/v4/tags",
  "method": "GET",
  "parameters": [
    { "name": "after", "type": "string", "description": "Cursor for pagination.", "required": false, "example": "" },
    { "name": "per_page", "type": "integer", "description": "Number of tags per page. Default 50.", "required": false, "example": 50 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.convertkit.com/v4/tags?per_page=50",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/json"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "tags": [
        {
          "id": 201,
          "name": "interested-in-product",
          "created_at": "2024-01-01T00:00:00Z"
        },
        {
          "id": 202,
          "name": "webinar-attendee",
          "created_at": "2024-01-05T00:00:00Z"
        }
      ],
      "pagination": {
        "has_next_page": false,
        "end_cursor": null
      }
    }
  }
}
