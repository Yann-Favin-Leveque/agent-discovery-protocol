{
  "name": "get_broadcast_stats",
  "description": "Retrieve engagement statistics for a sent broadcast including open rate, click rate, unsubscribes, and total recipients.",
  "endpoint": "/v4/broadcasts/{broadcast_id}/stats",
  "method": "GET",
  "parameters": [
    { "name": "broadcast_id", "type": "integer", "description": "The unique identifier of the broadcast.", "required": true, "example": 5001 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.convertkit.com/v4/broadcasts/5001/stats",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/json"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "broadcast": {
        "id": 5001,
        "stats": {
          "recipients": 1250,
          "open_rate": 0.42,
          "click_rate": 0.08,
          "unsubscribes": 3,
          "total_clicks": 100,
          "show_total_clicks": true,
          "status": "completed",
          "progress": 100
        }
      }
    }
  }
}
