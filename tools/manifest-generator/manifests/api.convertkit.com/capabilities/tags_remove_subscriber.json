    {
      "name": "tag_id",
      "type": "integer",
      "description": "The ID of the tag.",
      "required": true,
      "example": 101,
      "in": "path"
    },
    {
      "name": "subscriber_id",
      "type": "integer",
      "description": "The subscriber ID.",
      "required": true,
      "example": 1001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.convertkit.com/v4/tags/101/subscribers/1001",
