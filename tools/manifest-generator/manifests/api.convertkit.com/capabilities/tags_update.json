{
  "name": "tags_update",
  "description": "Rename an existing tag by ID.",
  "resource_group": "tags",
  "endpoint": "/v4/tags/{tag_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "tag_id",
      "type": "integer",
      "description": "The ID of the tag.",
      "required": true,
      "example": 101,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "The new name for the tag.",
      "required": true,
      "example": "premium-customer",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.convertkit.com/v4/tags/101",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "premium-customer"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tag": {
        "id": 101,
        "name": "premium-customer"
      }
    }
  }
}
