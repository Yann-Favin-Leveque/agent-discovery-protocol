{
  "name": "forms_list_subscribers",
  "description": "Retrieve all subscribers who signed up through a specific form.",
  "resource_group": "forms",
  "endpoint": "/v4/forms/{form_id}/subscribers",
  "method": "GET",
  "parameters": [
    {
      "name": "form_id",
      "type": "integer",
      "description": "The ID of the form.",
      "required": true,
      "example": 201,
      "in": "path"
    },
    {
      "name": "after",
      "type": "string",
      "description": "Pagination cursor.",
      "required": false,
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Number per page.",
      "required": false,
      "example": 50,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.convertkit.com/v4/forms/201/subscribers",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscribers": [
        {
          "id": 1001,
          "email_address": "john@example.com"
        }
      ],
      "pagination": {
        "has_next_page": false
      }
    }
  }
}
