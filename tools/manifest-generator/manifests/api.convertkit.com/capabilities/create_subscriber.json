{
  "name": "create_subscriber",
  "description": "Add a new subscriber to your ConvertKit account. Acts as an upsert -- if the email already exists, it updates the existing record.",
  "endpoint": "/v4/subscribers",
  "method": "POST",
  "parameters": [
    { "name": "email_address", "type": "string", "description": "The subscriber's email address.", "required": true, "example": "john@example.com" },
    { "name": "first_name", "type": "string", "description": "The subscriber's first name.", "required": false, "example": "John" },
    { "name": "state", "type": "string", "description": "Initial subscriber state. One of: active, inactive.", "required": false, "example": "active" },
    { "name": "fields", "type": "object", "description": "Custom field key-value pairs for the subscriber.", "required": false, "example": { "company": "Acme Corp", "role": "Developer" } }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/subscribers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "john@example.com",
      "first_name": "John",
      "state": "active",
      "fields": {
        "company": "Acme Corp",
        "role": "Developer"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriber": {
        "id": 1001,
        "email_address": "john@example.com",
        "first_name": "John",
        "state": "active",
        "created_at": "2024-01-15T10:00:00Z",
        "fields": {
          "company": "Acme Corp",
          "role": "Developer"
        }
      }
    }
  }
}
