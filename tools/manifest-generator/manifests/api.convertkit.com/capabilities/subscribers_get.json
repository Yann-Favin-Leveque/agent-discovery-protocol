{
  "name": "subscribers_get",
  "description": "Retrieve details for a specific subscriber by ID.",
  "resource_group": "subscribers",
  "endpoint": "/v4/subscribers/{subscriber_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "subscriber_id",
      "type": "integer",
      "description": "The ID of the subscriber to retrieve.",
      "required": true,
      "example": 1001,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.convertkit.com/v4/subscribers/1001",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriber": {
        "id": 1001,
        "email_address": "john@example.com",
        "first_name": "John",
        "state": "active",
        "created_at": "2024-01-10T08:00:00Z",
        "fields": {}
      }
    }
  }
}
