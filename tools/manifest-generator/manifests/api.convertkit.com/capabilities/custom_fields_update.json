{
  "name": "custom_fields_update",
  "description": "Update a custom field label.",
  "resource_group": "custom_fields",
  "endpoint": "/v4/custom_fields/{custom_field_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "custom_field_id",
      "type": "integer",
      "description": "The ID of the custom field.",
      "required": true,
      "example": 501,
      "in": "path"
    },
    {
      "name": "label",
      "type": "string",
      "description": "New display label.",
      "required": true,
      "example": "Organization",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.convertkit.com/v4/custom_fields/501",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "label": "Organization"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "custom_field": {
        "id": 501,
        "label": "Organization",
        "key": "organization"
      }
    }
  }
}
