{
  "name": "tags_list",
  "description": "Retrieve all tags in your account.",
  "resource_group": "tags",
  "endpoint": "/v4/tags",
  "method": "GET",
  "parameters": [
    {
      "name": "after",
      "type": "string",
      "description": "Pagination cursor.",
      "required": false,
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Number of tags per page.",
      "required": false,
      "example": 50,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.convertkit.com/v4/tags",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tags": [
        {
          "id": 101,
          "name": "newsletter",
          "created_at": "2024-01-05T00:00:00Z"
        }
      ],
      "pagination": {
        "has_next_page": false
      }
    }
  }
}
