{
  "name": "sequences_add_subscriber",
  "description": "Enroll a subscriber into an automated email sequence by subscriber ID.",
  "resource_group": "sequences",
  "endpoint": "/v4/sequences/{sequence_id}/subscribers",
  "method": "POST",
  "parameters": [
    {
      "name": "sequence_id",
      "type": "integer",
      "description": "The ID of the sequence.",
      "required": true,
      "example": 301,
      "in": "path"
    },
    {
      "name": "email_address",
      "type": "string",
      "description": "Email of the subscriber to enroll.",
      "required": true,
      "example": "jane@example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/sequences/301/subscribers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "jane@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriber": {
        "id": 1002,
        "email_address": "jane@example.com"
      }
    }
  }
}
