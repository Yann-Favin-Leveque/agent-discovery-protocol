{
  "name": "subscribers_create",
  "description": "Create a new subscriber or update an existing one by email (upsert).",
  "resource_group": "subscribers",
  "endpoint": "/v4/subscribers",
  "method": "POST",
  "parameters": [
    {
      "name": "email_address",
      "type": "string",
      "description": "The email address of the subscriber.",
      "required": true,
      "example": "jane@example.com",
      "in": "body"
    },
    {
      "name": "first_name",
      "type": "string",
      "description": "The subscriber's first name.",
      "required": false,
      "example": "Jane",
      "in": "body"
    },
    {
      "name": "fields",
      "type": "object",
      "description": "Custom field key-value pairs.",
      "required": false,
      "example": {
        "company": "Acme"
      },
      "in": "body"
    },
    {
      "name": "state",
      "type": "string",
      "description": "Subscriber state: active or inactive.",
      "required": false,
      "example": "active",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.convertkit.com/v4/subscribers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email_address": "jane@example.com",
      "first_name": "Jane",
      "state": "active"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "subscriber": {
        "id": 1002,
        "email_address": "jane@example.com",
        "first_name": "Jane",
        "state": "active",
        "created_at": "2024-06-15T10:00:00Z"
      }
    }
  }
}
