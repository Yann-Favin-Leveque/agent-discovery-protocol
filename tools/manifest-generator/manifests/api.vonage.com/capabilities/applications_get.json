{
  "name": "applications_get",
  "description": "Retrieve detailed information about a specific Vonage application by its ID.",
  "resource_group": "applications",
  "endpoint": "/v2/applications/{application_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "application_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The application ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vonage.com/v2/applications/78d335fa-323d-0114-9c3d-d6f0d48968cf",
    "headers": {
      "Authorization": "Bearer eyJhbGciOiJSUzI1NiJ9..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "78d335fa-323d-0114-9c3d-d6f0d48968cf",
      "name": "My Voice App",
      "capabilities": {
        "voice": {}
      },
      "keys": {
        "public_key": "-----BEGIN PUBLIC KEY-----\n..."
      }
    }
  }
}
