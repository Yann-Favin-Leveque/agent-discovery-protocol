{
  "name": "numbers_search",
  "description": "Search for available phone numbers to purchase, filtered by country, type, features, and number pattern.",
  "resource_group": "numbers",
  "endpoint": "/number/search",
  "method": "GET",
  "parameters": [
    {
      "name": "country",
      "type": "string",
      "required": true,
      "description": "2-letter country code (e.g., 'US', 'GB').",
      "in": "query"
    },
    {
      "name": "type",
      "type": "string",
      "required": false,
      "description": "Number type: 'landline', 'mobile-lvn', or 'landline-toll-free'.",
      "in": "query"
    },
    {
      "name": "features",
      "type": "string",
      "required": false,
      "description": "Comma-separated features: 'SMS', 'VOICE', 'MMS'.",
      "in": "query"
    },
    {
      "name": "pattern",
      "type": "string",
      "required": false,
      "description": "Number pattern to search for.",
      "in": "query"
    },
    {
      "name": "search_pattern",
      "type": "integer",
      "required": false,
      "description": "How to apply pattern: 0=starts with, 1=anywhere, 2=ends with.",
      "in": "query"
    },
    {
      "name": "size",
      "type": "integer",
      "required": false,
      "description": "Page size (1-100). Default 10.",
      "in": "query"
    },
    {
      "name": "index",
      "type": "integer",
      "required": false,
      "description": "Page index (1-based). Default 1.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.nexmo.com/number/search?country=US&features=SMS,VOICE&size=5&api_key=abc123&api_secret=xyz789",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 1234,
      "numbers": [
        {
          "country": "US",
          "msisdn": "12015550100",
          "type": "mobile-lvn",
          "cost": "1.00",
          "features": [
            "SMS",
            "VOICE"
          ]
        }
      ]
    }
  }
}
