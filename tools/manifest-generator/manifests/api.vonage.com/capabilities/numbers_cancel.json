{
  "name": "numbers_cancel",
  "description": "Cancel (release) a phone number from your Vonage account. The number becomes available for others to purchase.",
  "resource_group": "numbers",
  "endpoint": "/number/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "country",
      "type": "string",
      "required": true,
      "description": "2-letter country code of the number.",
      "in": "body"
    },
    {
      "name": "msisdn",
      "type": "string",
      "required": true,
      "description": "The phone number to cancel.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.nexmo.com/number/cancel",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": "api_key=abc123&api_secret=xyz789&country=US&msisdn=12015550100"
  },
  "response_example": {
    "status": 200,
    "body": {
      "error-code": "200",
      "error-code-label": "success"
    }
  }
}
