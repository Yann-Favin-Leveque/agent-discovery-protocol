{
  "name": "applications_list",
  "description": "List all Vonage applications in your account. Applications configure how Vonage interacts with your webhooks for voice, messages, and other features.",
  "resource_group": "applications",
  "endpoint": "/v2/applications",
  "method": "GET",
  "parameters": [
    {"name": "page_size", "type": "integer", "required": false, "description": "Number of applications per page (1-100). Default 10."},
    {"name": "page", "type": "integer", "required": false, "description": "Page number (1-based). Default 1."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vonage.com/v2/applications?page_size=20",
    "headers": {"Authorization": "Bearer eyJhbGciOiJSUzI1NiJ9..."}
  },
  "response_example": {
    "status": 200,
    "body": {
      "page_size": 20, "page": 1, "total_items": 3, "total_pages": 1,
      "_embedded": {
        "applications": [
          {"id": "78d335fa-323d-0114-9c3d-d6f0d48968cf", "name": "My Messaging App", "capabilities": {"messages": {"webhooks": {"inbound_url": {"address": "https://example.com/webhooks/inbound", "http_method": "POST"}}}}}
        ]
      }
    }
  }
}
