{
  "name": "subaccounts_get",
  "description": "Retrieve details of a specific subaccount by its API key.",
  "resource_group": "subaccounts",
  "endpoint": "/accounts/{api_key}/subaccounts/{subaccount_key}",
  "method": "GET",
  "parameters": [
    {"name": "api_key", "type": "string", "required": true, "location": "path", "description": "Your primary account API key."},
    {"name": "subaccount_key", "type": "string", "required": true, "location": "path", "description": "The subaccount API key."}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vonage.com/accounts/abc123/subaccounts/sub001",
    "headers": {"Authorization": "Bearer eyJhbGciOiJSUzI1NiJ9..."}
  },
  "response_example": {
    "status": 200,
    "body": {"api_key": "sub001", "name": "Marketing Team", "primary_account_api_key": "abc123", "use_primary_account_balance": true, "created_at": "2025-06-01T08:00:00Z", "suspended": false}
  }
}
