{
  "name": "voice_calls_stream_create",
  "description": "Stream an audio file into an active voice call. Supports MP3 and WAV formats hosted at a public URL.",
  "resource_group": "voice",
  "endpoint": "/v1/calls/{uuid}/stream",
  "method": "PUT",
  "parameters": [
    {"name": "uuid", "type": "string", "required": true, "location": "path", "description": "The UUID of the call."},
    {"name": "stream_url", "type": "array", "required": true, "description": "Array of audio file URLs to stream (MP3 or WAV)."},
    {"name": "loop", "type": "integer", "required": false, "description": "Number of times to repeat the audio. 0 for infinite. Default 1."},
    {"name": "level", "type": "string", "required": false, "description": "Audio level from -1 to 1. Default 0."}
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.vonage.com/v1/calls/63f61863-4a51-4f6b-86e1-46edebcf9356/stream",
    "headers": {"Content-Type": "application/json", "Authorization": "Bearer eyJhbGciOiJSUzI1NiJ9..."},
    "body": {"stream_url": ["https://example.com/audio/hold-music.mp3"], "loop": 0, "level": "0"}
  },
  "response_example": {"status": 200, "body": {"message": "Stream started", "uuid": "63f61863-4a51-4f6b-86e1-46edebcf9356"}}
}
