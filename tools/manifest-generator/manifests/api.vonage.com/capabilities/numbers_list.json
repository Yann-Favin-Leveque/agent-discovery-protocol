{
  "name": "numbers_list",
  "description": "List all phone numbers currently owned by your Vonage account. Supports filtering by country, pattern, and application ID.",
  "resource_group": "numbers",
  "endpoint": "/account/numbers",
  "method": "GET",
  "parameters": [
    {
      "name": "application_id",
      "type": "string",
      "required": false,
      "description": "Filter numbers linked to a specific application.",
      "in": "query"
    },
    {
      "name": "has_application",
      "type": "boolean",
      "required": false,
      "description": "Filter by whether the number has an application linked.",
      "in": "query"
    },
    {
      "name": "country",
      "type": "string",
      "required": false,
      "description": "Filter by 2-letter country code (e.g., 'US', 'GB').",
      "in": "query"
    },
    {
      "name": "pattern",
      "type": "string",
      "required": false,
      "description": "Pattern to match against the number.",
      "in": "query"
    },
    {
      "name": "search_pattern",
      "type": "integer",
      "required": false,
      "description": "How to apply pattern: 0=starts with, 1=anywhere, 2=ends with.",
      "in": "query"
    },
    {
      "name": "size",
      "type": "integer",
      "required": false,
      "description": "Page size (1-100). Default 10.",
      "in": "query"
    },
    {
      "name": "index",
      "type": "integer",
      "required": false,
      "description": "Page index (1-based). Default 1.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://rest.nexmo.com/account/numbers?country=US&size=20&api_key=abc123&api_secret=xyz789",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 3,
      "numbers": [
        {
          "country": "US",
          "msisdn": "12015550145",
          "type": "mobile-lvn",
          "features": [
            "SMS",
            "VOICE"
          ],
          "moHttpUrl": "",
          "voiceCallbackType": "app",
          "voiceCallbackValue": "app-id-123",
          "app_id": "app-id-123"
        }
      ]
    }
  }
}
