{
  "name": "voice_calls_talk_delete",
  "description": "Stop text-to-speech playback in an active voice call.",
  "resource_group": "voice",
  "endpoint": "/v1/calls/{uuid}/talk",
  "method": "DELETE",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The UUID of the call.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.vonage.com/v1/calls/63f61863-4a51-4f6b-86e1-46edebcf9356/talk",
    "headers": {
      "Authorization": "Bearer eyJhbGciOiJSUzI1NiJ9..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Talk stopped",
      "uuid": "63f61863-4a51-4f6b-86e1-46edebcf9356"
    }
  }
}
