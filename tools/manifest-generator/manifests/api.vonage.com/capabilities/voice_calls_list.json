{
  "name": "voice_calls_list",
  "description": "List all voice calls associated with your Vonage application, with optional filtering by status, date range, and conversation UUID.",
  "resource_group": "voice",
  "endpoint": "/v1/calls",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by call status: 'started', 'ringing', 'answered', 'machine', 'completed', 'busy', 'cancelled', 'failed', 'rejected', 'timeout', 'unanswered'."
    },
    {
      "name": "date_start",
      "type": "string",
      "required": false,
      "description": "Return calls placed after this date (ISO 8601 format)."
    },
    {
      "name": "date_end",
      "type": "string",
      "required": false,
      "description": "Return calls placed before this date (ISO 8601 format)."
    },
    {
      "name": "page_size",
      "type": "integer",
      "required": false,
      "description": "Number of results per page (1-100). Default 10."
    },
    {
      "name": "record_index",
      "type": "integer",
      "required": false,
      "description": "Starting record index for pagination. Default 0."
    },
    {
      "name": "order",
      "type": "string",
      "required": false,
      "description": "Sort order: 'asc' or 'desc'. Default 'desc'."
    },
    {
      "name": "conversation_uuid",
      "type": "string",
      "required": false,
      "description": "Filter by conversation UUID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.vonage.com/v1/calls?status=completed&page_size=20&date_start=2026-02-01T00:00:00Z",
    "headers": {
      "Authorization": "Bearer eyJhbGciOiJSUzI1NiJ9..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 42,
      "page_size": 20,
      "record_index": 0,
      "_embedded": {
        "calls": [
          {
            "uuid": "63f61863-4a51-4f6b-86e1-46edebcf9356",
            "conversation_uuid": "CON-f972836a-550f-45fa-956c-12a2ab5b7d22",
            "to": { "type": "phone", "number": "14155550123" },
            "from": { "type": "phone", "number": "12015550145" },
            "status": "completed",
            "direction": "outbound",
            "duration": "45",
            "start_time": "2026-02-28T14:30:00.000Z",
            "end_time": "2026-02-28T14:30:45.000Z",
            "price": "0.0100",
            "rate": "0.0127",
            "network": "310260"
          }
        ]
      }
    }
  }
}
