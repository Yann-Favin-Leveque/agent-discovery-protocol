{
  "name": "numbers_buy",
  "description": "Purchase an available phone number for your Vonage account. The number will be billed monthly.",
  "resource_group": "numbers",
  "endpoint": "/number/buy",
  "method": "POST",
  "parameters": [
    {
      "name": "country",
      "type": "string",
      "required": true,
      "description": "2-letter country code of the number.",
      "in": "body"
    },
    {
      "name": "msisdn",
      "type": "string",
      "required": true,
      "description": "The phone number to buy in international format without leading '+'.",
      "in": "body"
    },
    {
      "name": "target_api_key",
      "type": "string",
      "required": false,
      "description": "API key of the subaccount to assign the number to.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://rest.nexmo.com/number/buy",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "body": "api_key=abc123&api_secret=xyz789&country=US&msisdn=12015550100"
  },
  "response_example": {
    "status": 200,
    "body": {
      "error-code": "200",
      "error-code-label": "success"
    }
  }
}
