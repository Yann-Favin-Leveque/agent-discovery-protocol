{
  "name": "authorization",
  "description": "Manage authorization — request access token, refresh access token, revoke access token. Supports standard CRUD operations through the REST API.",
  "endpoint": "/oauth2/token",
  "method": "POST",
  "parameters": [],
  "request_example": {
    "method": "POST",
    "url": "https://api.box.com/2.0/oauth2/token",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {}
    }
  },
  "auth_scopes": [
    "root_readonly",
    "root_readwrite",
    "manage_app_users",
    "manage_managed_users",
    "manage_groups"
  ]
}
