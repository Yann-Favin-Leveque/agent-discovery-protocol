{
  "name": "collaborations_update",
  "description": "Update a collaboration role.",
  "resource_group": "collaborations",
  "endpoint": "/2.0/collaborations/{collaboration_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "collaboration_id",
      "type": "string",
      "description": "The collaboration ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "role",
      "type": "string",
      "description": "Updated role.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.box.com/2.0/collaborations/collab123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "role": "viewer"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "collaboration",
      "id": "collab123",
      "role": "viewer"
    }
  }
}
