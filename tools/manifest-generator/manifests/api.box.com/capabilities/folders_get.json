{
  "name": "folders_get",
  "description": "Retrieve folder metadata by ID.",
  "resource_group": "folders",
  "endpoint": "/2.0/folders/{folder_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "folder_id",
      "type": "string",
      "description": "The folder ID (use 0 for root).",
      "required": true,
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Fields to include.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/folders/0",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "folder",
      "id": "0",
      "name": "All Files"
    }
  }
}
