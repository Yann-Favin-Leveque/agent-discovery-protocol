{
  "name": "webhooks_get",
  "description": "Retrieve a specific webhook.",
  "resource_group": "webhooks",
  "endpoint": "/2.0/webhooks/{webhook_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "The webhook ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/webhooks/wh123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "webhook",
      "id": "wh123"
    }
  }
}
