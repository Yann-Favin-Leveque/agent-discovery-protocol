{
  "name": "webhooks_update",
  "description": "Update a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/2.0/webhooks/{webhook_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "webhook_id",
      "type": "string",
      "description": "The webhook ID.",
      "required": true
    },
    {
      "name": "address",
      "type": "string",
      "description": "Updated URL.",
      "required": false
    },
    {
      "name": "triggers",
      "type": "array",
      "description": "Updated triggers.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.box.com/2.0/webhooks/wh123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "address": "https://example.com/webhook-v2"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "webhook",
      "id": "wh123"
    }
  }
}