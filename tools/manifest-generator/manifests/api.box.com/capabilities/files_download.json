{
  "name": "files_download",
  "description": "Download the contents of a file in binary format.",
  "resource_group": "files",
  "endpoint": "/2.0/files/{file_id}/content",
  "method": "GET",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "version",
      "type": "string",
      "description": "Specific version to download.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/files/12345/content",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "<binary content>"
  }
}
