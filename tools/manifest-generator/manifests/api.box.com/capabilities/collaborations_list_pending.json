{
  "name": "collaborations_list_pending",
  "description": "List all pending collaborations.",
  "resource_group": "collaborations",
  "endpoint": "/2.0/collaborations",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "description": "Filter status: pending.",
      "required": true,
      "example": "pending"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/collaborations?status=pending",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 1,
      "entries": [
        {
          "type": "collaboration",
          "id": "collab456",
          "status": "pending"
        }
      ]
    }
  }
}