{
  "name": "collaborations_get",
  "description": "Retrieve a specific collaboration.",
  "resource_group": "collaborations",
  "endpoint": "/2.0/collaborations/{collaboration_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "collaboration_id",
      "type": "string",
      "description": "The collaboration ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/collaborations/collab123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "collaboration",
      "id": "collab123",
      "role": "editor"
    }
  }
}