{
  "name": "files_delete",
  "description": "Delete a file, permanently or to trash.",
  "resource_group": "files",
  "endpoint": "/2.0/files/{file_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.box.com/2.0/files/12345",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  }
}
