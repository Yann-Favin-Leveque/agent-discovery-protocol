{
  "name": "folders_delete",
  "description": "Delete a folder and its contents.",
  "resource_group": "folders",
  "endpoint": "/2.0/folders/{folder_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "folder_id",
      "type": "string",
      "description": "The folder ID.",
      "required": true
    },
    {
      "name": "recursive",
      "type": "boolean",
      "description": "Delete non-empty folder recursively.",
      "required": false
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.box.com/2.0/folders/67890?recursive=true",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204
  }
}