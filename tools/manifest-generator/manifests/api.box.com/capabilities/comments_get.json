{
  "name": "comments_get",
  "description": "Retrieve a specific comment.",
  "resource_group": "comments",
  "endpoint": "/2.0/comments/{comment_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "comment_id",
      "type": "string",
      "description": "The comment ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/comments/comment123",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "comment",
      "id": "comment123",
      "message": "Great file!"
    }
  }
}