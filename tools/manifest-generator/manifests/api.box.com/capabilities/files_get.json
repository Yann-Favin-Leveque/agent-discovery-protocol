{
  "name": "files_get",
  "description": "Retrieve file metadata by ID.",
  "resource_group": "files",
  "endpoint": "/2.0/files/{file_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "description": "The file ID.",
      "required": true
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Comma-separated fields to include.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/files/12345",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "file",
      "id": "12345",
      "name": "document.pdf",
      "size": 123456
    }
  }
}