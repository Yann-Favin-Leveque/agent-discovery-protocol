{
  "name": "shared_links_find",
  "description": "Find a file or folder by its shared link URL.",
  "resource_group": "shared_links",
  "endpoint": "/2.0/shared_items",
  "method": "GET",
  "parameters": [
    {
      "name": "boxapi",
      "type": "string",
      "description": "BoxAPI header with shared_link URL.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/shared_items",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "BoxApi": "shared_link=https://app.box.com/s/abc123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "file",
      "id": "12345",
      "name": "doc.pdf"
    }
  }
}