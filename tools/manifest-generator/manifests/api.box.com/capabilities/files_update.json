{
  "name": "files_update",
  "description": "Update a file's metadata (rename, move, or set description).",
  "resource_group": "files",
  "endpoint": "/2.0/files/{file_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "file_id",
      "type": "string",
      "description": "The file ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "New file name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "description": "New description.",
      "required": false,
      "in": "body"
    },
    {
      "name": "parent",
      "type": "object",
      "description": "New parent folder.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.box.com/2.0/files/12345",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "renamed.pdf"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "file",
      "id": "12345",
      "name": "renamed.pdf"
    }
  }
}
