{
  "name": "comments_update",
  "description": "Update a comment.",
  "resource_group": "comments",
  "endpoint": "/2.0/comments/{comment_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "comment_id",
      "type": "string",
      "description": "The comment ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "message",
      "type": "string",
      "description": "Updated message.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.box.com/2.0/comments/comment123",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "message": "Updated comment"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "comment",
      "id": "comment123",
      "message": "Updated comment"
    }
  }
}
