{
  "name": "folders_list_items",
  "description": "List all items in a folder.",
  "resource_group": "folders",
  "endpoint": "/2.0/folders/{folder_id}/items",
  "method": "GET",
  "parameters": [
    {
      "name": "folder_id",
      "type": "string",
      "description": "The folder ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "description": "Fields to include.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max items per page.",
      "required": false,
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.box.com/2.0/folders/0/items?limit=100",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "total_count": 5,
      "entries": [
        {
          "type": "file",
          "id": "12345",
          "name": "doc.pdf"
        }
      ]
    }
  }
}
