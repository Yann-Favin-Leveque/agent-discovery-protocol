{
  "name": "routes_get",
  "description": "Retrieve a single route by ID.",
  "resource_group": "routes",
  "endpoint": "/v3/routes/{route_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "route_id",
      "type": "string",
      "description": "Route ID.",
      "required": true,
      "example": "route-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/routes/route-123",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "route": {
        "id": "route-123",
        "expression": "match_recipient('.*@mg.example.com')"
      }
    }
  }
}
