{
  "name": "domains_create",
  "description": "Create a new sending domain.",
  "resource_group": "domains",
  "endpoint": "/v3/domains",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Domain name.",
      "required": true,
      "example": "mg.example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mailgun.com/v3/domains",
    "headers": {
      "Authorization": "Basic {base64(api:key)}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "mg.example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "domain": {
        "name": "mg.example.com",
        "state": "unverified"
      }
    }
  }
}
