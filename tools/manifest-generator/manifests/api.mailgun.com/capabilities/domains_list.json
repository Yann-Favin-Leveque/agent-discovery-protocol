{
  "name": "domains_list",
  "description": "Retrieve a list of all domains in your account.",
  "resource_group": "domains",
  "endpoint": "/v3/domains",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "number",
      "description": "Max domains to return.",
      "required": false,
      "example": 100,
      "in": "query"
    },
    {
      "name": "skip",
      "type": "number",
      "description": "Number of records to skip.",
      "required": false,
      "example": 0,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/domains",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "name": "mg.example.com",
          "state": "active",
          "type": "custom"
        }
      ],
      "total_count": 1
    }
  }
}
