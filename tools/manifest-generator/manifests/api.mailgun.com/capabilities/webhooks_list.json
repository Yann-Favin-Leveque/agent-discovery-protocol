{
  "name": "webhooks_list",
  "description": "Retrieve all webhooks for a domain.",
  "resource_group": "webhooks",
  "endpoint": "/v3/domains/{domain}/webhooks",
  "method": "GET",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/domains/mg.example.com/webhooks",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "webhooks": {
        "clicked": {
          "urls": [
            "https://example.com/clicked"
          ]
        }
      }
    }
  }
}
