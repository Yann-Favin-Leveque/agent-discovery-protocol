{
  "name": "domains_delete",
  "description": "Delete a domain.",
  "resource_group": "domains",
  "endpoint": "/v3/domains/{domain}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name.",
      "required": true,
      "example": "mg.example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/domains/mg.example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Domain has been deleted"
    }
  }
}
