{
  "name": "mailing_lists_members_delete",
  "description": "Remove a member from a mailing list.",
  "resource_group": "mailing_lists",
  "endpoint": "/v3/lists/{address}/members/{member_address}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "description": "List email address.",
      "required": true,
      "example": "list@mg.example.com"
    },
    {
      "name": "member_address",
      "type": "string",
      "description": "Member email address.",
      "required": true,
      "example": "member@example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/lists/list@mg.example.com/members/member@example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "member": {
        "address": "member@example.com"
      },
      "message": "Mailing list member has been deleted"
    }
  }
}