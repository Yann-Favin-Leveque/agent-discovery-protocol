{
  "name": "mailing_lists_list",
  "description": "Retrieve all mailing lists.",
  "resource_group": "mailing_lists",
  "endpoint": "/v3/lists/pages",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "number",
      "description": "Max lists to return.",
      "required": false,
      "example": 100,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/lists/pages?limit=100",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "address": "list@mg.example.com",
          "name": "Newsletter",
          "members_count": 100
        }
      ]
    }
  }
}
