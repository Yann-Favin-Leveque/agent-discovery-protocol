{
  "name": "bounces_clear",
  "description": "Clear all bounces for a domain.",
  "resource_group": "bounces",
  "endpoint": "/v3/{domain}/bounces",
  "method": "DELETE",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/mg.example.com/bounces",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Bounces have been cleared"
    }
  }
}