{
  "name": "messages_send",
  "description": "Send an email message via the Mailgun API. Supports HTML, plain text, attachments, and custom headers.",
  "resource_group": "messages",
  "endpoint": "/v3/{domain}/messages",
  "method": "POST",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun sending domain.",
      "required": true,
      "example": "mg.example.com",
      "in": "path"
    },
    {
      "name": "from",
      "type": "string",
      "description": "Sender email address.",
      "required": true,
      "example": "Sender <sender@mg.example.com>",
      "in": "body"
    },
    {
      "name": "to",
      "type": "string",
      "description": "Recipient email address(es).",
      "required": true,
      "example": "user@example.com",
      "in": "body"
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Email subject.",
      "required": true,
      "example": "Hello",
      "in": "body"
    },
    {
      "name": "text",
      "type": "string",
      "description": "Plain text body.",
      "required": false,
      "in": "body"
    },
    {
      "name": "html",
      "type": "string",
      "description": "HTML body.",
      "required": false,
      "example": "<h1>Hello</h1>",
      "in": "body"
    },
    {
      "name": "cc",
      "type": "string",
      "description": "CC recipients.",
      "required": false,
      "in": "body"
    },
    {
      "name": "bcc",
      "type": "string",
      "description": "BCC recipients.",
      "required": false,
      "in": "body"
    },
    {
      "name": "o:tag",
      "type": "string",
      "description": "Tag for tracking.",
      "required": false,
      "in": "body"
    },
    {
      "name": "o:tracking",
      "type": "boolean",
      "description": "Enable tracking.",
      "required": false,
      "example": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mailgun.com/v3/mg.example.com/messages",
    "headers": {
      "Authorization": "Basic {base64(api:key)}",
      "Content-Type": "multipart/form-data"
    },
    "body": {
      "from": "sender@mg.example.com",
      "to": "user@example.com",
      "subject": "Hello",
      "html": "<h1>Hello</h1>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "<abc123@mg.example.com>",
      "message": "Queued. Thank you."
    }
  }
}
