{
  "name": "mailing_lists_members_list",
  "description": "Retrieve members of a mailing list.",
  "resource_group": "mailing_lists",
  "endpoint": "/v3/lists/{address}/members/pages",
  "method": "GET",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "description": "List email address.",
      "required": true,
      "example": "list@mg.example.com",
      "in": "path"
    },
    {
      "name": "limit",
      "type": "number",
      "description": "Max members to return.",
      "required": false,
      "example": 100,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/lists/list@mg.example.com/members/pages?limit=100",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "address": "member@example.com",
          "name": "John",
          "subscribed": true
        }
      ]
    }
  }
}
