{
  "name": "bounces_delete",
  "description": "Remove an address from the bounce list.",
  "resource_group": "bounces",
  "endpoint": "/v3/{domain}/bounces/{address}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com"
    },
    {
      "name": "address",
      "type": "string",
      "description": "Email address to remove.",
      "required": true,
      "example": "bounce@example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/mg.example.com/bounces/bounce@example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Bounce has been removed"
    }
  }
}