{
  "name": "unsubscribes_delete",
  "description": "Remove an address from the unsubscribe list.",
  "resource_group": "unsubscribes",
  "endpoint": "/v3/{domain}/unsubscribes/{address}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com"
    },
    {
      "name": "address",
      "type": "string",
      "description": "Email address.",
      "required": true,
      "example": "unsub@example.com"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/mg.example.com/unsubscribes/unsub@example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Unsubscribe event has been removed"
    }
  }
}