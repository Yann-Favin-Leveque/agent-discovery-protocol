{
  "name": "routes_delete",
  "description": "Delete a route.",
  "resource_group": "routes",
  "endpoint": "/v3/routes/{route_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "route_id",
      "type": "string",
      "description": "Route ID.",
      "required": true,
      "example": "route-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/routes/route-123",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Route has been deleted"
    }
  }
}
