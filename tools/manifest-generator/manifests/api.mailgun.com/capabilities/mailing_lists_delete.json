{
  "name": "mailing_lists_delete",
  "description": "Delete a mailing list.",
  "resource_group": "mailing_lists",
  "endpoint": "/v3/lists/{address}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "description": "List email address.",
      "required": true,
      "example": "list@mg.example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/lists/list@mg.example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Mailing list has been deleted"
    }
  }
}
