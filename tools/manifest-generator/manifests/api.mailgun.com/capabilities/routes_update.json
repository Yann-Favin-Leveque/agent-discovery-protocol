{
  "name": "routes_update",
  "description": "Update an existing route.",
  "resource_group": "routes",
  "endpoint": "/v3/routes/{route_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "route_id",
      "type": "string",
      "description": "Route ID.",
      "required": true,
      "example": "route-123",
      "in": "path"
    },
    {
      "name": "expression",
      "type": "string",
      "description": "Updated expression.",
      "required": false,
      "in": "body"
    },
    {
      "name": "action",
      "type": "array",
      "description": "Updated actions.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.mailgun.com/v3/routes/route-123",
    "headers": {
      "Authorization": "Basic {base64(api:key)}",
      "Content-Type": "application/json"
    },
    "body": {
      "priority": 1
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Route has been updated"
    }
  }
}
