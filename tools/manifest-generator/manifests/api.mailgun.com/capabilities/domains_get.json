{
  "name": "domains_get",
  "description": "Retrieve a single domain by name.",
  "resource_group": "domains",
  "endpoint": "/v3/domains/{domain}",
  "method": "GET",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name.",
      "required": true,
      "example": "mg.example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/domains/mg.example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "domain": {
        "name": "mg.example.com",
        "state": "active"
      },
      "receiving_dns_records": [],
      "sending_dns_records": []
    }
  }
}
