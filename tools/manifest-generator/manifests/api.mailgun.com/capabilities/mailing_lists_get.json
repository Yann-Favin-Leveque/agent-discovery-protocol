{
  "name": "mailing_lists_get",
  "description": "Retrieve a single mailing list.",
  "resource_group": "mailing_lists",
  "endpoint": "/v3/lists/{address}",
  "method": "GET",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "description": "List email address.",
      "required": true,
      "example": "list@mg.example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/lists/list@mg.example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "list": {
        "address": "list@mg.example.com",
        "name": "Newsletter",
        "members_count": 100
      }
    }
  }
}
