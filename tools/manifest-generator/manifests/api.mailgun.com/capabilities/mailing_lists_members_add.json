{
  "name": "mailing_lists_members_add",
  "description": "Add a member to a mailing list.",
  "resource_group": "mailing_lists",
  "endpoint": "/v3/lists/{address}/members",
  "method": "POST",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "description": "List email address.",
      "required": true,
      "example": "list@mg.example.com"
    },
    {
      "name": "member_address",
      "type": "string",
      "description": "Member email address.",
      "required": true,
      "example": "member@example.com"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Member name.",
      "required": false,
      "example": "John"
    },
    {
      "name": "subscribed",
      "type": "boolean",
      "description": "Subscription status.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mailgun.com/v3/lists/list@mg.example.com/members",
    "headers": {
      "Authorization": "Basic {base64(api:key)}",
      "Content-Type": "application/json"
    },
    "body": {
      "address": "member@example.com",
      "name": "John",
      "subscribed": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "member": {
        "address": "member@example.com"
      },
      "message": "Mailing list member has been created"
    }
  }
}