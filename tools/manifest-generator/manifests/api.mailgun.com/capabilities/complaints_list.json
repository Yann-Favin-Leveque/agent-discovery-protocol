{
  "name": "complaints_list",
  "description": "Retrieve spam complaints for a domain.",
  "resource_group": "complaints",
  "endpoint": "/v3/{domain}/complaints",
  "method": "GET",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/mg.example.com/complaints",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "address": "spam@example.com",
          "created_at": "2024-01-01T00:00:00Z"
        }
      ]
    }
  }
}
