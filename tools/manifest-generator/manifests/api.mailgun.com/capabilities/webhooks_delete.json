{
  "name": "webhooks_delete",
  "description": "Delete a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/v3/domains/{domain}/webhooks/{webhook_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com"
    },
    {
      "name": "webhook_id",
      "type": "string",
      "description": "Webhook event type.",
      "required": true,
      "example": "delivered"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.mailgun.com/v3/domains/mg.example.com/webhooks/delivered",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Webhook has been deleted"
    }
  }
}