{
  "name": "mailing_lists_update",
  "description": "Update a mailing list.",
  "resource_group": "mailing_lists",
  "endpoint": "/v3/lists/{address}",
  "method": "PUT",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "description": "List email address.",
      "required": true,
      "example": "list@mg.example.com",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.mailgun.com/v3/lists/list@mg.example.com",
    "headers": {
      "Authorization": "Basic {base64(api:key)}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Newsletter"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Mailing list has been updated"
    }
  }
}
