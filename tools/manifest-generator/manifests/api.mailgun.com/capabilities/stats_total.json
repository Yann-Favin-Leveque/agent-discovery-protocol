{
  "name": "stats_total",
  "description": "Retrieve total statistics for a domain.",
  "resource_group": "stats",
  "endpoint": "/v3/{domain}/stats/total",
  "method": "GET",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com",
      "in": "path"
    },
    {
      "name": "event",
      "type": "string",
      "description": "Event type to filter by.",
      "required": true,
      "example": "delivered",
      "in": "query"
    },
    {
      "name": "start",
      "type": "string",
      "description": "Start date (RFC 2822 or Unix timestamp).",
      "required": false,
      "in": "query"
    },
    {
      "name": "end",
      "type": "string",
      "description": "End date.",
      "required": false,
      "in": "query"
    },
    {
      "name": "duration",
      "type": "string",
      "description": "Time period (e.g., 1m, 1d, 7d).",
      "required": false,
      "example": "7d",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/mg.example.com/stats/total?event=delivered&duration=7d",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "stats": [
        {
          "time": "2024-01-01T00:00:00Z",
          "delivered": {
            "total": 1000
          },
          "accepted": {
            "total": 1050
          }
        }
      ]
    }
  }
}
