{
  "name": "domains_verify",
  "description": "Verify a domain's DNS records.",
  "resource_group": "domains",
  "endpoint": "/v3/domains/{domain}/verify",
  "method": "PUT",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Domain name.",
      "required": true,
      "example": "mg.example.com"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.mailgun.com/v3/domains/mg.example.com/verify",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "domain": {
        "name": "mg.example.com",
        "state": "active"
      }
    }
  }
}