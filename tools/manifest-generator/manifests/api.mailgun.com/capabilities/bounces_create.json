{
  "name": "bounces_create",
  "description": "Add an address to the bounce list.",
  "resource_group": "bounces",
  "endpoint": "/v3/{domain}/bounces",
  "method": "POST",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com",
      "in": "path"
    },
    {
      "name": "address",
      "type": "string",
      "description": "Email address to add.",
      "required": true,
      "example": "bounce@example.com",
      "in": "body"
    },
    {
      "name": "code",
      "type": "string",
      "description": "Error code.",
      "required": false,
      "example": "550",
      "in": "body"
    },
    {
      "name": "error",
      "type": "string",
      "description": "Error description.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.mailgun.com/v3/mg.example.com/bounces",
    "headers": {
      "Authorization": "Basic {base64(api:key)}",
      "Content-Type": "application/json"
    },
    "body": {
      "address": "bounce@example.com",
      "code": "550"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Address has been added to the bounces table",
      "address": "bounce@example.com"
    }
  }
}
