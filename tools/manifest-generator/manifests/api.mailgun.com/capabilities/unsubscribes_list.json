{
  "name": "unsubscribes_list",
  "description": "Retrieve unsubscribed email addresses for a domain.",
  "resource_group": "unsubscribes",
  "endpoint": "/v3/{domain}/unsubscribes",
  "method": "GET",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "description": "Your Mailgun domain.",
      "required": true,
      "example": "mg.example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.mailgun.com/v3/mg.example.com/unsubscribes",
    "headers": {
      "Authorization": "Basic {base64(api:key)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "address": "unsub@example.com",
          "tags": [
            "*"
          ],
          "created_at": "2024-01-01T00:00:00Z"
        }
      ]
    }
  }
}