{
  "name": "members_list",
  "description": "Retrieve a list of team members (agents) for a property.",
  "endpoint": "/v1/property/{propertyId}/members",
  "method": "GET",
  "resource_group": "members",
  "parameters": [
    {
      "name": "propertyId",
      "type": "string",
      "description": "The property ID",
      "required": true,
      "example": "property_id_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tawk.to/v1/property/property_id_123/members",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "agent_001",
          "name": "Jane Smith",
          "email": "jane@company.com",
          "role": "agent",
          "status": "online"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}