{
  "name": "get_visitor_info",
  "description": "Retrieve information about a specific visitor including their name, email, location, and browsing history on your site.",
  "endpoint": "/v1/property/{property_id}/visitors/{visitor_id}",
  "method": "GET",
  "parameters": [
    { "name": "property_id", "type": "string", "description": "The unique identifier for your tawk.to property.", "required": true, "example": "prop_abc123def456" },
    { "name": "visitor_id", "type": "string", "description": "The unique identifier of the visitor.", "required": true, "example": "visitor_xyz789" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tawk.to/v1/property/prop_abc123def456/visitors/visitor_xyz789",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": {
        "id": "visitor_xyz789",
        "name": "Jane Smith",
        "email": "jane@example.com",
        "city": "San Francisco",
        "country": "US",
        "current_page": "https://example.com/pricing",
        "pages_viewed": 5,
        "first_visit": "2024-01-10T08:00:00Z"
      }
    }
  }
}
