{
  "name": "messages_send",
  "description": "Send a message to an active chat conversation as an agent.",
  "endpoint": "/v1/property/{propertyId}/chat/{chatId}/message",
  "method": "POST",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "propertyId",
      "type": "string",
      "description": "The property ID",
      "required": true,
      "example": "property_id_123"
    },
    {
      "name": "chatId",
      "type": "string",
      "description": "The active chat session ID",
      "required": true,
      "example": "chat_123"
    },
    {
      "name": "body",
      "type": "string",
      "description": "The message text",
      "required": true,
      "example": "How can I help you?"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.tawk.to/v1/property/property_id_123/chat/chat_123/message",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "body": "How can I help you?"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "messageId": "msg_001"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}