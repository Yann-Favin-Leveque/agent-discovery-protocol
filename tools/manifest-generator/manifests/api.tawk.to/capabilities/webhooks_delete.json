{
  "name": "webhooks_delete",
  "description": "Delete a webhook subscription for a property.",
  "endpoint": "/v1/property/{propertyId}/webhooks/{webhookId}",
  "method": "DELETE",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "propertyId",
      "type": "string",
      "description": "The property ID",
      "required": true,
      "example": "property_id_123",
      "in": "path"
    },
    {
      "name": "webhookId",
      "type": "string",
      "description": "The webhook ID to delete",
      "required": true,
      "example": "wh_001",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.tawk.to/v1/property/property_id_123/webhooks/wh_001",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
