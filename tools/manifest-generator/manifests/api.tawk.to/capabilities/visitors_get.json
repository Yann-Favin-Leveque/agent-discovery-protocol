{
  "name": "visitors_get",
  "description": "Retrieve information about a specific visitor including name, email, location, and browsing history.",
  "endpoint": "/v1/property/{propertyId}/visitor/{visitorId}",
  "method": "GET",
  "resource_group": "visitors",
  "parameters": [
    {
      "name": "propertyId",
      "type": "string",
      "description": "The property ID",
      "required": true,
      "example": "property_id_123"
    },
    {
      "name": "visitorId",
      "type": "string",
      "description": "The visitor ID",
      "required": true,
      "example": "visitor_789"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tawk.to/v1/property/property_id_123/visitor/visitor_789",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "visitor_789",
      "name": "John Doe",
      "email": "john@example.com",
      "city": "New York",
      "country": "US"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}