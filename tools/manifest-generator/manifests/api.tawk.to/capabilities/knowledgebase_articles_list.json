{
  "name": "knowledgebase_articles_list",
  "description": "List knowledge base articles for a property.",
  "endpoint": "/v1/property/{propertyId}/kb/articles",
  "method": "GET",
  "resource_group": "knowledgebase",
  "parameters": [
    {
      "name": "propertyId",
      "type": "string",
      "description": "The property ID",
      "required": true,
      "example": "property_id_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tawk.to/v1/property/property_id_123/kb/articles",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "article_001",
          "title": "Getting Started",
          "category": "Setup",
          "status": "published"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}