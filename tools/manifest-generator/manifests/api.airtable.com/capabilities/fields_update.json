{
  "name": "fields_update",
  "description": "Update a field's name, description, or configuration.",
  "resource_group": "fields",
  "endpoint": "/v0/meta/bases/{baseId}/tables/{tableIdOrName}/fields/{fieldId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table"
    },
    {
      "name": "fieldId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the field"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New field name"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New description"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}