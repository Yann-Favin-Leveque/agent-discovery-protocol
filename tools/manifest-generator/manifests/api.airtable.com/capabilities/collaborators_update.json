{
  "name": "collaborators_update",
  "description": "Update a collaborator's permissions.",
  "resource_group": "collaborators",
  "endpoint": "/v0/meta/bases/{baseId}/collaborators/{userId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base"
    },
    {
      "name": "userId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "User ID of the collaborator"
    },
    {
      "name": "permissionLevel",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "New permission level"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}