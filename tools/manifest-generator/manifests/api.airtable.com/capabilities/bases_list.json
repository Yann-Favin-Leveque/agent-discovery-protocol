{
  "name": "bases_list",
  "description": "List all bases accessible to the authenticated user.",
  "resource_group": "bases",
  "endpoint": "/v0/meta/bases",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination offset"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ],
  "response_example": {
    "bases": [
      {
        "id": "appABC123",
        "name": "My Base",
        "permissionLevel": "create"
      }
    ]
  }
}