{
  "name": "comments_create",
  "description": "Add a comment to a record.",
  "resource_group": "comments",
  "endpoint": "/v0/{baseId}/{tableIdOrName}/{recordId}/comments",
  "method": "POST",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table"
    },
    {
      "name": "recordId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the record"
    },
    {
      "name": "text",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Comment text"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ],
  "request_example": {
    "text": "This looks good!"
  }
}