{
  "name": "webhooks_payloads_list",
  "description": "List webhook payloads.",
  "resource_group": "webhooks",
  "endpoint": "/v0/bases/{baseId}/webhooks/{webhookId}/payloads",
  "method": "GET",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "webhookId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the webhook",
      "in": "path"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination cursor",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}
