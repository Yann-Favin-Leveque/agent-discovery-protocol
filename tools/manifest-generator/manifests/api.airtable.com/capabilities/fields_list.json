{
  "name": "fields_list",
  "description": "List fields in a table.",
  "resource_group": "fields",
  "endpoint": "/v0/meta/bases/{baseId}/tables/{tableIdOrName}/fields",
  "method": "GET",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}
