{
  "name": "views_list",
  "description": "List views in a table.",
  "resource_group": "views",
  "endpoint": "/v0/meta/bases/{baseId}/tables/{tableIdOrName}/views",
  "method": "GET",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}
