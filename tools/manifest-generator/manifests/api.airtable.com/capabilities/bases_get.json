{
  "name": "bases_get",
  "description": "Get schema of a base including all tables and fields.",
  "resource_group": "bases",
  "endpoint": "/v0/meta/bases/{baseId}/tables",
  "method": "GET",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ],
  "response_example": {
    "tables": [
      {
        "id": "tblABC",
        "name": "Tasks",
        "fields": [
          {
            "id": "fldABC",
            "name": "Name",
            "type": "singleLineText"
          }
        ]
      }
    ]
  }
}