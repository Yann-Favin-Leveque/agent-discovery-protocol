{
  "name": "get_base_schema",
  "description": "Retrieve the complete schema of an Airtable base, including all tables and their field definitions. For each field, returns the name, type, and type-specific configuration. Essential for understanding the structure of a base before reading or writing records.",
  "endpoint": "/v0/meta/bases/{baseId}/tables",
  "method": "GET",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "description": "The ID of the base to retrieve the schema for (starts with 'app').",
      "required": true,
      "example": "appABC123def456"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.airtable.com/v0/meta/bases/appABC123def456/tables",
    "headers": {
      "Authorization": "Bearer pat1234567890abcdef"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tables": [
        {
          "id": "tblXYZ789ghi012",
          "name": "Tasks",
          "description": "Project tasks and assignments",
          "primaryFieldId": "fldPrimary001",
          "fields": [
            {
              "id": "fldPrimary001",
              "name": "Name",
              "type": "singleLineText"
            },
            {
              "id": "fldStatus002",
              "name": "Status",
              "type": "singleSelect",
              "options": {
                "choices": [
                  { "id": "selChoice1", "name": "To Do", "color": "blueLight2" },
                  { "id": "selChoice2", "name": "In Progress", "color": "yellowLight2" },
                  { "id": "selChoice3", "name": "Done", "color": "greenLight2" }
                ]
              }
            },
            {
              "id": "fldDate003",
              "name": "Due Date",
              "type": "date",
              "options": {
                "dateFormat": { "name": "iso" }
              }
            }
          ],
          "views": [
            {
              "id": "viwGridView01",
              "name": "Grid view",
              "type": "grid"
            }
          ]
        }
      ]
    }
  }
}
