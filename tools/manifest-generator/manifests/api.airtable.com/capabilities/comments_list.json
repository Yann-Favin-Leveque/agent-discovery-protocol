{
  "name": "comments_list",
  "description": "List comments on a record.",
  "resource_group": "comments",
  "endpoint": "/v0/{baseId}/{tableIdOrName}/{recordId}/comments",
  "method": "GET",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table",
      "in": "path"
    },
    {
      "name": "recordId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the record",
      "in": "path"
    },
    {
      "name": "offset",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination offset",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}
