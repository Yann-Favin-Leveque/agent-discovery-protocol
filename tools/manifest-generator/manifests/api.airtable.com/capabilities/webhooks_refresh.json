{
  "name": "webhooks_refresh",
  "description": "Refresh a webhook to extend its expiration.",
  "resource_group": "webhooks",
  "endpoint": "/v0/bases/{baseId}/webhooks/{webhookId}/refresh",
  "method": "POST",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base"
    },
    {
      "name": "webhookId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the webhook"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}