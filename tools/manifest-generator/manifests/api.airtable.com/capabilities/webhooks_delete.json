{
  "name": "webhooks_delete",
  "description": "Delete a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/v0/bases/{baseId}/webhooks/{webhookId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "webhookId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the webhook",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}
