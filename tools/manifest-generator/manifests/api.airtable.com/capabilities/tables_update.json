{
  "name": "tables_update",
  "description": "Update a table's name or description.",
  "resource_group": "tables",
  "endpoint": "/v0/meta/bases/{baseId}/tables/{tableIdOrName}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New table name",
      "in": "body"
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "location": "body",
      "description": "New description",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}
