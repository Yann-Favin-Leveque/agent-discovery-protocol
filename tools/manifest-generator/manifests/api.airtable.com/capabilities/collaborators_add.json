{
  "name": "collaborators_add",
  "description": "Add a collaborator to a base.",
  "resource_group": "collaborators",
  "endpoint": "/v0/meta/bases/{baseId}/collaborators",
  "method": "POST",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base"
    },
    {
      "name": "email",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Email of the collaborator"
    },
    {
      "name": "permissionLevel",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Permission level (read, comment, edit, create)"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}