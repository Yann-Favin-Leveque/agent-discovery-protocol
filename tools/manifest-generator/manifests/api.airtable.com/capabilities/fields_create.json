{
  "name": "fields_create",
  "description": "Create a new field in a table.",
  "resource_group": "fields",
  "endpoint": "/v0/meta/bases/{baseId}/tables/{tableIdOrName}/fields",
  "method": "POST",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Field name",
      "in": "body"
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Field type (singleLineText, number, singleSelect, etc.)",
      "in": "body"
    },
    {
      "name": "options",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Type-specific options",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}
