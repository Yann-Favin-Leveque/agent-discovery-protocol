{
  "name": "records_create",
  "description": "Create one or more new records.",
  "resource_group": "records",
  "endpoint": "/v0/{baseId}/{tableIdOrName}",
  "method": "POST",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base",
      "in": "path"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table",
      "in": "path"
    },
    {
      "name": "records",
      "type": "array",
      "required": true,
      "location": "body",
      "description": "Array of record objects with fields",
      "in": "body"
    },
    {
      "name": "typecast",
      "type": "boolean",
      "required": false,
      "location": "body",
      "description": "Automatically typecast values",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ],
  "request_example": {
    "records": [
      {
        "fields": {
          "Name": "New Task",
          "Status": "Todo"
        }
      }
    ]
  }
}
