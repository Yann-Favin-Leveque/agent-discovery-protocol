{
  "name": "records_get",
  "description": "Get a single record by ID.",
  "resource_group": "records",
  "endpoint": "/v0/{baseId}/{tableIdOrName}/{recordId}",
  "method": "GET",
  "parameters": [
    {
      "name": "baseId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the Airtable base"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID or name of the table"
    },
    {
      "name": "recordId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the record"
    }
  ],
  "auth_scopes": [
    "data.records:read",
    "data.records:write",
    "schema.bases:read",
    "schema.bases:write"
  ]
}