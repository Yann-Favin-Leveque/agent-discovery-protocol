{
  "name": "account_get",
  "description": "Retrieve account details including balance and timezone.",
  "resource_group": "account",
  "endpoint": "/v1/Account/{auth_id}/",
  "method": "GET",
  "parameters": [
    {
      "name": "auth_id",
      "type": "string",
      "description": "Plivo Auth ID (path parameter).",
      "required": true,
      "example": "MAXXXXXXXXXXXXXXX",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.plivo.com/v1/Account/{auth_id}/",
    "headers": {
      "Authorization": "Basic {base64(auth_id:auth_token)}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "account_type": "standard",
      "auth_id": "MAXXXXXXXXXXXXXXX",
      "cash_credits": "100.00000",
      "city": "San Francisco",
      "name": "My Account"
    }
  }
}
