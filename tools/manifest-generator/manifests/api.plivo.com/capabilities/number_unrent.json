{
  "name": "number_unrent",
  "description": "Unrent (release) a phone number from your account.",
  "resource_group": "number",
  "endpoint": "/v1/Account/{auth_id}/Number/{number}/",
  "method": "DELETE",
  "parameters": [
    {
      "name": "auth_id",
      "type": "string",
      "description": "Plivo Auth ID (path parameter).",
      "required": true,
      "example": "MAXXXXXXXXXXXXXXX",
      "in": "path"
    },
    {
      "name": "number",
      "type": "string",
      "description": "The phone number to unrent (path parameter).",
      "required": true,
      "example": "14151234567",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.plivo.com/v1/Account/{auth_id}/Number/{number}/",
    "headers": {
      "Authorization": "Basic {base64(auth_id:auth_token)}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
