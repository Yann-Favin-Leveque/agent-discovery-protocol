{
  "name": "message_get",
  "description": "Retrieve details of a specific message by its UUID.",
  "resource_group": "message",
  "endpoint": "/v1/Account/{auth_id}/Message/{message_uuid}/",
  "method": "GET",
  "parameters": [
    {
      "name": "auth_id",
      "type": "string",
      "description": "Plivo Auth ID (path parameter).",
      "required": true,
      "example": "MAXXXXXXXXXXXXXXX",
      "in": "path"
    },
    {
      "name": "message_uuid",
      "type": "string",
      "description": "The message UUID (path parameter).",
      "required": true,
      "example": "db3ce55a-7f1d-11e1-8ea7-1231380bc196",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.plivo.com/v1/Account/{auth_id}/Message/{message_uuid}/",
    "headers": {
      "Authorization": "Basic {base64(auth_id:auth_token)}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message_uuid": "db3ce55a-7f1d-11e1-8ea7-1231380bc196",
      "from_number": "+14151234567",
      "to_number": "+14157654321",
      "message_state": "delivered",
      "message_type": "sms",
      "total_amount": "0.00350",
      "total_rate": "0.00350"
    }
  }
}
