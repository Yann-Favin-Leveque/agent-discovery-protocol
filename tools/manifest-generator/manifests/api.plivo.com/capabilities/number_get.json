{
  "name": "number_get",
  "description": "Retrieve details of a specific rented number.",
  "resource_group": "number",
  "endpoint": "/v1/Account/{auth_id}/Number/{number}/",
  "method": "GET",
  "parameters": [
    {
      "name": "auth_id",
      "type": "string",
      "description": "Plivo Auth ID (path parameter).",
      "required": true,
      "example": "MAXXXXXXXXXXXXXXX"
    },
    {
      "name": "number",
      "type": "string",
      "description": "The phone number (path parameter).",
      "required": true,
      "example": "14151234567"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.plivo.com/v1/Account/{auth_id}/Number/{number}/",
    "headers": {
      "Authorization": "Basic {base64(auth_id:auth_token)}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "number": "+14151234567",
      "type": "local",
      "country": "US",
      "sms_enabled": true,
      "voice_enabled": true,
      "monthly_rental_rate": "0.80"
    }
  }
}