{
  "name": "application_get",
  "description": "Retrieve details of a specific application by ID.",
  "resource_group": "application",
  "endpoint": "/v1/Account/{auth_id}/Application/{app_id}/",
  "method": "GET",
  "parameters": [
    {
      "name": "auth_id",
      "type": "string",
      "description": "Plivo Auth ID (path parameter).",
      "required": true,
      "example": "MAXXXXXXXXXXXXXXX"
    },
    {
      "name": "app_id",
      "type": "string",
      "description": "The application ID (path parameter).",
      "required": true,
      "example": "123456789"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.plivo.com/v1/Account/{auth_id}/Application/{app_id}/",
    "headers": {
      "Authorization": "Basic {base64(auth_id:auth_token)}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "app_id": "123456789",
      "app_name": "My App",
      "answer_url": "https://example.com/answer/",
      "message_url": "https://example.com/message/"
    }
  }
}