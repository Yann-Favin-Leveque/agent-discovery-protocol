{
  "name": "call_speak",
  "description": "Play text-to-speech on a live call.",
  "resource_group": "call",
  "endpoint": "/v1/Account/{auth_id}/Call/{call_uuid}/Speak/",
  "method": "POST",
  "parameters": [
    {
      "name": "auth_id",
      "type": "string",
      "description": "Plivo Auth ID (path parameter).",
      "required": true,
      "example": "MAXXXXXXXXXXXXXXX"
    },
    {
      "name": "call_uuid",
      "type": "string",
      "description": "The call UUID (path parameter).",
      "required": true,
      "example": "abc-123-def-456"
    },
    {
      "name": "text",
      "type": "string",
      "description": "Text to speak.",
      "required": true,
      "example": "Hello, this is a test call."
    },
    {
      "name": "voice",
      "type": "string",
      "description": "Voice: WOMAN or MAN.",
      "required": false,
      "example": "WOMAN"
    },
    {
      "name": "language",
      "type": "string",
      "description": "Language code.",
      "required": false,
      "example": "en-US"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.plivo.com/v1/Account/{auth_id}/Call/{call_uuid}/Speak/",
    "headers": {
      "Authorization": "Basic {base64(auth_id:auth_token)}",
      "Content-Type": "application/json"
    },
    "body": {
      "text": "Hello, this is a test call.",
      "voice": "WOMAN"
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "message": "speak started",
      "api_id": "xxx"
    }
  }
}