{
  "name": "call_hangup",
  "description": "Hang up a specific live call by its UUID.",
  "resource_group": "call",
  "endpoint": "/v1/Account/{auth_id}/Call/{call_uuid}/",
  "method": "DELETE",
  "parameters": [
    {
      "name": "auth_id",
      "type": "string",
      "description": "Plivo Auth ID (path parameter).",
      "required": true,
      "example": "MAXXXXXXXXXXXXXXX"
    },
    {
      "name": "call_uuid",
      "type": "string",
      "description": "The call UUID (path parameter).",
      "required": true,
      "example": "abc-123-def-456"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.plivo.com/v1/Account/{auth_id}/Call/{call_uuid}/",
    "headers": {
      "Authorization": "Basic {base64(auth_id:auth_token)}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}