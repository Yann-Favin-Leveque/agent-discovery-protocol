{
  "name": "daily_resilience_list",
  "description": "Retrieve daily resilience data tracking recovery capacity for a date range. Supports pagination with next_token.",
  "resource_group": "daily",
  "endpoint": "/v2/usercollection/daily_resilience",
  "method": "GET",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "required": false,
      "description": "Start date YYYY-MM-DD.",
      "in": "query"
    },
    {
      "name": "end_date",
      "type": "string",
      "required": false,
      "description": "End date YYYY-MM-DD.",
      "in": "query"
    },
    {
      "name": "next_token",
      "type": "string",
      "required": false,
      "description": "Pagination token from previous response.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "resilience"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ouraring.com/v2/usercollection/daily_resilience?start_date=2025-01-10&end_date=2025-01-15",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "abc-678",
          "day": "2025-01-15",
          "level": "solid",
          "contributors": {
            "sleep_recovery": 85,
            "daytime_recovery": 78,
            "stress": 72
          }
        }
      ],
      "next_token": null
    }
  }
}