{
  "name": "get_workouts",
  "description": "Retrieve workout sessions detected automatically or logged manually by the user. Each workout includes activity type, start and end times, duration, calories burned, average and max heart rate, and intensity classification.",
  "endpoint": "/v2/usercollection/workout",
  "method": "GET",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "description": "Start date in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-01-01"
    },
    {
      "name": "end_date",
      "type": "string",
      "description": "End date in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-01-07"
    },
    {
      "name": "next_token",
      "type": "string",
      "description": "Pagination token for retrieving the next page of results.",
      "required": false,
      "example": null
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ouraring.com/v2/usercollection/workout?start_date=2024-01-01&end_date=2024-01-07",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "abc123",
          "day": "2024-01-03",
          "activity": "running",
          "start_datetime": "2024-01-03T08:00:00+00:00",
          "end_datetime": "2024-01-03T08:45:00+00:00",
          "duration": 2700,
          "calories": 380,
          "distance": 5200,
          "average_heart_rate": 145,
          "max_heart_rate": 172,
          "intensity": "moderate",
          "source": "manual"
        }
      ],
      "next_token": null
    }
  }
}
