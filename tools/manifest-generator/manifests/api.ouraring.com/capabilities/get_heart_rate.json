{
  "name": "get_heart_rate",
  "description": "Retrieve continuous heart rate measurements recorded by the Oura Ring throughout the day and night. Data is returned as timestamped BPM readings at approximately 5-minute intervals, along with the source context (rest, sleep, workout, etc.).",
  "endpoint": "/v2/usercollection/heartrate",
  "method": "GET",
  "parameters": [
    {
      "name": "start_datetime",
      "type": "string",
      "description": "Start datetime in ISO 8601 format (e.g. 2024-01-01T00:00:00Z).",
      "required": false,
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "end_datetime",
      "type": "string",
      "description": "End datetime in ISO 8601 format.",
      "required": false,
      "example": "2024-01-01T23:59:59Z"
    },
    {
      "name": "next_token",
      "type": "string",
      "description": "Pagination token for retrieving the next page of results.",
      "required": false,
      "example": null
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ouraring.com/v2/usercollection/heartrate?start_datetime=2024-01-01T00:00:00Z&end_datetime=2024-01-01T23:59:59Z",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "bpm": 62,
          "source": "rest",
          "timestamp": "2024-01-01T03:15:00+00:00"
        },
        {
          "bpm": 58,
          "source": "sleep",
          "timestamp": "2024-01-01T03:20:00+00:00"
        }
      ],
      "next_token": null
    }
  }
}
