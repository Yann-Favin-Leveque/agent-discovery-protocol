{
  "name": "get_daily_readiness",
  "description": "Retrieve daily readiness scores for a date range. The readiness score reflects how recovered and prepared the user's body is for the day, based on contributors like previous night's sleep, HRV balance, body temperature, and recovery index.",
  "endpoint": "/v2/usercollection/daily_readiness",
  "method": "GET",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "description": "Start date in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-01-01"
    },
    {
      "name": "end_date",
      "type": "string",
      "description": "End date in YYYY-MM-DD format.",
      "required": false,
      "example": "2024-01-07"
    },
    {
      "name": "next_token",
      "type": "string",
      "description": "Pagination token for retrieving the next page of results.",
      "required": false,
      "example": null
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ouraring.com/v2/usercollection/daily_readiness?start_date=2024-01-01&end_date=2024-01-07",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "abc123",
          "day": "2024-01-01",
          "score": 78,
          "temperature_deviation": -0.2,
          "temperature_trend_deviation": 0.1,
          "contributors": {
            "activity_balance": 80,
            "body_temperature": 85,
            "hrv_balance": 72,
            "previous_day_activity": 75,
            "previous_night": 82,
            "recovery_index": 90,
            "resting_heart_rate": 78,
            "sleep_balance": 76
          },
          "timestamp": "2024-01-01T00:00:00+00:00"
        }
      ],
      "next_token": null
    }
  }
}
