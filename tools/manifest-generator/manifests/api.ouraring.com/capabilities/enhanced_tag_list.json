{
  "name": "enhanced_tag_list",
  "description": "Retrieve enhanced tags with additional metadata and custom fields.",
  "resource_group": "tag",
  "endpoint": "/v2/usercollection/enhanced_tag",
  "method": "GET",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "required": false,
      "description": "Start date YYYY-MM-DD.",
      "in": "query"
    },
    {
      "name": "end_date",
      "type": "string",
      "required": false,
      "description": "End date YYYY-MM-DD.",
      "in": "query"
    },
    {
      "name": "next_token",
      "type": "string",
      "required": false,
      "description": "Pagination token.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "tag"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ouraring.com/v2/usercollection/enhanced_tag?start_date=2025-01-10&end_date=2025-01-15",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "etag-123",
          "day": "2025-01-15",
          "tag_type_code": "alcohol",
          "comment": "2 glasses of wine"
        }
      ]
    }
  }
}