{
  "name": "daily_spo2_list",
  "description": "Retrieve daily SpO2 blood oxygen averages for a date range. Supports pagination with next_token.",
  "resource_group": "daily",
  "endpoint": "/v2/usercollection/daily_spo2",
  "method": "GET",
  "parameters": [
    {
      "name": "start_date",
      "type": "string",
      "required": false,
      "description": "Start date YYYY-MM-DD.",
      "in": "query"
    },
    {
      "name": "end_date",
      "type": "string",
      "required": false,
      "description": "End date YYYY-MM-DD.",
      "in": "query"
    },
    {
      "name": "next_token",
      "type": "string",
      "required": false,
      "description": "Pagination token from previous response.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "spo2"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.ouraring.com/v2/usercollection/daily_spo2?start_date=2025-01-10&end_date=2025-01-15",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "abc-345",
          "day": "2025-01-15",
          "spo2_percentage": {
            "average": 96.5
          }
        }
      ],
      "next_token": null
    }
  }
}