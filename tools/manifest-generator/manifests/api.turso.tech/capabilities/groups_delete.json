{
  "name": "groups_delete",
  "resource_group": "groups",
  "description": "Delete a group.",
  "endpoint": "/v1/organizations/{organizationSlug}/groups/{groupName}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "groupName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Group name."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.turso.tech/v1/organizations/my-org/groups/my-group",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "group": {
        "name": "my-group"
      }
    }
  }
}