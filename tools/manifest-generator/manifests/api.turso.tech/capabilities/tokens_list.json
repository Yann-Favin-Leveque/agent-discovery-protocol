{
  "name": "tokens_list",
  "resource_group": "tokens",
  "description": "List API tokens.",
  "endpoint": "/v1/auth/api-tokens",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/auth/api-tokens",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tokens": [
        {
          "name": "my-token",
          "id": "tok-abc123"
        }
      ]
    }
  }
}