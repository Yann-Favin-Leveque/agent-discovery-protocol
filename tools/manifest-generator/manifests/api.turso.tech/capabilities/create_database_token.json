{
  "name": "create_database_token",
  "description": "Generate authentication tokens for connecting to a specific database. These tokens are used by libSQL clients to authenticate with your Turso database.",
  "endpoint": "/v1/organizations/{organization}/databases/{database}/auth/tokens",
  "method": "POST",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name.", "required": true, "example": "my-org" },
    { "name": "database", "type": "string", "description": "The database name.", "required": true, "example": "my-db" },
    { "name": "expiration", "type": "string", "description": "Token expiration (e.g., '2w' for 2 weeks, 'never').", "required": false, "example": "2w" },
    { "name": "authorization", "type": "string", "description": "Token permission level: 'full-access' or 'read-only'.", "required": false, "example": "full-access" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.turso.tech/v1/organizations/my-org/databases/my-db/auth/tokens",
    "headers": { "Authorization": "Bearer {api_token}", "Content-Type": "application/json" },
    "body": { "expiration": "2w", "authorization": "full-access" }
  },
  "response_example": {
    "status": 200,
    "body": { "jwt": "eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9..." }
  }
}
