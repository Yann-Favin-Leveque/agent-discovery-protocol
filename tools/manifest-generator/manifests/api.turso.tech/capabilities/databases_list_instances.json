{
  "name": "databases_list_instances",
  "resource_group": "databases",
  "description": "List database instances (primary and replicas).",
  "endpoint": "/v1/organizations/{organizationSlug}/databases/{databaseName}/instances",
  "method": "GET",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "databaseName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/databases/my-db/instances",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "instances": [
        {
          "name": "us-east-1",
          "type": "primary",
          "region": "us-east-1"
        }
      ]
    }
  }
}