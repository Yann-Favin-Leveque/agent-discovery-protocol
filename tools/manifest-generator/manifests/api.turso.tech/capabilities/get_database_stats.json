{
  "name": "get_database_stats",
  "description": "Retrieve usage statistics and metrics for your databases including storage, rows read/written, and query counts.",
  "endpoint": "/v1/organizations/{organization}/databases/{database}/stats",
  "method": "GET",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name.", "required": true, "example": "my-org" },
    { "name": "database", "type": "string", "description": "The database name.", "required": true, "example": "my-db" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/databases/my-db/stats",
    "headers": { "Authorization": "Bearer {api_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "top_queries": [
        { "query": "SELECT * FROM users WHERE id = ?", "rows_read": 1500, "rows_written": 0 }
      ]
    }
  }
}
