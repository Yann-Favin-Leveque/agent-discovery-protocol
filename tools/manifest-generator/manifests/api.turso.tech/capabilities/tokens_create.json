{
  "name": "tokens_create",
  "resource_group": "tokens",
  "description": "Create a new API token. The token is only returned once.",
  "endpoint": "/v1/auth/api-tokens/{tokenName}",
  "method": "POST",
  "parameters": [
    {
      "name": "tokenName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Token name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.turso.tech/v1/auth/api-tokens/my-token",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "my-token",
      "id": "tok-abc123",
      "token": "eyJ..."
    }
  }
}