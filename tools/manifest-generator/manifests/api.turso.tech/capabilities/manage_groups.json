{
  "name": "manage_groups",
  "description": "Create and manage database groups that control replication regions. Groups define where your databases are replicated across Turso's edge network.",
  "endpoint": "/v1/organizations/{organization}/groups",
  "method": "POST",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name.", "required": true, "example": "my-org" },
    { "name": "name", "type": "string", "description": "Group name.", "required": true, "example": "production" },
    { "name": "location", "type": "string", "description": "Primary location for the group.", "required": true, "example": "iad" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.turso.tech/v1/organizations/my-org/groups",
    "headers": { "Authorization": "Bearer {api_token}", "Content-Type": "application/json" },
    "body": { "name": "production", "location": "iad" }
  },
  "response_example": {
    "status": 200,
    "body": { "group": { "name": "production", "locations": ["iad"], "primary": "iad" } }
  }
}
