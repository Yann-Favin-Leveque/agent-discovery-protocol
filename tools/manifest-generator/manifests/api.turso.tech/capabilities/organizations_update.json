{
  "name": "organizations_update",
  "resource_group": "organizations",
  "description": "Update organization settings.",
  "endpoint": "/v1/organizations/{organizationSlug}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "overages",
      "type": "boolean",
      "required": false,
      "in": "body",
      "description": "Enable/disable overages."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.turso.tech/v1/organizations/my-org",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "overages": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "my-org",
      "overages": true
    }
  }
}