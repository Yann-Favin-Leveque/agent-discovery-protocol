{
  "name": "organizations_get_usage",
  "resource_group": "organizations",
  "description": "Retrieve organization usage metrics.",
  "endpoint": "/v1/organizations/{organizationSlug}/usage",
  "method": "GET",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/usage",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "organization": {
        "rows_read": 100000,
        "rows_written": 5000,
        "databases": 3
      }
    }
  }
}