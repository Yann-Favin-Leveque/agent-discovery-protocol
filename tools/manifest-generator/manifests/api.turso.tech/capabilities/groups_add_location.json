{
  "name": "groups_add_location",
  "resource_group": "groups",
  "description": "Add a location to a group.",
  "endpoint": "/v1/organizations/{organizationSlug}/groups/{groupName}/locations/{location}",
  "method": "POST",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "groupName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Group name."
    },
    {
      "name": "location",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Location code."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.turso.tech/v1/organizations/my-org/groups/default/locations/eu-west-1",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "group": {
        "name": "default",
        "locations": [
          "us-east-1",
          "eu-west-1"
        ]
      }
    }
  }
}