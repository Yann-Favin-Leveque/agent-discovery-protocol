{
  "name": "groups_list",
  "resource_group": "groups",
  "description": "List groups in an organization.",
  "endpoint": "/v1/organizations/{organizationSlug}/groups",
  "method": "GET",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/groups",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "groups": [
        {
          "name": "default",
          "uuid": "abc123",
          "primary": "us-east-1"
        }
      ]
    }
  }
}