{
  "name": "databases_invalidate_tokens",
  "resource_group": "databases",
  "description": "Invalidate all auth tokens for a database.",
  "endpoint": "/v1/organizations/{organizationSlug}/databases/{databaseName}/auth/rotate",
  "method": "POST",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "databaseName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.turso.tech/v1/organizations/my-org/databases/my-db/auth/rotate",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": null
  }
}