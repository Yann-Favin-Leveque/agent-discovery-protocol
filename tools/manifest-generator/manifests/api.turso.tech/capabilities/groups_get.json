{
  "name": "groups_get",
  "resource_group": "groups",
  "description": "Retrieve group details.",
  "endpoint": "/v1/organizations/{organizationSlug}/groups/{groupName}",
  "method": "GET",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "groupName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Group name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/groups/default",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "group": {
        "name": "default",
        "primary": "us-east-1",
        "locations": [
          "us-east-1"
        ]
      }
    }
  }
}