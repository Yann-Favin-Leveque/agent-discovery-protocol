{
  "name": "manage_databases",
  "description": "Create, list, get details, and delete databases in your Turso organization. Databases are distributed SQLite instances that can be replicated to multiple edge locations.",
  "endpoint": "/v1/organizations/{organization}/databases",
  "method": "GET",
  "parameters": [
    { "name": "organization", "type": "string", "description": "The organization name or slug.", "required": true, "example": "my-org" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/databases",
    "headers": { "Authorization": "Bearer {api_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "databases": [
        { "Name": "my-db", "DbId": "abc123", "Hostname": "my-db-my-org.turso.io", "regions": ["iad"], "primaryRegion": "iad", "group": "default" }
      ]
    }
  }
}
