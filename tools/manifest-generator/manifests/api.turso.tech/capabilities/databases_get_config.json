{
  "name": "databases_get_config",
  "resource_group": "databases",
  "description": "Retrieve database configuration.",
  "endpoint": "/v1/organizations/{organizationSlug}/databases/{databaseName}/configuration",
  "method": "GET",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "databaseName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/databases/my-db/configuration",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "size_limit": "500mb",
      "allow_attach": false
    }
  }
}