{
  "name": "tokens_revoke",
  "resource_group": "tokens",
  "description": "Revoke an API token.",
  "endpoint": "/v1/auth/api-tokens/{tokenName}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "tokenName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Token name."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.turso.tech/v1/auth/api-tokens/my-token",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "token": "my-token"
    }
  }
}