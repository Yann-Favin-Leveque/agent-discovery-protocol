{
  "name": "organizations_remove_member",
  "resource_group": "organizations",
  "description": "Remove a member from an organization.",
  "endpoint": "/v1/organizations/{organizationSlug}/members/{username}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "username",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Username to remove."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.turso.tech/v1/organizations/my-org/members/jane",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "member": "jane"
    }
  }
}