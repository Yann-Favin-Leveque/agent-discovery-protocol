{
  "name": "organizations_get",
  "resource_group": "organizations",
  "description": "Retrieve organization details.",
  "endpoint": "/v1/organizations/{organizationSlug}",
  "method": "GET",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "my-org",
      "slug": "my-org",
      "type": "team"
    }
  }
}