{
  "name": "databases_get",
  "resource_group": "databases",
  "description": "Retrieve details of a database.",
  "endpoint": "/v1/organizations/{organizationSlug}/databases/{databaseName}",
  "method": "GET",
  "parameters": [
    {
      "name": "organizationSlug",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Organization slug."
    },
    {
      "name": "databaseName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Database name."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.turso.tech/v1/organizations/my-org/databases/my-db",
    "headers": {
      "Authorization": "Bearer {api_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "database": {
        "Name": "my-db",
        "DbId": "abc123",
        "Hostname": "my-db-my-org.turso.io"
      }
    }
  }
}