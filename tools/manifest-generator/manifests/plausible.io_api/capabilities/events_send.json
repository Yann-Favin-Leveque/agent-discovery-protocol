{
  "name": "events_send",
  "description": "Send a pageview or custom event to Plausible for tracking.",
  "resource_group": "events",
  "endpoint": "/event",
  "method": "POST",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Site domain"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Event name (pageview for page tracking)"
    },
    {
      "name": "url",
      "type": "string",
      "required": true,
      "description": "Full page URL"
    },
    {
      "name": "referrer",
      "type": "string",
      "required": false,
      "description": "Referrer URL"
    },
    {
      "name": "props",
      "type": "object",
      "required": false,
      "description": "Custom properties (max 30)"
    },
    {
      "name": "revenue",
      "type": "object",
      "required": false,
      "description": "Revenue data with currency and amount"
    }
  ],
  "request_example": {
    "domain": "example.com",
    "name": "pageview",
    "url": "https://example.com/pricing"
  },
  "response_example": {},
  "auth_scopes": []
}
