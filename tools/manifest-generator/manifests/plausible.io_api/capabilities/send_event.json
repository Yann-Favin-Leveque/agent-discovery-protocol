{
  "name": "send_event",
  "description": "Send a custom pageview or event to Plausible for tracking.",
  "endpoint": "/event",
  "method": "POST",
  "parameters": [
    {"name": "domain", "type": "string", "description": "Domain of the site.", "required": true, "example": "example.com"},
    {"name": "name", "type": "string", "description": "Event name ('pageview' or custom name).", "required": true, "example": "Signup"},
    {"name": "url", "type": "string", "description": "URL of the page.", "required": true, "example": "https://example.com/signup"},
    {"name": "props", "type": "object", "description": "Custom properties for the event.", "required": false, "example": {"plan": "enterprise", "source": "homepage"}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://plausible.io/api/event",
    "headers": {"Content-Type": "application/json", "User-Agent": "Mozilla/5.0"},
    "body": {"domain": "example.com", "name": "Signup", "url": "https://example.com/signup", "props": {"plan": "enterprise"}}
  },
  "response_example": {
    "status": 202,
    "body": {}
  }
}
