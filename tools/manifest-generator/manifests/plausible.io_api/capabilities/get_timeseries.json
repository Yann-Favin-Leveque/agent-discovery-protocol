{
  "name": "get_timeseries",
  "description": "Get time-series data for one or more metrics over a date range, broken down by day or month.",
  "endpoint": "/stats/timeseries",
  "method": "GET",
  "parameters": [
    {"name": "site_id", "type": "string", "description": "Domain of the site.", "required": true, "example": "example.com"},
    {"name": "period", "type": "string", "description": "Time period: day, 7d, 30d, month, 6mo, 12mo, custom.", "required": false, "example": "30d"},
    {"name": "metrics", "type": "string", "description": "Comma-separated metrics.", "required": false, "example": "visitors,pageviews"},
    {"name": "interval", "type": "string", "description": "Interval: date or month.", "required": false, "example": "date"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://plausible.io/api/v1/stats/timeseries?site_id=example.com&period=30d&metrics=visitors,pageviews&interval=date",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"results": [{"date": "2024-01-01", "visitors": 500, "pageviews": 1500}, {"date": "2024-01-02", "visitors": 520, "pageviews": 1560}]}
  }
}
