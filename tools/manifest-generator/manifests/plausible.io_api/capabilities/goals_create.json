{
  "name": "goals_create",
  "description": "Find or create a goal for a site.",
  "resource_group": "goals",
  "endpoint": "/v1/sites/goals",
  "method": "PUT",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "required": true,
      "description": "Site domain"
    },
    {
      "name": "goal_type",
      "type": "string",
      "required": true,
      "description": "Goal type (event or page)"
    },
    {
      "name": "event_name",
      "type": "string",
      "required": false,
      "description": "Event name for event goals"
    },
    {
      "name": "page_path",
      "type": "string",
      "required": false,
      "description": "Page path for page goals"
    }
  ],
  "request_example": {
    "site_id": "example.com",
    "goal_type": "event",
    "event_name": "Signup"
  },
  "response_example": {
    "id": 1,
    "event_name": "Signup"
  },
  "auth_scopes": []
}
