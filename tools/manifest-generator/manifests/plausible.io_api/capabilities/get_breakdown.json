{
  "name": "get_breakdown",
  "description": "Break down analytics metrics by a property such as page, source, country, browser, or OS.",
  "endpoint": "/stats/breakdown",
  "method": "GET",
  "parameters": [
    {"name": "site_id", "type": "string", "description": "Domain of the site.", "required": true, "example": "example.com"},
    {"name": "property", "type": "string", "description": "Property to break down by: event:page, visit:source, visit:country, visit:browser, visit:os.", "required": true, "example": "visit:source"},
    {"name": "period", "type": "string", "description": "Time period.", "required": false, "example": "30d"},
    {"name": "metrics", "type": "string", "description": "Comma-separated metrics.", "required": false, "example": "visitors,pageviews"},
    {"name": "limit", "type": "number", "description": "Number of results to return.", "required": false, "example": 10}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://plausible.io/api/v1/stats/breakdown?site_id=example.com&property=visit:source&period=30d&metrics=visitors&limit=10",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"results": [{"source": "Google", "visitors": 5000}, {"source": "Direct / None", "visitors": 3000}, {"source": "Twitter", "visitors": 1500}]}
  }
}
