{
  "name": "sites_update",
  "description": "Update a site domain name and tracker configuration.",
  "resource_group": "sites",
  "endpoint": "/v1/sites/{site_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "required": true,
      "description": "Site domain",
      "location": "path",
      "in": "path"
    },
    {
      "name": "domain",
      "type": "string",
      "required": false,
      "description": "Updated domain",
      "in": "body"
    }
  ],
  "request_example": {
    "domain": "updated-site.com"
  },
  "response_example": {
    "domain": "updated-site.com"
  },
  "auth_scopes": []
}
