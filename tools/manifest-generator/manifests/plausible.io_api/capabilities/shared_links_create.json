{
  "name": "shared_links_create",
  "description": "Find or create a shared dashboard link.",
  "resource_group": "sites",
  "endpoint": "/v1/sites/shared-links",
  "method": "PUT",
  "parameters": [
    {
      "name": "site_id",
      "type": "string",
      "required": true,
      "description": "Site domain"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Name for the shared link"
    }
  ],
  "request_example": {
    "site_id": "example.com",
    "name": "Public Dashboard"
  },
  "response_example": {
    "url": "https://plausible.io/share/example.com?auth=abc123",
    "name": "Public Dashboard"
  },
  "auth_scopes": []
}
