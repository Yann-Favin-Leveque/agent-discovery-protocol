{
  "name": "manage_sites",
  "description": "Create, update, or delete sites from your Plausible Analytics account.",
  "endpoint": "/sites",
  "method": "POST",
  "parameters": [
    {"name": "domain", "type": "string", "description": "Domain of the site to create.", "required": true, "example": "newsite.com"},
    {"name": "timezone", "type": "string", "description": "Timezone for the site.", "required": false, "example": "America/New_York"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://plausible.io/api/v1/sites",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"domain": "newsite.com", "timezone": "America/New_York"}
  },
  "response_example": {
    "status": 200,
    "body": {"domain": "newsite.com", "timezone": "America/New_York"}
  }
}
