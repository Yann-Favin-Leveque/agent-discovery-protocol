{
  "name": "sites_create",
  "description": "Create a new site in the Plausible account.",
  "resource_group": "sites",
  "endpoint": "/v1/sites",
  "method": "POST",
  "parameters": [
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "description": "Site domain",
      "in": "body"
    },
    {
      "name": "timezone",
      "type": "string",
      "required": false,
      "description": "Timezone for the site",
      "in": "body"
    }
  ],
  "request_example": {
    "domain": "newsite.com",
    "timezone": "America/New_York"
  },
  "response_example": {
    "domain": "newsite.com",
    "timezone": "America/New_York"
  },
  "auth_scopes": []
}
