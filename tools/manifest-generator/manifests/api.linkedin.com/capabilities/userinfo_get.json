{
  "name": "userinfo_get",
  "description": "Retrieve user info via OpenID Connect.",
  "resource_group": "profile",
  "endpoint": "/v2/userinfo",
  "method": "GET",
  "auth_scopes": [
    "openid",
    "profile",
    "email"
  ],
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.linkedin.com/v2/userinfo",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sub": "abc123",
      "name": "John Doe",
      "given_name": "John",
      "family_name": "Doe",
      "picture": "https://media.licdn.com/...",
      "email": "john@example.com",
      "email_verified": true
    }
  }
}