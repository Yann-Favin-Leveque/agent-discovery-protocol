{
  "name": "posts_get",
  "description": "Retrieve a specific post by URN.",
  "resource_group": "posts",
  "endpoint": "/v2/posts/{post_urn}",
  "method": "GET",
  "parameters": [
    {
      "name": "post_urn",
      "type": "string",
      "required": true,
      "description": "Post URN.",
      "example": "urn:li:share:123456789",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.linkedin.com/v2/posts/urn:li:share:123456789",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "urn:li:share:123456789",
      "author": "urn:li:person:abc123",
      "commentary": "My post content",
      "lifecycleState": "PUBLISHED"
    }
  }
}
