{
  "name": "organizations_get",
  "description": "Retrieve organization page information.",
  "resource_group": "organizations",
  "endpoint": "/v2/organizations/{organization_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.linkedin.com/v2/organizations/12345678",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345678,
      "localizedName": "Acme Corp",
      "vanityName": "acme-corp",
      "localizedDescription": "Leading technology company"
    }
  }
}
