{
  "name": "posts_delete",
  "description": "Delete a post by URN.",
  "resource_group": "posts",
  "endpoint": "/v2/posts/{post_urn}",
  "method": "DELETE",
  "auth_scopes": [
    "w_member_social"
  ],
  "parameters": [
    {
      "name": "post_urn",
      "type": "string",
      "required": true,
      "description": "Post URN to delete."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.linkedin.com/v2/posts/urn:li:share:123456789",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}