{
  "name": "profile_get",
  "description": "Retrieve the authenticated member LinkedIn profile.",
  "resource_group": "profile",
  "endpoint": "/v2/me",
  "method": "GET",
  "auth_scopes": [
    "profile"
  ],
  "parameters": [
    {
      "name": "projection",
      "type": "string",
      "required": false,
      "description": "Fields projection.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.linkedin.com/v2/me",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "urn:li:person:abc123",
      "localizedFirstName": "John",
      "localizedLastName": "Doe",
      "localizedHeadline": "Software Engineer at Acme",
      "vanityName": "johndoe"
    }
  }
}
