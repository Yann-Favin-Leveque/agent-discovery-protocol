{
  "name": "files_delete",
  "description": "Delete a file or folder at the specified path.",
  "resource_group": "files",
  "endpoint": "/2/files/delete_v2",
  "method": "POST",
  "parameters": [
    {
      "name": "path",
      "type": "string",
      "description": "Path to delete.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/files/delete_v2",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "path": "/test/file.txt"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "metadata": {
        "name": "file.txt",
        "path_display": "/test/file.txt"
      }
    }
  }
}