{
  "name": "files_get_temporary_link",
  "description": "Get a temporary link to stream content of a file.",
  "resource_group": "files",
  "endpoint": "/2/files/get_temporary_link",
  "method": "POST",
  "parameters": [
    {
      "name": "path",
      "type": "string",
      "description": "File path.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/files/get_temporary_link",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "path": "/test/file.txt"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "metadata": {
        "name": "file.txt"
      },
      "link": "https://dl.dropboxusercontent.com/..."
    }
  }
}