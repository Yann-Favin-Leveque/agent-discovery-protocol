{
  "name": "sharing_revoke_shared_link",
  "description": "Revoke a shared link.",
  "resource_group": "sharing",
  "endpoint": "/2/sharing/revoke_shared_link",
  "method": "POST",
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "description": "URL of the shared link to revoke.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/sharing/revoke_shared_link",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://www.dropbox.com/s/abc123/file.txt?dl=0"
    }
  },
  "response_example": {
    "status": 200
  }
}
