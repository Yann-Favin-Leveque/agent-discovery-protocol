{
  "name": "files_upload_session_start",
  "description": "Start an upload session for files larger than 150 MB.",
  "resource_group": "files",
  "endpoint": "/2/files/upload_session/start",
  "method": "POST",
  "parameters": [
    {
      "name": "close",
      "type": "boolean",
      "description": "Close session after upload.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://content.dropboxapi.com/2/files/upload_session/start",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Dropbox-API-Arg": "{\"close\":false}",
      "Content-Type": "application/octet-stream"
    },
    "body": "<chunk data>"
  },
  "response_example": {
    "status": 200,
    "body": {
      "session_id": "session123"
    }
  }
}
