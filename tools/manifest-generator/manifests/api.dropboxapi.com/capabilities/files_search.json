{
  "name": "files_search",
  "description": "Search for files and folders by name or content.",
  "resource_group": "files",
  "endpoint": "/2/files/search_v2",
  "method": "POST",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "Search query string.",
      "required": true,
      "example": "report",
      "in": "body"
    },
    {
      "name": "options",
      "type": "object",
      "description": "Search options (path, max_results, file_categories, etc.).",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/files/search_v2",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "report"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "matches": [
        {
          "metadata": {
            ".tag": "metadata",
            "metadata": {
              "name": "report.pdf",
              "path_display": "/report.pdf"
            }
          }
        }
      ],
      "has_more": false
    }
  }
}
