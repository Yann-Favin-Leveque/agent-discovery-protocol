{
  "name": "files_download",
  "description": "Download a file from Dropbox by its path or ID.",
  "resource_group": "files",
  "endpoint": "/2/files/download",
  "method": "POST",
  "parameters": [
    {
      "name": "Dropbox-API-Arg",
      "type": "object",
      "description": "JSON header with path.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://content.dropboxapi.com/2/files/download",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Dropbox-API-Arg": "{\"path\":\"/test/file.txt\"}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "<binary file content>"
  }
}