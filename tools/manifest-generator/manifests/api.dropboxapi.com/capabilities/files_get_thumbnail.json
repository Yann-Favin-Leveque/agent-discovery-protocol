{
  "name": "files_get_thumbnail",
  "description": "Get a thumbnail for an image file.",
  "resource_group": "files",
  "endpoint": "/2/files/get_thumbnail_v2",
  "method": "POST",
  "parameters": [
    {
      "name": "resource",
      "type": "object",
      "description": "Resource with .tag (path) and path.",
      "required": true,
      "in": "body"
    },
    {
      "name": "format",
      "type": "string",
      "description": "Thumbnail format: jpeg or png.",
      "required": false,
      "in": "body"
    },
    {
      "name": "size",
      "type": "string",
      "description": "Size: w32h32 to w2048h1536.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://content.dropboxapi.com/2/files/get_thumbnail_v2",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Dropbox-API-Arg": "{\"resource\":{\".tag\":\"path\",\"path\":\"/photo.jpg\"},\"format\":\"jpeg\",\"size\":\"w256h256\"}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "<thumbnail binary>"
  }
}
