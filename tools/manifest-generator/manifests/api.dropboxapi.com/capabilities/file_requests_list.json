{
  "name": "file_requests_list",
  "description": "List all file requests.",
  "resource_group": "file_requests",
  "endpoint": "/2/file_requests/list_v2",
  "method": "POST",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/file_requests/list_v2",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "limit": 100
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "file_requests": [
        {
          "id": "abc123",
          "title": "Submit homework"
        }
      ]
    }
  }
}