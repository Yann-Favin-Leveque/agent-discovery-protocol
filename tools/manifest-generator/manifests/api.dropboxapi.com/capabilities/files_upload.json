{
  "name": "files_upload",
  "description": "Upload a file to Dropbox at a specified path (up to 150 MB).",
  "resource_group": "files",
  "endpoint": "/2/files/upload",
  "method": "POST",
  "parameters": [
    {
      "name": "Dropbox-API-Arg",
      "type": "object",
      "description": "JSON header with path, mode, autorename, mute, strict_conflict.",
      "required": true,
      "in": "body"
    },
    {
      "name": "Content-Type",
      "type": "string",
      "description": "Must be application/octet-stream.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://content.dropboxapi.com/2/files/upload",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Dropbox-API-Arg": "{\"path\":\"/test/file.txt\",\"mode\":\"add\",\"autorename\":true}",
      "Content-Type": "application/octet-stream"
    },
    "body": "<file content>"
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "file.txt",
      "path_display": "/test/file.txt",
      "id": "id:abc123",
      "size": 1234
    }
  }
}
