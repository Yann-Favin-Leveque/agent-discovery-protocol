{
  "name": "files_create_folder",
  "description": "Create a new folder at the specified path.",
  "resource_group": "files",
  "endpoint": "/2/files/create_folder_v2",
  "method": "POST",
  "parameters": [
    {
      "name": "path",
      "type": "string",
      "description": "Folder path to create.",
      "required": true,
      "example": "/new_folder",
      "in": "body"
    },
    {
      "name": "autorename",
      "type": "boolean",
      "description": "Auto-rename if conflict.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/files/create_folder_v2",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "path": "/new_folder"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "metadata": {
        "name": "new_folder",
        "path_display": "/new_folder",
        "id": "id:def456"
      }
    }
  }
}
