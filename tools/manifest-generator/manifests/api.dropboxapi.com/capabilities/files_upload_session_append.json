{
  "name": "files_upload_session_append",
  "description": "Append more data to an upload session.",
  "resource_group": "files",
  "endpoint": "/2/files/upload_session/append_v2",
  "method": "POST",
  "parameters": [
    {
      "name": "cursor",
      "type": "object",
      "description": "Object with session_id and offset.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://content.dropboxapi.com/2/files/upload_session/append_v2",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Dropbox-API-Arg": "{\"cursor\":{\"session_id\":\"session123\",\"offset\":1048576}}",
      "Content-Type": "application/octet-stream"
    },
    "body": "<chunk data>"
  },
  "response_example": {
    "status": 200
  }
}