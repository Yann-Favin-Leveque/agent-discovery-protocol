{
  "name": "files_list_folder_continue",
  "description": "Continue listing folder contents from a cursor.",
  "resource_group": "files",
  "endpoint": "/2/files/list_folder/continue",
  "method": "POST",
  "parameters": [
    {
      "name": "cursor",
      "type": "string",
      "description": "Cursor from previous list_folder call.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/files/list_folder/continue",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "cursor": "cursor123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "entries": [],
      "has_more": false
    }
  }
}