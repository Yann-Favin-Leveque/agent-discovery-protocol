{
  "name": "file_requests_update",
  "description": "Update a file request.",
  "resource_group": "file_requests",
  "endpoint": "/2/file_requests/update",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "File request ID.",
      "required": true
    },
    {
      "name": "title",
      "type": "string",
      "description": "Updated title.",
      "required": false
    },
    {
      "name": "destination",
      "type": "string",
      "description": "Updated destination.",
      "required": false
    },
    {
      "name": "open",
      "type": "boolean",
      "description": "Open/close the request.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/file_requests/update",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "abc123",
      "open": false
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "open": false
    }
  }
}