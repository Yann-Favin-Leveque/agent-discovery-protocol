{
  "name": "file_requests_get",
  "description": "Get a specific file request.",
  "resource_group": "file_requests",
  "endpoint": "/2/file_requests/get",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "File request ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/file_requests/get",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "abc123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123",
      "title": "Submit homework"
    }
  }
}