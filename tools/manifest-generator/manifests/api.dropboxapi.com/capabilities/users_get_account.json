{
  "name": "users_get_account",
  "description": "Get information about a specific user's account by account ID.",
  "resource_group": "users",
  "endpoint": "/2/users/get_account",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The account ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/users/get_account",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "account_id": "dbid:abc123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "account_id": "dbid:abc123",
      "name": {
        "display_name": "John Doe"
      }
    }
  }
}