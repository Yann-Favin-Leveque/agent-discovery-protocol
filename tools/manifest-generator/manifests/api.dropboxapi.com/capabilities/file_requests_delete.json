{
  "name": "file_requests_delete",
  "description": "Delete file requests.",
  "resource_group": "file_requests",
  "endpoint": "/2/file_requests/delete",
  "method": "POST",
  "parameters": [
    {
      "name": "ids",
      "type": "array",
      "description": "List of file request IDs to delete.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.dropboxapi.com/2/file_requests/delete",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "ids": [
        "abc123"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "file_requests": [
        {
          "id": "abc123"
        }
      ]
    }
  }
}
