{
  "name": "docs_create",
  "resource_group": "docs",
  "description": "Create a new Coda document, optionally from a template.",
  "endpoint": "/docs",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Document title",
      "example": "New Project Plan",
      "in": "body"
    },
    {
      "name": "sourceDoc",
      "type": "string",
      "required": false,
      "description": "Source doc ID to copy from",
      "example": "AbCDeFGH",
      "in": "body"
    },
    {
      "name": "folderId",
      "type": "string",
      "required": false,
      "description": "Folder to create the doc in",
      "example": "fl-5678",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://coda.io/apis/v1/docs",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "New Project Plan"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "IjKLmNOP",
      "type": "doc",
      "name": "New Project Plan",
      "browserLink": "https://coda.io/d/_dIjKLmNOP"
    }
  }
}
