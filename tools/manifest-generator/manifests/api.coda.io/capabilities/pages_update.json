{
  "name": "pages_update",
  "resource_group": "pages",
  "description": "Update a page's name, subtitle, or icon.",
  "endpoint": "/docs/{docId}/pages/{pageIdOrName}",
  "method": "PUT",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "pageIdOrName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Page ID or name",
      "example": "canvas-abc"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "New page name",
      "example": "Updated Overview"
    },
    {
      "name": "subtitle",
      "type": "string",
      "required": false,
      "description": "New subtitle",
      "example": "Updated subtitle"
    },
    {
      "name": "iconName",
      "type": "string",
      "required": false,
      "description": "Icon name",
      "example": "star"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/pages/canvas-abc",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Overview"
    }
  },
  "response_example": {
    "status": 202,
    "body": {
      "id": "canvas-abc",
      "name": "Updated Overview"
    }
  }
}