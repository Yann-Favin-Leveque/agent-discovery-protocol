{
  "name": "formulas_get",
  "resource_group": "formulas",
  "description": "Retrieve a specific formula and its current value.",
  "endpoint": "/docs/{docId}/formulas/{formulaIdOrName}",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "formulaIdOrName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Formula ID or name",
      "example": "f-abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/formulas/f-abc",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "f-abc",
      "type": "formula",
      "name": "TotalTasks",
      "value": 42
    }
  }
}