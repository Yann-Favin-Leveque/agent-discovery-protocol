{
  "name": "list_pages",
  "description": "Retrieve all pages within a Coda document, including their hierarchy, titles, and metadata. Use this to navigate document structure, understand page organization, and reference specific pages for further operations.",
  "endpoint": "/docs/{docId}/pages",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "description": "The unique identifier of the Coda document.",
      "required": true,
      "example": "abcdef123456"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of pages to return per page (1-100). Defaults to 25.",
      "required": false,
      "example": 50
    },
    {
      "name": "pageToken",
      "type": "string",
      "description": "Token for pagination to fetch the next page of results.",
      "required": false,
      "example": "pageToken789"
    },
    {
      "name": "sortBy",
      "type": "string",
      "description": "Field to sort by: 'name', 'createdTime', or 'modifiedTime'. Default is 'name'.",
      "required": false,
      "example": "modifiedTime"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/abcdef123456/pages?limit=25&sortBy=modifiedTime",
    "headers": {
      "Authorization": "Bearer YOUR_API_KEY",
      "Content-Type": "application/json"
    }
  },
