{
  "name": "list_docs",
  "description": "Retrieve a list of all documents accessible to the authenticated user. Returns document metadata including IDs, titles, owners, creation and modification timestamps, and folder information. Supports pagination to handle workspaces with many documents.",
  "endpoint": "/docs",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "The maximum number of documents to return per page (1-100). Defaults to 25.",
      "required": false,
      "example": 25
    },
    {
      "name": "pageToken",
      "type": "string",
      "description": "Token for pagination to fetch the next page of results.",
      "required": false,
      "example": "nextPageToken123"
    },
    {
      "name": "sortBy",
      "type": "string",
      "description": "Field to sort by: 'name', 'createdTime', or 'modifiedTime'. Default is 'name'.",
      "required": false,
      "example": "modifiedTime"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs?limit=25&sortBy=modifiedTime",
    "headers": {
      "Authorization": "Bearer YOUR_API_KEY",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "abcdef123456",
          "type": "doc",
          "name": "Q1 Planning",
          "owner": {
            "id": "user123",
            "name": "Alice Smith",
            "email": "alice@company.com"
          },
          "createdTime": "2024-01-15T10:30:00Z",
          "modifiedTime": "2024-02-28T14:45:00Z",
          "folder": {
            "id": "folder456",
            "name": "Work",
            "type": "folder"
          }
        },
        {
          "id": "ghijkl789012",
          "type": "doc",
          "name": "Team Meeting Notes",
          "owner": {
            "id": "user456",
            "name": "Bob Johnson",
            "email": "bob@company.com"
          },
          "createdTime": "2024-01-20T09:15:00Z",
          "modifiedTime": "2024-02-27T16:20:00Z",
          "folder": null
        }
      ],
      "nextPageToken": "nextPageToken456"
    }
  }
}
