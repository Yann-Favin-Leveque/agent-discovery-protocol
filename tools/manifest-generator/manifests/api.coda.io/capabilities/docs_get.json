{
  "name": "docs_get",
  "resource_group": "docs",
  "description": "Retrieve detailed information about a specific document.",
  "endpoint": "/docs/{docId}",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "AbCDeFGH",
      "type": "doc",
      "name": "Project Plan",
      "owner": "user@example.com",
      "createdAt": "2025-01-15T10:00:00.000Z",
      "updatedAt": "2025-03-10T14:30:00.000Z"
    }
  }
}