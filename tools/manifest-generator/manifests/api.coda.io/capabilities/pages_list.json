{
  "name": "pages_list",
  "resource_group": "pages",
  "description": "List all pages within a document.",
  "endpoint": "/docs/{docId}/pages",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results",
      "example": 25,
      "in": "query"
    },
    {
      "name": "pageToken",
      "type": "string",
      "required": false,
      "description": "Pagination token",
      "example": "eyJsaW1pd",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/pages",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "canvas-abc",
          "type": "page",
          "name": "Overview",
          "browserLink": "https://coda.io/d/_dAbCDeFGH/Overview_suabc",
          "children": []
        }
      ]
    }
  }
}
