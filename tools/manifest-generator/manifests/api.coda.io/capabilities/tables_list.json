{
  "name": "tables_list",
  "resource_group": "tables",
  "description": "List all tables in a document.",
  "endpoint": "/docs/{docId}/tables",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results",
      "example": 25,
      "in": "query"
    },
    {
      "name": "pageToken",
      "type": "string",
      "required": false,
      "description": "Pagination token",
      "example": "eyJsaW1pd",
      "in": "query"
    },
    {
      "name": "sortBy",
      "type": "string",
      "required": false,
      "description": "Sort order",
      "example": "name",
      "in": "query"
    },
    {
      "name": "tableTypes",
      "type": "string",
      "required": false,
      "description": "Comma-separated types (table, view)",
      "example": "table",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/tables",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "grid-abc",
          "type": "table",
          "name": "Tasks",
          "href": "https://coda.io/apis/v1/docs/AbCDeFGH/tables/grid-abc",
          "browserLink": "https://coda.io/d/_dAbCDeFGH/Tasks_tabc",
          "rowCount": 42,
          "createdAt": "2025-01-15T10:00:00.000Z"
        }
      ]
    }
  }
}
