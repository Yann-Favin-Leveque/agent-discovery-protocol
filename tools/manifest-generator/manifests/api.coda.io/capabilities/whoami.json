{
  "name": "whoami",
  "resource_group": "misc",
  "description": "Retrieve information about the authenticated API token owner.",
  "endpoint": "/whoami",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/whoami",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "John Doe",
      "loginId": "john@example.com",
      "type": "user",
      "tokenName": "My API Token",
      "scoped": false,
      "href": "https://coda.io/apis/v1/whoami"
    }
  }
}