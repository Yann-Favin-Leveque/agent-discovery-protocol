{
  "name": "columns_get",
  "resource_group": "columns",
  "description": "Retrieve a specific column by ID.",
  "endpoint": "/docs/{docId}/tables/{tableIdOrName}/columns/{columnIdOrName}",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Table ID or name",
      "example": "grid-abc"
    },
    {
      "name": "columnIdOrName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Column ID or name",
      "example": "c-abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/tables/grid-abc/columns/c-abc",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "c-abc",
      "type": "column",
      "name": "Task Name",
      "format": {
        "type": "text"
      }
    }
  }
}