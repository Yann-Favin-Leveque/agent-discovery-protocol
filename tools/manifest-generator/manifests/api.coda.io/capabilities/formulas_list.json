{
  "name": "formulas_list",
  "resource_group": "formulas",
  "description": "List all named formulas in a document.",
  "endpoint": "/docs/{docId}/formulas",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results",
      "example": 25,
      "in": "query"
    },
    {
      "name": "pageToken",
      "type": "string",
      "required": false,
      "description": "Pagination token",
      "example": "eyJsaW1pd",
      "in": "query"
    },
    {
      "name": "sortBy",
      "type": "string",
      "required": false,
      "description": "Sort order",
      "example": "name",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/formulas",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "f-abc",
          "type": "formula",
          "name": "TotalTasks",
          "value": 42
        }
      ]
    }
  }
}
