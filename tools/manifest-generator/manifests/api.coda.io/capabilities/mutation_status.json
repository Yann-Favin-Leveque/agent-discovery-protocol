{
  "name": "mutation_status",
  "resource_group": "misc",
  "description": "Check the status of an asynchronous mutation (row insert/update/delete).",
  "endpoint": "/mutationStatus/{requestId}",
  "method": "GET",
  "parameters": [
    {
      "name": "requestId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Request ID from the mutation response",
      "example": "req-abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/mutationStatus/req-abc123",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "completed": true,
      "warning": null
    }
  }
}