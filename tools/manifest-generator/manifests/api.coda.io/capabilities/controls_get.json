{
  "name": "controls_get",
  "resource_group": "controls",
  "description": "Retrieve a specific control and its current value.",
  "endpoint": "/docs/{docId}/controls/{controlIdOrName}",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "controlIdOrName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Control ID or name",
      "example": "ctrl-abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/controls/ctrl-abc",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ctrl-abc",
      "type": "control",
      "name": "StatusFilter",
      "controlType": "select",
      "value": "Active"
    }
  }
}