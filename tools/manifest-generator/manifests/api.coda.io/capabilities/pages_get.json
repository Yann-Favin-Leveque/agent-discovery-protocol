{
  "name": "pages_get",
  "resource_group": "pages",
  "description": "Retrieve a specific page by ID.",
  "endpoint": "/docs/{docId}/pages/{pageIdOrName}",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "pageIdOrName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Page ID or name",
      "example": "canvas-abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/pages/canvas-abc",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "canvas-abc",
      "type": "page",
      "name": "Overview",
      "subtitle": "Project overview",
      "contentType": "canvas"
    }
  }
}