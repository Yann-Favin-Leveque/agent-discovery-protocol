{
  "name": "tables_get",
  "resource_group": "tables",
  "description": "Retrieve detailed information about a specific table.",
  "endpoint": "/docs/{docId}/tables/{tableIdOrName}",
  "method": "GET",
  "parameters": [
    {
      "name": "docId",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Document ID",
      "example": "AbCDeFGH"
    },
    {
      "name": "tableIdOrName",
      "type": "string",
      "required": true,
      "in": "path",
      "description": "Table ID or name",
      "example": "grid-abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://coda.io/apis/v1/docs/AbCDeFGH/tables/grid-abc",
    "headers": {
      "Authorization": "Bearer CODA_API_KEY"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "grid-abc",
      "type": "table",
      "name": "Tasks",
      "rowCount": 42
    }
  }
}