{
  "name": "device_tags_list",
  "description": "List tags for a device.",
  "resource_group": "tags",
  "endpoint": "/v7/device_tag",
  "method": "GET",
  "parameters": [
    {
      "name": "$filter",
      "type": "string",
      "description": "OData filter by device.",
      "required": false,
      "example": "device eq 1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.balena-cloud.com/v7/device_tag?$filter=device eq 1",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "d": [
        {
          "id": 1,
          "tag_key": "location",
          "value": "office"
        }
      ]
    }
  }
}