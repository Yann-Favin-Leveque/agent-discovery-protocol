{
  "name": "applications_create",
  "description": "Create a new application.",
  "resource_group": "applications",
  "endpoint": "/v7/application",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "description": "Application name.",
      "required": true,
      "in": "body"
    },
    {
      "name": "device_type",
      "type": "string",
      "description": "Device type slug.",
      "required": true,
      "example": "raspberrypi4-64",
      "in": "body"
    },
    {
      "name": "organization",
      "type": "integer",
      "description": "Organization ID.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.balena-cloud.com/v7/application",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "app_name": "new-fleet",
      "device_type": "raspberrypi4-64",
      "organization": 1
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2,
      "app_name": "new-fleet"
    }
  }
}
