{
  "name": "applications_get",
  "description": "Get a specific application.",
  "resource_group": "applications",
  "endpoint": "/v7/application({id})",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Application ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.balena-cloud.com/v7/application(1)",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "d": [
        {
          "id": 1,
          "app_name": "my-fleet",
          "device_count": 5
        }
      ]
    }
  }
}