{
  "name": "set_environment_variables",
  "description": "Set, update, or delete environment variables for a device or an entire application fleet. Device-level variables override fleet-level ones. Variables are injected into all running containers on the target.",
  "endpoint": "/v7/device_environment_variable",
  "method": "POST",
  "parameters": [
    {
      "name": "device",
      "type": "integer",
      "description": "The numeric ID of the device to set the variable on.",
      "required": true,
      "example": 1234567
    },
    {
      "name": "name",
      "type": "string",
      "description": "The environment variable name.",
      "required": true,
      "example": "API_ENDPOINT"
    },
    {
      "name": "value",
      "type": "string",
      "description": "The environment variable value.",
      "required": true,
      "example": "https://api.example.com"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.balena-cloud.com/v7/device_environment_variable",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "device": 1234567,
      "name": "API_ENDPOINT",
      "value": "https://api.example.com"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 98765,
      "device": {
        "__id": 1234567
      },
      "name": "API_ENDPOINT",
      "value": "https://api.example.com"
    }
  }
}
