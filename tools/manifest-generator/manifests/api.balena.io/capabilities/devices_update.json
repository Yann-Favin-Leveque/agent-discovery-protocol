{
  "name": "devices_update",
  "description": "Update device properties.",
  "resource_group": "devices",
  "endpoint": "/v7/device({id})",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Device ID.",
      "required": true
    },
    {
      "name": "device_name",
      "type": "string",
      "description": "New device name.",
      "required": false
    },
    {
      "name": "note",
      "type": "string",
      "description": "Device notes.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.balena-cloud.com/v7/device(1)",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "device_name": "updated-device"
    }
  },
  "response_example": {
    "status": 200,
    "body": "OK"
  }
}