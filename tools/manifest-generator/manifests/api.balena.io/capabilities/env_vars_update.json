{
  "name": "env_vars_update",
  "description": "Update an environment variable.",
  "resource_group": "environment_variables",
  "endpoint": "/v7/device_environment_variable({id})",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Variable ID.",
      "required": true
    },
    {
      "name": "value",
      "type": "string",
      "description": "New value.",
      "required": true
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.balena-cloud.com/v7/device_environment_variable(1)",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "value": "updated-secret"
    }
  },
  "response_example": {
    "status": 200,
    "body": "OK"
  }
}