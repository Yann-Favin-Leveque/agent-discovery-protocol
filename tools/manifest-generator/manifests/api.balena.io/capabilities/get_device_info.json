{
  "name": "get_device_info",
  "description": "Get detailed information about a specific device by its UUID. Returns status, IP addresses, OS version, supervisor version, running release, and optionally expanded relationships like services and tags.",
  "endpoint": "/v7/device",
  "method": "GET",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "description": "The unique UUID of the device to inspect.",
      "required": true,
      "example": "abc123def456"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.balena-cloud.com/v7/device?$filter=uuid eq 'abc123def456'&$expand=is_running__release",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "d": [
        {
          "id": 1234567,
          "uuid": "abc123def456",
          "device_name": "bold-moon",
          "is_online": true,
          "ip_address": "192.168.1.42",
          "os_version": "balenaOS 2.98.12",
          "supervisor_version": "14.0.8",
          "is_running__release": {
            "id": 2345678,
            "commit": "a1b2c3d4"
          }
        }
      ]
    }
  }
}
