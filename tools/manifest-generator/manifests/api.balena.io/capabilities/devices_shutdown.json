{
  "name": "devices_shutdown",
  "description": "Shut down a device.",
  "resource_group": "devices",
  "endpoint": "/supervisor/v1/shutdown",
  "method": "POST",
  "parameters": [
    {
      "name": "uuid",
      "type": "string",
      "description": "Device UUID.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.balena-cloud.com/supervisor/v1/shutdown",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "uuid": "abc123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Data": "OK",
      "Error": ""
    }
  }
}
