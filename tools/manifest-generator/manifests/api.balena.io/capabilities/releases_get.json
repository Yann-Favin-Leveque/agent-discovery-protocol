{
  "name": "releases_get",
  "description": "Get a specific release.",
  "resource_group": "releases",
  "endpoint": "/v7/release({id})",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "Release ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.balena-cloud.com/v7/release(1)",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "d": [
        {
          "id": 1,
          "commit": "abc123",
          "status": "success"
        }
      ]
    }
  }
}
