{
  "name": "device_tags_create",
  "description": "Add a tag to a device.",
  "resource_group": "tags",
  "endpoint": "/v7/device_tag",
  "method": "POST",
  "parameters": [
    {
      "name": "device",
      "type": "integer",
      "description": "Device ID.",
      "required": true
    },
    {
      "name": "tag_key",
      "type": "string",
      "description": "Tag key.",
      "required": true
    },
    {
      "name": "value",
      "type": "string",
      "description": "Tag value.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.balena-cloud.com/v7/device_tag",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "device": 1,
      "tag_key": "location",
      "value": "office"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": 2,
      "tag_key": "location",
      "value": "office"
    }
  }
}