{
  "name": "contacts_delete",
  "description": "Permanently delete a contact by their Intercom ID.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The Intercom contact ID."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.intercom.io/contacts/abc123def456",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "abc123def456",
      "type": "contact",
      "deleted": true
    }
  }
}