{
  "name": "contacts_unarchive",
  "description": "Unarchive a previously archived contact, restoring them to active status.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}/unarchive",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The Intercom contact ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.intercom.io/contacts/abc123def456/unarchive",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "contact",
      "id": "abc123def456",
      "archived": false
    }
  }
}