{
  "name": "conversations_search",
  "description": "Search conversations using structured field queries with AND/OR logic.",
  "resource_group": "conversations",
  "endpoint": "/conversations/search",
  "method": "POST",
  "parameters": [
    {
      "name": "query",
      "type": "object",
      "required": true,
      "description": "Search query with field filters and operators."
    },
    {
      "name": "pagination",
      "type": "object",
      "required": false,
      "description": "Pagination parameters."
    },
    {
      "name": "sort",
      "type": "object",
      "required": false,
      "description": "Sort by field and order."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.intercom.io/conversations/search",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    },
    "body": {
      "query": {
        "field": "state",
        "operator": "=",
        "value": "open"
      },
      "pagination": {
        "per_page": 20
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "conversation.list",
      "conversations": [
        {
          "type": "conversation",
          "id": "123456",
          "state": "open"
        }
      ],
      "pages": {
        "type": "pages",
        "per_page": 20,
        "total_pages": 3
      }
    }
  }
}