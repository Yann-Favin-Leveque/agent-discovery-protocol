{
  "name": "admins_list",
  "description": "List all admins (team members) in your Intercom workspace.",
  "resource_group": "admins",
  "endpoint": "/admins",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.intercom.io/admins",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "admin.list",
      "admins": [
        {
          "type": "admin",
          "id": "admin-1",
          "name": "Agent Smith",
          "email": "smith@company.com",
          "job_title": "Support Lead",
          "away_mode_enabled": false
        }
      ]
    }
  }
}