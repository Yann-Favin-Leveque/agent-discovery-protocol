{
  "name": "companies_get",
  "description": "Retrieve a company by its Intercom ID.",
  "resource_group": "companies",
  "endpoint": "/companies/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The Intercom company ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.intercom.io/companies/company-1",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "company",
      "id": "company-1",
      "company_id": "acme-corp",
      "name": "Acme Corp",
      "user_count": 42,
      "custom_attributes": {
        "industry": "Technology"
      }
    }
  }
}