{
  "name": "tickets_get",
  "description": "Retrieve a ticket by its ID with full details.",
  "resource_group": "tickets",
  "endpoint": "/tickets/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ticket ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.intercom.io/tickets/ticket-123",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "ticket",
      "id": "ticket-123",
      "state": "submitted",
      "ticket_attributes": {
        "_default_title_": "Bug Report"
      }
    }
  }
}