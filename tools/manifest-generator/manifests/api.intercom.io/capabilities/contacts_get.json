{
  "name": "contacts_get",
  "description": "Retrieve a single contact by their Intercom ID with full profile data including tags, companies, and custom attributes.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The Intercom contact ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.intercom.io/contacts/6578a0b1c2d3e4f567890abc",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "contact",
      "id": "6578a0b1c2d3e4f567890abc",
      "role": "user",
      "email": "jane@example.com",
      "name": "Jane Doe",
      "phone": "+14155550123",
      "custom_attributes": {
        "plan": "pro"
      },
      "tags": {
        "type": "list",
        "data": [
          {
            "type": "tag",
            "id": "123",
            "name": "vip"
          }
        ]
      }
    }
  }
}
