{
  "name": "conversations_open",
  "description": "Reopen a closed conversation.",
  "resource_group": "conversations",
  "endpoint": "/conversations/{id}/parts",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The conversation ID."
    },
    {
      "name": "message_type",
      "type": "string",
      "required": true,
      "description": "Must be 'open'."
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "Must be 'admin'."
    },
    {
      "name": "admin_id",
      "type": "string",
      "required": true,
      "description": "The admin reopening the conversation."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.intercom.io/conversations/123456/parts",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    },
    "body": {
      "message_type": "open",
      "type": "admin",
      "admin_id": "admin-1"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "conversation",
      "id": "123456",
      "state": "open"
    }
  }
}