{
  "name": "list_articles",
  "description": "List help center articles from your Intercom workspace. Returns a paginated list of articles with their titles, body content, authorship, publication state, and parent collection/section. Use this to audit help center content, find articles that need updating, or retrieve article IDs for linking in conversations.",
  "endpoint": "/articles",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "The page number to retrieve. Default is 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of articles per page. Default is 50, maximum is 250."
    }
  ],
  "request_example": {
    "method": "GET",
