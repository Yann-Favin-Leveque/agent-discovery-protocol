{
  "name": "admins_get",
  "description": "Retrieve an admin by their ID.",
  "resource_group": "admins",
  "endpoint": "/admins/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The admin ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.intercom.io/admins/admin-1",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "admin",
      "id": "admin-1",
      "name": "Agent Smith",
      "email": "smith@company.com"
    }
  }
}