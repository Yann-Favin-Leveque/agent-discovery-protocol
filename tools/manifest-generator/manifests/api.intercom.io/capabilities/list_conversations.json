{
  "name": "list_conversations",
  "description": "List conversations in your Intercom workspace. Returns a paginated list of conversations ordered by most recently updated. Each conversation includes the latest message, current assignee, open/closed status, tags, and contact information. Use this to monitor open support threads, find unassigned conversations, or review recent customer interactions.",
  "endpoint": "/conversations",
  "method": "GET",
  "parameters": [
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of conversations per page. Default is 20, maximum is 150."
    },
    {
      "name": "starting_after",
      "type": "string",
      "required": false,
      "description": "Pagination cursor. Use the value from the previous response's 'pages.next.starting_after' to get the next page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.intercom.io/conversations?per_page=10",
