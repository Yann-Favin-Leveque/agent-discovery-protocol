{
  "name": "contacts_archive",
  "description": "Archive a contact. Archived contacts are excluded from searches and segments.",
  "resource_group": "contacts",
  "endpoint": "/contacts/{id}/archive",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The Intercom contact ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.intercom.io/contacts/abc123def456/archive",
    "headers": {
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "contact",
      "id": "abc123def456",
      "archived": true
    }
  }
}
