{
  "name": "tickets_reply",
  "description": "Reply to a ticket as an admin or on behalf of a contact.",
  "resource_group": "tickets",
  "endpoint": "/tickets/{id}/reply",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ticket ID."
    },
    {
      "name": "message_type",
      "type": "string",
      "required": true,
      "description": "Type: comment or note."
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "Who is replying: admin or user."
    },
    {
      "name": "admin_id",
      "type": "string",
      "required": false,
      "description": "Admin ID when type is admin."
    },
    {
      "name": "intercom_user_id",
      "type": "string",
      "required": false,
      "description": "Contact ID when type is user."
    },
    {
      "name": "body",
      "type": "string",
      "required": true,
      "description": "HTML reply body."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.intercom.io/tickets/ticket-123/reply",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer dG9rOjEyMzQ1Njc4OTBhYmNkZWY=",
      "Intercom-Version": "2.11"
    },
    "body": {
      "message_type": "comment",
      "type": "admin",
      "admin_id": "admin-1",
      "body": "<p>We are investigating this issue.</p>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "type": "ticket_part",
      "id": "part-456",
      "part_type": "comment",
      "body": "<p>We are investigating this issue.</p>"
    }
  }
}