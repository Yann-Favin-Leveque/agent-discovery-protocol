{
  "name": "expenses_list",
  "description": "List all expenses for an account with optional filtering by date, category, or vendor.",
  "endpoint": "/accounting/account/{account_id}/expenses/expenses",
  "method": "GET",
  "resource_group": "expenses",
  "parameters": [
    {"name": "account_id", "type": "string", "description": "The FreshBooks account ID.", "required": true, "example": "xB2yw"},
    {"name": "page", "type": "integer", "description": "Page number.", "required": false, "example": 1},
    {"name": "search[vendor]", "type": "string", "description": "Filter by vendor name.", "required": false, "example": "Office Depot"},
    {"name": "search[date_min]", "type": "string", "description": "Minimum expense date.", "required": false, "example": "2024-01-01"},
    {"name": "search[date_max]", "type": "string", "description": "Maximum expense date.", "required": false, "example": "2024-12-31"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.freshbooks.com/accounting/account/xB2yw/expenses/expenses?page=1",
    "headers": {"Authorization": "Bearer {token}", "Api-Version": "alpha"},
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {"response": {"result": {"expenses": [{"id": 111, "vendor": "Office Depot", "amount": {"amount": "45.99", "code": "USD"}, "date": "2024-06-15", "categoryid": 5}], "page": 1, "pages": 2, "total": 30}}}
  },
  "auth_scopes": ["user:expenses:read"],
  "rate_limits": {"requests_per_minute": 100}
}
