{
  "name": "taxes_list",
  "description": "List all tax rates configured for the account.",
  "endpoint": "/accounting/account/{account_id}/taxes/taxes",
  "method": "GET",
  "resource_group": "taxes",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The FreshBooks account ID.",
      "required": true,
      "example": "xB2yw",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.freshbooks.com/accounting/account/xB2yw/taxes/taxes",
    "headers": {
      "Authorization": "Bearer {token}",
      "Api-Version": "alpha"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "response": {
        "result": {
          "taxes": [
            {
              "taxid": 1,
              "name": "HST",
              "number": "RT 0001",
              "amount": "13",
              "compound": false
            }
          ]
        }
      }
    }
  },
  "auth_scopes": [
    "user:taxes:read"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
