{
  "name": "create_invoice",
  "description": "Create a new invoice for a client with line items, payment terms, and due date. Each line item includes a name, description, quantity, and unit cost. The invoice is created as a draft by default.",
  "endpoint": "/accounting/account/{account_id}/invoices/invoices",
  "method": "POST",
  "parameters": [
    { "name": "account_id", "type": "string", "description": "Your FreshBooks account ID.", "required": true, "example": "xZNQ1X" },
    { "name": "customerid", "type": "integer", "description": "The client ID to invoice.", "required": true, "example": 12345 },
    { "name": "create_date", "type": "string", "description": "Invoice creation date in YYYY-MM-DD format.", "required": true, "example": "2026-03-01" },
    { "name": "due_offset_days", "type": "integer", "description": "Number of days until the invoice is due.", "required": false, "example": 30 },
    { "name": "lines", "type": "array", "description": "Array of line items, each with name, description, qty, and unit_cost.", "required": true, "example": [{ "name": "Web Development", "description": "March 2026 development work", "qty": 40, "unit_cost": { "amount": "150.00", "code": "USD" } }] },
    { "name": "notes", "type": "string", "description": "Notes to display on the invoice.", "required": false, "example": "Payment due within 30 days." }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.freshbooks.com/accounting/account/xZNQ1X/invoices/invoices",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "invoice": {
        "customerid": 12345,
        "create_date": "2026-03-01",
        "due_offset_days": 30,
        "notes": "Payment due within 30 days.",
        "lines": [
          {
            "name": "Web Development",
            "description": "March 2026 development work",
            "qty": 40,
            "unit_cost": { "amount": "150.00", "code": "USD" }
          }
        ]
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "response": {
        "result": {
          "invoice": {
            "id": 98765,
            "invoice_number": "0042",
            "status": 1,
            "amount": { "amount": "6000.00", "code": "USD" },
            "outstanding": { "amount": "6000.00", "code": "USD" },
            "create_date": "2026-03-01",
            "due_date": "2026-03-31"
          }
        }
      }
    }
  }
}
