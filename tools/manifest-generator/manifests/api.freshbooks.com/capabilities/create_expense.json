{
  "name": "create_expense",
  "description": "Record a new business expense in FreshBooks with category, amount, vendor, and date. Expenses can be linked to a client and marked as billable for re-invoicing.",
  "endpoint": "/accounting/account/{account_id}/expenses/expenses",
  "method": "POST",
  "parameters": [
    { "name": "account_id", "type": "string", "description": "Your FreshBooks account ID.", "required": true, "example": "xZNQ1X" },
    { "name": "amount", "type": "object", "description": "The expense amount with currency code.", "required": true, "example": { "amount": "49.99", "code": "USD" } },
    { "name": "vendor", "type": "string", "description": "Name of the vendor or merchant.", "required": false, "example": "Adobe Inc." },
    { "name": "date", "type": "string", "description": "Expense date in YYYY-MM-DD format.", "required": true, "example": "2026-03-01" },
    { "name": "categoryid", "type": "integer", "description": "The expense category ID.", "required": true, "example": 4567 },
    { "name": "notes", "type": "string", "description": "Notes or description for the expense.", "required": false, "example": "Monthly Creative Cloud subscription" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.freshbooks.com/accounting/account/xZNQ1X/expenses/expenses",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "expense": {
        "amount": { "amount": "49.99", "code": "USD" },
        "vendor": "Adobe Inc.",
        "date": "2026-03-01",
        "categoryid": 4567,
        "notes": "Monthly Creative Cloud subscription"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "response": {
        "result": {
          "expense": {
            "id": 55555,
            "amount": { "amount": "49.99", "code": "USD" },
            "vendor": "Adobe Inc.",
            "date": "2026-03-01",
            "categoryid": 4567,
            "notes": "Monthly Creative Cloud subscription",
            "status": 0
          }
        }
      }
    }
  }
}
