{
  "name": "create_client",
  "description": "Create a new client in your FreshBooks account with their name, email, organization, and billing address. The client can then be used when creating invoices, expenses, and time entries.",
  "endpoint": "/accounting/account/{account_id}/users/clients",
  "method": "POST",
  "parameters": [
    { "name": "account_id", "type": "string", "description": "Your FreshBooks account ID.", "required": true, "example": "xZNQ1X" },
    { "name": "fname", "type": "string", "description": "Client's first name.", "required": false, "example": "John" },
    { "name": "lname", "type": "string", "description": "Client's last name.", "required": false, "example": "Smith" },
    { "name": "email", "type": "string", "description": "Client's email address.", "required": true, "example": "john@acme.com" },
    { "name": "organization", "type": "string", "description": "Client's company or organization name.", "required": false, "example": "Acme Corp" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.freshbooks.com/accounting/account/xZNQ1X/users/clients",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "client": {
        "fname": "John",
        "lname": "Smith",
        "email": "john@acme.com",
        "organization": "Acme Corp"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "response": {
        "result": {
          "client": {
            "id": 12346,
            "fname": "John",
            "lname": "Smith",
            "email": "john@acme.com",
            "organization": "Acme Corp"
          }
        }
      }
    }
  }
}
