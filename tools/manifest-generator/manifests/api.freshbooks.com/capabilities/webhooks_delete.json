{
  "name": "webhooks_delete",
  "description": "Delete a registered webhook callback by its ID.",
  "endpoint": "/events/account/{account_id}/events/callbacks/{callback_id}",
  "method": "DELETE",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "description": "The FreshBooks account ID.",
      "required": true,
      "example": "xB2yw",
      "in": "path"
    },
    {
      "name": "callback_id",
      "type": "integer",
      "description": "The webhook callback ID to delete.",
      "required": true,
      "example": 777,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.freshbooks.com/events/account/xB2yw/events/callbacks/777",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "response": {
        "result": {}
      }
    }
  },
  "auth_scopes": [
    "user:webhooks:write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
