{
  "name": "list_invoices",
  "description": "List all invoices for a FreshBooks account with optional filtering by status, date range, or client. Returns invoice details including amounts, dates, and payment status.",
  "endpoint": "/accounting/account/{account_id}/invoices/invoices",
  "method": "GET",
  "parameters": [
    { "name": "account_id", "type": "string", "description": "Your FreshBooks account ID.", "required": true, "example": "xZNQ1X" },
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 },
    { "name": "search[status]", "type": "integer", "description": "Filter by status: 1=draft, 2=sent, 3=viewed, 4=paid, 5=auto-paid.", "required": false, "example": 2 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.freshbooks.com/accounting/account/xZNQ1X/invoices/invoices?page=1&per_page=25",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "response": {
        "result": {
          "invoices": [
            {
              "id": 98765,
              "invoice_number": "0042",
              "status": 2,
              "amount": { "amount": "6000.00", "code": "USD" },
              "outstanding": { "amount": "6000.00", "code": "USD" },
              "create_date": "2026-03-01",
              "due_date": "2026-03-31",
              "customerid": 12345
            }
          ],
          "page": 1,
          "pages": 2,
          "per_page": 25,
          "total": 42
        }
      }
    }
  }
}
