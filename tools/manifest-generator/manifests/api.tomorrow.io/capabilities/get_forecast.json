{
  "name": "get_forecast",
  "description": "Retrieve a weather forecast with minutely (next hour), hourly (up to 120 hours), and daily (up to 15 days) breakdowns. Each timestep includes 80+ weather fields like temperature, precipitation, wind, humidity, cloud cover, snow, and air quality. Minutely data is ideal for precipitation nowcasting.",
  "endpoint": "/v4/weather/forecast",
  "method": "GET",
  "parameters": [
    {
      "name": "location",
      "type": "string",
      "description": "Location as a city name, latitude/longitude pair, or place ID.",
      "required": true,
      "example": "New York"
    },
    {
      "name": "apikey",
      "type": "string",
      "description": "Your API key for authentication.",
      "required": true,
      "example": "{api_key}"
    },
    {
      "name": "timesteps",
      "type": "string",
      "description": "Comma-separated time intervals: '1m' (minutely), '1h' (hourly), '1d' (daily).",
      "required": false,
      "example": "1h,1d"
    },
    {
      "name": "units",
      "type": "string",
      "description": "Unit system: 'metric' or 'imperial'.",
      "required": false,
      "example": "metric"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.tomorrow.io/v4/weather/forecast?location=New+York&timesteps=1h,1d&units=metric&apikey={api_key}",
    "headers": {
      "Accept-Encoding": "gzip"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "timelines": {
        "hourly": [
          {
            "time": "2024-01-15T15:00:00Z",
            "values": {
              "temperature": 5.2,
              "temperatureApparent": 2.1,
              "humidity": 55,
              "windSpeed": 6.8,
              "windGust": 12.3,
              "precipitationProbability": 20,
              "precipitationIntensity": 0,
              "snowIntensity": 0,
              "weatherCode": 1001,
              "cloudCover": 80,
              "visibility": 16.0
            }
          }
        ],
        "daily": [
          {
            "time": "2024-01-15T06:00:00Z",
            "values": {
              "temperatureMax": 7.8,
              "temperatureMin": 1.2,
              "humidityAvg": 58,
              "windSpeedMax": 14.5,
              "precipitationProbabilityMax": 30,
              "weatherCodeMax": 1001,
              "sunriseTime": "2024-01-15T12:18:00Z",
              "sunsetTime": "2024-01-15T21:50:00Z",
              "uvIndexMax": 2
            }
          }
        ]
      },
      "location": {
        "lat": 40.7128,
        "lon": -74.006,
        "name": "New York, NY, United States"
      }
    }
  }
}
