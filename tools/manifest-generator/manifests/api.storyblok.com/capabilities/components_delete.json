{
  "name": "components_delete",
  "description": "Delete a component definition.",
  "endpoint": "/v1/spaces/{space_id}/components/{component_id}",
  "method": "DELETE",
  "resource_group": "components",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "component_id",
      "type": "integer",
      "description": "Component ID to delete",
      "required": true,
      "example": 3
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/components/3",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}