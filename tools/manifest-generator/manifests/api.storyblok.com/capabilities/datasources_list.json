{
  "name": "datasources_list",
  "description": "List all datasources in the space.",
  "endpoint": "/v2/cdn/datasources",
  "method": "GET",
  "resource_group": "datasources",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "description": "API token",
      "required": true,
      "example": "your-token"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.storyblok.com/v2/cdn/datasources?token=your-token",
    "headers": {
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "datasources": [
        {
          "id": 1,
          "name": "Colors",
          "slug": "colors"
        }
      ]
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}