{
  "name": "spaces_get",
  "description": "Retrieve information about the current space.",
  "endpoint": "/v2/cdn/spaces/me",
  "method": "GET",
  "resource_group": "spaces",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "description": "API token",
      "required": true,
      "example": "your-token"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.storyblok.com/v2/cdn/spaces/me?token=your-token",
    "headers": {
      "Accept": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "space": {
        "id": 12345,
        "name": "My Space",
        "domain": "https://example.com",
        "version": 42
      }
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}