{
  "name": "components_get",
  "description": "Retrieve a specific component definition by ID.",
  "endpoint": "/v1/spaces/{space_id}/components/{component_id}",
  "method": "GET",
  "resource_group": "components",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "component_id",
      "type": "integer",
      "description": "Component ID",
      "required": true,
      "example": 2
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/components/2",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "component": {
        "id": 2,
        "name": "post",
        "schema": {
          "title": {
            "type": "text"
          },
          "body": {
            "type": "richtext"
          }
        }
      }
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}