{
  "name": "assets_get",
  "description": "Retrieve a specific asset by ID.",
  "endpoint": "/v1/spaces/{space_id}/assets/{asset_id}",
  "method": "GET",
  "resource_group": "assets",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "asset_id",
      "type": "integer",
      "description": "Asset ID",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/assets/1",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "filename": "image.jpg",
      "content_type": "image/jpeg"
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}