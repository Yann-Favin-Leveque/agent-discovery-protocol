{
  "name": "components_update",
  "description": "Update a component definition.",
  "endpoint": "/v1/spaces/{space_id}/components/{component_id}",
  "method": "PUT",
  "resource_group": "components",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345,
      "in": "path"
    },
    {
      "name": "component_id",
      "type": "integer",
      "description": "Component ID",
      "required": true,
      "example": 3,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/components/3",
    "headers": {
      "Authorization": "your-management-token",
      "Content-Type": "application/json"
    },
    "body": {
      "component": {
        "name": "hero",
        "schema": {
          "title": {
            "type": "text"
          },
          "subtitle": {
            "type": "text"
          },
          "image": {
            "type": "image"
          }
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "component": {
        "id": 3,
        "name": "hero"
      }
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
