{
  "name": "assets_create",
  "description": "Upload a new asset (image or file) to the space. Returns a signed upload URL.",
  "endpoint": "/v1/spaces/{space_id}/assets",
  "method": "POST",
  "resource_group": "assets",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "filename",
      "type": "string",
      "description": "File name",
      "required": true,
      "example": "photo.jpg"
    },
    {
      "name": "size",
      "type": "string",
      "description": "File size",
      "required": false,
      "example": "1024x768"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/assets",
    "headers": {
      "Authorization": "your-management-token",
      "Content-Type": "application/json"
    },
    "body": {
      "filename": "photo.jpg",
      "size": "1024x768"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "pretty_url": "//a.storyblok.com/f/12345/photo.jpg",
      "public_url": "https://a.storyblok.com/f/12345/photo.jpg",
      "fields": {
        "key": "value"
      },
      "post_url": "https://s3.amazonaws.com/a.storyblok.com"
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}