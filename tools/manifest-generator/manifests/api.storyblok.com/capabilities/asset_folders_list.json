{
  "name": "asset_folders_list",
  "description": "List all asset folders in the space.",
  "endpoint": "/v1/spaces/{space_id}/asset_folders",
  "method": "GET",
  "resource_group": "asset_folders",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/asset_folders",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "asset_folders": [
        {
          "id": 1,
          "name": "Images"
        }
      ]
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
