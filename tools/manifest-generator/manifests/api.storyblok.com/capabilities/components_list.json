{
  "name": "components_list",
  "description": "List all component definitions (content type schemas) in the space.",
  "endpoint": "/v1/spaces/{space_id}/components",
  "method": "GET",
  "resource_group": "components",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/components",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "components": [
        {
          "id": 1,
          "name": "page",
          "schema": {
            "body": {
              "type": "bloks"
            }
          }
        },
        {
          "id": 2,
          "name": "post",
          "schema": {
            "title": {
              "type": "text"
            }
          }
        }
      ]
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
