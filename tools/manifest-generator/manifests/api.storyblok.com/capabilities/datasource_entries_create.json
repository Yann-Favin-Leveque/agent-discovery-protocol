{
  "name": "datasource_entries_create",
  "description": "Create a new entry in a datasource.",
  "endpoint": "/v1/spaces/{space_id}/datasource_entries",
  "method": "POST",
  "resource_group": "datasources",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345,
      "in": "path"
    },
    {
      "name": "datasource_entry",
      "type": "object",
      "description": "Entry with name, value, and datasource_id",
      "required": true,
      "example": {
        "name": "Small",
        "value": "S",
        "datasource_id": 2
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/datasource_entries",
    "headers": {
      "Authorization": "your-management-token",
      "Content-Type": "application/json"
    },
    "body": {
      "datasource_entry": {
        "name": "Small",
        "value": "S",
        "datasource_id": 2
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "datasource_entry": {
        "id": 3,
        "name": "Small",
        "value": "S"
      }
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
