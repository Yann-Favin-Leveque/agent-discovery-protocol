{
  "name": "releases_delete",
  "description": "Delete a content release.",
  "endpoint": "/v1/spaces/{space_id}/releases/{release_id}",
  "method": "DELETE",
  "resource_group": "releases",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "release_id",
      "type": "integer",
      "description": "Release ID",
      "required": true,
      "example": 2
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/releases/2",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}