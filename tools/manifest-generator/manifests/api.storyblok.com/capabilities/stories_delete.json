{
  "name": "stories_delete",
  "description": "Permanently delete a story by its ID.",
  "endpoint": "/v1/spaces/{space_id}/stories/{story_id}",
  "method": "DELETE",
  "resource_group": "stories",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345,
      "in": "path"
    },
    {
      "name": "story_id",
      "type": "integer",
      "description": "Story ID to delete",
      "required": true,
      "example": 456,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/stories/456",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "story": {
        "id": 456
      }
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}
