{
  "name": "releases_list",
  "description": "List all content releases in the space.",
  "endpoint": "/v1/spaces/{space_id}/releases",
  "method": "GET",
  "resource_group": "releases",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/releases",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "releases": [
        {
          "id": 1,
          "name": "Spring Update",
          "released_at": null
        }
      ]
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}