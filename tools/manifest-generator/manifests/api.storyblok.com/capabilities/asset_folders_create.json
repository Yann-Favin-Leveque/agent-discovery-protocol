{
  "name": "asset_folders_create",
  "description": "Create a new asset folder.",
  "endpoint": "/v1/spaces/{space_id}/asset_folders",
  "method": "POST",
  "resource_group": "asset_folders",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "asset_folder",
      "type": "object",
      "description": "Folder object",
      "required": true,
      "example": {
        "name": "Documents"
      }
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/asset_folders",
    "headers": {
      "Authorization": "your-management-token",
      "Content-Type": "application/json"
    },
    "body": {
      "asset_folder": {
        "name": "Documents"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "asset_folder": {
        "id": 2,
        "name": "Documents"
      }
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}