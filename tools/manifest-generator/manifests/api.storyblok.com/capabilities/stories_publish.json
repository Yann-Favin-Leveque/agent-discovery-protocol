{
  "name": "stories_publish",
  "description": "Publish a story to make it available via the Content Delivery API.",
  "endpoint": "/v1/spaces/{space_id}/stories/{story_id}/publish",
  "method": "GET",
  "resource_group": "stories",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "story_id",
      "type": "integer",
      "description": "Story ID to publish",
      "required": true,
      "example": 456
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/stories/456/publish",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "story": {
        "id": 456,
        "published": true
      }
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}