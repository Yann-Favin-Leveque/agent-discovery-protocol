{
  "name": "webhooks_list",
  "description": "List all webhooks configured for the space.",
  "endpoint": "/v1/spaces/{space_id}/webhook_endpoints",
  "method": "GET",
  "resource_group": "webhooks",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/webhook_endpoints",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "webhook_endpoints": [
        {
          "id": 1,
          "name": "My Webhook",
          "endpoint": "https://example.com/webhook"
        }
      ]
    }
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}