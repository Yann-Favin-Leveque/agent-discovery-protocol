{
  "name": "assets_delete",
  "description": "Delete an asset from the space.",
  "endpoint": "/v1/spaces/{space_id}/assets/{asset_id}",
  "method": "DELETE",
  "resource_group": "assets",
  "parameters": [
    {
      "name": "space_id",
      "type": "integer",
      "description": "Space ID",
      "required": true,
      "example": 12345
    },
    {
      "name": "asset_id",
      "type": "integer",
      "description": "Asset ID to delete",
      "required": true,
      "example": 1
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://mapi.storyblok.com/v1/spaces/12345/assets/1",
    "headers": {
      "Authorization": "your-management-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [
    "read",
    "write"
  ],
  "rate_limits": {
    "requests_per_minute": 100
  }
}