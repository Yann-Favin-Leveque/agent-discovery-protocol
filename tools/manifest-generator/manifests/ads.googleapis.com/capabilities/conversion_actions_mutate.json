{
  "name": "conversion_actions_mutate",
  "description": "Create, update, or remove conversion actions.",
  "resource_group": "conversions",
  "endpoint": "/v18/customers/{customerId}/conversionActions:mutate",
  "method": "POST",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "Customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "operations",
      "type": "array",
      "description": "Array of create/update/remove operations.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v18/customers/1234567890/conversionActions:mutate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "operations": [
        {
          "create": {
            "name": "Purchase",
            "type": "UPLOAD_CLICKS",
            "category": "PURCHASE",
            "valueSettings": {
              "defaultValue": 0,
              "alwaysUseDefaultValue": false
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "resourceName": "customers/1234567890/conversionActions/789"
        }
      ]
    }
  }
}
