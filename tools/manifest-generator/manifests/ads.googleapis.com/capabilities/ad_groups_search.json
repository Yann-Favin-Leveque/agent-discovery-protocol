{
  "name": "ad_groups_search",
  "description": "Search and retrieve ad groups using GAQL.",
  "resource_group": "ad_groups",
  "endpoint": "/v18/customers/{customerId}/googleAds:searchStream",
  "method": "POST",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "Customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "query",
      "type": "string",
      "description": "GAQL query for ad_group resource.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v18/customers/1234567890/googleAds:searchStream",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "SELECT ad_group.id, ad_group.name, ad_group.status FROM ad_group"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "results": [
          {
            "adGroup": {
              "id": "444",
              "name": "Ad Group 1",
              "status": "ENABLED"
            }
          }
        ]
      }
    ]
  }
}
