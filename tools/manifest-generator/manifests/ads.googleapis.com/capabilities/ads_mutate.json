{
  "name": "ads_mutate",
  "description": "Create, update, pause, or remove ads.",
  "resource_group": "ads",
  "endpoint": "/v18/customers/{customerId}/adGroupAds:mutate",
  "method": "POST",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "Customer ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "operations",
      "type": "array",
      "description": "Array of create/update/remove operations.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v18/customers/1234567890/adGroupAds:mutate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "operations": [
        {
          "create": {
            "adGroup": "customers/1234567890/adGroups/444",
            "status": "ENABLED",
            "ad": {
              "responsiveSearchAd": {
                "headlines": [
                  {
                    "text": "Great Product"
                  }
                ],
                "descriptions": [
                  {
                    "text": "Buy now"
                  }
                ]
              }
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "resourceName": "customers/1234567890/adGroupAds/777~888"
        }
      ]
    }
  }
}
