{
  "name": "manage_conversions",
  "description": "Upload offline conversions, create conversion actions, and manage conversion tracking. Offline conversions let you attribute sales or leads that happen outside your website (phone calls, in-store visits) back to your Google Ads clicks.",
  "endpoint": "/v17/customers/{customer_id}/conversionActions:mutate",
  "method": "POST",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The Google Ads customer ID (without dashes).",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "operations",
      "type": "array",
      "description": "Array of create or update operations for conversion actions.",
      "required": true,
      "example": [
        {
          "create": {
            "name": "Phone Call Lead",
            "type": "UPLOAD_CALLS",
            "category": "LEAD",
            "status": "ENABLED",
            "valueSettings": {
              "defaultValue": 25.0,
              "defaultCurrencyCode": "USD",
              "alwaysUseDefaultValue": false
            }
          }
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v17/customers/1234567890/conversionActions:mutate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "operations": [
        {
          "create": {
            "name": "Phone Call Lead",
            "type": "UPLOAD_CALLS",
            "category": "LEAD",
            "status": "ENABLED",
            "valueSettings": {
              "defaultValue": 25.0,
              "defaultCurrencyCode": "USD",
              "alwaysUseDefaultValue": false
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "resourceName": "customers/1234567890/conversionActions/131415"
        }
      ]
    }
  }
}
