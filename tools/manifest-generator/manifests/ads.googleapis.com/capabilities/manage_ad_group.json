{
  "name": "manage_ad_group",
  "description": "Create, update, or remove ad groups within a Google Ads campaign. Ad groups contain ads and keywords grouped by theme. You can set CPC bids, status, and targeting settings at the ad group level.",
  "endpoint": "/v17/customers/{customer_id}/adGroups:mutate",
  "method": "POST",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The Google Ads customer ID (without dashes).",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "operations",
      "type": "array",
      "description": "Array of create, update, or remove operations for ad groups.",
      "required": true,
      "example": [
        {
          "create": {
            "name": "Running Shoes",
            "campaign": "customers/1234567890/campaigns/111222333",
            "status": "ENABLED",
            "cpcBidMicros": "1500000",
            "type": "SEARCH_STANDARD"
          }
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v17/customers/1234567890/adGroups:mutate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "operations": [
        {
          "create": {
            "name": "Running Shoes",
            "campaign": "customers/1234567890/campaigns/111222333",
            "status": "ENABLED",
            "cpcBidMicros": "1500000",
            "type": "SEARCH_STANDARD"
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "resourceName": "customers/1234567890/adGroups/444555666"
        }
      ]
    }
  }
}
