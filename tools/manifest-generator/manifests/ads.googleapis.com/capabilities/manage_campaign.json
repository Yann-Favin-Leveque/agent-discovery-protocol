{
  "name": "manage_campaign",
  "description": "Create, update, pause, or enable a Google Ads campaign. You can set the campaign name, type (Search, Display, Shopping, Video), budget, bidding strategy, start/end dates, and network targeting. Uses the mutate endpoint with create or update operations.",
  "endpoint": "/v17/customers/{customer_id}/campaigns:mutate",
  "method": "POST",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The Google Ads customer ID (without dashes).",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "operations",
      "type": "array",
      "description": "Array of create or update operations to apply to campaigns.",
      "required": true,
      "example": [
        {
          "create": {
            "name": "Spring Sale 2026",
            "advertisingChannelType": "SEARCH",
            "status": "PAUSED",
            "campaignBudget": "customers/1234567890/campaignBudgets/555666",
            "biddingStrategyType": "MAXIMIZE_CLICKS"
          }
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v17/customers/1234567890/campaigns:mutate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "operations": [
        {
          "create": {
            "name": "Spring Sale 2026",
            "advertisingChannelType": "SEARCH",
            "status": "PAUSED",
            "campaignBudget": "customers/1234567890/campaignBudgets/555666",
            "biddingStrategyType": "MAXIMIZE_CLICKS",
            "networkSettings": {
              "targetGoogleSearch": true,
              "targetSearchNetwork": true
            }
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "resourceName": "customers/1234567890/campaigns/111222333"
        }
      ]
    }
  }
}
