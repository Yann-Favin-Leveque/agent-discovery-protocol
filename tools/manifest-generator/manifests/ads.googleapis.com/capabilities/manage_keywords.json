{
  "name": "manage_keywords",
  "description": "Add, update, or remove keyword criteria in a Google Ads ad group. Keywords determine when your ads appear in search results. Set match types (EXACT, PHRASE, BROAD), CPC bids, and negative keywords to refine targeting.",
  "endpoint": "/v17/customers/{customer_id}/adGroupCriteria:mutate",
  "method": "POST",
  "parameters": [
    {
      "name": "customer_id",
      "type": "string",
      "description": "The Google Ads customer ID (without dashes).",
      "required": true,
      "example": "1234567890"
    },
    {
      "name": "operations",
      "type": "array",
      "description": "Array of create, update, or remove operations for keywords.",
      "required": true,
      "example": [
        {
          "create": {
            "adGroup": "customers/1234567890/adGroups/444555666",
            "status": "ENABLED",
            "keyword": {
              "text": "running shoes",
              "matchType": "PHRASE"
            },
            "cpcBidMicros": "2000000"
          }
        }
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v17/customers/1234567890/adGroupCriteria:mutate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "operations": [
        {
          "create": {
            "adGroup": "customers/1234567890/adGroups/444555666",
            "status": "ENABLED",
            "keyword": {
              "text": "running shoes",
              "matchType": "PHRASE"
            },
            "cpcBidMicros": "2000000"
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "resourceName": "customers/1234567890/adGroupCriteria/444555666~101112"
        }
      ]
    }
  }
}
