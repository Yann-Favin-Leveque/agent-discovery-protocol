{
  "name": "campaign_budgets_mutate",
  "description": "Create, update, or remove campaign budgets.",
  "resource_group": "campaign_budgets",
  "endpoint": "/v18/customers/{customerId}/campaignBudgets:mutate",
  "method": "POST",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "Customer ID.",
      "required": true
    },
    {
      "name": "operations",
      "type": "array",
      "description": "Array of create/update/remove operations.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://googleads.googleapis.com/v18/customers/1234567890/campaignBudgets:mutate",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "operations": [
        {
          "create": {
            "name": "Daily Budget",
            "amountMicros": "50000000",
            "deliveryMethod": "STANDARD"
          }
        }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "resourceName": "customers/1234567890/campaignBudgets/222"
        }
      ]
    }
  }
}