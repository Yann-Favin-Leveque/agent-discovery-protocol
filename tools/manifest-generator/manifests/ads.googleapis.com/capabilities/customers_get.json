{
  "name": "customers_get",
  "description": "Retrieve customer account details.",
  "resource_group": "customers",
  "endpoint": "/v18/customers/{customerId}",
  "method": "GET",
  "parameters": [
    {
      "name": "customerId",
      "type": "string",
      "description": "Customer ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://googleads.googleapis.com/v18/customers/1234567890",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "developer-token": "{developer_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "resourceName": "customers/1234567890",
      "id": "1234567890",
      "descriptiveName": "My Account",
      "currencyCode": "USD",
      "timeZone": "America/New_York"
    }
  }
}
