{
  "name": "automations_create",
  "description": "Create a new automation triggered by RSS feeds or other events.",
  "resource_group": "automations",
  "endpoint": "/v1/automations",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Automation name.",
      "required": true,
      "example": "Blog Digest",
      "in": "body"
    },
    {
      "name": "feed_url",
      "type": "string",
      "description": "RSS feed URL to monitor.",
      "required": false,
      "example": "https://example.com/feed.xml",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.buttondown.email/v1/automations",
    "headers": {
      "Authorization": "Token {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Blog Digest",
      "feed_url": "https://example.com/feed.xml"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "auto-uuid-2",
      "name": "Blog Digest",
      "status": "active"
    }
  }
}
