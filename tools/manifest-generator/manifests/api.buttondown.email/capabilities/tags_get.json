{
  "name": "tags_get",
  "description": "Retrieve a specific tag by ID.",
  "resource_group": "tags",
  "endpoint": "/v1/tags/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Tag UUID.",
      "required": true,
      "example": "tag-uuid-1",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.buttondown.email/v1/tags/tag-uuid-1",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tag-uuid-1",
      "name": "newsletter",
      "color": "blue"
    }
  }
}
