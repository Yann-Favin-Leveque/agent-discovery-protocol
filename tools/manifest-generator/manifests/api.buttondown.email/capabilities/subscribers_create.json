{
  "name": "subscribers_create",
  "description": "Create a new subscriber and optionally assign tags.",
  "resource_group": "subscribers",
  "endpoint": "/v1/subscribers",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Email address of the new subscriber.",
      "required": true,
      "example": "jane@example.com",
      "in": "body"
    },
    {
      "name": "metadata",
      "type": "object",
      "description": "Key-value metadata for the subscriber.",
      "required": false,
      "in": "body"
    },
    {
      "name": "tags",
      "type": "array",
      "description": "Tags to assign. Non-existent tags are created automatically.",
      "required": false,
      "example": [
        "newsletter"
      ],
      "in": "body"
    },
    {
      "name": "referrer_url",
      "type": "string",
      "description": "Referrer URL for tracking.",
      "required": false,
      "in": "body"
    },
    {
      "name": "notes",
      "type": "string",
      "description": "Internal notes about the subscriber.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.buttondown.email/v1/subscribers",
    "headers": {
      "Authorization": "Token {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "jane@example.com",
      "tags": [
        "newsletter"
      ]
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "uuid-456",
      "email": "jane@example.com",
      "creation_date": "2024-06-15T10:00:00Z",
      "tags": [
        "newsletter"
      ]
    }
  }
}
