{
  "name": "automations_list",
  "description": "Retrieve all automations configured for your newsletter.",
  "resource_group": "automations",
  "endpoint": "/v1/automations",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.buttondown.email/v1/automations",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 2,
      "results": [
        {
          "id": "auto-uuid-1",
          "name": "RSS Digest",
          "status": "active",
          "creation_date": "2024-01-01T00:00:00Z"
        }
      ]
    }
  }
}
