{
  "name": "emails_send_draft",
  "description": "Send a draft email to subscribers or specific recipients.",
  "resource_group": "emails",
  "endpoint": "/v1/emails/{id}/send-draft",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Email UUID of the draft.",
      "required": true,
      "example": "email-uuid-2",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.buttondown.email/v1/emails/email-uuid-2/send-draft",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "email-uuid-2",
      "status": "sent"
    }
  }
}
