{
  "name": "subscribers_delete",
  "description": "Delete a subscriber by ID.",
  "resource_group": "subscribers",
  "endpoint": "/v1/subscribers/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscriber UUID.",
      "required": true,
      "example": "uuid-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.buttondown.email/v1/subscribers/uuid-123",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
