{
  "name": "subscribers_send_reminder",
  "description": "Send a reminder email to a subscriber.",
  "resource_group": "subscribers",
  "endpoint": "/v1/subscribers/{id}/send-reminder",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Subscriber UUID.",
      "required": true,
      "example": "uuid-123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.buttondown.email/v1/subscribers/uuid-123/send-reminder",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "status": "sent"
    }
  }
}
