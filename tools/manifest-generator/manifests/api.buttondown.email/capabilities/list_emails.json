{
  "name": "list_emails",
  "description": "Retrieve a paginated list of your sent and drafted emails. Each email includes metadata like subject, status, send date, and engagement statistics such as open and click counts.",
  "endpoint": "/v1/emails",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "description": "Filter by email status. Options: draft, about_to_send, sent, imported.",
      "required": false,
      "example": "sent"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for paginated results.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.buttondown.email/v1/emails?status=sent&page=1",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 58,
      "next": "https://api.buttondown.email/v1/emails?page=2",
      "previous": null,
      "results": [
        {
          "id": "email_xyz789",
          "subject": "This Week in Tech #41",
          "status": "sent",
          "creation_date": "2026-02-22T09:00:00Z",
          "publish_date": "2026-02-22T09:00:00Z",
          "email_type": "public",
          "secondary_id": 41,
          "open_count": 1240,
          "click_count": 310
        }
      ]
    }
  }
}
