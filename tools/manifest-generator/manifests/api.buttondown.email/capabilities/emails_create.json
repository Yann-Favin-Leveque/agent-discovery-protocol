{
  "name": "emails_create",
  "description": "Create a new email draft or schedule it for future delivery.",
  "resource_group": "emails",
  "endpoint": "/v1/emails",
  "method": "POST",
  "parameters": [
    {
      "name": "subject",
      "type": "string",
      "description": "Email subject line.",
      "required": true,
      "example": "Monthly Newsletter",
      "in": "body"
    },
    {
      "name": "body",
      "type": "string",
      "description": "Email body in Markdown format.",
      "required": true,
      "example": "# Hello\nThis is the newsletter.",
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Email status: draft or about_to_send.",
      "required": false,
      "example": "draft",
      "in": "body"
    },
    {
      "name": "publish_date",
      "type": "string",
      "description": "ISO 8601 datetime for scheduling. Required if status is about_to_send.",
      "required": false,
      "example": "2024-07-01T10:00:00Z",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.buttondown.email/v1/emails",
    "headers": {
      "Authorization": "Token {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "subject": "Monthly Newsletter",
      "body": "# Hello\nThis is the newsletter.",
      "status": "draft"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "email-uuid-2",
      "subject": "Monthly Newsletter",
      "status": "draft"
    }
  }
}
