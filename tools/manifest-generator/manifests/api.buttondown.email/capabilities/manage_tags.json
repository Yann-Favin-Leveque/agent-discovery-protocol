{
  "name": "manage_tags",
  "description": "Create, list, update, or delete tags in your Buttondown newsletter. Tags let you segment and organize subscribers into groups for targeted email sends.",
  "endpoint": "/v1/tags",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number for paginated results.",
      "required": false,
      "example": 1
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.buttondown.email/v1/tags",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 5,
      "next": null,
      "previous": null,
      "results": [
        {
          "id": "tag_abc123",
          "name": "tech",
          "creation_date": "2025-06-01T10:00:00Z",
          "description": "Subscribers interested in tech content"
        }
      ]
    }
  }
}
