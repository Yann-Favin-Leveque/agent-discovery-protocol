{
  "name": "tags_list",
  "description": "Retrieve all tags in your newsletter.",
  "resource_group": "tags",
  "endpoint": "/v1/tags",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.buttondown.email/v1/tags",
    "headers": {
      "Authorization": "Token {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "count": 5,
      "results": [
        {
          "id": "tag-uuid-1",
          "name": "newsletter",
          "color": "blue",
          "description": "Main list"
        }
      ]
    }
  }
}
