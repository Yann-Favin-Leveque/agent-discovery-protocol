{
  "name": "event_get",
  "description": "Retrieve a specific event by its ID including payload and metadata.",
  "resource_group": "event",
  "endpoint": "/v1/events/{eventId}",
  "method": "GET",
  "parameters": [
    {
      "name": "eventId",
      "type": "string",
      "description": "Event ID (path parameter).",
      "required": true,
      "example": "01HWAVEB858VPPX47Z65GR6P6R",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.inngest.com/v1/events/01HWAVEB858VPPX47Z65GR6P6R",
    "headers": {
      "Authorization": "Bearer {signing_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "01HWAVEB858VPPX47Z65GR6P6R",
      "name": "app/user.created",
      "data": {
        "user_id": "usr_123"
      },
      "received_at": "2024-01-01T00:00:00Z"
    }
  }
}
