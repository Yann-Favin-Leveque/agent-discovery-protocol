{
  "name": "key_create",
  "description": "Create a new event key for sending events.",
  "resource_group": "key",
  "endpoint": "/v1/keys",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Key name.",
      "required": true,
      "example": "Staging Key",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.inngest.com/v1/keys",
    "headers": {
      "Authorization": "Bearer {signing_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Staging Key"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "key_xyz",
      "name": "Staging Key",
      "pkey": "evt_key_xyz123"
    }
  }
}
