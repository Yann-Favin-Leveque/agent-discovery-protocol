{
  "name": "app_get",
  "description": "Retrieve details of a specific app by ID.",
  "resource_group": "app",
  "endpoint": "/v1/apps/{appId}",
  "method": "GET",
  "parameters": [
    {
      "name": "appId",
      "type": "string",
      "description": "App ID (path parameter).",
      "required": true,
      "example": "my-app"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.inngest.com/v1/apps/my-app",
    "headers": {
      "Authorization": "Bearer {signing_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "my-app",
      "name": "My Application",
      "url": "https://example.com/api/inngest",
      "functions_count": 5
    }
  }
}