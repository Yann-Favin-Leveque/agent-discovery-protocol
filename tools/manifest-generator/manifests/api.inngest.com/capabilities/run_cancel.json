{
  "name": "run_cancel",
  "description": "Cancel a specific function run that is currently in progress.",
  "resource_group": "run",
  "endpoint": "/v1/runs/{runId}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.inngest.com/v1/runs/run_abc123/cancel",
    "headers": {
      "Authorization": "Bearer {signing_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "run_id": "run_abc123",
      "status": "Cancelled"
    }
  }
}
