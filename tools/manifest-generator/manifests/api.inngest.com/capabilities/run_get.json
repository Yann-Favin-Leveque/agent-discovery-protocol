{
  "name": "run_get",
  "description": "Retrieve details and status of a specific function run including output.",
  "resource_group": "run",
  "endpoint": "/v1/runs/{runId}",
  "method": "GET",
  "parameters": [
    {
      "name": "runId",
      "type": "string",
      "description": "Run ID (path parameter).",
      "required": true,
      "example": "run_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.inngest.com/v1/runs/run_abc123",
    "headers": {
      "Authorization": "Bearer {signing_key}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "run_id": "run_abc123",
      "function_id": "my-app-my-function",
      "status": "Completed",
      "started_at": "2024-01-01T00:00:00Z",
      "ended_at": "2024-01-01T00:01:00Z",
      "output": "result data"
    }
  }
}
