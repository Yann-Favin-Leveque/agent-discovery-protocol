{
  "name": "cors_put",
  "description": "Set CORS rules for a bucket.",
  "resource_group": "cors",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/cors",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier",
      "in": "path"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "request_example": {
    "rules": [
      {
        "allowed_origins": [
          "*"
        ],
        "allowed_methods": [
          "GET",
          "PUT"
        ],
        "allowed_headers": [
          "*"
        ],
        "max_age_seconds": 3600
      }
    ]
  }
}
