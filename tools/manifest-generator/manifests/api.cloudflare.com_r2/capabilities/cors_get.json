{
  "name": "cors_get",
  "description": "Get the CORS policy for a bucket.",
  "resource_group": "cors",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/cors",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}