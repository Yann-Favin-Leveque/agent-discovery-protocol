{
  "name": "custom_domains_update",
  "description": "Update custom domain configuration.",
  "resource_group": "custom_domains",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/domains/custom/{domain}",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket"
    },
    {
      "name": "domain",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Custom domain name"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}