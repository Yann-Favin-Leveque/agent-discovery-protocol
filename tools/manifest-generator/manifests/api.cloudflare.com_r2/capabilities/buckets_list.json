{
  "name": "buckets_list",
  "description": "List all R2 buckets in an account.",
  "resource_group": "buckets",
  "endpoint": "/accounts/{account_id}/r2/buckets",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier",
      "in": "path"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Pagination cursor",
      "in": "query"
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "location": "query",
      "description": "Results per page (max 1000)",
      "in": "query"
    },
    {
      "name": "name_contains",
      "type": "string",
      "required": false,
      "location": "query",
      "description": "Filter buckets by name substring",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "response_example": {
    "success": true,
    "result": {
      "buckets": [
        {
          "name": "my-bucket",
          "creation_date": "2024-01-01T00:00:00Z"
        }
      ]
    }
  }
}
