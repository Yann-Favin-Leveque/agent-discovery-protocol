{
  "name": "managed_domain_update",
  "description": "Configure r2.dev domain access for a bucket.",
  "resource_group": "managed_domains",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/domains/managed",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "request_example": {
    "enabled": true
  }
}