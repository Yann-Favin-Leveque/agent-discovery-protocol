{
  "name": "buckets_create",
  "description": "Create a new R2 bucket.",
  "resource_group": "buckets",
  "endpoint": "/accounts/{account_id}/r2/buckets",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "request_example": {
    "name": "my-bucket",
    "locationHint": "wnam"
  },
  "response_example": {
    "success": true,
    "result": {
      "name": "my-bucket",
      "creation_date": "2024-01-01T00:00:00Z"
    }
  }
}
