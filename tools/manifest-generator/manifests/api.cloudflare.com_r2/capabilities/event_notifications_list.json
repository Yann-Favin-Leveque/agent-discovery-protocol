{
  "name": "event_notifications_list",
  "description": "List event notification rules for a bucket.",
  "resource_group": "event_notifications",
  "endpoint": "/accounts/{account_id}/event_notifications/r2/{bucket_name}/configuration",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}