{
  "name": "lock_put",
  "description": "Set lock policies for a bucket.",
  "resource_group": "locks",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/lock",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}