{
  "name": "custom_domains_create",
  "description": "Register a custom domain for a bucket.",
  "resource_group": "custom_domains",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/domains/custom",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier",
      "in": "path"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "request_example": {
    "domain": "cdn.example.com"
  }
}
