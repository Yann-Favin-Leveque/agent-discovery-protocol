{
  "name": "sippy_put",
  "description": "Configure Sippy migration for a bucket.",
  "resource_group": "sippy",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/sippy",
  "method": "PUT",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier",
      "in": "path"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
