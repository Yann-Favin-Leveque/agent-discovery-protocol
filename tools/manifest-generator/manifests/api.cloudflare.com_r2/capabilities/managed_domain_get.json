{
  "name": "managed_domain_get",
  "description": "Get state of r2.dev public access for a bucket.",
  "resource_group": "managed_domains",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}/domains/managed",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}