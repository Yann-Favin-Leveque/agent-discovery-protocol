{
  "name": "event_notifications_get",
  "description": "Get a specific event notification rule.",
  "resource_group": "event_notifications",
  "endpoint": "/accounts/{account_id}/event_notifications/r2/{bucket_name}/configuration/queues/{queue_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket"
    },
    {
      "name": "queue_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Queue identifier for notifications"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}