{
  "name": "temp_credentials_create",
  "description": "Create temporary access credentials for a bucket.",
  "resource_group": "temp_credentials",
  "endpoint": "/accounts/{account_id}/r2/temp-access-credentials",
  "method": "POST",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ],
  "request_example": {
    "bucket": "my-bucket",
    "parentAccessKeyId": "key-id",
    "permission": "object-read-write",
    "ttlSeconds": 3600
  }
}