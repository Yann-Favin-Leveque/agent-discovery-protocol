{
  "name": "buckets_update",
  "description": "Update properties of an R2 bucket.",
  "resource_group": "buckets",
  "endpoint": "/accounts/{account_id}/r2/buckets/{bucket_name}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "account_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Cloudflare account identifier",
      "in": "path"
    },
    {
      "name": "bucket_name",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "Name of the R2 bucket",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read",
    "write"
  ]
}
