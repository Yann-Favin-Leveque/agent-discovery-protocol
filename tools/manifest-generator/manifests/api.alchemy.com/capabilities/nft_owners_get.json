{
  "name": "nft_owners_get",
  "description": "Get the owner(s) of a specific NFT by contract address and token ID.",
  "endpoint": "/nft/v3/{apiKey}/getOwnersForNFT",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "contractAddress",
      "type": "string",
      "required": true,
      "description": "NFT contract address."
    },
    {
      "name": "tokenId",
      "type": "string",
      "required": true,
      "description": "Token ID of the NFT."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/getOwnersForNFT?contractAddress=0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D&tokenId=1234",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "owners": ["0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
