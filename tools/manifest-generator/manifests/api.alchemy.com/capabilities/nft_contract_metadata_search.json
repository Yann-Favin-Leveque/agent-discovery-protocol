{
  "name": "nft_contract_metadata_search",
  "description": "Search for NFT contracts by keyword across contract names and metadata. Useful for discovering collections.",
  "endpoint": "/nft/v3/{apiKey}/searchContractMetadata",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "Search keyword to match against contract names and metadata."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/searchContractMetadata?query=bored%20ape",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "contracts": [
        {
          "address": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D",
          "name": "BoredApeYachtClub",
          "symbol": "BAYC",
          "tokenType": "ERC721",
          "totalSupply": "10000"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
