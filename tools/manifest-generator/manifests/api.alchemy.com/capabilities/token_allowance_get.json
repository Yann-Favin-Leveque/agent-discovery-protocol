{
  "name": "token_allowance_get",
  "description": "Check the amount a spender is approved to withdraw from an owner's ERC-20 token balance.",
  "endpoint": "/v2/{apiKey}",
  "method": "POST",
  "resource_group": "token",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "JSON-RPC request ID."
    },
    {
      "name": "method",
      "type": "string",
      "required": true,
      "description": "Must be 'alchemy_getTokenAllowance'."
    },
    {
      "name": "params",
      "type": "array",
      "required": true,
      "description": "Array: [{contract, owner, spender}] - object with contract address, owner address, and spender address."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://eth-mainnet.g.alchemy.com/v2/{apiKey}",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "id": 1,
      "jsonrpc": "2.0",
      "method": "alchemy_getTokenAllowance",
      "params": [{
        "contract": "0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48",
        "owner": "0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045",
        "spender": "0x1111111254fb6c44bAC0beD2854e76F90643097d"
      }]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "jsonrpc": "2.0",
      "id": 1,
      "result": "1000000000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
