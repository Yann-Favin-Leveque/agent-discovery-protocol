{
  "name": "nft_holder_check",
  "description": "Check whether a wallet address holds any NFT from a specific collection. Useful for token-gating.",
  "endpoint": "/nft/v3/{apiKey}/isHolderOfContract",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter).",
      "in": "path"
    },
    {
      "name": "wallet",
      "type": "string",
      "required": true,
      "description": "Wallet address to check.",
      "in": "query"
    },
    {
      "name": "contractAddress",
      "type": "string",
      "required": true,
      "description": "NFT contract address to check ownership against.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/isHolderOfContract?wallet=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045&contractAddress=0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "isHolderOfContract": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
