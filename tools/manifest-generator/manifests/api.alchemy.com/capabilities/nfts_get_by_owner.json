{
  "name": "nfts_get_by_owner",
  "description": "Retrieve all NFTs owned by a specific wallet address across collections with metadata, images, and attributes. Supports pagination.",
  "endpoint": "/nft/v3/{apiKey}/getNFTsForOwner",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "description": "Wallet address to query NFTs for (query parameter).",
      "example": "0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"
    },
    {
      "name": "withMetadata",
      "type": "boolean",
      "required": false,
      "description": "Include full metadata for each NFT. Default true."
    },
    {
      "name": "pageKey",
      "type": "string",
      "required": false,
      "description": "Pagination key from a previous response."
    },
    {
      "name": "pageSize",
      "type": "integer",
      "required": false,
      "description": "Number of NFTs per page. Default 100."
    },
    {
      "name": "contractAddresses[]",
      "type": "array",
      "required": false,
      "description": "Filter by specific NFT contract addresses."
    },
    {
      "name": "excludeFilters[]",
      "type": "array",
      "required": false,
      "description": "Exclude NFTs matching filters: 'SPAM', 'AIRDROPS'."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/getNFTsForOwner?owner=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045&withMetadata=true&pageSize=10",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "ownedNfts": [
        {
          "contract": { "address": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D" },
          "tokenId": "1234",
          "tokenType": "ERC721",
          "name": "Bored Ape #1234",
          "image": { "cachedUrl": "https://res.cloudinary.com/alchemyapi/..." },
          "raw": { "metadata": { "attributes": [] } }
        }
      ],
      "totalCount": 42,
      "pageKey": "next_page_key_abc"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
