{
  "name": "nft_metadata_refresh",
  "description": "Trigger a metadata refresh for a specific NFT to update cached data from the token URI source.",
  "endpoint": "/nft/v3/{apiKey}/refreshNftMetadata",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter).",
      "in": "path"
    },
    {
      "name": "contractAddress",
      "type": "string",
      "required": true,
      "description": "NFT contract address.",
      "in": "query"
    },
    {
      "name": "tokenId",
      "type": "string",
      "required": true,
      "description": "Token ID to refresh metadata for.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/refreshNftMetadata?contractAddress=0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D&tokenId=1234",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 60
  }
}
