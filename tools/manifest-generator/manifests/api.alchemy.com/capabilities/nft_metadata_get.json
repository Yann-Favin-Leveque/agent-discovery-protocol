{
  "name": "nft_metadata_get",
  "description": "Fetch detailed metadata for a specific NFT by contract address and token ID, including name, description, image, and attributes.",
  "endpoint": "/nft/v3/{apiKey}/getNFTMetadata",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "contractAddress",
      "type": "string",
      "required": true,
      "description": "NFT contract address.",
      "example": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D"
    },
    {
      "name": "tokenId",
      "type": "string",
      "required": true,
      "description": "Token ID of the NFT."
    },
    {
      "name": "tokenType",
      "type": "string",
      "required": false,
      "description": "Token standard: 'ERC721' or 'ERC1155'."
    },
    {
      "name": "refreshCache",
      "type": "boolean",
      "required": false,
      "description": "Force refresh of cached metadata."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/getNFTMetadata?contractAddress=0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D&tokenId=1234",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "contract": { "address": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D", "name": "BoredApeYachtClub", "symbol": "BAYC", "tokenType": "ERC721" },
      "tokenId": "1234",
      "name": "Bored Ape #1234",
      "description": "A unique Bored Ape NFT",
      "image": { "cachedUrl": "https://res.cloudinary.com/alchemyapi/..." },
      "raw": { "metadata": { "attributes": [{ "trait_type": "Background", "value": "Orange" }] } }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
