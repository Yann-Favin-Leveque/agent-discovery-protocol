{
  "name": "nft_spam_contracts_get",
  "description": "Retrieve a list of NFT contracts that have been classified as spam by Alchemy's spam detection system.",
  "endpoint": "/nft/v3/{apiKey}/getSpamContracts",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter).",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/getSpamContracts",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "contractAddresses": [
        "0x000000000a42c2791eec307fff43f87ea9ce1533",
        "0x0000000000664ceffed39244a8312bD895470803"
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
