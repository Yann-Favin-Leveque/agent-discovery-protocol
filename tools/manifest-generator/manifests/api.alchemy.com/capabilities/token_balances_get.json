{
  "name": "token_balances_get",
  "description": "Get ERC-20 token balances for a wallet address, including all tokens the address has ever transacted with or a specified list of contracts.",
  "endpoint": "/v2/{apiKey}",
  "method": "POST",
  "resource_group": "token",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "JSON-RPC request ID."
    },
    {
      "name": "method",
      "type": "string",
      "required": true,
      "description": "Must be 'alchemy_getTokenBalances'."
    },
    {
      "name": "params",
      "type": "array",
      "required": true,
      "description": "Array: [address (string), tokenAddresses (array or 'DEFAULT_TOKENS')]."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://eth-mainnet.g.alchemy.com/v2/{apiKey}",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "id": 1,
      "jsonrpc": "2.0",
      "method": "alchemy_getTokenBalances",
      "params": ["0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045", "DEFAULT_TOKENS"]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "jsonrpc": "2.0",
      "id": 1,
      "result": {
        "address": "0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045",
        "tokenBalances": [
          {
            "contractAddress": "0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48",
            "tokenBalance": "0x00000000000000000000000000000000000000000000000000000000e8d4a510"
          }
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
