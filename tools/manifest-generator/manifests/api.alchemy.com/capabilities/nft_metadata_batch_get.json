{
  "name": "nft_metadata_batch_get",
  "description": "Retrieve metadata for multiple NFTs across different contracts in a single batch request. More efficient than individual queries.",
  "endpoint": "/nft/v3/{apiKey}/getNFTMetadataBatch",
  "method": "POST",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "tokens",
      "type": "array",
      "required": true,
      "description": "Array of objects with 'contractAddress' and 'tokenId' fields."
    },
    {
      "name": "refreshCache",
      "type": "boolean",
      "required": false,
      "description": "Force refresh of cached metadata for all tokens."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/getNFTMetadataBatch",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "tokens": [
        { "contractAddress": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D", "tokenId": "1234" },
        { "contractAddress": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D", "tokenId": "5678" }
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "nfts": [
        { "contract": { "address": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D" }, "tokenId": "1234", "name": "Bored Ape #1234" },
        { "contract": { "address": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D" }, "tokenId": "5678", "name": "Bored Ape #5678" }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
