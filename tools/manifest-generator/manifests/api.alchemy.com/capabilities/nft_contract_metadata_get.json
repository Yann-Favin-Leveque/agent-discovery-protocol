{
  "name": "nft_contract_metadata_get",
  "description": "Retrieve metadata for an NFT contract including name, symbol, total supply, token type, and deployer address.",
  "endpoint": "/nft/v3/{apiKey}/getContractMetadata",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "contractAddress",
      "type": "string",
      "required": true,
      "description": "NFT contract address."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/getContractMetadata?contractAddress=0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "address": "0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13D",
      "name": "BoredApeYachtClub",
      "symbol": "BAYC",
      "totalSupply": "10000",
      "tokenType": "ERC721",
      "contractDeployer": "0xabc...",
      "deployedBlockNumber": 12287507,
      "openSeaMetadata": {
        "floorPrice": 28.5,
        "collectionName": "Bored Ape Yacht Club"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
