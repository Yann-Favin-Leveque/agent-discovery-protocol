{
  "name": "nft_spam_check",
  "description": "Check whether a specific NFT contract is classified as spam.",
  "endpoint": "/nft/v3/{apiKey}/isSpamContract",
  "method": "GET",
  "resource_group": "nft",
  "parameters": [
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "description": "Your Alchemy API key (path parameter)."
    },
    {
      "name": "contractAddress",
      "type": "string",
      "required": true,
      "description": "NFT contract address to check."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://eth-mainnet.g.alchemy.com/nft/v3/{apiKey}/isSpamContract?contractAddress=0x000000000a42c2791eec307fff43f87ea9ce1533",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "isSpamContract": true
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 300
  }
}
