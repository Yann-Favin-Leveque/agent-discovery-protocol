{
  "name": "cycles_get",
  "description": "Get a specific cycle.",
  "resource_group": "cycles",
  "endpoint": "/graphql",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Cycle ID"
    }
  ],
  "auth_scopes": [
    "read",
    "write",
    "issues:create",
    "issues:write"
  ],
  "request_example": {
    "query": "{ cycle(id: \"cycle-id\") { id name number startsAt endsAt issues { nodes { id identifier title state { name } } } } }"
  }
}