{
  "name": "teams_get",
  "description": "Get a specific team.",
  "resource_group": "teams",
  "endpoint": "/graphql",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Team ID",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write",
    "issues:create",
    "issues:write"
  ],
  "request_example": {
    "query": "{ team(id: \"team-id\") { id name key members { nodes { id name email } } states { nodes { id name color type } } labels { nodes { id name color } } } }"
  }
}
