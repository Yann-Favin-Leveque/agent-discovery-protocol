{
  "name": "cycles_list",
  "description": "List cycles for a team.",
  "resource_group": "cycles",
  "endpoint": "/graphql",
  "method": "POST",
  "parameters": [
    {
      "name": "filter",
      "type": "object",
      "required": false,
      "location": "body",
      "description": "Filter by team, state, etc.",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write",
    "issues:create",
    "issues:write"
  ],
  "request_example": {
    "query": "{ cycles(first: 20) { nodes { id name number startsAt endsAt progress { scope completed } team { name } } } }"
  }
}
