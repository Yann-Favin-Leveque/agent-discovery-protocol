{
  "name": "comments_list",
  "description": "List comments on an issue.",
  "resource_group": "comments",
  "endpoint": "/graphql",
  "method": "POST",
  "parameters": [
    {
      "name": "issueId",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Issue ID",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write",
    "issues:create",
    "issues:write"
  ],
  "request_example": {
    "query": "{ issue(id: \"issue-id\") { comments { nodes { id body user { name } createdAt } } } }"
  }
}
