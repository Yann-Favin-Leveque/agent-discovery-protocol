{
  "name": "comments_update",
  "description": "Update a comment.",
  "resource_group": "comments",
  "endpoint": "/graphql",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Comment ID"
    },
    {
      "name": "body",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Updated body"
    }
  ],
  "auth_scopes": [
    "read",
    "write",
    "issues:create",
    "issues:write"
  ],
  "request_example": {
    "query": "mutation { commentUpdate(id: \"comment-id\", input: { body: \"Updated comment\" }) { success } }"
  }
}