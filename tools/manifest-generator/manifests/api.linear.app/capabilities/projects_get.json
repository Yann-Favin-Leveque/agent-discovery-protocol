{
  "name": "projects_get",
  "description": "Get a specific project.",
  "resource_group": "projects",
  "endpoint": "/graphql",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "location": "body",
      "description": "Project ID",
      "in": "body"
    }
  ],
  "auth_scopes": [
    "read",
    "write",
    "issues:create",
    "issues:write"
  ],
  "request_example": {
    "query": "{ project(id: \"project-id\") { id name description state lead { name } startDate targetDate progress issues { nodes { id identifier title } } } }"
  }
}
