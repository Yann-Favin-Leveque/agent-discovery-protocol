{
  "name": "orgs_list",
  "description": "List all organizations the authenticated user belongs to.",
  "resource_group": "organizations",
  "endpoint": "/rest/orgs",
  "method": "GET",
  "parameters": [
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "API version date (e.g., '2024-06-21')."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.snyk.io/rest/orgs?version=2024-06-21",
    "headers": {
      "Authorization": "token <api_token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "org-uuid",
          "type": "org",
          "attributes": {
            "name": "My Org",
            "slug": "my-org",
            "group": null,
            "is_personal": false
          }
        }
      ]
    }
  }
}