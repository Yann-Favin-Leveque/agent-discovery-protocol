{
  "name": "targets_get",
  "description": "Get details of a specific target.",
  "resource_group": "targets",
  "endpoint": "/rest/orgs/{org_id}/targets/{target_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "org_id",
      "type": "string",
      "required": true,
      "description": "Organization UUID."
    },
    {
      "name": "target_id",
      "type": "string",
      "required": true,
      "description": "Target UUID."
    },
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "API version date."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.snyk.io/rest/orgs/org-uuid/targets/target-uuid?version=2024-06-21",
    "headers": {
      "Authorization": "token <api_token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "target-uuid",
        "type": "target",
        "attributes": {
          "display_name": "my-org/my-repo",
          "origin": "github"
        }
      }
    }
  }
}