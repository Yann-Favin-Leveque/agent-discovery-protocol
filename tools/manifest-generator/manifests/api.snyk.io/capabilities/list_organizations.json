{
  "name": "list_organizations",
  "description": "List all Snyk organizations that the authenticated user has access to. Returns organization IDs, names, slugs, and group membership. Organization IDs are required as parameters for most other Snyk API calls, so this is typically the first call you should make when working with the Snyk API.",
  "endpoint": "/v1/orgs",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.snyk.io/v1/orgs",
    "headers": {
      "Authorization": "token snyk-api-token-here",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "orgs": [
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "name": "My Company",
          "slug": "my-company",
          "url": "https://app.snyk.io/org/my-company",
          "group": {
            "name": "My Group",
            "id": "g1a2b3c4-d5e6-7890-abcd-ef1234567890"
          }
        },
        {
          "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
          "name": "Personal Org",
          "slug": "personal-org",
          "url": "https://app.snyk.io/org/personal-org",
          "group": null
        }
      ]
    }
  }
}