{
  "name": "orgs_get",
  "description": "Get details of a specific organization.",
  "resource_group": "organizations",
  "endpoint": "/rest/orgs/{org_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "org_id",
      "type": "string",
      "required": true,
      "description": "Organization UUID.",
      "in": "path"
    },
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "API version date.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.snyk.io/rest/orgs/org-uuid?version=2024-06-21",
    "headers": {
      "Authorization": "token <api_token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "org-uuid",
        "type": "org",
        "attributes": {
          "name": "My Org",
          "slug": "my-org"
        }
      }
    }
  }
}
