{
  "name": "targets_delete",
  "description": "Delete a target and optionally its projects.",
  "resource_group": "targets",
  "endpoint": "/rest/orgs/{org_id}/targets/{target_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "org_id",
      "type": "string",
      "required": true,
      "description": "Organization UUID."
    },
    {
      "name": "target_id",
      "type": "string",
      "required": true,
      "description": "Target UUID."
    },
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "API version date."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.snyk.io/rest/orgs/org-uuid/targets/target-uuid?version=2024-06-21",
    "headers": {
      "Authorization": "token <api_token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}