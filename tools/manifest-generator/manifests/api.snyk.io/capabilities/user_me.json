{
  "name": "user_me",
  "description": "Get details of the currently authenticated user.",
  "resource_group": "users",
  "endpoint": "/rest/self",
  "method": "GET",
  "parameters": [
    {
      "name": "version",
      "type": "string",
      "required": true,
      "description": "API version date."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.snyk.io/rest/self?version=2024-06-21",
    "headers": {
      "Authorization": "token <api_token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "user-uuid",
        "type": "user",
        "attributes": {
          "name": "John Doe",
          "email": "john@example.com",
          "username": "johndoe"
        }
      }
    }
  }
}