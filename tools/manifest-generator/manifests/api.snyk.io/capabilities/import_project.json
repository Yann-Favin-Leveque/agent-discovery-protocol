{
  "name": "import_project",
  "description": "Import a repository or target for continuous vulnerability monitoring (v1 API).",
  "resource_group": "integrations",
  "endpoint": "/v1/org/{orgId}/integrations/{integrationId}/import",
  "method": "POST",
  "parameters": [
    {
      "name": "orgId",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    },
    {
      "name": "integrationId",
      "type": "string",
      "required": true,
      "description": "Integration ID.",
      "in": "path"
    },
    {
      "name": "target",
      "type": "object",
      "required": true,
      "description": "Target to import with owner and name.",
      "in": "body"
    },
    {
      "name": "files",
      "type": "array",
      "required": false,
      "description": "Specific files to test.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.snyk.io/v1/org/org-uuid/integrations/int-uuid/import",
    "headers": {
      "Authorization": "token <api_token>",
      "Content-Type": "application/json"
    },
    "body": {
      "target": {
        "owner": "my-org",
        "name": "my-repo",
        "branch": "main"
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "id": "import-job-uuid",
      "status": "pending"
    }
  }
}
