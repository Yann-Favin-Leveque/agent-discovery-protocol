{
  "name": "list_devices",
  "description": "List all devices under a specific user or across your entire Tuya cloud project. Returns each device's ID, name, category, online status, and product ID. Use this to discover what devices are available before controlling them.",
  "endpoint": "/v1.0/users/{uid}/devices",
  "method": "GET",
  "parameters": [
    {
      "name": "uid",
      "type": "string",
      "description": "The Tuya user ID whose devices to list.",
      "required": true,
      "example": "ay1622097346281rUjx9"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/users/ay1622097346281rUjx9/devices",
    "headers": {
      "client_id": "{client_id}",
      "access_token": "{access_token}",
      "sign": "{hmac_sha256_signature}",
      "sign_method": "HMAC-SHA256",
      "t": "1638360000000"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": [
        {
          "id": "bf12345abcdef67890",
          "name": "Living Room Light",
          "category": "dj",
          "online": true,
          "product_id": "abc123xyz",
          "sub": false,
          "time_zone": "-05:00"
        }
      ]
    }
  }
}
