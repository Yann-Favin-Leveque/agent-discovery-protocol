{
  "name": "devices_get_functions",
  "description": "Get available functions for a device.",
  "resource_group": "devices",
  "endpoint": "/v1.0/devices/{device_id}/functions",
  "method": "GET",
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/devices/dev_1/functions",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "functions": [
          {
            "code": "switch_led",
            "type": "Boolean"
          },
          {
            "code": "bright_value",
            "type": "Integer",
            "values": {
              "min": 0,
              "max": 255
            }
          }
        ]
      },
      "success": true
    }
  }
}
