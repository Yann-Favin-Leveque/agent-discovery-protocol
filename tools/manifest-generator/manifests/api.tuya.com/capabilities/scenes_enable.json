{
  "name": "scenes_enable",
  "description": "Enable or disable an automation.",
  "resource_group": "scenes",
  "endpoint": "/v1.0/iot-03/linkage-rules/{ruleId}/enabled",
  "method": "PUT",
  "parameters": [
    {
      "name": "ruleId",
      "type": "string",
      "description": "Rule ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "enabled",
      "type": "boolean",
      "description": "Enable or disable.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://openapi.tuyaus.com/v1.0/iot-03/linkage-rules/rule_1/enabled",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "enabled": false
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": true,
      "success": true
    }
  }
}
