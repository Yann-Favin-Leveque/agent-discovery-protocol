{
  "name": "devices_get",
  "description": "Get device details.",
  "resource_group": "devices",
  "endpoint": "/v1.0/devices/{device_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/devices/dev_1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "id": "dev_1",
        "name": "Light",
        "online": true,
        "category": "dj",
        "model": "AB-123",
        "time_zone": "+08:00"
      },
      "success": true
    }
  }
}
