{
  "name": "get_device_details",
  "description": "Get detailed metadata about a specific device including its name, model, icon URL, firmware version, category, time zone, activation time, and whether it is a sub-device of a gateway. Useful for inventory and troubleshooting.",
  "endpoint": "/v1.0/devices/{device_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "The unique ID of the device.",
      "required": true,
      "example": "bf12345abcdef67890"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/devices/bf12345abcdef67890",
    "headers": {
      "client_id": "{client_id}",
      "access_token": "{access_token}",
      "sign": "{hmac_sha256_signature}",
      "sign_method": "HMAC-SHA256",
      "t": "1638360000000"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "id": "bf12345abcdef67890",
        "name": "Living Room Light",
        "category": "dj",
        "product_id": "abc123xyz",
        "product_name": "Smart LED Bulb",
        "online": true,
        "sub": false,
        "time_zone": "-05:00",
        "active_time": 1622097346,
        "create_time": 1622097300,
        "icon": "https://images.tuyaus.com/smart/icon/abc123.png",
        "model": "SLB-100W"
      }
    }
  }
}
