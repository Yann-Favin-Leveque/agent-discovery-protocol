{
  "name": "scenes_update",
  "description": "Update an automation scene.",
  "resource_group": "scenes",
  "endpoint": "/v1.0/iot-03/linkage-rules/{ruleId}",
  "method": "PUT",
  "parameters": [
    {
      "name": "ruleId",
      "type": "string",
      "description": "Rule ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://openapi.tuyaus.com/v1.0/iot-03/linkage-rules/rule_1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Night Mode"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": true,
      "success": true
    }
  }
}
