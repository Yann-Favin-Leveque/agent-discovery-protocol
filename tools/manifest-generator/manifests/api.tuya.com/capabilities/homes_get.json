{
  "name": "homes_get",
  "description": "Get home details.",
  "resource_group": "homes",
  "endpoint": "/v1.0/homes/{home_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "home_id",
      "type": "integer",
      "description": "Home ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/homes/1",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "home_id": 1,
        "name": "My Home",
        "rooms": [
          {
            "room_id": 1,
            "name": "Living Room"
          }
        ]
      },
      "success": true
    }
  }
}
