{
  "name": "homes_create",
  "description": "Create a new home.",
  "resource_group": "homes",
  "endpoint": "/v1.0/home/create-home",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Home name.",
      "required": true,
      "in": "body"
    },
    {
      "name": "geo_name",
      "type": "string",
      "description": "Location name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "lat",
      "type": "number",
      "description": "Latitude.",
      "required": false,
      "in": "body"
    },
    {
      "name": "lon",
      "type": "number",
      "description": "Longitude.",
      "required": false,
      "in": "body"
    },
    {
      "name": "rooms",
      "type": "array",
      "description": "Room names.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://openapi.tuyaus.com/v1.0/home/create-home",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "My Home",
      "geo_name": "San Francisco",
      "rooms": [
        "Living Room",
        "Bedroom"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "home_id": 2
      },
      "success": true
    }
  }
}
