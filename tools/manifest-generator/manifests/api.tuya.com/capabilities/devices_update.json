{
  "name": "devices_update",
  "description": "Modify device properties.",
  "resource_group": "devices",
  "endpoint": "/v1.0/devices/{device_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "Device ID.",
      "required": true
    },
    {
      "name": "name",
      "type": "string",
      "description": "New device name.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://openapi.tuyaus.com/v1.0/devices/dev_1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Living Room Light"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": true,
      "success": true
    }
  }
}