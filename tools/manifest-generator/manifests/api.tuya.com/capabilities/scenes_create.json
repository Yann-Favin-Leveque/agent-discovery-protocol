{
  "name": "scenes_create",
  "description": "Create a new automation scene.",
  "resource_group": "scenes",
  "endpoint": "/v1.0/iot-03/linkage-rules",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Scene name.",
      "required": true,
      "in": "body"
    },
    {
      "name": "conditions",
      "type": "array",
      "description": "Trigger conditions.",
      "required": true,
      "in": "body"
    },
    {
      "name": "actions",
      "type": "array",
      "description": "Actions to execute.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://openapi.tuyaus.com/v1.0/iot-03/linkage-rules",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Night Mode",
      "conditions": [],
      "actions": []
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "id": "rule_2"
      },
      "success": true
    }
  }
}
