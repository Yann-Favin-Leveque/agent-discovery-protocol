{
  "name": "homes_update",
  "description": "Update home properties.",
  "resource_group": "homes",
  "endpoint": "/v1.0/homes/{home_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "home_id",
      "type": "integer",
      "description": "Home ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "geo_name",
      "type": "string",
      "description": "Updated location.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://openapi.tuyaus.com/v1.0/homes/1",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Home"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": true,
      "success": true
    }
  }
}
