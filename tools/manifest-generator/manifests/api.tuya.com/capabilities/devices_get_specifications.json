{
  "name": "devices_get_specifications",
  "description": "Get device specifications and data model.",
  "resource_group": "devices",
  "endpoint": "/v1.0/devices/{device_id}/specifications",
  "method": "GET",
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "Device ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/devices/dev_1/specifications",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "category": "dj",
        "functions": [
          {
            "code": "switch_led",
            "type": "Boolean"
          }
        ],
        "status": [
          {
            "code": "switch_led",
            "type": "Boolean"
          }
        ]
      },
      "success": true
    }
  }
}
