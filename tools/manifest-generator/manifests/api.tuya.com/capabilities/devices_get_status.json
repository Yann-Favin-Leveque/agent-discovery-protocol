{
  "name": "devices_get_status",
  "description": "Get device status/data points.",
  "resource_group": "devices",
  "endpoint": "/v1.0/devices/{device_id}/status",
  "method": "GET",
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "Device ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/devices/dev_1/status",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": [
        {
          "code": "switch_led",
          "value": true
        },
        {
          "code": "bright_value",
          "value": 255
        }
      ],
      "success": true
    }
  }
}