{
  "name": "devices_list",
  "description": "List all devices.",
  "resource_group": "devices",
  "endpoint": "/v1.0/iot-03/devices",
  "method": "GET",
  "parameters": [
    {
      "name": "page_no",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 1
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Page size.",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://openapi.tuyaus.com/v1.0/iot-03/devices?page_no=1&page_size=20",
    "headers": {
      "Authorization": "Bearer {access_token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "list": [
          {
            "id": "dev_1",
            "name": "Light",
            "online": true,
            "category": "dj"
          }
        ],
        "total": 5
      },
      "success": true
    }
  }
}