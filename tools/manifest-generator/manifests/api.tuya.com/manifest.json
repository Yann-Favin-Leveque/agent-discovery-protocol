{
  "spec_version": "1.0",
  "name": "Tuya",
  "description": "Tuya is a global IoT cloud platform for smart home and commercial devices. Control devices, query status, manage users, homes, and create automation scenes across thousands of device categories.",
  "base_url": "https://openapi.tuyaus.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer",
    "setup_url": "https://platform.tuya.com/cloud"
  },
  "capabilities": [
    {
      "name": "devices_list",
      "resource_group": "devices",
      "description": "List all devices in your project.",
      "detail_url": "/capabilities/devices_list"
    },
    {
      "name": "devices_get",
      "resource_group": "devices",
      "description": "Get device details by ID.",
      "detail_url": "/capabilities/devices_get"
    },
    {
      "name": "devices_get_status",
      "resource_group": "devices",
      "description": "Get current status/data points of a device.",
      "detail_url": "/capabilities/devices_get_status"
    },
    {
      "name": "devices_send_commands",
      "resource_group": "devices",
      "description": "Send control commands to a device.",
      "detail_url": "/capabilities/devices_send_commands"
    },
    {
      "name": "devices_get_functions",
      "resource_group": "devices",
      "description": "Get available instruction set for a device.",
      "detail_url": "/capabilities/devices_get_functions"
    },
    {
      "name": "devices_get_specifications",
      "resource_group": "devices",
      "description": "Get device specifications and data model.",
      "detail_url": "/capabilities/devices_get_specifications"
    },
    {
      "name": "devices_get_logs",
      "resource_group": "devices",
      "description": "Get historical status change logs.",
      "detail_url": "/capabilities/devices_get_logs"
    },
    {
      "name": "devices_update",
      "resource_group": "devices",
      "description": "Modify device basic properties (name, etc.).",
      "detail_url": "/capabilities/devices_update"
    },
    {
      "name": "devices_delete",
      "resource_group": "devices",
      "description": "Delete a device.",
      "detail_url": "/capabilities/devices_delete"
    },
    {
      "name": "devices_freeze",
      "resource_group": "devices",
      "description": "Freeze a device.",
      "detail_url": "/capabilities/devices_freeze"
    },
    {
      "name": "devices_unfreeze",
      "resource_group": "devices",
      "description": "Unfreeze a device.",
      "detail_url": "/capabilities/devices_unfreeze"
    },
    {
      "name": "scenes_list",
      "resource_group": "scenes",
      "description": "List all automation scenes/linkage rules.",
      "detail_url": "/capabilities/scenes_list"
    },
    {
      "name": "scenes_get",
      "resource_group": "scenes",
      "description": "Get scene details by ID.",
      "detail_url": "/capabilities/scenes_get"
    },
    {
      "name": "scenes_create",
      "resource_group": "scenes",
      "description": "Create a new automation scene.",
      "detail_url": "/capabilities/scenes_create"
    },
    {
      "name": "scenes_update",
      "resource_group": "scenes",
      "description": "Update an automation scene.",
      "detail_url": "/capabilities/scenes_update"
    },
    {
      "name": "scenes_delete",
      "resource_group": "scenes",
      "description": "Delete a scene.",
      "detail_url": "/capabilities/scenes_delete"
    },
    {
      "name": "scenes_trigger",
      "resource_group": "scenes",
      "description": "Trigger a tap-to-run scene.",
      "detail_url": "/capabilities/scenes_trigger"
    },
    {
      "name": "scenes_enable",
      "resource_group": "scenes",
      "description": "Enable or disable an automation scene.",
      "detail_url": "/capabilities/scenes_enable"
    },
    {
      "name": "homes_list",
      "resource_group": "homes",
      "description": "List all homes.",
      "detail_url": "/capabilities/homes_list"
    },
    {
      "name": "homes_get",
      "resource_group": "homes",
      "description": "Get home details.",
      "detail_url": "/capabilities/homes_get"
    },
    {
      "name": "homes_create",
      "resource_group": "homes",
      "description": "Create a new home.",
      "detail_url": "/capabilities/homes_create"
    },
    {
      "name": "homes_update",
      "resource_group": "homes",
      "description": "Update home properties.",
      "detail_url": "/capabilities/homes_update"
    },
    {
      "name": "homes_delete",
      "resource_group": "homes",
      "description": "Delete a home.",
      "detail_url": "/capabilities/homes_delete"
    }
  ]
}