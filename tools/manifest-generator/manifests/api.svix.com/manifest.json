{
  "spec_version": "1.0",
  "name": "Svix",
  "description": "Webhooks-as-a-service platform for reliable webhook delivery. Manage applications, endpoints, messages, and message delivery attempts programmatically.",
  "base_url": "https://api.svix.com",
  "auth": {
    "type": "api_key",
    "header": "Authorization",
    "prefix": "Bearer"
  },
  "capabilities": [
    {
      "name": "application_list",
      "description": "List all webhook applications with pagination.",
      "detail_url": "/capabilities/application_list",
      "resource_group": "application"
    },
    {
      "name": "application_create",
      "description": "Create a new webhook application.",
      "detail_url": "/capabilities/application_create",
      "resource_group": "application"
    },
    {
      "name": "application_get",
      "description": "Retrieve a specific application by ID.",
      "detail_url": "/capabilities/application_get",
      "resource_group": "application"
    },
    {
      "name": "application_update",
      "description": "Update an existing application.",
      "detail_url": "/capabilities/application_update",
      "resource_group": "application"
    },
    {
      "name": "application_patch",
      "description": "Partially update an application.",
      "detail_url": "/capabilities/application_patch",
      "resource_group": "application"
    },
    {
      "name": "application_delete",
      "description": "Delete an application.",
      "detail_url": "/capabilities/application_delete",
      "resource_group": "application"
    },
    {
      "name": "endpoint_list",
      "description": "List all endpoints for an application.",
      "detail_url": "/capabilities/endpoint_list",
      "resource_group": "endpoint"
    },
    {
      "name": "endpoint_create",
      "description": "Create a new webhook endpoint for an application.",
      "detail_url": "/capabilities/endpoint_create",
      "resource_group": "endpoint"
    },
    {
      "name": "endpoint_get",
      "description": "Retrieve a specific endpoint.",
      "detail_url": "/capabilities/endpoint_get",
      "resource_group": "endpoint"
    },
    {
      "name": "endpoint_update",
      "description": "Update an existing endpoint.",
      "detail_url": "/capabilities/endpoint_update",
      "resource_group": "endpoint"
    },
    {
      "name": "endpoint_patch",
      "description": "Partially update an endpoint.",
      "detail_url": "/capabilities/endpoint_patch",
      "resource_group": "endpoint"
    },
    {
      "name": "endpoint_delete",
      "description": "Delete an endpoint.",
      "detail_url": "/capabilities/endpoint_delete",
      "resource_group": "endpoint"
    },
    {
      "name": "message_list",
      "description": "List all messages for an application.",
      "detail_url": "/capabilities/message_list",
      "resource_group": "message"
    },
    {
      "name": "message_create",
      "description": "Create and send a new webhook message.",
      "detail_url": "/capabilities/message_create",
      "resource_group": "message"
    },
    {
      "name": "message_get",
      "description": "Retrieve a specific message by ID.",
      "detail_url": "/capabilities/message_get",
      "resource_group": "message"
    },
    {
      "name": "event_type_list",
      "description": "List all event types.",
      "detail_url": "/capabilities/event_type_list",
      "resource_group": "event_type"
    },
    {
      "name": "event_type_create",
      "description": "Create a new event type.",
      "detail_url": "/capabilities/event_type_create",
      "resource_group": "event_type"
    },
    {
      "name": "event_type_get",
      "description": "Retrieve a specific event type.",
      "detail_url": "/capabilities/event_type_get",
      "resource_group": "event_type"
    },
    {
      "name": "event_type_update",
      "description": "Update an event type.",
      "detail_url": "/capabilities/event_type_update",
      "resource_group": "event_type"
    },
    {
      "name": "event_type_delete",
      "description": "Delete an event type.",
      "detail_url": "/capabilities/event_type_delete",
      "resource_group": "event_type"
    },
    {
      "name": "attempt_list_by_endpoint",
      "description": "List delivery attempts for a specific endpoint.",
      "detail_url": "/capabilities/attempt_list_by_endpoint",
      "resource_group": "attempt"
    },
    {
      "name": "attempt_list_by_message",
      "description": "List delivery attempts for a specific message.",
      "detail_url": "/capabilities/attempt_list_by_message",
      "resource_group": "attempt"
    },
    {
      "name": "endpoint_replay_missing",
      "description": "Replay missing webhook messages to an endpoint.",
      "detail_url": "/capabilities/endpoint_replay_missing",
      "resource_group": "endpoint"
    }
  ]
}