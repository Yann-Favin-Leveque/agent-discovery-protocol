{
  "name": "application_list",
  "description": "List all webhook applications with pagination and optional filtering.",
  "resource_group": "application",
  "endpoint": "/api/v1/app",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results (default 50).",
      "required": false,
      "example": 50,
      "in": "query"
    },
    {
      "name": "iterator",
      "type": "string",
      "description": "Pagination cursor from previous response.",
      "required": false,
      "in": "query"
    },
    {
      "name": "order",
      "type": "string",
      "description": "Sort order: ascending or descending.",
      "required": false,
      "example": "descending",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.svix.com/api/v1/app?limit=10",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "uid": "app_123",
          "name": "My App",
          "createdAt": "2024-01-01T00:00:00Z"
        }
      ],
      "iterator": "next_cursor",
      "done": false
    }
  }
}
