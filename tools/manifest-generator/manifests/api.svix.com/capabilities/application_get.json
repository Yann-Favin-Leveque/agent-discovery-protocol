{
  "name": "application_get",
  "description": "Retrieve a specific application by its ID or UID.",
  "resource_group": "application",
  "endpoint": "/api/v1/app/{app_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Application ID or UID (path parameter).",
      "required": true,
      "example": "app_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.svix.com/api/v1/app/app_123",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "app_abc123",
      "uid": "app_123",
      "name": "My Webhook App",
      "createdAt": "2024-01-01T00:00:00Z"
    }
  }
}