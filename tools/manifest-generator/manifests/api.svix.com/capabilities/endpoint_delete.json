{
  "name": "endpoint_delete",
  "description": "Delete a webhook endpoint.",
  "resource_group": "endpoint",
  "endpoint": "/api/v1/app/{app_id}/endpoint/{endpoint_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Application ID or UID (path parameter).",
      "required": true,
      "example": "app_123",
      "in": "path"
    },
    {
      "name": "endpoint_id",
      "type": "string",
      "description": "Endpoint ID or UID (path parameter).",
      "required": true,
      "example": "ep_abc",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.svix.com/api/v1/app/app_123/endpoint/ep_abc",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
