{
  "name": "endpoint_get",
  "description": "Retrieve a specific endpoint by ID.",
  "resource_group": "endpoint",
  "endpoint": "/api/v1/app/{app_id}/endpoint/{endpoint_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Application ID or UID (path parameter).",
      "required": true,
      "example": "app_123"
    },
    {
      "name": "endpoint_id",
      "type": "string",
      "description": "Endpoint ID or UID (path parameter).",
      "required": true,
      "example": "ep_abc"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.svix.com/api/v1/app/app_123/endpoint/ep_abc",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ep_abc",
      "url": "https://example.com/webhook",
      "description": "Production webhook",
      "disabled": false
    }
  }
}