{
  "name": "event_type_list",
  "description": "List all registered event types.",
  "resource_group": "event_type",
  "endpoint": "/api/v1/event-type",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "example": 50,
      "in": "query"
    },
    {
      "name": "iterator",
      "type": "string",
      "description": "Pagination cursor.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.svix.com/api/v1/event-type?limit=10",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "name": "user.created",
          "description": "A new user was created"
        }
      ],
      "done": true
    }
  }
}
