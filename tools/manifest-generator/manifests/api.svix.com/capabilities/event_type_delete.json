{
  "name": "event_type_delete",
  "description": "Delete an event type by name.",
  "resource_group": "event_type",
  "endpoint": "/api/v1/event-type/{event_type_name}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "event_type_name",
      "type": "string",
      "description": "Event type name (path parameter).",
      "required": true,
      "example": "user.created",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.svix.com/api/v1/event-type/user.created",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}
