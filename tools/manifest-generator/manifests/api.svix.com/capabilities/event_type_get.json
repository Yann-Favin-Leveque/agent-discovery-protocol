{
  "name": "event_type_get",
  "description": "Retrieve a specific event type by name.",
  "resource_group": "event_type",
  "endpoint": "/api/v1/event-type/{event_type_name}",
  "method": "GET",
  "parameters": [
    {
      "name": "event_type_name",
      "type": "string",
      "description": "Event type name (path parameter).",
      "required": true,
      "example": "user.created"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.svix.com/api/v1/event-type/user.created",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "name": "user.created",
      "description": "Fired when a new user is created"
    }
  }
}