{
  "name": "application_patch",
  "description": "Partially update an application.",
  "resource_group": "application",
  "endpoint": "/api/v1/app/{app_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Application ID or UID (path parameter).",
      "required": true,
      "example": "app_123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Application name.",
      "required": false,
      "example": "Patched App",
      "in": "body"
    },
    {
      "name": "rateLimit",
      "type": "integer",
      "description": "Rate limit.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.svix.com/api/v1/app/app_123",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Patched App"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "app_abc123",
      "uid": "app_123",
      "name": "Patched App"
    }
  }
}
