{
  "name": "application_delete",
  "description": "Delete an application and all its endpoints and messages.",
  "resource_group": "application",
  "endpoint": "/api/v1/app/{app_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "app_id",
      "type": "string",
      "description": "Application ID or UID (path parameter).",
      "required": true,
      "example": "app_123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.svix.com/api/v1/app/app_123",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  }
}