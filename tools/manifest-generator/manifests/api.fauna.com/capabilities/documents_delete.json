{
  "name": "documents_delete",
  "description": "Delete a document from a collection by its ID. Returns the deleted document data.",
  "endpoint": "/query/1",
  "method": "POST",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "FQL query to delete a document. Use Collection.byId('id')!.delete() syntax.",
      "required": true,
      "example": "Product.byId('394508947012837376')!.delete()",
      "in": "body"
    },
    {
      "name": "arguments",
      "type": "object",
      "description": "Named arguments for the query.",
      "required": false,
      "example": {},
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://db.fauna.com/query/1",
    "headers": {
      "Authorization": "Bearer fn_your_secret_key",
      "Content-Type": "application/json",
      "X-Format": "simple"
    },
    "body": {
      "query": "Product.byId('394508947012837376')!.delete()"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "394508947012837376",
        "coll": "Product",
        "ts": "2024-09-01T10:00:00.000Z",
        "name": "Widget",
        "price": 9.99,
        "quantity": 100
      },
      "txn_ts": 1693563600000000,
      "stats": {
        "compute_ops": 1,
        "read_ops": 1,
        "write_ops": 1
      }
    }
  },
  "auth_scopes": [
    "server",
    "admin"
  ],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
