{
  "name": "documents_create",
  "description": "Create a new document in a collection by executing an FQL create query. Fauna assigns a unique ID and tracks timestamps.",
  "endpoint": "/query/1",
  "method": "POST",
  "resource_group": "documents",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "FQL query to create a document. Use Collection.create({...}) syntax.",
      "required": true,
      "example": "Product.create({ name: 'Widget', price: 9.99, quantity: 100 })"
    },
    {
      "name": "arguments",
      "type": "object",
      "description": "Named arguments to pass as variables into the create query.",
      "required": false,
      "example": {}
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://db.fauna.com/query/1",
    "headers": {
      "Authorization": "Bearer fn_your_secret_key",
      "Content-Type": "application/json",
      "X-Format": "simple"
    },
    "body": {
      "query": "Product.create({ name: 'Widget', price: 9.99, quantity: 100 })"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": "394508947012837376",
        "coll": "Product",
        "ts": "2024-09-01T10:00:00.000Z",
        "name": "Widget",
        "price": 9.99,
        "quantity": 100
      },
      "txn_ts": 1693560000000000,
      "stats": {
        "compute_ops": 1,
        "read_ops": 0,
        "write_ops": 1
      }
    }
  },
  "auth_scopes": ["server", "admin"],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
