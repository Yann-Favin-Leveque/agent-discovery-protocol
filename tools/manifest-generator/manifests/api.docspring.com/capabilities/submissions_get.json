{
  "name": "submissions_get",
  "description": "Check the status and details of a PDF generation submission. Use this to poll for completion of asynchronous submissions.",
  "resource_group": "submissions",
  "endpoint": "/api/v1/submissions/{submission_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "submission_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The unique submission ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.docspring.com/api/v1/submissions/sub_xyz789",
    "headers": {
      "Authorization": "Basic {base64(token_id:token_secret)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sub_xyz789",
      "state": "processed",
      "download_url": "https://api.docspring.com/submissions/sub_xyz789/download",
      "permanent_download_url": "https://api.docspring.com/submissions/sub_xyz789/permanent_download",
      "template_id": "tpl_abc123",
      "test": false,
      "expires_at": "2026-03-08T12:00:00.000Z",
      "metadata": {
        "pdf_filename": "invoice-001.pdf"
      }
    }
  }
}
