{
  "name": "list_templates",
  "description": "List all PDF templates in your DocSpring account. Each template includes its ID, name, description, field definitions (name, type, required), and metadata. Use this to discover available templates before generating PDFs. You need the template_id from this response to call generate_pdf.",
  "endpoint": "/api/v1/templates",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number for pagination. Starts at 1. Default is 1."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Number of templates per page. Default is 10, maximum is 100."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.docspring.com/api/v1/templates?page=1&per_page=10",
    "headers": {
      "Authorization": "Basic dG9rZW5faWQ6dG9rZW5fc2VjcmV0"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "tpl_abc123XYZ",
        "name": "Invoice Template",
        "description": "Standard company invoice",
        "public_web_form": false,
        "public_submissions": false,
        "template_type": "pdf",
        "page_count": 1,
        "fields": [
          {
            "name": "invoice_number",
            "type": "string",
            "required": true
          },
          {
            "name": "customer_name",
            "type": "string",
            "required": true
          },
          {
            "name": "total_amount",
            "type": "number",
            "required": true
          },
          {
            "name": "due_date",
            "type": "date",
            "required": false
          }
        ]
      }
    ]
  }
}
