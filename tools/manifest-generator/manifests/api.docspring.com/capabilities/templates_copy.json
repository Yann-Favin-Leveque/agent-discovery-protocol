{
  "name": "templates_copy",
  "description": "Create a copy of an existing template. Can copy the draft version (default) or a specific published version.",
  "resource_group": "templates",
  "endpoint": "/api/v1/templates/{template_id}/copy",
  "method": "POST",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The ID of the template to copy.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://sync.api.docspring.com/api/v1/templates/tpl_abc123/copy",
    "headers": {
      "Authorization": "Basic {base64(token_id:token_secret)}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "tpl_copy456",
      "name": "Invoice Template (Copy)",
      "status": "active",
      "parent_id": "tpl_abc123",
      "created_at": "2026-03-01T14:00:00.000Z"
    }
  }
}
