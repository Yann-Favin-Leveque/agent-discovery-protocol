{
  "name": "dns_records_create",
  "description": "Create a new DNS record in a zone. Supports A, AAAA, CNAME, MX, TXT, NS, SRV, CAA, and other record types.",
  "endpoint": "/zones/{zone_id}/dns_records",
  "method": "POST",
  "resource_group": "dns_records",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "description": "The zone ID.",
      "required": true,
      "example": "023e105f4ecef8ad9ca31a8372d0c353",
      "in": "path"
    },
    {
      "name": "type",
      "type": "string",
      "description": "DNS record type: A, AAAA, CNAME, MX, TXT, NS, SRV, CAA, etc.",
      "required": true,
      "example": "A",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "description": "DNS record name (e.g., example.com or subdomain.example.com). Use @ for root.",
      "required": true,
      "example": "www.example.com",
      "in": "body"
    },
    {
      "name": "content",
      "type": "string",
      "description": "Record content (e.g., IP address for A/AAAA, hostname for CNAME).",
      "required": true,
      "example": "198.51.100.4",
      "in": "body"
    },
    {
      "name": "ttl",
      "type": "integer",
      "description": "TTL in seconds. Use 1 for automatic.",
      "required": false,
      "example": 1,
      "in": "body"
    },
    {
      "name": "proxied",
      "type": "boolean",
      "description": "Whether to proxy traffic through Cloudflare.",
      "required": false,
      "example": true,
      "in": "body"
    },
    {
      "name": "priority",
      "type": "integer",
      "description": "Priority for MX and SRV records.",
      "required": false,
      "example": 10,
      "in": "body"
    },
    {
      "name": "comment",
      "type": "string",
      "description": "Comment about the DNS record.",
      "required": false,
      "example": "Web server",
      "in": "body"
    },
    {
      "name": "tags",
      "type": "array",
      "description": "Tags for the DNS record.",
      "required": false,
      "example": [
        "production"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dns_records",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "type": "A",
      "name": "www.example.com",
      "content": "198.51.100.4",
      "ttl": 1,
      "proxied": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "id": "372e67954025e0ba6aaa6d586b9e0b59",
        "type": "A",
        "name": "www.example.com",
        "content": "198.51.100.4",
        "proxied": true,
        "ttl": 1
      }
    }
  },
  "auth_scopes": [
    "dns_records:edit"
  ],
  "rate_limits": {
    "requests_per_minute": 1200
  }
}
