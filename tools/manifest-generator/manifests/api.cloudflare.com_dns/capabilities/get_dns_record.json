{
  "name": "get_dns_record",
  "description": "Retrieve details of a specific DNS record by its ID. Returns the full record configuration including type, name, content, TTL, and proxy status.",
  "endpoint": "/zones/{zone_id}/dns_records/{dns_record_id}",
  "method": "GET",
  "parameters": [
    { "name": "zone_id", "type": "string", "description": "The zone identifier.", "required": true, "example": "023e105f4ecef8ad9ca31a8372d0c353" },
    { "name": "dns_record_id", "type": "string", "description": "The DNS record identifier.", "required": true, "example": "372e67954025e0ba6aaa6d586b9e0b59" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dns_records/372e67954025e0ba6aaa6d586b9e0b59",
    "headers": { "Authorization": "Bearer {api_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": { "id": "372e67954025e0ba6aaa6d586b9e0b59", "type": "A", "name": "example.com", "content": "198.51.100.4", "proxied": true, "ttl": 1, "created_on": "2024-01-15T10:00:00Z", "modified_on": "2024-01-15T10:00:00Z" }
    }
  }
}
