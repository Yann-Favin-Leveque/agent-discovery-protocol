{
  "name": "dnssec_delete",
  "description": "Delete DNSSEC configuration for a zone. Removes all signing keys and disables DNSSEC.",
  "endpoint": "/zones/{zone_id}/dnssec",
  "method": "DELETE",
  "resource_group": "dnssec",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "description": "The zone ID.",
      "required": true,
      "example": "023e105f4ecef8ad9ca31a8372d0c353",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dnssec",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": ""
    }
  },
  "auth_scopes": [
    "dns_records:edit"
  ],
  "rate_limits": {
    "requests_per_minute": 1200
  }
}
