{
  "name": "dns_records_delete",
  "description": "Delete a DNS record from a zone by its record ID.",
  "endpoint": "/zones/{zone_id}/dns_records/{dns_record_id}",
  "method": "DELETE",
  "resource_group": "dns_records",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "description": "The zone ID.",
      "required": true,
      "example": "023e105f4ecef8ad9ca31a8372d0c353"
    },
    {
      "name": "dns_record_id",
      "type": "string",
      "description": "The DNS record ID to delete.",
      "required": true,
      "example": "372e67954025e0ba6aaa6d586b9e0b59"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dns_records/372e67954025e0ba6aaa6d586b9e0b59",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "id": "372e67954025e0ba6aaa6d586b9e0b59"
      }
    }
  },
  "auth_scopes": ["dns_records:edit"],
  "rate_limits": {
    "requests_per_minute": 1200
  }
}