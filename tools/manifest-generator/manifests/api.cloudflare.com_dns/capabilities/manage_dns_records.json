{
  "name": "manage_dns_records",
  "description": "List, search, sort, and filter DNS records for a zone. Supports filtering by record type, name, content, and proxy status.",
  "endpoint": "/zones/{zone_id}/dns_records",
  "method": "GET",
  "parameters": [
    { "name": "zone_id", "type": "string", "description": "The zone identifier.", "required": true, "example": "023e105f4ecef8ad9ca31a8372d0c353" },
    { "name": "type", "type": "string", "description": "Filter by record type (A, AAAA, CNAME, MX, TXT, etc.).", "required": false, "example": "A" },
    { "name": "name", "type": "string", "description": "Filter by record name.", "required": false, "example": "example.com" },
    { "name": "content", "type": "string", "description": "Filter by record content/value.", "required": false, "example": "1.2.3.4" },
    { "name": "proxied", "type": "boolean", "description": "Filter by Cloudflare proxy status.", "required": false, "example": true },
    { "name": "per_page", "type": "number", "description": "Results per page (max 5000).", "required": false, "example": 100 },
    { "name": "page", "type": "number", "description": "Page number.", "required": false, "example": 1 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dns_records?type=A",
    "headers": { "Authorization": "Bearer {api_token}", "Content-Type": "application/json" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": [
        { "id": "372e67954025e0ba6aaa6d586b9e0b59", "type": "A", "name": "example.com", "content": "198.51.100.4", "proxied": true, "ttl": 1 }
      ],
      "result_info": { "page": 1, "per_page": 100, "total_count": 1 }
    }
  }
}
