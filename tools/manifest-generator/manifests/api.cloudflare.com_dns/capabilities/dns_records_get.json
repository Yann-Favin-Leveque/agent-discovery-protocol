{
  "name": "dns_records_get",
  "description": "Retrieve details of a specific DNS record by its ID including type, name, content, TTL, and proxy status.",
  "endpoint": "/zones/{zone_id}/dns_records/{dns_record_id}",
  "method": "GET",
  "resource_group": "dns_records",
  "parameters": [
    {
      "name": "zone_id",
      "type": "string",
      "description": "The zone ID.",
      "required": true,
      "example": "023e105f4ecef8ad9ca31a8372d0c353"
    },
    {
      "name": "dns_record_id",
      "type": "string",
      "description": "The DNS record ID.",
      "required": true,
      "example": "372e67954025e0ba6aaa6d586b9e0b59"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dns_records/372e67954025e0ba6aaa6d586b9e0b59",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "id": "372e67954025e0ba6aaa6d586b9e0b59",
        "type": "A",
        "name": "example.com",
        "content": "198.51.100.4",
        "proxied": true,
        "ttl": 1,
        "proxiable": true,
        "created_on": "2024-01-01T00:00:00Z",
        "modified_on": "2024-01-10T00:00:00Z"
      }
    }
  },
  "auth_scopes": ["dns_records:read"],
  "rate_limits": {
    "requests_per_minute": 1200
  }
}