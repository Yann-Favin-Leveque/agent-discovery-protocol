{
  "name": "manage_dnssec",
  "description": "Enable, disable, and configure DNSSEC for a zone. DNSSEC adds cryptographic signatures to DNS records to prevent DNS spoofing and cache poisoning.",
  "endpoint": "/zones/{zone_id}/dnssec",
  "method": "GET",
  "parameters": [
    { "name": "zone_id", "type": "string", "description": "The zone identifier.", "required": true, "example": "023e105f4ecef8ad9ca31a8372d0c353" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dnssec",
    "headers": { "Authorization": "Bearer {api_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": { "status": "active", "algorithm": "13", "digest": "abc123...", "ds": "example.com. 3600 IN DS 2371 13 2 abc123..." }
    }
  }
}
