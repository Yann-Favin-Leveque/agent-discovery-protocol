{
  "name": "get_dns_analytics",
  "description": "Retrieve DNS query analytics and metrics for a zone. Get insights into query volume, response codes, and query types over time.",
  "endpoint": "/zones/{zone_id}/dns_analytics/report",
  "method": "GET",
  "parameters": [
    { "name": "zone_id", "type": "string", "description": "The zone identifier.", "required": true, "example": "023e105f4ecef8ad9ca31a8372d0c353" },
    { "name": "since", "type": "string", "description": "Start date (ISO 8601).", "required": false, "example": "2024-01-01T00:00:00Z" },
    { "name": "until", "type": "string", "description": "End date (ISO 8601).", "required": false, "example": "2024-01-31T23:59:59Z" },
    { "name": "metrics", "type": "string", "description": "Comma-separated metrics: queryCount, responseTimeAvg, etc.", "required": false, "example": "queryCount" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.cloudflare.com/client/v4/zones/023e105f4ecef8ad9ca31a8372d0c353/dns_analytics/report?since=2024-01-01T00:00:00Z&until=2024-01-31T23:59:59Z&metrics=queryCount",
    "headers": { "Authorization": "Bearer {api_token}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "result": {
        "totals": { "queryCount": 150000 },
        "min": { "queryCount": 100 },
        "max": { "queryCount": 10000 }
      }
    }
  }
}
