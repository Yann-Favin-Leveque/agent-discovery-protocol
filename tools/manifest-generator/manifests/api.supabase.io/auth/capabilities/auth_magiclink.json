{
  "name": "auth_magiclink",
  "resource_group": "auth",
  "description": "Send a magic link to a user's email for passwordless login.",
  "endpoint": "/magiclink",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": true,
      "description": "Email to send the magic link to."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://myproject.supabase.co/auth/v1/magiclink",
    "headers": {
      "apikey": "your-anon-key",
      "Authorization": "Bearer your-anon-key",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "alice@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}