{
  "name": "auth_user_get",
  "resource_group": "auth",
  "description": "Retrieve the currently authenticated user's profile.",
  "endpoint": "/user",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://myproject.supabase.co/auth/v1/user",
    "headers": {
      "apikey": "your-anon-key",
      "Authorization": "Bearer eyJhbGciOi..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "uuid-here",
      "email": "alice@example.com",
      "phone": "",
      "created_at": "2024-01-15T10:30:00Z",
      "app_metadata": {
        "provider": "email"
      },
      "user_metadata": {}
    }
  }
}