{
  "name": "auth_otp",
  "resource_group": "auth",
  "description": "Send a one-time password via email or SMS for passwordless login.",
  "endpoint": "/otp",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "Email to send OTP to."
    },
    {
      "name": "phone",
      "type": "string",
      "required": false,
      "description": "Phone number to send OTP to."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://myproject.supabase.co/auth/v1/otp",
    "headers": {
      "apikey": "your-anon-key",
      "Authorization": "Bearer your-anon-key",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "alice@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}