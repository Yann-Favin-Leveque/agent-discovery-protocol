{
  "name": "admin_users_get",
  "resource_group": "admin",
  "description": "Retrieve a specific user by ID (admin only).",
  "endpoint": "/admin/users/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "The user UUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://myproject.supabase.co/auth/v1/admin/users/uuid-here",
    "headers": {
      "apikey": "your-anon-key",
      "Authorization": "Bearer your-service-role-key",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "uuid-here",
      "email": "alice@example.com",
      "app_metadata": {
        "provider": "email"
      },
      "user_metadata": {}
    }
  }
}