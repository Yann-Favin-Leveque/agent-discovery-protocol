{
  "name": "auth_signin_password",
  "description": "Sign in a user with email and password.",
  "endpoint": "/auth/v1/token?grant_type=password",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "User email",
      "required": true,
      "example": "user@example.com"
    },
    {
      "name": "password",
      "type": "string",
      "description": "User password",
      "required": true,
      "example": "securePassword123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{project_ref}.supabase.co/auth/v1/token?grant_type=password",
    "headers": {
      "apikey": "{anon_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "password": "securePassword123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "access_token": "eyJ...",
      "token_type": "bearer",
      "expires_in": 3600,
      "refresh_token": "abc...",
      "user": {
        "id": "uuid-123",
        "email": "user@example.com"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}