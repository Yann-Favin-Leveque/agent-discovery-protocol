{
  "name": "auth_signout",
  "description": "Sign out a user and invalidate their session.",
  "endpoint": "/auth/v1/logout",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "Authorization",
      "type": "string",
      "description": "Bearer token of the user to sign out",
      "required": true,
      "example": "Bearer eyJ...",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{project_ref}.supabase.co/auth/v1/logout",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer eyJ..."
    }
  },
  "response_example": {
    "status": 204,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
