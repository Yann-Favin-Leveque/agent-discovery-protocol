{
  "name": "storage_objects_get_public_url",
  "description": "Get the public URL for a file in a public bucket.",
  "endpoint": "/storage/v1/object/public/{bucket_id}/{path}",
  "method": "GET",
  "resource_group": "storage",
  "parameters": [
    {
      "name": "bucket_id",
      "type": "string",
      "description": "Public bucket ID",
      "required": true,
      "example": "avatars"
    },
    {
      "name": "path",
      "type": "string",
      "description": "File path",
      "required": true,
      "example": "user123/avatar.png"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{project_ref}.supabase.co/storage/v1/object/public/avatars/user123/avatar.png",
    "headers": {}
  },
  "response_example": {
    "status": 200,
    "body": "(redirects to file or returns file content)"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}