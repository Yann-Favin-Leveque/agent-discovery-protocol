{
  "name": "storage_buckets_empty",
  "description": "Empty all objects from a storage bucket.",
  "endpoint": "/storage/v1/bucket/{id}/empty",
  "method": "POST",
  "resource_group": "storage",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Bucket ID",
      "required": true,
      "example": "documents",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{project_ref}.supabase.co/storage/v1/bucket/documents/empty",
    "headers": {
      "apikey": "{service_role_key}",
      "Authorization": "Bearer {service_role_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Successfully emptied"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
