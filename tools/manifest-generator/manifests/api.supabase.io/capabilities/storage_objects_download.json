{
  "name": "storage_objects_download",
  "description": "Download a file from a storage bucket.",
  "endpoint": "/storage/v1/object/{bucket_id}/{path}",
  "method": "GET",
  "resource_group": "storage",
  "parameters": [
    {
      "name": "bucket_id",
      "type": "string",
      "description": "Bucket ID",
      "required": true,
      "example": "avatars",
      "in": "path"
    },
    {
      "name": "path",
      "type": "string",
      "description": "File path",
      "required": true,
      "example": "user123/avatar.png",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{project_ref}.supabase.co/storage/v1/object/avatars/user123/avatar.png",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer {anon_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "(binary file content)"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
