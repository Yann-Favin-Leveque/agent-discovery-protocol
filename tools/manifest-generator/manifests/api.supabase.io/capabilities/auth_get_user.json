{
  "name": "auth_get_user",
  "description": "Retrieve the currently authenticated user's profile.",
  "endpoint": "/auth/v1/user",
  "method": "GET",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "Authorization",
      "type": "string",
      "description": "Bearer token",
      "required": true,
      "example": "Bearer eyJ...",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{project_ref}.supabase.co/auth/v1/user",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer eyJ..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "uuid-123",
      "email": "user@example.com",
      "role": "authenticated",
      "user_metadata": {
        "name": "John Doe"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
