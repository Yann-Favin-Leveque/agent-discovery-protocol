{
  "name": "rows_update",
  "description": "Update rows matching filter conditions. Always requires a filter to prevent full-table updates.",
  "endpoint": "/rest/v1/{table}",
  "method": "PATCH",
  "resource_group": "database",
  "parameters": [
    {
      "name": "table",
      "type": "string",
      "description": "Table name",
      "required": true,
      "example": "posts",
      "in": "path"
    },
    {
      "name": "body",
      "type": "object",
      "description": "Fields to update",
      "required": true,
      "example": {
        "status": "published"
      },
      "in": "body"
    },
    {
      "name": "column.operator",
      "type": "string",
      "description": "Filter condition (required)",
      "required": true,
      "example": "id=eq.3",
      "in": "body"
    },
    {
      "name": "Prefer",
      "type": "string",
      "description": "Set to 'return=representation' to return updated rows",
      "required": false,
      "example": "return=representation",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://{project_ref}.supabase.co/rest/v1/posts?id=eq.3",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer {anon_key}",
      "Content-Type": "application/json",
      "Prefer": "return=representation"
    },
    "body": {
      "status": "published"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": 3,
        "title": "New Post",
        "status": "published"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
