{
  "name": "storage_buckets_get",
  "description": "Retrieve a specific bucket by ID.",
  "endpoint": "/storage/v1/bucket/{id}",
  "method": "GET",
  "resource_group": "storage",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Bucket ID",
      "required": true,
      "example": "documents",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{project_ref}.supabase.co/storage/v1/bucket/documents",
    "headers": {
      "apikey": "{service_role_key}",
      "Authorization": "Bearer {service_role_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "documents",
      "name": "documents",
      "public": false
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
