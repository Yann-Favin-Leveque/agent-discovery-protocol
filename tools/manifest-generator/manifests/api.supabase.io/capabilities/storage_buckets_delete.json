{
  "name": "storage_buckets_delete",
  "description": "Delete a storage bucket (must be empty).",
  "endpoint": "/storage/v1/bucket/{id}",
  "method": "DELETE",
  "resource_group": "storage",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Bucket ID to delete",
      "required": true,
      "example": "documents",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://{project_ref}.supabase.co/storage/v1/bucket/documents",
    "headers": {
      "apikey": "{service_role_key}",
      "Authorization": "Bearer {service_role_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "message": "Successfully deleted"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
