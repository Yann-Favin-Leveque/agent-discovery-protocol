{
  "name": "auth_admin_get_user",
  "description": "Retrieve a specific user by ID (admin only).",
  "endpoint": "/auth/v1/admin/users/{user_id}",
  "method": "GET",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "User UUID",
      "required": true,
      "example": "uuid-123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{project_ref}.supabase.co/auth/v1/admin/users/uuid-123",
    "headers": {
      "apikey": "{service_role_key}",
      "Authorization": "Bearer {service_role_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "uuid-123",
      "email": "user@example.com",
      "role": "authenticated"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}