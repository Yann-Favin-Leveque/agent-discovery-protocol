{
  "name": "rows_insert",
  "description": "Insert one or more rows into a table. Supports upserts and bulk inserts.",
  "endpoint": "/rest/v1/{table}",
  "method": "POST",
  "resource_group": "database",
  "parameters": [
    {
      "name": "table",
      "type": "string",
      "description": "Table name",
      "required": true,
      "example": "posts",
      "in": "path"
    },
    {
      "name": "body",
      "type": "object",
      "description": "Row data (single object or array for bulk)",
      "required": true,
      "example": {
        "title": "New Post",
        "content": "Hello world",
        "status": "draft"
      },
      "in": "body"
    },
    {
      "name": "Prefer",
      "type": "string",
      "description": "Set to 'return=representation' to return inserted rows, 'resolution=merge-duplicates' for upsert",
      "required": false,
      "example": "return=representation",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{project_ref}.supabase.co/rest/v1/posts",
    "headers": {
      "apikey": "{anon_key}",
      "Authorization": "Bearer {anon_key}",
      "Content-Type": "application/json",
      "Prefer": "return=representation"
    },
    "body": {
      "title": "New Post",
      "content": "Hello world",
      "status": "draft"
    }
  },
  "response_example": {
    "status": 201,
    "body": [
      {
        "id": 3,
        "title": "New Post",
        "content": "Hello world",
        "status": "draft",
        "created_at": "2026-03-02T10:00:00Z"
      }
    ]
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
