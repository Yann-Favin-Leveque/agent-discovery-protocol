{
  "name": "auth_signin_otp",
  "description": "Send a magic link or OTP to a user's email or phone.",
  "endpoint": "/auth/v1/otp",
  "method": "POST",
  "resource_group": "auth",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "User email for magic link",
      "required": false,
      "example": "user@example.com",
      "in": "body"
    },
    {
      "name": "phone",
      "type": "string",
      "description": "User phone for SMS OTP",
      "required": false,
      "example": "+15551234567",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{project_ref}.supabase.co/auth/v1/otp",
    "headers": {
      "apikey": "{anon_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 1000
  }
}
