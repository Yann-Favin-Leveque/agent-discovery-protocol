{
  "name": "indices_delete",
  "description": "Delete an entire index and all its records, settings, synonyms, and rules permanently.",
  "endpoint": "/1/indexes/{indexName}",
  "method": "DELETE",
  "resource_group": "indices",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "Name of the index to delete.",
      "required": true,
      "example": "old_products"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/old_products",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deletedAt": "2024-06-15T11:00:00.000Z",
      "taskID": 686
    }
  },
  "auth_scopes": ["deleteIndex"],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
