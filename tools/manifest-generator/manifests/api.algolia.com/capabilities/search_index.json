{
  "name": "search_index",
  "description": "Perform a full-text search query against a specific Algolia index. Returns ranked results with highlighted matches, facet counts, and pagination info. Supports filtering by attributes, geo-distance, typo tolerance, and custom ranking.",
  "endpoint": "/1/indexes/{indexName}/query",
  "method": "POST",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "The name of the index to search.",
      "required": true,
      "example": "products"
    },
    {
      "name": "query",
      "type": "string",
      "description": "The search query text.",
      "required": false,
      "example": "wireless headphones"
    },
    {
      "name": "filters",
      "type": "string",
      "description": "Filter expression using attribute:value syntax (e.g. 'category:Electronics AND price < 100').",
      "required": false,
      "example": "category:Electronics AND price < 100"
    },
    {
      "name": "facets",
      "type": "array",
      "description": "List of attributes to return facet counts for.",
      "required": false,
      "example": ["category", "brand"]
    },
    {
      "name": "hitsPerPage",
      "type": "integer",
      "description": "Number of results per page (default 20, max 1000).",
      "required": false,
      "example": 20
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number to retrieve (0-indexed).",
      "required": false,
      "example": 0
    },
    {
      "name": "attributesToRetrieve",
      "type": "array",
      "description": "List of attributes to include in the response. Use ['*'] for all.",
      "required": false,
      "example": ["name", "price", "category", "image_url"]
    },
    {
      "name": "attributesToHighlight",
      "type": "array",
      "description": "List of attributes to highlight matching text in.",
      "required": false,
      "example": ["name", "description"]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/products/query",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "wireless headphones",
      "hitsPerPage": 5,
      "filters": "category:Electronics",
      "facets": ["brand", "price_range"]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hits": [
        {
          "objectID": "12345",
          "name": "Premium Wireless Headphones",
          "price": 79.99,
          "category": "Electronics",
          "brand": "AudioTech",
          "_highlightResult": {
            "name": {
              "value": "Premium <em>Wireless Headphones</em>",
              "matchLevel": "full"
            }
          }
        }
      ],
      "nbHits": 342,
      "page": 0,
      "nbPages": 69,
      "hitsPerPage": 5,
      "processingTimeMS": 2,
      "query": "wireless headphones",
      "facets": {
        "brand": {
          "AudioTech": 45,
          "SoundPro": 38
        }
      }
    }
  }
}
