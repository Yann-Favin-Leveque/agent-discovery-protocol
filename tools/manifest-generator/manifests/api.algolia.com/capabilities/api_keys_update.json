{
  "name": "api_keys_update",
  "description": "Update the permissions, restrictions, or description of an existing API key.",
  "endpoint": "/1/keys/{key}",
  "method": "PUT",
  "resource_group": "api_keys",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "The API key to update.",
      "required": true,
      "example": "abcdef1234567890",
      "in": "path"
    },
    {
      "name": "acl",
      "type": "array",
      "description": "Updated list of permissions.",
      "required": false,
      "example": [
        "search"
      ],
      "in": "body"
    },
    {
      "name": "indexes",
      "type": "array",
      "description": "Updated list of accessible indices.",
      "required": false,
      "example": [
        "products",
        "categories"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://{APPLICATION_ID}.algolia.net/1/keys/abcdef1234567890",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{ADMIN_API_KEY}",
      "Content-Type": "application/json"
    },
    "body": {
      "acl": [
        "search"
      ],
      "indexes": [
        "products",
        "categories"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "key": "abcdef1234567890",
      "updatedAt": "2024-06-15T15:30:00.000Z"
    }
  },
  "auth_scopes": [
    "admin"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
