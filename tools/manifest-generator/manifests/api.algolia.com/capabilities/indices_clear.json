{
  "name": "indices_clear",
  "description": "Remove all records from an index while keeping its settings, synonyms, and rules intact.",
  "endpoint": "/1/indexes/{indexName}/clear",
  "method": "POST",
  "resource_group": "indices",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "Name of the index to clear.",
      "required": true,
      "example": "products",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/products/clear",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "updatedAt": "2024-06-15T11:00:00.000Z",
      "taskID": 687
    }
  },
  "auth_scopes": [
    "deleteIndex"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
