{
  "name": "api_keys_list",
  "description": "List all API keys associated with the Algolia application including their permissions and restrictions.",
  "endpoint": "/1/keys",
  "method": "GET",
  "resource_group": "api_keys",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://{APPLICATION_ID}.algolia.net/1/keys",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{ADMIN_API_KEY}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "keys": [
        {
          "value": "abcdef1234567890",
          "createdAt": 1686816000,
          "acl": ["search", "browse"],
          "description": "Search-only key",
          "indexes": ["products"],
          "validity": 0
        }
      ]
    }
  },
  "auth_scopes": ["admin"],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
