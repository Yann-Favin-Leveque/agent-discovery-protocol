{
  "name": "multi_index_search",
  "description": "Execute multiple search queries across one or more Algolia indexes in a single API call. Each query can target a different index with its own parameters. Ideal for building federated search experiences, autocomplete dropdowns, or combining results from different data types (products, articles, categories).",
  "endpoint": "/1/indexes/*/queries",
  "method": "POST",
  "parameters": [
    {
      "name": "requests",
      "type": "array",
      "description": "Array of search request objects, each with 'indexName' and search parameters like 'query', 'hitsPerPage', 'filters'.",
      "required": true,
      "example": [
        {"indexName": "products", "query": "headphones", "hitsPerPage": 3},
        {"indexName": "articles", "query": "headphones", "hitsPerPage": 2}
      ]
    },
    {
      "name": "strategy",
      "type": "string",
      "description": "Multi-query strategy: 'none' (default, all queries independent) or 'stopIfEnoughMatches' (stop querying once enough hits found).",
      "required": false,
      "example": "none"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/*/queries",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}",
      "Content-Type": "application/json"
    },
    "body": {
      "requests": [
        {
          "indexName": "products",
          "query": "headphones",
          "hitsPerPage": 3,
          "facets": ["brand"]
        },
        {
          "indexName": "blog_posts",
          "query": "headphones",
          "hitsPerPage": 2
        }
      ],
      "strategy": "none"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "hits": [
            {
              "objectID": "prod_1",
              "name": "Pro Wireless Headphones",
              "price": 199.99
            }
          ],
          "nbHits": 45,
          "page": 0,
          "hitsPerPage": 3,
          "index": "products",
          "processingTimeMS": 1
        },
        {
          "hits": [
            {
              "objectID": "post_42",
              "title": "Best Headphones of 2025"
            }
          ],
          "nbHits": 12,
          "page": 0,
          "hitsPerPage": 2,
          "index": "blog_posts",
          "processingTimeMS": 1
        }
      ]
    }
  }
}
