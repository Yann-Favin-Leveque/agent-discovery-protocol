{
  "name": "rules_save",
  "description": "Create or update a query rule that customizes search behavior for specific queries. Rules can pin results, boost items, or add filters.",
  "endpoint": "/1/indexes/{indexName}/rules/{objectID}",
  "method": "PUT",
  "resource_group": "rules",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "Name of the index.",
      "required": true,
      "example": "products",
      "in": "path"
    },
    {
      "name": "objectID",
      "type": "string",
      "description": "Unique ID for the rule.",
      "required": true,
      "example": "rule-promote-sale",
      "in": "path"
    },
    {
      "name": "forwardToReplicas",
      "type": "boolean",
      "description": "Whether to forward to replica indices.",
      "required": false,
      "example": true,
      "in": "body"
    },
    {
      "name": "conditions",
      "type": "array",
      "description": "Array of condition objects defining when the rule triggers.",
      "required": true,
      "example": [
        {
          "anchoring": "contains",
          "pattern": "sale"
        }
      ],
      "in": "body"
    },
    {
      "name": "consequence",
      "type": "object",
      "description": "The consequence applied when the rule triggers (promote, filter, hide, userData).",
      "required": true,
      "example": {
        "promote": [
          {
            "objectID": "promo-1",
            "position": 0
          }
        ]
      },
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/products/rules/rule-promote-sale",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}",
      "Content-Type": "application/json"
    },
    "body": {
      "objectID": "rule-promote-sale",
      "conditions": [
        {
          "anchoring": "contains",
          "pattern": "sale"
        }
      ],
      "consequence": {
        "promote": [
          {
            "objectID": "promo-1",
            "position": 0
          }
        ]
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "updatedAt": "2024-06-15T14:00:00.000Z",
      "taskID": 693
    }
  },
  "auth_scopes": [
    "editSettings"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
