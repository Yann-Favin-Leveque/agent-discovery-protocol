{
  "name": "rules_delete",
  "description": "Delete a specific query rule from an index by its objectID.",
  "endpoint": "/1/indexes/{indexName}/rules/{objectID}",
  "method": "DELETE",
  "resource_group": "rules",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "Name of the index.",
      "required": true,
      "example": "products"
    },
    {
      "name": "objectID",
      "type": "string",
      "description": "ID of the rule to delete.",
      "required": true,
      "example": "rule-promote-sale"
    },
    {
      "name": "forwardToReplicas",
      "type": "boolean",
      "description": "Whether to forward to replica indices.",
      "required": false,
      "example": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/products/rules/rule-promote-sale",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "updatedAt": "2024-06-15T14:30:00.000Z",
      "taskID": 694
    }
  },
  "auth_scopes": ["editSettings"],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
