{
  "name": "synonyms_delete",
  "description": "Delete a specific synonym set from an index by its objectID.",
  "endpoint": "/1/indexes/{indexName}/synonyms/{objectID}",
  "method": "DELETE",
  "resource_group": "synonyms",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "Name of the index.",
      "required": true,
      "example": "products",
      "in": "path"
    },
    {
      "name": "objectID",
      "type": "string",
      "description": "ID of the synonym to delete.",
      "required": true,
      "example": "syn-phone-mobile",
      "in": "path"
    },
    {
      "name": "forwardToReplicas",
      "type": "boolean",
      "description": "Whether to forward to replica indices.",
      "required": false,
      "example": true,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/products/synonyms/syn-phone-mobile",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deletedAt": "2024-06-15T13:30:00.000Z",
      "taskID": 692
    }
  },
  "auth_scopes": [
    "editSettings"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
