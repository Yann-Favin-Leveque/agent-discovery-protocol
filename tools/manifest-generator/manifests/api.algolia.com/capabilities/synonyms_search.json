{
  "name": "synonyms_search",
  "description": "Search for synonyms defined on an index. Supports text query and filtering by synonym type.",
  "endpoint": "/1/indexes/{indexName}/synonyms/search",
  "method": "POST",
  "resource_group": "synonyms",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "Name of the index.",
      "required": true,
      "example": "products"
    },
    {
      "name": "query",
      "type": "string",
      "description": "Search query to find synonyms.",
      "required": false,
      "example": "phone"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Filter by synonym type.",
      "required": false,
      "example": "synonym"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 0
    },
    {
      "name": "hitsPerPage",
      "type": "integer",
      "description": "Number of results per page.",
      "required": false,
      "example": 20
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/products/synonyms/search",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}",
      "Content-Type": "application/json"
    },
    "body": { "query": "phone", "hitsPerPage": 20 }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hits": [
        { "objectID": "syn-phone-mobile", "type": "synonym", "synonyms": ["phone", "mobile"] }
      ],
      "nbHits": 1
    }
  },
  "auth_scopes": ["settings"],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
