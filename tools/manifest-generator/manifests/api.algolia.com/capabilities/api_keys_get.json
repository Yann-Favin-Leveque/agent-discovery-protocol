{
  "name": "api_keys_get",
  "description": "Retrieve the permissions and restrictions of a specific API key.",
  "endpoint": "/1/keys/{key}",
  "method": "GET",
  "resource_group": "api_keys",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "The API key to retrieve.",
      "required": true,
      "example": "abcdef1234567890"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{APPLICATION_ID}.algolia.net/1/keys/abcdef1234567890",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{ADMIN_API_KEY}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "value": "abcdef1234567890",
      "createdAt": 1686816000,
      "acl": ["search", "browse"],
      "description": "Search-only key",
      "indexes": ["products"],
      "validity": 0
    }
  },
  "auth_scopes": ["admin"],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
