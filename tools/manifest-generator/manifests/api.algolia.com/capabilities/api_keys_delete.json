{
  "name": "api_keys_delete",
  "description": "Delete an API key permanently. The key will no longer be usable for any requests.",
  "endpoint": "/1/keys/{key}",
  "method": "DELETE",
  "resource_group": "api_keys",
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "The API key to delete.",
      "required": true,
      "example": "abcdef1234567890",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://{APPLICATION_ID}.algolia.net/1/keys/abcdef1234567890",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{ADMIN_API_KEY}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deletedAt": "2024-06-15T16:00:00.000Z"
    }
  },
  "auth_scopes": [
    "admin"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
