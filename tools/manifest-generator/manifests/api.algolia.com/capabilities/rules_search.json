{
  "name": "rules_search",
  "description": "Search for query rules defined on an index. Supports text query and pagination.",
  "endpoint": "/1/indexes/{indexName}/rules/search",
  "method": "POST",
  "resource_group": "rules",
  "parameters": [
    {
      "name": "indexName",
      "type": "string",
      "description": "Name of the index.",
      "required": true,
      "example": "products",
      "in": "path"
    },
    {
      "name": "query",
      "type": "string",
      "description": "Search query to find rules.",
      "required": false,
      "example": "sale",
      "in": "body"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "example": 0,
      "in": "body"
    },
    {
      "name": "hitsPerPage",
      "type": "integer",
      "description": "Number of results per page.",
      "required": false,
      "example": 20,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{APPLICATION_ID}.algolia.net/1/indexes/products/rules/search",
    "headers": {
      "x-algolia-application-id": "{APPLICATION_ID}",
      "x-algolia-api-key": "{API_KEY}",
      "Content-Type": "application/json"
    },
    "body": {
      "query": "sale"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "hits": [
        {
          "objectID": "rule-promote-sale",
          "conditions": [
            {
              "anchoring": "contains",
              "pattern": "sale"
            }
          ]
        }
      ],
      "nbHits": 1
    }
  },
  "auth_scopes": [
    "settings"
  ],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
