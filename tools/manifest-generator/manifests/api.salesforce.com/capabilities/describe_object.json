{
  "name": "describe_object",
  "description": "Get metadata describing a Salesforce object's fields, relationships, and available operations.",
  "endpoint": "/sobjects/{object_name}/describe",
  "method": "GET",
  "parameters": [
    {"name": "object_name", "type": "string", "description": "API name of the Salesforce object.", "required": true, "example": "Account"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mycompany.salesforce.com/services/data/v59.0/sobjects/Account/describe",
    "headers": {"Authorization": "Bearer {access_token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"name": "Account", "label": "Account", "fields": [{"name": "Id", "type": "id", "label": "Account ID"}, {"name": "Name", "type": "string", "label": "Account Name", "length": 255}], "createable": true, "updateable": true, "queryable": true}
  }
}
