{
  "name": "sobject_get",
  "description": "Retrieve a specific record by SObject type and ID with selected fields.",
  "resource_group": "sobjects",
  "endpoint": "/sobjects/{sobject_type}/{record_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "sobject_type",
      "type": "string",
      "required": true,
      "description": "SObject API name",
      "location": "path",
      "in": "path"
    },
    {
      "name": "record_id",
      "type": "string",
      "required": true,
      "description": "Record ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Comma-separated list of fields to return",
      "location": "query",
      "in": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "Id": "001xx",
    "Name": "Acme",
    "Industry": "Technology"
  },
  "auth_scopes": [
    "api"
  ]
}
