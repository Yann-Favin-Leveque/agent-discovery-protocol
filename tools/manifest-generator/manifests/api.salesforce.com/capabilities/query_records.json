{
  "name": "query_records",
  "description": "Execute a SOQL (Salesforce Object Query Language) query to search, filter, and retrieve records from any object.",
  "endpoint": "/query",
  "method": "GET",
  "parameters": [
    {"name": "q", "type": "string", "description": "SOQL query string.", "required": true, "example": "SELECT Id, Name, Email FROM Contact WHERE LastName = 'Smith' LIMIT 10"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mycompany.salesforce.com/services/data/v59.0/query?q=SELECT+Id,Name,Email+FROM+Contact+WHERE+LastName='Smith'+LIMIT+10",
    "headers": {"Authorization": "Bearer {access_token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"totalSize": 2, "done": true, "records": [{"attributes": {"type": "Contact", "url": "/services/data/v59.0/sobjects/Contact/003abc"}, "Id": "003abc", "Name": "Jane Smith", "Email": "jane@acme.com"}]}
  }
}
