{
  "name": "sobject_upsert",
  "description": "Create or update a record using an external ID field for matching.",
  "resource_group": "sobjects",
  "endpoint": "/sobjects/{sobject_type}/{external_id_field}/{external_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "sobject_type",
      "type": "string",
      "required": true,
      "description": "SObject API name",
      "location": "path",
      "in": "path"
    },
    {
      "name": "external_id_field",
      "type": "string",
      "required": true,
      "description": "External ID field name",
      "location": "path",
      "in": "path"
    },
    {
      "name": "external_id",
      "type": "string",
      "required": true,
      "description": "External ID value",
      "location": "path",
      "in": "path"
    },
    {
      "name": "body",
      "type": "object",
      "required": true,
      "description": "Field values",
      "in": "body"
    }
  ],
  "request_example": {
    "Name": "Acme",
    "Industry": "Technology"
  },
  "response_example": {
    "id": "001xx",
    "success": true,
    "created": true
  },
  "auth_scopes": [
    "api"
  ]
}
