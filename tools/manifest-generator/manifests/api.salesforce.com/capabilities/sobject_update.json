{
  "name": "sobject_update",
  "description": "Update fields on an existing Salesforce record by ID.",
  "resource_group": "sobjects",
  "endpoint": "/sobjects/{sobject_type}/{record_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "sobject_type",
      "type": "string",
      "required": true,
      "description": "SObject API name",
      "location": "path"
    },
    {
      "name": "record_id",
      "type": "string",
      "required": true,
      "description": "Record ID",
      "location": "path"
    },
    {
      "name": "body",
      "type": "object",
      "required": true,
      "description": "Fields to update"
    }
  ],
  "request_example": {
    "Industry": "Finance"
  },
  "response_example": {},
  "auth_scopes": [
    "api"
  ]
}
