{
  "name": "sobject_create",
  "description": "Create a new record in any standard or custom Salesforce object.",
  "resource_group": "sobjects",
  "endpoint": "/sobjects/{sobject_type}",
  "method": "POST",
  "parameters": [
    {
      "name": "sobject_type",
      "type": "string",
      "required": true,
      "description": "SObject API name",
      "location": "path"
    },
    {
      "name": "body",
      "type": "object",
      "required": true,
      "description": "Field values for the new record"
    }
  ],
  "request_example": {
    "Name": "Acme Corp",
    "Industry": "Technology"
  },
  "response_example": {
    "id": "001xx",
    "success": true,
    "errors": []
  },
  "auth_scopes": [
    "api"
  ]
}
