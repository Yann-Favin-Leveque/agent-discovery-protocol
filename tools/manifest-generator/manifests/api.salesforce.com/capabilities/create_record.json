{
  "name": "create_record",
  "description": "Create a new record in any standard or custom Salesforce object (Contact, Account, Lead, Opportunity, etc.).",
  "endpoint": "/sobjects/{object_name}",
  "method": "POST",
  "parameters": [
    {"name": "object_name", "type": "string", "description": "API name of the Salesforce object.", "required": true, "example": "Contact"},
    {"name": "FirstName", "type": "string", "description": "First name (for Contact/Lead).", "required": false, "example": "Jane"},
    {"name": "LastName", "type": "string", "description": "Last name (for Contact/Lead).", "required": true, "example": "Smith"},
    {"name": "Email", "type": "string", "description": "Email address.", "required": false, "example": "jane@acme.com"},
    {"name": "AccountId", "type": "string", "description": "Parent account ID.", "required": false, "example": "001abc"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://mycompany.salesforce.com/services/data/v59.0/sobjects/Contact",
    "headers": {"Authorization": "Bearer {access_token}", "Content-Type": "application/json"},
    "body": {"FirstName": "Jane", "LastName": "Smith", "Email": "jane@acme.com", "AccountId": "001abc"}
  },
  "response_example": {
    "status": 201,
    "body": {"id": "003xyz", "success": true, "errors": []}
  }
}
