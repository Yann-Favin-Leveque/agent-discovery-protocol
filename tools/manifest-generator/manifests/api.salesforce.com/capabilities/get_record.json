{
  "name": "get_record",
  "description": "Retrieve a specific Salesforce record by ID with selected fields.",
  "endpoint": "/sobjects/{object_name}/{record_id}",
  "method": "GET",
  "parameters": [
    {"name": "object_name", "type": "string", "description": "API name of the Salesforce object.", "required": true, "example": "Account"},
    {"name": "record_id", "type": "string", "description": "Record ID.", "required": true, "example": "001abc"},
    {"name": "fields", "type": "string", "description": "Comma-separated list of fields to return.", "required": false, "example": "Id,Name,Industry,Website"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://mycompany.salesforce.com/services/data/v59.0/sobjects/Account/001abc?fields=Id,Name,Industry,Website",
    "headers": {"Authorization": "Bearer {access_token}"}
  },
  "response_example": {
    "status": 200,
    "body": {"Id": "001abc", "Name": "Acme Corp", "Industry": "Technology", "Website": "https://acme.com"}
  }
}
