{
  "name": "files_list",
  "description": "List the metadata for all uploaded data files including file ID, size, purpose, and processing status.",
  "resource_group": "files",
  "endpoint": "/v1/files",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.together.xyz/v1/files",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "file-abc123",
          "object": "file",
          "created_at": 1699564800,
          "filename": "training_data.jsonl",
          "bytes": 2048,
          "purpose": "fine-tune",
          "FileType": "jsonl",
          "Processed": true
        }
      ]
    }
  }
}
