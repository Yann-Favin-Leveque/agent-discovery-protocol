{
  "name": "fine_tunes_events_list",
  "description": "List the training events and progress for a specific fine-tuning job, including step counts, checkpoints, and error messages.",
  "resource_group": "fine_tunes",
  "endpoint": "/v1/fine-tunes/{id}/events",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The ID of the fine-tuning job to list events for.",
      "example": "ft-01234567890123456789",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.together.xyz/v1/fine-tunes/ft-01234567890123456789/events",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "object": "fine-tune-event",
          "created_at": "2024-01-01T00:00:00.000Z",
          "message": "Training started",
          "type": "job_start",
          "level": "info"
        },
        {
          "object": "fine-tune-event",
          "created_at": "2024-01-01T02:30:00.000Z",
          "message": "Training completed",
          "type": "training_complete",
          "level": "info",
          "step": 1000,
          "total_steps": 1000
        }
      ]
    }
  }
}
