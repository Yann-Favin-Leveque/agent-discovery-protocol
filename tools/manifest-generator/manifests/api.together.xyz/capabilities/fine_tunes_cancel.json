{
  "name": "fine_tunes_cancel",
  "description": "Cancel a currently running fine-tuning job. Returns the job metadata with updated status.",
  "resource_group": "fine_tunes",
  "endpoint": "/v1/fine-tunes/{id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The ID of the fine-tuning job to cancel.",
      "example": "ft-01234567890123456789"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.together.xyz/v1/fine-tunes/ft-01234567890123456789/cancel",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ft-01234567890123456789",
      "status": "cancelled",
      "created_at": "2024-01-01T00:00:00.000Z",
      "updated_at": "2024-01-01T01:00:00.000Z",
      "model": "meta-llama/Llama-2-7b-hf",
      "model_output_name": "user/meta-llama-Llama-2-7b-hf-ft"
    }
  }
}
