{
  "name": "models_list",
  "description": "List all available open-source models on the Together AI platform. Returns model IDs, types (chat, language, code, image, embedding), context lengths, and pricing information.",
  "resource_group": "models",
  "endpoint": "/v1/models",
  "method": "GET",
  "parameters": [
    {
      "name": "dedicated",
      "type": "boolean",
      "required": false,
      "description": "Filter models to only return dedicated models."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.together.xyz/v1/models",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo",
        "object": "model",
        "created": 1692896905,
        "type": "chat",
        "display_name": "Meta Llama 3.1 8B Instruct Turbo",
        "organization": "meta-llama",
        "context_length": 131072,
        "pricing": {
          "input": 0.18,
          "output": 0.18,
          "hourly": 0,
          "base": 0,
          "finetune": 0
        }
      }
    ]
  }
}
