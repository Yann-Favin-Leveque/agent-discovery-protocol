{
  "name": "files_get",
  "description": "Retrieve the metadata for a single uploaded data file by its ID.",
  "resource_group": "files",
  "endpoint": "/v1/files/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The ID of the file to retrieve.",
      "example": "file-abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.together.xyz/v1/files/file-abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "file-abc123",
      "object": "file",
      "created_at": 1699564800,
      "filename": "training_data.jsonl",
      "bytes": 2048,
      "purpose": "fine-tune",
      "FileType": "jsonl",
      "Processed": true
    }
  }
}
