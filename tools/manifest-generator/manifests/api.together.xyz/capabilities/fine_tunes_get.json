{
  "name": "fine_tunes_get",
  "description": "Retrieve the metadata for a single fine-tuning job by its ID, including status, training progress, model output name, and cost.",
  "resource_group": "fine_tunes",
  "endpoint": "/v1/fine-tunes/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The ID of the fine-tuning job to retrieve.",
      "example": "ft-01234567890123456789",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.together.xyz/v1/fine-tunes/ft-01234567890123456789",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ft-01234567890123456789",
      "status": "completed",
      "created_at": "2024-01-01T00:00:00.000Z",
      "updated_at": "2024-01-01T02:30:00.000Z",
      "model": "meta-llama/Llama-2-7b-hf",
      "model_output_name": "user/meta-llama-Llama-2-7b-hf-ft",
      "n_epochs": 3,
      "batch_size": "max",
      "learning_rate": 0.0001,
      "epochs_completed": 3,
      "token_count": 850000,
      "total_price": 1500
    }
  }
}
