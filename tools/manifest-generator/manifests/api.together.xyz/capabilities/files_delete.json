{
  "name": "files_delete",
  "description": "Delete a previously uploaded data file by its ID.",
  "resource_group": "files",
  "endpoint": "/v1/files/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "The ID of the file to delete.",
      "example": "file-abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.together.xyz/v1/files/file-abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "file-abc123",
      "deleted": true
    }
  }
}
