    {
      "name": "insights_workflow_metrics",
      "resource_group": "insights",
      "description": "Get workflow metrics.",
      "detail_url": "/capabilities/insights_workflow_metrics"
    },
    {
      "name": "insights_flaky_tests",
      "resource_group": "insights",
      "description": "Get flaky tests for a project.",
      "detail_url": "/capabilities/insights_flaky_tests"
    },
    {
      "name": "context_list",
      "resource_group": "contexts",
      "description": "List contexts for an organization.",
      "detail_url": "/capabilities/context_list"
    },
    {
      "name": "context_create",
      "resource_group": "contexts",
      "description": "Create a context.",
      "detail_url": "/capabilities/context_create"
    },
    {
      "name": "context_delete",
      "resource_group": "contexts",
      "description": "Delete a context.",
      "detail_url": "/capabilities/context_delete"
    },
    {
      "name": "context_envvar_list",
