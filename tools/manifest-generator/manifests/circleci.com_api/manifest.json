{
  "spec_version": "1.0",
  "name": "CircleCI",
  "description": "CircleCI is a CI/CD platform. Trigger pipelines, monitor workflows and jobs, manage environment variables, get build insights, and configure schedules and webhooks.",
  "base_url": "https://circleci.com/api/v2",
  "auth": {
    "type": "api_key",
    "header": "Circle-Token",
    "setup_url": "https://app.circleci.com/settings/user/tokens"
  },
  "capabilities": [
    {
      "name": "pipeline_trigger",
      "resource_group": "pipelines",
      "description": "Trigger a new pipeline for a project.",
      "detail_url": "/capabilities/pipeline_trigger"
    },
    {
      "name": "pipeline_get",
      "resource_group": "pipelines",
      "description": "Get a pipeline by ID.",
      "detail_url": "/capabilities/pipeline_get"
    },
    {
      "name": "pipeline_list",
      "resource_group": "pipelines",
      "description": "List pipelines for a project.",
      "detail_url": "/capabilities/pipeline_list"
    },
    {
      "name": "pipeline_config_get",
      "resource_group": "pipelines",
      "description": "Get pipeline configuration.",
      "detail_url": "/capabilities/pipeline_config_get"
    },
    {
      "name": "workflow_get",
      "resource_group": "workflows",
      "description": "Get a workflow by ID.",
      "detail_url": "/capabilities/workflow_get"
    },
    {
      "name": "workflow_list",
      "resource_group": "workflows",
      "description": "List workflows for a pipeline.",
      "detail_url": "/capabilities/workflow_list"
    },
    {
      "name": "workflow_cancel",
      "resource_group": "workflows",
      "description": "Cancel a running workflow.",
      "detail_url": "/capabilities/workflow_cancel"
    },
    {
      "name": "workflow_rerun",
      "resource_group": "workflows",
      "description": "Rerun a workflow.",
      "detail_url": "/capabilities/workflow_rerun"
    },
    {
      "name": "workflow_approve_job",
      "resource_group": "workflows",
      "description": "Approve a pending approval job.",
      "detail_url": "/capabilities/workflow_approve_job"
    },
    {
      "name": "workflow_jobs_list",
      "resource_group": "workflows",
      "description": "List jobs for a workflow.",
      "detail_url": "/capabilities/workflow_jobs_list"
    },
    {
      "name": "job_get",
      "resource_group": "jobs",
      "description": "Get job details.",
      "detail_url": "/capabilities/job_get"
    },
    {
      "name": "job_cancel",
      "resource_group": "jobs",
      "description": "Cancel a running job.",
      "detail_url": "/capabilities/job_cancel"
    },
    {
      "name": "job_artifacts_list",
      "resource_group": "jobs",
      "description": "List artifacts from a job.",
      "detail_url": "/capabilities/job_artifacts_list"
    },
    {
      "name": "job_tests_list",
      "resource_group": "jobs",
      "description": "List test results for a job.",
      "detail_url": "/capabilities/job_tests_list"
    },
    {
      "name": "project_get",
      "resource_group": "projects",
      "description": "Get project settings.",
      "detail_url": "/capabilities/project_get"
    },
    {
      "name": "project_envvar_list",
      "resource_group": "projects",
      "description": "List environment variables.",
      "detail_url": "/capabilities/project_envvar_list"
    },
    {
      "name": "project_envvar_create",
      "resource_group": "projects",
      "description": "Create an environment variable.",
      "detail_url": "/capabilities/project_envvar_create"
    },
    {
      "name": "project_envvar_delete",
      "resource_group": "projects",
      "description": "Delete an environment variable.",
      "detail_url": "/capabilities/project_envvar_delete"
    },
    {
