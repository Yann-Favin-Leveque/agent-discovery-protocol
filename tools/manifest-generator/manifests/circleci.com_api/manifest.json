    },
    {
      "name": "context_envvar_delete",
      "resource_group": "contexts",
      "description": "Delete env var from context.",
      "detail_url": "/capabilities/context_envvar_delete"
    },
    {
      "name": "schedule_list",
      "resource_group": "schedules",
      "description": "List scheduled triggers.",
      "detail_url": "/capabilities/schedule_list"
    },
    {
      "name": "schedule_create",
      "resource_group": "schedules",
      "description": "Create a schedule trigger.",
      "detail_url": "/capabilities/schedule_create"
    },
    {
      "name": "schedule_delete",
      "resource_group": "schedules",
      "description": "Delete a schedule.",
      "detail_url": "/capabilities/schedule_delete"
    },
    {
      "name": "webhook_list",
      "resource_group": "webhooks",
      "description": "List webhooks.",
      "detail_url": "/capabilities/webhook_list"
    },
    {
      "name": "webhook_create",
      "resource_group": "webhooks",
      "description": "Create a webhook.",
      "detail_url": "/capabilities/webhook_create"
    },
    {
      "name": "webhook_delete",
      "resource_group": "webhooks",
      "description": "Delete a webhook.",
      "detail_url": "/capabilities/webhook_delete"
    },
    {
      "name": "user_get",
      "resource_group": "user",
      "description": "Get current authenticated user.",
      "detail_url": "/capabilities/user_get"
    },
    {
      "name": "user_collaborations",
