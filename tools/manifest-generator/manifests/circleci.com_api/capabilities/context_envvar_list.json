{
  "name": "context_envvar_list",
  "description": "List env vars in a context.",
  "resource_group": "contexts",
  "endpoint": "/context/{context-id}/environment-variable",
  "method": "GET",
  "parameters": [
    {
      "name": "context-id",
      "type": "string",
      "required": true,
      "description": "Context ID.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/context/ctx-abc/environment-variable"
  },
  "response_example": {
    "items": [
      {
        "variable": "AWS_KEY",
        "context_id": "ctx-abc"
      }
    ]
  }
}
