{
  "name": "workflow",
  "description": "Manage workflow — cancel a workflow, rerun a workflow, approve a job. Supports standard CRUD operations through the REST API.",
  "endpoint": "/workflow/{id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The unique ID of the workflow.",
      "required": true,
      "example": "5034460f-c7c4-4c43-9457-de07e2029e7b"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/workflow/{id}/cancel",
    "headers": {
      "Content-Type": "application/json",
      "Circle-Token": "{api_key}"
    },
    "body": {
      "id": "5034460f-c7c4-4c43-9457-de07e2029e7b"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "id": "5034460f-c7c4-4c43-9457-de07e2029e7b"
      }
    }
  }
}
