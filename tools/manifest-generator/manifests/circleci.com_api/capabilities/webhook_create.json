{
  "name": "webhook_create",
  "description": "Create a webhook.",
  "resource_group": "webhooks",
  "endpoint": "/webhook",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Name.",
      "in": "body"
    },
    {
      "name": "events",
      "type": "array",
      "required": true,
      "description": "Events: workflow-completed, job-completed.",
      "in": "body"
    },
    {
      "name": "url",
      "type": "string",
      "required": true,
      "description": "Webhook URL.",
      "in": "body"
    },
    {
      "name": "scope",
      "type": "object",
      "required": true,
      "description": "Scope: {id, type}.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/webhook",
    "body": {
      "name": "deploy",
      "events": [
        "workflow-completed"
      ],
      "url": "https://example.com/hook",
      "scope": {
        "id": "proj-abc",
        "type": "project"
      }
    }
  },
  "response_example": {
    "id": "wh-new",
    "name": "deploy"
  }
}
