{
  "name": "job_artifacts_list",
  "description": "List artifacts from a job.",
  "resource_group": "jobs",
  "endpoint": "/project/{project-slug}/{job-number}/artifacts",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug."
    },
    {
      "name": "job-number",
      "type": "integer",
      "required": true,
      "description": "Job number."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/42/artifacts"
  },
  "response_example": {
    "items": [
      {
        "path": "dist/app.js",
        "url": "https://output.circle-artifacts.com/abc",
        "node_index": 0
      }
    ]
  }
}