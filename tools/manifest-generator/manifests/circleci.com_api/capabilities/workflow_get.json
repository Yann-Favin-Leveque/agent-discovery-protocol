{
  "name": "workflow_get",
  "description": "Get a workflow by ID.",
  "resource_group": "workflows",
  "endpoint": "/workflow/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Workflow ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/workflow/wf-abc"
  },
  "response_example": {
    "id": "wf-abc",
    "name": "build-and-test",
    "status": "success",
    "pipeline_id": "pipeline-abc"
  }
}