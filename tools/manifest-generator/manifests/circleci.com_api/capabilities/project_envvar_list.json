{
  "name": "project_envvar_list",
  "description": "List environment variables.",
  "resource_group": "projects",
  "endpoint": "/project/{project-slug}/envvar",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/envvar"
  },
  "response_example": {
    "items": [
      {
        "name": "AWS_KEY",
        "value": "xxxx...xxxx"
      }
    ]
  }
}