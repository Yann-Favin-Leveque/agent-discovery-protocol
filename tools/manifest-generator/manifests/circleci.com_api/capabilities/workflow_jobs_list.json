{
  "name": "workflow_jobs_list",
  "description": "List jobs for a workflow.",
  "resource_group": "workflows",
  "endpoint": "/workflow/{id}/job",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Workflow ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/workflow/wf-abc/job"
  },
  "response_example": {
    "items": [
      {
        "id": "job-abc",
        "name": "build",
        "status": "success",
        "type": "build",
        "job_number": 1
      }
    ]
  }
}
