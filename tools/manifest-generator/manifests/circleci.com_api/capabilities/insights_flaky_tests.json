{
  "name": "insights_flaky_tests",
  "description": "Get flaky tests for a project.",
  "resource_group": "insights",
  "endpoint": "/insights/{project-slug}/flaky-tests",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/insights/gh/my-org/my-repo/flaky-tests"
  },
  "response_example": {
    "flaky_tests": [
      {
        "test_name": "test_login",
        "times_flaked": 5
      }
    ]
  }
}
