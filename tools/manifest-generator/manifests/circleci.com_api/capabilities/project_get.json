{
  "name": "project_get",
  "description": "Get project settings.",
  "resource_group": "projects",
  "endpoint": "/project/{project-slug}",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo"
  },
  "response_example": {
    "slug": "gh/my-org/my-repo",
    "name": "my-repo",
    "organization_name": "my-org"
  }
}
