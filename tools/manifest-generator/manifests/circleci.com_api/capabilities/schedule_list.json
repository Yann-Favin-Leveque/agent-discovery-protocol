{
  "name": "schedule_list",
  "description": "List scheduled triggers.",
  "resource_group": "schedules",
  "endpoint": "/project/{project-slug}/schedule",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/schedule"
  },
  "response_example": {
    "items": [
      {
        "id": "sched-abc",
        "name": "nightly",
        "timetable": {
          "per-hour": 1,
          "hours-of-day": [
            0
          ]
        }
      }
    ]
  }
}
