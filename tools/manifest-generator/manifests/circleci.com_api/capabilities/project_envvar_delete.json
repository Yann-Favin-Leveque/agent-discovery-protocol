{
  "name": "project_envvar_delete",
  "description": "Delete an environment variable.",
  "resource_group": "projects",
  "endpoint": "/project/{project-slug}/envvar/{name}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Variable name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/envvar/MY_VAR"
  },
  "response_example": {
    "message": "Deleted."
  }
}
