{
  "name": "job_tests_list",
  "description": "List test results for a job.",
  "resource_group": "jobs",
  "endpoint": "/project/{project-slug}/{job-number}/tests",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    },
    {
      "name": "job-number",
      "type": "integer",
      "required": true,
      "description": "Job number.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/42/tests"
  },
  "response_example": {
    "items": [
      {
        "name": "test_login",
        "classname": "AuthTests",
        "result": "success",
        "run_time": 0.5
      }
    ]
  }
}
