{
  "name": "job_cancel",
  "description": "Cancel a running job.",
  "resource_group": "jobs",
  "endpoint": "/project/{project-slug}/job/{job-number}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "body"
    },
    {
      "name": "job-number",
      "type": "integer",
      "required": true,
      "description": "Job number.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/job/42/cancel"
  },
  "response_example": {
    "message": "Accepted."
  }
}
