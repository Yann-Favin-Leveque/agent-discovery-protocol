{
  "name": "pipeline_list",
  "description": "List pipelines for a project.",
  "resource_group": "pipelines",
  "endpoint": "/project/{project-slug}/pipeline",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    },
    {
      "name": "branch",
      "type": "string",
      "required": false,
      "description": "Branch filter.",
      "in": "query"
    },
    {
      "name": "page-token",
      "type": "string",
      "required": false,
      "description": "Pagination.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/pipeline"
  },
  "response_example": {
    "items": [
      {
        "id": "pipeline-abc",
        "number": 42,
        "state": "created"
      }
    ],
    "next_page_token": "tok-123"
  }
}
