{
  "name": "workflow_list",
  "description": "List workflows for a pipeline.",
  "resource_group": "workflows",
  "endpoint": "/pipeline/{pipeline-id}/workflow",
  "method": "GET",
  "parameters": [
    {
      "name": "pipeline-id",
      "type": "string",
      "required": true,
      "description": "Pipeline ID."
    },
    {
      "name": "page-token",
      "type": "string",
      "required": false,
      "description": "Pagination."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/pipeline/pipeline-abc/workflow"
  },
  "response_example": {
    "items": [
      {
        "id": "wf-abc",
        "name": "build-and-test",
        "status": "success"
      }
    ]
  }
}