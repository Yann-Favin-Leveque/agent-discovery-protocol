{
  "name": "webhook_list",
  "description": "List webhooks.",
  "resource_group": "webhooks",
  "endpoint": "/webhook",
  "method": "GET",
  "parameters": [
    {
      "name": "scope-id",
      "type": "string",
      "required": true,
      "description": "Scope ID (project ID).",
      "in": "query"
    },
    {
      "name": "scope-type",
      "type": "string",
      "required": true,
      "description": "project.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/webhook?scope-id=proj-abc&scope-type=project"
  },
  "response_example": {
    "items": [
      {
        "id": "wh-abc",
        "name": "deploy-hook",
        "url": "https://example.com/hook"
      }
    ]
  }
}
