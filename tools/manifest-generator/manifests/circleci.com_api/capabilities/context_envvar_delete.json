{
  "name": "context_envvar_delete",
  "description": "Delete env var from context.",
  "resource_group": "contexts",
  "endpoint": "/context/{context-id}/environment-variable/{env-var-name}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "context-id",
      "type": "string",
      "required": true,
      "description": "Context ID.",
      "in": "query"
    },
    {
      "name": "env-var-name",
      "type": "string",
      "required": true,
      "description": "Variable name.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://circleci.com/api/v2/context/ctx-abc/environment-variable/MY_SECRET"
  },
  "response_example": {
    "message": "Deleted."
  }
}
