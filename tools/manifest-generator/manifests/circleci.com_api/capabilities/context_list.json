{
  "name": "context_list",
  "description": "List contexts for an organization.",
  "resource_group": "contexts",
  "endpoint": "/context",
  "method": "GET",
  "parameters": [
    {
      "name": "owner-slug",
      "type": "string",
      "required": true,
      "description": "Owner slug: gh/org."
    },
    {
      "name": "owner-type",
      "type": "string",
      "required": false,
      "description": "account or organization."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/context?owner-slug=gh/my-org"
  },
  "response_example": {
    "items": [
      {
        "id": "ctx-abc",
        "name": "production"
      }
    ]
  }
}