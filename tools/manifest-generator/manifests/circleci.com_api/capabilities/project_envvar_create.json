{
  "name": "project_envvar_create",
  "description": "Create an environment variable.",
  "resource_group": "projects",
  "endpoint": "/project/{project-slug}/envvar",
  "method": "POST",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug."
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Variable name."
    },
    {
      "name": "value",
      "type": "string",
      "required": true,
      "description": "Value."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/envvar",
    "body": {
      "name": "MY_VAR",
      "value": "my-value"
    }
  },
  "response_example": {
    "name": "MY_VAR",
    "value": "xxxx...alue"
  }
}