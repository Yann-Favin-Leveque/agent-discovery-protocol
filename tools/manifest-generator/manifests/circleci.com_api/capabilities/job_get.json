{
  "name": "job_get",
  "description": "Get job details.",
  "resource_group": "jobs",
  "endpoint": "/project/{project-slug}/job/{job-number}",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    },
    {
      "name": "job-number",
      "type": "integer",
      "required": true,
      "description": "Job number.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/job/42"
  },
  "response_example": {
    "name": "build",
    "status": "success",
    "duration": 120,
    "started_at": "2026-01-20T14:00:00Z"
  }
}
