{
  "name": "job",
  "description": "Manage job — cancel job by job id, cancel job by job number, get job details. Supports standard CRUD operations through the REST API.",
  "endpoint": "/jobs/{job-id}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "job-id",
      "type": "string",
      "description": "The unique ID of the job.",
      "required": true,
      "example": "abc_123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/jobs/{job-id}/cancel",
    "headers": {
      "Content-Type": "application/json",
      "Circle-Token": "{api_key}"
    },
    "body": {
      "job-id": "abc_123"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "job-id": "abc_123"
      }
    }
  }
}
