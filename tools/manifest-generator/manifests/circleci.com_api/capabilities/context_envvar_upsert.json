{
  "name": "context_envvar_upsert",
  "description": "Add/update env var in context.",
  "resource_group": "contexts",
  "endpoint": "/context/{context-id}/environment-variable/{env-var-name}",
  "method": "PUT",
  "parameters": [
    {
      "name": "context-id",
      "type": "string",
      "required": true,
      "description": "Context ID.",
      "in": "body"
    },
    {
      "name": "env-var-name",
      "type": "string",
      "required": true,
      "description": "Variable name.",
      "in": "body"
    },
    {
      "name": "value",
      "type": "string",
      "required": true,
      "description": "Value.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://circleci.com/api/v2/context/ctx-abc/environment-variable/MY_SECRET",
    "body": {
      "value": "secret"
    }
  },
  "response_example": {
    "variable": "MY_SECRET",
    "context_id": "ctx-abc"
  }
}
