{
  "name": "organization",
  "description": "Manage organization — create a new organization, create a new url orb allow-list entry, get an organization. Supports standard CRUD operations through the REST API.",
  "endpoint": "/organization",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "The name of the organization.",
      "required": true,
      "example": "Example"
    },
    {
      "name": "vcs_type",
      "type": "string",
      "description": "The version control system type for the organization.",
      "required": true,
      "example": "github"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/organization",
    "headers": {
      "Content-Type": "application/json",
      "Circle-Token": "{api_key}"
    },
    "body": {
      "name": "Example",
      "vcs_type": "github"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "name": "Example",
        "vcs_type": "github"
      }
    }
  }
}
