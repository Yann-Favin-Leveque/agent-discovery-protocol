{
  "name": "context_create",
  "description": "Create a context.",
  "resource_group": "contexts",
  "endpoint": "/context",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Context name.",
      "in": "body"
    },
    {
      "name": "owner",
      "type": "object",
      "required": true,
      "description": "Owner: {slug, type}.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/context",
    "body": {
      "name": "staging",
      "owner": {
        "slug": "gh/my-org",
        "type": "organization"
      }
    }
  },
  "response_example": {
    "id": "ctx-new",
    "name": "staging"
  }
}
