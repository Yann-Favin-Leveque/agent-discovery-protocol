{
  "name": "schedule_create",
  "description": "Create a schedule trigger.",
  "resource_group": "schedules",
  "endpoint": "/project/{project-slug}/schedule",
  "method": "POST",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "body"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Name.",
      "in": "body"
    },
    {
      "name": "timetable",
      "type": "object",
      "required": true,
      "description": "Cron schedule.",
      "in": "body"
    },
    {
      "name": "attribution-actor",
      "type": "string",
      "required": true,
      "description": "current or system.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/project/gh/my-org/my-repo/schedule",
    "body": {
      "name": "nightly",
      "timetable": {
        "per-hour": 1,
        "hours-of-day": [
          2
        ],
        "days-of-week": [
          "MON",
          "TUE",
          "WED",
          "THU",
          "FRI"
        ]
      },
      "attribution-actor": "current"
    }
  },
  "response_example": {
    "id": "sched-new",
    "name": "nightly"
  }
}
