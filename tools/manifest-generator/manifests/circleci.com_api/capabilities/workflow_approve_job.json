{
  "name": "workflow_approve_job",
  "description": "Approve a pending approval job.",
  "resource_group": "workflows",
  "endpoint": "/workflow/{id}/approve/{approval_request_id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Workflow ID.",
      "in": "path"
    },
    {
      "name": "approval_request_id",
      "type": "string",
      "required": true,
      "description": "Approval request ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://circleci.com/api/v2/workflow/wf-abc/approve/apr-abc"
  },
  "response_example": {
    "message": "Approved."
  }
}
