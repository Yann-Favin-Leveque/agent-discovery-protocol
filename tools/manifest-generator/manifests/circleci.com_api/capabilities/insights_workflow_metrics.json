{
  "name": "insights_workflow_metrics",
  "description": "Get workflow metrics.",
  "resource_group": "insights",
  "endpoint": "/insights/{project-slug}/workflows",
  "method": "GET",
  "parameters": [
    {
      "name": "project-slug",
      "type": "string",
      "required": true,
      "description": "Project slug.",
      "in": "query"
    },
    {
      "name": "branch",
      "type": "string",
      "required": false,
      "description": "Branch filter.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://circleci.com/api/v2/insights/gh/my-org/my-repo/workflows"
  },
  "response_example": {
    "items": [
      {
        "name": "build-and-test",
        "metrics": {
          "total_runs": 100,
          "successful_runs": 92,
          "success_rate": 0.92
        }
      }
    ]
  }
}
