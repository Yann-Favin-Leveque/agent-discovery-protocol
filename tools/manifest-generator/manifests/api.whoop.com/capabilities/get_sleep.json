{
  "name": "get_sleep",
  "description": "Retrieve sleep performance data for the authenticated user. Each sleep record includes start and end times, whether it was a nap, sleep stage durations (wake, light, SWS/deep, REM), sleep needed, respiratory rate, sleep efficiency, and an overall sleep performance percentage.",
  "endpoint": "/developer/v1/activity/sleep",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "string",
      "description": "Start datetime in ISO 8601 format to filter results.",
      "required": false,
      "example": "2024-01-01T00:00:00.000Z"
    },
    {
      "name": "end",
      "type": "string",
      "description": "End datetime in ISO 8601 format to filter results.",
      "required": false,
      "example": "2024-01-07T23:59:59.000Z"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of records to return per page.",
      "required": false,
      "example": 25
    },
    {
      "name": "nextToken",
      "type": "string",
      "description": "Pagination token for retrieving the next page of results.",
      "required": false,
      "example": null
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/activity/sleep?start=2024-01-01T00:00:00.000Z&end=2024-01-07T23:59:59.000Z&limit=25",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "records": [
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "user_id": 98765,
          "cycle_id": 12345678,
          "created_at": "2024-01-02T07:30:00.000Z",
          "start": "2024-01-01T23:00:00.000Z",
          "end": "2024-01-02T07:15:00.000Z",
          "timezone_offset": "-05:00",
          "nap": false,
          "score_state": "SCORED",
          "score": {
            "stage_summary": {
              "total_in_bed_time_milli": 29700000,
              "total_awake_time_milli": 2700000,
              "total_light_sleep_time_milli": 12600000,
              "total_slow_wave_sleep_time_milli": 5400000,
              "total_rem_sleep_time_milli": 7200000,
              "total_no_data_time_milli": 0,
              "sleep_cycle_count": 4,
              "disturbance_count": 6
            },
            "sleep_needed": {
              "baseline_milli": 28800000,
              "need_from_sleep_debt_milli": 3600000,
              "need_from_recent_strain_milli": 1800000
            },
            "respiratory_rate": 15.4,
            "sleep_performance_percentage": 88.0,
            "sleep_consistency_percentage": 82.0,
            "sleep_efficiency_percentage": 91.0
          }
        }
      ],
      "next_token": null
    }
  }
}
