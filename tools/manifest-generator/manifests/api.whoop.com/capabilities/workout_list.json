{
  "name": "workout_list",
  "description": "Retrieve all workouts with sport type, strain score, heart rate zones, calories burned, and distance. Sorted by start time descending.",
  "resource_group": "workout",
  "endpoint": "/developer/v1/activity/workout",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results per page (default 10, max 25).",
      "in": "query"
    },
    {
      "name": "start",
      "type": "string",
      "required": false,
      "description": "Return workouts after this ISO 8601 datetime.",
      "in": "query"
    },
    {
      "name": "end",
      "type": "string",
      "required": false,
      "description": "Return workouts before this ISO 8601 datetime.",
      "in": "query"
    },
    {
      "name": "nextToken",
      "type": "string",
      "required": false,
      "description": "Pagination token.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read:workout"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/activity/workout?start=2025-01-10T00:00:00.000Z&end=2025-01-15T23:59:59.000Z",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "records": [
        {
          "id": 98765,
          "user_id": 67890,
          "created_at": "2025-01-15T08:30:00.000Z",
          "start": "2025-01-15T07:30:00.000Z",
          "end": "2025-01-15T08:15:00.000Z",
          "timezone_offset": "-05:00",
          "sport_id": 1,
          "score_state": "SCORED",
          "score": {
            "strain": 14.2,
            "average_heart_rate": 152,
            "max_heart_rate": 178,
            "kilojoule": 1850,
            "percent_recorded": 100,
            "distance_meter": 5200,
            "altitude_gain_meter": 45,
            "altitude_change_meter": 12,
            "zone_duration": {
              "zone_zero_milli": 60000,
              "zone_one_milli": 300000,
              "zone_two_milli": 900000,
              "zone_three_milli": 1200000,
              "zone_four_milli": 600000,
              "zone_five_milli": 240000
            }
          }
        }
      ],
      "next_token": null
    }
  }
}