{
  "name": "get_workouts",
  "description": "Retrieve workout sessions logged by the WHOOP strap. Each workout includes sport type, strain score, average and max heart rate, calories burned (kilojoules), distance, altitude gain, and time spent in each heart rate zone. Supports over 100 sport types.",
  "endpoint": "/developer/v1/activity/workout",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "string",
      "description": "Start datetime in ISO 8601 format to filter results.",
      "required": false,
      "example": "2024-01-01T00:00:00.000Z"
    },
    {
      "name": "end",
      "type": "string",
      "description": "End datetime in ISO 8601 format to filter results.",
      "required": false,
      "example": "2024-01-07T23:59:59.000Z"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of records to return per page.",
      "required": false,
      "example": 25
    },
    {
      "name": "nextToken",
      "type": "string",
      "description": "Pagination token for retrieving the next page of results.",
      "required": false,
      "example": null
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/activity/workout?start=2024-01-01T00:00:00.000Z&end=2024-01-07T23:59:59.000Z&limit=25",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "records": [
        {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "user_id": 98765,
          "sport_id": 1,
          "sport_name": "Running",
          "start": "2024-01-03T08:00:00.000Z",
          "end": "2024-01-03T08:45:00.000Z",
          "timezone_offset": "-05:00",
          "score_state": "SCORED",
          "score": {
            "strain": 14.2,
            "average_heart_rate": 152,
            "max_heart_rate": 178,
            "kilojoule": 2800.0,
            "distance_meter": 7500.0,
            "altitude_gain_meter": 45.0,
            "percent_recorded": 100.0,
            "zone_durations": {
              "zone_zero_milli": 0,
              "zone_one_milli": 300000,
              "zone_two_milli": 900000,
              "zone_three_milli": 1200000,
              "zone_four_milli": 300000,
              "zone_five_milli": 0
            }
          }
        }
      ],
      "next_token": null
    }
  }
}
