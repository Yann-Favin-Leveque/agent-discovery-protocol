{
  "name": "cycle_get",
  "description": "Retrieve a single physiological cycle by its ID.",
  "resource_group": "cycle",
  "endpoint": "/developer/v1/cycle/{cycleId}",
  "method": "GET",
  "parameters": [
    {
      "name": "cycleId",
      "type": "integer",
      "required": true,
      "description": "The cycle ID.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read:cycles"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/cycle/12345",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 12345,
      "start": "2025-01-15T07:00:00.000Z",
      "end": "2025-01-16T06:45:00.000Z",
      "score_state": "SCORED",
      "score": {
        "strain": 12.5,
        "kilojoule": 8500,
        "average_heart_rate": 72,
        "max_heart_rate": 175
      }
    }
  }
}