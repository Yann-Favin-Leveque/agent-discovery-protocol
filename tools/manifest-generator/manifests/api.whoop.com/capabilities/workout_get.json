{
  "name": "workout_get",
  "description": "Retrieve a single workout by its ID.",
  "resource_group": "workout",
  "endpoint": "/developer/v1/activity/workout/{workoutId}",
  "method": "GET",
  "parameters": [
    {
      "name": "workoutId",
      "type": "integer",
      "required": true,
      "description": "The workout ID.",
      "in": "path"
    }
  ],
  "auth_scopes": [
    "read:workout"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/activity/workout/98765",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 98765,
      "sport_id": 1,
      "start": "2025-01-15T07:30:00.000Z",
      "end": "2025-01-15T08:15:00.000Z",
      "score": {
        "strain": 14.2,
        "average_heart_rate": 152,
        "max_heart_rate": 178,
        "kilojoule": 1850,
        "distance_meter": 5200
      }
    }
  }
}