{
  "name": "cycle_list",
  "description": "Retrieve all physiological cycles for the user. A cycle represents a full day of data from wake to wake, linking strain, recovery, and sleep. Results are paginated and sorted by start time descending.",
  "resource_group": "cycle",
  "endpoint": "/developer/v1/cycle",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results per page (default 10, max 25).",
      "in": "query"
    },
    {
      "name": "start",
      "type": "string",
      "required": false,
      "description": "Return cycles starting after this ISO 8601 datetime.",
      "in": "query"
    },
    {
      "name": "end",
      "type": "string",
      "required": false,
      "description": "Return cycles starting before this ISO 8601 datetime.",
      "in": "query"
    },
    {
      "name": "nextToken",
      "type": "string",
      "required": false,
      "description": "Pagination token from previous response.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read:cycles"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/cycle?start=2025-01-10T00:00:00.000Z&end=2025-01-15T23:59:59.000Z&limit=10",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "records": [
        {
          "id": 12345,
          "user_id": 67890,
          "created_at": "2025-01-15T07:00:00.000Z",
          "updated_at": "2025-01-15T22:00:00.000Z",
          "start": "2025-01-15T07:00:00.000Z",
          "end": "2025-01-16T06:45:00.000Z",
          "timezone_offset": "-05:00",
          "score_state": "SCORED",
          "score": {
            "strain": 12.5,
            "kilojoule": 8500,
            "average_heart_rate": 72,
            "max_heart_rate": 175
          }
        }
      ],
      "next_token": null
    }
  }
}