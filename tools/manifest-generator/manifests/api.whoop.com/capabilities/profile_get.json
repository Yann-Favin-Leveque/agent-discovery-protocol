{
  "name": "profile_get",
  "description": "Retrieve the authenticated user's WHOOP profile including name, email, and user ID.",
  "resource_group": "user",
  "endpoint": "/developer/v1/user/profile/basic",
  "method": "GET",
  "parameters": [],
  "auth_scopes": [
    "read:profile"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/user/profile/basic",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "user_id": 67890,
      "email": "user@example.com",
      "first_name": "Jane",
      "last_name": "Doe"
    }
  }
}