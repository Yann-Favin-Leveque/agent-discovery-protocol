{
  "name": "recovery_list",
  "description": "Retrieve all recovery scores for the user. Recovery indicates how prepared the body is for strain, based on HRV, resting heart rate, SpO2, and skin temperature.",
  "resource_group": "recovery",
  "endpoint": "/developer/v1/recovery",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results per page (default 10, max 25).",
      "in": "query"
    },
    {
      "name": "start",
      "type": "string",
      "required": false,
      "description": "Return recoveries after this ISO 8601 datetime.",
      "in": "query"
    },
    {
      "name": "end",
      "type": "string",
      "required": false,
      "description": "Return recoveries before this ISO 8601 datetime.",
      "in": "query"
    },
    {
      "name": "nextToken",
      "type": "string",
      "required": false,
      "description": "Pagination token.",
      "in": "query"
    }
  ],
  "auth_scopes": [
    "read:recovery"
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.prod.whoop.com/developer/v1/recovery?start=2025-01-10T00:00:00.000Z&end=2025-01-15T23:59:59.000Z",
    "headers": {
      "Authorization": "Bearer TOKEN"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "records": [
        {
          "cycle_id": 12345,
          "sleep_id": 54321,
          "user_id": 67890,
          "created_at": "2025-01-15T07:05:00.000Z",
          "score_state": "SCORED",
          "score": {
            "user_calibrating": false,
            "recovery_score": 78,
            "resting_heart_rate": 52,
            "hrv_rmssd_milli": 45.2,
            "spo2_percentage": 96.5,
            "skin_temp_celsius": 33.8
          }
        }
      ],
      "next_token": null
    }
  }
}