{
  "name": "incidents_notes_create",
  "description": "Add a note to an incident.",
  "resource_group": "incidents",
  "endpoint": "/incidents/{incident_id}/notes",
  "method": "POST",
  "parameters": [
    {
      "name": "incident_id",
      "type": "string",
      "required": true,
      "description": "Incident ID",
      "location": "path"
    },
    {
      "name": "note",
      "type": "object",
      "required": true,
      "description": "Note with content"
    }
  ],
  "request_example": {
    "note": {
      "content": "Root cause identified: memory leak in v2.3"
    }
  },
  "response_example": {
    "note": {
      "id": "N456",
      "content": "Root cause identified: memory leak in v2.3"
    }
  },
  "auth_scopes": []
}
