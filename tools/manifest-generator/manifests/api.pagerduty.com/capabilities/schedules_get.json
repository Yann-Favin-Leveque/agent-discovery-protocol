{
  "name": "schedules_get",
  "description": "Get a specific schedule with on-call entries.",
  "resource_group": "schedules",
  "endpoint": "/schedules/{schedule_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "schedule_id",
      "type": "string",
      "required": true,
      "description": "Schedule ID",
      "location": "path"
    },
    {
      "name": "since",
      "type": "string",
      "required": false,
      "description": "Start of on-call window",
      "location": "query"
    },
    {
      "name": "until",
      "type": "string",
      "required": false,
      "description": "End of on-call window",
      "location": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "schedule": {
      "id": "PSCHED",
      "name": "Primary On-Call",
      "final_schedule": {
        "rendered_schedule_entries": []
      }
    }
  },
  "auth_scopes": []
}
