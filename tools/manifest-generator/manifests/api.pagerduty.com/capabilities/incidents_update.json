{
  "name": "incidents_update",
  "description": "Update an existing incident (acknowledge, resolve, etc.).",
  "resource_group": "incidents",
  "endpoint": "/incidents/{incident_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "incident_id",
      "type": "string",
      "required": true,
      "description": "Incident ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "incident",
      "type": "object",
      "required": true,
      "description": "Updated incident fields (status, priority, etc.)",
      "in": "body"
    }
  ],
  "request_example": {
    "incident": {
      "type": "incident_reference",
      "status": "acknowledged"
    }
  },
  "response_example": {
    "incident": {
      "id": "P123",
      "status": "acknowledged"
    }
  },
  "auth_scopes": []
}
