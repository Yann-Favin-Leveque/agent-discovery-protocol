{
  "name": "escalation_policies_update",
  "description": "Update an existing escalation policy.",
  "resource_group": "escalation_policies",
  "endpoint": "/escalation_policies/{policy_id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "policy_id",
      "type": "string",
      "required": true,
      "description": "Policy ID",
      "location": "path",
      "in": "path"
    },
    {
      "name": "escalation_policy",
      "type": "object",
      "required": true,
      "description": "Updated policy",
      "in": "body"
    }
  ],
  "request_example": {
    "escalation_policy": {
      "type": "escalation_policy",
      "name": "Urgent v2"
    }
  },
  "response_example": {
    "escalation_policy": {
      "id": "PPOL2"
    }
  },
  "auth_scopes": []
}
