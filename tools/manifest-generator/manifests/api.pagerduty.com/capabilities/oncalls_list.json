{
  "name": "oncalls_list",
  "description": "List who is currently on call across all escalation policies.",
  "resource_group": "oncalls",
  "endpoint": "/oncalls",
  "method": "GET",
  "parameters": [
    {
      "name": "schedule_ids[]",
      "type": "string",
      "required": false,
      "description": "Filter by schedule IDs",
      "location": "query"
    },
    {
      "name": "escalation_policy_ids[]",
      "type": "string",
      "required": false,
      "description": "Filter by escalation policy IDs",
      "location": "query"
    },
    {
      "name": "since",
      "type": "string",
      "required": false,
      "description": "Start time",
      "location": "query"
    },
    {
      "name": "until",
      "type": "string",
      "required": false,
      "description": "End time",
      "location": "query"
    }
  ],
  "request_example": {},
  "response_example": {
    "oncalls": [
      {
        "user": {
          "id": "PUSER",
          "summary": "John Smith"
        },
        "schedule": {
          "id": "PSCHED"
        },
        "escalation_level": 1
      }
    ]
  },
  "auth_scopes": []
}
