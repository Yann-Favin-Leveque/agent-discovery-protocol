{
  "name": "services_create",
  "description": "Create a new service with escalation policy.",
  "resource_group": "services",
  "endpoint": "/services",
  "method": "POST",
  "parameters": [
    {
      "name": "service",
      "type": "object",
      "required": true,
      "description": "Service with name, escalation_policy, alert_creation",
      "in": "body"
    }
  ],
  "request_example": {
    "service": {
      "type": "service",
      "name": "API Service",
      "escalation_policy": {
        "id": "PPOL",
        "type": "escalation_policy_reference"
      },
      "alert_creation": "create_alerts_and_incidents"
    }
  },
  "response_example": {
    "service": {
      "id": "PSVC2",
      "name": "API Service"
    }
  },
  "auth_scopes": []
}
