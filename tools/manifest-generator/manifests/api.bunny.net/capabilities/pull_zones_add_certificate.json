{
  "name": "pull_zones_add_certificate",
  "resource_group": "pull_zones",
  "description": "Load a free Let's Encrypt SSL certificate for a hostname.",
  "endpoint": "/pullzone/{id}/loadFreeCertificate",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Pull zone ID.",
      "in": "path"
    },
    {
      "name": "hostname",
      "type": "string",
      "required": true,
      "description": "Hostname to issue certificate for."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/pullzone/12345/loadFreeCertificate?hostname=cdn.example.com",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  }
}