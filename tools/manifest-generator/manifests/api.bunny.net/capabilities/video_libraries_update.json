{
  "name": "video_libraries_update",
  "resource_group": "video",
  "description": "Update video library settings.",
  "endpoint": "/videolibrary/{id}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Library ID.",
      "in": "path"
    },
    {
      "name": "Name",
      "type": "string",
      "required": false,
      "description": "Updated name.",
      "in": "body"
    },
    {
      "name": "EnabledResolutions",
      "type": "string",
      "required": false,
      "description": "Enabled resolutions CSV.",
      "in": "body"
    },
    {
      "name": "WatermarkPositionLeft",
      "type": "integer",
      "required": false,
      "description": "Watermark X position.",
      "in": "body"
    },
    {
      "name": "WatermarkPositionTop",
      "type": "integer",
      "required": false,
      "description": "Watermark Y position.",
      "in": "body"
    },
    {
      "name": "EnableMP4Fallback",
      "type": "boolean",
      "required": false,
      "description": "Enable MP4 fallback.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/videolibrary/222",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "Name": "My Updated Videos",
      "EnableMP4Fallback": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Id": 222,
      "Name": "My Updated Videos"
    }
  }
}
