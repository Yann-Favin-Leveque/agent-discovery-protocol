{
  "name": "stream_videos_get",
  "resource_group": "stream",
  "description": "Get video details.",
  "endpoint": "/library/{libraryId}/videos/{videoId}",
  "method": "GET",
  "parameters": [
    {
      "name": "libraryId",
      "type": "integer",
      "required": true,
      "description": "Library ID.",
      "in": "path"
    },
    {
      "name": "videoId",
      "type": "string",
      "required": true,
      "description": "Video GUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/library/222/videos/video-guid",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "videoLibraryId": 222,
      "guid": "video-guid",
      "title": "My Video",
      "status": 4,
      "length": 120,
      "width": 1920,
      "height": 1080
    }
  }
}