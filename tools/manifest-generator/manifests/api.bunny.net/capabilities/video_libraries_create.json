{
  "name": "video_libraries_create",
  "resource_group": "video",
  "description": "Create a new video library.",
  "endpoint": "/videolibrary",
  "method": "POST",
  "parameters": [
    {
      "name": "Name",
      "type": "string",
      "required": true,
      "description": "Library name.",
      "in": "body"
    },
    {
      "name": "ReplicationRegions",
      "type": "array",
      "required": false,
      "description": "Replication regions.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/videolibrary",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "Name": "My Videos"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "Id": 222,
      "Name": "My Videos",
      "ApiKey": "library-api-key"
    }
  }
}
