{
  "name": "stream_videos_fetch",
  "resource_group": "stream",
  "description": "Import a video from an external URL.",
  "endpoint": "/library/{libraryId}/videos/{videoId}/fetch",
  "method": "POST",
  "parameters": [
    {
      "name": "libraryId",
      "type": "integer",
      "required": true,
      "description": "Library ID.",
      "in": "path"
    },
    {
      "name": "videoId",
      "type": "string",
      "required": true,
      "description": "Video GUID.",
      "in": "path"
    },
    {
      "name": "url",
      "type": "string",
      "required": true,
      "description": "URL of the video to fetch."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/library/222/videos/video-guid/fetch",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://example.com/video.mp4"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}