{
  "name": "dns_zones_get",
  "resource_group": "dns",
  "description": "Get a DNS zone with all records.",
  "endpoint": "/dnszone/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "DNS zone ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/dnszone/111",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Id": 111,
      "Domain": "example.com",
      "Records": [
        {
          "Id": 1,
          "Type": 1,
          "Name": "",
          "Value": "1.2.3.4",
          "Ttl": 300
        }
      ]
    }
  }
}