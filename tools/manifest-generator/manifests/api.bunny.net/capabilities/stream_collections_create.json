{
  "name": "stream_collections_create",
  "resource_group": "stream",
  "description": "Create a new video collection.",
  "endpoint": "/library/{libraryId}/collections",
  "method": "POST",
  "parameters": [
    {
      "name": "libraryId",
      "type": "integer",
      "required": true,
      "description": "Library ID.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Collection name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/library/222/collections",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Tutorials"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "videoLibraryId": 222,
      "guid": "new-collection-guid",
      "name": "Tutorials"
    }
  }
}