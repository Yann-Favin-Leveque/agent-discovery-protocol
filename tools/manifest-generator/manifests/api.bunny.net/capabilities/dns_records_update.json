{
  "name": "dns_records_update",
  "resource_group": "dns",
  "description": "Update an existing DNS record.",
  "endpoint": "/dnszone/{id}/records/{recordId}",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "DNS zone ID.",
      "in": "path"
    },
    {
      "name": "recordId",
      "type": "integer",
      "required": true,
      "description": "DNS record ID.",
      "in": "path"
    },
    {
      "name": "Value",
      "type": "string",
      "required": false,
      "description": "Updated value.",
      "in": "body"
    },
    {
      "name": "Ttl",
      "type": "integer",
      "required": false,
      "description": "Updated TTL.",
      "in": "body"
    },
    {
      "name": "Priority",
      "type": "integer",
      "required": false,
      "description": "Updated priority.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/dnszone/111/records/2",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "Value": "5.6.7.8",
      "Ttl": 600
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
