{
  "name": "list_pull_zones",
  "description": "Retrieve a list of all CDN pull zones in your account with their configuration, traffic stats, and status.",
  "endpoint": "/pullzone",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "The page number to return.",
      "required": false,
      "example": 1
    },
    {
      "name": "perPage",
      "type": "integer",
      "description": "The number of results per page. Maximum is 1000.",
      "required": false,
      "example": 100
    },
    {
      "name": "search",
      "type": "string",
      "description": "Search term to filter pull zones by name.",
      "required": false,
      "example": "my-website"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/pullzone?page=1&perPage=100",
    "headers": {
      "AccessKey": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Items": [
        {
          "Id": 123456,
          "Name": "my-website-cdn",
          "OriginUrl": "https://origin.example.com",
          "Enabled": true,
          "MonthlyBandwidthUsed": 1073741824,
          "Hostnames": [
            { "Id": 1, "Value": "my-website-cdn.b-cdn.net" }
          ]
        }
      ],
      "TotalItems": 1,
      "CurrentPage": 1
    }
  }
}
