{
  "name": "video_libraries_get",
  "resource_group": "video",
  "description": "Get video library details.",
  "endpoint": "/videolibrary/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Library ID.",
      "in": "path"
    },
    {
      "name": "includeSensitiveData",
      "type": "boolean",
      "required": false,
      "description": "Include API keys in response."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/videolibrary/222",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Id": 222,
      "Name": "My Videos",
      "VideoCount": 50
    }
  }
}