{
  "name": "storage_zones_get",
  "resource_group": "storage_zones",
  "description": "Get storage zone details.",
  "endpoint": "/storagezone/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Storage zone ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/storagezone/67890",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Id": 67890,
      "Name": "my-storage",
      "StorageUsed": 5368709120,
      "FilesStored": 1500
    }
  }
}