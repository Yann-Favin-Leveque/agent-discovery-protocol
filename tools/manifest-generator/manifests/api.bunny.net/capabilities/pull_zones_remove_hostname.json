{
  "name": "pull_zones_remove_hostname",
  "resource_group": "pull_zones",
  "description": "Remove a custom hostname from a pull zone.",
  "endpoint": "/pullzone/{id}/removeHostname",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Pull zone ID.",
      "in": "path"
    },
    {
      "name": "Hostname",
      "type": "string",
      "required": true,
      "description": "Hostname to remove."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.bunny.net/pullzone/12345/removeHostname?Hostname=cdn.example.com",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}