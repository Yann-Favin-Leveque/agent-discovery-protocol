{
  "name": "video_libraries_list",
  "resource_group": "video",
  "description": "List all video libraries.",
  "endpoint": "/videolibrary",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "perPage",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "search",
      "type": "string",
      "required": false,
      "description": "Search by name.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/videolibrary",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Items": [
        {
          "Id": 222,
          "Name": "My Videos",
          "VideoCount": 50,
          "StorageUsage": 10737418240
        }
      ],
      "TotalItems": 1
    }
  }
}
