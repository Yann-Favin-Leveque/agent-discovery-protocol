{
  "name": "stream_videos_update",
  "resource_group": "stream",
  "description": "Update video metadata.",
  "endpoint": "/library/{libraryId}/videos/{videoId}",
  "method": "POST",
  "parameters": [
    {
      "name": "libraryId",
      "type": "integer",
      "required": true,
      "description": "Library ID.",
      "in": "path"
    },
    {
      "name": "videoId",
      "type": "string",
      "required": true,
      "description": "Video GUID.",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Updated title."
    },
    {
      "name": "collectionId",
      "type": "string",
      "required": false,
      "description": "Updated collection."
    },
    {
      "name": "chapters",
      "type": "array",
      "required": false,
      "description": "Video chapters."
    },
    {
      "name": "moments",
      "type": "array",
      "required": false,
      "description": "Video moments."
    },
    {
      "name": "metaTags",
      "type": "array",
      "required": false,
      "description": "Meta tags."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/library/222/videos/video-guid",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "title": "Updated Video Title"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "guid": "video-guid",
      "title": "Updated Video Title"
    }
  }
}