{
  "name": "pull_zones_get",
  "resource_group": "pull_zones",
  "description": "Get details of a specific pull zone.",
  "endpoint": "/pullzone/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Pull zone ID.",
      "in": "path"
    },
    {
      "name": "includeCertificate",
      "type": "boolean",
      "required": false,
      "description": "Include SSL cert info.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/pullzone/12345",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Id": 12345,
      "Name": "my-zone",
      "OriginUrl": "https://origin.example.com",
      "CacheControlMaxAgeOverride": 86400,
      "EnableSmartCache": true
    }
  }
}
