{
  "name": "pull_zones_add_hostname",
  "resource_group": "pull_zones",
  "description": "Add a custom hostname to a pull zone.",
  "endpoint": "/pullzone/{id}/addHostname",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Pull zone ID.",
      "in": "path"
    },
    {
      "name": "Hostname",
      "type": "string",
      "required": true,
      "description": "Custom hostname to add.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/pullzone/12345/addHostname",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "Hostname": "cdn.example.com"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
