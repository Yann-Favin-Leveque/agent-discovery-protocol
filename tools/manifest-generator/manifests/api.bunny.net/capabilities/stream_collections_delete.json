{
  "name": "stream_collections_delete",
  "resource_group": "stream",
  "description": "Delete a video collection.",
  "endpoint": "/library/{libraryId}/collections/{collectionId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "libraryId",
      "type": "integer",
      "required": true,
      "description": "Library ID.",
      "in": "path"
    },
    {
      "name": "collectionId",
      "type": "string",
      "required": true,
      "description": "Collection GUID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.bunny.net/library/222/collections/collection-guid",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true
    }
  }
}