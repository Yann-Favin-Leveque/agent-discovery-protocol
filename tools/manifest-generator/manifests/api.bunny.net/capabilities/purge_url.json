{
  "name": "purge_url",
  "resource_group": "purge",
  "description": "Purge a specific URL from the CDN cache.",
  "endpoint": "/purge",
  "method": "POST",
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "description": "Full URL to purge.",
      "in": "body"
    },
    {
      "name": "async",
      "type": "boolean",
      "required": false,
      "description": "Purge asynchronously.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/purge?url=https://cdn.example.com/image.jpg&async=false",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
