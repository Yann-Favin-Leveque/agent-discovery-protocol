{
  "name": "dns_zones_list",
  "resource_group": "dns",
  "description": "List all DNS zones.",
  "endpoint": "/dnszone",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number."
    },
    {
      "name": "perPage",
      "type": "integer",
      "required": false,
      "description": "Results per page."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/dnszone",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Items": [
        {
          "Id": 111,
          "Domain": "example.com",
          "Records": [
            {
              "Id": 1,
              "Type": 1,
              "Name": "",
              "Value": "1.2.3.4",
              "Ttl": 300
            }
          ]
        }
      ],
      "TotalItems": 1
    }
  }
}