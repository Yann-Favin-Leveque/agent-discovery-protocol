{
  "name": "dns_zones_create",
  "resource_group": "dns",
  "description": "Create a new DNS zone.",
  "endpoint": "/dnszone",
  "method": "POST",
  "parameters": [
    {
      "name": "Domain",
      "type": "string",
      "required": true,
      "description": "Domain name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.bunny.net/dnszone",
    "headers": {
      "AccessKey": "your-api-key",
      "Content-Type": "application/json"
    },
    "body": {
      "Domain": "example.com"
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "Id": 111,
      "Domain": "example.com",
      "Nameserver1": "ns1.bunny.net",
      "Nameserver2": "ns2.bunny.net"
    }
  }
}