{
  "name": "storage_zones_list",
  "resource_group": "storage_zones",
  "description": "List all edge storage zones.",
  "endpoint": "/storagezone",
  "method": "GET",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number.",
      "in": "query"
    },
    {
      "name": "perPage",
      "type": "integer",
      "required": false,
      "description": "Results per page.",
      "in": "query"
    },
    {
      "name": "includeDeleted",
      "type": "boolean",
      "required": false,
      "description": "Include deleted zones.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.bunny.net/storagezone",
    "headers": {
      "AccessKey": "your-api-key"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "Items": [
        {
          "Id": 67890,
          "Name": "my-storage",
          "StorageUsed": 5368709120,
          "FilesStored": 1500,
          "Region": "DE",
          "PullZones": [
            {
              "Id": 12345,
              "Name": "my-zone"
            }
          ]
        }
      ],
      "TotalItems": 2
    }
  }
}
