{
  "name": "manage_leads",
  "description": "Add leads to campaigns, update lead information, mark leads as interested or not interested, pause or resume leads, and manage custom variables. You can also import leads from your CRM and retrieve leads by email or campaign with state filtering.",
  "endpoint": "/api/campaigns/{campaign_id}/leads",
  "method": "POST",
  "parameters": [
    {
      "name": "campaign_id",
      "type": "string",
      "description": "The ID of the campaign to add the lead to.",
      "required": true,
      "example": "cam_abc123"
    },
    {
      "name": "email",
      "type": "string",
      "description": "The lead's email address.",
      "required": true,
      "example": "john@acmecorp.com"
    },
    {
      "name": "firstName",
      "type": "string",
      "description": "The lead's first name.",
      "required": false,
      "example": "John"
    },
    {
      "name": "lastName",
      "type": "string",
      "description": "The lead's last name.",
      "required": false,
      "example": "Smith"
    },
    {
      "name": "companyName",
      "type": "string",
      "description": "The lead's company name.",
      "required": false,
      "example": "Acme Corp"
    },
    {
      "name": "phone",
      "type": "string",
      "description": "The lead's phone number.",
      "required": false,
      "example": "+1-555-123-4567"
    },
    {
      "name": "linkedinUrl",
      "type": "string",
      "description": "URL to the lead's LinkedIn profile.",
      "required": false,
      "example": "https://linkedin.com/in/johnsmith"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/campaigns/cam_abc123/leads",
    "headers": {
      "Authorization": "Basic {base64_encoded_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "john@acmecorp.com",
      "firstName": "John",
      "lastName": "Smith",
      "companyName": "Acme Corp",
      "linkedinUrl": "https://linkedin.com/in/johnsmith"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "lea_xyz789",
      "email": "john@acmecorp.com",
      "firstName": "John",
      "lastName": "Smith",
      "companyName": "Acme Corp",
      "campaignId": "cam_abc123",
      "isInterested": false,
      "isPaused": false,
      "createdAt": "2026-03-01T12:00:00.000Z"
    }
  }
}
