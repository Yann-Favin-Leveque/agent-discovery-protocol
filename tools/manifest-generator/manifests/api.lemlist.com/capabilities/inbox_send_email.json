{
  "name": "inbox_send_email",
  "description": "Send an email through lemlist inbox.",
  "resource_group": "inbox",
  "endpoint": "/api/inbox/email",
  "method": "POST",
  "parameters": [
    {
      "name": "to",
      "type": "string",
      "description": "Recipient email.",
      "required": true
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Email subject.",
      "required": true
    },
    {
      "name": "html",
      "type": "string",
      "description": "HTML body.",
      "required": true
    },
    {
      "name": "from",
      "type": "string",
      "description": "Sender email.",
      "required": false
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/inbox/email",
    "headers": {
      "Authorization": "Basic {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "to": "lead@example.com",
      "subject": "Follow up",
      "html": "<p>Hello!</p>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sent": true
    }
  }
}