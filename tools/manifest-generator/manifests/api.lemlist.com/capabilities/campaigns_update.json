{
  "name": "campaigns_update",
  "description": "Update campaign settings.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns/{campaignId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.lemlist.com/api/campaigns/camp_1",
    "headers": {
      "Authorization": "Basic {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Updated Outreach"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "camp_1",
      "name": "Updated Outreach"
    }
  }
}
