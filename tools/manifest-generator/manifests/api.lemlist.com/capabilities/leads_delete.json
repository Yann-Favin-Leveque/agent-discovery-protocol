{
  "name": "leads_delete",
  "description": "Delete or unsubscribe a lead.",
  "resource_group": "leads",
  "endpoint": "/api/campaigns/{campaignId}/leads/{emailOrId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "emailOrId",
      "type": "string",
      "description": "Lead email or ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.lemlist.com/api/campaigns/camp_1/leads/lead@example.com",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}
