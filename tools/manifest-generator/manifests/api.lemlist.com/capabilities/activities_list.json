{
  "name": "activities_list",
  "description": "Get history of all campaign activities.",
  "resource_group": "activities",
  "endpoint": "/api/activities",
  "method": "GET",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Filter by campaign.",
      "required": false,
      "in": "query"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Filter by type: emailsSent, emailsOpened, etc.",
      "required": false,
      "in": "query"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/activities?type=emailsSent",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "_id": "act_1",
        "type": "emailsSent",
        "leadId": "lead_1",
        "campaignId": "camp_1"
      }
    ]
  }
}
