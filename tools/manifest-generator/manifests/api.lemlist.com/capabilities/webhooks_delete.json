  "parameters": [
    {
      "name": "hookId",
      "type": "string",
      "description": "Webhook ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.lemlist.com/api/hooks/hook_1",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}
