{
  "name": "enrichment_enrich",
  "description": "Enrich data by finding emails, phones, or LinkedIn info.",
  "resource_group": "enrichment",
  "endpoint": "/api/enrich",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Email to enrich.",
      "required": false,
      "in": "body"
    },
    {
      "name": "firstName",
      "type": "string",
      "description": "First name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "lastName",
      "type": "string",
      "description": "Last name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "companyName",
      "type": "string",
      "description": "Company name.",
      "required": false,
      "in": "body"
    },
    {
      "name": "linkedinUrl",
      "type": "string",
      "description": "LinkedIn profile URL.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/enrich",
    "headers": {
      "Authorization": "Basic {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "firstName": "John",
      "lastName": "Doe",
      "companyName": "Acme"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "email": "john.doe@acme.com",
      "phone": "+1234567890",
      "linkedinUrl": "https://linkedin.com/in/johndoe"
    }
  }
}
