{
  "name": "get_activities",
  "description": "Retrieve the history of all campaign activities and steps performed. Activities include email sends, opens, clicks, replies, bounces, and unsubscribes. Use this to monitor outreach progress and identify engaged prospects.",
  "endpoint": "/api/activities",
  "method": "GET",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Filter activities by campaign ID.",
      "required": false,
      "example": "cam_abc123"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Filter by activity type. Options: emailsSent, emailsOpened, emailsClicked, emailsReplied, emailsBounced, emailsUnsubscribed.",
      "required": false,
      "example": "emailsReplied"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of activities to return.",
      "required": false,
      "example": 50
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/activities?campaignId=cam_abc123&type=emailsReplied&limit=50",
    "headers": {
      "Authorization": "Basic {base64_encoded_api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "_id": "act_def456",
        "type": "emailsReplied",
        "campaignId": "cam_abc123",
        "leadId": "lea_xyz789",
        "leadEmail": "john@acmecorp.com",
        "leadFirstName": "John",
        "stepNumber": 2,
        "sequenceName": "Main Sequence",
        "createdAt": "2026-02-28T14:30:00.000Z"
      }
    ]
  }
}
