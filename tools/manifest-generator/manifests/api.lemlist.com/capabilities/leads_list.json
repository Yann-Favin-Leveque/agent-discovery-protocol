{
  "name": "leads_list",
  "description": "List leads in a campaign.",
  "resource_group": "leads",
  "endpoint": "/api/campaigns/{campaignId}/leads",
  "method": "GET",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "in": "query"
    },
    {
      "name": "state",
      "type": "string",
      "description": "Filter by state.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/campaigns/camp_1/leads",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "_id": "lead_1",
        "email": "lead@example.com",
        "state": "active"
      }
    ]
  }
}
