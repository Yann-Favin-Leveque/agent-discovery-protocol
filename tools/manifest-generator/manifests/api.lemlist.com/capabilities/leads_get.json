{
  "name": "leads_get",
  "description": "Get a lead by email or ID.",
  "resource_group": "leads",
  "endpoint": "/api/leads/{emailOrId}",
  "method": "GET",
  "parameters": [
    {
      "name": "emailOrId",
      "type": "string",
      "description": "Lead email or ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/leads/lead@example.com",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "lead_1",
      "email": "lead@example.com",
      "firstName": "John"
    }
  }
}
