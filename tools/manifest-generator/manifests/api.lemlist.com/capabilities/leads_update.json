{
  "name": "leads_update",
  "description": "Update a lead in a campaign.",
  "resource_group": "leads",
  "endpoint": "/api/campaigns/{campaignId}/leads/{emailOrId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true
    },
    {
      "name": "emailOrId",
      "type": "string",
      "description": "Lead email or ID.",
      "required": true
    },
    {
      "name": "firstName",
      "type": "string",
      "description": "Updated first name.",
      "required": false
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.lemlist.com/api/campaigns/camp_1/leads/lead@example.com",
    "headers": {
      "Authorization": "Basic {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "firstName": "Johnny"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "lead_1",
      "firstName": "Johnny"
    }
  }
}