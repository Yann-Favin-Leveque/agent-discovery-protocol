{
  "name": "campaigns_create",
  "description": "Create a new outreach campaign.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Campaign name.",
      "required": true,
      "example": "Summer Outreach",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/campaigns",
    "headers": {
      "Authorization": "Basic {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "Summer Outreach"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "camp_2",
      "name": "Summer Outreach"
    }
  }
}
