{
  "name": "leads_mark_interested",
  "description": "Mark a lead as interested.",
  "resource_group": "leads",
  "endpoint": "/api/leads/{emailOrId}/interested",
  "method": "POST",
  "parameters": [
    {
      "name": "emailOrId",
      "type": "string",
      "description": "Lead email or ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/leads/lead@example.com/interested",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "interested": true
    }
  }
}