{
  "name": "campaigns_get_stats",
  "description": "Get performance statistics for a campaign.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns/{campaignId}/stats",
  "method": "GET",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/campaigns/camp_1/stats",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sent": 500,
      "delivered": 485,
      "opened": 210,
      "clicked": 45,
      "replied": 12,
      "bounced": 5
    }
  }
}