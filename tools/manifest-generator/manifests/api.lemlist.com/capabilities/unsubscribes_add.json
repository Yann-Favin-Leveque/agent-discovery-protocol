{
  "name": "unsubscribes_add",
  "description": "Add email or domain to unsubscribe list.",
  "resource_group": "unsubscribes",
  "endpoint": "/api/unsubscribes",
  "method": "POST",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Email or domain to unsubscribe.",
      "required": true,
      "example": "unsub@example.com",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/unsubscribes",
    "headers": {
      "Authorization": "Basic {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "email": "unsub@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "email": "unsub@example.com",
      "created": true
    }
  }
}
