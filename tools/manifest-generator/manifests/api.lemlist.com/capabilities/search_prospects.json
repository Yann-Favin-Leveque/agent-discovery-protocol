{
  "name": "search_prospects",
  "description": "Search the Lemlist people and companies database to find new prospects. Filter by job title, industry, company size, location, and keywords. Returns matching prospects with available contact information. Useful for building targeted lead lists.",
  "endpoint": "/api/database/people/search",
  "method": "POST",
  "parameters": [
    {
      "name": "filters",
      "type": "object",
      "description": "Search filters including job title, company, location, industry, and company size.",
      "required": true,
      "example": {
        "jobTitle": "CTO",
        "companySize": "11-50",
        "location": "United States"
      }
    },
    {
      "name": "keywords",
      "type": "string",
      "description": "Free-text keywords to search across all prospect fields.",
      "required": false,
      "example": "SaaS startup"
    },
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Maximum number of results to return.",
      "required": false,
      "example": 25
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/database/people/search",
    "headers": {
      "Authorization": "Basic {base64_encoded_api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "filters": {
        "jobTitle": "CTO",
        "companySize": "11-50",
        "location": "United States"
      },
      "keywords": "SaaS startup",
      "offset": 0,
      "limit": 25
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "firstName": "Jane",
          "lastName": "Doe",
          "title": "CTO",
          "companyName": "StartupXYZ",
          "companySize": "25",
          "industry": "Software",
          "location": "San Francisco, CA",
          "linkedinUrl": "https://linkedin.com/in/janedoe"
        }
      ],
      "total": 1250,
      "offset": 0,
      "limit": 25
    }
  }
}
