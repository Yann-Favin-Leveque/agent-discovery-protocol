{
  "name": "campaigns_export",
  "description": "Export campaign leads to CSV.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns/{campaignId}/export",
  "method": "POST",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/campaigns/camp_1/export",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "exportId": "exp_1",
      "status": "processing"
    }
  }
}
