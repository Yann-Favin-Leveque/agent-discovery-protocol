{
  "name": "unsubscribes_delete",
  "description": "Remove email from unsubscribe list.",
  "resource_group": "unsubscribes",
  "endpoint": "/api/unsubscribes/{email}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "email",
      "type": "string",
      "description": "Email to remove.",
      "required": true
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.lemlist.com/api/unsubscribes/unsub@example.com",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deleted": true
    }
  }
}