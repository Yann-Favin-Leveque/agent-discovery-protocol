{
  "name": "campaigns_start",
  "description": "Start or resume a paused campaign.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns/{campaignId}/start",
  "method": "POST",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/campaigns/camp_1/start",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "camp_1",
      "status": "running"
    }
  }
}