{
  "name": "unsubscribes_list",
  "description": "List all unsubscribed emails and domains.",
  "resource_group": "unsubscribes",
  "endpoint": "/api/unsubscribes",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/unsubscribes",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "email": "unsub@example.com",
        "createdAt": "2024-06-01T00:00:00Z"
      }
    ]
  }
}
