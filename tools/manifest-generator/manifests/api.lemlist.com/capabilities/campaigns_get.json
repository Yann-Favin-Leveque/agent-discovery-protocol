{
  "name": "campaigns_get",
  "description": "Get a specific campaign.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns/{campaignId}",
  "method": "GET",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/campaigns/camp_1",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "camp_1",
      "name": "Q1 Outreach",
      "status": "running",
      "labels": []
    }
  }
}