{
  "name": "inbox_send_linkedin",
  "description": "Send a LinkedIn message through lemlist.",
  "resource_group": "inbox",
  "endpoint": "/api/inbox/linkedin",
  "method": "POST",
  "parameters": [
    {
      "name": "to",
      "type": "string",
      "description": "LinkedIn URL or contact ID.",
      "required": true,
      "in": "body"
    },
    {
      "name": "message",
      "type": "string",
      "description": "Message content.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/inbox/linkedin",
    "headers": {
      "Authorization": "Basic {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "to": "https://linkedin.com/in/johndoe",
      "message": "Hi John!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "sent": true
    }
  }
}
