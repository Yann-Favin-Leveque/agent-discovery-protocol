{
  "name": "campaigns_pause",
  "description": "Pause a running campaign.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns/{campaignId}/pause",
  "method": "POST",
  "parameters": [
    {
      "name": "campaignId",
      "type": "string",
      "description": "Campaign ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemlist.com/api/campaigns/camp_1/pause",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "_id": "camp_1",
      "status": "paused"
    }
  }
}
