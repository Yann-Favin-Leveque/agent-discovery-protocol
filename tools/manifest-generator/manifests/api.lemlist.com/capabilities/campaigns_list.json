{
  "name": "campaigns_list",
  "description": "List all campaigns in your team.",
  "resource_group": "campaigns",
  "endpoint": "/api/campaigns",
  "method": "GET",
  "parameters": [
    {
      "name": "offset",
      "type": "integer",
      "description": "Pagination offset.",
      "required": false,
      "example": 0
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "Max results.",
      "required": false,
      "example": 100
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemlist.com/api/campaigns",
    "headers": {
      "Authorization": "Basic {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "_id": "camp_1",
        "name": "Q1 Outreach",
        "status": "running"
      }
    ]
  }
}