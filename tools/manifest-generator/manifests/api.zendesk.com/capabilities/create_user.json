{
  "name": "create_user",
  "description": "Create a new user in Zendesk. Users can be end-users (customers who submit tickets), agents (support staff), or admins. Associates them with an organization if provided.",
  "endpoint": "/api/v2/users",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "The user's full name.", "required": true, "example": "John Doe" },
    { "name": "email", "type": "string", "description": "The user's email address. Must be unique.", "required": true, "example": "john.doe@example.com" },
    { "name": "role", "type": "string", "description": "User role: 'end-user', 'agent', or 'admin'.", "required": false, "example": "end-user" },
    { "name": "organization_id", "type": "integer", "description": "ID of the organization this user belongs to.", "required": false, "example": 500 },
    { "name": "phone", "type": "string", "description": "The user's phone number.", "required": false, "example": "+1-555-123-4567" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.zendesk.com/api/v2/users",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "user": {
        "name": "John Doe",
        "email": "john.doe@example.com",
        "role": "end-user",
        "organization_id": 500
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "user": {
        "id": 12347,
        "name": "John Doe",
        "email": "john.doe@example.com",
        "role": "end-user",
        "organization_id": 500,
        "active": true,
        "created_at": "2025-01-15T16:00:00Z"
      }
    }
  }
}
