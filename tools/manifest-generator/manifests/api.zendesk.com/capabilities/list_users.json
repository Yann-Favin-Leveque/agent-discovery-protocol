{
  "name": "list_users",
  "description": "Retrieve all users in your Zendesk account, including end-users (customers), agents, and admins. Returns names, emails, roles, and group memberships. Supports filtering by role and organization.",
  "endpoint": "/api/v2/users",
  "method": "GET",
  "parameters": [
    { "name": "role", "type": "string", "description": "Filter by user role: 'end-user', 'agent', or 'admin'.", "required": false, "example": "agent" },
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.zendesk.com/api/v2/users?role=agent&per_page=25",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "users": [
        {
          "id": 67890,
          "name": "Agent Smith",
          "email": "smith@company.com",
          "role": "agent",
          "active": true,
          "default_group_id": 100,
          "created_at": "2024-06-01T08:00:00Z"
        }
      ],
      "count": 1,
      "next_page": null
    }
  }
}
