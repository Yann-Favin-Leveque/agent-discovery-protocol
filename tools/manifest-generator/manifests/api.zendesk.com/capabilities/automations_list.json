{
  "name": "automations_list",
  "description": "List all automations (time-based rules).",
  "endpoint": "/api/v2/automations",
  "method": "GET",
  "resource_group": "automations",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": "1"
    },
    {
      "name": "active",
      "type": "boolean",
      "description": "Filter by active state",
      "required": false,
      "example": "true"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/automations",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "automations": [
        {
          "id": 1,
          "title": "Close Stale Tickets",
          "active": true
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}