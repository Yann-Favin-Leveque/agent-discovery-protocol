{
  "name": "satisfaction_ratings_list",
  "description": "List customer satisfaction ratings.",
  "endpoint": "/api/v2/satisfaction_ratings",
  "method": "GET",
  "resource_group": "satisfaction_ratings",
  "parameters": [
    {
      "name": "score",
      "type": "string",
      "description": "Filter by score (good, bad)",
      "required": false,
      "example": "good"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/satisfaction_ratings",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "satisfaction_ratings": [
        {
          "id": 1,
          "score": "good",
          "ticket_id": 1
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}