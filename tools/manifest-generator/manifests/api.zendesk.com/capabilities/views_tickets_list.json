{
  "name": "views_tickets_list",
  "description": "Execute a view and retrieve its tickets.",
  "endpoint": "/api/v2/views/{view_id}/tickets",
  "method": "GET",
  "resource_group": "views",
  "parameters": [
    {
      "name": "view_id",
      "type": "integer",
      "description": "View ID",
      "required": true,
      "example": "1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/views/{view_id}/tickets",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "tickets": [
        {
          "id": 1,
          "subject": "Open ticket"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}