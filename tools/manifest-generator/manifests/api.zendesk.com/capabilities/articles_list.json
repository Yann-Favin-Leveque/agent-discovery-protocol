{
  "name": "articles_list",
  "description": "List Help Center articles.",
  "endpoint": "/api/v2/help_center/articles",
  "method": "GET",
  "resource_group": "help_center",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": "1"
    },
    {
      "name": "per_page",
      "type": "integer",
      "description": "Results per page",
      "required": false,
      "example": "25"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/help_center/articles",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "articles": [
        {
          "id": 1,
          "title": "Getting Started",
          "body": "<p>Welcome...</p>"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}