{
  "name": "tickets_get",
  "description": "Retrieve a single ticket by ID.",
  "endpoint": "/api/v2/tickets/{ticket_id}",
  "method": "GET",
  "resource_group": "tickets",
  "parameters": [
    {
      "name": "ticket_id",
      "type": "integer",
      "description": "Ticket ID",
      "required": true,
      "example": "1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "ticket": {
        "id": 1,
        "subject": "Help needed",
        "status": "open",
        "priority": "normal",
        "description": "I need help...",
        "requester_id": 123
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}