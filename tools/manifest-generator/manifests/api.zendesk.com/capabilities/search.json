{
  "name": "search",
  "description": "Search across tickets, users, and organizations using Zendesk query language.",
  "endpoint": "/api/v2/search",
  "method": "GET",
  "resource_group": "search",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "Zendesk search query",
      "required": true,
      "example": "status:open type:ticket assignee:me"
    },
    {
      "name": "sort_by",
      "type": "string",
      "description": "Sort field",
      "required": false,
      "example": "created_at"
    },
    {
      "name": "sort_order",
      "type": "string",
      "description": "Sort direction",
      "required": false,
      "example": "desc"
    },
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": "1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/search",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": 1,
          "subject": "Open ticket",
          "result_type": "ticket"
        }
      ],
      "count": 42
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}