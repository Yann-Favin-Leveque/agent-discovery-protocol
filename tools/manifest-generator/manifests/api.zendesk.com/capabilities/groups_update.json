{
  "name": "groups_update",
  "description": "Update a group.",
  "endpoint": "/api/v2/groups/{group_id}",
  "method": "PUT",
  "resource_group": "groups",
  "parameters": [
    {
      "name": "group_id",
      "type": "integer",
      "description": "Group ID",
      "required": true,
      "example": "1"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name",
      "required": false,
      "example": "Customer Support"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://{subdomain}.zendesk.com/api/v2/groups/{group_id}",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "group": {
        "name": "Customer Support"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "group": {
        "id": 1,
        "name": "Customer Support"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}