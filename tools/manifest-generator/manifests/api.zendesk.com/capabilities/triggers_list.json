{
  "name": "triggers_list",
  "description": "List all triggers (automation rules).",
  "endpoint": "/api/v2/triggers",
  "method": "GET",
  "resource_group": "triggers",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": "1",
      "in": "query"
    },
    {
      "name": "active",
      "type": "boolean",
      "description": "Filter by active state",
      "required": false,
      "example": "true",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/triggers",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "triggers": [
        {
          "id": 1,
          "title": "Notify on Urgent",
          "active": true
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}
