{
  "name": "groups_create",
  "description": "Create a new group.",
  "endpoint": "/api/v2/groups",
  "method": "POST",
  "resource_group": "groups",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Group name",
      "required": true,
      "example": "Engineering"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://{subdomain}.zendesk.com/api/v2/groups",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "group": {
        "name": "Engineering"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "group": {
        "id": 2,
        "name": "Engineering"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}