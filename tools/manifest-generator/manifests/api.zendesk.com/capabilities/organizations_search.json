{
  "name": "organizations_search",
  "description": "Search organizations by name or external ID.",
  "endpoint": "/api/v2/organizations/search",
  "method": "GET",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "description": "Search by name",
      "required": false,
      "example": "Acme",
      "in": "query"
    },
    {
      "name": "external_id",
      "type": "string",
      "description": "Search by external ID",
      "required": false,
      "example": "",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/organizations/search",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "organizations": [
        {
          "id": 1,
          "name": "Acme Corp"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}
