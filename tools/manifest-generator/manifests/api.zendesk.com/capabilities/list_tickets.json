{
  "name": "list_tickets",
  "description": "Retrieve all support tickets in your Zendesk account. Returns tickets sorted by creation date with pagination. Can sideload related users and organizations for efficient data retrieval.",
  "endpoint": "/api/v2/tickets",
  "method": "GET",
  "parameters": [
    { "name": "sort_by", "type": "string", "description": "Sort field: 'created_at', 'updated_at', 'priority', 'status', or 'ticket_type'.", "required": false, "example": "updated_at" },
    { "name": "sort_order", "type": "string", "description": "Sort direction: 'asc' or 'desc'.", "required": false, "example": "desc" },
    { "name": "include", "type": "string", "description": "Comma-separated list of related objects to sideload: 'users', 'groups', 'organizations'.", "required": false, "example": "users" },
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.zendesk.com/api/v2/tickets?sort_by=updated_at&sort_order=desc&per_page=25",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "tickets": [
        {
          "id": 1001,
          "subject": "Cannot access my account",
          "status": "open",
          "priority": "high",
          "requester_id": 12345,
          "assignee_id": 67890,
          "created_at": "2025-01-15T10:30:00Z",
          "updated_at": "2025-01-15T14:22:00Z"
        }
      ],
      "count": 1,
      "next_page": null,
      "previous_page": null
    }
  }
}
