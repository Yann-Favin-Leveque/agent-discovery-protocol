{
  "name": "organizations_update",
  "description": "Update an organization.",
  "endpoint": "/api/v2/organizations/{organization_id}",
  "method": "PUT",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "organization_id",
      "type": "integer",
      "description": "Organization ID",
      "required": true,
      "example": "1"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Updated name",
      "required": false,
      "example": "Acme Corporation"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://{subdomain}.zendesk.com/api/v2/organizations/{organization_id}",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "organization": {
        "name": "Acme Corporation"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "organization": {
        "id": 1,
        "name": "Acme Corporation"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}