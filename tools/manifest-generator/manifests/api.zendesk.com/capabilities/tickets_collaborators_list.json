{
  "name": "tickets_collaborators_list",
  "description": "List collaborators for a ticket.",
  "endpoint": "/api/v2/tickets/{ticket_id}/collaborators",
  "method": "GET",
  "resource_group": "tickets",
  "parameters": [
    {
      "name": "ticket_id",
      "type": "integer",
      "description": "Ticket ID",
      "required": true,
      "example": "1",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}/collaborators",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "users": [
        {
          "id": 123,
          "name": "Collaborator",
          "email": "collab@example.com"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}
