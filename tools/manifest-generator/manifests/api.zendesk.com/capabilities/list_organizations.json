{
  "name": "list_organizations",
  "description": "Retrieve all organizations in your Zendesk account. Organizations group end-users from the same company, enabling shared ticket visibility and organization-level reporting.",
  "endpoint": "/api/v2/organizations",
  "method": "GET",
  "parameters": [
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.zendesk.com/api/v2/organizations?per_page=25",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "organizations": [
        {
          "id": 500,
          "name": "Acme Corp",
          "domain_names": ["acme.com"],
          "group_id": 100,
          "shared_tickets": true,
          "created_at": "2024-01-10T08:00:00Z"
        }
      ],
      "count": 1,
      "next_page": null
    }
  }
}
