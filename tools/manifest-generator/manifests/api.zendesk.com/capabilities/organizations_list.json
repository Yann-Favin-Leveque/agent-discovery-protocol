{
  "name": "organizations_list",
  "description": "List all organizations.",
  "endpoint": "/api/v2/organizations",
  "method": "GET",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "page",
      "type": "integer",
      "description": "Page number",
      "required": false,
      "example": "1",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/organizations",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "organizations": [
        {
          "id": 1,
          "name": "Acme Corp",
          "domain_names": [
            "acme.com"
          ]
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}
