{
  "name": "search_tickets",
  "description": "Search for tickets using Zendesk's powerful query language. Combine keywords with field filters like status, requester, assignee, tags, and date ranges. Returns matching tickets sorted by relevance.",
  "endpoint": "/api/v2/search",
  "method": "GET",
  "parameters": [
    { "name": "query", "type": "string", "description": "Zendesk search query string. Supports field:value syntax (e.g., 'status:open priority:high billing').", "required": true, "example": "status:open priority:high billing" },
    { "name": "sort_by", "type": "string", "description": "Sort results by: 'relevance', 'updated_at', or 'created_at'.", "required": false, "example": "relevance" },
    { "name": "sort_order", "type": "string", "description": "Sort direction: 'asc' or 'desc'.", "required": false, "example": "desc" },
    { "name": "page", "type": "integer", "description": "Page number for pagination.", "required": false, "example": 1 },
    { "name": "per_page", "type": "integer", "description": "Number of results per page (max 100).", "required": false, "example": 25 }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.zendesk.com/api/v2/search?query=type%3Aticket+status%3Aopen+priority%3Ahigh+billing&sort_by=relevance&per_page=25",
    "headers": {
      "Authorization": "Bearer {api_token}",
      "Content-Type": "application/json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": 1002,
          "result_type": "ticket",
          "subject": "Billing discrepancy on last invoice",
          "status": "open",
          "priority": "high",
          "requester_id": 12346,
          "created_at": "2025-01-14T09:00:00Z"
        }
      ],
      "count": 1,
      "facets": null,
      "next_page": null
    }
  }
}
