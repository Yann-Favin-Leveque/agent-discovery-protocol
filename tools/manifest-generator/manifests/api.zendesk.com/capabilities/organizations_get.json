{
  "name": "organizations_get",
  "description": "Retrieve a specific organization.",
  "endpoint": "/api/v2/organizations/{organization_id}",
  "method": "GET",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "organization_id",
      "type": "integer",
      "description": "Organization ID",
      "required": true,
      "example": "1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/organizations/{organization_id}",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "organization": {
        "id": 1,
        "name": "Acme Corp",
        "domain_names": [
          "acme.com"
        ]
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}