{
  "name": "users_search",
  "description": "Search users by name, email, or external ID.",
  "endpoint": "/api/v2/users/search",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "Search query",
      "required": true,
      "example": "john@example.com"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/users/search",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "users": [
        {
          "id": 123,
          "name": "John Doe",
          "email": "john@example.com"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}