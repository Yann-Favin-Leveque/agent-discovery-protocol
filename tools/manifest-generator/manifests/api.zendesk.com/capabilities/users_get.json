{
  "name": "users_get",
  "description": "Retrieve a specific user by ID.",
  "endpoint": "/api/v2/users/{user_id}",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {
      "name": "user_id",
      "type": "integer",
      "description": "User ID",
      "required": true,
      "example": "123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/users/{user_id}",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "user": {
        "id": 123,
        "name": "John Doe",
        "email": "john@example.com",
        "role": "end-user"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}
