{
  "name": "articles_get",
  "description": "Retrieve a Help Center article.",
  "endpoint": "/api/v2/help_center/articles/{article_id}",
  "method": "GET",
  "resource_group": "help_center",
  "parameters": [
    {
      "name": "article_id",
      "type": "integer",
      "description": "Article ID",
      "required": true,
      "example": "1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/help_center/articles/{article_id}",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "article": {
        "id": 1,
        "title": "Getting Started",
        "body": "<p>Welcome to our help center...</p>"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}