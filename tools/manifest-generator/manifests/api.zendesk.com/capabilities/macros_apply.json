{
  "name": "macros_apply",
  "description": "Apply a macro to a ticket.",
  "endpoint": "/api/v2/tickets/{ticket_id}/macros/{macro_id}/apply",
  "method": "GET",
  "resource_group": "macros",
  "parameters": [
    {
      "name": "ticket_id",
      "type": "integer",
      "description": "Ticket ID",
      "required": true,
      "example": "1",
      "in": "path"
    },
    {
      "name": "macro_id",
      "type": "integer",
      "description": "Macro ID",
      "required": true,
      "example": "1",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}/macros/{macro_id}/apply",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "result": {
        "ticket": {
          "id": 1,
          "status": "solved"
        }
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}
