{
  "name": "tickets_incidents_list",
  "description": "List incidents linked to a problem ticket.",
  "endpoint": "/api/v2/tickets/{ticket_id}/incidents",
  "method": "GET",
  "resource_group": "tickets",
  "parameters": [
    {
      "name": "ticket_id",
      "type": "integer",
      "description": "Problem ticket ID",
      "required": true,
      "example": "1"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}/incidents",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "tickets": [
        {
          "id": 5,
          "subject": "Incident ticket"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}