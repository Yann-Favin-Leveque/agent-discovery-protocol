{
  "name": "job_statuses_get",
  "description": "Check the status of a background job.",
  "endpoint": "/api/v2/job_statuses/{job_status_id}",
  "method": "GET",
  "resource_group": "job_statuses",
  "parameters": [
    {
      "name": "job_status_id",
      "type": "string",
      "description": "Job status ID",
      "required": true,
      "example": "job_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/job_statuses/{job_status_id}",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "job_status": {
        "id": "job_123",
        "status": "completed",
        "total": 10,
        "progress": 10
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}
