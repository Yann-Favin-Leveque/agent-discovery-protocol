{
  "name": "articles_search",
  "description": "Search Help Center articles by keyword.",
  "endpoint": "/api/v2/help_center/articles/search",
  "method": "GET",
  "resource_group": "help_center",
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "Search query",
      "required": true,
      "example": "password reset"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/help_center/articles/search",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "results": [
        {
          "id": 5,
          "title": "How to Reset Your Password"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}