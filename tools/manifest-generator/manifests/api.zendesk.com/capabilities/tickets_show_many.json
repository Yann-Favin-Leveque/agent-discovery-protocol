{
  "name": "tickets_show_many",
  "description": "Retrieve multiple tickets by their IDs.",
  "endpoint": "/api/v2/tickets/show_many",
  "method": "GET",
  "resource_group": "tickets",
  "parameters": [
    {
      "name": "ids",
      "type": "string",
      "description": "Comma-separated ticket IDs",
      "required": true,
      "example": "1,2,3"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://{subdomain}.zendesk.com/api/v2/tickets/show_many",
    "headers": {
      "Authorization": "Bearer {token}"
    },
    "body": {}
  },
  "response_example": {
    "status": 200,
    "body": {
      "tickets": [
        {
          "id": 1,
          "subject": "Ticket 1"
        },
        {
          "id": 2,
          "subject": "Ticket 2"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 400
  }
}