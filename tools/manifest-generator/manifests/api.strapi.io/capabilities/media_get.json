{
  "name": "media_get",
  "description": "Retrieve details of a specific uploaded file by its ID.",
  "resource_group": "media",
  "endpoint": "/api/upload/files/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "The ID of the file to retrieve."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.strapi.io/api/upload/files/1",
    "headers": {
      "Authorization": "Bearer your-strapi-api-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "name": "photo.jpg",
      "alternativeText": "A scenic landscape",
      "caption": "Mountain view",
      "width": 1920,
      "height": 1080,
      "url": "/uploads/photo.jpg",
      "mime": "image/jpeg",
      "size": 245.5,
      "createdAt": "2026-03-01T12:00:00.000Z",
      "updatedAt": "2026-03-01T12:00:00.000Z"
    }
  }
}
