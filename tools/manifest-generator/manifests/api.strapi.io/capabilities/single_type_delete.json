{
  "name": "single_type_delete",
  "description": "Delete the document for a single type content type.",
  "resource_group": "single_types",
  "endpoint": "/api/{singularApiId}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "singularApiId",
      "type": "string",
      "required": true,
      "location": "path",
      "description": "The singular API ID of the single type (e.g., 'homepage')."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.strapi.io/api/homepage",
    "headers": {
      "Authorization": "Bearer your-strapi-api-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "id": 1,
        "attributes": {}
      }
    }
  }
}
