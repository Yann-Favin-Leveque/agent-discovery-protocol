{
  "name": "media_delete",
  "description": "Delete an uploaded file from the Strapi media library by its ID.",
  "resource_group": "media",
  "endpoint": "/api/upload/files/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "location": "path",
      "description": "The ID of the file to delete.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.strapi.io/api/upload/files/1",
    "headers": {
      "Authorization": "Bearer your-strapi-api-token"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": 1,
      "name": "photo.jpg"
    }
  }
}
