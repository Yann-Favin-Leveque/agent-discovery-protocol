{
  "name": "sys_policies_delete",
  "description": "Delete an ACL policy.",
  "resource_group": "system",
  "endpoint": "/v1/sys/policies/acl/{name}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Policy name to delete.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://vault.example.com/v1/sys/policies/acl/my-policy",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
