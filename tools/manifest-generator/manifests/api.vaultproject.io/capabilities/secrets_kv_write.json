{
  "name": "secrets_kv_write",
  "description": "Create or update a secret in a KV v2 secrets engine. Creates a new version.",
  "resource_group": "secrets_kv",
  "endpoint": "/v1/{mount}/data/{path}",
  "method": "POST",
  "parameters": [
    {
      "name": "mount",
      "type": "string",
      "required": true,
      "description": "KV mount path.",
      "in": "path"
    },
    {
      "name": "path",
      "type": "string",
      "required": true,
      "description": "Secret path.",
      "in": "path"
    },
    {
      "name": "data",
      "type": "object",
      "required": true,
      "description": "Key-value pairs to store.",
      "in": "body"
    },
    {
      "name": "options.cas",
      "type": "integer",
      "required": false,
      "description": "Check-and-set version for optimistic locking.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://vault.example.com/v1/secret/data/myapp/config",
    "headers": {
      "X-Vault-Token": "<token>",
      "Content-Type": "application/json"
    },
    "body": {
      "data": {
        "username": "admin",
        "password": "newsecret"
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "created_time": "2024-06-20T00:00:00Z",
        "version": 2,
        "destroyed": false
      }
    }
  }
}
