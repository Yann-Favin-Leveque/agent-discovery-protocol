{
  "name": "secrets_kv_destroy",
  "description": "Permanently destroy specific versions of a secret (cannot be recovered).",
  "resource_group": "secrets_kv",
  "endpoint": "/v1/{mount}/destroy/{path}",
  "method": "PUT",
  "parameters": [
    {
      "name": "mount",
      "type": "string",
      "required": true,
      "description": "KV mount path.",
      "in": "path"
    },
    {
      "name": "path",
      "type": "string",
      "required": true,
      "description": "Secret path.",
      "in": "path"
    },
    {
      "name": "versions",
      "type": "array",
      "required": true,
      "description": "Array of version numbers to permanently destroy.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://vault.example.com/v1/secret/destroy/myapp/config",
    "headers": {
      "X-Vault-Token": "<token>",
      "Content-Type": "application/json"
    },
    "body": {
      "versions": [
        1
      ]
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
