{
  "name": "secrets_kv_list",
  "description": "List secret keys at a given path in the KV secrets engine.",
  "resource_group": "secrets_kv",
  "endpoint": "/v1/{mount}/metadata/{path}",
  "method": "LIST",
  "parameters": [
    {
      "name": "mount",
      "type": "string",
      "required": true,
      "description": "KV mount path."
    },
    {
      "name": "path",
      "type": "string",
      "required": true,
      "description": "Directory path to list."
    }
  ],
  "request_example": {
    "method": "LIST",
    "url": "https://vault.example.com/v1/secret/metadata/myapp/",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "keys": [
          "config",
          "database/",
          "api-keys/"
        ]
      }
    }
  }
}