{
  "name": "secrets_kv_delete",
  "description": "Soft-delete the latest version of a secret (can be undeleted).",
  "resource_group": "secrets_kv",
  "endpoint": "/v1/{mount}/data/{path}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "mount",
      "type": "string",
      "required": true,
      "description": "KV mount path."
    },
    {
      "name": "path",
      "type": "string",
      "required": true,
      "description": "Secret path."
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://vault.example.com/v1/secret/data/myapp/config",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}