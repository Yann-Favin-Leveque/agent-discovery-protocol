{
  "name": "secrets_kv_read",
  "description": "Read a secret from a KV v2 secrets engine at the specified path. Returns the secret data and version metadata.",
  "resource_group": "secrets_kv",
  "endpoint": "/v1/{mount}/data/{path}",
  "method": "GET",
  "parameters": [
    {
      "name": "mount",
      "type": "string",
      "required": true,
      "description": "KV secrets engine mount path (e.g., 'secret').",
      "in": "path"
    },
    {
      "name": "path",
      "type": "string",
      "required": true,
      "description": "Path to the secret.",
      "in": "path"
    },
    {
      "name": "version",
      "type": "integer",
      "required": false,
      "description": "Secret version number. Omit for latest.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://vault.example.com/v1/secret/data/myapp/config",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "data": {
          "username": "admin",
          "password": "s3cret"
        },
        "metadata": {
          "created_time": "2024-01-01T00:00:00Z",
          "version": 1,
          "destroyed": false,
          "deletion_time": ""
        }
      }
    }
  }
}
