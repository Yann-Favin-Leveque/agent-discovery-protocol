{
  "name": "sys_policies_list",
  "description": "List all configured ACL policies.",
  "resource_group": "system",
  "endpoint": "/v1/sys/policies/acl",
  "method": "LIST",
  "parameters": [],
  "request_example": {
    "method": "LIST",
    "url": "https://vault.example.com/v1/sys/policies/acl",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "keys": [
          "default",
          "root",
          "my-policy"
        ]
      }
    }
  }
}