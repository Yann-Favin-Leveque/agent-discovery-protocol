{
  "name": "manage_policies",
  "description": "Create, read, update, and delete access control policies. Policies define what paths and operations a token or identity can access in Vault.",
  "endpoint": "/v1/sys/policies/acl/{name}",
  "method": "PUT",
  "parameters": [
    { "name": "name", "type": "string", "description": "Policy name.", "required": true, "example": "myapp-readonly" },
    { "name": "policy", "type": "string", "description": "Policy document in HCL or JSON format.", "required": true, "example": "path \"secret/data/myapp/*\" { capabilities = [\"read\", \"list\"] }" }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://vault.example.com:8200/v1/sys/policies/acl/myapp-readonly",
    "headers": { "X-Vault-Token": "{vault_token}", "Content-Type": "application/json" },
    "body": { "policy": "path \"secret/data/myapp/*\" {\n  capabilities = [\"read\", \"list\"]\n}" }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}
