{
  "name": "write_secret",
  "description": "Store or update a secret in a KV secrets engine. Creates a new version of the secret (KV v2) or overwrites it (KV v1).",
  "endpoint": "/v1/{mount}/data/{path}",
  "method": "POST",
  "parameters": [
    { "name": "mount", "type": "string", "description": "The secrets engine mount path.", "required": true, "example": "secret" },
    { "name": "path", "type": "string", "description": "The secret path.", "required": true, "example": "myapp/config" },
    { "name": "data", "type": "object", "description": "The secret key-value pairs to store.", "required": true, "example": { "database_url": "postgres://user:pass@host/db" } }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://vault.example.com:8200/v1/secret/data/myapp/config",
    "headers": { "X-Vault-Token": "{vault_token}", "Content-Type": "application/json" },
    "body": { "data": { "database_url": "postgres://user:pass@host/db", "api_key": "sk-newkey" } }
  },
  "response_example": {
    "status": 200,
    "body": { "data": { "created_time": "2024-02-01T14:00:00Z", "version": 4 } }
  }
}
