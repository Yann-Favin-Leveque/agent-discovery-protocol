{
  "name": "list_secrets",
  "description": "List secret keys at a given path in the secrets engine. Does not return secret values, only the key names available at that path.",
  "endpoint": "/v1/{mount}/metadata/{path}",
  "method": "LIST",
  "parameters": [
    { "name": "mount", "type": "string", "description": "The secrets engine mount path.", "required": true, "example": "secret" },
    { "name": "path", "type": "string", "description": "The path to list.", "required": true, "example": "myapp/" }
  ],
  "request_example": {
    "method": "LIST",
    "url": "https://vault.example.com:8200/v1/secret/metadata/myapp/",
    "headers": { "X-Vault-Token": "{vault_token}" }
  },
  "response_example": {
    "status": 200,
    "body": { "data": { "keys": ["config", "database", "tokens/"] } }
  }
}
