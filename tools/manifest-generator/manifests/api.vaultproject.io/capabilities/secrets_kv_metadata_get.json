{
  "name": "secrets_kv_metadata_get",
  "description": "Retrieve metadata and version history for a secret without exposing values.",
  "resource_group": "secrets_kv",
  "endpoint": "/v1/{mount}/metadata/{path}",
  "method": "GET",
  "parameters": [
    {
      "name": "mount",
      "type": "string",
      "required": true,
      "description": "KV mount path.",
      "in": "path"
    },
    {
      "name": "path",
      "type": "string",
      "required": true,
      "description": "Secret path.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://vault.example.com/v1/secret/metadata/myapp/config",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "cas_required": false,
        "created_time": "2024-01-01T00:00:00Z",
        "current_version": 2,
        "max_versions": 0,
        "versions": {
          "1": {
            "created_time": "2024-01-01T00:00:00Z",
            "deletion_time": "",
            "destroyed": false
          },
          "2": {
            "created_time": "2024-06-20T00:00:00Z",
            "deletion_time": "",
            "destroyed": false
          }
        }
      }
    }
  }
}
