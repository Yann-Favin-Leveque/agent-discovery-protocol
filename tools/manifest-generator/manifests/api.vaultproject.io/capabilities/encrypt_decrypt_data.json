{
  "name": "encrypt_decrypt_data",
  "description": "Encrypt and decrypt data using Vault's Transit secrets engine. Transit acts as encryption-as-a-service, letting you encrypt data without storing it in Vault.",
  "endpoint": "/v1/transit/encrypt/{name}",
  "method": "POST",
  "parameters": [
    { "name": "name", "type": "string", "description": "Named encryption key.", "required": true, "example": "my-key" },
    { "name": "plaintext", "type": "string", "description": "Base64-encoded plaintext to encrypt.", "required": true, "example": "bXkgc2VjcmV0IGRhdGE=" }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://vault.example.com:8200/v1/transit/encrypt/my-key",
    "headers": { "X-Vault-Token": "{vault_token}", "Content-Type": "application/json" },
    "body": { "plaintext": "bXkgc2VjcmV0IGRhdGE=" }
  },
  "response_example": {
    "status": 200,
    "body": { "data": { "ciphertext": "vault:v1:8SDd3WHDOjf7mq69CyCqYjBXAiQQAVZRkFM13ok481zoCmHnSeDX9vyf7w==" } }
  }
}
