{
  "name": "token_lookup_self",
  "description": "Look up information about the current authentication token.",
  "resource_group": "auth_token",
  "endpoint": "/v1/auth/token/lookup-self",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://vault.example.com/v1/auth/token/lookup-self",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "accessor": "abc123",
        "creation_time": 1718841600,
        "display_name": "token",
        "expire_time": "2024-06-21T00:00:00Z",
        "id": "hvs.CAESIG...",
        "policies": [
          "default",
          "my-policy"
        ],
        "renewable": true,
        "ttl": 3600
      }
    }
  }
}