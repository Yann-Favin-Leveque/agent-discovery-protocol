{
  "name": "sys_auth_list",
  "description": "List all enabled authentication methods.",
  "resource_group": "system",
  "endpoint": "/v1/sys/auth",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://vault.example.com/v1/sys/auth",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "token/": {
        "accessor": "auth_token_abc",
        "type": "token",
        "description": "token based credentials"
      },
      "approle/": {
        "accessor": "auth_approle_abc",
        "type": "approle",
        "description": "AppRole authentication"
      }
    }
  }
}