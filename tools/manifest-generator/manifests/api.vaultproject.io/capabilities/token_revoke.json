{
  "name": "token_revoke",
  "description": "Revoke a token and all child tokens.",
  "resource_group": "auth_token",
  "endpoint": "/v1/auth/token/revoke",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "description": "Token to revoke."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://vault.example.com/v1/auth/token/revoke",
    "headers": {
      "X-Vault-Token": "<token>",
      "Content-Type": "application/json"
    },
    "body": {
      "token": "hvs.target_token"
    }
  },
  "response_example": {
    "status": 204,
    "body": null
  }
}