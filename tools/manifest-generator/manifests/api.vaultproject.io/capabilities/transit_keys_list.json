{
  "name": "transit_keys_list",
  "description": "List all named encryption keys in the Transit engine.",
  "resource_group": "transit",
  "endpoint": "/v1/transit/keys",
  "method": "LIST",
  "parameters": [],
  "request_example": {
    "method": "LIST",
    "url": "https://vault.example.com/v1/transit/keys",
    "headers": {
      "X-Vault-Token": "<token>"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "keys": [
          "my-key",
          "backup-key",
          "signing-key"
        ]
      }
    }
  }
}