{
  "name": "bitlinks_devices",
  "description": "Get device type click metrics for a Bitlink.",
  "endpoint": "/v4/bitlinks/{bitlink}/devices",
  "method": "GET",
  "resource_group": "bitlinks",
  "parameters": [
    {
      "name": "bitlink",
      "type": "string",
      "description": "The Bitlink ID.",
      "required": true,
      "example": "bit.ly/abc123",
      "in": "path"
    },
    {
      "name": "unit",
      "type": "string",
      "description": "Time unit.",
      "required": false,
      "example": "day",
      "in": "query"
    },
    {
      "name": "units",
      "type": "integer",
      "description": "Number of time units.",
      "required": false,
      "example": 30,
      "in": "query"
    },
    {
      "name": "size",
      "type": "integer",
      "description": "Number of results.",
      "required": false,
      "example": 10,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/bitlinks/bit.ly/abc123/devices?unit=day&units=30",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "metrics": [
        {
          "value": "Desktop",
          "clicks": 600
        },
        {
          "value": "Mobile",
          "clicks": 400
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
