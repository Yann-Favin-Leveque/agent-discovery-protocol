{
  "name": "bitlinks_expand",
  "description": "Expand a Bitlink to retrieve its original long URL.",
  "endpoint": "/v4/expand",
  "method": "POST",
  "resource_group": "bitlinks",
  "parameters": [
    {
      "name": "bitlink_id",
      "type": "string",
      "description": "The Bitlink ID to expand.",
      "required": true,
      "example": "bit.ly/abc123"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api-ssl.bitly.com/v4/expand",
    "headers": {
      "Authorization": "Bearer {token}",
      "Content-Type": "application/json"
    },
    "body": {
      "bitlink_id": "bit.ly/abc123"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "bit.ly/abc123",
      "long_url": "https://example.com/page",
      "created_at": "2024-01-01T00:00:00+0000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}