{
  "name": "campaigns_list",
  "description": "Retrieve all campaigns for the authenticated user.",
  "endpoint": "/v4/campaigns",
  "method": "GET",
  "resource_group": "campaigns",
  "parameters": [
    {
      "name": "group_guid",
      "type": "string",
      "description": "Filter by group GUID.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/campaigns",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "campaigns": [
        {
          "guid": "Ca1bc2de3fg",
          "name": "Q1 Campaign",
          "group_guid": "Ba1bc2de3fg"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}