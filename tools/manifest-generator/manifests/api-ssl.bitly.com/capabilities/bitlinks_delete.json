{
  "name": "bitlinks_delete",
  "description": "Delete an unedited default Bitlink.",
  "endpoint": "/v4/bitlinks/{bitlink}",
  "method": "DELETE",
  "resource_group": "bitlinks",
  "parameters": [
    {
      "name": "bitlink",
      "type": "string",
      "description": "The Bitlink ID to delete.",
      "required": true,
      "example": "bit.ly/abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api-ssl.bitly.com/v4/bitlinks/bit.ly/abc123",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}