{
  "name": "groups_list",
  "description": "Retrieve a list of groups in the organization.",
  "endpoint": "/v4/groups",
  "method": "GET",
  "resource_group": "groups",
  "parameters": [
    {
      "name": "organization_guid",
      "type": "string",
      "description": "Filter by organization GUID.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/groups",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "groups": [
        {
          "guid": "Ba1bc2de3fg",
          "name": "My Group",
          "organization_guid": "Oa1bc2de3fg"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
