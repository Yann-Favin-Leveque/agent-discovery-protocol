{
  "name": "groups_get",
  "description": "Retrieve details of a specific group.",
  "endpoint": "/v4/groups/{group_guid}",
  "method": "GET",
  "resource_group": "groups",
  "parameters": [
    {
      "name": "group_guid",
      "type": "string",
      "description": "The group GUID.",
      "required": true,
      "example": "Ba1bc2de3fg"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/groups/Ba1bc2de3fg",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "guid": "Ba1bc2de3fg",
      "name": "My Group",
      "organization_guid": "Oa1bc2de3fg",
      "created": "2024-01-01T00:00:00+0000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}