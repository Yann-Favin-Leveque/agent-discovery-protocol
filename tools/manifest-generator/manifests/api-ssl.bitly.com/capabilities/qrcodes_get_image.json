{
  "name": "qrcodes_get_image",
  "description": "Retrieve a QR code image in SVG, PNG, or JSON format.",
  "endpoint": "/v4/qr-codes/{qrcode_id}/image",
  "method": "GET",
  "resource_group": "qrcodes",
  "parameters": [
    {
      "name": "qrcode_id",
      "type": "string",
      "description": "The QR code ID.",
      "required": true,
      "example": "qr_abc123",
      "in": "path"
    },
    {
      "name": "format",
      "type": "string",
      "description": "Image format: svg, png, or json.",
      "required": false,
      "example": "svg",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/qr-codes/qr_abc123/image?format=svg",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": "(SVG/PNG binary or JSON data)"
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}
