{
  "name": "bitlinks_get",
  "description": "Retrieve details of a specific Bitlink.",
  "endpoint": "/v4/bitlinks/{bitlink}",
  "method": "GET",
  "resource_group": "bitlinks",
  "parameters": [
    {
      "name": "bitlink",
      "type": "string",
      "description": "The Bitlink ID (e.g. bit.ly/abc123).",
      "required": true,
      "example": "bit.ly/abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/bitlinks/bit.ly/abc123",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "link": "https://bit.ly/abc123",
      "id": "bit.ly/abc123",
      "long_url": "https://example.com/page",
      "title": "My Link",
      "created_at": "2024-01-01T00:00:00+0000",
      "tags": []
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}