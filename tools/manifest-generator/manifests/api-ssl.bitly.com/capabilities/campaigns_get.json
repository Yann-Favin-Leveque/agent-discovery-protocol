{
  "name": "campaigns_get",
  "description": "Retrieve details of a specific campaign.",
  "endpoint": "/v4/campaigns/{campaign_guid}",
  "method": "GET",
  "resource_group": "campaigns",
  "parameters": [
    {
      "name": "campaign_guid",
      "type": "string",
      "description": "The campaign GUID.",
      "required": true,
      "example": "Ca1bc2de3fg"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/campaigns/Ca1bc2de3fg",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "guid": "Ca1bc2de3fg",
      "name": "Q1 Campaign",
      "group_guid": "Ba1bc2de3fg",
      "created": "2024-01-01T00:00:00+0000"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}