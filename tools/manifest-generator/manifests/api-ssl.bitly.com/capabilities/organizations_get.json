{
  "name": "organizations_get",
  "description": "Retrieve details of a specific organization.",
  "endpoint": "/v4/organizations/{organization_guid}",
  "method": "GET",
  "resource_group": "organizations",
  "parameters": [
    {
      "name": "organization_guid",
      "type": "string",
      "description": "The organization GUID.",
      "required": true,
      "example": "Oa1bc2de3fg"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api-ssl.bitly.com/v4/organizations/Oa1bc2de3fg",
    "headers": {
      "Authorization": "Bearer {token}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "guid": "Oa1bc2de3fg",
      "name": "My Org",
      "tier": "enterprise"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 600
  }
}