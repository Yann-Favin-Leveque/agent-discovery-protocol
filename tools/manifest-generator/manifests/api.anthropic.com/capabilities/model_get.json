{
  "name": "model_get",
  "description": "Retrieve detailed information about a specific Claude model by its ID, including capabilities and context window size.",
  "resource_group": "models",
  "endpoint": "/v1/models/{model_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "model_id",
      "type": "string",
      "required": true,
      "description": "The ID of the model to retrieve (e.g. 'claude-sonnet-4-6').",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.anthropic.com/v1/models/claude-sonnet-4-6",
    "headers": {
      "x-api-key": "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "anthropic-version": "2023-06-01"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "claude-sonnet-4-6",
      "display_name": "Claude Sonnet 4.6",
      "type": "model",
      "created_at": "2025-05-01T00:00:00Z"
    }
  }
}
