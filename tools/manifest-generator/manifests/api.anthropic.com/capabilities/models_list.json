{
  "name": "models_list",
  "description": "Retrieve the list of available Claude models including their IDs, display names, and context window sizes.",
  "resource_group": "models",
  "endpoint": "/v1/models",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Number of models to return (default 20).",
      "in": "query"
    },
    {
      "name": "before_id",
      "type": "string",
      "required": false,
      "description": "Return models before this ID for pagination.",
      "in": "query"
    },
    {
      "name": "after_id",
      "type": "string",
      "required": false,
      "description": "Return models after this ID for pagination.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.anthropic.com/v1/models",
    "headers": {
      "x-api-key": "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "anthropic-version": "2023-06-01"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "id": "claude-opus-4-6",
          "display_name": "Claude Opus 4.6",
          "type": "model",
          "created_at": "2025-05-01T00:00:00Z"
        },
        {
          "id": "claude-sonnet-4-6",
          "display_name": "Claude Sonnet 4.6",
          "type": "model",
          "created_at": "2025-05-01T00:00:00Z"
        }
      ]
    }
  }
}
