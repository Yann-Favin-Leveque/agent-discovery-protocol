{
  "name": "create_app",
  "description": "Create a new Fly.io application in a specific organization.",
  "endpoint": "/apps",
  "method": "POST",
  "parameters": [
    {"name": "app_name", "type": "string", "description": "Unique name for the application.", "required": true, "example": "my-new-app"},
    {"name": "org_slug", "type": "string", "description": "Organization to create the app in.", "required": true, "example": "personal"}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"app_name": "my-new-app", "org_slug": "personal"}
  },
  "response_example": {
    "status": 201,
    "body": {"id": "app_xyz789", "name": "my-new-app", "organization": {"slug": "personal"}, "status": "pending"}
  }
}
