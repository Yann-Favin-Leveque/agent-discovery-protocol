{
  "name": "volumes_get",
  "description": "Get volume details.",
  "resource_group": "volumes",
  "endpoint": "/v1/apps/{app_name}/volumes/{volume_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    },
    {
      "name": "volume_id",
      "type": "string",
      "required": true,
      "description": "Volume ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps/my-app/volumes/vol-abc"
  },
  "response_example": {
    "id": "vol-abc",
    "name": "data",
    "region": "iad",
    "size_gb": 10
  }
}
