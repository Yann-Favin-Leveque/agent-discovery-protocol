{
  "name": "apps_get",
  "description": "Get app details.",
  "resource_group": "apps",
  "endpoint": "/v1/apps/{app_name}",
  "method": "GET",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps/my-app"
  },
  "response_example": {
    "id": "app-abc",
    "name": "my-app",
    "organization": {
      "slug": "my-org"
    },
    "status": "deployed"
  }
}
