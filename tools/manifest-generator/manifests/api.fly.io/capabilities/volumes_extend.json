{
  "name": "volumes_extend",
  "description": "Extend a volume's size.",
  "resource_group": "volumes",
  "endpoint": "/v1/apps/{app_name}/volumes/{volume_id}/extend",
  "method": "PUT",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name."
    },
    {
      "name": "volume_id",
      "type": "string",
      "required": true,
      "description": "Volume ID."
    },
    {
      "name": "size_gb",
      "type": "integer",
      "required": true,
      "description": "New size (must be larger)."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.machines.dev/v1/apps/my-app/volumes/vol-abc/extend",
    "body": {
      "size_gb": 20
    }
  },
  "response_example": {
    "needs_restart": true,
    "volume": {
      "id": "vol-abc",
      "size_gb": 20
    }
  }
}