{
  "name": "apps_list",
  "description": "List all apps in an organization.",
  "resource_group": "apps",
  "endpoint": "/v1/apps",
  "method": "GET",
  "parameters": [
    {
      "name": "org_slug",
      "type": "string",
      "required": true,
      "description": "Organization slug."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps?org_slug=my-org"
  },
  "response_example": {
    "total_apps": 2,
    "apps": [
      {
        "id": "app-abc",
        "name": "my-app",
        "organization": {
          "slug": "my-org"
        }
      }
    ]
  }
}