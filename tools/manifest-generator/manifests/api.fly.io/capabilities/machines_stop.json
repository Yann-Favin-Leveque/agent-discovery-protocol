{
  "name": "machines_stop",
  "description": "Stop a running Machine.",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}/stop",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name."
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID."
    },
    {
      "name": "signal",
      "type": "string",
      "required": false,
      "description": "Signal to send."
    },
    {
      "name": "timeout",
      "type": "integer",
      "required": false,
      "description": "Timeout in seconds."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc/stop"
  },
  "response_example": {
    "ok": true
  }
}