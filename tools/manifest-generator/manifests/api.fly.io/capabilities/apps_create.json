{
  "name": "apps_create",
  "description": "Create a new Fly App.",
  "resource_group": "apps",
  "endpoint": "/v1/apps",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "Unique app name."
    },
    {
      "name": "org_slug",
      "type": "string",
      "required": true,
      "description": "Organization slug."
    },
    {
      "name": "network",
      "type": "string",
      "required": false,
      "description": "Private network name."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps",
    "body": {
      "app_name": "my-app",
      "org_slug": "my-org"
    }
  },
  "response_example": {
    "id": "app-new",
    "name": "my-app",
    "status": "pending"
  }
}