{
  "name": "list_apps",
  "description": "List all applications in the authenticated user's Fly.io organization.",
  "endpoint": "/apps",
  "method": "GET",
  "parameters": [
    {"name": "org_slug", "type": "string", "description": "Organization slug to filter apps by.", "required": true, "example": "personal"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps?org_slug=personal",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": {"total_apps": 5, "apps": [{"id": "app_abc123", "name": "my-web-app", "status": "deployed", "organization": {"slug": "personal"}}]}
  }
}
