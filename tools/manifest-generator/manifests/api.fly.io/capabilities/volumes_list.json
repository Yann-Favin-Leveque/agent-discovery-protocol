{
  "name": "volumes_list",
  "description": "List all volumes for an app.",
  "resource_group": "volumes",
  "endpoint": "/v1/apps/{app_name}/volumes",
  "method": "GET",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps/my-app/volumes"
  },
  "response_example": [
    {
      "id": "vol-abc",
      "name": "data",
      "region": "iad",
      "size_gb": 10,
      "state": "created"
    }
  ]
}
