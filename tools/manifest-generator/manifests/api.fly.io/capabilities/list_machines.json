{
  "name": "list_machines",
  "description": "List all Fly Machines (micro-VMs) running for a specific application.",
  "endpoint": "/apps/{app_name}/machines",
  "method": "GET",
  "parameters": [
    {"name": "app_name", "type": "string", "description": "Name of the Fly app.", "required": true, "example": "my-web-app"}
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps/my-web-app/machines",
    "headers": {"Authorization": "Bearer {api_key}"}
  },
  "response_example": {
    "status": 200,
    "body": [{"id": "machine_abc", "name": "my-web-app-1", "state": "started", "region": "iad", "instance_id": "inst_123", "config": {"image": "my-web-app:latest", "guest": {"cpus": 1, "memory_mb": 256}}}]
  }
}
