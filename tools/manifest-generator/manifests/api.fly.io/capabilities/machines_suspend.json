{
  "name": "machines_suspend",
  "description": "Suspend a Machine (save state to disk).",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}/suspend",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc/suspend"
  },
  "response_example": {
    "ok": true
  }
}
