{
  "name": "volumes_snapshots_list",
  "description": "List snapshots for a volume.",
  "resource_group": "volumes",
  "endpoint": "/v1/apps/{app_name}/volumes/{volume_id}/snapshots",
  "method": "GET",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    },
    {
      "name": "volume_id",
      "type": "string",
      "required": true,
      "description": "Volume ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps/my-app/volumes/vol-abc/snapshots"
  },
  "response_example": [
    {
      "id": "snap-abc",
      "size": 1073741824,
      "created_at": "2026-01-20T00:00:00Z"
    }
  ]
}
