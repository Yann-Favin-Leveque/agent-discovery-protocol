{
  "name": "machines_metadata_get",
  "description": "Get all metadata for a Machine.",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}/metadata",
  "method": "GET",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc/metadata"
  },
  "response_example": {
    "env": "production",
    "version": "1.2.3"
  }
}
