{
  "name": "machines_metadata_set",
  "description": "Set a metadata key-value on a Machine.",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}/metadata/{key}",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID.",
      "in": "path"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "Metadata key.",
      "in": "path"
    },
    {
      "name": "value",
      "type": "string",
      "required": true,
      "description": "Value.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc/metadata/version",
    "body": "1.3.0"
  },
  "response_example": null
}
