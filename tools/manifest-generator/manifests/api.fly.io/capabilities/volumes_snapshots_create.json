{
  "name": "volumes_snapshots_create",
  "description": "Create a volume snapshot.",
  "resource_group": "volumes",
  "endpoint": "/v1/apps/{app_name}/volumes/{volume_id}/snapshots",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name."
    },
    {
      "name": "volume_id",
      "type": "string",
      "required": true,
      "description": "Volume ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-app/volumes/vol-abc/snapshots"
  },
  "response_example": {
    "id": "snap-new",
    "status": "creating"
  }
}