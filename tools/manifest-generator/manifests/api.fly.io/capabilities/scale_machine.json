{
  "name": "scale_machine",
  "description": "Update a Fly Machine's CPU, memory, and resource configuration for vertical scaling.",
  "endpoint": "/apps/{app_name}/machines/{machine_id}",
  "method": "POST",
  "parameters": [
    {"name": "app_name", "type": "string", "description": "Name of the Fly app.", "required": true, "example": "my-web-app"},
    {"name": "machine_id", "type": "string", "description": "ID of the machine to update.", "required": true, "example": "machine_abc"},
    {"name": "config", "type": "object", "description": "Updated machine configuration with new resource limits.", "required": true, "example": {"guest": {"cpus": 2, "memory_mb": 512}}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-web-app/machines/machine_abc",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"config": {"guest": {"cpus": 2, "memory_mb": 512}}}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "machine_abc", "name": "web-1", "state": "started", "config": {"guest": {"cpus": 2, "memory_mb": 512}}}
  }
}
