{
  "name": "machines_metadata_delete",
  "description": "Delete a metadata key.",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}/metadata/{key}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID.",
      "in": "path"
    },
    {
      "name": "key",
      "type": "string",
      "required": true,
      "description": "Key to delete.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc/metadata/old-key"
  },
  "response_example": null
}
