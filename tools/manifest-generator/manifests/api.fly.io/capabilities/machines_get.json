{
  "name": "machines_get",
  "description": "Get Machine details.",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name."
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc"
  },
  "response_example": {
    "id": "mach-abc",
    "name": "web-1",
    "state": "started",
    "region": "iad",
    "config": {
      "image": "my-org/app:latest"
    }
  }
}