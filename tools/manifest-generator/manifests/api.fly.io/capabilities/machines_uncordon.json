{
  "name": "machines_uncordon",
  "description": "Uncordon a Machine (allow connections).",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}/uncordon",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name."
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc/uncordon"
  },
  "response_example": {
    "ok": true
  }
}