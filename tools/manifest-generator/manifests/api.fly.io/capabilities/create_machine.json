{
  "name": "create_machine",
  "description": "Create and start a new Fly Machine with a specified Docker image and resource configuration.",
  "endpoint": "/apps/{app_name}/machines",
  "method": "POST",
  "parameters": [
    {"name": "app_name", "type": "string", "description": "Name of the Fly app (path parameter).", "required": true, "example": "my-web-app"},
    {"name": "name", "type": "string", "description": "Name for the machine.", "required": false, "example": "web-1"},
    {"name": "region", "type": "string", "description": "Region to deploy the machine in.", "required": false, "example": "iad"},
    {"name": "config", "type": "object", "description": "Machine configuration including image, guest resources, services.", "required": true, "example": {"image": "registry.fly.io/my-web-app:latest", "guest": {"cpus": 1, "memory_mb": 256}}}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-web-app/machines",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": {"name": "web-1", "region": "iad", "config": {"image": "registry.fly.io/my-web-app:latest", "guest": {"cpus": 1, "memory_mb": 256}, "services": [{"ports": [{"port": 443, "handlers": ["tls", "http"]}], "protocol": "tcp", "internal_port": 8080}]}}
  },
  "response_example": {
    "status": 200,
    "body": {"id": "machine_new123", "name": "web-1", "state": "started", "region": "iad", "instance_id": "inst_456"}
  }
}
