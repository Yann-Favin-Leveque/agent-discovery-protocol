{
  "name": "machines_delete",
  "description": "Delete a Machine.",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name.",
      "in": "path"
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID.",
      "in": "path"
    },
    {
      "name": "force",
      "type": "boolean",
      "required": false,
      "description": "Force delete.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc"
  },
  "response_example": {
    "ok": true
  }
}
