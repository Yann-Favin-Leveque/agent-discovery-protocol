{
  "name": "manage_secrets",
  "description": "Set or manage secrets (encrypted environment variables) for a Fly.io application.",
  "endpoint": "/apps/{app_name}/secrets",
  "method": "POST",
  "parameters": [
    {"name": "app_name", "type": "string", "description": "Name of the Fly app (path parameter).", "required": true, "example": "my-web-app"},
    {"name": "secrets", "type": "array", "description": "Array of secret key-value pairs to set.", "required": true, "example": [{"name": "DATABASE_URL", "value": "postgresql://..."}]}
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-web-app/secrets",
    "headers": {"Authorization": "Bearer {api_key}", "Content-Type": "application/json"},
    "body": [{"name": "DATABASE_URL", "value": "postgresql://user:pass@host:5432/db"}, {"name": "REDIS_URL", "value": "redis://host:6379"}]
  },
  "response_example": {
    "status": 200,
    "body": {"message": "Secrets set successfully", "release": {"id": "rel_abc", "version": 3}}
  }
}
