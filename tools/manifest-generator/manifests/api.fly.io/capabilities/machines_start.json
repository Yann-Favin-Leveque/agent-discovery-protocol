{
  "name": "machines_start",
  "description": "Start a stopped Machine.",
  "resource_group": "machines",
  "endpoint": "/v1/apps/{app_name}/machines/{machine_id}/start",
  "method": "POST",
  "parameters": [
    {
      "name": "app_name",
      "type": "string",
      "required": true,
      "description": "App name."
    },
    {
      "name": "machine_id",
      "type": "string",
      "required": true,
      "description": "Machine ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.machines.dev/v1/apps/my-app/machines/mach-abc/start"
  },
  "response_example": {
    "previous_state": "stopped",
    "migrated": false
  }
}