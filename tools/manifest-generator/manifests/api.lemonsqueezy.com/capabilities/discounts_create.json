{
  "name": "discounts_create",
  "description": "Create a discount code.",
  "resource_group": "discounts",
  "endpoint": "/v1/discounts",
  "method": "POST",
  "parameters": [
    {
      "name": "data.attributes.name",
      "type": "string",
      "description": "Discount name.",
      "required": true
    },
    {
      "name": "data.attributes.code",
      "type": "string",
      "description": "Discount code.",
      "required": true,
      "example": "SAVE10"
    },
    {
      "name": "data.attributes.amount",
      "type": "integer",
      "description": "Discount amount.",
      "required": true
    },
    {
      "name": "data.attributes.amount_type",
      "type": "string",
      "description": "Type: percent or fixed.",
      "required": true,
      "example": "percent"
    },
    {
      "name": "data.relationships.store",
      "type": "object",
      "description": "Store relationship.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemonsqueezy.com/v1/discounts",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json",
      "Accept": "application/vnd.api+json"
    },
    "body": {
      "data": {
        "type": "discounts",
        "attributes": {
          "name": "10% Off",
          "code": "SAVE10",
          "amount": 10,
          "amount_type": "percent"
        },
        "relationships": {
          "store": {
            "data": {
              "type": "stores",
              "id": "1"
            }
          }
        }
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "type": "discounts",
        "id": "1",
        "attributes": {
          "code": "SAVE10"
        }
      }
    }
  }
}