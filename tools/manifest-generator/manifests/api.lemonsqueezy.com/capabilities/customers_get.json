{
  "name": "customers_get",
  "description": "Retrieve a specific customer by ID.",
  "resource_group": "customers",
  "endpoint": "/v1/customers/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The customer ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/customers/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "customers",
        "id": "1",
        "attributes": {
          "name": "John Doe"
        }
      }
    }
  }
}
