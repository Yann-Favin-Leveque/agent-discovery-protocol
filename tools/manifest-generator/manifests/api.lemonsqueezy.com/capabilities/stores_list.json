{
  "name": "stores_list",
  "description": "List all stores.",
  "resource_group": "stores",
  "endpoint": "/v1/stores",
  "method": "GET",
  "parameters": [
    {
      "name": "page[number]",
      "type": "integer",
      "description": "Page number.",
      "required": false,
      "in": "query"
    },
    {
      "name": "page[size]",
      "type": "integer",
      "description": "Items per page.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/stores",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "stores",
          "id": "1",
          "attributes": {
            "name": "My Store"
          }
        }
      ]
    }
  }
}
