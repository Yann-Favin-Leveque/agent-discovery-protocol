{
  "name": "prices_get",
  "description": "Retrieve a specific price by ID.",
  "resource_group": "prices",
  "endpoint": "/v1/prices/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The price ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/prices/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "prices",
        "id": "1"
      }
    }
  }
}