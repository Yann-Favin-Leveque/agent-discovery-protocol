{
  "name": "orders_get",
  "description": "Retrieve a specific order by ID.",
  "resource_group": "orders",
  "endpoint": "/v1/orders/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The order ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/orders/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "orders",
        "id": "1",
        "attributes": {
          "status": "paid"
        }
      }
    }
  }
}