{
  "name": "subscription_invoices_get",
  "description": "Retrieve a specific subscription invoice.",
  "resource_group": "subscription_invoices",
  "endpoint": "/v1/subscription-invoices/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The invoice ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/subscription-invoices/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "subscription-invoices",
        "id": "1"
      }
    }
  }
}