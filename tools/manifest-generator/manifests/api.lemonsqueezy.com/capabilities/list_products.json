{
  "name": "list_products",
  "description": "List all products in your Lemon Squeezy store. Products represent what you sell and have variants that define pricing. The response follows JSON:API format with pagination. You can filter products by store ID.",
  "endpoint": "/v1/products",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[store_id]",
      "type": "integer",
      "description": "Filter products belonging to a specific store.",
      "required": false,
      "example": 12345
    },
    {
      "name": "page[number]",
      "type": "integer",
      "description": "The page number for pagination.",
      "required": false,
      "example": 1
    },
    {
      "name": "page[size]",
      "type": "integer",
      "description": "Number of items per page. Default 10.",
      "required": false,
      "example": 10
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/products?filter[store_id]=12345&page[size]=10",
    "headers": {
      "Authorization": "Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...",
      "Accept": "application/vnd.api+json",
      "Content-Type": "application/vnd.api+json"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "meta": {
        "page": { "currentPage": 1, "from": 1, "lastPage": 3, "perPage": 10, "to": 10, "total": 25 }
      },
      "jsonapi": { "version": "1.0" },
      "links": {
        "first": "https://api.lemonsqueezy.com/v1/products?page[number]=1&page[size]=10",
        "last": "https://api.lemonsqueezy.com/v1/products?page[number]=3&page[size]=10",
        "next": "https://api.lemonsqueezy.com/v1/products?page[number]=2&page[size]=10"
      },
      "data": [
        {
          "type": "products",
          "id": "1",
          "attributes": {
            "store_id": 12345,
            "name": "Pro License",
            "slug": "pro-license",
            "description": "Full access to all pro features",
            "status": "published",
            "status_formatted": "Published",
            "thumb_url": "https://app.lemonsqueezy.com/storage/media/images/product-thumb.png",
            "price": 4999,
            "price_formatted": "$49.99",
            "created_at": "2024-01-15T10:00:00.000000Z",
            "updated_at": "2024-03-10T08:30:00.000000Z"
          },
          "relationships": {
            "store": { "links": { "related": "https://api.lemonsqueezy.com/v1/products/1/store" } },
            "variants": { "links": { "related": "https://api.lemonsqueezy.com/v1/products/1/variants" } }
          }
        }
      ]
    }
  }
}
