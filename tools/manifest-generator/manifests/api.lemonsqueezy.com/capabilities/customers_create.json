{
  "name": "customers_create",
  "description": "Create a new customer.",
  "resource_group": "customers",
  "endpoint": "/v1/customers",
  "method": "POST",
  "parameters": [
    {
      "name": "data.type",
      "type": "string",
      "description": "Resource type (customers).",
      "required": true
    },
    {
      "name": "data.attributes.name",
      "type": "string",
      "description": "Customer name.",
      "required": true
    },
    {
      "name": "data.attributes.email",
      "type": "string",
      "description": "Customer email.",
      "required": true
    },
    {
      "name": "data.relationships.store",
      "type": "object",
      "description": "Store relationship.",
      "required": true
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemonsqueezy.com/v1/customers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json",
      "Accept": "application/vnd.api+json"
    },
    "body": {
      "data": {
        "type": "customers",
        "attributes": {
          "name": "John Doe",
          "email": "john@example.com"
        },
        "relationships": {
          "store": {
            "data": {
              "type": "stores",
              "id": "1"
            }
          }
        }
      }
    }
  },
  "response_example": {
    "status": 201,
    "body": {
      "data": {
        "type": "customers",
        "id": "1",
        "attributes": {
          "name": "John Doe"
        }
      }
    }
  }
}