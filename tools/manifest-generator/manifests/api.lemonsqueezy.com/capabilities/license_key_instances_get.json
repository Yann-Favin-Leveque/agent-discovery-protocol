{
  "name": "license_key_instances_get",
  "description": "Retrieve a specific license key instance.",
  "resource_group": "license_key_instances",
  "endpoint": "/v1/license-key-instances/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The instance ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/license-key-instances/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "license-key-instances",
        "id": "1"
      }
    }
  }
}
