{
  "name": "subscription_invoices_generate",
  "description": "Generate a subscription invoice PDF.",
  "resource_group": "subscription_invoices",
  "endpoint": "/v1/subscription-invoices/{id}/generate-invoice",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The subscription invoice ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemonsqueezy.com/v1/subscription-invoices/1/generate-invoice",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "meta": {
        "urls": {
          "download_invoice": "https://..."
        }
      }
    }
  }
}
