{
  "name": "files_list",
  "description": "List all files.",
  "resource_group": "files",
  "endpoint": "/v1/files",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[variant_id]",
      "type": "integer",
      "description": "Filter by variant.",
      "required": false,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/files",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "files",
          "id": "1"
        }
      ]
    }
  }
}
