{
  "name": "subscriptions_list",
  "description": "List all subscriptions with filtering.",
  "resource_group": "subscriptions",
  "endpoint": "/v1/subscriptions",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[store_id]",
      "type": "integer",
      "description": "Filter by store.",
      "required": false
    },
    {
      "name": "filter[status]",
      "type": "string",
      "description": "Filter by status.",
      "required": false
    },
    {
      "name": "filter[product_id]",
      "type": "integer",
      "description": "Filter by product.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/subscriptions",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "subscriptions",
          "id": "1"
        }
      ]
    }
  }
}