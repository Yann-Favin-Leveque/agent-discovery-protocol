{
  "name": "licenses_validate",
  "description": "Validate a license key.",
  "resource_group": "licenses",
  "endpoint": "/v1/licenses/validate",
  "method": "POST",
  "parameters": [
    {
      "name": "license_key",
      "type": "string",
      "description": "The license key to validate.",
      "required": true,
      "in": "body"
    },
    {
      "name": "instance_id",
      "type": "string",
      "description": "Instance ID for per-instance validation.",
      "required": false,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemonsqueezy.com/v1/licenses/validate",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json",
      "Accept": "application/vnd.api+json"
    },
    "body": {
      "license_key": "XXXXX-XXXXX-XXXXX"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "valid": true,
      "license_key": {
        "status": "active",
        "activation_limit": 5,
        "activations_count": 1
      }
    }
  }
}
