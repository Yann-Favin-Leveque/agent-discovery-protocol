{
  "name": "orders_list",
  "description": "List all orders with filtering.",
  "resource_group": "orders",
  "endpoint": "/v1/orders",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[store_id]",
      "type": "integer",
      "description": "Filter by store.",
      "required": false
    },
    {
      "name": "filter[user_email]",
      "type": "string",
      "description": "Filter by email.",
      "required": false
    },
    {
      "name": "filter[status]",
      "type": "string",
      "description": "Filter by status.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/orders",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "orders",
          "id": "1"
        }
      ]
    }
  }
}