{
  "name": "subscription_items_usage",
  "description": "Get current usage for a metered subscription item.",
  "resource_group": "subscription_items",
  "endpoint": "/v1/subscription-items/{id}/current-usage",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The subscription item ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/subscription-items/1/current-usage",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "meta": {
        "quantity": 42,
        "period_start": "2024-01-01",
        "period_end": "2024-01-31"
      }
    }
  }
}