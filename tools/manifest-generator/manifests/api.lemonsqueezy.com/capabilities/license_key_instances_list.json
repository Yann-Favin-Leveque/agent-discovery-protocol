{
  "name": "license_key_instances_list",
  "description": "List all license key instances.",
  "resource_group": "license_key_instances",
  "endpoint": "/v1/license-key-instances",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[license_key_id]",
      "type": "integer",
      "description": "Filter by license key.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/license-key-instances",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "license-key-instances",
          "id": "1"
        }
      ]
    }
  }
}