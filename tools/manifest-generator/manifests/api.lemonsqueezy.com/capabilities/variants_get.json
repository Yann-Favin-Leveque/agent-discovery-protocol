{
  "name": "variants_get",
  "description": "Retrieve a specific variant by ID.",
  "resource_group": "variants",
  "endpoint": "/v1/variants/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The variant ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/variants/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "variants",
        "id": "1",
        "attributes": {
          "name": "Default"
        }
      }
    }
  }
}