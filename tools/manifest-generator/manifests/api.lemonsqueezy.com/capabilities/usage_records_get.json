{
  "name": "usage_records_get",
  "description": "Retrieve a specific usage record.",
  "resource_group": "usage_records",
  "endpoint": "/v1/usage-records/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The usage record ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/usage-records/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "usage-records",
        "id": "1"
      }
    }
  }
}