{
  "name": "license_keys_list",
  "description": "List all license keys.",
  "resource_group": "license_keys",
  "endpoint": "/v1/license-keys",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[store_id]",
      "type": "integer",
      "description": "Filter by store.",
      "required": false
    },
    {
      "name": "filter[order_id]",
      "type": "integer",
      "description": "Filter by order.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/license-keys",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "license-keys",
          "id": "1"
        }
      ]
    }
  }
}