{
  "name": "discounts_get",
  "description": "Retrieve a specific discount by ID.",
  "resource_group": "discounts",
  "endpoint": "/v1/discounts/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The discount ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/discounts/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "discounts",
        "id": "1"
      }
    }
  }
}
