{
  "name": "license_keys_get",
  "description": "Retrieve a specific license key.",
  "resource_group": "license_keys",
  "endpoint": "/v1/license-keys/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The license key ID.",
      "required": true
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/license-keys/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "license-keys",
        "id": "1",
        "attributes": {
          "key": "XXXXX-XXXXX-XXXXX"
        }
      }
    }
  }
}