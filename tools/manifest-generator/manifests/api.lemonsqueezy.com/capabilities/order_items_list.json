{
  "name": "order_items_list",
  "description": "List all order items.",
  "resource_group": "order_items",
  "endpoint": "/v1/order-items",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[order_id]",
      "type": "integer",
      "description": "Filter by order.",
      "required": false
    },
    {
      "name": "filter[product_id]",
      "type": "integer",
      "description": "Filter by product.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/order-items",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "order-items",
          "id": "1"
        }
      ]
    }
  }
}