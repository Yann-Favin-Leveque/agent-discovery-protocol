{
  "name": "get_customer",
  "description": "Retrieve the full details of a specific customer in your Lemon Squeezy store. Returns the customer's name, email, city, country, total revenue, and links to their orders and subscriptions.",
  "endpoint": "/v1/customers/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "description": "The unique customer ID.",
      "required": true,
      "example": 1
    },
    {
      "name": "include",
      "type": "string",
      "description": "Comma-separated list of related resources to include. Options: 'license-keys', 'orders', 'subscriptions', 'store'.",
      "required": false,
      "example": "orders,subscriptions"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/customers/1?include=orders,subscriptions",
    "headers": {
      "Authorization": "Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...",
      "Accept": "application/vnd.api+json",
      "Content-Type": "application/vnd.api+json"
    },
    "body": null
  },
  "response_example": {
    "status": 200,
    "body": {
      "jsonapi": { "version": "1.0" },
      "data": {
        "type": "customers",
        "id": "1",
        "attributes": {
          "store_id": 12345,
          "name": "Jane Doe",
          "email": "jane@example.com",
          "status": "subscribed",
          "status_formatted": "Subscribed",
          "city": "Amsterdam",
          "region": "North Holland",
          "country": "NL",
          "total_revenue_currency": 4999,
          "mrr": 999,
          "created_at": "2024-01-10T08:00:00.000000Z",
          "updated_at": "2024-03-14T14:30:00.000000Z"
        },
        "relationships": {
          "store": { "links": { "related": "https://api.lemonsqueezy.com/v1/customers/1/store" } },
          "orders": { "links": { "related": "https://api.lemonsqueezy.com/v1/customers/1/orders" } },
          "subscriptions": { "links": { "related": "https://api.lemonsqueezy.com/v1/customers/1/subscriptions" } },
          "license-keys": { "links": { "related": "https://api.lemonsqueezy.com/v1/customers/1/license-keys" } }
        }
      }
    }
  }
}
