{
  "name": "subscriptions_cancel",
  "description": "Cancel an active subscription.",
  "resource_group": "subscriptions",
  "endpoint": "/v1/subscriptions/{id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The subscription ID.",
      "required": true,
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.lemonsqueezy.com/v1/subscriptions/1",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "subscriptions",
        "id": "1",
        "attributes": {
          "status": "cancelled"
        }
      }
    }
  }
}
