{
  "name": "licenses_deactivate",
  "description": "Deactivate a license key instance.",
  "resource_group": "licenses",
  "endpoint": "/v1/licenses/deactivate",
  "method": "POST",
  "parameters": [
    {
      "name": "license_key",
      "type": "string",
      "description": "The license key string.",
      "required": true,
      "in": "body"
    },
    {
      "name": "instance_id",
      "type": "string",
      "description": "The instance ID to deactivate.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemonsqueezy.com/v1/licenses/deactivate",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json",
      "Accept": "application/vnd.api+json"
    },
    "body": {
      "license_key": "XXXXX-XXXXX-XXXXX",
      "instance_id": "ins_1234"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "deactivated": true
    }
  }
}
