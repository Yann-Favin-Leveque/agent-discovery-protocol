{
  "name": "customers_list",
  "description": "List all customers with filtering and pagination.",
  "resource_group": "customers",
  "endpoint": "/v1/customers",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[store_id]",
      "type": "integer",
      "description": "Filter by store.",
      "required": false
    },
    {
      "name": "filter[email]",
      "type": "string",
      "description": "Filter by email.",
      "required": false
    },
    {
      "name": "page[number]",
      "type": "integer",
      "description": "Page number.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/customers",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "customers",
          "id": "1"
        }
      ]
    }
  }
}