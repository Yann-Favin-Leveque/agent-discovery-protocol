{
  "name": "subscription_invoices_list",
  "description": "List all subscription invoices.",
  "resource_group": "subscription_invoices",
  "endpoint": "/v1/subscription-invoices",
  "method": "GET",
  "parameters": [
    {
      "name": "filter[store_id]",
      "type": "integer",
      "description": "Filter by store.",
      "required": false
    },
    {
      "name": "filter[status]",
      "type": "string",
      "description": "Filter by status.",
      "required": false
    },
    {
      "name": "filter[subscription_id]",
      "type": "integer",
      "description": "Filter by subscription.",
      "required": false
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.lemonsqueezy.com/v1/subscription-invoices",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Accept": "application/vnd.api+json"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": [
        {
          "type": "subscription-invoices",
          "id": "1"
        }
      ]
    }
  }
}