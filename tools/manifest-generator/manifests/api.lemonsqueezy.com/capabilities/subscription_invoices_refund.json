{
  "name": "subscription_invoices_refund",
  "description": "Issue a refund for a subscription invoice.",
  "resource_group": "subscription_invoices",
  "endpoint": "/v1/subscription-invoices/{id}/refund",
  "method": "POST",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "The subscription invoice ID.",
      "required": true,
      "in": "path"
    },
    {
      "name": "data.attributes.amount",
      "type": "integer",
      "description": "Amount to refund in cents.",
      "required": true,
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.lemonsqueezy.com/v1/subscription-invoices/1/refund",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json",
      "Accept": "application/vnd.api+json"
    },
    "body": {
      "data": {
        "type": "subscription-invoices",
        "attributes": {
          "amount": 999
        }
      }
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "type": "subscription-invoices",
        "id": "1",
        "attributes": {
          "refunded": true
        }
      }
    }
  }
}
