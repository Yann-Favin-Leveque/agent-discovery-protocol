{
  "name": "objects_list",
  "description": "List all objects in a collection.",
  "endpoint": "/v1/objects/{collection}",
  "method": "GET",
  "resource_group": "objects",
  "parameters": [
    {
      "name": "collection",
      "type": "string",
      "description": "Collection name.",
      "required": true,
      "example": "projects",
      "in": "path"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 50,
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/objects/projects?page_size=50",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "project_123",
          "name": "My Project"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
