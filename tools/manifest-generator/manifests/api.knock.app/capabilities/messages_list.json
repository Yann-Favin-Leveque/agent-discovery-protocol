{
  "name": "messages_list",
  "description": "List messages for the current environment with optional filtering.",
  "endpoint": "/v1/messages",
  "method": "GET",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "channel_id",
      "type": "string",
      "description": "Filter by channel.",
      "required": false,
      "example": "email-channel"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Filter by status.",
      "required": false,
      "example": "delivered"
    },
    {
      "name": "page_size",
      "type": "integer",
      "description": "Results per page.",
      "required": false,
      "example": 50
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/messages?status=delivered&page_size=50",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "msg_abc",
          "status": "delivered",
          "channel_id": "email-channel"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}