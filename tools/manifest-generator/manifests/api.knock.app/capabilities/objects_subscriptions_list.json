{
  "name": "objects_subscriptions_list",
  "description": "List subscriptions for an object (users subscribed to it).",
  "endpoint": "/v1/objects/{collection}/{object_id}/subscriptions",
  "method": "GET",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "collection",
      "type": "string",
      "description": "Collection name.",
      "required": true,
      "example": "projects"
    },
    {
      "name": "object_id",
      "type": "string",
      "description": "Object ID.",
      "required": true,
      "example": "project_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/objects/projects/project_123/subscriptions",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "recipient": {
            "id": "user_123"
          },
          "inserted_at": "2024-01-15T10:00:00Z"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}