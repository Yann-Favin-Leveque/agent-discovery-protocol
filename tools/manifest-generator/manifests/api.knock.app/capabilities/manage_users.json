{
  "name": "manage_users",
  "description": "Create, update, and manage user profiles in Knock. Users are the recipients of notifications and can have channel-specific data like push tokens and email addresses.",
  "endpoint": "/v1/users/{user_id}",
  "method": "PUT",
  "parameters": [
    { "name": "user_id", "type": "string", "description": "Unique user identifier.", "required": true, "example": "user_123" },
    { "name": "name", "type": "string", "description": "User display name.", "required": false, "example": "Jane Doe" },
    { "name": "email", "type": "string", "description": "User email address.", "required": false, "example": "jane@example.com" },
    { "name": "phone_number", "type": "string", "description": "User phone number for SMS.", "required": false, "example": "+15551234567" }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.knock.app/v1/users/user_123",
    "headers": { "Authorization": "Bearer {api_key}", "Content-Type": "application/json" },
    "body": { "name": "Jane Doe", "email": "jane@example.com", "phone_number": "+15551234567" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "user_123", "name": "Jane Doe", "email": "jane@example.com", "created_at": "2024-01-15T10:00:00Z", "updated_at": "2024-02-01T14:30:00Z" }
  }
}
