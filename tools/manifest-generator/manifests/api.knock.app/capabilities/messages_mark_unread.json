{
  "name": "messages_mark_unread",
  "description": "Mark a message as unread.",
  "endpoint": "/v1/messages/{message_id}/read",
  "method": "DELETE",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "message_id",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "msg_abc123"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.knock.app/v1/messages/msg_abc123/read",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "msg_abc123",
      "read_at": null
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}