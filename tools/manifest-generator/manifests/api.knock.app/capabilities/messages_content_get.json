{
  "name": "messages_content_get",
  "description": "Get the fully rendered content of a message.",
  "endpoint": "/v1/messages/{message_id}/content",
  "method": "GET",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "message_id",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "msg_abc123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/messages/msg_abc123/content",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "data": {
        "subject": "New comment on your post",
        "body": "<p>John commented: Great work!</p>"
      }
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}