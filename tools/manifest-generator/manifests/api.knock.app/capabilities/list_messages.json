{
  "name": "list_messages",
  "description": "List and retrieve notification messages with their delivery status, content, and engagement events. Filter by channel, status, and more.",
  "endpoint": "/v1/messages",
  "method": "GET",
  "parameters": [
    { "name": "channel_id", "type": "string", "description": "Filter by channel ID.", "required": false, "example": "ch_email" },
    { "name": "status", "type": "string", "description": "Filter by status: queued, sent, delivered, bounced, etc.", "required": false, "example": "delivered" },
    { "name": "page_size", "type": "number", "description": "Number of results per page.", "required": false, "example": 50 },
    { "name": "after", "type": "string", "description": "Cursor for pagination.", "required": false, "example": "msg_abc" }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/messages?status=delivered&page_size=50",
    "headers": { "Authorization": "Bearer {api_key}" }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        { "id": "msg_xyz789", "channel_id": "ch_email", "recipient": { "id": "user_123" }, "status": "delivered", "inserted_at": "2024-02-01T14:30:00Z", "delivered_at": "2024-02-01T14:30:02Z" }
      ],
      "page_info": { "after": "msg_xyz789", "before": null }
    }
  }
}
