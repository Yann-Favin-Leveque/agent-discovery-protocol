{
  "name": "messages_events_list",
  "description": "List delivery events for a message.",
  "endpoint": "/v1/messages/{message_id}/events",
  "method": "GET",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "message_id",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "msg_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/messages/msg_abc123/events",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "type": "message.delivered",
          "inserted_at": "2024-01-15T10:00:01Z"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
