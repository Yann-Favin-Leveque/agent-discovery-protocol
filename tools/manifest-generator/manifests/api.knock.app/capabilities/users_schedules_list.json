{
  "name": "users_schedules_list",
  "description": "List notification schedules for a user.",
  "endpoint": "/v1/users/{user_id}/schedules",
  "method": "GET",
  "resource_group": "schedules",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "User ID.",
      "required": true,
      "example": "user_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/users/user_123/schedules",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "id": "schedule_1",
          "workflow": "weekly-digest",
          "next_occurrence": "2024-01-22T10:00:00Z"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}