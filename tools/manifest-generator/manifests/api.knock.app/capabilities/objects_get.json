{
  "name": "objects_get",
  "description": "Retrieve a specific object from a collection.",
  "endpoint": "/v1/objects/{collection}/{id}",
  "method": "GET",
  "resource_group": "objects",
  "parameters": [
    {
      "name": "collection",
      "type": "string",
      "description": "Collection name.",
      "required": true,
      "example": "projects",
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "Object ID.",
      "required": true,
      "example": "project_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/objects/projects/project_123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "project_123",
      "collection": "projects",
      "name": "My Project"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
