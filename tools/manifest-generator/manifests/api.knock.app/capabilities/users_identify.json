{
  "name": "users_identify",
  "description": "Create or update a user with identification data (name, email, phone, etc.).",
  "endpoint": "/v1/users/{user_id}",
  "method": "PUT",
  "resource_group": "users",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "User ID to create or update.",
      "required": true,
      "example": "user_123"
    },
    {
      "name": "name",
      "type": "string",
      "description": "User display name.",
      "required": false,
      "example": "John Doe"
    },
    {
      "name": "email",
      "type": "string",
      "description": "User email.",
      "required": false,
      "example": "john@example.com"
    },
    {
      "name": "phone_number",
      "type": "string",
      "description": "Phone number.",
      "required": false,
      "example": "+15551234567"
    },
    {
      "name": "avatar",
      "type": "string",
      "description": "Avatar URL.",
      "required": false,
      "example": "https://example.com/avatar.jpg"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.knock.app/v1/users/user_123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "John Doe",
      "email": "john@example.com"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_123",
      "name": "John Doe",
      "email": "john@example.com"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}