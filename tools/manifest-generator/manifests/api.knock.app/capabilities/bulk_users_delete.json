{
  "name": "bulk_users_delete",
  "description": "Permanently delete up to 1,000 users at a time.",
  "endpoint": "/v1/users/bulk/delete",
  "method": "POST",
  "resource_group": "bulk",
  "parameters": [
    {
      "name": "user_ids",
      "type": "array",
      "description": "Array of user IDs to delete.",
      "required": true,
      "example": [
        "user_1",
        "user_2"
      ],
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.knock.app/v1/users/bulk/delete",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "user_ids": [
        "user_1",
        "user_2"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
