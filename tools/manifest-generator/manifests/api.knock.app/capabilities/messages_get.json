{
  "name": "messages_get",
  "description": "Retrieve a specific message by its ID.",
  "endpoint": "/v1/messages/{message_id}",
  "method": "GET",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "message_id",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "msg_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/messages/msg_abc123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "msg_abc123",
      "channel_id": "email-channel",
      "recipient": {
        "id": "user_123"
      },
      "status": "delivered",
      "inserted_at": "2024-01-15T10:00:00Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
