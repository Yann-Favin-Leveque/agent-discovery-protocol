{
  "name": "messages_mark_seen",
  "description": "Mark a message as seen.",
  "endpoint": "/v1/messages/{message_id}/seen",
  "method": "PUT",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "message_id",
      "type": "string",
      "description": "Message ID.",
      "required": true,
      "example": "msg_abc123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.knock.app/v1/messages/msg_abc123/seen",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "msg_abc123",
      "seen_at": "2024-01-15T10:05:00Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
