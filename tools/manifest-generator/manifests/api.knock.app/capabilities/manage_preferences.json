{
  "name": "manage_preferences",
  "description": "Get and update notification preferences for users. Preferences control which workflows and channels a user receives notifications on, letting users opt in or out of specific notification types.",
  "endpoint": "/v1/users/{user_id}/preferences/{id}",
  "method": "PUT",
  "parameters": [
    { "name": "user_id", "type": "string", "description": "The user ID.", "required": true, "example": "user_123" },
    { "name": "id", "type": "string", "description": "Preference set ID (use 'default' for the default set).", "required": true, "example": "default" },
    { "name": "workflows", "type": "object", "description": "Per-workflow preference overrides.", "required": false, "example": { "new-comment": { "channel_types": { "email": true, "push": false } } } }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.knock.app/v1/users/user_123/preferences/default",
    "headers": { "Authorization": "Bearer {api_key}", "Content-Type": "application/json" },
    "body": { "workflows": { "new-comment": { "channel_types": { "email": true, "push": false } } } }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "default", "workflows": { "new-comment": { "channel_types": { "email": true, "push": false } } } }
  }
}
