{
  "name": "users_get",
  "description": "Retrieve a specific user by their ID.",
  "endpoint": "/v1/users/{user_id}",
  "method": "GET",
  "resource_group": "users",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "User ID.",
      "required": true,
      "example": "user_123",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/users/user_123",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_123",
      "name": "John Doe",
      "email": "john@example.com",
      "created_at": "2024-01-15T10:00:00Z"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
