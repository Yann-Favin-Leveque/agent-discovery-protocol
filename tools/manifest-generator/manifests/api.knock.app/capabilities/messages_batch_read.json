{
  "name": "messages_batch_read",
  "description": "Batch mark multiple messages as read.",
  "endpoint": "/v1/messages/batch/read",
  "method": "POST",
  "resource_group": "messages",
  "parameters": [
    {
      "name": "message_ids",
      "type": "array",
      "description": "Array of message IDs.",
      "required": true,
      "example": [
        "msg_1",
        "msg_2",
        "msg_3"
      ]
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.knock.app/v1/messages/batch/read",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "message_ids": [
        "msg_1",
        "msg_2"
      ]
    }
  },
  "response_example": {
    "status": 200,
    "body": {}
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}