{
  "name": "objects_set",
  "description": "Create or update an object in a collection (e.g., a project or team).",
  "endpoint": "/v1/objects/{collection}/{id}",
  "method": "PUT",
  "resource_group": "objects",
  "parameters": [
    {
      "name": "collection",
      "type": "string",
      "description": "Collection name.",
      "required": true,
      "example": "projects",
      "in": "path"
    },
    {
      "name": "id",
      "type": "string",
      "description": "Object ID.",
      "required": true,
      "example": "project_123",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "description": "Object name.",
      "required": false,
      "example": "My Project",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.knock.app/v1/objects/projects/project_123",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "name": "My Project"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "project_123",
      "collection": "projects",
      "name": "My Project"
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}
