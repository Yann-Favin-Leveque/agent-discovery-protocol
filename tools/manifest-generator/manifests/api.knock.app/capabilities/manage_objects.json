{
  "name": "manage_objects",
  "description": "Create and manage objects that can receive notifications, like teams, projects, or other entities. Objects act as non-user recipients and can have their own subscriptions and preferences.",
  "endpoint": "/v1/objects/{collection}/{id}",
  "method": "PUT",
  "parameters": [
    { "name": "collection", "type": "string", "description": "The object collection name.", "required": true, "example": "projects" },
    { "name": "id", "type": "string", "description": "The object identifier.", "required": true, "example": "project_abc" },
    { "name": "name", "type": "string", "description": "Object display name.", "required": false, "example": "My Project" },
    { "name": "properties", "type": "object", "description": "Custom properties for the object.", "required": false, "example": { "team": "engineering" } }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.knock.app/v1/objects/projects/project_abc",
    "headers": { "Authorization": "Bearer {api_key}", "Content-Type": "application/json" },
    "body": { "name": "My Project", "team": "engineering" }
  },
  "response_example": {
    "status": 200,
    "body": { "id": "project_abc", "collection": "projects", "properties": { "name": "My Project", "team": "engineering" }, "created_at": "2024-01-20T10:00:00Z" }
  }
}
