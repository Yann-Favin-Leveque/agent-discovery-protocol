{
  "name": "users_subscriptions_list",
  "description": "List all topic subscriptions for a user.",
  "endpoint": "/v1/users/{user_id}/subscriptions",
  "method": "GET",
  "resource_group": "subscriptions",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "description": "User ID.",
      "required": true,
      "example": "user_123"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.knock.app/v1/users/user_123/subscriptions",
    "headers": {
      "Authorization": "Bearer {api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "items": [
        {
          "object": {
            "id": "project_123",
            "collection": "projects"
          },
          "inserted_at": "2024-01-15T10:00:00Z"
        }
      ]
    }
  },
  "auth_scopes": [],
  "rate_limits": {
    "requests_per_minute": 500
  }
}