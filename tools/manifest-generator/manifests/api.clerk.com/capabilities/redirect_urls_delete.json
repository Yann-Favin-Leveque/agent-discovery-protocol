{
  "name": "redirect_urls_delete",
  "resource_group": "redirect_urls",
  "description": "Delete a redirect URL.",
  "endpoint": "/v1/redirect_urls/{redirect_url_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "redirect_url_id",
      "type": "string",
      "required": true,
      "description": "Redirect URL ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.clerk.com/v1/redirect_urls/ru_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ru_abc",
      "deleted": true
    }
  }
}