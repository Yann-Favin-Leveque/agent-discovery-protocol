{
  "name": "email_addresses_delete",
  "resource_group": "email_addresses",
  "description": "Delete an email address from a user.",
  "endpoint": "/v1/email_addresses/{email_address_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "email_address_id",
      "type": "string",
      "required": true,
      "description": "Email address ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.clerk.com/v1/email_addresses/idn_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "idn_abc",
      "deleted": true
    }
  }
}