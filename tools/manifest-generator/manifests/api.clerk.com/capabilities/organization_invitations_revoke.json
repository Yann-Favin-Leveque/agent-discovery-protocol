{
  "name": "organization_invitations_revoke",
  "resource_group": "organization_invitations",
  "description": "Revoke a pending organization invitation.",
  "endpoint": "/v1/organizations/{organization_id}/invitations/{invitation_id}/revoke",
  "method": "POST",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    },
    {
      "name": "invitation_id",
      "type": "string",
      "required": true,
      "description": "Invitation ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/organizations/org_abc123/invitations/orginv_abc/revoke",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "orginv_abc",
      "status": "revoked"
    }
  }
}