{
  "name": "organization_memberships_delete",
  "resource_group": "organization_memberships",
  "description": "Remove a user from an organization.",
  "endpoint": "/v1/organizations/{organization_id}/memberships/{user_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    },
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "User ID to remove.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.clerk.com/v1/organizations/org_abc123/memberships/user_2abc123",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "orgmem_xyz",
      "object": "organization_membership",
      "deleted": true
    }
  }
}