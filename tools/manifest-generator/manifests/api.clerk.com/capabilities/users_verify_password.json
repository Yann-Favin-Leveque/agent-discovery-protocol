{
  "name": "users_verify_password",
  "resource_group": "users",
  "description": "Verify a user password without creating a session.",
  "endpoint": "/v1/users/{user_id}/verify_password",
  "method": "POST",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "The Clerk user ID.",
      "in": "path"
    },
    {
      "name": "password",
      "type": "string",
      "required": true,
      "description": "The password to verify."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/users/user_2abc123/verify_password",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "password": "securePass123!"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "verified": true
    }
  }
}