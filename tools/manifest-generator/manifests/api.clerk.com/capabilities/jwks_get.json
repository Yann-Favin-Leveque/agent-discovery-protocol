{
  "name": "jwks_get",
  "resource_group": "jwks",
  "description": "Retrieve the JSON Web Key Set (JWKS) for verifying JWTs issued by your Clerk instance.",
  "endpoint": "/v1/jwks",
  "method": "GET",
  "parameters": [],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/jwks",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "keys": [
        {
          "kty": "RSA",
          "kid": "ins_abc123",
          "use": "sig",
          "alg": "RS256",
          "n": "...",
          "e": "AQAB"
        }
      ]
    }
  }
}