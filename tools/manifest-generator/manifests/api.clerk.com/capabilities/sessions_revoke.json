{
  "name": "sessions_revoke",
  "resource_group": "sessions",
  "description": "Revoke a session, signing the user out.",
  "endpoint": "/v1/sessions/{session_id}/revoke",
  "method": "POST",
  "parameters": [
    {
      "name": "session_id",
      "type": "string",
      "required": true,
      "description": "The session ID to revoke.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/sessions/sess_abc123/revoke",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sess_abc123",
      "object": "session",
      "status": "revoked"
    }
  }
}