{
  "name": "allowlist_delete",
  "resource_group": "allowlist",
  "description": "Remove an identifier from the allowlist.",
  "endpoint": "/v1/allowlist_identifiers/{identifier_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "identifier_id",
      "type": "string",
      "required": true,
      "description": "Allowlist identifier ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.clerk.com/v1/allowlist_identifiers/alid_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "alid_abc",
      "object": "allowlist_identifier",
      "deleted": true
    }
  }
}