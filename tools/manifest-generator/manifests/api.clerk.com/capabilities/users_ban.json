{
  "name": "users_ban",
  "resource_group": "users",
  "description": "Ban a user, preventing them from signing in.",
  "endpoint": "/v1/users/{user_id}/ban",
  "method": "POST",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "The Clerk user ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/users/user_2abc123/ban",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_2abc123",
      "banned": true
    }
  }
}