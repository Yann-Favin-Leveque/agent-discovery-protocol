{
  "name": "organization_invitations_list",
  "resource_group": "organization_invitations",
  "description": "List pending invitations for an organization.",
  "endpoint": "/v1/organizations/{organization_id}/invitations",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Offset."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter by status: pending, accepted, revoked."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/organizations/org_abc123/invitations?status=pending",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "orginv_abc",
        "object": "organization_invitation",
        "email_address": "bob@example.com",
        "role": "org:member",
        "status": "pending"
      }
    ]
  }
}