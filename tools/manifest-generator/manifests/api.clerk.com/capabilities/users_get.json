{
  "name": "users_get",
  "resource_group": "users",
  "description": "Retrieve a single user by their Clerk user ID with full profile data.",
  "endpoint": "/v1/users/{user_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "The Clerk user ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/users/user_2abc123",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_2abc123",
      "object": "user",
      "first_name": "Alice",
      "email_addresses": [
        {
          "id": "idn_2xyz",
          "email_address": "alice@example.com",
          "verification": {
            "status": "verified"
          }
        }
      ],
      "created_at": 1702656000000
    }
  }
}