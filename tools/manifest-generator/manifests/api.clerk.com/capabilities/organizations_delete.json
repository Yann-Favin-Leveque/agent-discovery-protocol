{
  "name": "organizations_delete",
  "resource_group": "organizations",
  "description": "Delete an organization and all associated data.",
  "endpoint": "/v1/organizations/{organization_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.clerk.com/v1/organizations/org_abc123",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "org_abc123",
      "object": "organization",
      "deleted": true
    }
  }
}