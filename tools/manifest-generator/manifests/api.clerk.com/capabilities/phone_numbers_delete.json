{
  "name": "phone_numbers_delete",
  "resource_group": "phone_numbers",
  "description": "Delete a phone number from a user.",
  "endpoint": "/v1/phone_numbers/{phone_number_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "phone_number_id",
      "type": "string",
      "required": true,
      "description": "Phone number ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.clerk.com/v1/phone_numbers/phn_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "phn_abc",
      "deleted": true
    }
  }
}