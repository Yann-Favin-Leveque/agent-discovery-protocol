{
  "name": "users_delete",
  "resource_group": "users",
  "description": "Permanently delete a user and all associated data.",
  "endpoint": "/v1/users/{user_id}",
  "method": "DELETE",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "The Clerk user ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "DELETE",
    "url": "https://api.clerk.com/v1/users/user_2abc123",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_2abc123",
      "object": "user",
      "deleted": true
    }
  }
}