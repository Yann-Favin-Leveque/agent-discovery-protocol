{
  "name": "redirect_urls_create",
  "resource_group": "redirect_urls",
  "description": "Add a new redirect URL to your instance's allowlist.",
  "endpoint": "/v1/redirect_urls",
  "method": "POST",
  "parameters": [
    {
      "name": "url",
      "type": "string",
      "required": true,
      "description": "The redirect URL to add.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/redirect_urls",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "url": "https://app.example.com/callback"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "ru_abc",
      "object": "redirect_url",
      "url": "https://app.example.com/callback"
    }
  }
}
