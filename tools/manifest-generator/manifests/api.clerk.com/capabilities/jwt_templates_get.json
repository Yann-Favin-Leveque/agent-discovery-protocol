{
  "name": "jwt_templates_get",
  "resource_group": "jwt_templates",
  "description": "Retrieve a single JWT template by its ID.",
  "endpoint": "/v1/jwt_templates/{template_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "template_id",
      "type": "string",
      "required": true,
      "description": "JWT template ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/jwt_templates/jtmpl_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "jtmpl_abc",
      "name": "supabase",
      "claims": {},
      "lifetime": 3600
    }
  }
}