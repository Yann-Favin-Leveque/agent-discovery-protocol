{
  "name": "email_addresses_update",
  "resource_group": "email_addresses",
  "description": "Update an existing email address.",
  "endpoint": "/v1/email_addresses/{email_address_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "email_address_id",
      "type": "string",
      "required": true,
      "description": "Email address ID.",
      "in": "path"
    },
    {
      "name": "verified",
      "type": "boolean",
      "required": false,
      "description": "Set verification status."
    },
    {
      "name": "primary",
      "type": "boolean",
      "required": false,
      "description": "Set as primary."
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.clerk.com/v1/email_addresses/idn_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "primary": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "idn_abc",
      "email_address": "alice@work.com"
    }
  }
}