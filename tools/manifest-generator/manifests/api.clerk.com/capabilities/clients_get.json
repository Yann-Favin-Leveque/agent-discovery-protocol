{
  "name": "clients_get",
  "resource_group": "clients",
  "description": "Retrieve a single client by its ID.",
  "endpoint": "/v1/clients/{client_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "client_id",
      "type": "string",
      "required": true,
      "description": "The client ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/clients/client_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "client_abc",
      "object": "client",
      "session_ids": [
        "sess_xyz"
      ]
    }
  }
}