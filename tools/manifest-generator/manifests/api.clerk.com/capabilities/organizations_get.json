{
  "name": "organizations_get",
  "resource_group": "organizations",
  "description": "Retrieve a single organization by its ID or slug.",
  "endpoint": "/v1/organizations/{organization_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "organization_id",
      "type": "string",
      "required": true,
      "description": "Organization ID or slug.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/organizations/org_abc123",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "org_abc123",
      "object": "organization",
      "name": "Acme Corp",
      "slug": "acme-corp",
      "members_count": 15
    }
  }
}