{
  "name": "phone_numbers_update",
  "resource_group": "phone_numbers",
  "description": "Update an existing phone number.",
  "endpoint": "/v1/phone_numbers/{phone_number_id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "phone_number_id",
      "type": "string",
      "required": true,
      "description": "Phone number ID.",
      "in": "path"
    },
    {
      "name": "verified",
      "type": "boolean",
      "required": false,
      "description": "Set verification status.",
      "in": "body"
    },
    {
      "name": "primary",
      "type": "boolean",
      "required": false,
      "description": "Set as primary.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.clerk.com/v1/phone_numbers/phn_abc",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "primary": true
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "phn_abc",
      "phone_number": "+15551234567"
    }
  }
}
