{
  "name": "clients_list",
  "resource_group": "clients",
  "description": "List all clients (browser/device sessions) with pagination.",
  "endpoint": "/v1/clients",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "offset",
      "type": "integer",
      "required": false,
      "description": "Offset."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/clients",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": [
      {
        "id": "client_abc",
        "object": "client",
        "session_ids": [
          "sess_xyz"
        ],
        "created_at": 1702656000000
      }
    ]
  }
}