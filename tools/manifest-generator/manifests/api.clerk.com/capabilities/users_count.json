{
  "name": "users_count",
  "resource_group": "users",
  "description": "Count total users matching optional filter criteria.",
  "endpoint": "/v1/users/count",
  "method": "GET",
  "parameters": [
    {
      "name": "email_address",
      "type": "array",
      "required": false,
      "description": "Filter by email(s).",
      "in": "query"
    },
    {
      "name": "phone_number",
      "type": "array",
      "required": false,
      "description": "Filter by phone(s).",
      "in": "query"
    },
    {
      "name": "query",
      "type": "string",
      "required": false,
      "description": "Free-text search.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/users/count",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "object": "total_count",
      "total_count": 1523
    }
  }
}
