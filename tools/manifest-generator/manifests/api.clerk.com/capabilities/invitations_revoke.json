{
  "name": "invitations_revoke",
  "resource_group": "invitations",
  "description": "Revoke a pending application-level invitation.",
  "endpoint": "/v1/invitations/{invitation_id}/revoke",
  "method": "POST",
  "parameters": [
    {
      "name": "invitation_id",
      "type": "string",
      "required": true,
      "description": "Invitation ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/invitations/inv_abc/revoke",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "inv_abc",
      "status": "revoked"
    }
  }
}