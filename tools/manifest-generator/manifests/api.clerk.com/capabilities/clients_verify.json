{
  "name": "clients_verify",
  "resource_group": "clients",
  "description": "Verify a client token and return the client object.",
  "endpoint": "/v1/clients/verify",
  "method": "POST",
  "parameters": [
    {
      "name": "token",
      "type": "string",
      "required": true,
      "description": "The client token to verify.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/clients/verify",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx",
      "Content-Type": "application/json"
    },
    "body": {
      "token": "eyJhbGciOiJSUzI1NiJ9..."
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "client_abc",
      "object": "client",
      "session_ids": [
        "sess_xyz"
      ]
    }
  }
}
