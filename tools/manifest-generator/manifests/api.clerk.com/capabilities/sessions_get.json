{
  "name": "sessions_get",
  "resource_group": "sessions",
  "description": "Retrieve a single session by its ID.",
  "endpoint": "/v1/sessions/{session_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "session_id",
      "type": "string",
      "required": true,
      "description": "The session ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.clerk.com/v1/sessions/sess_abc123",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "sess_abc123",
      "object": "session",
      "user_id": "user_2abc123",
      "status": "active",
      "last_active_at": 1702742000000
    }
  }
}