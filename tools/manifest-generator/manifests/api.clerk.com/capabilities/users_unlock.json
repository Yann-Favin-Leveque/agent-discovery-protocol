{
  "name": "users_unlock",
  "resource_group": "users",
  "description": "Unlock a previously locked user account.",
  "endpoint": "/v1/users/{user_id}/unlock",
  "method": "POST",
  "parameters": [
    {
      "name": "user_id",
      "type": "string",
      "required": true,
      "description": "The Clerk user ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.clerk.com/v1/users/user_2abc123/unlock",
    "headers": {
      "Authorization": "Bearer sk_live_xxxxx"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "id": "user_2abc123",
      "locked": false
    }
  }
}