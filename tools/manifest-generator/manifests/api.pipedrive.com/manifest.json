{
  "spec_version": "1.0",
  "name": "Pipedrive",
  "description": "Pipedrive is a sales CRM and pipeline management tool. Manage deals, contacts, organizations, activities, leads, notes, and sales pipelines with a REST API.",
  "base_url": "https://api.pipedrive.com/v1",
  "auth": {
    "type": "api_key",
    "header": "x-api-token",
    "setup_url": "https://app.pipedrive.com/settings/api"
  },
  "capabilities": [
