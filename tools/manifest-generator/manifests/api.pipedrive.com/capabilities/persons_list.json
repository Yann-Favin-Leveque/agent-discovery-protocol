{
  "name": "persons_list",
  "description": "List all persons (contacts).",
  "resource_group": "persons",
  "endpoint": "/persons",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "required": false,
      "description": "Offset."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort field."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/persons?limit=10"
  },
  "response_example": {
    "success": true,
    "data": [
      {
        "id": 1,
        "name": "Jane Doe",
        "email": [
          {
            "value": "jane@example.com",
            "primary": true
          }
        ],
        "phone": [
          {
            "value": "+15551234567",
            "primary": true
          }
        ],
        "org_id": 1
      }
    ]
  }
}