{
  "name": "persons_search",
  "description": "Search persons.",
  "resource_group": "persons",
  "endpoint": "/persons/search",
  "method": "GET",
  "parameters": [
    {
      "name": "term",
      "type": "string",
      "required": true,
      "description": "Search term."
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Fields to search: name, email, phone, notes."
    },
    {
      "name": "start",
      "type": "integer",
      "required": false,
      "description": "Offset."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/persons/search?term=jane"
  },
  "response_example": {
    "success": true,
    "data": {
      "items": [
        {
          "item": {
            "id": 1,
            "name": "Jane Doe",
            "emails": [
              "jane@example.com"
            ]
          }
        }
      ]
    }
  }
}