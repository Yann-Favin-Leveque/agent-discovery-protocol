{
  "name": "persons_update",
  "description": "Update a person.",
  "resource_group": "persons",
  "endpoint": "/persons/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Person ID.",
      "in": "path"
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Name.",
      "in": "body"
    },
    {
      "name": "email",
      "type": "array",
      "required": false,
      "description": "Emails.",
      "in": "body"
    },
    {
      "name": "phone",
      "type": "array",
      "required": false,
      "description": "Phones.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.pipedrive.com/v1/persons/1",
    "body": {
      "name": "Jane Smith"
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 1,
      "name": "Jane Smith"
    }
  }
}
