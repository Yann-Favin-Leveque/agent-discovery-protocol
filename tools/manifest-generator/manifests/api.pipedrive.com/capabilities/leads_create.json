{
  "name": "leads_create",
  "description": "Create a lead.",
  "resource_group": "leads",
  "endpoint": "/leads",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Lead title.",
      "in": "body"
    },
    {
      "name": "person_id",
      "type": "integer",
      "required": false,
      "description": "Person ID.",
      "in": "body"
    },
    {
      "name": "organization_id",
      "type": "integer",
      "required": false,
      "description": "Org ID.",
      "in": "body"
    },
    {
      "name": "value",
      "type": "object",
      "required": false,
      "description": "Value: {amount, currency}.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pipedrive.com/v1/leads",
    "body": {
      "title": "New lead",
      "person_id": 1,
      "value": {
        "amount": 5000,
        "currency": "USD"
      }
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": "lead-new",
      "title": "New lead"
    }
  }
}
