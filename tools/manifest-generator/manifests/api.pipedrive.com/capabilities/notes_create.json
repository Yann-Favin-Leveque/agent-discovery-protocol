{
  "name": "notes_create",
  "description": "Create a note.",
  "resource_group": "notes",
  "endpoint": "/notes",
  "method": "POST",
  "parameters": [
    {
      "name": "content",
      "type": "string",
      "required": true,
      "description": "Note content (HTML supported).",
      "in": "body"
    },
    {
      "name": "deal_id",
      "type": "integer",
      "required": false,
      "description": "Deal ID.",
      "in": "body"
    },
    {
      "name": "person_id",
      "type": "integer",
      "required": false,
      "description": "Person ID.",
      "in": "body"
    },
    {
      "name": "org_id",
      "type": "integer",
      "required": false,
      "description": "Org ID.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pipedrive.com/v1/notes",
    "body": {
      "content": "<p>Meeting notes</p>",
      "deal_id": 1
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 2,
      "content": "<p>Meeting notes</p>",
      "deal_id": 1
    }
  }
}
