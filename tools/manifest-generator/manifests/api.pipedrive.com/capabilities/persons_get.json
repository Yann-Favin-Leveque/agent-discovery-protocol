{
  "name": "persons_get",
  "description": "Get a person by ID.",
  "resource_group": "persons",
  "endpoint": "/persons/{id}",
  "method": "GET",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Person ID.",
      "in": "path"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/persons/1"
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 1,
      "name": "Jane Doe",
      "email": [
        {
          "value": "jane@example.com",
          "primary": true
        }
      ],
      "org_name": "Acme"
    }
  }
}
