{
  "name": "activities_list",
  "description": "List activities.",
  "resource_group": "activities",
  "endpoint": "/activities",
  "method": "GET",
  "parameters": [
    {
      "name": "start",
      "type": "integer",
      "required": false,
      "description": "Offset.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "type",
      "type": "string",
      "required": false,
      "description": "Activity type.",
      "in": "query"
    },
    {
      "name": "done",
      "type": "integer",
      "required": false,
      "description": "0=undone, 1=done.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/activities?done=0&limit=10"
  },
  "response_example": {
    "success": true,
    "data": [
      {
        "id": 1,
        "type": "call",
        "subject": "Follow up call",
        "due_date": "2026-01-21",
        "done": false,
        "person_id": 1,
        "deal_id": 1
      }
    ]
  }
}
