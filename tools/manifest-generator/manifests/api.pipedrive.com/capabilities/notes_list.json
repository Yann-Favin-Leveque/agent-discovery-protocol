      "required": false,
      "description": "Offset."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/notes?deal_id=1&limit=10"
