    {
      "name": "deal_id",
      "type": "integer",
      "required": false,
      "description": "Filter by deal."
    },
    {
      "name": "person_id",
      "type": "integer",
      "required": false,
      "description": "Filter by person."
    },
    {
      "name": "org_id",
      "type": "integer",
      "required": false,
      "description": "Filter by org."
    },
    {
      "name": "start",
