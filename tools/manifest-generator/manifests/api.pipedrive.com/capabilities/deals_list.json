{
  "name": "deals_list",
  "description": "List all deals with filtering and pagination.",
  "resource_group": "deals",
  "endpoint": "/deals",
  "method": "GET",
  "parameters": [
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "Filter: open, won, lost, deleted, all_not_deleted."
    },
    {
      "name": "sort",
      "type": "string",
      "required": false,
      "description": "Sort field and order."
    },
    {
      "name": "start",
      "type": "integer",
      "required": false,
      "description": "Pagination offset."
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results (default 100)."
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/deals?status=open&limit=10"
  },
  "response_example": {
    "success": true,
    "data": [
      {
        "id": 1,
        "title": "Big Deal",
        "value": 50000,
        "currency": "USD",
        "status": "open",
        "stage_id": 1,
        "person_id": 1,
        "org_id": 1
      }
    ]
  }
}