{
  "name": "activities_update",
  "description": "Update an activity.",
  "resource_group": "activities",
  "endpoint": "/activities/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Activity ID."
    },
    {
      "name": "subject",
      "type": "string",
      "required": false,
      "description": "Subject."
    },
    {
      "name": "done",
      "type": "integer",
      "required": false,
      "description": "0 or 1."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.pipedrive.com/v1/activities/1",
    "body": {
      "done": 1
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 1,
      "done": true
    }
  }
}