{
  "name": "deals_update",
  "description": "Update a deal.",
  "resource_group": "deals",
  "endpoint": "/deals/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Deal ID.",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "New title.",
      "in": "body"
    },
    {
      "name": "value",
      "type": "number",
      "required": false,
      "description": "New value.",
      "in": "body"
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "New status.",
      "in": "body"
    },
    {
      "name": "stage_id",
      "type": "integer",
      "required": false,
      "description": "New stage.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.pipedrive.com/v1/deals/1",
    "body": {
      "status": "won",
      "value": 55000
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 1,
      "title": "Big Deal",
      "value": 55000,
      "status": "won"
    }
  }
}
