{
  "name": "organizations_create",
  "description": "Create an organization.",
  "resource_group": "organizations",
  "endpoint": "/organizations",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Organization name.",
      "in": "body"
    },
    {
      "name": "address",
      "type": "string",
      "required": false,
      "description": "Address.",
      "in": "body"
    },
    {
      "name": "visible_to",
      "type": "integer",
      "required": false,
      "description": "Visibility: 1=owner, 3=whole company.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pipedrive.com/v1/organizations",
    "body": {
      "name": "New Corp",
      "address": "456 Oak Ave"
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 2,
      "name": "New Corp"
    }
  }
}
