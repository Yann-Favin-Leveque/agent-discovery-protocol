{
  "name": "activities_create",
  "description": "Create an activity.",
  "resource_group": "activities",
  "endpoint": "/activities",
  "method": "POST",
  "parameters": [
    {
      "name": "subject",
      "type": "string",
      "required": true,
      "description": "Subject."
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "Activity type: call, meeting, task, deadline, email, lunch."
    },
    {
      "name": "due_date",
      "type": "string",
      "required": false,
      "description": "Due date YYYY-MM-DD."
    },
    {
      "name": "due_time",
      "type": "string",
      "required": false,
      "description": "Due time HH:MM."
    },
    {
      "name": "deal_id",
      "type": "integer",
      "required": false,
      "description": "Deal ID."
    },
    {
      "name": "person_id",
      "type": "integer",
      "required": false,
      "description": "Person ID."
    },
    {
      "name": "note",
      "type": "string",
      "required": false,
      "description": "Note/description."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pipedrive.com/v1/activities",
    "body": {
      "subject": "Follow up call",
      "type": "call",
      "due_date": "2026-01-21",
      "person_id": 1
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 2,
      "subject": "Follow up call",
      "type": "call"
    }
  }
}