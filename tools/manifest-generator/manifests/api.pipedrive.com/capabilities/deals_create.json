{
  "name": "deals_create",
  "description": "Create a new deal.",
  "resource_group": "deals",
  "endpoint": "/deals",
  "method": "POST",
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "required": true,
      "description": "Deal title."
    },
    {
      "name": "value",
      "type": "number",
      "required": false,
      "description": "Deal value."
    },
    {
      "name": "currency",
      "type": "string",
      "required": false,
      "description": "Currency code."
    },
    {
      "name": "person_id",
      "type": "integer",
      "required": false,
      "description": "Contact ID."
    },
    {
      "name": "org_id",
      "type": "integer",
      "required": false,
      "description": "Organization ID."
    },
    {
      "name": "stage_id",
      "type": "integer",
      "required": false,
      "description": "Pipeline stage ID."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "open, won, lost, deleted."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pipedrive.com/v1/deals",
    "body": {
      "title": "New Deal",
      "value": 25000,
      "currency": "USD",
      "stage_id": 1
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 2,
      "title": "New Deal",
      "value": 25000,
      "status": "open"
    }
  }
}