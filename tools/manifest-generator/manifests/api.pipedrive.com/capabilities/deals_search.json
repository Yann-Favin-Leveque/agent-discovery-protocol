{
  "name": "deals_search",
  "description": "Search deals.",
  "resource_group": "deals",
  "endpoint": "/deals/search",
  "method": "GET",
  "parameters": [
    {
      "name": "term",
      "type": "string",
      "required": true,
      "description": "Search term.",
      "in": "query"
    },
    {
      "name": "fields",
      "type": "string",
      "required": false,
      "description": "Fields to search: title, notes, custom_fields.",
      "in": "query"
    },
    {
      "name": "start",
      "type": "integer",
      "required": false,
      "description": "Offset.",
      "in": "query"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/deals/search?term=enterprise"
  },
  "response_example": {
    "success": true,
    "data": {
      "items": [
        {
          "item": {
            "id": 1,
            "title": "Enterprise Deal",
            "value": 50000
          }
        }
      ]
    }
  }
}
