{
  "name": "persons_create",
  "description": "Create a person.",
  "resource_group": "persons",
  "endpoint": "/persons",
  "method": "POST",
  "parameters": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Full name."
    },
    {
      "name": "email",
      "type": "array",
      "required": false,
      "description": "Email addresses."
    },
    {
      "name": "phone",
      "type": "array",
      "required": false,
      "description": "Phone numbers."
    },
    {
      "name": "org_id",
      "type": "integer",
      "required": false,
      "description": "Organization ID."
    }
  ],
  "request_example": {
    "method": "POST",
    "url": "https://api.pipedrive.com/v1/persons",
    "body": {
      "name": "John Smith",
      "email": [
        {
          "value": "john@example.com",
          "primary": true
        }
      ],
      "phone": [
        {
          "value": "+15559876543",
          "primary": true
        }
      ]
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 2,
      "name": "John Smith"
    }
  }
}