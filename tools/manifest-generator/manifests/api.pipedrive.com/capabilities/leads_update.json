{
  "name": "leads_update",
  "description": "Update a lead.",
  "resource_group": "leads",
  "endpoint": "/leads/{id}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "required": true,
      "description": "Lead ID.",
      "in": "path"
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "Title.",
      "in": "body"
    },
    {
      "name": "value",
      "type": "object",
      "required": false,
      "description": "Value.",
      "in": "body"
    }
  ],
  "request_example": {
    "method": "PATCH",
    "url": "https://api.pipedrive.com/v1/leads/lead-abc",
    "body": {
      "title": "Updated lead"
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": "lead-abc",
      "title": "Updated lead"
    }
  }
}
