{
  "name": "organizations_update",
  "description": "Update an organization.",
  "resource_group": "organizations",
  "endpoint": "/organizations/{id}",
  "method": "PUT",
  "parameters": [
    {
      "name": "id",
      "type": "integer",
      "required": true,
      "description": "Org ID."
    },
    {
      "name": "name",
      "type": "string",
      "required": false,
      "description": "Name."
    },
    {
      "name": "address",
      "type": "string",
      "required": false,
      "description": "Address."
    }
  ],
  "request_example": {
    "method": "PUT",
    "url": "https://api.pipedrive.com/v1/organizations/1",
    "body": {
      "name": "Acme Inc"
    }
  },
  "response_example": {
    "success": true,
    "data": {
      "id": 1,
      "name": "Acme Inc"
    }
  }
}