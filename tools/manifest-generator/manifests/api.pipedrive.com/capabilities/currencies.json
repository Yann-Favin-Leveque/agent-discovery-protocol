{
  "name": "currencies",
  "description": "Manage currencies — get all supported currencies. Supports standard CRUD operations through the REST API.",
  "endpoint": "/currencies",
  "method": "GET",
  "parameters": [
    {
      "name": "term",
      "type": "string",
      "description": "Optional search term that is searched for from currency's name and/or code",
      "required": false,
      "example": "example_value"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/currencies",
    "headers": {
      "Content-Type": "application/json",
      "x-api-token": "{api_key}"
    }
  },
  "response_example": {
    "status": 200,
    "body": {
      "success": true,
      "data": [
        {
          "id": 1,
          "code": "EUR",
          "name": "Euro",
          "decimal_points": 2,
          "symbol": "€",
          "active_flag": true,
          "is_custom_flag": false
        },
        {
          "id": 2,
          "code": "USD",
          "name": "US Dollar",
          "decimal_points": 2,
          "symbol": "$",
          "active_flag": true,
          "is_custom_flag": false
        }
      ]
    }
  }
}
