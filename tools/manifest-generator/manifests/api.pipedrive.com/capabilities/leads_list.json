{
  "name": "leads_list",
  "description": "List all leads.",
  "resource_group": "leads",
  "endpoint": "/leads",
  "method": "GET",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Max results.",
      "in": "query"
    },
    {
      "name": "start",
      "type": "integer",
      "required": false,
      "description": "Offset.",
      "in": "query"
    },
    {
      "name": "archived_status",
      "type": "string",
      "required": false,
      "description": "not_archived or archived.",
      "in": "query"
    }
  ],
  "request_example": {
    "method": "GET",
    "url": "https://api.pipedrive.com/v1/leads?limit=10"
  },
  "response_example": {
    "success": true,
    "data": [
      {
        "id": "lead-abc",
        "title": "Potential client",
        "person_id": 1,
        "organization_id": 1,
        "value": {
          "amount": 10000,
          "currency": "USD"
        }
      }
    ]
  }
}
