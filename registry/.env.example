# ─── Database (PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/agent_registry
# Set to "false" to disable SSL (local dev)
# DATABASE_SSL=false

# ─── Admin ───────────────────────────────────────────────────────
ADMIN_SECRET=

# ─── Stripe (Payments) ──────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get this from https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Auth / JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── OAuth (Registry web login) ──────────────────────────────────
# Only web app credentials are needed here. Desktop app credentials
# are embedded in the gateway CLI and don't need to be configured.

# Google: https://console.cloud.google.com/apis/credentials
OAUTH_GOOGLE_WEB_APP_ID=
OAUTH_GOOGLE_WEB_APP_SECRET=

# GitHub: https://github.com/settings/applications/new
OAUTH_GITHUB_WEB_APP_ID=
OAUTH_GITHUB_WEB_APP_SECRET=

# Microsoft: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
OAUTH_MICROSOFT_WEB_APP_ID=
OAUTH_MICROSOFT_WEB_APP_SECRET=

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
