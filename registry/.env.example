# ─── Database (Turso) ────────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Admin ───────────────────────────────────────────────────────
ADMIN_SECRET=

# ─── Stripe (Payments) ──────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get this from https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Auth / JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── OAuth: Google ───────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Web app credentials (for registry browser-based login)
OAUTH_GOOGLE_WEB_APP_ID=
OAUTH_GOOGLE_WEB_APP_SECRET=
# Desktop app credentials (for gateway CLI login)
OAUTH_GOOGLE_DESKTOP_APP_ID=
OAUTH_GOOGLE_DESKTOP_APP_SECRET=

# ─── OAuth: GitHub ───────────────────────────────────────────────
# https://github.com/settings/applications/new
OAUTH_GITHUB_WEB_APP_ID=
OAUTH_GITHUB_WEB_APP_SECRET=
OAUTH_GITHUB_DESKTOP_APP_ID=
OAUTH_GITHUB_DESKTOP_APP_SECRET=

# ─── OAuth: Microsoft ───────────────────────────────────────────
# https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
OAUTH_MICROSOFT_WEB_APP_ID=
OAUTH_MICROSOFT_WEB_APP_SECRET=
OAUTH_MICROSOFT_DESKTOP_APP_ID=
OAUTH_MICROSOFT_DESKTOP_APP_SECRET=

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
